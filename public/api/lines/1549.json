[{"Id": 1011835, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "It is narrated from the Messenger of Allah (s) that one who keeps awake this night, his heart will not die on the day that all hearts are dead due to fear.", "GujaratiDescription": null, "RUrduDescription": "Allah ke Rasool (s) se waarid hai, keh jo shakhs Shabe Eid mein jaagta rahega, to uska dil murda nahi hoga us din jab saare dil murda ho jaayege khouf ki bina par.", "UrduDescription": "یکم شوال کی رات با برکت راتوں میں سے ہے، اس کی فضیلت، بیداری،عبادت اور ثواب سے متعلق بہت سی احادیث وارد ہوئیں ہیں،حضرت رسولؐ سے مروی ہے : یہ رات مرتبے میں شب ِقدر سے کچھ کم نہیں اور اس میں چند اعمال ہیں۔ شب بیداری یعنی نماز، دعا، استغفار اور خدا سے طلب ِحاجات کرتے ہوئے مسجد میں جاگ کر رات گزارے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "Ara