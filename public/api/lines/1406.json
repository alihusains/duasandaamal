[{"Id": 1000110, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Recite the following dua after Namaz-e-Asr as is quoted from Misbah al-Mutahajjid…", "GujaratiDescription": null, "RUrduDescription": "Namaz-e-Asr ke baad is dua ko padhe jo Misbah al-Mutahajjid se naql ki gayi hai…", "UrduDescription": "نماز عصر کے بعد اس دعا کو پڑھے جو منقول ازمصباح متہجد سے نقل کی گئی ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000111, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I ask forgiveness of Allah, (who is) \"There is no god save He,\" ever living, eternal, beneficent, merciful, owner of might and majesty. I beseech Him to accept my repentance, the repentance of a servant-insignificant, submissive, destitute, needy, worried and helpless seeking protection, who, on his own, neither can win nor lose, nor die, nor live, nor come to life again.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai us Allah se talab'e maghferat karta hu, jiske alaawa koi Mabood nahi hai. Woh zinda wa hamesha rehne waala aur rehman wa rahim hai, jalaalat wa buzurgi waala hai. Mai us se sawaal karta hu, keh Woh meri dua ko qabool kare ek zaleel, past, faqeer, pareshan haal, be-chaara, zameen-ghir aur panah chaha-ne waale ghulam ki tauba (qabool kar le) jo na to apne nafa wa nuqsaan hi ka maalik hai aur na hi maut wa zindagi wa hashr wa nashr uske ikhteyaar mein hai.", "Urdu": "اس خدا سے بخشش چاہتاہوں جس کے سوا کوئی معبود نہیں وہ زندہ وپائندہ ہے بڑے رحم والا مہربان صاحب ِجلال و اکرام ہے، میں اس سے سوال کرتا ہوں کہ وہ اپنے عاجز ذلیل و حقیر محتاج مصیبت زدہ مسکین بے چارہ طالب ِپناہ بندے کی توبہ قبول فرمائے جو اپنے نفع ونقصان کا مالک نہیں ہے نہ ہی اپنی موت وحیات اور آخرت پر اختیار رکھتا ہے۔", "RArabic": "AS-TAGH FERULLAA-HAL LAZEE ILAAHA ILLAA HO-WAL HAIYYUL QAIYYOOMO AR-RAHMAA-NUR RAHEEMO ZUL-JALAALE WAL-IKRAAME WA AS-ALO-HU AN YATOOBA A’LAIYYA TAWBA-TAN AB’DIN ZALEE-LIN KHAAZE-IN FAQEE-RIN BA-AA'e SIN MISKEE-NIN MUSTA-KEENIN MUSTA-JEE-RIN LAA YAMLE-KO LE-NAFSE-HI NAF-AW’ WA LAA ZARRAN WA LAA MAWTAN WA LAA HAYAA-TAN WA LAA NOSHOO-RAN.", "ArabicText1": "اَسْتَغْفِرُ اللہَ الَّذِیْ لَآ اِلٰہَ اِلَّا ھُوَالْحَیُّ الْقَیُّوْمُ اَلرَّحْمٰنُ الرَّحِیْمُ ذُوالْجَلَالِ وَالْاِکْرَامِ وَاَسْئَلُہٗ اَنْ یَّتُوْبَ عَلَیَّ تَوْبَۃَ عَبْدٍ ذَلِیْلٍ خَاضِعٍ فَقِیْرٍ بَآئِسٍ مِّسْکِیْنٍ مُّسْتَکِیْنٍ مُّسْتَجِیْرٍلَّا یَمْلِکُ لِنَفْسِہٖ نَفْعًا وَّلَا ضَرًّا وَّلَا مَوْتًا وَّلَا حَیٰاۃً وَّلَا نُشُوْرًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010129, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I run away (unto you) from an insatiable self, unremorseful heart, useless intelligence, unaccorded prayer, and unfulfilled request. O Allah I beseech You for ease in the wake of distress, joy after sorrow, comfort coming after hardship. O Allah whatever facility have in from You. There is no god save You. I ask for your forgiveness and I turn repentant unto you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Mai Teri panah chahta hu, aise nafs se jo (duniya) se syer na ho, aur aise dil se jo Tera farma-bardaar na ho, aur us ilm se jo faiyde-mand na ho aur aisi namaz se (panah chahta hu) jo (qabooliyat ke liye) Teri bargah mein buland na hoti ho aur aisi dua se jo (Teri bargah mein) sooni nahi jaati. Khudaaya! Mai Tujh se tangh-dasti ke baad aasaani chahta hu aur ranjh ke baad raahat ka taalib hu aur sakhti ke baad neymat ki faraawaani chahta hu. Khuda! (hamein iqraar hai keh) jo bhi neymat hamare paas hai, woh Teri hi bargah se mili hai. siwaaye Tere koi Mabood nahi hai. Tujh hi se maghferat chahta hu aur Teri hi bargah mein palat kar aane waala hu.", "Urdu": "اے معبود! میں سیر نہ ہونے والے نفس،خوف نہ رکھنے والے دل، نفع نہ دینے والے علم،قبول نہ ہونے والی نماز اور نہ سنی جانے والی دعا سے تیری پناہ چاہتا ہوں۔ اے معبود! میں تجھ سے سوال کرتا ہوں کہ مجھے مشکل کے بعد آسانی، تنگی کے بعد وسعت اور شدّت کے بعد سہولت دے۔ خدایا! ہمارے پاس جو تیری نعمت ہے وہ تیری طرف سے ہے تیرے سوا کوئی معبود نہیں۔ میں تجھ سے بخشش چاہتا اور تیرے حضور توبہ کرتا ہوں۔", "RArabic": "ALLAAHUMMA INNE A-O’OZO BEKA MIN NAFSIL LAA TASHBA-O’, WA MIN QALBIL LAA YAKH-SHA-O’, WA MIN I’LMIL LAA YANFA-O’, WA MIN SALAATIL LAA TURFA-O’, WA MIN DO-A’A-IL LAA YUSMA-O’, ALLAAHUMMA INNEE AS-ALOKAL YUSRA BA’DAL U’SRE, WAL FARAJA BA’-DAL KARBE WAR-RAKHAAA-A BA’-DASH SHIDDATE ALLAAHUMMA MAA BENAA MIN NE’MATIN FA-MINKA, LAA ELAAHA ILLAA ANTA, ASTAGHFEROKA WA A-TOOBO ELAYKA.", "ArabicText1": "اَللّٰھُمَّ اِنِّیْ اَعُوْذُ بِکَ مِنْ نَّفْسٍ لَّا تَشْبَعُ وَمِنْ قَلْبٍ لَّا یَخْشَعُ وَمِنْ عِلْمٍ لَّا یَنْفَعُ وَمِنْ صَلَاۃٍ لَّا تُرْفَعُ وَمِنْ دُعَآئٍ لَّا یُسْمَعُ۔ اَللّٰھُمَّ اِنِّیْ اَسْئَلُکَ الْیُسْرَ بَعْدَ الْعُسْرِ وَالْفَرَجَ بَعْدَ الْکَرْبِ وَالرَّخَآئَ بَعْدَ الشِّدَّۃِ۔ اَللّٰھُمَّ مَا بِنَا مِنْ نِّعْمَۃٍ فَمِنْکَ لَآ اِلٰہَ اِلَّا اَنْتَ اَسْتَغْفِرُکَ وَاَتُوْبُ اِلَیْکَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "A