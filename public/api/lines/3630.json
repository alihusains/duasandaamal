[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016116, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Mai Tera banda hu, pas Tu mujh ko apni taraf aane waalo’n mein sab se ghaate (nuqsaan) mein na qaraar de aur dur-daraaz aur nasheb o faraaz (pershaaniyo’n aur aasaaniyo’n) se Tere paas aane par mujh par rahem farma, ay tamaam maqamaat'e ibaadat ke Parwardigaar! Meri gardan (neck) Jahannam se azaad kar de aur apna halaal rizq mere upar kushaadah kar de aur Jinn o Ins ke faasiqo’n ko mujh se dur kar de. Khudaaya! Mujhe nuqsaan uthaane, dhoka khaane aur tabaayi o barbaadi ki har tadbeer se bacha.", "Urdu": "خدایا! میں تیرا بندہ ہوں، پس تو مجھ کو اپنی طرف آنے اولوں میں سب سے گھاٹے میں نہ قرار دے اور دور دراز اور نشیب و فراز سے تیرے پاس آنے پر مجھ پر رحم فرما، اے تمام مقاماتِ عبادت کے پروردگار! میری گردن جہنم سے آزاد کردے اور اپنا حلال رزق میرے اوپر کشادہ کردےاور جن و انس کے فاسقوں کو مجھ سے دور کردے۔ خدایا! مجھے نقصان اٹھانے، دھوکا کھانے اور تباہی و بربادی کی ہرتدبیر سے بچا۔", "RArabic": "ALLAAHUMMA INNEE A’BDOKA FALAA TAJ-A’LNEE MIN AKH-YABE WAFDEKA WAR-HAM MASEEREE ELAYKA MENAL FAJJIL A’MEEQE ALLAAHUMMA RABBAL MASHAA-E’RE KULLEHAA FUKKA RAQA-BATEE MENAN NAARE WA AWSEA’ A’LAYYA MIN RIZQE-KAL HALAALE WAD RAA A’NNEE SHARRA FA-SAQA-TIL JINNE WAL INSE ALLAAHUMMA LAA TAMKUR BEE WA LAA TAKHDA’NEE WA LAA TAS-TADRIJ-NEE.", "ArabicText1": "اَللّٰہُمَّ اِنِّیْ عَبْدُكَ فَلَا تَجْعَلْنِیْ مِنْ اَخْیَبِ وَفْدِكَ وَارْحَمْ مَسِیْرِیْ اِلَیْكَ مِنَ الْفَجِّ الْعَمِیْقِ۔ اَللّٰہُمَّ رَبَّ الْمَشَاعِرِ كُلِّہَا فُكَّ رَقَبَتِیْ مِنَ النَّارِ وَاَوْسِعْ عَلَیَّ مِنْ رِزْقِكَ الْحَلَالِ وَادْرَاْ عَنِّیْ شَرَّ فَسَقَۃِ الْجِنِّ وَالْاِنْسِ۔ اَللّٰہُمَّ لَا تَمْكُرْ بِیْ وَلَا تَخْدَعْنِیْ وَلَا تَسْتَدْرِجْنِیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016117, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Mai Tujh se Teri quwwat, Tere jood o karam aur Tere fazl o ehsaan ke waaste se sawaal karta hu, ay sab se behtar soonne waale, ay sabse behtar dekhne waale, ay sab se jaldi hisaab karne waale, ay sab se ziyadah rahem karne waale! Keh Tu Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma aur mujhe duniya o aakherat ki nekiya’n ataa farma.", "Urdu": "خدایا! میں تجھ سے تیری قوت، تیرے جود و کرم اور تیرے فضل و احسان کے واسطہ سے سوال کرتا ہوں، اے سب سے بہتر سننے والے، اے سب سے بہتر دیکھنے والے، اے سب سے جلدی حساب کرنے والے، اے سب سے زیادہ رحم کرنے والے! کہ تو محمدؐ و آلِ محمدؑ پر رحمت نازل فرما اور مجھے دُنیا و آخرت کی نیکیاں عطا فرما۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA BE-HAWLE-KA WA JOODE-KA WA KARAME-KA WA FAZLE-KA WA MANNE-KA YAA ASMA-A’S SAAME-E’ENA WA YAA AB-SARAN NAAZE-REENA WA YAA ASRA-A’L HAASE-BEENA WA YAA ARHAMAR RAAHE-MEENA AN TOSALLE-YA A’LAA MOHAMMADIW WA AALE MOHAMMADIN. (WA AN TARZO-QANEE KHAYRAD DUNYAA WAL AAKHERA-TE.)", "ArabicText1": "اَللّٰہُمَّ اِنِّیْ اَسئَلُكَ بِحَوْلِكَ وَجُوْدِكَ وَكَرَمِكَ وَفَضْلِكَ وَمَنِّكَ یَا اَسْمَعَ السَّامِعِیْنَ وَیَا اَبْصَرَ النَّاظِرِیْنَ وَیَا اَسْرَعَ الْحَاسِبِیْنَ وَیَا اَرْحَمَ الرَّاحِمِیْنَ اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔ (وَاَنْ تَرْزُقَنِیْ خَیْرَ الدُّنْیَا وَالْآخِرَۃِ)۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016118, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Then seek one’s desire and recite the following after raising hands towards the sky…", "GujaratiDescription": null, "RUrduDescription": "Iske baad apni haajat talab kare, phir aasmaan ki jaanib haatho’n ko buland kar ke yeh dua padhe…", "UrduDescription": "اس کے بعد اپنی حاجتیں طلب کرے، پھر آسمان کی جانب ہاتھ بلند کر کے یہ دُعا پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "