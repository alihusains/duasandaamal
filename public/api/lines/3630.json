ے ہو مجھے فائدہ نہیں پہونچائےگا۔ خدایا! میں تجھ سے اپنی گردن جہنم سے آزاد کرنے کا سوال کرتا ہوں۔ اے میرے اللہ! میں تیرا بندہ ہوں اور میری پیشانی کی ملکیت تیرے قبضہ میں ہے اور میری موت تیرے علم میں ہے۔", "RArabic": "ALLAAHUMMA HAAJATEE ELAYKA AN A-A’TAYTANEEHAA LAM YAZURRANEE MAA MANA’TANEE WA AN MANA’TANEEHAA LAM YANFA’NEE MAA A-A’TAYTANEE AS-ALOKA KHALAASA RAQABATEE MENAN NAARE ALLAAHUMMA INNEE A’BDOKA WA MILKO NAASEYATEE BEYADEKA WA AJALEE BE-I’LMEKA.", "ArabicText1": "اَللّٰہُمَّ حَاجَتِیْ اِلَیْكَ اِنْ اَعْطَیْتَنِیْہَا لَمْ یَضُرَّنِیْ مَا مَنَعْتَنِیْ وَاِنْ مَنَعْتَنِیْہَا لَمْ یَنْفَعْنِیْ مَا اَعْطَیْتَنِیْ اَسْئَلُكَ خَلَاصَ رَقَبَتِیْ مِنَ النَّارِ۔ اَللّٰہُمَّ اِنِّیْ عَبْدُكَ وَمِلْكُ نَاصِیَتِیْ بِیَدِكَ وَاَجَلِیْ بِعِلْمِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016120, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Mera sawaal hai keh mujhe us cheez ki taufiq de jis se Tu raazi ho aur mere manaasik ibaadat ko qabool farma jise Tu ne apne khaleel Hazrat Ibrahim (a.s) ko dikhaaya aur jis par apne nabi Hazrat Muhammad (s.a.w.a) ki rehbari kar di (un par aur unki Aale paak par durood o salaam ho). Khudaaya! Mujhe un logo’n mein qaraar de jinke amal se Tu raazi huwa aur jin ki umr ko Tu ne badhaya aur jinhe marne ke baad paak o paakeeza hayaat ke saath zindah kiya.", "Urdu": "میرا سوال ہے کہ مجھے اس چیز کی توفیق دے جس سے تو راضی ہو اور میرے مناسک ِ عبادت کو قبول فرما، جسے تونے خلیل حضرت ابراہیمؑ کو دکھایا اور جس پر اپنے نبی حضرت محمدؐ کی رہبری کی (ان پر اور ان کی آل پاک پر درود و سلام ہو)۔ خدایا! مجھے ان لوگوں میں قرار دے جن کے عمل سے تو راضی ہوا اور جن کی عمر کو تو نے بڑھایا اور جنہیں مرنے کہ بعد پاک و پاکیزہ حیات کے ساتھ زندہ کیا۔", "RArabic": "AS-ALOKA AN TOWAFFEQANEE LEMAA YURZEEKA A’NNEE WA AN TOSALLEMA MINNEE MANAASEKIL LATEE ARAYTAHAA KHALEELAKA IBRAAHEEMA A’LAYHIS SALAAMO WA DALALTA A’LAYHA NABIYYAKA MOHAMMADAN SALLAL LAAHO A’LAYHE WA AALEHI ALLAAHUMMAJ A’LNEE MIMMAN RAZEETA A’MALAHU WA ATALTA U’MRAHU WA AHBAYTAHU BA’DAL MAWTE HAYAATAN TAYYEBATAN.", "ArabicText1": "اَسْئَلُكَ اَنْ تُوَفِّقَنِیْ لِمَا یُرْضِیْكَ عَنِّیْ وَاَنْ تُسَلِّمَ مِنِّیْ مَنَاسِكِی الَّتِیْ اَرَیْتَہَا خَلِیْلَكَ اِبْرَاہِیْمَ عَلَیْہِ السَّلَامُ وَدَلَلْتَ عَلَیْہَا نَبِیَّكَ مُحَمَّدًا صَلَّی اللهُ عَلَیْہِ وَآلِہٖ۔ اَللّٰہُمَّ اجْعَلْنِیْ مِمَّنْ رَضِیْتَ عَمَلَہٗ وَاَطَلْتَ عُمْرَہٗ وَاَحْیَیْتَہٗ بَعْدَ الْمَوْتِ حَیَاۃً طَیِّبَۃً۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": nul