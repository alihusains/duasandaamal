[{"Id": 1019966, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Imam Reza (a) said: Whoever recites this name on Friday after Namaz 998 times with pure intention giving full attention towards Almighty Allah and its meaning, writes its nicely, makes amulet and ties on his shoulder, he will remain safe from Satanic goadings, evils, futile, useless thoughts and injuries of wild and dreadful beasts…", "GujaratiDescription": null, "RUrduDescription": "Imam Reza (a) farmate hai: jo koi baad az Namaz’e Juma, khuloos’e dil se aur iske maaine (meaning) par tawajjoh karte huwe 998 martaba is zikr ko padhe aur isey ek kaaghaz par likh kar taaweez bana kar apne baazu (shoulder) par baandh de, to woh shaitaan ke hamlo’n se, shar, galat khayalaat aur wehshi jaanwar wa jantu ke khatro’n se mehfooz rahega…", "UrduDescription": "امام رضاؑفرماتے ہیں: جو کوئی بعد از نماز جمعہ، خلوصِ دل سے اور اس کے معنی پر توجہ سے ۹۹۸ مرتبہ اس ذکر کو پڑھے اور اسے ایک کاغذ پر لکھ کر تعویذ بنا کر اپنے بازو پر باندھ دے، تو وہ شیطان کے حملوں سے، شر، غلط خیالات اور وحشی جانور و جنتؤں کے خطروں سے محفوظ رہے گا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSig