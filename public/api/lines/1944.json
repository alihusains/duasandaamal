[{"Id": 1010075, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Imam Sadiq (a) is reported to have said: These words should be said before circumcising any boy. However, if one neglects saying these words, he must say them before the boy attains maturity. If he does, the boy will be saved from the heat of iron (ie. being killed by a sword or the like)…", "GujaratiDescription": null, "RUrduDescription": "Imam Sadiq (a) se waarid huwa keh farmate hai: Is dua ko padhe jab kisi ladke ki khatna ki jaaye, agar koi isey nazar andaaz kare to chahiye ke ladka baaligh hone se pehle isey padhle. Aisa karne se us ladke ki maut talwaar ya us jaisi cheez se hone se mehfooz rahega…", "UrduDescription": "امام جعفر صادق ؑ سے منقول ہے : بچے کے ختنے کے وقت یہ دعا پڑھی جائے اگر اس وقت نہ پڑھی جاسکے تو لڑکے کے بالغ ہونے تک جب بھی موقع ملے دعا پڑھی جائے کہ اس طرح گرم لوہے سے مرنے اور اس سے پہنچنے والی دوسری تکلیفوں سے محفوظ رہتا ہے وہ دعا یہ ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": 