: null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013616, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O righteous servant! Peace be upon you, O sincere friend! Peace be upon you, O Aba Ishaq al-Mukhtar! Peace be upon you, O avenger, warrior battling against evil disbelievers!", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "AS SALAAMO A’LAIKA AYYO-HAL A’BDUS SAALE-HO. AS SALAAMO A’LAIKA AYYO-HAL WALE-YOON NAASE-HO. SALAAMO A’LAIKA YAA ABAA IS-HAA-QAL MUKHTAARE. SALAAMO A’LAIKA AYYO-HAL AAKHE-ZO BIS-SAARIL MO-HAARE-BO LIL-KAFARA-TIL FUJ-JAARE.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ اَیُّهَا الْعَبْدُ الصَّالِحُ۔ اَلسَّلَامُ عَلَیْكَ اَیُّهَا الْوَلِیُ النَّاصِحُ۔ اَلسَّلَامُ عَلَیْكَ یَا اَبَا اِسْحَاقَ الْمُخْتَارِ۔ اَلسَّلَامُ عَلَیْكَ اَیُّهَا الْآخِذُ بِالثَّارِ الْمُحَارِبُ لِلْكَفَرَۃِ الْفُجَّارِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013617, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O the one sincere in his obedience to Allah and in his love for Imam Zayn ul Abedin (a.s). Peace be upon you, O the one with whom were pleased the chosen Prophet, the distributor of heaven and hell and the remover of grief and sorrow. None from the community reach such a position.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": "AS SALAAMO A’LAIKA AYYO-HAL MUKHLE-SO LIL-LAAHE FEE TAA-A’TE-HI WA LIZZEE-NIL AA’BE-DEENA FEE MA-HABBATE-HE. AS SALAAMO A’LAIKA YAA MAN RAZEYA A’N-HUN NABIYYUL MUKHTAA-RO WA QASEE-MUL JANNATE WAN-NARE WA KAA-SHE-FUL KARABE WAL GHUMMA-TE QAA-E-MAN LAM YA-SIL ILAI-HE AHADO MINAL UMMATE.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ اَیُّهَا الْمُخْلِصُ لِلهِ فِیْ طَاعَتِهٖ وَلِزِّیْنِ الْعَابِدِیْنَ فِیْ مَحَبَّتِهِ۔ اَلسَّلَامُ عَلَیْكَ یَا مَنْ رَضِیَ عَنْهُ النَّبِیُّ الْمُخْتَارُ وَقَسِیْمُ الْجَنَّۃِ وَالنَّرِ وَكَاشِفُ الْكَرْبِ وَالْغُمَّۃِ قَائِمًا لَمْ یَصِلْ اِلَیْهِ اَحَدُ مِنَ الْاُمَّۃِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": nul