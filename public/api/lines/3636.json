mage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015691, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 9, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": "Imam Jafar Sadiq (a) Hajj ke baateni adaab ke baare mein farmaate hai…", "UrduDescription": "امام جعفر صادقؑ حج کے باطنی آداب کے بارے میں فرماتے ہیں۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015692, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Hajj ka qasad karo to pehle apne dil se “ghairullah” (gair’e Khuda) ko nikaal baahar karo, apne aur Khuda ke darmiyaan se har qism ke hijaabaat aur digar haael cheezo’n ko hata do aur apne tamaam umoor ko Usi (Allah) ke hawaale kar do. Apne tamaam harkaat o saknaat mein Usi par tawakkul karo, qaza o qadr’e Ilaahi aur Uske faislo’n ke saamne sar tasleem kham karo, dunyawi lazzato’n aur logo’n se ta’luk khatm kar lo…phir taubah ke khaalis paani se gunaho’n ki aaloodgi bartaraf karo, sidq o safa aur khuzoo’a o khushoo’a ka libaas zebe-tan kar ke har us cheez ke liye “Ehraam” baandh lo jo tumhe yaad’e Khuda aur zikr’e Ilaahi se ghaafil karti ho aur ita’at’e Parwardigaar se mane (rukaawat) hoti ho. Khuda ki mazboot rassi se mutamassik (attachment) ikhteyaar karte huwe paak aur khaalis tareen andaaz mein “Labbaik” kahe kar daawat’e Ilaahi ka jawaab do. Aur jaise yahan musalmaano ke saath Khaana’e Kaaba ke gird tawaaf kar rahe ho sameem'e qalb (mazboot iraade) se dil ko duniya mein farishto’n ke saath arsh'e Ilaahi ka tawaaf karo.", "Urdu": "حج کا قصد کرو تو پہلے اپنے دل سے غیراللہ کو نکال باہر کرو، اپنے اور خدا کے درمیان سے ہر قسم کے حجابات اور دیگر حائل چیزوں کو ہٹا دو اور اپنے تمام امور کو اسی کے حوالے کردو۔ اپنے تمام حرکات و سکنات میں اسی پر توکل کرو، قضاء و قدر الٰہی اور اس کے فیصلوں کے سامنے سر تسلیم خم کرو، دنیاوی لذتوں اور لوگوں سے تعلق ختم کر لو۔۔۔ پھر توبہ کے خلص پانی سے گناہوں کی آلودگی برطرف کرو، صدق و صفا اور خضوع و خشوع کا لباس زیب تن کر کے ہر اس چیز کے لئے احرام باندھ لو جو تمہیں یاد خدا اور ذکر الٰہی سے غافل کرتی ہو اور اطاعت پروردگار سے مانع ہوتی ہو۔ خدا کی مضبوط رسّی سے تمسک اختیار کر تے ہوئے پاک اور خالص ترین انداز میں لبّیک کہہ کر دعوت الٰہی کا جواب دو اور جیسے یہاں مسلماموں کے ساتھ خانۂ کعبہ کے گرد طواف کر رہے ہو صمیم قلب سے دل کی دنیا میں فرشتوں کے ساتھ عرش الٰہی کا طواف کرو۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اِذَا اَرَدْتَّ الْحَجَّ فَجَرِّدْ قَلْبَكَ لِلهِ مِنْ قَبْلِ عَزْمِكَ مِنْ كُلِّ شَاغِلٍ وَّحِجَابِ كُلِّ حَاجِبٍ وَّفَوِّضْ اُمُوْرَكَ كُلَّهَا اِلٰی خَالِقِكَ وَتَوَكَّلْ عَلَیْهِ فِیْ جَمِیْعِ مَا یَظْهَرُ مِنْ حَرَكَاتِكَ وَسَكَنَاتِكَ وَسَلِّمْ لِقَضَاۗئِهٖ وَحُكْمِهٖ وَقَدَرِهٖ وَ وَدِّعِ الدُّنْیَا وَالرَّاحَۃَ وَالْخَلْقَ۔۔۔ ثُمَّ اغْ تَسِلْ بِمَاۗئِ التَّوْبَۃِ الْخَالِصَۃِ مِنَ الذُّنُوْبِ وَاَلْبِسْ كِسْوَۃَ الصِّدْقِ وَالصَّفَاۗئِ وَالْخُضُوْعِ وَالْخُشُوْعِ وَاَحْرِمْ عَنْ كُلِّ شَیْءٍ یَّمْنَعُكَ مِنْ ذِكْرِ اللهِ عَزَّ وَجَلَّ وَیَحْجُبُكَ عَنْ طَاعَتَهٖ وَلَبِّ بِمَعْنٰی اِجَابَۃٍ صَافِیَۃٍ خَالِصَۃٍ زَاكِیَۃٍ لِّلهِ عَزَّ وَ جَلَّ فِیْ دَعْوَتِكَ مُتَمَسِّكًاۢ بِالْعُرْوَۃِ الْوُثْقٰی وَطُفْبِقَلْبِكَ مَعَ الْمَلَٓائِكَۃِ حَوْلَ الْعَرْشِ كَتَوَافِكَ مَعَ الْمُسْلِمِیْنَ بِنَفْسِكَ حَوْلَ الْبَیْتِ۔۔۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBl