[{"Id": 1015683, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "INSHA-ALLAH COMING SOON", "GujaratiDescription": null, "RUrduDescription": "Hazrat Paighambar (s) ke baad Madina mein Hajj ke wajoob ka hukm naazil huwa aur har saahebe isteta’at musalmaan se poori zindagi mein sirf ek baar Hajj waajib “Hujjatul Islaam” ka mutaalba kiya gaya hai (nazariya kisi dusre unwaan se waajib hona ek alag masla hai).", "UrduDescription": "ہجرتِ پیغمبرؐ کے بعد مدینہ میں حج کے وجوب کا حکم نازل ہوا اور ہر صاحب استطاعت مسلمان سے پوری زندگی میں صرف ایک بار حج واجب حجّتہ الاسلام کا مطالبہ کیا گیا ہے (نظریہ کسی دوسرے عنوان سے واجب ہونا ایک الگ مسلہ ہے)۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": nu