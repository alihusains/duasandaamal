[{"Id": 1000598, "EnglishTitle": "His Supplication in Fleeing to God", "GujaratiTitle": null, "RUrduTitle": "Allah (s) se talab wa fariyaad ke liye yeh dua padhte…", "UrduTitle": "الله سے تضرع و زاری کے سلسلے میں دعاء۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000599, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, I showed sincerity by cutting myself off from everything but Thee. I approached Thee with my whole self. I averted my face from everyone who needs Thy support. I ceased to ask from any who cannot do without Thy bounty. I saw that the needy who seeks from the needy is foolish in his opinion, and misguided in his intellect.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay mere Ma’bood! Mai ne to sirf Tujh hi par bharosa kiya hai aur Teri hi taraf motawajjeh hu, jo Teri bakhshish ka mohtaaj hai, usse mooh phere huwe hu, apne sawaal ko aise shakhs se bacha liya hai jo Tere fazl se be-parwah nahi, kyu’n keh mai samajhta hu keh mohtaaj ka ek mohtaaj se maangna na-samjhi aur aql ki gumrahi hai.", "Urdu": "اے اللہ! میں پورے خلوص کے ساتھ دوسروں سے منہ موڑ کر تجھ سے لو لگاۓ ہوں اور ہمہ تن تیری طرف متوجّہ ہوں، اور اس شخص سے جو خود تیری عطا و بخشش کا محتاج ہے، منہ پھیر لیا ہے۔ اور اس شخص سے جو تیرے فضل و احسان سے بے نیاز نہیں ہے، سوال کا رخ موڑ لیا ہے۔ اور اس نتیجہ پر پہنچا ہوں کہ محتاج کا محتاج سے مانگنا سراسر سمجھ بوجھ کی سبکی اور عقل کی گمراہی ہے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اِنِّيْ اَخْلَصْتُ بِانْقِطَاعِيْ اِلَيْكَ وَاَقْبَلْتُ بِكُلِّيْ عَلَيْكَ وَصَرَفْتُ وَجْهِيْ عَمَّنْ يَحْتَاجُ اِلٰى رِفْدِكَ وَقَلَبْتُ مَسْئَلَتِي عَمَّنْ لَمْ يَسْتَغْنِ عَنْ فَضْلِكَ وَرَاَيْتُ اَنَّ طَلَبَ الْمُحْتَاجِ اِلَى الْمُحْتَاجِ سَفَهٌ مِنْ رَايِهٖ وَضَلَّةٌ مِنْ عَقْلِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001798, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "How many people have I seen, my God, who sought exaltation through other than Thee and were abased, who wanted wealth from someone else and became poor, who tried to rise high and fell down low! Observing the likes of them corrects a prudent man; his taking heed gives him success; his choosing the best guides him to the path of right. So Thou, my Master, art the object of my asking to the exclusion of all those who are asked and the patron of my need to the exclusion of all those from whom requests are made.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur mai ne kitne hi aadmiyo’n ko dekha hai keh jinho ne Tere dar ko chhod kar dusro’n se izzat chaahi woh zaleel huwa, jinho ne Tere alaawa dusro’n se tawangari haasil karne ka iraada kiya to aur ziyadah mohtaaj ho gaye, jinho ne gair ke sahaare se sarfaraazi wa bulandi ki tamanna ki woh pasti mein chale gaye, pas aise shakhso’n ki misaal dekh kar aql-mand thik ho gaya jisko uski ibrat haasil karne mein (sachchaayi ki) taufiq mili, aur uske duroost intekhaab ne usko thik raaste ki rehbari ki.", "Urdu": "کیونکہ اے میرے اللہ! میں نے بہت سے ایسے لوگوں کو دیکھا ہے جو تجھے چھوڑ کر دوسروں کے ذریعہ عزّت کے طلب گار ہوۓ تو وہ ذلیل و رسوا ہوۓ۔ اور دوسروں سے نعمت و دولت کے خواہشمند ہوۓ تو فقیر و نادار ہی رہے۔ اور بلندی کا قصد کیا تو پستی پر جا گرے۔ لہذا ان جیسوں کو دیکھنے سے ایک دور اندیش کی دوراندیشی بالکل برمحل ہے کہ عبرت کے نتیجہ میں اسے توفیق حاصل ہوئی اور اس کے (صحیح) انتخاب نے اسے سیدھا راستہ دکھایا۔ جب حقیقت یہی ہے۔", "RArabic": null, "ArabicText1": "فَكَمْ قَدْ رَاَيْتُ يَا اِلٰهِيْ مِنْ اُنَاسٍ طَلَبُوا الْعِزَّ بِغَيْرِكَ فَذَلُّوا وَرَامُوا الثَّرْوَةَ مِنْ سِوَاكَ فَافْتَقَرُوْا وَحَاوَلُوا الْاِرْتِفَاعَ فَاتَّضَعُوا فَصَحَّ بِمُعَايَنَةِ اَمْثَالِهِمْ حَازِمٌ وَفَّقَهُ اعْتِبَارُهٗ وَارْشَدَهٗ اِلٰى طَرِيقِ صَوَابِهٖ باِخْتِيَارُهٖ فَاَنْتَ يَا مَوْلَايَ دُوْنَ كُلِّ مَسْئُوْلٍ مَوْضِعُ مَسْئَلَتِيْ وَدُوْنَ كُلِّ مَطْلُوْبٍ اِلَيْهِ وَلِيُّ حَاجَتِيْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001799, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Thou art singled out for my call before all who are called; none is associated with Thee in my hope, none comes along with Thee in my supplication, nor does any join with Thee within it, for to Thee is my appeal. To Thee, my God, belongs the Unity of number, the property of eternal power, the excellence of force and strength, the degree of sublimity and elevation.", "Gujarati": null, "RGujarati": null, "RUrdu": "Pas ay mere Maalik jin logo’n se maanga jaata hai un se mujhe koi matlab nahi, mere maangne ki jagah Tu hai aur tamaam un logo’n se qat'e nazar kar ke jinse duniya waale kuchh talab karte hai, meri haajat ka sirf Tu hi maalik hai. Mai ne jab pukara, Tujhe pukara, Tuhi meri dua se makhsoos hai (jinko duniya pukaarti hai un se mujhe koi garaz nahi) meri ummeed mein Tera koi sharik nahi, meri dua mein Tere saath koi aur mila huwa (sharik) nahi, na mera Tujh ko pukaarna kisi gair ko Tere saath jama kar sakta hai.", "Urdu": "تو پھر اے میرے مالک! تو ہی میرے سوال کا مرجع ہے نہ وہ جس سے سوال کیا جاتا ہے۔ اور تو ہی میرا حاجت روا ہے نہ وہ جن سے حاجت طلب کی جاتی ہے اور ان تمام لوگوں سے پہلے جنہیں پکارا جاتا ہے تو میری دعا کے لۓ مخصوص ہے اور میری امید میں تیرا کوئی شریک نہیں ہے۔ اور میری دعا میں تیرا کوئی ہم پایہ نہیں ہے۔ اور میری آواز تیرے ساتھ کسی اور کو شریک نہیں کرتی۔", "RArabic": null, "ArabicText1": "اَنْتَ الْمَخْصُوْصُ قَبْلَ كُلِّ مَدْعُوٍّ بِدَعْوَتِيْ لَا يُشْرَكُكَ اَحَدٌ فِيْ رَجَاۗئِيْ وَلَا يَتَّفِقُ اَحَدٌ مَعَكَ فِيْ دُعَاۗئِيْ وَلَا يَنْظِمُهٗ وَاِيَّاكَ نِدَاۗئِيْ لَكَ يَا اِلٰهِيْ وَحْدَانِيَّةُ الْعَدَدِ وَمَلَكَةُ الْقُدْرَةِ الصَّمَدِ وَفَضِيْلَةُ الْحَوْلِ وَالْقُوَّةِ وَدَرَجَةُ الْعُلُوِّ وَالرِّفْعَةِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001800, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Everyone other than Thee is the object of compassion in his lifetime, overcome in his affair, overwhelmed in his situation, diverse in states, constantly changing in attributes. So Thou art high exalted above likenesses and opposites, proudly magnified beyond similitudes and rivals! Glory be to Thee! There is no God but Thou.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Ma’bood! Haqeeqat mein Tu hi wahdahu la-sharik hai (jiska koi saathi nahin) aur Tu hi be-neyaaz hai (jisko kisi ki zaroorat nahin), tamaam taaqat o quwwat ki baagh-dod bhi Tere ikhteyaar mein hai, Tu azeem rif’at o bulandi ka maalik hai, Tere alaawa jo bhi hai woh apni zindagi mein har tarah se Tere rahem o karam ke mohtaaj hai, apne tamaam kaamo mein har tarah se be-bas o laachaar hai, uske haalaat badalte rehte hai, uski sifate’n badalti rehti hai. Haa’n Tu hai aur sirf Tu, Tu buland hai, Tere jaisa koi nahin hai, Tu buzurg hai, Tera misl koi nahin, Tu har ehtebaar se bartar wa paak o paakeeza hai. Siwaaye Tere koi Ma’bood nahi.", "Urdu": "اے اللہ! عدد کی یکتائی، قدرت کاملہ کی کارفرمائی اور کمال قوّت و توانائی اور مقام رفعت و بلندی تیرے لۓ ہے اور تیرے علاوہ جو ہے وہ اپنی زندگی میں تیرے رحم و کرم کا محتاج، اپنے امور میں درماندہ اور اپنے مقام پر بے بس و لاچار ہے۔ جس کے حالات گوناگوں ہیں اور ایک حالت سے دوسری حالت کی طرف پلٹتا رہتا ہے۔ تو مانند و ہمسر سے بلند تر اور مثل و نظیر سے بالا تر ہے تو پاک ہے تیرے علاوہ کوئی معبود نہیں ہے۔", "RArabic": null, "ArabicText1": "وَمَنْ سِوَاكَ مَرْحُوْمٌ فِيْ عُمُرِهٖ مَغْلُوْبٌ عَلٰى اَمْرِهٖ مَقْهُوْرٌ عَلٰى شَانِهٖ مُخْتَلِفُ الْحَالَاتِ مُتَنَقِّلٌ فِي الصِّفَاتِ فَتَعَالَيْتَ عَنِ الْاَشْبَاهِ وَالْاَضْدَادِ وَتَكَبَّرْتَ عَنِ الْاَمْثَالِ وَالْاَنْدَادِ فَسُبْحَانَكَ لَا اِلٰهَ اِلَّا اَنْتَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "