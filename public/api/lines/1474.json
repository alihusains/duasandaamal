[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010110, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O Imam of the world! Peace be upon you, O secure and lasting link of Allah! Peace be upon you, O strong rope of Allah! Peace be upon you, O bright light of Allah! Peace be upon you, O true Jafar Ibne Muhammad, treasurer of Allah’s knowledge, O true invitor of people towards Allah! O Allah! In the same way as Thou hast made him treasurer of Thy wonders and of Thy messages and of Thy knowledge, and giveth him the language of Thy Oneness, the ownership of Thy realm and the protectorship of Thy religion, send the choicest of blessings on him the same blessings bestowed by Thee on Thy regents and successors, Indubitably, Thou art worthy of praise and Thou art revered!", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay rehbar’e insaan. Salaam ho aap par ay ittehaad (unity) ki mazboot rassi. Salaam ho aap par ay Allah ki mazboot rassi. Salaam ho aap par ay Allah ke roshan o aashkaar (waazeh) noor. Salaam ho aap par ay raast-go (sachche) Jaafar ibne Muhammad (a.s), saaheb’e ilm’e Ilaahi, haqeeqi Khuda ki taraf daawat dene waale. Ay Allah! Tu ne jis tarah un ko apne kalaam aur wahi ka makhzan (khazaana) qaraar diya hai aur apne ilm ka mohaafiz qaraar diya hai, aur apni tawheed ki zabaan qaraar di hai, aur apne umoor ki wilaayat ataa ki hai, aur deen ka mohaafiz qaraar diya hai, lehaaza un par aisi hi rehmat o durood ko naazil farma keh jis tarah apne awsiya aur ambiya ki har fard par naazil farmaayi hai, be-shak Tu laayaq’e sataaish (taareef) aur qaabil’e ehteraam hai.", "Urdu": "سلام ہو آپ پر اے رہبر انساب، سلام ہو آپ پر اے اتحاد کی مضبوط رسی، سلام ہو آپ پر اے اللہ کی مضبوط رسی، سلام ہو آپ پر اے اللہ کے روشن و آشکار نور، سلام ہو آپ پر اے راست گو، جعفر ابن محمدؑ، صاحب علم الہی، حقیقی اللہ کی طرف دعوت دینے والے، اے اللہ! تو نے جس طرح ان کو اپنے کلام اور وحی کا مخزن بنایا ہے اور اپنے علم کا محافظ قرار دیا ہے، اور اپنی توحید کی زبان قرار دیا ہے اور اپنے امور کی ولایت عطا کی ہے اور دین کا محافظ قرار دیا ہے لہذا ان پر ایسی ہی رحمت و درود کو نازل فرما جس طرح اپنے اوصیاء اور انبیاؤں کی ہر فرد پر نازل فرمائی ہے، بے شک تو لائق ستائش اور قابل احترام ہے۔", "RArabic": "AS-SALAAMO A’LAIKA YAA IMAAMAL WARAA. AS-SALAAMO A’LAIKA AYYO-HAL U’R-WA-TUL WUSQAA. AS-SALAAMO A’LAIKA YAA HABLAL LAAHILMATEE-NE. AS-SALAAMO A’LAIKA YAA NOORA-HUL MOBEE-NE. AS-SALAAMO A’LAIKA AYYO-HAS SAADEQO JA’FA-RUBNO MOHAMMADIN KHAAZE-NUL I’LME, ADDAA-EE’ ILAL LAAHEBIL-HAQQE. ALLAAHUMMA KAMAA JA-AL-TAHU MA’DE-NAA KALAAME-KA WA WAH-YEKA, WA KHAAZE-NA I’LME-KA, WA LESAA-NATAWHEE-DEKA, WA WALIYYA AMRE-KA, WA MUS-TAH-FEZA DEENE-KA FA-SALLE A’LAIHE AF-ZALA MAA SAL-LAIY-TA A’LAA AHA-DIN MIN AWSE-YAAA-E-KA WA HUJA-JEKA, INNA-KA HAMEE-DOON MAJEE-DOON.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ یَا اِمَامَ الْوَرٰی۔ اَلسَّلَامُ عَلَیْکَ اَیُّھَاالْعُرْوَۃُالْوُثْقٰی۔ اَلسَّلَامُ عَلَیْکَ یَاحَبْلَ اللہِ الْمَتِیْنِ۔ اَلسَّلَامُ عَلَیْکَ یَانُوْرَہُ الْمُبِیْنِ۔ اَلسَّلَامُ عَلَیْکَ اَیُّھَاالصَّادِقُ جَعْفَرُابْنُ مُحَمَّدٍ خَازِنُ الْعِلْمِ، اَلدَّاعِیْ اِلَی اللہِ بِالْحَقِّ۔ اَللّٰہُمَّ کَمَا جَعَلْتَہٗ مَعْدِنَ کَلَامِکَ وَوَحْیِکَ‘ وَخَازِنَ عِلْمِکَ‘ وِلِسَانَ تَوْحِیْدِکَ‘ وَوَلِیَّ اَمْرِکَ‘ وَمُسْتَحْفِظَ دِیْنِکَ فَصَلِّ عَلَیْہِ اَفْضَلَ مَا صَلَّیْتَ عَلٰی اَحَدٍ مِّنْ اَوْصِیَآئِکَ وَحُجَجِکَ‘ اِنَّکَ حَمِیْدٌ مَّجِیْدٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "Ar