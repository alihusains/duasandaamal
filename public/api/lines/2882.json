[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002260, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "All praise be to Allah Whose treasures are inexhaustible and those whom are secured by Him shall never fear anything. O my Lord, as I have committed acts of disobedience to You, this was only out of my full confidence in Your generosity. Verily, You accept the repentance of Your servants, pardon their wrongdoings, and forgive their flaws. You verily respond to one who prays You, and You are close to him.", "Gujarati": null, "RGujarati": null, "RUrdu": "Hamd hai us Khuda ke liye jiske khazaane khatm nahi hote aur jise woh amaan de usey khouf nahi. Mere Parwardigaar, agar mai ne na-farmaaniya ki ho to us waaste keh mujhe Tere karam par bharosa tha kyu keh Tu apne bando’n ki taubah qabool farmata hai unki buraaiyo’n se dar-guzar karta aur khataae’n maaf karta hai. Tu pukaarne waale ka jawaab deta hai aur Tu us se qareeb hota hai.", "Urdu": "حمد ہے اس خداکے لئے جس کے خزانے ختم نہیں ہوتے اور جسے وہ امان دے اسے خوف نہیں میرے پروردگار اگر میں نے نافرمانیاں کی ہیں تو اس واسطے کہ مجھے تیرے کرم پر بھروسہ تھا کیوں کہ تو اپنے بندوں کی توبہ قبول فرماتا ہے ان کی برائیوں سے در گزر کرتا اور خطائیں معاف کرتا ہے تو پکارنے والے کا جواب دیتا ہے اور تو اس سے قریب ہوتا ہے۔", "RArabic": "AL-HAMDO LILLAA-HIL LAZEE LAA TANFA-DO KHAZAA-E-NOHU WA LAA YA-KHAA-FO AA-MENO-HU RABBE ENIR TAKAB-TUL MA-AA’SEYA FA-ZAALEKA SEQA-TOON MINNEE BE-KARAME-KA INNA-KA TAQBA-LUT TAWBATA A’N E’BAADE-KA WA TA’FOO A’N SAIYYE-AATE-HIM WA TAGH-FE-RUZ ZALA-LA WA INNAKA MOJEE-BOON LE-DAA-EE’KA WA MINHO QAREE-BOON.", "ArabicText1": "اَلْحَمْدُ لِلهِ الَّذِيْ لَا تَنْفَدُ خَزَائِنُهٗ وَلَا يَخَافُ آمِنُهٗ رَبِّ اِنِ ارْتَكَبْتُ الْمَعَاصِيَ فَذٰلِكَ ثِقَةٌ مِّنِّيْ بِكَرَمِكَ اِنَّكَ تَقْبَلُ التَّوْبَةَ عَنْ عِبَادِكَ وَتَعْفُوْ عَنْ سَيِّئَاتِهِمْ وَتَغْفِرُ الزَّلَلَ وَاِنَّكَ مُجِيْبٌ لِدَاعِيْكَ وَمِنْهُ قَرِيْبٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002261, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I am repenting before You from my sins and from You do I desire for a good portion of Your donations. O Creator of all beings! O my Redeemer from all hardships! O my Rescuer from all perils! (Please do) confer upon me with pleasure and save me from the evil end results of matters. Verily, You are Allah the thanked for Your bounties and affluent gifts and hoped for all good things.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur mai Tere huzoor apne gunaho’n se taubah kar raha hu aur Tujh se Teri ataawo’n mein apne hisse mein farawaani chahta hu, ay makhlooq ke paiyda karne waale, ay mujhe har mushkil se nikaal ne waale, ay mujh ko har badi (buraayi) se bachaane waale, mujh par masarrat (khushiyo’n) ki farawaani farma, mujhe sab maamlo’n ke burey anjaam se mehfooz rakh keh Tu hi woh Khuda hai keh kaseer neymato’n aur ataawo’n par jiska shukr kiya jaata hai aur har bhalaayi Tere yahan zakhira hai.", "Urdu": "اور میں تیرے حضور اپنے گناہوں سے توبہ کر رہا ہوں اور تجھ سے تیری عطاؤں میں اپنے حصے میں فراوانی چاہتا ہوں اے مخلوق کے پیدا کرنے والے اے مجھے ہر مشکل سے نکالنے والے اےمجھ کو ہر بدی سے بچانے والے مجھ پر مسرت کی فراوانی فرما مجھے سب معاملوں کے برے انجام سے محفوظ رکھ کہ تو ہی وہ خدا ہے کہ کثیر نعمتوں اور عطاؤں پر جس کا شکر کیا جاتا ہے اور ہر بھلائی تیرے ہاں ذخیرہ ہے۔", "RArabic": "WA ANAA TAA-E-BOON ILAIKA MENAL KHATAA-YAA WA RAAGHE-BOON ILAIKA FEE TAW-FEE-RE HAZZEE MENAL A’TAA-YAA, YAA KHAALE-KAL BARAA-YAA, YAA MUNQE-ZEE MIN KULLE SHADEEDA-TIN YAA MOJEE-REE MIN KULLE MAHZOO-RIN WA FIR A’LAIY-YAS SOROO-RA FAQFE-NEE SHARRA A’WAAQE-BIL OMOO-RE FA-ANTAL LAAHO A’LAA NA’MAA-E-KA WA JAZEE-LE A’TAA-E-KA MASHKOO-ROON WA LE-KULLE KHAIRIN MAZKHOO-RIN.", "ArabicText1": "وَاَنَا تَائِبٌ اِلَيْكَ مِنَ الْخَطَايَا وَرَاغِبٌ اِلَيْكَ فِيْ تَوْفِيْرِ حَظِّيْ مِنَ الْعَطَايَا، يَا خَالِقَ الْبَرَايَا، يَا مُنْقِذِيْ مِنْ كُلِّ شَدِيْدَةٍ يَا مُجِيْرِيْ مِنْ كُلِّ مَحْذُوْرٍ وَفِّرْ عَلَيَّ السُّرُوْرَ وَاكْفِنِيْ شَرَّ عَوَاقِبِ الْاُمُوْرِ فَاَنْتَ اللهُ عَلٰى نَعْمَائِكَ وَجَزِيْلِ عَطَائِكَ مَشْكُوْرٌ وَلِكُلِّ خَيْرٍ مَذْخُوْرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10