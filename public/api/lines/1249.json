[{"Id": 1010033, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Al-Kafami, in Misbah, says “This is the supplicatory prayer of Imam Mahdi (a)…", "GujaratiDescription": null, "RUrduDescription": "Kafami ne apni kitabab Misbah mein tehreer ki hai keh yeh dua Imam Mahdi (a) ki hai…", "UrduDescription": "کفعمیؒ نے بلدالامین میں تحریرکیا ہے۔ یہ بھی حضرت حجت(عج)ہی کی دعا ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010034, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Grant us the good fortune of being obedient (to You) and keep us away from disobedience. Let us be sincere in our intentions. Provide us with the knowledge of what is sacred. Honor us with guidance and honesty¬, and direct our tongues to what is right and wise; fill our hearts with learning and knowledge, and cleanse our stomachs from what is forbidden and of doubt.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Taufiq de hamein ita’at karne aur na-farmani se dur rehne, niyyat saaf rakhne aur hurmato’n ko pehchaan ne ki aur hamein raahe raast aur saabit qadami se sarfaraaz farma aur hamari zabaano ko khoobi o danaayi se bolne ki taufiq de. Hamare dilo’n ko ilm o maarefat se bhar de. Hamare shikamo’n ko haraam aur mashkuk gizah se paak rakh.", "Urdu": "اے معبود! توفیق دے ہمیں اطاعت کرنے، نافرمانی سے دور رہنے، نیت صاف رکھنے اور حرمتوں کو پہچاننے کی اور ہمیں راہ ِراست اور ثابت قدمی سے سرفراز فرما اور ہماری زبانوں کو خوبی و دانائی سے بولنے کی توفیق دے ہمارے دلوں کو علم و معرفت سے بھر دے اور ہمارے شکموں کو حرام اور مشکوک غذا سے پاک رکھ۔", "RArabic": "ALLAAHUMMAR ZUQNAA TAWFEEQAT TAA-A’TE WA BO’DAL MA’SEYATE WA SIDQAN NIYYATE WA I’RFAANAL HURMATE WA AKRIMNAA BIL HODAA WAL ISTEQAAMATE WA SADDID ALSENATANAA BIS SAWAABE WAL HIKMATE WAM-LAA QOLOOBANAA BIL I’LME WAL MA’REFATE WA TAHHIR BOTOONANAA MENAL HARAAME WASH-SHUBHATE.", "ArabicText1": "اَللّٰھُمَّ ارْزُقْنَا تَوْفِیْقَ الطَّاعَۃِ وَبُعْدَ الْمَعْصِیَۃِ وَصِدْقَ النِّیَّۃِ وَعِرْفَانَ الْحُرْمَۃِ وَاَكْرِمْنَا بِالْھُدٰی وَالْاِسْتِقَامَۃِ وَسَدِّدْ اَلْسِنَتَنَا بِالصَّوَابِ وَالْحِكْمَۃِ وَامْلَا قُلُوْبَنَا بِالْعِلْمِ وَالْمَعْرِفَۃِ وَطَھِّرْ بُطُوْنَنَا مِنَ الْحَرَامِ وَالشُّبْھَۃِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010035, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Prevent our hands from committing oppression and theft, lower our gaze (out of modesty) from immorality and disloyalty, and block our ears from hearing foolish talk and slander. O Allah! Oblige our learned scholars with piety and sincere advice, and those who are learning with restrain and desire to learn. Bless those who are with desire to follow the religious teachings, impart recovery and comfort to the Muslims suffering from illness and bless those dead among them with kindness and mercy.", "Gujarati": null, "RGujarati": null, "RUrdu": "Hamare haato’n ko sitam aur chori karne se bachaaye rakh aur hamari ankho’n ko badi aur kheyaanat se baaz rakh aur hamare kaano ko chugli aur be-faaida baate’n soonne se mehfooz farma. Hamare ulema ko zohad o nasihat ki taufiq ataa kar aur hamare taalib'e ilmo ko mehnat aur raghbat ataa kar. Waaz o nasihat soonne waalo’n ko nasihat pakad ne aur pairawi karne ki taufiq de aur bimaar musalmaano ko shifayaab farma aur aaraam-de unke marhumeen par maher-baani aur rehmat farma.", "Urdu": "ہمارے ہاتھوں کو ستم اور چوری کرنے سے بچائے رکھ اور ہماری آنکھوں کو بدی اور خیانت سے باز رکھ اور ہمارے کانوں کو چغلی اور بے فائدہ باتیں سننے سے محفوظ فرما ہمارے علمائے دین کو زہد ونصیحت فرما اور ہمارے طالب علموں کو محنت اور رغبت عطا کروعظ سننے والوں کو نصیحت حاصل کرنے اور پیروی کرنے کی توفیق دے اور بیمار مسلمانوں کو شفایاب فرما اور آرام دے ان کے مرحومین پر مہربانی فرما۔", "RArabic": "WAK-FUF AYDEYANAA A’NIZ ZULME WAS SAREQATE WAGH-ZUZ ABSAARANAA A’NIL FOJOORE WAL KHEYAANATE WAS-DUD ASMAA-A’NAA A’NIL LAGHWE WAL GHEEBATE WA TAFAZZAL A’LAA O’LAMAAA-ENAA BIZ ZOHDE WAN NASEEHATE WA A’LAL MOTA-A’LLEMEENA BIL JOHDE WAR-RAGHBATE WA A’LAL MUSTAME-E’ENA BIL ITTEBAA-E’ WAL MAW-E’ZATE WA A’LAA MARZAL MUSLEMEENA BISH-SHE-FAAA-E WAR RAAHATE WA A’LAA MAWTAAHUM BIR-RAAFATE WAR-RAHMATE.", "ArabicText1": "وَاكْفُفْ اَیْدِیَنَا عَنِ الظُّلْمِ وَالسَّرِقَۃِ وَاغْضُضْ اَبْصَارَنَا عَنِ الْفُجُوْرِ وَالْخِیَانَۃِ وَاسْدُدْ اَسْمَاعَنَا عَنِ اللَّغْوِ وَالْغِیْبَۃِ وَتَفَضَّلْ عَلٰی عُلَمَآئِنَا بِالزُّھْدِ وَالنَّصِیْحَۃِ وَعَلَی الْمُتَعَلِّمِیْنَ بِالْجَھْدِ وَالرَّغْبَۃِ وَعَلَی الْمُسْتَمِعِیْنَ بِالْاِتِّبَاعِ وَالْمَوْعِظَۃِ وَعَلٰی مَرْضَی الْمُسْلِمِیْنَ بِالشِّفَآءِ وَالرَّاحَۃِ وَعَلٰی مَوْتَاھُمْ بِالرَّافَۃِ وَالرَّحْمَۃِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010036, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Award dignity and peace of mind to old people, confer repentance and turning away from sin to our young people, Bestow modesty and chastity to our women. Supply the rich with humility and abundance; and the poor with patience and contentment. and the warriors with help & victory and the imprisoned with release & comfort.", "Gujarati": null, "RGujarati": null, "RUrdu": "Hamare budho ko waqaar aur itmenaan ataa kar aur hamare jawano ko tauba o isteghfaar ki taufiq de aur aurto’n ko haya aur paak-damani inaayat farma. Hamare tawangaro’n ko frutani aur sakhaawat ataa kar de aur mufliso’n ko sabr o qenaa’at bakhsh de. Ghaziyo’n ko madad aur ghalba de. Qaidiyo’n ko rehaayi aur aaraam de.", "Urdu": "ہمارے بوڑھوں کو وقار اور سکون عطا کر اور ہمارے جوانوں کوتوبہ و استغفار کی توفیق دے اور عورتوں کو حیا اور پاک دامنی عنایت فرما ہمارے تونگروں کو عدالت سخاوت اور شفقت و محبت عطا کر دے اور مفلسوں کو صبر و قناعت بخش دے غازیوں کو مدد اور غلبہ دے قیدیوں کورہائی اور آرام دے۔", "RArabic": "WA A’LAA MASHAA-YEKHENAA BIL WAQAARE WAS-SAKINATE WA A’LASH SHABAABE BIL ENAABATE WAT TAWBATE WA A’LAN NESAAA-E BIL HAYAAA-E WAL I’FFATE WA A’LAL AGHNEYAAA-E BIT TAWAA-ZO-E’ WAS SA-A’TE WA A’LAL FOQARAAA-E BIS SABRE WAL QANAA-A’TE WA A’LAL GHOZAATE BIN NASRE WAL GHALABATE WA A’LAL OSARAAA-E BIL KHALAASE WAR-RAAHATE.", "ArabicText1": "وَعَلٰی مَشَایِخِنَا بِالْوَقَارِ وَالسَّكِیْنَۃِ وَعَلَی الشَّبَابِ بِالْاِنَابَۃِ وَالتَّوْبَۃِ وَعَلَی النِّسَآءِ بِالْحَیَآءِ وَالْعِفَّۃِ وَعَلَی الْاَغْنِیَآءِ بِالتَّوَاضُعِ وَالسَّعَۃِ وَعَلَی الْفُقَرَآءِ بِالصَّبْرِ وَالْقَنَاعَۃِ وَعَلَی الْغُزَاۃِ بِالنَّصْرِ وَالْغَلَبَۃِ وَعَلَی الْاُسَرَآءِ بِالْخَلَاصِ وَالرَّاحَۃِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010037, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Let the rulers be just and kind and the ruled receive just treatment and good character. Bless those who are on pilgrimage with adequate support, and helping them complete what is obligatory on them With Your Grace and Kindness, O Most Kind.", "Gujarati": null, "RGujarati": null, "RUrdu": "Haakimo ko insaaf aur narmi ki taufiq de aur awaam ko haq-shanaasi (haq pehchaan ne ki) aur nek kirdaar bana de. Hajiyo’n aur Zaayero’n ke zaad'e raah aur kharch mein barkat de aur un par jo Tu ne Haj aur Umrah waajib kiya hai woh achchi tarah adaa kar de Tere fazl se aur Teri rehmat se ay sabse ziyadah rahem karne waale.", "Urdu": "حاکموں کو انصاف اور نرمی کی توفیق دے اور عوام کو حق شناسی اور نیک کردار بنا دے حاجیوں اور زائروں کے زادِ راہ اور خرچ میں برکت دے اور ان پر جو حج اور عمرہ تو نے واجب کیا ہے وہ اچھی طرح ادا کر دے اپنے فضل سے اور اپنی رحمت سے اے سب سے زیادہ رحم کرنے والے۔", "RArabic": "WA A’LAL OMARAAA-E BIL A’DLE WASH-SHAFAQATE WA A’LAR RA-E’EYYATE BIL INSAAFE WA HUSNIS SEERATE WA BAARIK LIL-HUJJAAJE WAZ-ZUWWAARE FIZ-ZAADE WAN-NAFAQATE WAQZE MAA AWJABTA A’LAYHIM MENAL HAJJE WAL-U’MRATE BE FAZLEKA WA RAHMATEKA YAA ARHAMAR RAAHEMEEN.", "ArabicText1": "وَعَلَی الْاُمَرَآءِ بِالْعَدْلِ وَالشَّفَقَۃِ وَعَلَی الرَّعِیَّۃِ بِالْاِنْصَافِ وَحُسْنِ السِّیْرَۃِ وَبَارِكْ لِلْحُجَّاجِ وَالزُّوَّارِ فِیْ الزَّادِ وَالنَّفَقَۃِ وَاقْضِ مَا اَوْجَبْتَ عَلَیْھِمْ مِنَ الْحَجِّ وَالْعُمْرَۃِ بِفَضْلِكَ وَرَحْمَتِكَ یَااَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) c