وَدُعَاۗءِ قَلْبٍ قَرِيْحٍ وَاِعْلَانِ قَوْلٍ صَرِيْحٍ۔ اَللّٰهُمَّ فَتَقَبَّلْ مِنِّىْ مُخْلَصَ التَّوْبَةِ وَاِقْبَالَ سَرِيْعِ الْاَوْبَةِ وَمَصَارِعَ تَخَشُّعِ الْحَوْبَةِ وَقَابِلْ رَبِّ تَوْبَتِىْ بِجَزِيْلِ الثَّوَابِ وَكَرِيْمِ الْمَاۗءِبِ وَحَطِّ الْعِقَابِ وَصَرْفِ الْعَذَابِ وَغُنْمِ الْاِيَابِ وَسِتْرِ الْحِجَابِ وَامْحُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012644, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Aur ay Ma’bood! Mere jo gunah Tu ne likhe woh mita de, meri taubah qabool kar ke meri gunah dho de, us taubah ko mere dil mein roshan karne waali, meri aql ki baseerat ka maqaam dene waali meri gard o ghubaar ko dur karne waali, mere badan se na-paaki hataane waali, mere qalb o zameer ko durust karne waali, meri aql o samajh ko baseerat se ham-kinaar karne waali panah de.", "Urdu": "اور اے معبود! میرے جو گناہ تو نے لکھے وہ مٹا دے میری توبہ قبول کرکے میرے گناہ دھو دے اس توبہ کو میرے دل میں روشن کرنے والی میری عقل کو بصیرت کا مقام دینے والی میری میل کو دور کرنے والی میرے بدن سے ناپاکی ہٹانے والی میرے قلب وضمیر کو درست کرنے والی میری عقل و سمجھ کو بصیرت سے ہم کنار کرنے والی بنادے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ مَا ثَبَتَ مِنْ ذُنُوْبِىْ وَاغْسِلْ بِقَبُوْلِهَا جَمِيْعِ عُيُوْبِىْ وَاجْعَلْهَا جَالِيَةً لِقَلْبِىْ شَاخِصَةً لِبَصِيْرَةِ لُبِّىْ غَاسِلَةً لِدَرَنِىْ مُطَهِّرَةً لِنِجَاسَةِ بَدَنِىْ مُصَحِّحَةً فِيْهَا ضَمِيْرِىْ عَاجِلَةً اِلَى الْوَفَاۗءِ بِهَا بَصِيْرَتِىْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4