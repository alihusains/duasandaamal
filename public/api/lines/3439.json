n": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Aur ay Parwardigaar! Meri taubah qabool farma keh yeh meri khaalis niyyat aur samajh-bujh ke saath anjaam pa rahi hai, mere baatin ke har pehlu se ho rahi hai, dil ke chhupe ghosho’n ki tawajjoh se huwi hai, Tere huzoor meri baaz-gasht aur Tere hukm par jald-tar amal ke saath ho rahi hai.", "Urdu": "اور اے پروردگار! میری توبہ قبول فرما کہ یہ میری خالص نیت اور سمجھ بوجھ کے ساتھ انجام پارہی ہے میرے باطن کے ہر پہلوسے ہو رہی ہے دل کے چھپے گوشوں کی توجہ سے ہوئی ہے تیر ےحضور میری بازگشت اور تیرے حکم پر جلد تر عمل کے ساتھ ہو رہی ہے۔", "RArabic": null, "ArabicText1": "وَاقْبَلْ يَا رَبِّ تَوْبَتِىْ فَاِنَّهَا تَصْدُرُ مِنْ اِخْلَاصِ نِيَّتِىْ وَمَحْضٍ مِنْ تَصْحِيْحِ بَصِيْرَتِىْ وَاحْتِفَالٍ فِىْ طَوِيَّتِىْ وَاجْتِهَادٍ فِىْ نَقَاۗءِ سَرِيْرَتِىْ وَتَثْبِيْتٍ لِاِنَابَتِىْ وَمُسَارَعَةً اِلٰى اَمْرِكَ بِطَاعَتِىْ وَاجْلُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012646, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Is taubah ke zariye mujh se gunaho’n par israar ki taareeki dur kar de, aur is se pehle jo gunah kar chuka hu woh mita de, mujhe parhez-gaari ka libaas pehna aur hidaayat ki chaadar udha de, kyu’n keh mai ne apne upar se gunaho’n ka lebaadah (libaas) utaar diya aur khataawo’n ka pairaahan apne badan se kaat phainka hai, ay Parwardigaar! Mai ne apne nafs ke khilaaf Teri qudrat ka sahaara liya hai, Teri izzat se madad haasil kar ke apni taubah ko bachaane ke liye Tere supurd kar raha hu, usey ruswaayi se mehfooz rakhne ke liye Teri nigeh-baani mein de raha hu yeh kahe kar keh nahi hai taaqat o quwwat magar Tujh se.", "Urdu": "اے معبود! اس توبہ کے ذریعے مجھ سے گناہوں پر اصرار کی تاریکی دور کردے اور اس سے پہلے جو گناہ کرچکا ہوں وہ مٹادے مجھے پرہیز گاری کا لباس پہنا اور ہدایت کی چادر اوڑھا دے کیوں کہ میں نے اپنے اوپر سے گناہوں کا لبادہ اتار دیا اور خطاؤں کا پیراہن اپنے بدن سے کاٹ پھینکا ہے اے پروردگار!میں نے اپنے نفس کے خلاف تیری قدرت کا سہارا لیا ہےتیری عزّت سے مدد حاصل کرکے اپنی توبہ کو بچانے کے لئے تیرے سپرد کررہا ہوں اسے رسوائی سے محفوظ رکھنے کے لئے تیری نگہبانی میں دے رہا ہوں یہ کہہ کر کہ نہیں ہے طاقت و قوت مگر تجھ سے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ بِالتَّوْبَةِ عَنِّىْ ظُلْمَةَ الْاِصْرَارِ وَامْحُ بِهَا مَا قَدَّمْتُهٗ مِنَ الْاَوْزَارِ وَاكْسُنِىْ لِبَاسَ التَّقْوٰى وَجَلَابِيْبَ الْهُدٰى فَقَدْ خَلَعْتُ رِبْقَ الْمَعَاصِىَ عَنْ جَلَدِىْ وَنَزَعْتُ سِرْبَالَ الذُّنُوْبِ عَنْ جَسَدِىْ مُسْتَمْسِكًا رَبِّ بِقُدْرَتِكَ مُسْتَعِيْنًا عَلٰى نَفْسِىْ بِعِزَّتِكَ مُسْتَوْدِعًا تَوْبَتِىْ مِنَ النَّكْثِ بِخَفْرَتِكَ مُعْتَصِمًا مِنَ الْخِذْلَانِ بِعِصْمَتِكَ مُقَارِنًا بِهٖ لَا حَوْلَ وَلَا قُوَّةَ اِلَّا بِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlue