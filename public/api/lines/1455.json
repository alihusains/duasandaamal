[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010126, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Salam on you, O pious being, obedient to Allah, O sympathiser with the Prophet (s.a.w.a), Amirul Momeneen (a.s), Fatema Zahra (s.a), Hasan (a.s) and Husain (a.s)! I bear witness that you sacrificed in the way of Allah, that you helped Husain (a.s) the son of the daughter of Rasoolullah (s.a.w.a), that you believed in him as if he was life and soul and that you sacrificed your life for his. Hence, the complete Salam of Allah be on you! Salam on you, O bright moon! Salam on you, O Habeeb Ibne Mazahir’e Asadi and Allah’s blessings and bounties on you!", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay bande saaleh ita’at karne waale Allah aur uske Rasool (s.a.w.a) aur Amirul Momeneen (a.s) aur Fatema Zahra (s.a) wa Hasan (a.s) wa Hussain (a.s), keh ay gareeb o musaafir Imam ke gham-khwaar. Mai gawahi deta hu keh yaqeenan aap ne raahe Khuda mein jehaad kiya, aur aap ne nusrat ki Imam Hussain (a.s) jo farzande dukhtare Rasoole Khuda (s.a.w.a) hai, aur aap ne unki himaayat ki apni zaat se aur apni jaan un par nisaar kar di. Pas aap par Khuda ki taraf se mukammal salaam ho. Salaam ho mera aap par ay chamakte huwe chaand. Salaam ho aap par ay Habib ibne Mazahir Asadi aur Khuda ki rehmat o barkat ho aap par.", "Urdu": "سلام ہو آپ پر اے بندہ صالح اطاعت کرنے والے اللہ اور اس کے رسولؐ اور امیر المؤمنینؑ اور فاطمہ زہراؑ و حسنؑ و حسینؑ، کہ اے غریب و مسافر امام کے غم خوار، میں گواہی دیتا ہو کہ یقینًا آپ نے راہے خدا میں جہاد کیا، اور آپ نے نصرت کی امام حسینؑ جو فرزند دختر رسول خداؐ ہے، اور آپ نے ان کی حمایت کی اپنی ذات سے اور اپنی جان اُن پر نثار کر دی، پس آپ پر خدا کی طرف سے مکمل سلام ہو، سلام ہو میرا آپ پر اے چمکتے ہوئے چاند، سلام ہو آپ پر اے حبیب ابن مظاہر اسدیؑ اور خدا کی رحمت و برکت ہو آپ پر۔", "RArabic": "ASSALAAMO A'LAYKA AYYOHAL A'BDUS SAALEHUL MOTEE-O' LILLAAHE WA LERASOOLEHI WA LE-AMEERIL MOAMENEENA WA LEFAATEMATAZ ZAHRAAA-E WAL HASANE WAL HUSAYNE A'LAYHEMUS SALAAMO AL-GHAREEBUL MAWAASEE. ASH-HADO ANNAKA JAAHADTA FEE SABEELIL LAAHE WA NASARTAL HUSAYNABNA BINTE RASOOLIL LAAHE WA WAASAYTA BENAFSEKA WA BAZALTA MOHJATAKA FA-A'LAYKA MENAL LAAHE ASSALAAMUT TAAAMMO ASSALAAMO A'LAYKA AYYOHAL QAMARUZ ZAAHERO ASSALAAMO A'LAYKA YAA HABEEBAB NA MAZAAHERE AL-ASADIYYE WA RAHMATUL LAAHE WA BARAKAATOHU.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ اَیُّھَا الْعَبْدُ الصَّالِحُ الْمُطِیْعُ لِلہِ وَلِرَسُوْلِہٖ وَلِاَمِیْرِ الْمُؤْمِنِیْنَ وَلِفَاطِمَۃَ الزَّھْرَائِ‘ وَالْحَسَنِ وَالْحُسَیْنِ عَلَیْہِمُ السَّلَامُ اَلْغَرِیْبُ الْمُوَاسِیْ۔ اَشْہَدُ اَنَّکَ جَاھَدْتَ فِیْ سَبِیْلِ اللہِ‘ وَنَصَرْتَ الْحُسَیْنَ ابْنَ بِنْتِ رَسُوْلِ اللہِ وَاَسَیْتَ بِنَفْسِکَ‘ وَبَذَلْتَ مُھْجَتَکَ‘ فَعَلَیْکَ مِنَ اللہِ۔ اَلسَّلَامُ التَّآمُّ۔ اَلسَّلَامُ عَلَیْکَ اَیُّھَا الْقَمَرُ الزَّاھِرُ۔ اَلسَّلَامُ عَلَیْکَ یَاحَبِیْبَ ابْنَ مُظَاھِرَ الْاَسَدِیْ وَرَحْمَۃُ اللہِ وَ بَرَکَاتُہٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBl