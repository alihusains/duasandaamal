[{"Id": 1015758, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Tawaaf-e-Wida is recommended for a person who intends to leave Mecca. It is recommended to touch the Black stone and the Pillar of Yemen in each round if possible. Upon reaching ’Mustajaar’, he should perform those recommendations which are described for this place. One should seek his desires and touch his belly with Kaba. Keep one hand on the Black stone and the other to the side of the door. Praise and glorify Allah, send salutations on Mohammed and his progeny and recite this supplication…", "GujaratiDescription": null, "RUrduDescription": "Jo shakhs bhi Makkah se rukhsat hona chahe uske liye Tawaaf-e-Wida karna mustahab hai aur tawaaf ke har shoot (round) mein imkaan ho to Hajar-e-Aswad aur Rukne Yamaani ko chumna bhi mustahab hai aur jab Mustajaar ke paas pohonche to un mustahabaat ko baja laaye jin ka zikr pehle ho chuka hai aur dua-e-maange, apne shikam (stomach) ko Khaana-e-Kaaba ke mass (touch) kare, ek haath Hajar-e-Aswad aur dusra darwaaze par rakh kar hamd o sana-e-Ilaahi kare, Paighambar (s) aur unki Aale Paak (a) par durood o salaam bheje, aur yeh dua padhe…", "UrduDescription": "جو شخص بھی مکہ سے رخصت ہو رہا ہے اس کے لئے طواف وداع کرنا مستحب ہے اور طواف کے ہر شوط (چکر) میں امکان ہو تو حجر اسود اور رکن یمانی کو چومنا بھی مستحب ہے اور جب مستجار کے پاس پہنچے تو ان مستحبات کو بجا لائے جن کا ذکر پہلے ہوچکا ہے اور دُعائیں مانگے، اپنے شکم کو خانہ کعبہ سے مس کرے، ایک ہاتھ حجر اسود اور دوسرا درواذہ پر رکھ کر حمد و ثنائے الٰہی کرے، پیغمبرؐ اور آپ کی آل پاکؑ پر درود و سلام بھیجے اور یہ دُعا پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015759, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Tu apne bande wa rasool aur apne nabi aur ameen, apne habeeb aur muntakhab (choone huwe) bande, Teri makhlooq mein Tere choone huwe bande Hazrat Muhammad (s.a.w.a) par rehmate’n naazil farma. Khudaaya! Usi tarah durood bhej jaise unho ne Teri risaalato’n ki tableegh ki aur Teri raah mein jehaad kiya aur Tere hukm ko wa shigaaf (amal) kiya, unhe Teri raah mein aziyyate’n di gayi aur Tere saamne aziyyat di gayi yahan tak keh unhe maut aa gayi.", "Urdu": "خدایا! تو اپنے بندے و رسولؐ اور اپنے بنی اور امین، اپنے حبیب اور منتخب بندے، تیری مخلوق میں تیرے چنے ہوئے بندے حضرت محمدؐ پر رحمتیں نازل فرما۔ خدایا! اسی طرح درود بھیج جیسے انہوں نے تیری رسالتوں کی تبلیغ کی اور تیری راہ میں جہاد کیا اور تیرے حکم کو وا شگاف کیا، انہیں تیری راہ میں اذیتیں دی گئیں اور تیرے سامنے اذیت دی گئی یہاں تک کہ انہیں موت آگئی۔", "RArabic": "ALLAAHUMMA SALLE A’LAA MOHAMMADIN A’BDEKA WA RASOOLEKA WA NABIYYEKA WA AMEENEKA WA HABEEBEKA WA NAJIYYEKA WA KHEYARATEKA MIN KHALQEKA ALLAAHUMMA KAMAA BALLAGHA RESAALAATEKA WA JAAHADA FEE SABEELEKA SADA-A’ BE-AMREKA OOZEYA FEEKA WA FEE JANBEKA HATTAA ATAAHUL YAQEENO.", "ArabicText1": "اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ عَبْدِكَ وَرَسُوْلِكَ وَنَبِیِّكَ وَاَمِیْنِكَ وَحَبِیْبِكَ وَنَجِیِّكَ وَخِیَرَتِكَ مِنْ خَلْقِكَ۔ اَللّٰہُمَّ كَمَا بَلَّغَ رِسَالَاتِكَ وَجَاہَدَ فِیْ سَبِیْلِكَ صَدَعَ بِاَمْرِكَ اُوْذِیَ فِیْكَ وَفِیْ جَنْبِكَ حَتّٰی اَتٰیہُ الْیَقِیْنُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015760, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Tu mujhe palta kaamyaab o kaamraan bana kar, meri dua'e qabool kar le, behtareen tohfe aur inaam ke saath jaise Tere paas aane waale giroh (group) ka koi shakhs palat-ta hai, woh behtareen inaam'e maghferat aur Teri barkat, Teri raza aur maafi hai. Un cheezo’n mein jinhe mai talab karu keh Tu mujhe ataa kare waisi hi cheeze’n jo Tu ne behtar shakl mein ataa ki apne kisi ibaadat guzaar bande ko, mujhe us se ziyadah ataa farma de.", "Urdu": "خدایا! تو مجھے پلٹا کامیاب اور کامران بنا کر میری دُعائیں قبول کر کے، بہترین تحفے اور انعام کے ساتھ جیسے تیرے پاس آنے والے گروہ کا کوئی شخص پلٹتا ہے، وہ بہترین انعام مغفرت اور تیری برکت، تیری رضا اور معافی ہے، ان چیزوں میں، جنہیں میں طلب کروں کہ تو مجھے عطا کرے ویسی ہی چیز جو تونے بہتر شکل میں عطا کی اپنے کسی عبادت گزار بندے کو، مجھے اس سے زائد عطا فرما دے۔", "RArabic": "ALLAAHUMMAQ LIBNEE MUNJEHAN MUFLEHAN MUSTAJAABAN LEE BE-AFZALE MAA YARJE-O’ BEHI AHADUN MIN WAFDEKA MENAL MAGHFERATE WAL BARAKATE WAR RIZWAANE WAL A’AFEYATE FEEMAA YASA-O’NEE AN ATLOBA AN TO’TEYANEE MISLAL LAZEE A-A’TAYTAHU AFZALA MAN A’BADAKA WA TAZEEDANEE A’LAYHE.", "ArabicText1": "اَللّٰہُمَّ اقْلِبْنِیْ مُنْجِحًا مُفْلِحًا مُسْتَجَابًا لِیْ بِاَفْضَلِ مَا یَرْجِعُ بِہٖ اَحَدٌ مِّنْ وَفْدِكَ مِنَ الْمَغْفِرَۃِ وَالْبَرَكَۃِ وَالرِّضْوَانِ وَالْعَافِیَۃِ فِیْمَا یَسَعُنِیْ اَنْ اَطْلُبَ اَنْ تُعْطِیَنِیْ مِثْلَ الَّذِیْ اَعْطَیْتَہٗ اَفْضَلَ مَنْ عَبَدَكَ وَتَزِیْدَنِیْ عَلَیْہِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015761, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Tu mere is Hajj ko apne ghar ka aakhri ahed na qaraar de. Ay Allah! Mai Tera banda hu aur Tere bande ka beta hu, Tu ne apne jaanwar par mujhe sawaar kiya aur apne shahero’n ki mujhe saher karaayi, yahan tak keh mujhe apne haram aur mahal'e amn mein daakhil kiya aur mera Tere baare mein yeh husne-zan hai keh Tu mere gunaho’n ko bakhsh de aur agar Tu ne mere gunaho’n ko bakhsh diya hai to mere liye apni raza ka izaafa kar de aur mujhe apne se qareeb kar le aur mujhe dur na kar.", "Urdu": "خدایا! تو میرے اس حج کو اپنے گھر آخری عہد نہ قرار دے۔ اے اللہ! میں تیرا بندہ ہوں اور تیرے بندہ کا بیٹا ہوں، تو نے اپنے جانور پر سوار کیا اور اپنے شہروں کی مجھے سیر کرائی، یہاں تک کہ مجھے اپنے حرم اور محلِ امن میں داخل کیا اور میرا تیرے بارے میں یہ حُسن ظن ہے کہ تو میرے گناہوں کو بخش دے اور اگر تونے میرے گناہوں کو بخش دیا ہے تو میرے لئے اپنی رضا کا اضافہ کر دے اور مجھے اپنے سے قریب کر لے اور مجھے دور نہ کر۔", "RArabic": "ALLAAHUMMA LAA TAJ-A’LHO AAKHERAL A’HDE MIN BAYTEKA ALLAAHUMMA INNEE A’BDOKA WAB NO AMATEKA HAMALTANEE A’LAA DAAB-BATEKA WA SAYYARTANEE FEE BELAADEKA HATTAA ADKHALTANEE HARAMAKA WA AMNAKA WA QAD KAANA FEE HUSNE ZANNEE BEKA AN TAGHFERA LEE ZONOOBEE FA-IN KUNTA QAD GHAFARTA ZONOOBEE FAZDAD A’NNEE REZAN WA QARRIBNEE ELAYKA ZULFAA.", "ArabicText1": "اَللّٰہُمَّ لَا تَجْعَلْہُ آخِرَ الْعَہْدِ مِنْۢ بَیْتِكَ۔ اَللّٰہُمَّ اِنِّیْ عَبْدُكَ وَابْنُ عَبْدِكَ وَابْنُ اَمَتِكَ حَمَلْتَنِیْ عَلٰی دَابَّتِكَ وَسَیَّرْتَنِیْ فِیْ بِلَادِكَ حَتّٰی اَدْخَلْتَنِیْ حَرَمَكَ وَاَمْنَكَ وَقَدْ كَانَ فِیْ حُسْنِ ظَنِّیْ بِكَ اَنْ ت