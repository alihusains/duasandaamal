ge": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002400, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, Thy protection, Thy protection: on the day when they can neither delay (the event) by a single moment, nor can they hasten it (death). My God, Thy protection, Thy protection at the time of the parting of the soul from the body and in the presence of death. My God, Thy protection, Thy protection at the time of the narration (of our sins) and at the time of our tarrying in front of Thee.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اِلٰهِيْ اَلْاَمَانُ اَلْاَمَانُ يَوْمَ لَا يَسْتَاخِرُوْنَ سَاعَةً وَّلَا يَسْتَقْدِمُوْنَ۔ اِلٰهِيْ اَلْاَمَانُ اَلْاَمَانُ عِنْدَ سَكَرَاتِ الْمَوْتِ وَعِنْدَ مُفَارِقَةِ الرُّوْحِ وَعِنْدَ مُعَايَنَةِ الْمَوْتِ۔ اِلٰهِيْ اَلْاَمَانُ اَلْاَمَانُ عِنْدَ حَوْلِ الْمُطَّلَعِ وَعِنْدَ الْوُقُوْفِ بَيْنَ يَدَيْكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null,