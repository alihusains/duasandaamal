[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000259, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my Beloved Favourite in my comforts! O my Allah, And Allah of Ibraaheem, And Ismaa-eel, And Ishaaq, And Yaaqoob. O Lord Of Kaaaf Haa Yaa Ayyyn Saaad And Yaa Seeen And the Quranil Hakeem I beseech Thee, O He Who grants favour to him who makes a request! O He Who does good to him who calls! O He Who fills to over flowing whom He gives! O Generous Merciful Who is implored and entreated! I beseech Thee, To send blessings on Muhammad and on the children of Muhammad.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay meri tanghi mein mere saathi, ay neymat mein mere sardar aur mere Ma’bood! Aur Ibrahim o Ismail o Is’haaq o Yaqoob ke Ma’bood, ay Kaaf-Haa-Yaa-Ain-Saad aur Yaa-Sin wal Quranul hakeem ke Rab mai Tujh se sawaal karta hu ay behtareen sawaal kiye jaane waale aur ay behtatreen pukaare jaane waale, ay ataa karne waalo’n se ziyadah sakhi aur ay behtareen ummeed-gah mai Tujh se sawaal karta hu keh Tu Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat farma.", "Urdu": "اے میری تنگی میں میرے ساتھی! اے نعمت میں میرے سرپرست اور اے میرے معبود! اور ابراہیمؑ و اسماعیلؑ و اسحاقؑ و یعقوبؑ کے معبود اے کھیعٓص اور یٰسٓ و القرآن الحکیم کے رب میں تجھ سے سوال کرتا ہوں اے بہترین ذات جس سے سوال کیے جاتے ہیں اور اے بہترین پکارے جانے والے اے عطا کرنے والوں میں زیادہ سخی اور اے بہترین اُمیدگاہ میں تجھ سے سوال کرتا ہوں کہ تو محمدؐ و آلِ محمدؐ پر رحمت فرما۔", "RArabic": "YAA SAAHEBEE FEE SHIDDATEE WA YAA WALIYYEE FEE NE’MATEE WA YAA ELAAHEE WA ELAAHA IBRAAHEEMA WA ISMAA-E’ELA WA ISHAAQA WA YA’QOOBA YAA RABBA KAAF-HAA-YAA-A’YN-SWAAD WA YAA-SEEN WAL QUR-AAANIL HAKEEME AS-ALOKA YAA AHSANA MAN SO-ELA WA YAA KHAYRA MAN DO-E’YA WA YAA AJWADA MAN A-A’TAA YAA KHAYRA MURTAJAA AS-ALOKA AN TOSALLEYA A’LAA MOHAMMADIWN WA AALE MOHAMMAD.", "ArabicText1": "يَاصَاحِبِيْ فِيْ شِدَّتِيْ وَيَا وَلِيِّيْ فِيْ نِعْمَتِيْ وَيَا اِلٰهِيْ وَاِلٰهَ اِبْرَاهِيْمَ وَاِسْمَاعِيْلَ وَاِسْحَاقَ وَيَعْقُوْبَ يَارَبَّ كهيعص وَيٰس وَالْقُرْٓءَانِ الْحَكِيْمِ اَسْاَلُكَ يَااَحْسَنَ مَنْ سُئِلَ وَيَا خَيْرَ مَنْ دُعِيَ وَيَا اَجْوَدَ مَنْ اَعْطٰى وَيَا خَيْرَ مُرْتَجًى اَسْاَلُكَ اَنْ تُصَلِّيَ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "Arabi