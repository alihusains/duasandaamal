[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002289, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "All praise is due to Allah, Who has not taken a son and Who has not a partner in the kingdom, and Who has not a helper to save Him from disgrace; and proclaim His greatness with thorough proclamation. O my Supporter throughout my lifetime! O my Companion in hardships! O the provider of me with all graces that I experience! O my Succor in my desires! O the source of success of my needs! O my guardian while I am absent! O He Who is sufficient for me when I am alone! O my entertainment in my loneliness! You alone conceal my faults!", "Gujarati": null, "RGujarati": null, "RUrdu": "Hamd Khuda hi ki liye hai jisne kisi ko apna beta nahi banaya aur na azali saltanat mein koi Uska shareek hai, na woh aajeez hai keh koi Uska madad-gaar ho, aur Uski badaayi bayaan karo bohot bohot, ay meri umr mein meri aamadgi, ay sakhti mein mere saathi, ay neymat mein mere sar-parast, ay meri tawajjoh par mere faryaad-ras, ay meri haajat mein meri kaamyaabi, ay meri poshidgi mein mere nigheh-baan, ay meri tanhaai mein meri kifaayat karne waale, ay meri tanhaayi mein mere anees, Tu hi mere aiyb ka parda-poshi hai.", "Urdu": "حمد خدا ہی کے لئے ہے جس نے کسی کو اپنا بیٹا نہیں بنا یا اور نہ ازلی سلطنت میں کوئی اس کا شریک ہے نہ وہ عاجز ہے کہ کوئی اس کا مددگار ہو اور اس کی بڑائی بیان کرو بہت بہت، اے میری عمر میں میری آمادگی، اے سختی میں میرے ساتھی، اے نعمت میں میرے سرپرست، اے میری توجہ پر میرے فریاد رس، اے میری حاجت میں میری کامیابی، اے میری پوشیدگی میں میرے نگہبان، اے میری تنہائی میں میری کفایت کرنے والے، اے میری تنہائی میں میرے انس تو ہی میرے عیب کا پردہ پوش ہے۔", "RArabic": "AL-HAMDO LIL-LAAHIL LAZEE LAM YATTA-KHIZ WALA-DAN, WA LAM YAKUN LAHU SAHREE-KOON FIL MUL-KE, WA LAM YAKUN LAHU WALIYYUN MENAZ ZULLE, WA KABBIR-HO TAKBEE-RAN. YAA U’DDA-TEE FEE MUDDA-TEE, YAA SAAHE-BEE FEE SHIDDA-TEE, YAA WALIYYI FEE NE’MATEE, YAA GHEYAA-SEE FEE RAGH-BATEE, YAA NAJAA-HEE FEE HAAJA-TEE, YAA HAAFE-ZEE FEE GHAIY-BATEE, YAA KAA-FIYYE FEE WAH-DATEE, YAA OON-SEE FEE WAH-SHATEE, ANTAS SAATE-RO A’W-RATEE.", "ArabicText1": "اَلْحَمْدُ لِلهِ الَّذِيْ لَمْ يَتَّخِذْ وَلَدًا، وَلَمْ يَكُنْ لَهٗ شَرِيْكٌ فِي الْمُلْكِ، وَلَمْ يَكُنْ لَهٗ وَلِيٌّ مِنَ الذُّلِّ، وَكَبِّرْهُ تَكْبِيْرًا۔ يَا عُدَّتِي فِيْ مُدَّتِيْ، يَاصَاحِبِيْ فِيْ شِدَّتِي، يَا وَلِيِّيْ فِيْ نِعْمَتِيْ، يَا غِيَاثِيْ فِيْ رَغْبَتِيْ، يَانَجَاحِيْ فِيْ حَاجَتِيْ، يَا حَافِظِيْ فِيْ غَيْبَتِيْ، يَا كَافِيِّ فِيْ وَحْدَتِيْ، يَا اُنْسِيْ فِيْ وَحْشَتِيْ، اَنْتَ السَّاتِرُ عَوْرَتِيْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002290, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "So, all praise be to You. You alone overlook my slips. So, all praise be to You. You alone revive my deterioration. So, all praise be to You. (Please do) send blessings upon Muhammad and the Household of Muhammad and conceal my defects, and secure my apprehensions, and oversee my slips, and pardon my offenses, and overlook my evildoings and include me with the People of Paradise; the promise of truth which they were promised.", "Gujarati": null, "RGujarati": null, "RUrdu": "To hamd Tere hi liye hai aur Tuhi meri laghzish se dar-guzar karne waala hai. Hamd Tere hi liye hai, Tu hi mujhe be-hoshi se hosh mein laane waala hai, pas hamd hai Tere liye. Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat farma aur mere aiyb chhupa de, mujhe khouf se bachaaye rakh, meri khata maaf farma, mere jurm se dar-guzar farma, mere gunah maaf kar ke mujhe ahle Jannat mein se qaraar de, yeh woh sachcha waada hai jo duniya mein un se kiya jaata hai.", "Urdu": "توحمد تیرے ہی لئے ہے اور تو ہی میری لغزش سے درگزر کرنے والا ہے حمد تیرے ہی لئے ہے تو ہی مجھے بے ہوشی سے ہوش میں لانے والا ہے پس حمد ہے تیرے لئے محمدؐ و آل محمدؐ پر رحمت فرما اور میرے عیب چھپا دے مجھے خوف سے بچائے رکھ میری خطا معاف فرما میرے جرم سے درگزر فرما میرے گناہ معاف کرکے مجھے اہل جنت میں سے قرار دے یہ وہ سچا وعدہ ہے جو دنیا میں ان سے کیا جاتا ہے۔", "RArabic": "FA-LAKAL HAMDO, WA ANTAL MO-QEE-LO A’S-RATEE, FA-LAKAL HAMDO, WA ANTAL MUN-E’SHO SAR-A’TEE, FA-LAKAL HAMDO, SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WAS-TUR A’W-TAYEE, WA AAMIN RAW-A’TEE, WA AQIL-NEE A’S-RATEE, WAS-FAH A’N JURMEE, WA TAJAA-WAZ A’N SAIYYE-AATEE FEE AS-HAABIL JANNATE WA’DAS SIDQIL LAZEE KAANO-WAA YAW A’DOO-NA.", "ArabicText1": "فَلَكَ الْحَمْدُ، وَاَنْتَ الْمُقِيْلُ عَثْرَتِيْ، فَلَكَ الْحَمْدُ، وَاَنْتَ الْمُنْعِشُ صَرْعَتِيْ، فَلَكَ الْحَمْدُ، صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَاسْتُرْ عَوْرَتِيْ، وَآمِنْ رَوْعَتِيْ، وَاَقِلْنِيْ عَثْرَتِيْ، وَاصْفَحْ عَنْ جُرْمِيْ، وَتَجَاوَزْ عَنْ سَيِّئَاتِيْ فِيْ اَصْحَابِ الْجَنَّةِ وَعْدَ الصِّدْقِ الَّذِيْ كَانُوَا يُوْعَدُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) choicest blessings be upon Mohammed and his holy progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar Tu rehmat naazil farma Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par.", "Urdu": "اے معبود! رحمت نازل فرما حضرت محمدؐ اور انکی آل ؑپر۔", "RArabic": "ALLAHUMMA SWALLE ALAA MUHAMMADIW WA AALE MUHAMMADIN", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": n