[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000255, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He Who makes known what is good and beautiful, and covers up ugliness and defects. O He Who does not demand submission under duress, with tying ropes and shackling chains, And does not withdraw protection. O Generous Pardoner! O Subtle Indulgent! O Free-handed lavish Forgiver! O Open-handed Merciful! O He Who brings every fugitive to a place of safety! O the Ultimate Relief of every sufferer! O He Who overlooks, and grants amnesty! O He Who fulfils hopes and expectations! O He Who takes initiative to bestow benefits before they become due! O our Lord! O our Chief! O our Master! O Sole purpose of our love! I beseech Thee, O my Allah, To send blessings on Muhammad and on the children of Muhammad.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay woh jo achchaaiyo’n ko zaahir karta hai aur buraaiyo’n ko dhaanp-ta hai, ay woh jo gunah par nahi pakdta aur parda phaash nahi karta, ay azeem afvo waale, ay behtareen dar-guzar karne waale, ay wasee maghferat karne waale, ay rehmat karne mein dono haath khule rakhne waale, ay har bhed (raaz) ke jaanne waale, ay tamaam shikaayato’n ki aakhri bargah, ay chashm-poshi karne waale maher-baan, ay sab se badi ummeed-gah, ay kisi ke haq-daar hone se pehle neymate’n dene waale, ay hamare Rab, ay hamare sardar, ay hamare aaqa, ay hamari raghbat ki inteha. Ay Allah! Mai sawaal karta hu keh Tu Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par apni rehmat naazil farma.", "Urdu": "اے وہ جو اچھائی کو ظاہر اور برائی کو چھپاتا ہے اور وہ جو گناہ پر نہیں پکڑتا اورپردہ فاش نہیں کرتا اے عظیم عفوودرگزر والے اے بہترین درگزر کرنے والے اے وسیع مغفرت والے اے رحمت کرنےکے لئے دونوں ہاتھ کھلے رکھنے والے اے ہر بھید کے جاننے والے اے تمام شکایتوں کی آخری بارگاہ اے درگزر اور معاف کرنے والے مہربان اے سب سے بڑی امیدگاہ اے کسی کے حق دار ہو نے سے پہلے نعمتیں دینے والے اے ہمارے رب اے ہمارے سردار! اے ہمارے آقا!اے ہماری رغبت کی انتہا اے اللہ! میں سوال کرتا ہوں کہ تو محمدؐ و آلِ محمدؑ پر اپنی رحمت نازل فرما۔", "RArabic": "YAA MAN AZHARAL JAMEELA WA SATARAL QABEEHA YAA MAN LAM YO-AAKHIZ BIL JAREERATE WA LA YAHTEKIS SITRA YAA A’ZEEMAL A’FWE YAA HASANAT TAJAAWOZE YAA WAASE-A’L MAGHFERATE YAA BAASETAL YADAYNE BIR RAHMATE YAA SAAHEBA KULLE NAJWAA YAA MUNTAHAA KULLE SHAKWAA YAA KAREEMAS SAF-HE YAA A’ZEEMAR RAJAAA-E YAA MUBTADAN BIN-NE-A’ME QABLAS TEH-QAAQEHAA YAA RABBANAA WA SAYYEDANAA WA MAWLAANAA YAA GHAAYATA RAGHBATENAA AS-ALOKA ALLAAHUMMA AN TOSALLEYA A’LAA MOHAMMADIN WA AALE MOHAMMAD.", "ArabicText1": "يَامَنْ اَظْهَرَ الْجَمِيْلَ وَسَتَرَ الْقَبِيْحَ يَامَنْ لَّمْ يُؤَاخِذْ بِالْجَرِيْرَةِ وَلَمْ يَهْتِكِ السِّتْرَ يَاعَظِيْمَ الْعَفْوِ يَاحَسَنَ التَّجَاوُزِ يَاوَاسِعَ الْمَغْفِرَةِ يَابَاسِطَ الْيَدَيْنِ بِالرَّحْمَةِ يَاصَاحِبَ كُلِّ نَجْوٰى يَامُنْتَهٰى كُلِّ شَكْوٰى يَاكَرِيْمَ الصَّفْحِ يَاعَظِيْمَ الرَّجَآءِ يَامُبْتَدِئًۢا بِالنِّعَمِ قَبْلَ اسْتِحْقَاقِهَا يَارَبَّنَا وَسَيِّدَنَا وَمَوْلَانَا يَاغَايَةَ رَغْبَتِنَا، اَسْاَلُكَ اللّٰهُمَّ اَنْ تُصَلِّىَ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign