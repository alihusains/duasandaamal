Text8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002514, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to God equivalent to the number of His creation, Glory be to God like He pleased Himself, Glory be to God equivalent to the ink of His worlds, Glory be to God equivalent to the weight of His Throne, praise be to God equivalent to all that.", "Gujarati": null, "RGujarati": null, "RUrdu": "Allah-taala apni makhlooqaat ki taadaad ke bara-bar paak o paakeezah hai, Allah-taala apni raza ke mutaabiq aur apne phaile huwe kalemaat ke bara-bar paak o paakeezah hai, Allah-taala apne arsh ke wazn ke bara-bar paak o paakeezah hai aur un sab ke misl Usi wahdawu la-shareek ke liye hamd o sana makhsoos hai.", "Urdu": "اللہ تعلیٰ اپنی مخلوقات کی تعدادکے برابر پاک و پاکیزہ ہے، اللہ تعلیٰ اپنی رضا کے مطابق اور اپنے پھیلے ہوئے کلمات کے برابر پاک و پاکیزہ ہے، اللہ تعلیٰ اپنے عرش کے وزن کے برابر پاک و پاکیزہ ہے اور ان سب کے مثل اسی وحدۂ لاشریک کے لئے حمد و ثنا مخصوص ہے۔", "RArabic": "SUBHAANAL LAAHE A’DADA KHALQE-HI. SUBHAANAL LAAHE REZAA NAFSE-HI. SUBHAANAL LAAHE ME-DAADA KALEMAATE-HI. SUBHAANAL (LAAHE) ZENATA A’RSHE-HI, WAL-HAMDO LILLAAHE MISLA ZAALEKA.", "ArabicText1": "سُبْحَانَ اللهِ عَدَدَ خَلْقِهِ، سُبْحَانَ اللهِ رِضٰى نَفْسِهِ، سُبْحَانَ اللهِ مِدَادَ كَلِمَاتِهِ، سُبْحَانَ (اللهِ) زِنَةَ عَرْشِهِ، وَالْحَمْدُ لِلّٰهِ مِثْلَ ذٰلِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSi