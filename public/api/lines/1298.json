[{"Id": 1000471, "EnglishTitle": "The Whispered Prayer of the Thankful (Shakereen)…", "GujaratiTitle": null, "RUrduTitle": "Shukr karne waalo’n ki Munajaat…", "UrduTitle": "چھٹی مناجات مناجاتِ شاکرین۔۔۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000472, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, the uninterrupted flow of Thy graciousness hast distracted me from thanking Thee! The flood of Thy bounty has rendered me incapable of counting Thy praises! The succession of Thy kind acts has diverted me from mentioning Thee in laudation! The continuous rush of Thy benefits has thwarted me from spreading the news of Thy gentle favours! This is the station of him who confesses to the lavishness of favours, meets them with shortcomings, and witnesses to his own disregard and negligence.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Mabood! Teri lagaataar bakhshisho’n ne mujhe Tera shukr adaa karne se ghaafil kar diya hai, aur Tere fazl ke tawaatur o tasalsul ne mujhe Teri hamd o sana ka ehaata karne se aajiz kar diya hai aur Teri pai-dar-pai (ek ke baad ek) hone waali maher-baaniyo’n ne mujhe Teri taarifo’n ke bayaan se be-dhyaan (ghaafil) kar diya aur Teri musalsal neymato’n ne mujhe Tere ehsaanaat ke zikr se thaka kar rakh diya.", "Urdu": "خدا کے نام سے شروع جو بڑا مہربان نہایت رحم والا ہے۔میرے معبود! تیری لگاتار بخششوں نے مجھے تیرا شکر ادا کرنے سے غافل کردیا ہے اور تیرے فضل کے تسلسل نے مجھے تیری ثنا کا احاطہ کرنے سے عاجز کردیا ہے اور تیری پے در پے ہونے والی مہربانیوں نے مجھے تیری تعریفوں کے بیان سے بے دھیان کردیا اور تیری مسلسل نعمتوں نے مجھے تیرے احسانات کے ذکر سے تھکاکر رکھ دیا۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اِلٰهِىْ اَذْهَلَنِىْ عَنْ اِقَامَةِ شُكْرِكَ تَتَابُعُ طَوْلِكَ وَاَعْجَزَنِىْ عَنْ اِحْصَآءِ ثَنآئِكَ فَيْضُ فَضْلِكَ وَشَغَلَنِىْ عَنْ ذِكْرِ مُحَامِدِكَ تَرَادُفُ عَوَآئِدِكَ وَاَعْيَانِىْ عَنْ نَشْرِعَوَارِفِكَ تَوَالِىْ اَيَادِيْكَ وَهٰذَا مَقَامُ مَنِ اعْتَرَفَ بِسُبُوْغِ النَّعَمَآءِ وَقَابَلَهَا بِالتَّقْصِيْرِ وَشَهِدَ عَلٰى نَفْسِهٖ بِالْاِهْمَالِ وَالتَّضْيِيْعِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012346, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Thou art the Clement, the Compassionate, the Good, the Generous, who does not disappoint those who aim for Him, nor cast out from His courtyard those who expect from Him! In Thy yard are put down the saddlebags of the hopeful and in Thy plain stand the hopes of the help-seekers! So meet not our hopes by disappointing and disheartening and clothe us not in the shirt of despair and despondency!", "Gujarati": null, "RGujarati": null, "RUrdu": "Yahi maqaam hai us shakhs ka jo Teri neymato’n ka mo’tarif (qabool karne waala) hai, aur un par shukr se qaasir hai. Woh Apni is be-dhyaani (ghaflat) aur na-fikri (la-parvaayi) par khud hi gawah hai aur Tu hi woh shafeeq o maher-baan nek-naam sakhi hai jo apni bargah ka qasd karne waalo’n ko na-ummeed nahi karta, aur aarzoo-mando’n ko apne aastaane se dur nahi karta. Tere hi dar par ummeed-waaro’n ke kaarwa utar-te hai aur Tere hi maidaane sakhaawat mein taalebaane neymat ki tamannaye jagah paati hai. Pas hamari chaahato’n ke muqaable mein na-ummeedi o yaas (hopeless) na de. Aur hamein na-ummeedi aur pashe-maani ka pairahan na pehna.", "Urdu": "یہی مقام ہے اس شخص کا جو تیری نعمتوں کا معترف ہے اور ان پر شکر سے قاصر ہے وہ اپنی اس بے دھیانی اور نافکری پر خود ہی گواہ ہے اور تو ہی وہ شفیق و مہربان نیک نام سخی ہے جو اپنی درگاہ کا قصد کرنے والوں کو ناامید نہیں کرتا اور آرزومندوں کو اپنے آستانے سے دور نہیں کرتا تیرے ہی در پر امیدواروں کےکارواں اترتے ہیں اور تیرے ہی میدان میں طالبانِ نعمت کی تمنائیں جگہ پاتی ہیں پس ہماری چاہتوں کے مقابلے میں یاس و ناامیدی نہ دے اور ہمیں ناامیدی اور پشیمانی کا پیراہن نہ پہنا۔", "RArabic": null, "ArabicText1": "وَاَنْتَ الرَّؤُفُ الرَّحِيْمُ الْبَرُّ الْكَرِيْمُ الَّذِىْ لَا يُخَيِّبُ قَاصِدِيْهِ وَلَا يَطْرُدُ عَنْ فِنَآئِهٖ اٰمِلِيْهٖ بِسَاحَتِ تَحُطُّ رِحَالُ الرَّاجِيْنَ وَبِعَرْصَتِكَ تَقِفُ اٰمَالُ الْمُسْتَرْفِدِيْنَ فَلَا تُقَابِلْ اٰمَالَنَا بِالتَّخْيِيْبِ وَالْاِيَاسِ وَلَا تُلْبِسْنَا سِرْبَالَ الْقُنُوْطِ وَالْاِبْلَاسِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012347, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, my thanksgiving is small before Thy great boons, and my praise and news-spreading shrink beside Thy generosity toward me! Thy favours have wrapped me in the robes of the lights of faith, and the gentlenesses of Thy goodness have let down over me delicate curtains of might! Thy kindnesses have collared me with collars not to be moved and adorned me with neck-rings not to be broken! Thy boons are abundant - my tongue is too weak to count them!", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Mabood! Teri buzurg-tareen neymato’n ke saamne mera shukr o sepaas (thanks) heech (past/low) hai. Teri azmato’n ke muqaabil meri zabaan se Teri taarif o zikr be-maaya (be-maana) hai. Teri neymato’n ne mujhe imaan ke nooraani poshaako’n se dhaanp diya, aur Teri khush karne waali bhalaayi ne mujhe izzat ke taaj (crown) pehnaaye hai. Tu ne mujhe fakhr ke woh zewar pehnaaye jo utarte nahi aur gardan mein woh haar (neckless) daala jo toot-ta nahi.", "Urdu": "میرے معبود! تیری بزرگ تر نعمتوں کے سامنے میرا شکر و سپاس ہیچ ہےتیری عظمتوں کے مقابل میری زبان سے تیری تعریف و ذکر بے بضاعت ہے تیری نعمتوں نے مجھے ایمان کے نورانی پوشاکوں سے ڈھانپ دیا اور تیری خوش گوار بھلائیوں اور احسانات نے مجھے عزّت کے تاج پہنائے ہیں تو نے مجھے فخر کے وہ زیور پہنائے جو اترتےنہیں اور گردن میں وہ ہار ڈالا جو ٹوٹتا نہیں۔", "RArabic": null, "ArabicText1": "اِلٰهِىْ تَصَاغَرَ عِنْدَ تَعَاظُمِ اٰلَآئِكَ شُكْرِىْ وَتَضَآئَلَ فِىْ جَنْبِ اِكْرَامِكَ اِيَّاىَ ثَنَآئِىْ وَنَشْرِىْ جَلَّلَتْنِىْ نِعَمُكَ مِنْ اَنْوَارِ الْاِيْمَانِ حُلَلًا وَضَرَبَتْ عَلَيَّ لَطَائِفُ بِرِّكَ مِنَ الْعِزِّ كِلَلًا وَقَلَّدَتْنِىْ مِنَنُكَ قَلَآئِدَ لَا تُحَلُّ وَطَوَّقَتْنِىْ اَطْوَاقًا لَا تُفَلُّ فَاٰلَآئُكَ جَمَّهٌ ضَعُفَ لِسَانِىْ عَنْ اِحْصَآئِهَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012348, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Thy favours are many - my understanding falls short of grasping them, not to speak of exhausting them! So how can I achieve thanksgiving? For my thanking Thee requires thanksgiving. Whenever I say, ’To Thee belongs praise!’, it becomes thereby incumbent upon me to say, ’To Thee belongs praise’!", "Gujarati": null, "RGujarati": null, "RUrdu": "Teri maher-baaniya ziyadah hai meri zabaan unko shumaar karne se aajiz hai aur Teri neymate’n kaseer hai, mera fahem (samajh) unko samajh ne se qaasir hai. Che-jaaye keh unki tadaad ko jaan sake’n, to mai kaise maqaame shukr haasil karu keh mera shukr karna bhi mohtaaje shukr hai. To jab mai kahu keh Tere liye hamd hai, uske liye mujh par waajib hai keh mai kahu Tere liye hamd hai.", "Urdu": "تیری مہربانیاں زیادہ ہیں میری زبان ان کو شمار کرنے سے عاجز ہے اور تیری نعمتیں کثیر ہیں میرا فہم ان کو سمجھنے سے قاصر ہے چہ جائیکہ ان کی تعداد کو جان سکے تو میں کیسے مقام ِشکر حاصل کروں کہ میرا شکر کرنا بھی محتاج شکر ہے تو جب میں کہوں کہ تیرے لئے حمد ہے اس کے لئے مجھ پر واجب ہے کہ میں کہوں تیرے لئے حمد ہے۔", "RArabic": null, "ArabicText1": "وَنَعْمَآؤُكَ كَثِيْرَةٌ قَصُرَ فَهْمِىْ عَنْ اِدْرَاكِهَا فَضْلًا عَنِ اسْتِقْصَآئِهَا فَكَيْفَ لِىْ بِتَحْصِيْلِ الشُّكْرِ وَشُكْرِىْ اِيَّاكَ يَفْتَقِرُ اِلٰى شُكْرٍ۔ فَكُلَّمَا قُلْتُ لَكَ الْحَمْدُ وَجَبَ عَلَيَّ لِذَالِكَ اَنْ اَقُوْلَ لَكَ الْحَمْدُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012349, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, as Thou hast fed us through Thy gentleness and nurtured us through Thy benefaction, so also complete for us lavish favours, repel from us detested acts of vengeance, and of the shares of the two abodes, give us their most elevated and their greatest, both the immediate and the deferred! To Thee belongs praise for Thy good trial and the lavishness of Thy favours, a praise conforming to Thy good pleasure and attracting Thy great goodness and magnanimity. O All-mighty, O All-generous! By Thy mercy, O Most Merciful of the merciful!", "Gujarati": null, "RGujarati": null, "RUrdu": "Pas jaise Tu ne hamein apne lutf se ghiza (food) di aur apne ehsaan se parwarish ki hai to ham par apni kaseer neymate’n bhi tamaam farma. Aur azaab ki sakhtiya ham se dur kar de, aur hamein duniya o aakherat mein behtar aur bishtar (bohot ziyada) hissa ataa farma, ab bhi aur tab bhi. Tere liye hamd hai Teri behtareen aazmaaish aur kaseer neymato’n par aisi hamd jo Teri raza ke mowaafiq o motaabiq ho. Aur Tere azeem ehsaan o bakhshish ko haasil kare, ay Azeem ay Karim Teri rehmat ka waasta ay sabse ziyadah rahem karne waale.", "Urdu": "پس جیسے تو نے ہمیں اپنے لطف سے غذا دی اور اپنے احسان سے پرورش کی ہے تو ہم پر اپنی کثیر نعمتیں بھی تمام فرما اور عذاب کی سختیاں ہم سے دور کردے اور ہمیں دنیا و آخرت میں بہتر اور بیشتر حصہ عطا فرمااب بھی اور تب بھی تیرے لئے حمد ہے تیری بہترین آزمائش اور کثیر نعمتوں پرایسی حمد جو تیری رضا کے موافق ہو اور تیرے عظیم احسان و بخشش کو حاصل کرے اے عظیم اے کریم تیری رحمت کا واسطہ اے سب سے زیادہ رحم کرنے والے۔", "RArabic": null, "ArabicText1": "اِلٰهِىْ فَكَمَا غَذَّيْتَـنَا بِلُطْفِكَ وَرَبَّيْتَـنَا بِصُنْعِكَ فَتَمِّمْ عَلَيْنَا سَوَابِغَ النِّعَمِ وَادْفَعْ عَنَّا مَكَارِهَ النِّقَمِ وَاٰتِنَا مِنْ حُظُوْظِ الدَّارَيْنِ اَرْفَعَهَا وَاَجَلَّهَا عَاجِلًا وَّاجِلًا۔ وَلَكَ الْحَمْدُ عَلٰى حُسْنِ بَلَآئِكَ وَسُبُوْغِ نَعْمَآئِكَ حَمْدًا يُّوَافِقُ رِضَاكَ وَيَمْتَرِى الْعَظِيْمَ مِنْۢ بِرِّكَ وَنَدَاكَ يَاعَظِيْمُ يَاكَرِيْمُ بِرَحْمَتِكَ يآاَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) choicest blessings be upon Mohammed and his holy progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar Tu rehmat naaz