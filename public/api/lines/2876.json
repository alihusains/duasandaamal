, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012754, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap logo’n ke jad’e buzurg-waar Mustafa (s.a.w.a) par. Salaam ho aap logo’n ke pidar’e buzurg-waar Murtaza (a.s) par jo mukammal raza thay. Salaam ho do (2) sardaaro’n Hasan (a.s) aur Husain (a.s) par. Salaam ho Ummul Momeneen Janabe Khadija (s.a) par jo aalameen ke aurto’n ki sardaar ki maadar’e giraami hai. Salaam ho paak o paakeeza Imamo ki maa Fatema Zahra (s.a) par.", "Urdu": "سلام ہو آپ لوگوں کے جد بزرگوار مصطفیؐ پر، سلام ہو آپ لوگوں کے پیدبزرگوار مررتضٰی جو مکمل رضی تھے، سلام ہو دو سرداروں حسنؑ اور حسینؑ پر، سلام ہو ام المومنین جناب خدیجہؑ پع جو عالمین کی عورتوں کی سردار کی مدر گرامی ہیں، سلام ہو پاک و پاکیزہ اماموں کی ماں فاطمہ زہراؑ پر۔", "RArabic": "ASSALAAMO A’LAA JADDEKOMUL MUSTAFAA ASSALAAMO A’LAA ABEEKOMUL MURTAZAR REZAA ASSALAAMO A’LAS SAYYEDAYNIL HASANE WAL HUSAYNE ASSALAAMO A’LAA KHADEEJATA UMMIL MOAMENEENA UMME SAYYEDATE NESAAA-IL A’ALAMEENA ASSALAAMO A’LAA FAATEMATA UMMIL A-IMMATIT TAAHEREENA.", "ArabicText1": "اَلسَّلَامُ عَلٰی جَدِّكُمُ الْمُصْطَفٰی۔ اَلسَّلَامُ عَلٰی اَبِیْكُمُ الْمُرْتَضَی الرِّضَا۔ اَلسَّلَامُ عَلَی السَّیِّدَیْنِ الْحَسَنِ وَالْحُسَیْنِ۔ اَلسَّلَامُ عَلٰی خَدِیْجَۃَ اُمِّ الْمُؤْمِنِیْنَ اُمِّ سَیِّدَۃِ نِسَآئِ الْعَالَمِیْنَ۔ اَلسَّلَامُ عَلٰی فَاطِمَۃَ اُمِّ الْاَئِمَّۃِ الطَّاہِرِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012755, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho achchhe nafoos par jo kaseer ilm ke samandar hai, woh aakherat mein meri shafa’at karne waale hai aur jab rooh bosidah haddiyo’n ki tarah (qayaamat mein) paltegi to woh log mere auliya hai aur haq ke wali hai. Salaam ho aap logo’n par ay shareef, taaher aur kareem ashkhaas (zaat).", "Urdu": "سلام ہو اچھے نفرس پر جو کثیر علم کے سمندر ہیں، وہ آخرت میں میری شفاعت کرنے والے ہیں اور جب روح بوسیدہ ہڈیوں کی طرف (قیا مت میں) پلٹے گی تو وہ لوگ میرے اولیا ہیں اور حق کے ولی ہیں، سلام ہو آپ لوگوں پر اے شریف، طاہر اور کریم اشخاص۔", "RArabic": "ASSALAAMO A’LAN NOFOOSIL FAAKHERATE BOHOORIL O’OLOOMIZ ZAAKHERATE SHOFA-A’AA-E FIL AAKHERATE WA AWLEYAAA-EE I’NDA A’WDIR RROHE ELAL E’ZAAMIN NAKHERATE A-IMMATIL KAHLQE WA WOLAATIL HAQQE ASSALAAMO A’LAYKUM AYYOHAL ASHKHAASUSH SHAREEFATUT TAAHERATUL KAREEMATO.", "ArabicText1": "اَلسَّلَامُ عَلَی النُّفُوْسِ الْفَاخِرَۃِ بُحُوْرِ الْعُلُوْمِ الزَّاخِرَۃِ شُفَعَآئِ فِیْ الْآخِرَۃِ وَاَوْلِیَآئِیْ عِنْدَ عَوْدِ الرُّوْحِ اِلَی الْعِظَامِ النَّخِرَۃِ اَئِمَّۃِ الْخَلْقِ وَ وُلَاۃِ الْحَقِّ۔ اَلسَّلَامُ عَلَیْكُمْ اَیُّہَا الْاَشْخَاصُ الشَّرِیْفَۃُ الطَّاہِرَۃُ الْكَرِیْمَۃُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012756, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawahi deta hu keh siwaaye Khuda ke koi ma’bood nahi hai aur yeh keh Muhammad (s.a.w.a) Uske bande aur Uske muntakhab (chune huwe) hai aur Ali (a.s) Allah ke wali hai aur uske chune huwe bande hai aur yeh keh Imaamat (qayaamat tak) unki aulaad mein hai. Yeh baat ham ilm-ul-yaqeen se jaante hai aur usi ka eteqaad rakhte hai aur unki madad karne mein koshish karne waale hai.", "Urdu": "میں گواہی دیتا ہوں کہ سوائے خدا کے کوئی معبود نہیں ہے اور یہ کہ محمدؐ اس کے بندے اور اس کے منتخب ہیں اور علیؑ اللہ کے ولی ہیں اور اس کے چنے ہوئے بندے ہیں اور یہ کہ امامت (ویامت تک) ان کی اولاد میں ہے، یہ بات ہم علم الیقین سے جانتے ہیں اور اسی کا اعتقاد رکھتے ہیں اور ان کی مدد کرنے میں کوشش کرنے والے ہیں۔", "RArabic": "ASH-HADO AN LAA ELAAHA ILLAL 