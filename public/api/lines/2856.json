بڑے رحم والا ہے اور عرش پر مسلط ہے اے وہ جس کی مثل کوئی چیز نہیں ہے اور وہ سننے دیکھنے والا ہے سوال کرتا ہوں تجھ سے کہ محمدؐ و آل محمدؐ پر رحمت نازل فرما۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA YAA MAN HOWA AQRA-BO ELAIYYA MIN HABLIL WAREE-DE YAA MAN YAHOO-LO BAIY-NAL MAR-E WA QALBE-HI YAA MAN HOWA BIL MANZA-RIL A’LAA WA BIL OFO-QIL MOBEENE YAA MAN HOWAR RAHMAANO A’LAL A’R-SHIS TAWAA YAA MAN LAISA KA-MISLE-HI SHAI-OON WA HO-WAS SAMEE-U’L BASEERO AS-ALOKA AN TO-SALLEYA A’LAA MOHAMMADIW WA AALE MOHAMMADIN.", "ArabicText1": "اَللّٰھُمَّ اِنِّیْ اَسْئَلُکَ یَامَنْ ھُوَ اَقْرَبُ اِلَیَّ مِنْ حَبْلِ الْوَرِیْدِ یَامَنْ یَّحُوْلُ بَیْنَ الْمَرْئِ وَقَلْبِہٖ یَامَنْ ھُوَ بِالْمَنْظَرِ الْاَعْلٰی وَبِالْاُفُقِ الْمُبِیْنِ یَامَنْ ھُوَ الرَّحْمٰنُ عَلَی الْعَرْشِ اسْتَوٰی یَامَنْ لَیْسَ کَمِثْلِہٖ شَيْٓءٌ وَھُوَ السَّمِیْعُ الْبَصِیْرُ اَسْئَلُکَ اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "Arabi