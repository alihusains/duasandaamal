[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018713, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He, whose generosity and mercy increases by the plea of the seekers. O He who possess the kingdom of the Heavens and the skies, O He to whom belongs the apparent and visible treasures. My sins does not curtail Your obligations. I plead with You to deal with one in a way which befits You because You are possessor of generosity, mercy and forgiveness. O Lord! O Lord! You have the power to punish. O Lord! I have become liable for Your punishment, now I don't have any excuse which I may put forth, nor any love which can be forwarded. I have submitted all my transactions in Your presence and I confess that You forgive me and You are more aware of all the things better than me, all the sins and evils which I commit is presented to You. Therefore forgive me and have mercy on me and whatever is in Your knowledge forgive me because surely You are the most honoured and exalted.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay woh keh faryaadiyo’n ki faryaad jis ki sakhaawat o karam mein ziyaadati karti hai, ay woh keh aasmaan o zameen ke khazaane jis ki milkiyat mein hai, ay woh keh poshidah o roshan khazaane jis ki milkiyat mein hai, meri badee (buraayi) Tere ehsaan ko nahin rokti, mai dar-khwaast karta hu keh mere saath woh sulook farma jis ka Tu ahel hai kyu’n keh Tu saaheb’e sakhaawat o karam o maafi hai. Ay Parwardigaar, ay Parwardigaar! Tu hi saza dene par qaadir hai, ay Parwardigaar! Mai Tere azaab ka mustahaq ho chuka hu. Ab mere paas na koi uzr (excuse) hai na Tere huzoor mein pesh karne ki koi hujjat (daleel), mai ne apne tamaam maamelaat Teri panah mein de diye, mai eteraaf karta hu keh Tu maaf farma de aur Tu to sab baate’n mujh se behtar jaanta hai. Teri baargah mein tamaam woh gunah aur khataaye’n aur badeeya (buraaiya’n) pesh hoti hai. Jo mai baja laaya (anjaam diya) hu. Lehaaza mujhe bakhsh de, aur rahem farma, aur jo bhi Tere ilm mein hai usey maaf farma de, kyu’n keh bila-shubah (yaqeenan) Tu sab se ziyadah ba-izzat o ikraam (mohtaram) hai.", "Urdu": "اے وہ کہ فریادیوں کی فریاد جس کی سخاوت و کرم میں زیادتی کرتی ہے، اے وہ کہ آسمان و زمین کے خزانے جس کی ملکیت میں ہیں، اے وہ کہ پوشیدہ و روشن خزانے جس کی ملکیا میں ہیں، میری بدی تیرے احسان کو نہیں روکتی، میں درخاوست کرتا ہوں کہ میرے ساتھ وہ سلوک فرما جس کا تو اہل ہے کیونکہ تو صاحبِ سخاوت و کرم و معافی ہے۔ اے پروردگار! اے پروردگار! توہی سزا دینے پر قادر ہے، اے پروردگار! میں تیرے عذاب کا مستحق ہو چکا ہوں، اب میرے پاس نہ کوئی عذر ہے نہ تیرے حضور میں پیش کرنے کی کوئی حجت، میں نے اپنے تمام معاملات تیری پناہ میں دے دیئے، میں اعتراف کرتا ہوں کہ تو معاف فرما دے اور تو تو سب باتیں مجھ سے پہتر جانتا ہے۔ تیری بارگاہ میں تمام وہ گناہ اور خطائیں اور بدیاں پیش ہوتی ہیں، جو میں بجا لایا ہوں۔ لہذا مجھے بخش دے، اور رحم فرما اور جو بھی تیرے علم میں ہے اسے معاف فرما دے کیونکہ بلا شبہ تو سب سے زیادہ باعزّت و اکرام ہے۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "یَا مَنْ لَّا یَزِیْدُهٗ اِلْحَاحُ الْمُلِحِّیْنَ اِلَّا جُوْدًا وَكَرَمًا یَا مَنْ لَهٗ خَزَاۗئِنُ السَّمٰوٰتِ وَالْاَرْضِ یَا مَنْ لَهٗ خَزَاۗئِنُ مَادَقَّ وَجَلَّ لَا تَمْنَعُكَ اِسَاۗئَتِیْ مِنْ اِحْسَانِكَ اَسْئَلُكَ اَنْ تَفْعَلْ بِیْ مَا اَنْتَ اَهْلَهٗ فَاَنْتَ اَهْلُ الْجُوْدِ وَالْكَرَمِ وَالْعَفْوِ یَا رَبِّ وَاَنْتَ قَادِرٌ عَلَی الْعُقُوْبَۃِ یَا رَبِّ وَقَدِ اسْتَحْقَقْتُهَا لَا حُجَّۃَ لِیْ وَلَا عُذْرَلِیْ عِنْدَكَ اِلَیْكَ اَلْجَاتُ اُمُوْرِیْ كُلَّهَا اَعْتَرِفُ بِهَا كَیْ تَعْفُوَ عَنِّیْ وَاَنْتَ اَعْلَمُ بِهَا مِنِّیْ یُؤْتَ اِلَیْكَ بِكُلِّ ذَنْۢبٍ اَذْنَبْتُهٗ وَبِكُلِّ خَطِیْۗئَۃٍ اَخْطَاتُهَا وَبِكُلِّ سَیِّئَۃٍ عَمِلْتُهَا فَاغْفِرْ وَارْحَمْ وَتَجَاوَزَ عَمَّا تَعْلَمُ اِنَّكَ اَنْتَ الْاَعَزُّ الْاَكْرَمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": 