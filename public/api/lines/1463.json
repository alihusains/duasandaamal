[{"Id": 1010147, "EnglishTitle": "Tuesday has been assigned to Imam Sajjad (a), Imam Baqir (a) & Imam Sadiq (a)", "GujaratiTitle": null, "RUrduTitle": "Tuesday Imam Sajjad (a), Imam Baqir (a) aur Imam Sadiq (a) se mansoob hai.", "UrduTitle": "منگل امام زین العابدین (ع)،امام محمد باق (ع)ر اور امام جعفر صادق (ع)کا دن ہے لہازا ان کی یہ زیارت پڑھیں۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010427, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on you, O depositories of Allah’s knowledge! Peace be on you, O interpreters of Allah’s Revelation! Peace be on you, O leaders to true guidance! Peace be on you, O signs of piety! Peace be on you, O descendants of Allah’s Messenger! I recognize your rights, I discernibly acknowledge your true standing, I incur the hostility of your enemies, and I show loyalty to your loyalists. May Allah accept me, my father, and mother as ransoms for you! Blessings of Allah be upon you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay ilm’e Khuda ke khazaane daaro’n. Salaam ho aap par ay wahi’e ilaahi ke tarjumaano! Salaam ho aap par ay peshwa’e hidaayat. Salaam ho aap par ay taqwe ke parchamo. Salaam ho aap par ay Rasoole Khuda ke farzando’n. Mai aap ke haq ka irfaan aur aap ki shaan o shaukat ki basirat rakhta hu. Aap ke dushmano ka dushman aur aap ke dosto’n ka dost hu aap par mere maa baap qurbaan ho aur (aap par) Allah ki rehmato’n ka nuzool ho.", "Urdu": "سلام ہو آپ پر جو علمِ الہٰی کے خزانہ دار ہیں،سلام ہو آپ پر جو وحیِ خدا کے ترجمان ہیں، آپ پر سلام ہو جو ہدایت دینے والے امام ہیں، آپ پر سلام ہو جو تقویٰ کے نشان ہیں، آپ پر سلام ہو جو رسولؐ خدا کے فرزند ہیں، میں آپ کے حق کو جانتا ہوں آپ کی شان کو سمجھتا ہوں آپ کے دشمنوں کا دشمن ہوں آپ کے دوستوں کا دوست ہوں میرے ماں باپ آپ پر قربان! آپ پر خدا کی رحمتیں ہوں!", "RArabic": "ASSALAAMO A’LAYKUM YAA KHUZZAANA I’LMIL LAAHE ASSALAAMO A’LAYKUM YAA TARAAJEMATA WAHYIL LAAHE ASSALAAMO A’LAYKUM YAA A-IMMATAL HODAA ASSALAAMO A’LAYKUM YAA AA’LAAMAT TOQAA ASSALAAMO A’LAYKUM YAA AWLAADA RASOOLIL LAAHE ANAA A’AREFUN BE HAQQEKUM MUSTABSERUN BE SHAANEKUM MOA’ADIN LE AA’DAAAEKUM MOWAALIN LE AWLEYAAAEIKUM BE ABEE ANTUM WA UMMEE SALAWAATUL LAAHE A’LAYKUM.", "ArabicText1": "اَلسَّلَامُ عَلَیْکُمْ یَاخُزَّانَ عِلْمِ اللہِ۔ اَلسَّلَامُ عَلَیْکُمْ یَاتَرَاجِمَۃَ وَحْیِ اللہِ۔ اَلسَّلَامُ عَلَیْکُمْ یَااَئِمَّۃَ الْھُدٰی۔ اَلسَّلَامُ عَلَیْکُمْ یَااَعْلَامَ الْتُّقٰی۔ اَلسَّلَامُ عَلَیْکُمْ یَااَوْلَادَ رَسُوْلِ اللہِ اَنَا عَارِفٌ بِحَقِّکُمْ مُسْتَبْصِرٌۢ بِشَانِکُمْ مُعَادٍ لِّاَعْدَآئِکُمْ مُوَالٍ لِّاَوْلِیَآئِکُمْ بِاَبِیْ اَنْتُمْ وَاُمِّیْ صَلَوَاتُ اللہِ عَلَیْکُمْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010428, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I am willingly showing loyalty to the last of them just as I have shown loyalty to the first of them, I release myself from any confidant other than them, and I reject all idols, false deities, al-Lat, and al-`Uzza. Blessings of Allah be upon you, O my Masters! Mercy of Allah and His benedictions be upon you, too. Peace be upon you, O master of the worshippers and descendant of the Prophets’ successors.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar! Inke awwal ki tarah inke aakhir ko bhi dost rakhta hu aur inke agyaar (dushmano) ki mohabbat se bari hu aur mai har sar-kash, taaghoot aur Laat o Uzza se inkaar karta hu. Ay mere aqaa’o aap par Allah ka durood aur uski rehmate’n aur barkate’n naazil ho. Salaam ho aap par ay ibaadat guzaaro’n ke sardaar, aur ausiya ke khaandaan.", "Urdu": "اے معبود! میں ان کے آخری سے ایسی محبت رکھتا ہوں جیسی ان کے اول سے ہے اور ان کے مقابل ہر گروہ سے دور ہوں اور جادوگر طاغوت اور لات وعزیٰ کا انکار کرتا ہوں اے میرے سردارو! آپ پر خدا کی رحمت اور برکت ہو، آپ پر سلام ہو اے عابدوں کے سردار اور وصیوں کی اصل۔", "RArabic": "ALLAAHUMMA INNEE ATAWAALAA AAKHERAHUM KAMAA TAWAALAYTO AWWALAHUM WA ABRAO MIN KULLE WALEEJATIN DOONAHUM WA AKFORO BIL JIBTE WAT TAAGHOOTE WAL LAATE WAL UZZAA SALAWAATUL LAAHE A’LAYKUM YAA MAWAALIYYA WA RAHMATUL LAAHE WA BARAKAATOHU ASSALAAMO A’LAYKA YAA SAYYEDAL A’ABEDEEDA WA SOLAALATAL WASIYYEENA.", "ArabicText1": "اَللّٰھُمَّ اِنِّیْ اَتَوَالٰی اٰخِرَھُمْ کَمَا تَوَالَیْتُ اَوَّلَھُمْ وَاَبْرَئُ مِنْ کُلِّ وَلِیْجَۃٍ دُوْنَھُمْ وَاَکْفُرُ بِالْجِبْتِ وَالطَّاغُوْتِ وَاللّٰاتِ وَالْعُزّٰی صَلَوَاتُ اللہِ عَلَیْکُمْ یَامَوَالِیَّ وَرَحْمَۃُ اللہِ وَبَرَکَاْتُہٗ۔ اَلسَّلَامُ عَلَیْکَ یَاسَیِّدَ الْعَابِدِیْنَ وَسُلَالَۃَ الْوَصِیِّیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010148, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O he who split open the knowledge of the Prophets. Peace be upon you, O veracious and honest in all [your] words and deeds. O my Masters! Today is your day, which is Tuesday, and on this day, I am your guest and I am in your vicinity; so, receive me as your guest and treat me as your neighbor, [I ask you] by Allah’s standing with you and with your Household, the pure and immaculate.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay nabiyo’n ke ilm ko shighaaf karne waale. Salaam ho aap par ay saheb'e sadaaqat (apne) qaul o faiyl mein musdiq. Ay mere sar-parasto’n yeh Seh-Shamba (Tuesday) ka din aap ka din hai aur mai aap hazraat ka mehmaan hu aur aap ki panah ka taalib hu, pas aap ko Khuda ki us manzelat ka waasta jo uski manzelat aap aur aap ke tayyab o taahir ghar waalo’n ke nazdik hai, meri mehmaan nawazi kijiye aur mujhe panah dijiye.", "Urdu": "آپ پر سلام ہو اے انبیاء کے علم کو ظاہر کرنے والے آپ پر سلام ہو اے وہ صادق جس کی تصدیق اس کے قول و فعل میں کی گئی۔ اے میرے تینوں سردارو! یہ منگل والا دن، آپ کا دن ہے اور میں اس میں آپ کا مہمان ہوں اور آپ کی پناہ میں ہوں لہٰذا آپ میری مہمانوازی کیجیے اور مجھے پناہ دیجیے خدا کے اس مقام کے واسطے جو آپ کے نزدیک ہے اور اپنے پاک و پاکیزہ خاندان کے واسطے سے۔", "RArabic": "ASSALAAMO A’LAYKA YAA BAAQERA I’LMIN NABIYYEENA ASSALAAMO A’LAYKA YAA SAADEQAN MOSADDAQAN FIL QAWLE WAL FE’LE YAA MAWAALIYYA HAAZAA YAWMOKUM WA HOWA YAWMUS SOLASAAA-E WA ANAA FEEHE ZAYFUN LAKUM WA MUSTAJEERUN BEKUM FA AZEEFOONEE WA AJEEROONEE BE MANZELATIL LAAHE I’NDAKUM WA AALE BAYTEKOMUT TAYYEBEENAT TAAHEREENA.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ یَابَاقِرَ عِلْمِ النَّبِیِّیْنَ۔ اَلسَّلَامُ عَلَیْکَ یَاصَادِقًا مُّصَدَّقًا فِیْ القَوْلِ وَالْفِعْلِ یَامَوَالِیَّ ھٰذَا یَوْمُکُمْ وَھُوَ یَوْمُ الثُّلَثَآئِ وَاَنَا فِیْہِ ضَیْفٌ لَّکُمْ وَمُسْتَجِیْرٌۢ بِکُمْ فَاَضِیْفُوْنِیْ وَاَجِیْرُوْنِیْ بِمَنْزِلَۃِ اللہِ عِنْدَکُمْ وَآلِ بَیْتِکُمُ الطَّیِّبِیْنَ الطَّاھِرِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": n