[{"Id": 1000485, "EnglishTitle": "The Whispered Prayer of the Rememberers (Zakereen)…", "GujaratiTitle": null, "RUrduTitle": "Aarifo’n ki Munajaat…", "UrduTitle": "تیرہویں مناجات مناجاتِ ذاکرین۔۔۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000486, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, were it not incumbent to accept Thy command, I would declare Thee far too exalted for me to remember Thee, for I remember Thee in my measure, not in Thy measure, and my scope can hardly reach the point where I may be a locus for calling Thee holy! Among Thy greatest favours to us is the running of Thy remembrance across our tongues and Thy permission to us to supplicate Thee, declare Thee exalted, and call Thee holy!", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Mabood! Agar Tera hukm maan na waajib na hota to mai Tera zikr apni zabaan par na laata, kyu’n keh mai Tera jo zikr karta hu woh mere andaaze se hai na keh Tere shaan ke mutabik. Aur meri kya be-saat (auqaat) keh mai Teri taqdees o paakeezgi ka mahel qaraar pa saku. Yeh cheez ham par Teri azeem neymato’n mein se hai keh Tera zikr hamari zabaano par jaari hai. Aur hamein Tujh se dua maangne aur Teri paakeezgi o nizaafat bayaan karne ki ijazat hai.", "Urdu": "خدا کے نام سے شروع جو بڑا مہربان نہایت رحم والا ہے۔میرے معبود!اگر تیرا حکم ماننا واجب نہ ہوتا تو میں تیرا ذکر اپنی زبان پر نہ لاتا کیوں کہ میں تیرا جو ذکر کرتا ہوں وہ میرے اندازے سے ہے نہ تیری شان کے مطابق اور میری کیا بساط کہ میں تیری تقدیس و پاکیزگی کا محل قرار پا سکوں یہ چیز ہم پر تیری عظیم نعمتوں میں سے ہے کہ تیرا ذکر ہماری زبانوں پر جاری ہے اور ہمیں تجھ سے دعا مانگنے اور تیری پاک و پاکیزگی بیان کرنے کی اجازت ہے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اِلٰهِىْ لَوْلَا الْوَاجِبُ مِنْ قَبُوْلِ اَمْرِكَ لَنَزَّهْتُكَ مِنْ ذِكْرِىْ اِيَّاكَ عَلٰى اَنَّ ذِكْرِىْ لَكَ بِقَدْرِىْ لَا بِقَدْرِكَ وَمَا عَسٰى اَنْ يَّبْلُغَ مِقْدَارِىْ حَتّٰى اَجْعَلَ مَحَّلًا لِّتَقْدِيْسِيْكَ وَمِنْ اَعْظَمِ النِّعَمِ عَلَيْنَا جَرَيَانُ ذِكْرِكَ عَلٰۤى اَلْسِنَتِنَا وَاِذْنُكَ لَنَا بِدُعَآئِكَ وَتَنْزِيْهِكَ وَتَسْبِيْحِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012369, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, inspire us with Thy remembrance alone and in assemblies, by night and day, publicly and secretly, in prosperity and adversity! Make us intimate with silent remembrance, employ us in purified works and effort pleasing to Thee, and reward us with the full balance!", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Mabood! Hamein Apne zikr ki taufiq de, keh ham neha aur ayaa (chhup kar aur zaaheri taur par) raat-din zaahir o baatin aur khushi o ghami mein Tera zikr kiya kare.", "Urdu": "میرے معبود ہمیں اپنے ذکر کی توفیق دے کہ ہم پوشیدہ اور ظاہر، رات اور دن، ظاہر و باطن اورخوشی و غمی میں تیرا ذکر کیا کریں۔", "RArabic": null, "ArabicText1": "اِلٰهِىْ فَاَلْهِمْنَا ذِكْرَكَ فِى الْخَلَآءِ وَالْمَلَآءِ وَاللَّيْلِ وَالنَّهَارِ وَالْاِعْلَانِ وَالْاِسْرَارِ وَفِى السَّرَّآءِ وَالضَّرَّآءِ وَاٰنِسْنَا بِالذِّكْرِا لْخَفِىِّ وَاسْتَعْمِلْنَا بِالْعَلِىِّ الزَّكِىِّ وَالسَّعْىِ الْمَرْضِىِّ وَجَازِنَا بِالْمِيْزَانِ الْوَفِىِّ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012370, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, love-mad hearts are enraptured by Thee, disparate intellects are brought together by knowing Thee, hearts find no serenity except in remembering Thee, souls find no rest except in seeing Thee.", "Gujarati": null, "RGujarati": null, "RUrdu": "Hamein Apne poshida zikr se maanoos farma, hamein paakeeza amal aur Apne pasandida koshish mein laga, aur (poore insaaf se) mizaane amal se hamein jaza de, mera mohabbat bhara dil Tujh se lagaaw rakkhe huwe hai, Teri maarefat mein mukhtaalif qism ki aqle ittefaaq rakhti hai. Pas dil ko chain o sukoon nahi milta magar Tere zikr se aur Teri zaat par yaqeen se nafso’n ko sukoon milta hai.", "Urdu": "ہمیں اپنے پوشیدہ ذکر سے مانوس فرما ہمیں پاکیزہ عمل اور پسندیدہ کوشش میں لگا اور پوری میزان سے ہمیں جزا دے میرا محبت بھرا دل تجھ سے لگاؤ رکھے ہوئے ہے تیری معرفت میں مختلف قسم کی عقلیں اتفاق رکھتی ہیں پس دل چین نہیں پکڑتے مگر تیرے ذکر سے اور تیری ذات پر یقین سے نفسوں کو سکون ملتا ہے۔", "RArabic": null, "ArabicText1": "اِلٰهِىْ بِكَ هَامَتِ الْقُلُوْبُ الْوَالِهَةُ وَعَلٰى مَعْرِفَتِكَ جُمِعَتِ الْعُقُوْلُ الْمُتَبَايِنَةُ فَلَا تَطْمَئِنُّ الْقُلُوْبُ اِلَّا بِذِكْرَاكَ وَلَا تَسْكُنُ النُّفُوْسُ اِلَّا عِنْدَ رُؤْيَاكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012371, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Thou art the glorified in every place, the worshipped at every time, the found at every moment, the called by every tongue, the magnified in every heart! I pray forgiveness from Thee for every pleasure but remembering Thee, every ease but intimacy with Thee, every happiness but nearness to Thee, every occupation but obeying Thee!", "Gujarati": null, "RGujarati": null, "RUrdu": "Tu hi hai jiski tasbeeh har jagah hoti hai, aur jo har zamaane mein Mabood hai. Aur har waqt har jagah maujood hai aur har zabaan se pukaara jaata hai aur har dil mein Teri azmat qaayem hai. Mai maafi chahta hu Tujh se Tere zikr ke siwa har lazzat se, Teri mohabbat ke siwa har raahat se, Teri qurbat ke siwa har khushi par. Aur maafi chahta hu Tujh se Teri ita’at ke siwa har kaam se.", "Urdu": "تو ہی ہے جس کی تسبیح ہر جگہ ہوتی ہے اور جو ہر زمانے میں معبود ہے اور ہروقت ہر جگہ موجود ہے اور ہر زبان سے پکارا جاتا ہے اور ہر دل میں تیری عظمت قائم ہے میں معافی چاہتاہوں تجھ سے تیرے ذکر کے سوا ہر لذت سے تیری محبت کے سوا ہر راحت سے تیری قربت کے سوا ہر خوشی پر اور معافی چاہتا ہوں تجھ سے تیری اطاعت کے سوا ہر کام سے۔", "RArabic": null, "ArabicText1": "اَنْتَ الْمُسَبَّحُ كُلِّ مَكَانٍ وَّالْمَعْبُوْدُ فِىْ كُلِّ زَمَانٍ وَّالْمَوْجُوْدُ فِىْ كُلِّ اَوَانٍ وَّالْمَدْعُوُّ بِكُلِّ لِسَانٍ وَّالْمُعَظَّمُ فِىْ كُلِّ جَنَانٍ۔ وَاَسْتَغْفِرُكَ مِنْ كُلِّ لَذَّةٍۢ بِغَيْرِ ذِكْرِكَ وَمِنْ كُلِّ رَاحَةٍۢ بِغَيْرِ اُنْسِكَ وَمِنْ كُلِّ سُرُوْرٍۢ بِغَيْرِ قُرْبِكَ وَمِنْ كُلِّ شُغْلٍۢ بِغَيْرِ طَاعَتِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012372, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, Thou hast said - and Thy word is true - O you who have faith, remember God with much remembrance and glorify Him at dawn and in the evening! Thou hast said - and Thy word is true - Remember Me, and I will remember you! Thou hast commanded us to remember Thee, and promised us that Thou wilt remember us thereby, in order to ennoble, respect, and honour us. Here we are, remembering Thee as Thou hast commanded us! So accomplish what Thou hast promised, O Rememberer of the rememberers! O Most Merciful of the merciful!", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Mabood! Tu ne hi kaha hai aur Tera qaul haq hai keh “Ay imaan laane waalo’n zikr karo Allah ka bohot ziyadah zikr aur subah o shaam uski paakeezgi bayaan karo”. Neez (also) Tu ne hi kaha aur Tera qaul sachcha hai “Pas Tum Mujhe yaad karo (to) Mai tumhe yaad karunga”. Tu ne hamein Apni yaad ka hukm diya aur ham se waada kiya is par keh Tu bhi hamein yaad karega. Yeh hamare liye sharaf o ehteraam aur badaayi (fakhr ki baat) hai, to ab ham Tujhe yaad kar rahe hai, jaise Tu ne hukm diya hai. Pas Tu bhi ham se kiya huwa waada pura kar. Ay yaad karne waalo’n ko yaad karne waale, aur ay sabse ziyadah rahem karne waale.", "Urdu": "میرے معبود تو نے ہی کہا ہے اور تیرا قول حق ہے کہ اے ایمان لانے والو! ذکر کرو اللہ کا بہت زیادہ ذکر اور صبح و شام اس کی پاکیزگی بیان کرو نیز تو نے ہی کہا اور تیرا قول حق ہے پس تم مجھے یاد کرو میں تمہیں یاد کروں گا تو نے ہمیں اپنی یاد کا حکم دیا اور ہم سے وعدہ کیا اس پرکہ تو بھی ہمیں یاد کرے گا یہ ہمارے لئے شرف و احترام اور بڑائی ہے تو اب ہم تجھے یاد کررہے ہیں جیسے تو نے حکم دیا ہے پس تو بھی ہم سے کیا ہوا وعدہ پورا کر اے یاد کرنے والوں کو یاد کرنے والے اور اے سب سے زیادہ رحم کرنے والے۔", "RArabic": null, "ArabicText1": "اِلٰهِىْ اَنْتَ قُلْتَ وَقُوْلَكَ الْحَقُّ يَآاَيُّهَا الَّذِيْنَ اٰمَنُوْا اَذْكُرُوا اللهَ ذِكْرًا كَثِيْرًا وَّسَبِّحُوْهُ بُكْرَةً وَّاَصِيْلًا وَّقُلْتَ وَقَوْلُكَ الْحَقُّ فَاذْكُرُوْنِىْ اَذْكُرْكُمْ فَاَمَرْتَنَا بِذِكْرِكَ وَوَعَدْتَنَا عَلَيْهِ اَنْ تَذْكُرَنَا تَشْرِيْفًا لَنَا وَتَفْخِيْمًا وَّاِعْظَامًا۔ وَهَا نَحْنُ ذَاكِرُوْكَ كَمَا اَمَرْتَنَا فَاَنْجِزْ لَنَا مَا وَعَدْتَنَا يَاذَاكِرَ الذَّاكِرِيْنَ وَيَآ اَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicTex