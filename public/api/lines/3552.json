 WA HUSNAA NA-A’SHAT-NEE WA AS-ALOHO ITMAA-MAB TEDAA-E-HI WA ZIYAA-DATAN LEE MENIJ TABAA-E-HI FA-INNA-HUL MALEE-KUL QADEERO WA SALLAL LAAHO A’LAA MOHAMMADIW WA AALE-HI WA SALLAMA KASEE-RAN.", "ArabicText1": "لَا بَقَاۗءَ وَلَا دَوَامَ اِلَّا لَهُ الْوَاحِدُ الْغَالِبُ الَّذِيْ لَا يُغْلَبُ وَالْمَالِكُ الَّذِيْ لَا يُمْلَكُ الْحَمْدُ لِلهِ الَّذِيْ بَلَّغَنِيْكِ (بَلَّغَنِيْ) لَيْلَةً طَوَيْتُ يَوْمَهَا عَلٰى صِيَامٍ وَرُزِقْتُ فِيْهِ الْيَقَظَةَ مِنَ الْمَنَامِ وَقَصَدْتُ رَبَّ الْعِزَّةِ بِالْقِيَامِ بِرَحْمَةٍ مِنْهُ تَخُصُّنِيْ وَنِعْمَةٍ اُلْبِسَتْنِيْ وَحُسْنٰى نَعَشَتْنِيْ وَاَسْئَلُهُ اِتْمَامَ ابْتِدَاۗئِهٖ وَزِيَادَةً لِيْ مِنِ اجْتِبَاۗئِهٖ فَاِنَّهُ الْمَلِيْكُ الْقَدِيْرُ وَصَلَّى اللهُ عَلٰى مُحَمَّدٍ وَّآلِهٖ وَسَلَّمَ كَثِيْرًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, 