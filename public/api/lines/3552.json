[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015576, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to God whose Power is dominant over the thoughts, whose wonders have filled the eyes, His Bestowals do not diminish and smart asking does not force Him to bestow! He Himself who made the tongues to speak about His Attributes, and He was Powerful to do what He did with His Own Acts. And He joined corruption with their correctness, scattering with their union, and discord with their orderliness so as to guide the blind ones that all of them shall be destroyed and they are the created by the Creator.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "SUBHAANA MAN TAB-HARO QUDRATO-HUL AF-QAARA WA TAMLA-O A’JAA-E-BOHUL AB-SAARAL LAZEE LAA YAN-QOSO-HUL A’TAA-O WA LAA YA’TAREZO JOODA-HUZ ZAKAA-UL (AZ ZAKKAA-O) LAZEE ANTA-QAL AL-SONA BE-SEFAATE-HI WAQTA-DARA BIL-FE’LE A’LAA MAF-OO’LAATE-HI WA AD-KHALA FEE SALAAHE-HAL FA-SAADA WA A’LAA MUJTAMA-E’HASH SHA-TAATA WA A’LAA MUNTA-ZAME-HAL INFE-SAAMA LE-YADUL-LAL MUBSE-REENA (AL MOTA-BASSE-REENA) A’LAA ANNA-HAA FAANE-YATOON MIN SAN-A’TE BAA-QIN MAKH-LOO-QATOON MIN IN-SHAA-E KHALQE (KHAALE-QE).", "ArabicText1": "سُبْحَانَ مَنْ تَبْهَرُ قُدْرَتُهُ الْاَفْكَارَ وَتَمْلَاُ عَجَاۗئِبُهُ الْاَبْصَارَ الَّذِيْ لَا يَنْقُصُهُ الْعَطَاۗءُ وَلَا يَعْتَرِضُ جُوْدَهُ الذَّكَاۗءُ (الذَّكَّاۗءُ) الَّذِيْ اَنْطَقَ الْاَلْسُنَ بِصِفَاتِهٖ وَاقْتَدَرَ بِالْفِعْلِ عَلٰى مَفْعُوْلَاتِهٖ وَاَدْخَلَ فِيْ صَلَاحِهَا الْفَسَادَ وَعَلٰى مُجْتَمَعِهَا الشَّتَاتَ وَعَلٰى مُنْتَظَمِهَا الْاِنْفِصَامَ لِيَدُلَّ الْمُبْصِرِيْنَ (الْمُتَبَصِّرِيْنَ) عَلٰى اَنَّهَا فَانِيَةٌ مِنْ صَنْعَةِ بَاقٍ مَخْلُوْقَةٌ مِنْ اِنْشَاۗءِ خَلْقٍ (خَالِقٍ)۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign