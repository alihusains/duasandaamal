[{"Id": 1014676, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "When you intend to leave and bid farewell to the Imam, you may recite farewell ziyarat in the following words…", "GujaratiDescription": null, "RUrduDescription": "Jab tum Imam (a) se aakhri rukhsati lena chaho to ziyarat’e wida in alfaazo’n mein adaa karo…", "UrduDescription": "قبرِ مبارک سے آخری رخصتی لیتے وقت اس طرح سے کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014677, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Certainly I have performed some of the etiquette from your visitation, O my master! If I have performed what was obligatory on me, O my master! I have performed by making your courtyard abode of resting but as I am the son of the world, I worked hard in it as per my habit of the past, then I ask Allah, the Caring, the Merciful, to send blessing upon Muhammad and the progeny of Muhammad, and not to decide this time of my visit to you as the last and for all the believers, surely He is Most Merciful and He has power over all things.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay mere Aaqa! Mai ne aap ki ziyarat mein se chand faraaez anjaam diye hai. Ay mere Mawla! Agar mumkin hota mere bas mein to mai aap ke sahen (haram) ko apna hamesha ka thikaana bana leta, magar is dunya mein rehta hu aur yahan par mehnat o mashaqqat karta hu, jaisa keh yeh dunya ka rasm o riwaaj hai, jaisa keh guzre huwe logo’n ka riwaaj tha. Pas ay Allah! Mai Tujh se sawaal karta hu keh Tu sab se ziyadah rahem karne waala hai, yeh dua karta hu keh Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur mere aur tamaam momeeno ke liye in ki ziyarat ko aakhri mauqa qaraar na de, be-shak Tu sab se ziyadah rahem karne waala hai aur har cheez par qudrat rakhta hai.", "Urdu": "اے میرے آقا میں نے آپ کی زیارت میں سے چند فرائض انجام دیے ہیں، اے میرے مولا! اگر ممکن ہوتا میرے بس میں تو میں آپ کے صحن کو اپنا ہمیشہ کا ٹھکانا بنا دیتا مگر میں اِس دنیا میں رہتا ہوں اور یہاں پر محنت و مشقت کر تا ہوں جیسا کہ یہ دنیا کا رسم و رواج ہے جیسا کہ گزرے ہوئے لوگوں کا رواج تھا، پس اے اللہ! میں تجھ سے سوال کرتا ہوں کہ تو سب سے زیادہ رحم کرنے والا ہے یہ دعا کرتا ہوں کہ محمدؐ اور آل محمدؑ پر رحمت نازل فرما  اور میرے اور تمام مومنین کے لیے اِن کی زیارت کا آخری موقع قرار نہ دے، بےشک تو سب سے زیادہ رحم کرنے والا ہے اور ہر چیز پر قدرت رکھتا ہے۔", "RArabic": "QAD QA-ZAITO YAA MAWLAAYA BA’ZAL IRBE MIN ZIYAA-RATE-KA WA LAU FAA’LTO YAA MAWLAAYA MAA YAJE-BO A’LAIYYA LA-JA-A’LTO A’RSA-TA-KA DAARA IQAA-MATEEN WA LAA KINNA-NEE MIN ABNAA-ID-DUNYAA AK AKDA-HO FEEHAA KAMAA JA-RAT A’ADA-TO MIN MAZAA FA-AS-A-LUL LAA-HAL BAAR-RAR RAHEEMA AN YO-SALLE-YA A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA AN LAA YAJ-A’LA-HU AAKHE-RAL A’HDE MIN ZIYAARATE-KUM WA JAMEEI’L MOMENEENA INNA-HU AR-HA-MUR RAAHE-MEENA WA HOWA A’LAA KULLE SHAI-IN QADEEROON.", "ArabicText1": "قَدْ قَضَيْتُ يَا مَوْلَايَ بَعْضَ الْاِرْبِ مِنْ زِيَارَتِكَ وَلَوْ فَعَلْتُ يَا مَوْلَايَ مَا يَجِبُ عَلَيَّ لَجَعَلْتُ عَرْصَتَكَ دَارَ اِقَامَةٍ وَلٰكِنَّنِيْ مِنْ اَبْنَآءِ الدُّنْيَا اَكْدَحُ فِيْهَا كَمَا جَرَتْ عَادَةُ مَنْ مَضٰى فَاَسْاَلُ اللهَ الْبَآرَّ الرَّحِيْمَ اَنْ يُصَلِّيَ عَلٰى مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاَنْ لَا يَجْعَلَهٗ اٰخِرَ الْعَهْدِ مِنْ زِيَارَتِكُمْ وَجَمِيْعِ الْمُؤْمِنِيْنَ اِنَّهٗ اَرْحَمُ الرَّاحِمِيْنَ وَهُوَ عَلٰى‏ كُلِّ شَيْ‏ءٍ قَدِيْرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null,