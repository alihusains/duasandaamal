[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002199, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I ask You for forbearance of the grateful and (practice of) actions of the fearful of You & conviction of the devotees to Your worship O Allah: You are verily the Most High, the All-great, I am Your bondman unlucky and indigent You are self-sufficient and praise-worthy. while I am Your worthless bondman O Allah: bless Muhammad and his Household & cover my neediness through Your self-sufficiency and my ignorance through Your forbearance, and my weakness through Your power. O All-powerful, O Almighty. O Allah: bless Muhammad and his Household the Successors (of prophet hood) and the Pleased and save me from whatever aggrieves me among the worldly and those of the hereafter O the most Merciful of all those who show mercy.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai Tujh se sawaal karta hu keh mujhe shukr guzaaro’n ka sabr, darr ne waalo’n ka amal aur ibaadat guzaaro’n ka yaqeen ataa farma. Ay Ma’bood! Tu buland wa buzurg hai aur mai Tera haajat-mand aur be-maal wa manaal (be-sahaara) banda hu, Tu be-haajat aur taarif waala hai aur mai Tera past-tar banda hu. Ay Ma’bood! Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur meri mohtaaji apni tawanggari se, meri na-daani par apni malaamat wa burdbaari se, aur apni quwwat se meri kamzori par ehsaan farma, ay quwwat waale se zabardast. Ay Ma’bood Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma jo pasandida wasi aur ja-nasheen hai aur duniya wa aakherat ke ahem maamlo’n mein meri kifaayat farma, ay sabse ziyadah rahem karne waale.", "Urdu": "اے معبود! میں تجھ سے سوال کرتا ہوں کہ مجھے شکر گزاروں کا صبر ڈرنے والوں کا عمل اور عبادت گزاروں کا یقین عطا فرما اے معبود!تو بلند و بزرگ ہے اور میں تیرا حاجت مند اور بے مال واسباب بندہ ہوں تو بے حاجت اور تعریف والا ہے اور میں تیرا پست تر بندہ ہوں اے معبود! محمدؐاور ان کی آلؑ پر رحمت نازل فرما اور میری محتاجی پر اپنی تونگری سے میری نادانی پر اپنی ملائمت و بردباری سے اور اپنی قوت سے میری کمزوری پر احسان فرما اے قوت والے اسے زبردست اے معبود! محمدؐ اوران کی آلؑ پر رحمت نازل فرما جو پسندیدہ وصی اور جانشین ہیں اور دنیا و آخرت کے اہم معاملوں میں میری کفایت فرما اے سب سے زیادہ رحم کرنے والے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ اِنِّيْ اَسْئَلُكَ صَبْرَ الشَّاكِرِيْنَ لَكَ وَعَمَلَ الْخَائِفِيْنَ مِنْكَ وَيَقِيْنَ الْعَابِدِيْنَ لَكَ۔ اَللّٰهُمَّ اَنْتَ الْعَلِيُّ الْعَظِيْمُ وَاَنَا عَبْدُكَ الْبَائِسُ الْفَقِيْرُ اَنْتَ الْغَنِيُّ الْحَمِيْدُ وَاَنَا الْعَبْدُ الذَّلِيْلُ۔ اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِهٖ وَامْنُنْ بِغِنَاكَ عَلٰى فَقْرِيْ وَبِحِلْمِكَ عَلٰى جَهْلِيْ وَبِقُوَّتِكَ عَلٰى ضَعْفِيْ يَا قَوِيُّ يَا عَزِيزُ۔ اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِهِ الْاَوْصِيَاءِ الْمَرْضِيِّيْنَ وَاكْفِنِيْ مَا اَهَمَّنِيْ مِنْ اَمْرِ الدُّنْيَا وَالْآخِرَةِ يَا اَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4