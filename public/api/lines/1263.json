[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000257, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Artist Creator of all things that has been created! O He Who joins together separate bones! O He Who is everywhere! O He Who is aware of all secrets! O He who knows the obscure and the unseen! O He Who is present everywhere without being absent from any other place! O He Who prevails, and is never dominated! O He who is near, and is never out of reach! O Companion of every unattended desolate! O Everliving, Who brings the dead to life, And makes the living dead, Everlasting vigilant over all souls for that which they have earned! O He Who was (ever) alive when nothing existed! There is no god except Thou. Send blessings on Muhammad and on the children of Muhammad.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay har bani huwi cheez ke banane waale, ay har shikasta ko jodne waale aur ay har giroh mein maujood rehne waale aur ay har raaz ke shaahid wa gawah aur ay har chhupi huwi cheez ke jaanne waale, aur ay woh haazir jo kabhi ghaayab nahi hota, ay woh ghaalib jo kabhi maghloob nahi hota, ay woh qareeb jo kabhi dur nahi hota, ay har akele ke saath rehne waale aur ay woh zinda jo murdo’n ko zinda karta hai aur zindo’n ko maut deta hai, har nafs ko uske kaam ka (badla) dene waale, ay us waqt zinda rehne waale jab koi zinda na hoga. Nahi koi Ma’bood siwaaye Tere, rehmat farma Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par.", "Urdu": "اے ہربنی ہوئی چیز کے بنانے والے! اے ہر شکستہ کو جوڑنے والے! اور اے ہرگروہ میں موجود رہنے والے اور اے ہر راز کے شا ہد و گواہ اور اے ہر چھپی ہوئی چیز کے جاننے والے اور اے وہ حاضر جو کبھی غائب نہیں ہوتا اے وہ غالب جو کبھی مغلوب نہیں ہوتا اے وہ قریب جو کبھی دور نہیں ہوتا اے ہر اکیلے کے ساتھ رہنے والے اور اے وہ زندہ جو مردوں کو زندہ کرتا ہے اور زندوں کو موت دیتا ہے ہر نفس کو اس کے کئے کا بدلہ دینے والے اے اس وقت زندہ رہنے والے جب کوئی زندہ نہ ہو گا۔ تیرے سوا کوئی معبود نہیں محمدؐ اور آلِ محمدؐ پر رحمت فرما۔", "RArabic": "YAA SAANE-A’ KULLE MASNOO-I’N YAA JAABERA KULLE KASEERIN WA YAA HAAZERA KULLE MALAA-IN WA YAA SHAAHEDA KULLE NAJWAA WA YAA A’ALEMA KULLE KHAFIYYATIN WA YAA SHAAHEDO GHAYRA GHAA-EBIN WA GHAALEBO GHAYRA MAGHLOOBIN WA YAA QAREEBO GHAYRA BA-E’EDIN WA YAA MOONESA KULLE WAHEEDIN WA YAA HAYYO MOHYEYAL MAWTAA WA MOMEETAL AHYAAA-IL QAAA-EME A’LAA KULLE NAFSIN BEMAA KASABAT WA YAA HAYYAN HEENA LAA HAYYA LAA ELAAHA ILLAA ANTA SALLE A’LAA MOHAMMADIN WA AALE MOHAMMAD.", "ArabicText1": "يَاصَانِعَ كُلِّ مَصْنُوْعٍ يَاجَابِرَ كُلِّ كَسِيْرٍ (كَسْرٍ) وَّيَا حَاضِرَ كُلِّ مَلَاٍ وَّيَا شَاهِدَ كُلِّ نَجْوٰى وَيَا عَالِمَ كُلِّ خَفِيَّةٍ وَّيَا شَاهِدُ (شَاهِدًا) غَيْرَ غَآئِبٍ وَّيَا غَالِبُ (غَالِبًا) غَيْرَ مَغْلُوْبٍ وَّيَا قَرِيْبُ (قَرِيْبًا) غَيْرَ بَعِيْدٍ وَّ يَا مُوْنِسَ كُلِّ وَحِيْدٍ وَّيَا حَيُّ مُحْيِيَ الْمَوْتٰى وَمُمِيْتَ الْاَحْيَآءِ الْقَآئِمُ (الْقَآئِمَ) عَلٰى كُلِّ نَفْسٍۢ بِمَا كَسَبَتْ وَيَا حَيًّا حِيْنَ لَا حَيَّ لَا اِلٰهَ اِلَّا اَنْتَ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicT