[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011695, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Blessed is Allah, the best of the creators. The creator of the creatures and the shaper of the clouds; one who orders the thunder to praise Him and blessed is one in whose hands is the Kingdom and who is powerful over everything. The one who created death and life, so that He may test you which of you perform the best deeds. Blessed is the one who revealed the Criterion upon His servant so that it be a warner to the worlds. Blessed is one who can give us gardens better than these, in which streams flow and He make for you palaces. Blessed is Allah the best of the creators.", "Gujarati": null, "RGujarati": null, "RUrdu": "Bada hi barkat waala hai woh Khuda keh jo sab se achcha khaaliq hai. Tamaam makhlooq ka paiyda karne waala hai, baadalo’n aur ghataawo’n ka utha ne waala hai, garaj aur ra’aad (bijlee) ko hukm dene waala hai keh woh Uski tasbeeh karte rahe. Barkat waali zaat uski hai keh jiske qabze qudrat mein saare jahan ki hukumat hai aur woh har cheez par qudrat rakhta hai, woh keh jisne maut aur zindagi ko is liye paiyda kiya hai ta-keh tumhaari aazmaaish kare, keh tum mein amal aur kirdaar ke etebaar se kaun sab se achcha hai. Barkat waala hai keh jisne apne bando’n par haq o baatil mein tameez karne waala Qur’an naazil kiya ta-keh woh tamaam aalam ke liye daraane (khoufe Khuda dil mein paiyda karne) waala saabit ho. Barkat waala hai woh keh agar woh chaahe to in neymato’n se behtar baagh (garden) tum ko ataa kar de keh jin mein nehre (rivers) behti ho aur qaraar de tumhaare liye aali-shaan mahel, barkat waala hai woh jo sab se achcha paiyda karne waala hai.", "Urdu": "بڑا ہی برکت والا ہے وہ خدا کہ جو سب سے اچھا خالق ہے۔ تمام مخلوق کا پیدا کرنے والا ہے، بادلوں اور گھٹاؤں کا اٹھا نے والا ہے، گرج اور بجلی کو حکم دینے والا ہے کہ وہ اس کی تسبیح کرتے رہے۔ برکت والی ذات اس کی ہے کہ جس کے قبضہ قدرت میں سارے جہاں کی حکمت ہے اور وہ ہر چیز پر قدرت رکھتا ہے، وہ کہ جس نے موت اور زندگی کو اس لئے پیدا کیا ہے تاکہ تمہاری آزمائش کرے، کہ تم میں عمل اور کردار کے اعتبار سے کون سب سے اچھا ہے۔ برکت والا ہے کہ جس نے بندوں پر حق و باطل میں تمیز کرنے والا قرآن نازل کیا تاکہ وہ تمام عالم کے لئے ڈرانے والا سابت ہو۔ برکت والا ہے وہ کہ اگر وہ چاہے تو ان نعمتوں سے بہتر باغ تم کو عطا کر دے کہ جن میں نہریں بہتی ہو اور قرار دے تمہارے لئے عالی شان محل، برکت والا ہے وہ جو سب سے اچھا پیدا کرنے والا ہے۔ ", "RArabic": "TABAA-RA-KAL LAAHO AH-SANUL KHAALE-QEENA KHAALE-QUL KHALQE WA MUN-SHE-US SE-HAABE WA AAME-RUR RA’DE AN YO-SABBE-HO LAHU TABAA-RA-KAL LAZEE BE-YADE-HIL MULKO WA HOWA A’LAA KULLE SHAIY-IN QADEE-RUL LAZEE KHALA-QAL MAWTA WAL-HAYAATA LE-YAB-LOWA-KUM AIYYO-KUM AHSA-NO A’MALAN TABAA-RA-KAL LAZEE NAZZA-LAL FUR-QAANA A’LAA A’B-DEHI LE-YAKOO-NA LIL-A’A-LAMEENA NAZEE-RAN TABAA-RA-KAL LAZEE INSHAA-A JA-A’LA LAKA KHAIRAN MIN ZAALEKA JANNAA-TIN TAJREE MIN TAHTE-HAL AN-HAARO WA YAJ-A’LO LAKA QOSOO-RAN TABAA-RAKAL LAAHO AH-SANUL KHAALE-QEENA.", "ArabicText1": "تَبَارَکَ اللهُ اَحْسَنُ الْخَالِقِیْنَ خَالِقُ الْخَلْقِ وَمُنْشِیُٔ السِّحَابِ وَاٰمِرُ الرَّعْدِ اَنْ یُسَبِّحُ لَہٗ تَبَارَکَ الَّذِیْ بِیَدِہِ الْمُلْکُ وَھُوَ عَلٰی کُلِّ شَیْٓءٍ قَدِیْرٌ الَّذِیْ خَلَقَ الْمَوْتَ وَالْحَیٰوۃَ لِیَبْلُوَکُمْ اَیُّکُمْ اَحْسَنُ عَمَلًا تَبَارَکَ الَّذِیْ نَزَّلَ الْفُرْقَانَ عَلٰی عَبْدِہٖ لِیَکُوْنَ لِلْعٰالَمِیْنَ نَذِیْرًا تَبَارَکَ الَّذِیْ اِنْشَآئَ جَعَلَ لَکَ خَیْرًا مِّنْ ذٰلِکَ جَنَّاتٍ تَجْرِیْ مِنْ تَحْتِھَا الْاَنْھَارُ وَیَجْعَلُ لَکَ قُصُوْرًا تَبَارَکَ اللہُ اَحْسَنُ الْخَالِقِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": n