[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002486, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, grant us a part of Your fear, that acts as a barrier between us and Your disobedience, Your obedience, that helps us achieve Your pleasure, the certainty that makes the miseries of the world seem insignificant. O Allah, make us enjoy, our hearing, our sight, our strength as long as You Keep us alive. Make us take rise against those who oppress us, and help us against those who show animosity to us. Place not our miseries in our religion, and let not this world be our biggest concern, nor the extent of our knowledge. And do not appoint over us one who has no mercy on us, by your mercy, O Most Merciful of the Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Hamein apne khouf ka itna hissa de jo hamare aur hamari taraf se Teri na-farmaani ke darmiyaan rukaawat ban jaaye aur farmaan bardaari se itna hissa de keh us se ham Teri khushnoodi haasil kar sake’n aur itna yaqeen ataa kar keh jiski ba-daulat duniya ki taklife’n hamein sabuk (halki) maaloom ho. Ay Ma’bood! Jab tak Tu hamein zindah rakkhe hamein hamare kaano, aankho’n aur quwwat se mustafid farma. Is Qaaem (a.t.f.s) ko hamara waaris bana aur un se badla lene waala qaraar de jinho ne ham par zulm kiya hamaare dushmano ke khilaaf hamaari madad farma aur hamaare deen mein hamaare liye koi museebat na la aur hamaari himmat aur hamaare ilm ke liye duniya ko bada maqsad qaraar na dena aur ham par us shakhs ko ghaalib na kar jo ham par rahem na kare, waasta Teri rehmat ka ay sab se ziyadah rahem waale.", "Urdu": "اے معبود! ہمیں اپنے خوف کا اتنا حصہ دے جو ہمارے اور ہماری طرف سے تیری نافرمانی کے درمیان رکاوٹ بن جائے اور فرماں برداری سے اتنا حصہ دے کہ اس سے ہم تیری خوشنودی حاصل کرسکیں اور اتنا یقین عطا کر کہ جس کی بدولت دنیا کی تکلیفیں ہمیں معمولی معلوم ہوں اے معبود! جب تک تو ہمیں زندہ رکھے ہمیں ہمارے کانوں، آنکھوں اور قوت سے مستفید فرما اور اس قائمؑ کو ہمارا وارث بنا اور ان سے بدلہ لینے والا قرار دے جنہوں نے ہم پر ظلم کیا ہمارے دشمنوں کے خلاف ہماری مدد فرما اور ہمارے دین میں ہمارے لئے کوئی مصیبت نہ لا اور ہماری ہمت اور ہمارے علم کے لئے دنیا کو بڑا مقصد قرار نہ دے اور ہم پر اس شخص کو غالب نہ کر جو ہم پر رحم نہ کرے تیری رحمت کا واسطہ اے سب سے زیادہ رحم کرنے والے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ اقْسِمْ لَنَا مِنْ خَشْيَتِكَ مَا يَحُوْلُ بَيْنَنَا وَبَيْنَ مَعْصِيَتِكَ وَمِنْ طَاعَتِكَ مَا تُبَلِّغُنَا بِهٖ رِضْوَانَكَ وَمِنَ الْيَقِيْنِ مَا يَهُوْنُ عَلَيْنَا بِهٖ مُصِيْبَاتُ الدُّنْيَا۔ اَللّٰهُمَّ اَمْتِعْنَا بِاَسْمَاعِنَا وَاَبْصَارِنَا وَقُوَّتِنَا مَا اَحْيَيْتَنَا وَاجْعَلْهُ الْوَارِثَ مِنَّا وَاجْعَلْ ثَارَنَا عَلٰى مَنْ ظَلَمَنَا وَانْصُرْنَا عَلٰى مَنْ عَادَانَا وَلَا تَجْعَلْ مُصِيْبَتَنَا فِيْ دِيْنِنَا وَلَا تَجْعَلِ الدُّنْيَا اَكْبَرَ هَمِّنَا وَلَا مَبْلَغَ عِلْمِنَا وَلَا تُسَلِّطْ عَلَيْنَا مَنْ لَّا يَرْحَمُنَا بِرَحْمَتِكَ يَااَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSi