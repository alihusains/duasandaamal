[{"Id": 1011846, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "The first 10 days of this month are called Ayyame maalumat (The Stated Days) by the Holy Qur’an. The Holy Prophet (s) is reported to have said that nothing is more preferable to Almighty Allah than practicing acts of worship on these 10 days.", "GujaratiDescription": null, "RUrduDescription": "Mahe Zil-Hijjah ke pehle 10 din ko Qur’an Majeed mein Ayyame maalumaat (chune huwe din) kaha gaya hai. Rasoole Khuda (s) ne farmaya, keh Allah (swt) ko is 10 dino mein koi cheez ziyadah pasand nahi hai magar yeh keh banda Uski ibaadat kare.", "UrduDescription": "قرآن مجید میں اس کے ابتدائی ۱۰ دنوں کو ’’ایام معلومات‘‘ کہا گیا ہے اور یہ بڑی فضیلت اور برکت والے ایام ہیں۔ حضرت رسول اللہؐ کا فرمان ہے : کسی بھی دن کی نیکی و عبادت خدا کے ہاں اس نیکی و عبادت سے زیادہ محبوب نہیں جو ان ۱۰ دنوں میں کی جائے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": n