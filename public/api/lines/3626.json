[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016103, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah is great, Allah is great, and praise belongs to Allah. There is no god save Allah, the One; He has fulfilled His word, granted victory to [helped] His servant, and alone defeated the parties. There is no god save Allah; only Him we do worship, and we make our religion sincerely His, though the unbelievers may be averse. O Allah! I ask Thee guidance, piety, chastity and sufficiency.", "Gujarati": null, "RGujarati": null, "RUrdu": "Allaho Akbar, Allaho Akbar, Allaho Akbar tamaam taarife’n sirf aur sirf Allah ke liye hai. Koi ma’bood nahi siwaaye us Khuda'e yakta ke jis ne apne waade ko pura kiya aur apne bande ki madad ki aur akele hi kufr o nifaaq ke giroho’n ko naabood kiya. Koi ma’bood nahi siwaaye us Allah ke aur ham sirf Usi ki ibaadat karte hai aur mukhlisaana taur par Uske deen ki pairawi karte hai, agar-che kaafiro’n ko yeh baat pasand na ho. Baar'e Ilaaha! Mai Tujh se hidaayat, taqwa, paak-daamani aur be-neyaazi talab karta hu.", "Urdu": "اللہ اکبر، اللہ اکبر، اللہ اکبر تمام تعریفیں صرف اور صرف اللہ کے لئے ہیں۔ کوئی معبود نہیں سوائے اس خدا ئے یکتا کے جس نے اپنے وعدے کو پورا کیا اور اپنے بندے کی مدد کی اور اکیلے ہی کفر و نفاق کے گروہوں کو نابود کیا۔ کوئی معبود نہیں سوائے اس اللہ کے اور ہم صرف اسی کی عبادت کرتے ہیں اور مخلصانہ طور پر اسکے دین کی پیروی کرتے ہیں، اگرچہ کافروں کو یہ بات پسند نہ ہو۔ بار الٰہا! میں تجھ سے ہدایت، تقویٰ، پاک دامنی اور بے نیازی طلب کرتا ہوں۔", "RArabic": "ALLAAHO AKBARO ALLAAHO AKBARO, ALLAAHO AKBARO WA LILLAA-HIL HAMDO, LAA ILAAHA ILLAL LAAHO WAHDA-HU, SADAQA WA’DAHU, WA NASARA A’BDA-HU, WA HAZA-MAL AHZAA-BA WAHDA-HU. LAA ILAAHA ILLAL LAAHO WA LAA NA’BODO ILLAA IYYAA-HO, MUKHLE-SEENA LAHUD DEENA WA LAW KARE-HAL KAAFE-ROONA. ALLAAHUMMA INNEE AS-ALOKAL HODAA WAT TOQAA WAL E’FAAFA WAL GHENAA.", "ArabicText1": "اَللہُ اَكْبَرُ اَللہُ اَكْبَرُ، اَللہُ اَكْبَرُ وَلِلهِ الْحَمْدُ۔ لَآ اِلٰهَ اِلَّا اللهُ وَحْدَهٗ، صَدَقَ وَعْدَهٗ، وَنَصَرَ عَبْدَهٗ، وَهَزَمَ الْاَحْزَابَ وَحْدَهٗ، لَآ اِلٰهَ اِلَّا اللهُ وَلَا نَعْبُدُ اِلَّا اِیَّاهُ، مُخْلِصِیْنَ لَهُ الدِّیْنَ وَلَوْ كَرِهَ الْكَافِرُوْنَ۔ اَللّٰهُمَّ اِنِّیْ اَسْئَلُكَ الْهُدٰی وَالتُّقٰی وَالْعِفَافَ وَالْغِنٰی۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016104, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Praise is Thine as Thou sayest, and what Thou sayest is right. O Allah! I ask Thee Thy satisfaction and I take refuge in Thee from Thy dissatisfaction and from Fire and that which brings me close to it, of words or deeds or actions. O Allah! We are guided by Thy light, we are sufficient by Thy grace, and we begin our morning and night under Thy protection, blessings, endowment and bounty.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baar'e Ilaaha! Taareef Tere liye hai jaisa keh khud Tu ne farmaaya hai aur Tu jo kuchh farmaata hai woh hamaare liye khair hai. Baar'e Ilaaha! Mai sawaal karta hu Tujh se Teri raza aur Jannat ka aur panah maangta hu Tere ghazab aur aatish'e jahannam se apne har us qoul, fael aur amal se jo mujhe us se nazdik kare. Baar'e Ilaaha! Mai ne Tere noor ke zariye hidaayat paayi hai aur Tere fazl ke zariye se be-neya huwa aur Teri tawajjoh, ne’maat, ataawo’n, ehsaanaat ke saaye mein mai ne subh se shaam ki.", "Urdu": "بار الٰہا! تعریف تیرے لئے ہے جیسا کہ خود تونے فرمایا ہے اور تو جو کچھ فرماتا ہے وہ ہمارے لئے خیر ہے۔ بار الٰہا! میں سوال کرتا ہوں تجھ سے تیری رضا اور جنت کا اور پناہ مانگتا ہوں تیرے غضب اور آتش جہنم سے اپنے ہر اس فعل اور عمل سے کو مجھے اس سے نزدیک کرے۔ بار الٰہا! میں نے تیرے نور کے ذریعہ ہدایت پائی ہے اور تیرے فضل کے ذریعہ سے بے نیاز ہوا ہوں اور تیری توجہ، نعمات، عطاؤں، احسانات کے سائے میں، میں نے صبح سے شام کی ہے۔", "RArabic": "ALLAAHUMMA LAKAL HAMDO KAL-LAZEE TAQOO-LO WA KHAIRAN MIMMAA TAQOO-LO. ALLAAHUMMA INNEE AS-ALOKA REZAA-KA WAL JANNATA, WA A-OO’ZO BEKA MIN SAKHTE-KA WAN-NAARA WA MAA YO-KARRE-BONEE ILAI-HAA MIN QAWLIN WA FE’LIN AW A’MA-LIN. ALLAAHUMMA BE-NOORE-KAH TA-DAIYNAA, WA BE-FAZLE-KAS TAGH-NAIY-NAA, WA FEE KANAFE-KA WA IN-AA’MEKA WA A’TAA'e KA WA EH-SAANE-KA ASBAH-NAA WA AM-SAIY-NAA.", "ArabicText1": "اَللّٰهُمَّ لَكَ الْحَمْدُ كَالَّذِیْ تَقُوْلُ وَخَیْرًا مِمَّا تَقُوْلُ۔ اَللّٰهُمَّ اِنِّیْ اَسْئَلُكَ رِضَاكَ وَالْجَنَّۃَ، وَاَعُوْذُ بِكَ مِنْ سَخْطِكَ وَالنَّارَ وَمَا یُقَرِّبُنِیْ اِلَیْهَا مِنْ قَوْلٍ وَفِعْلٍ اَوْ عَمَلٍ۔ اَللّٰهُمَّ بِنُوْرِكَ اهْتَدَیْنَا، وَبِفَضْلِكَ اسْتَغْنَیْنَا، وَفِیْ كَنَفِكَ وَاِنْعَامِكَ وَعَطَائِكَ وَاِحْسَانِكَ اَصْبَحْنَا وَاَمْسَیْنَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016105, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Thou art the First before Whom there was nothing, The last after Whom there will be nothing, The Manifest above Whom there is nothing, The Hidden beyond Whom there is nothing. We take refuge in Thee from bankruptcy, indolence, the pain of the grave, and the temptation of sufficiency, and we ask Thee to reward us with paradise. O Lord! Forgive and have mercy and pardon and be gracious and excuse what Thou knowest, surely Thou knowest what we do not know, verily Thou art Allah, the All-mighty, the most Generous.", "Gujarati": null, "RGujarati": null, "RUrdu": "Tu sab se awwal hai, nahi hai Tujh se pehle koi cheez aur na Tere baad koi cheez aur Tu aisa zaahir hai jis se pehle koi cheez zaahir na thi aur Tu aisa chahya huwa hai, jis se ziyadah chahyi huwi koi cheez nahi hai. Ham panah maangte hai muflisee se aur susti se aur azaab'e qabr se aur be-neyaazi ke zariye imtehaan karne se aur sawaal karte hai Jannat ki kaamyaabi ka. Parwardigaar! Mujhe bakhsh de, rahem farma, maaf karde aur mujh par karam farma aur un cheezo’n se dar-guzar farma jo Tu mere mutaaliq jaanta hai aur be-shak Tu woh kuchh jaanta hai jise ham nahi jaante. Be-shak Tu saaheb'e izzat aur buzurg-waar Khuda hai.", "Urdu": "تو سب سے اوّل ہے، نہیں ہے تجھ سے پہلے کوئی چیز اور نہ تیرے بعد ہوئی چیز اور تو ایسا ظاہر ہے جس سے پہلے ہوئی چیز ظاہر نہ تھی اور تو ایسا چھپا ہوا ہے جس سے زیادہ چہپی ہوئی کوئی چیز نہیں ہے۔ ہم پناہ مانگتے ہیں مفلسی سے اور سستی سے اور عذابِ قبر سے اور بے نیازی کے ذریعہ امتحان کرنے سے اور سوال کرتے ہیں جنت کی کامیابی کا۔ پروردگار! مجھے بخش دے، رحم فرما، معاف کردے اور مجھ پر کرم فرما اور ان چیزوں سے درگزر فرما جو تو میرے متعلق جانتا ہے اور بے شک تو وہ کچھ جانتا ہے جسے ہم نہیں جانتے۔ بےشک توہی صاحب عزت اور بزرگوار خدا ہے۔", "RArabic": "ANTAL AWWALO FALAA QABLA-KA SHAI-OON WAL AA-KHERO FALAA BA’DAKA SHAI-OON, WAZ ZAAHE-RO FALAA SHAI-A WAFQA-KA, WAL BAATE-NO FALAA SHAI-A DOO-NAKA, NA-OO’ZO BEKA MENAL FALSE WAL KASA-LE WA A’ZAA-BIL QABRE, WA FITNA-TIL GHE-NAA, WA NAS-ALO-KAL FAWZA BIL JANNATE, RAB-BIGH-FIR WAR-HAM WA’FO WA TA-KARRAM WA TAJAA-WAZ A’MMAA TA’LAMO, INNA-KA TA’LAMO MA-LAA NA’LAMO, INNAKA ANTAL LAAHUL A-A’ZZUL AKRAMO.", "ArabicText1": "اَنْتَ الْاَوَّلُ فَلَا قَبْلَكَ شَیْئٌ وَالْاٰخِرُ فَلَا بَعْدَكَ شَیْئٌ، وَظَّاهِرُ فَلَا شَیْئَ فَوْقَكَ، وَالْبَاطِنُ فَلَا شَیْئَ دُوْنَكَ، نَعُوْذُ بِكَ مِنَ الْفَلْسِ وَالْكَسَلِ وَعَذَابِ الْقَبْرِ، وَفِتْنَۃِ الْغِنٰی، وَنَسْئَلُكَ الْفَوْزَ بِالْجَنَّۃِ، رَبِّ اغْفِرْ وَارْحَمْ وَاعْفُ وَتَكَرَّمْ وَتَجَاوَزْ عَمَّا تَعْلَمُ، اِنَّكَ تَعْلَمُ مَلَا نَعْلَمُ، اِنَّكَ اَنْتَ اللهُ الْاَعَزُّ الْاَكْرَمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "Arabic