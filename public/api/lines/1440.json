[{"Id": 1010561, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "This form of ziyarat can be recite at visiting the holy shrines of any Imam (a) or even all other holy shrines, like these of the Prophets and the Prophets’ successors…", "GujaratiDescription": null, "RUrduDescription": "Yeh ziyarat sabhi Imam (a) ki qabr pe, hatta koi bhi Nabi ya unke ja-nasheen ki qabre mubarak par bhi padhi ja sakti hai…", "UrduDescription": "شیخ صدوقؒ نے من لا یحضرہ الفقیہ میں روایت کی ہے : بعض لوگوں نے امام رضا ؑ سے دریافت کیا کہ امام موسیٰ کاظم ؑ کی زیارت کس طرح کی جائے؟ آپ نے فرمایا: حضرتؑ کے روضۂ پاک کے نزدیک جو مسجدیں ہیں ان میں نماز ادا کرو اور تمہارے لئے کافی ہو گا کہ تم جس نبی ؐ اور وصی ؑ یا امام ؑکی زیارت کو جاؤ تووہاں یہ زیارت پڑھو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010390, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be unto the lovers and chosen ones of God; Peace be unto the trustees and beloved ones of God; Peace be unto the auxiliaries and vice agents of God; Peace be unto the repositories of the understanding of God; Peace be unto the sanctuaries of the remembrance of God; Peace be unto the sanctuaries of the commands and prohibitions of God; Peace be unto the heralds of God; Peace be unto the dwellers in the pleasure of God; Peace be unto the sincere ones in the obedience of God.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho auliya’e Khuda aur uske bar-guzida bando’n par. Salaam ho Khuda ke amaanat-daaro’n aur uske pyaaro’n par. Salaam ho Khuda ke naasiro’n aur uske khalifaao’n par. Salaam ho Khuda ki maarefat ke nishano par. Salaam ho zikre ilaahi ke manzil-gaaho par. Salaam ho Khuda ke amr o nahi (amr-bil maroof wa nehi-anil munkar) ke aash-kaar (waazeh) karne waalo’n par. Salaam ho Khuda ki taraf bula ne waalo’n par. Salaam ho Khuda ki razaawo’n mein rehne waalo’n par. Salaam ho Khuda ke sachche ita’at guzaaro’n par. Salaam ho Khuda ki taraf rehnumaayi karne waalo’n par.", "Urdu": "سلام ہو اولیاء خدا اور اس کے برگزیدہ پر، سلام ہو خدا کے امانت داروں اور اس کے پیاروں پر، سلام ہو خدا کے ناصروں اور اس کے نائبوں پر،سلام ہو خدا کی معرفت کے نشانوں پر، سلام ہو ذکرِ الہٰی کی منزل گاہوں پر،سلام ہو خدا کے امرو نہی کے آشکار کرنے والوں پر، سلام ہو خدا کی طرف بلانے والوں پر، سلام ہو خدا کی رضاؤں میں رہنے والوں پر،سلام ہو خدا کے سچے اطاعت گزاروں پر، سلام ہو خدا کی طرف رہنمائی کرنے والوں پر۔", "RArabic": "AS-SALAAMO A’LAA AWLEYAA-ILLAA-HE WA AS-FEYAAA-E-HI. AS-SALAAMO A’LAA OMA-NAAA-ILLAAHE WA AHIBBAAA-E-HI. AS-SALAAMO A’LAA ANSAA-RIL-LAAHE WA KHOLAFAAA-E-HI. AS-SALAAMO A’LAA MA-HALLE MA’REFA-TIL LAAHE. AS-SALAAMO A’LAA MASAAKE-NE ZIKRIL LAAHE. AS-SALAAMO A’LAA MUZHE-REE AMRIL LAAHE WA NAH-YEHI. AS-SALAAMO A’LAD DO-AA’TE ILAL-LAAHE. AS-SALAAMO A’LAL MUSTAQIR-REENA FEE MARZAA-TIL LAAHE. AS-SALAAMO A’LAL MUKHLE-SEENA FEE TAA-A’TIL LAAHE.", "ArabicText1": "اَلسَّلَامُ عَلٰى اَوْلِيَآءِ اللهِ وَاَصْفِيَآئِهٖ۔ اَلسَّلَامُ عَلٰى اُمَنَآءِ اللهِ وَاَحِبَّآئِهٖ۔ اَلسَّلَامُ عَلٰى اَنْصَارِ اللهِ وَخُلَفَآئِهٖ۔ اَلسَّلَامُ عَلٰى مَحَالِّ مَعْرِفَةِ اللهِ۔ اَلسَّلَامُ عَلٰى مَسَاكِنِ ذِكْرِ اللهِ۔ اَلسَّلَامُ عَلٰى مُظْهِرِيْ اَمْرِ اللهِ وَنَهْيِهٖ۔ اَلسَّلَامُ عَلَى الدُّعَاةِ اِلَى اللهِ۔ اَلسَّلَامُ عَلَى الْمُسْتَقِرِّيْنَ فِيْ مَرْضَاةِ اللهِ۔ اَلسَّلَامُ عَلَى الْمُخْلِصِيْنَ فِيْ طَاعَةِ اللهِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010191, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be unto those who are such that he who loves them loves God; and whoever is their enemy is the enemy of God; and whoever knows them knows God; and whoever is ignorant of them is ignorant of God; and whoever clings to them clings to God; and whoever forsakes them forsakes God.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho un par keh jo un se mohabbat kare to Khuda us se mohabbat karta hai, aur jo un se dushmani rakkhe Khuda us se dushmani rakhta hai. Salaam ho un par keh jo unki maarefat haasil kar le woh Khuda ko pehchaan leta hai, aur jo un se na-waaqif ho woh Khuda se na-waaqif hota hai. Jo un se taalluq rakkhe woh Khuda se taalluq rakhta hai, aur jo un se alag rahe woh Khuda se alag rahe jaata hai.", "Urdu": "سلام ہو ان پر کہ جو ان سے محبت کرے تو خدا اس سے محبت کرتا ہے اور جو ان سے دشمنی رکھے خدا اس سے دشمنی رکھتا ہے سلام ہو ان پر کہ جو ان کی معرفت کر لے وہ خدا کو پہچان لیتا ہے اور جو ان سے ناواقف ہو وہ خدا سے ناواقف ہوتا ہے جو ان سے تعلق رکھے وہ خدا سے تعلق رکھتا ہے اور جو ان سے الگ رہے وہ خدا سے الگ رہ جاتا ہے۔", "RArabic": "AS-SALAAMO A’LAL ADILLAA-E A’LAL LAAHE. AS-SALAAMO A’LAL LAZEE-NA MIN WAALAA-HUM FA-QAD WA LAL-LAAHA WA MAN AA’DA-HUM FA-QAD AA’DAL LAAHA, WA MAN A’RAFA-HUM FA-QAD A’RAFAL LAAHA WA MAN JAHELA-HUM FA-QAD JAHE-LAL LAAHA WA MANE’ TASAMA BE-HIM FA-QADE’TASAMA BILLAAHE WA MAN TA-KHALLAA MIN-HUM FA-QAD TA-KHALLAA MINAL LAAHE A’ZZA WA JALLA.", "ArabicText1": "اَلسَّلَامُ عَلَى الْاَدِلَّآءِ عَلَى اللهِ۔ اَلسَّلَامُ عَلَى الَّذِيْنَ مَنْ وَّالَاهُمْ فَقَدْ وَالَى اللهَ وَمَنْ عَادَاهُمْ فَقَدْ عَادَى اللهَ، وَمَنْ عَرَفَهُمْ فَقَدْ عَرَفَ اللهَ وَمَنْ جَهِلَهُمْ فَقَدْ جَهِلَ اللهَ وَمَنِ اعْتَصَمَ بِهِمْ فَقَدِ اعْتَصَمَ بِاللهِ وَمَنْ تَخَلّٰى مِنْهُمْ فَقَدْ تَخَلّٰى مِنَ اللهِ عَزَّ وَ جَلَّ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010389, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I Call upon Allah as my witness that I am at peace with those who are at peace with Thee, and at war with those who are at war against Thee; I believe in Thy secrets and Thy disclosures, entrusting in this matter everything to Thee. May God curse the enemies of the Children of Muhammad from among the Jinns and men, (and from the first to the last of them). I dissociate myself from them and turn towards God. God bless Muhammad and his Children.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai Khuda ko gawah banata hu keh meri sulah (peace) hai us se jis se aap ki sulah ho aur meri jang hai us se jis se aap ki jang ho. Mai aap ke zaahir o baatin par imaan rakhta hu, is baare mein khud ko aap ke supurd (hawaale) karta hu. Khuda laanat kare Aale Muhammad (a.s) ke dushmano par jo Jinn o Ins mein se hai. Mai Khuda ke saamne un se bari hu, aur Khuda rehmat kare Muhammad (s.a.w.a) aur unki Aal’e Paak (a.s) par.", "Urdu": "میں خداکو گواہ بناتا ہوں کہ میری صلح ہے اس سے جس سے آپ کی صلح ہو اور میری جنگ ہےاس سے جس سے آپ کی جنگ ہو میں آپ کے ظاہر و باطن پر ایمان رکھتا ہوں اس بارے میں خود کو آپ کے سپرد کرتا ہوں خدا لعنت کرے آل محمد ؐکے دشمنوں پر جو جن وانس میں سے ہیں میں خدا کے سامنے ان سے بری ہوں اور خدا محمدؐاور ان کی آل ؑ پر رحمت کرے۔", "RArabic": "WA ASH-HADUL LAAHA ANNEE SILMOON LEMAN SAA-LAM-TUM WA HARBOON LEMAN HAARAB-TUM MO-MENOON BE-SIRRE-KUM WA A’LAA NEYATE-KUM MO-FAWWE-ZOON FEE ZAALEKA KULLE-HI ILAI-KUM LA-A’NAL LAAHO A’DOOWA AALE MOHAMMADIN MINAL JINNE WAL INSE WA ABRA-O ILAL-LAAHE MIN-HUM WA SALLAL-LAAHO A’LAA MOHAMMADIW WA AALE-HI.", "ArabicText1": "وَاُشْهِدُ اللهَ اَنِّيْ سِلْمٌ لِمَنْ سَالَمْتُمْ وَحَرْبٌ لِمَنْ حَارَبْتُمْ مُؤْمِنٌ بِسِرِّكُمْ وَعَلَانِيَتِكُمْ مُفَوِّضٌ فِيْ ذٰلِكَ كُلِّهٖ اِلَيْكُمْ لَعَنَ اللهُ عَدُوَّ آلِ مُحَمَّدٍ مِّنَ الْجِنِّ وَالْاِنْسِ وَاَبْرَاُ اِلَى اللهِ مِنْهُمْ وَصَلَّى اللهُ عَلٰى مُحَمَّدٍ وَّآلِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSi