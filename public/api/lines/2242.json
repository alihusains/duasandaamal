 null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019068, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I have prayed for You and bowed for You and prostrated for You, there is no partner to You. This is because it is not permissible that the prayers, bowing and prostration except for You, for You are Allah, there is no god but You. O Allah! send Your greetings to Muhammad and his family, convey from me the best salutations and greetings and return their salutations and greetings to me. O Allah! these 2 rakats are my token to my leader and master Ali Ibn Moosa (a.s) O Allah! send your blessings on Muhammad and his family, accept my deeds, reward me by fulfilling my best hopes and expectations of You and of Your representative, O master of the believers.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Be-shak mai ne Tere liye namaz padhi, Tere liye ruku kiya aur Tere liye sajdah kiya, Tu yakta hai aur Tera koi shareek nahin. Pas namaz padhna jaaez nahin hai aur ruku karna aur sajdah karna magar Tere hi waaste, is liye keh Tu woh Allah hai keh Tere siwa koi ma’bood nahin. Ay Ma’bood! Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur unko meri taraf se beh-tareen salaam aur durood pohoncha aur mujh par un ki taraf se dua’e salaamati  palta. Ay Ma’bood! Meri yeh 2 rakat namaz hadiya hai meri taraf se mere sardaar Ali (a.s) ke liye jo Moosa (a.s) ke farzand hai un dono par salaam. Ay Ma’bood! Hazrat Muhammad (s.a.w.a) par aur Ali (a.s) par rehmat farma aur bosa de (kiss kar) un ko meri taraf se aur poori kar unke khaatir meri beh-tareen aarzoo aur ummeed jo mai Tujh se aur Tere us wali se rakhta hu, ay momino ke sar-parast.", "Urdu": "اے معبود! بے شک میں نے تیرے لیے نماز پڑھی تیرے لیے رکوع کیااور تیرے لیے سجدہ کیا تو یکتا ہے اور تیرا کوئی شریک نہیں، پس نماز پڑھناجائز نہیں ہے اور رکوع کرنااور سجدہ کرنا مگر تیرے ہی واسطے، اس لیے کہ تو وہ اللہ ہے کہ تیرے سوا کوئی معبود نہیں۔ اے معبود! محمدؐ وآل محمدؐ پر رحمت نازل فرما اور ان کو میری طرف سے بہترین سلام اور درودپہنچا اورمجھ پر ان کی طرف سے دعاءسلامتی پلٹا۔ اے معبود! میری یہ دو رکعت نماز ہدیہ ہے میری طرف سے میرے سردار علی ؑکے لیے جو موسی ؑ کے فرزند ہیں ان دونوں پر سلام۔ اے معبود! حضرت محمدؐ پر اور علی ؑپر رحمت فرما اور بوسہ دے ان کو میری طرف سے اور پوری کران کے خاطر میری بہترین آرزو اور امید جو میں تجھ سے اور تیرے اس ولی سے رکھتا ہوں اے مومنوں کے سرپرست۔", "RArabic": "ALLAAHUMMA INNEE LAKA SALLAIY-TO WA LAKA RAKA’TO WA LAKA SAJAD-TO WAH-DAKA LAA SHAREE-KA LAKA LE-ANNA-HU LAA YAJOO-ZUS SALAA-TO WAR-ROKOO-O’ WAS-SOJOO-DO ILLAA LAKA LE-ANNA-KA ANTAL LAAHO LAA ILAAHA ILLAA ANTA. ALLAAHUMMA SALLE ALAA MOHAMMADIW WA AALE MOHAMMADIN WA AB-LIGH-HUM A’NNEE AFZA-LAS SALAAME WAT-TAHIY-YA-TE WAR-DUD A’LAIYYA MIN-HO-MUS SALAAMA WATTA-HIYYA-TA. ALLAAHUMMA WA HAATAA-NIR RAK-A’TAA-NE HADIYYA-TOOM MINNEE ILAA SAIYYE-DEE WA MAWLAA-YA A’LAIY-YIBNE MOOSAR REZAA ALAIY-HE-MAS SALAAMO. ALLAAHUMMA SALLE A’LAA MOHAMMADIN WA AALE-HI WA TAQABBAL-HOMAA MINNEE WAA JURNEE A’LAIY-HEMAA AF-ZALE AMA-LEE WA RAJAAA-EE FEE-KA WA FEE WALIYYE-KA YAA WALIY-YAL MOMENEENA.", "ArabicText1": "اَللّٰهُمَّ اِنِّىْ لَكَ صَلَّيْتُ وَلَكَ رَكَعْتُ وَلَكَ سَجَدْتُ وَحْدَكَ لَا شَرِيْكَ لَكَ لِاَنَّهٗ لَا تَجُوْزُ الصَّلَاةُ وَالرُّكُوْعُ وَالسُّجُوْدُ اِلَّا لَكَ لِاَنَّكَ اَنْتَ اللهُ لَا اِلٰهَ اِلَّا اَنْتَ۔ اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاَبْلِغْهُمْ عَنِّىْ اَفْضَلَ السَّلَامِ وَالتَّحِيَّةِ وَارْدُدْ عَلَىَّ مِنْهُمُ السَّلَامَ وَالتَّحِيَّةَ۔ اَللّٰهُمَّ وَهَاتَانِ الرَّكْعَتَانِ هَدِيَّةٌ مِّنِّىْ اِلٰى سَيِّدِيْ وَمَوْلَاىَ عَلِيِّ بْنِ مُوْسَي الرِّضَا عَلَيْهِمَا السَّلَامُ۔ اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَاٰلِہٖ وَتَقَبَّلْهُمَا مِنِّىْ وَاجُرْنِىْ عَلَيْهِمَا اَفْضَلِ اَمَلِيْ وَرَجَآئِىْ فِيْكَ وَفِىْ وَلِيِّكَ يَا وَلِىَّ الْمُؤْمِنِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "Arabi