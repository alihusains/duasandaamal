[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013016, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay Imam Sadiq (a.s) Salaam ho aap par ay Rasool ke naatiq wasi. Salaam ho aap par (kamaal mein) faaiq aur laaeq (buland-tar). Salaam ho aap par ay buland choti (high peak). Salaam ho aap par ay bohot seedhi raah. Salaam ho aap par ay taarikiyo’n ke chiraag. Salaam ho aap par ay sakhtiyo’n ko dur karne waale.", "Urdu": "سلام ہو آپ پر اے امام صادقؑ، سلام ہو آپ پر اے رسولؐ کے ناطق وصی، سلام ہو آپ پر اے (کمال میں) فائق اور رائق، سلام ہو آپ پر اے بلند چوٹی، سلام ہو آپ پر اے بہت سیدھی راہ، سلام ہو آپ پر اے تاریکیوں کے چراغ، سلام ہو آپ پر اے سختیوں کو دور کرنے والے۔", "RArabic": "ASSALAAMO A’LAYKA AYYOHAL EMAAMUS SAADEQO ASSALAAMO A’LAYKA AYYOHAL WASIYYUN NAATEQO ASSALAAMO A’LAYKA AYYOHAL FAA-EQUR RAA-EQO ASSALAAMO A’LAYKA AYYOHAS SANAAMUL A-A’ZAMO ASSALAAMO A’LAYKA AYYOHAS SERAATUL AQWAMO ASSALAAMO A’LAYKA YAA MISBAAHAZ ZOLOMAATE ASSALAAMO A’LAYKA YAA DAA-FE-A’L MO’ZALAATE.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ اَیُّہَا الْاِمَامُ الصَّادِقُ۔ اَلسَّلَامُ عَلَیْكَ ا