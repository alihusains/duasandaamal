are of the hidden matters without any difficulty and hardship, and You O Allah certainly sight all that has not deviated from You, but Your forbearance and endurance has secured those men who committed such wrongdoings, which resulted in further daring, mischief, obstinacy and enmity.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَلْفَزَعُ الْفَزَعُ اِلَیْكَ یَا ذَاالْمُحَاضَرَۃِ، وَالرَّغْبَۃُ الرَّغْبَۃُ اِلَیْكَ یَا مَنْ بِهِ الْفَاخَرَۃُ، وَاَنْتَ اللّٰهُمَّ مَشَاهِدُ هَوَاجِسِ النُّفُوْسِ، وَمُرَاصِدُ حَعَكَاتِ الْقُلُوْبِ، وَمُطَالِعُ مَسَرَّاتِ السَّرَائِرِ مِنْ غَیْرِ تَكَلُّفٍ لَا تَعَسُّفٍ، وَقَدْ تَرَی اللّٰهُمَّ مَا لَیْسَ عَنْكَ بِمُنْطَوْیٍ، وَلٰكِنَّ حِلْمِكَ آمَنَ اَهْلَهٗ عَلَیْهِ جُرْئَۃً وَتَمَرُّدًا وَعُتُوَّا وَعِنَادًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "Ara