[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000200, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Allah, before everyone (glorifies Him). Glory be to Allah, after everyone (glorifies Him). Glory be to Allah, when everyone (glorifies Him). Glory be to Allah, Everlasting Forever is our Lord Nourisher, and everyone passes away. Glory be to Allah, the glorification of the glorifiers exalts His glory, immeasurably exalted in His glory, before everyone (exalts Him).", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai woh Khuda jo har cheez se pehle hai. Paak hai woh Khuda jo har cheez ke baad hai. Paak hai woh Khuda jo har cheez ke saath hai. Paak hai woh Khuda jo hamara Rab hai aur hamesha baaqi rehne waala hai jab-keh har shai fanah ho jaane waali hai. Paak hai woh Khuda jo nehaayat paakeeza hai jo tasbeeh karne waalo’n ki tasbeeh se bohot bohot baala o aala (buland o bartar) hai har cheez se pehle.", "Urdu": "پاک ہے وہ خدا جو ہر چیز سے پہلے ہے، پاک ہے وہ خدا جو ہر چیز کے بعد ہے، پاک ہے وہ خدا جو ہر چیز کے ساتھ ہے، پاک ہے خدا ہمارا رب جو وہ باقی رہے گا جب کہ ہر چیز فنا ہوجائے گی، پاک ہے خدا نہایت پاکیزہ ہے جو تسبیح کرنے والوں کی تسبیح سے بہت بہت برتر ہے ہر ایک چیز سے پہلے اور پاک ہے خدا نہایت پاکیزہ ہے جو تسبیح کرنے والوں کی تسبیح سے بہت بہت برتر ہے ہر چیز کے بعد۔", "RArabic": "SUBHAA-NAL-LAAHE QABLA KULLA AHA-DIN, WA SUBHAA-NAL-LAAHE BA’DA KULLE AHA-DIN, WA SUBHAA-NAL-LAAHE MA-A’ KULLE AHA-DIN, WA SUBHAA-NAL-LAAHE YABQAA RABBO-NAA WA YAFNAA KULLO AHA-DIN, WA SUBHAA-NAL-LAAHE TASBEE-HAN YAFZOLO TASBEE-HIL MOSABBE-HEENA FAZ-LAN KASEE-RAN QABLA KULLE AHA-DAN.", "ArabicText1": "سُبْحَانَ اللہِ قَبْلَ کُلَّ اَحَدٍ وَّسُبْحَانَ اللہِ بَعْدَ کُلِّ اَحَدٍ وَّسُبْحَانَ اللہِ مَعَ کُلِّ اَحَدٍ وَّسُبْحَانَ اللہِ یَبْقٰی رَبُّنَا وَیَفْنٰی کُلُّ اَحَدٍ وَّسُبْحَانَ اللہِ تَسْبِیْحًا یَّفْضُلُ تَسْبِیْحَ الْمُسَبِّحِیْنَ فَضْلًا کَثِیْرًا قَبْلَ کُلِّ اَحَدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002122, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Allah, the glorification of the glorifiers exalts His glory, immeasurably exalted is His glory, after everyone (exalts Him). Glory be to Allah, the glorification of the glorifiers exalts His glory, immeasurably exalted is the glory of our Everlasting Lord-Nourisher, and everyone passes away. Glory be to Allah, glory which is, immeasurable, unperceivable, unforgetable, unperishing, indestructible, and there is no end to it.", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai woh Khuda jo nehaayat paakeeza hai jo tasbeeh karne waalo’n ki tasbeeh se bohot bohot baala o aala (buland o bartar) hai har cheez ke baad. Paak hai woh Khuda jo nehaayat paakeeza hai jo tasbeeh karne waalo’n ki tasbeeh se bohot bohot baala o aala (buland o bartar) hai har cheez ke saath. Paak hai woh Khuda jo nehaayat paakeeza hai jo tasbeeh karne waalo’n ki tasbeeh se bohot bohot baala o aala (buland o bartar) hai keh hamara Rab hamesha baaqi rehne waala hai jab-keh har cheez fanah ho jaane waali hai. Paak hai aur nehaayat paakeeza hai woh Khuda jo shumaar (ghinti) mein nahi aata. Aur na samajh mein aata hai na faramosh hota hai (na bhulaya jaata hai) na woh purana hota hai na fanah (khatm) aur uski koi inteha nahi hai.", "Urdu": "پاک ہے خدا نہایت پاکیزہ ہے جو تسبیح کرنے والوں کی تسبیح سے بہت بہت برتر ہے ہر چیزکے ساتھ اور پاک ہے خدا نہایت پاکیزہ ہے جو تسبیح کرنے والوں کی تسبیح سے بہت بہت برتر ہے کہ ہمارا رب باقی رہے گاجب کہ ہر چیز فنا ہو جائے گی، پاک ہے نہایت پاکیزہ ہے کہ شمار نہیں ہوسکتا سمجھ میں نہیں آتا فراموش نہیں ہوتا پرانا نہیں ہوتا ختم نہیں ہوتا اور اس کی کوئی انتہا نہیں ہے۔", "RArabic": "WA SUBHAA-NAL-LAAHE TASBEE-HAN YAF-ZOLO TASBEE-HIL MOSABBE-HEENA FAZ-LAN KASEE-RAM BA’DA KULLE AHA-DIN, WA SUBHAA-NAL-LAAHE TASBEE-HAN YAF-ZOLO TASBEE-HIL MOSABBE-HEENA FAZ-LAN KASEE-RAN LE-RABBE-NAL BAA-QEE WA YAF-NAA KULLO AHA-DIN, WA SUBHAA-NAL-LAAHE TASBEE-HAN LAA YOHSAA WA LAA YUDRA WA LAA YUNSAA WA LAA YABLAA WA LAA YAFNAA WA LAISA LAHU MUNTA-HAA.", "ArabicText1": "وَسُبْحَانَ اللہِ تَسْبِیْحًا یَّفْضُلُ تَسْبِیْحَ الْمُسَبِّحِیْنَ فَضْلًا کَثِیْرًۢابَعْدَ کُلِّ اَحَدٍ وَّسُبْحَانَ اللہِ تَسْبِیْحًا یَّفْضُلُ تَسْبِیْحَ الْمُسَبِّحِیْنَ فَضْلًا کَثِیْرًا لِرَبِّنَاالْبَاقِیْ وَیَفْنٰی کُلُّ اَحَدٍ وَسُبْحَانَ اللہِ تَسْبِیْحًا لَّا یُحْصٰی وَلَا یُدْرٰی وَلَا یُنْسٰی وَلَا یَبْلٰی وَلَا یَفْنٰی وَلَیْسَ لَہٗ مُنْتَھٰی۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002123, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Allah everlasting duration of His glory makes His glorification eternal, continuous existence of His glory keeps His glorification alive for ever, throughout the cosmic ages, months all through the centuries, days passing by in this world, and every moment of the nights and days. Glory be to Allah, never-ending glorification along with ever eternal glory, which neither can be counted in addition, nor can be terminated into an end, nor can ever be discontinued, be praised and hallowed is Allah, the Best Creator.", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai aur nehaayat paakeeza hai woh Khuda jo (apne bal-boote par) jaari o saari hai, hamesha se hai aur hamesha rahega, jahano ke barso (years) aur har ek mahino, duniya ke tamaam dino aur raat-din ki ghadiyo’n (saa’ato’n) ke saath hamesha se hai aur hamesha baaqi rahega. Paak hai woh Khuda jo (apne bal-boote par) hamesha se hai aur hamesha rahega. Keh jiski zaat ka andaaza nahi kiya ja sakta. Woh zamaana guzarne se fanah nahi hota aur na zamaana kabhi us se munqate (juda) ho sakta hai. Aur ba-barkat hai woh Khuda jo behtareen khaaliq hai.", "Urdu": "پاک ہے خدا نہایت پاکیزہ ہے جو ہمیشہ ہے اس کی ہمیشگی سے باقی ہے اس کی بقاکے ساتھ جہانوں کے برسوں ہر زمانے کے مہینوں دنیا کے تمام دنوں اور رات دن کی ہر ہر گھڑی میں، پاک ہے وہ خدا جو ہمیشہ ہمیشہ ہے ہمیشگی کے ساتھ کہ جس کی ذات کا اندازہ نہیں کیا جاسکتا وہ زمانہ گزرنے سے فنا نہیں ہوا اور ہمیشگی اس سے جدا نہیں ہوسکتی اور برکت والا ہے وہ خدا جو بہترین خالق ہے۔ ", "RArabic": "WA SUBHAA-NAL-LAAHE TASBEE-HAN YA-DOO-MO BE-DAWAAME-HI WA YABQAA BE-BAQAA-E-HI FEE SE-NIL AA’LAMEE-NA WA SHOHOO-RID DOHOO-RE WA AYYAA-MID DUNYAA WA SAA-AA’TIL LAIYLE WAN NAHAA-RE. WA SUBHAA-NAL-LAAHE ABA-DAL ABA-DE WA MA-A’L ABA-DE MIMMAA LAA YOHSEE-HIL A’DA-DE WA LAA YUFNEE-HIL AMA-DO WA LAA YAQTA-O’HUL ABA-DO WA TABAA-RA-KAL LAAHO AHSA-NUL KHAALE-QEENA.", "ArabicText1": "وَسُبْحَانَ اللہِ تَسْبِیْحًا یَّدُوْمُ بِدَوَامِہٖ وَیَبْقٰی بِبَقَآئِہٖ فِیْ سِنِی الْعَالَمِیْنَ وَشُھُوْرِ الدُّھُوْرِ وَاَیَّامِ الدُّنْیَا وَسَاعَاتِ اللَّیْلِ وَالنَّھَارِ۔ وَسُبْحَانَ اللہِ اَبَدًا اَلْاَبَدِ وَمَعَ الْاَبَدِ مِمَّا لَایُحْصِیْہِ الْعَدَدِ وَلَا یُفْنِیْہِ الْاَمَدُ وَلَا یَقْطَعُہُ الْاَبَدُ وَتَبَارَکَ اللہُ اَحْسَنُ الْخَالِقِیْنَ۔", "ArabicGreenSig