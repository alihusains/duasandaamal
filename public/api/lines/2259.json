: null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019149, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "There is no god except Allah, the Highest, the Greatest. There is no god except Allah, the Patient, the Noble. The Lord of Muhammad and Ali! Grant me the best in my action… (pray for your needs) for this world and for the next world, the best from Yourself, that in which Your pleasure lies in and which is good for me in goodness and good health. O Lord of favor and munificence!", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke siwa koi ma’bood nahin jo buland tareen aur azeem hai, Us ke siwa koi ma’bood nahin hai. Ay Rabb’e kareem! Hamein is dunya mein bhalaayi farma aur aakherat mein maghferat ataa kar, aur woh cheeze’n ataa kar jin se Tu raazi hai, aur hamaare umoor ki islaah kar, khair o aafiyat ataa kar, ay hamesha rehne waale Rab.", "Urdu": " خدا کے سوا کوئی معبود نہیں ہے، جو بلند ترین اور عظیم ہے، اس کے سوا کوئی معبود نہیں ہے، اے رب کریم! ہمیں اس دنیا میں بھلائی فرما اور آخرت میں مغفرت عطا کر اور وہ چیزیں عطا کر جن سے تو راضی ہے، اور ہمارے امور کی اصلاح کر، خیر و عافیت عطا کر، اے ہمیشہ رہنے والے رب۔", "RArabic": "LAA ILAAHA ILLAL LAAHUL A’LIYYUL A’ZEEMO LAA ILAAHA ILLAL LAAHUL HALEE-MUL KAREEMO RABBA MOHAMMADIN WA A’LIYYIN KHIR LEE FEE AMREE KAZAA WA KAZAA LID-DUNYA WAL AAKHE-RATE KHAIRA-TIN MIN I’N-DEKA MAA LAKA FEEHE REZAN WALEYA FEEHE SALAA-HOON FEE KHAI-REEN WA A’AFE-YATAN YAA ZAL-MANNE WAT-TAWL.", "ArabicText1": "لَا اِلٰهَ اِلَّا اللهُ الْعَلِيُّ الْعَظِيْمُ لَا اِلٰهَ اِلَّا اللهُ الْحَلِيْمُ الْكَرِيْمُ رَبَّ مُحَمَّدٍ وَعَلِيٍّ خِرْ لِيْ فِيْ اَمْرِيْ كَذَا وَكَذَا لِلدُّنْيَا وَالْاٰخِرَةِ خِيَرَةً مِنْ عِنْدِكَ مَا لَكَ فِيْهِ رِضًى وَلِيَ فِيْهِ صَلَاحٌ فِيْ خَيْرٍ وَعَافِيَةٍ يَا ذَا الْمَنِّ وَالطَّوْلِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicB