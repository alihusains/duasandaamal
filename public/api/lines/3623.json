[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016094, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah is great, Allah is great, and praise belongs to Allah; O Lord! Make our light perfect for us, and forgive us, truly Thou hast power over all things. O Allah! I ask Thee all that is good, present and future good, and I ask Thee to forgive me my sins, and I ask Thee Thy mercy, O Thou most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Allaho Akbar, Allaho Akbar, Allaho Akbar, hamd Usi ke liye hai. Baar'e Ilaaha! Ham par hamaare noor ko kaamil farma aur hamein maaf farma, keh Tu har cheez par qaadir hai. Baar'e Ilaaha! Ham Tujh se dunya o aakherat ke tamaam khair ke talab-gaar hai aur apne gunaho’n ki isteghfaar talab karte hai aur Teri rehmat ka sawaal karte hai. Ay maher-baan mein sab se bade maher-baan.", "Urdu": "اللہ اکبر، اللہ اکبر، اللہ اکبر، تعریف اللہ کے لئے ہے۔ بارالٰہا! ہم پر ہمارے نور کو کامل فرما اور ہمیں معاف فرماکہ تو ہر چیز پر قادر ہے۔ بارالٰہا! ہم تجھ سے دنیا اور آخرت کے تمام خیر طلبگار ہیں اور اپنے گناہوں کی استغفار طلب کرتے ہیں اور تیری رحمت کا سوال کرتے ہیں، اے مہربانوں میں سب سے پڑے مہربان۔", "RArabic": "ALLAAHO AKBARO ALLAAHO AKBARO, ALLAAHO AKBARO WA LILLAA-HIL HAMDO, RABBA-NAA ATMIM LANAA NOORAN WAGH-FIR-LANAA INNA-KA A’LAA KULLE SHAI-IN QADEE-ROON. ALLAAHUMMA INNEE AS-ALOKAL KHAIRA KULLA-HU AA’JE-LAHU WA AAJE-LAHU, WA AS-TAGH-FERO-KA LE ZANBEE, WA AS-ALOKA RAHMATE-KA YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "اَللہُ اَكْبَرُ اَللہُ اَكْبَرُ، اَللہُ اَكْبَرُ وَلِلهِ الْحَمْدُ، رَبَّنَا اَتْمِمْ لَنَا نُوْرًا وَاغْفِرْلَنَا اِنَّكَ عَلٰی كُلِّ شَیْئٍ قَدِیْرٌ۔ اَللّٰهُمَّ اِنِّیْ اَسْئَلُكَ الْخَیْرَ كُلَّهٗ عَاجِلَهٗ وَاٰجِلَهٗ، وَاَسْتَغْفِرُكَ لِذَنْبِیْ، وَاَسْئَلُكَ رَحْمَتَكَ یَا اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016095, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Lord! Forgive and have mercy and pardon and be gracious and excuse what Thou knowest, surely Thou knowest what we do not know, verily Thou art Allah, the All-mighty, the most Generous. O Lord, increase my knowledge, and do not make my heart swerve now that Thou hast guided me, and bestow on me Thy mercy, truly Thou art the bestower. O Allah! Protect my ears (hearing) and my sight (eye). There is no god save Thee.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar! Hamari maghferat farma, ham par rahem farma, hamein maaf farma, ham par lutf o karam farma, aur hamaare jin (burey) amaal se Tu waaqif hai un se dar-guzar farma keh jo Tu jaanta hai aur ham nahi jaante, keh Tu intehaayi ghaalib aur buzurg-waar Khuda hai. Baar'e Ilaaha! Mere ilm mein izaafah farma aur jab Tu ne hidaayat de di hai to hamaare qalb (dil) ko gumrah na farma aur apni taraf se mujhe rehmat bakhsh de, keh Tu bada bakhsh-ne waala hai. Baar'e Ilaaha! Aafiyat ataa farma mere kaan aur aankh ko. Tere siwa koi ma’bood nahi.", "Urdu": "پروردگار! ہماری مغفرت فرما، ہم پر رحم فرما، ہمیں معاف فرما، ہم پر لطف و کرم فرما، اور ہمارے جن (برے) اعمال سے تو واقف ہے ان سے درگزر فرما کہ جو تو جانتا ہے وہ ہم نہیں جانتے کہ تو انتہائی غالب اور بزرگوار خدا ہے۔ بار الٰہا! میرے علم میں اضافہ فرما اور جب تو نے ہدایت دے دی تو ہمارے قلب کو گمراہ نہ فرما اور اپنی طرف سے مجھے رحمت بخش دے کہ تو بڑا بخشنے والا ہے۔ بار الٰہا! عافیت عطا فرما میرے کان اور آنکھ کو، تیرے سوا کوئی معبود نہیں۔", "RArabic": "RABBIGH WAR-HAM WA’FO WA TA-KARRAM WA TAJAA-WAZ A’MMAA TA’LAMO, INNA-KA TA’LAMO MAA LAA NA’LAMO, INNA-KA ANTAL LAAHUL A-A’ZZUL AKRAMO, RABBE ZIDNEE I’LMAN WA LAA TO-ZIGH QALBEE BA’DA IZ-HADAIY-TANEE WA HABLEE MIN LA-DUNKA RAH-MATAN INNA-KA ANTAL WAHHAA-BO. ALLAAHUMMA AA’FENEE FEE SAMEE’, LAA ILAAHA ILLAA ANTA.", "ArabicText1": "رَبِّ اغْفِرْ وَارْحَمْ وَاعْفُ وَتَكَرَّمْ وَتَجَاوَزْ عَمَّا تَعْلَمُ، اِنَّكَ تَعْلَمُ مَا لَا نَعْلَمُ، اِنَّكَ اَنْتَ اللهُ الْاَعَزُّ الْاَكْرَمُ، رَبِّ زِدْنِیْ عِلْمًا وَّلَا تُزِغْ قَلْبِیْ بَعْدَ اِذْ هَدَیْتَنِیْ وَهَبْ لِیْ مِنْ لَّدُنْكَ رَحْمَۃً اِنَّكَ اَنْتَ الْوَهَّابُ۔ اَللّٰهُمَّ عَافِنِیْ فِیْ سَمْعِیْ وَبَصَرِیْ، لَآ اِلٰهَ اِلَّا اَنْتَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016096, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I take refuge in Thee from the pains of the grave; Glory be to Thee, surely I have been of the wrongdoers. O Allah! I take refuge in Thee from disbelief and poverty. O Allah! I take refuge in Thy satisfaction from Thy wrath, I take refuge in Thy well-being from Thy chastisement, I take refuge in Thee from Thee; I cannot estimate Thy praise as Thou hast praised Thyself, Praise is due to Thee as much as Thou art satisfied.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baar'e Ilaaha! Ham Teri panah chahte hai azaab'e qabr se Tu munazzah hai aur mai ne apne aap par zulm kiya hai. baar'e Ilaaha! Mai Teri raza ke zariye Tere ghazab se aur Tere afwo wa dar-guzar ke zariye Teri saza se aur Teri panah chahta hu, Teri sana ki na-tawaani se keh Tu usi tarah hai jis tarah Tu ne khud apni sana ki hai, pas Tere hi liye hamd hai yahan tak-keh Tu raazi ho jaaye.", "Urdu": "بار الٰہا! ہم تیری پناہ چاہتے ہیں عذاب قبر سے تو منزہ ہے اور میں نے اپنے آپ پر ظلم کیا ہے۔ بار الٰہا! میں تیری پناہ چاہتا ہوں کفر سے اور فقر سے۔ بار الٰہا! میں تیری پناہ چاہتا ہوں تیری رضا کے ذریعے تیرے غضب سے اور تیرے عفو و درگزر کے ذریعے تیری سزا سے اور تیری پناہ چاہتا ہوں تیری ثنا کی نا توانی سے کہ تو اسی طرح ہے جس طرح تو نے خود اپنی ثنا کی ہے۔پس تیرے ہی لئے حمد ہے یہاں تک کہ تو راضی ہو جائے۔", "RArabic": "ALLAAHUMMA INNEE A-OO’ZO-BEKA MIN A’ZAA-BIL QABRE, SUBHAANA-KA INNEE KUNTO MENAZ ZAALE-MEENA. ALLAAHUMMA INNE A-OO’ZO BEKA MENAL KUFRE WAL FAQRA. ALLAAHUMMA INNEE A’OO-ZO BE-RAZAA-KA MIN SAKHA-TEKA WA BE-MO-AA’FAATE-KA MIN O’QOO-BATEKA, WA A-OO’ZO BEKA LAA OHSEE SANAA-AN A’LAIKA, ANTA KAMAA AS-NAIY-TA A’LAA NAFSE-KA, FA-LAKAL HAMDO HATTAA TARZAA.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَعُوْذُ بِكَ مِنْ عَذَابَ الْقَبْرِ، سُبْحَانَكَ اِنِّیْ كُنْتُ مِنَ الظَّالِمِیْنَ۔ اَللّٰهُمَّ اِنِّیْ اَعُوْذُ بِكَ مِنَ الْكُفْرِ وَالْفَقْرَ۔ اَللّٰهُمَّ اِنِّیْ اَعُوْذُ بِرِضَاكَ مِنْ سَخَطِكَ وَبِمُعَافَاتِكَ مِنْ عُقُوْبَتِكَ، وَاَعُوْذُ بِكَ لَا اُحْصِیْ ثَنَائً عَلَیْكَ، اَنْتَ كَمَا اَثْنَیْتَ عَلٰی نَفْسِكَ، فَلَكَ الْحَمْدُ حَتّٰی تَرْضٰی۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": 