abicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013651, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, if my sins and faults have caused my face to be tattered in Your view; my impeded they, therefore voice from reaching You and You thus have not responded to any of my prayers, I then beseech You in Your Name, O Allah, for there is verily nothing like You, I seek the intercession of Muhammad and his Household to You, and I beseech You to send blessings upon Muhammad and the Household of Muhammad, to come to me with Your Noble Face, to accept my turning my face towards You, not to let me down when I supplicate You, and not to deprive me (of Your response) when I please You. O most merciful of all those who show mercy!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Agar mere gunaho’n aur laghzisho’n ke baais mera chehra Tere saamne aaluda hai, meri aawaaz Tujh tak nahi pohonch rahi hai aur Tu meri dua qabool nahi kar raha hai, to bhi mai sawaal karta hu Tera waasta de kar ay Allah, keh nahi hai Tere jaisa koi aur neez mai wasila banata hu Tere huzoor Muhammad (s.a.w.a) aur unki Aal (a.s) ko aur mai Tujh se sawaal karta hu keh Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil kar aur yeh keh tawajjoh farma mujh par ba-waasta apni zaat’e Kareem ke aur mera rukh apni taraf kar de mujhe maayoos na kar jab keh Tujhe pukaarta hu aur mujhe na-kaam na kar jab keh Tujh se ummeed hu, ay sab se ziyadah rahem karne waale.", "Urdu": "اے معبود! اگر میرے گناہوں اور لغزشوں کے باعث میرا چہر ہ تیرے سامنے آلودہ ہے میری آواز تجھ تک نہیں پہنچ رہی ہےاور تو میری دعا قبول نہیں کررہا ہے تو بھی میں سوال کرتا ہوں تیرا واسطہ دے کر اے اللہ کہ نہیں ہے تیرے جیسا کوئی اور میں بھی وسیلہ بناتا ہوں تیرے حضور محمدؐ اور ان کی آل کو اور میں تجھ سے سوال کرتا ہوں کہ محمدؐ وآل محمدؑ پر رحمت نازل کر اور یہ کہ توجہ فرمامجھ پر اپنی ذاتِ کریم کے واسطے سےاور میرا رخ اپنی طرف کردے مجھے مایوس نہ کر جب کہ تجھے پکارتا ہوں اور مجھے ناکام نہ کر جب کہ تجھ سے امید رکھتا ہوں اے سب سے زیادہ رحم کرنے والے۔", "RArabic": "ALLAAHUMMA IN KAANATIZ ZONOOBO WAL-KHATAAYAA QAD AKHLAQAT WAJ-HEE I’NDAKA FA-LAM TAR-FA’ LEE ILAIKA SAWTAWN WA LAM TAS-TAJIB LEE DA’WATAN FA-INNEE AS-ALOKA BEKA YAA ALLAAHO FA-INNAHU LAYSA MISLAKA AHDUWN WA ATAWASSALO ILAIKA BE-MOHAMMADIWN WA AALEHI WA AS-ALOKA AN TOSALLEYA A’LAA MOHAMMADIWN WA AALE MOHAMMADIWN WA AN TUQBELA ELAYYA BE-WAJHEKAL KAREEME WA TUQ-BELA BE-WAJHEE ILAIKA WA LAA TO-KHAYYIBNEE HEENA AD-O’OKA WA LAA TAHRIMNEE HEENA ARJOOKA YAA ARHAMAR RAAHEMEEN.", "ArabicText1": "اَللّٰھُمَّ اِنْ كَانَتِ الذُّنُوْبُ وَالْخَطَایَا قَدْ اَخْلَقَتْ وَجْھِیْ عِنْدَكَ فَلَمْ تَرْفَعْ لِیْ اِلَیْكَ صَوْتًا وَّلَمْ تَسْتَجِبْ لِیْ دَعْوَۃً فَاِنِّیْ اَسْئَلُكَ بِكَ یَا اَللهُ فَاِنَّهٗ لَیْسَ مِثْلَكَ اَحْدٌ وَّاَتَوَسَّلُ اِلَیْكَ بِمُحَمَّدٍ وَّاٰلِهٖ وَاَسْئَلُكَ اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَّاَنْ تُقْبِلَ اِلَیَّ بِوَجْھِكَ الْكَرِیْمِ وَتُقْبِلَ بِوَجْھِیْ اِلَیْكَ وَلَا تُخَیِّبْنِیْ حِیْنَ اَدْعُوْكَ وَلَا تَحْرِمْنِیْ حِیْنَ اَرْجُوْكَ یَا اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null,