abicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1005900, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 35, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah is the light of the heavens and the earth; a likeness of His light is as a niche in which is a lamp, the lamp is in a glass, (and) the glass is as it were a brightly shining star, lit from a blessed olive-tree, neither eastern nor western, the oil whereof almost gives light though fire touch it not- light upon light- Allah guides to His light whom He pleases, and Allah sets forth parables for men, and Allah is Cognizant of all things.", "Gujarati": null, "RGujarati": null, "RUrdu": "Allah aasmaano aur zameen ka noor hai. Iske noor ki misaal us taaq (almaari) ki hai jis mein chiraag ho aur chiraag sheeshe ki qandil mein ho aur qandil ek jag-magaate sitaare ke maanind ho jo zaitoon ke ba-barkat darakht se roshan kiya jaaye jo na mashriq (east) waala ho na maghrib (west) waala aur qareeb hai keh uska rogan bhadak utthe chahe usey aag mass bhi na kare yeh noor baala'e noor hai aur Allah apne noor ke liye jise chahta hai hidaayat de deta hai aur isi tarah misaale bayaan karta hai aur Woh har shai ka jaanne waala hai.", "Urdu": "اللہ آسمانوں اور زمین کا نور ہے، اس کے نور کی مثال اس طاق کی ہے جس میں چراغ ہو اور چراغ شیشہ کی قندیل میں ہو اور قندیل ایک جگمگاتے ستارے کے مانند ہو جو زیتون کے بابرکت درخت سے روشن کیا جائے جو نہ مشرق والا ہو نہ مغرب والا اور قریب ہے کہ اس کا روغن بھڑک اٹھے چاہے اسے آگ مس بھی نہ کرے یہ نور بالائے نور ہے اور اللہ اپنے نور کے لئے جسے چاہتا ہے ہدایت دے دیتا ہے اور اسی طرح مثالیں بیان کرتا ہے اور وہ ہر شے کا جاننے والا ہے۔", "RArabic": "ALLAAHU NOORUS SAMAAWAATI WAL ARD; MASALU NOORIHEE KAMISHKAATIN FEEHAA MISBAAH; ALMISBAAHU FEE ZUJAAJATIN AZZUJAAJATU KA ANNAHAA KAWKABUN DURRIYYUNY YOOQADU MIN SHAJARATIM MUBAARAKATIN ZAITOONATIL LAA SHARIQIYYATINW WA LAA GHARBIYYATINY YAKAADU ZAITUHAA YUDEEE’U WA LAW LAM TAMSASHU NAAR; NOORUN ’ALAA NOOR; YAHDIL LAAHU LINOORIHEE MAI YASHAAA’; WA YADRIBUL LAAHUL AMSAALA LINNAAS; WALLAAHU BIKULLI SHAI’IN ALEEM.", "ArabicText1": "اَللهُ نُوْرُ السَّمٰوٰتِ وَالْاَرْضِ", "ArabicGreenSign1": null, "ArabicRedSign1": "ط ", "ArabicBlueSign1": null, "ArabicText2": "مَثَلُ نُوْرِهٖ كَمِشْكٰوةٍ فِيْهَا مِصْبَاحٌ", "ArabicGreenSign2": null, "ArabicRedSign2": "ط ", "ArabicBlueSign2": null, "ArabicText3": "اَلْمِصْبَاحُ فِيْ زُجَاجَةٍ", "ArabicGreenSign3": null, "ArabicRedSign3": "ط ", "ArabicBlueSign3": null, "ArabicText4": "اَلزُّجَاجَةُ كَاَنَّهَا كَوْكَبٌ دُرِّيٌّ يُّوْقَدُ مِنْ شَجَرَةٍ مُّبٰرَكَةٍ زَيْتُوْنَةٍ لَّا شَرْقِيَّةٍ وَّلَا غَرْبِيَّةٍ يَّكَادُ زَيْتُهَا يُضِيْۗءُ وَلَوْ لَمْ تَمْسَسْهُ نَارٌ", "ArabicGreenSign4": null, "ArabicRedSign4": "ط ", "ArabicBlueSign4": null, "ArabicText5": "نُّوْرٌ عَلٰى نُوْرٍ", "ArabicGreenSign5": null, "ArabicRedSign5": "ط ", "ArabicBlueSign5": null, "ArabicText6": "يَّهْدِي اللهُ لِنُوْرِهٖ مَنْ يَّشَاۗءُ", "ArabicGreenSign6": null, "ArabicRedSign6": "ط ", "ArabicBlueSign6": null, "ArabicText7": "وَيَضْرِبُ اللهُ الْاَمْثَالَ لِلنَّاسِ", "ArabicGreenSign7": null, "ArabicRedSign7": "ط ", "ArabicBlueSign7": null, "ArabicText8": "وَاللهُ بِكُلِّ شَيْءٍ عَلِيْمٌ", "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 4, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescripti