[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019030, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Here I am! Here I am! You are the Master! Have mercy on this helpless creature whose refuge is Your realm. O the owner of heights I have faith in You, Blesses is the one whose Master You are. Fortunate is the one who is himself repentant and who keeps awake at night. And mentions his afflictions to the Lord of majesty and honor. He neither has a sickness nor a disease. One who has collected the treasure of his Master. When he prays with fervour in loneliness in the dark nights. Allah accepts his supplications and says Labbaik. (Here I am).", "Gujarati": null, "RGujarati": null, "RUrdu": "Labbaik, labbaik Tu Mawla hai. Us aajiz bande par rahem farma, jis ki panah-gah Teri baargah hai. Ay bulandiyo’n ke maalik Tujh par mera bharosa hai. Mubaarak hai woh jis ka Tu waali o waaris ho. Khush naseeb hai woh jo naadim (sharminda) hai, raato’n ko jaagta hai, aur Ma’bood’e zul-jalaal se apne dukh bayaan kiya karta hai. Usey koi illat hai na bimaari, jis ne apne Ma’bood ki mohabbat ka khazaana jama kar liya. Jab andheri raato’n mein gid-gida kar tanhaayi ke aalam mein dua karta hai to Allah uski dua ko qabool karta aur labbaik farmaata hai.", "Urdu": "لبیک لبیک، تو مولا ہے، اس عاجز بندے پر رحم فرما جس کی پناہ گاہ تیری بارگاہ ہے۔ اے بلندیوں کے مالک، تجھ پر میرا بھروسہ ہے۔ مُبارک ہے وہ جس کا تو والی و وارث ہو۔ خوش نصیب ہے وہ جو نادم ہے، راتوں کو جاگتا ہے، اور معبود ذوالجلال سے اپنے دکھ بیان کیا کرتا ہے۔ اسے کوئی علّت ہے نہ بیماری، جس نے اپنے معبود کی محبت کا خزانہ جمع کر لیا۔ جب اندھری راتوں میں گڑگڑا کر تنہائی کے عالم میں دعا کرتا ہے تو اللہ اس کی دعا کو قبول کرتا اور لبیک فرماتا ہے۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "لَبَّیْكَ لَبَّیْكَ اَنْتَ مَوْلَاهٗ، فَارْحَمْ عُبَیْدًا اِلَیْكَ مَلْجَاهٗ۔ یَا ذَاالْمَعَالِیْ عَلَیْكَ مُعْتَمِدِیْ، طُوْبٰی لِمَنْ كُنْتَ اَنْتَ مَوْلَاهٗ۔ طُوْبٰی لِمَنْ كَانَ نَادِمًا اَرِقًا، یَشْكُوْ اِلٰی ذِی الْجَلَالِ بَلْوَاهٗ۔ وَمَا بِهٖ عِلَّۃٌ وَلَا سَقَمٌ، اَكْنَزَ مِنْ حُبِّهٖ لِمَوْلَاهٗ۔ اِذَا خَلَا فِی الظَّلَامِ مُبْتَهِلًا، اَحَابَهُ اللهُ ثُمَّ لَبَّاهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSig