icText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000476, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Thee! How narrow are the paths for him whom Thou hast not guided! How plain the truth for him whom Thou hast guided on his way! My God, so make us travel on the roads that arrive at Thee and set us into motion on the paths nearest to reaching Thee! Make near for us the far, and make easy for us the hard and difficult! Join us to Thy servants, those who hurry to Thee swiftly, knock constantly at Thy door.", "Gujarati": null, "RGujarati": null, "RUrdu": "Tu paak hai! Uske liye raaste kitne tangh hai jiska rehbar (guide) Tu na ho. Aur uske liye haq kitna waazeh hai jisey Tu raah dikhaaye. Mere Mabood! Hamein Apni bargah tak pohoncha ne waale raasto’n par chala. Aur hamein Apni taraf le jaane waale qareeb-tareen raaho’n par rawa’n farma. Jo dur hai usey hamare qareeb le aa. Aur jo mushkil aur kathin (difficult) hai woh hamare liye aasaan farma de, hamein Apne un bando’n se molhaq kar de (mila de) jo Teri taraf badh ne mein jaldi karne waale hai aur Tere dar’e rehmat ko hamesha khat khataate hai. Raat-din Teri bandagi mein mashgul rehte hai. Aur Tere rob o dabdabe se khaayef o tarsa rehte hai.", "Urdu": "خدا کے نام سے شروع جو بڑا مہربان نہایت رحم والا ہے۔تو پاک ہے اس کے لئے راستے کتنے تنگ ہیں جس کا رہبر تو نہ ہو اور اس کے لئے حق کتنا واضح ہےجسے تو راستہ بتائے میرے معبود ہمیں اپنی درگاہ تک پہنچانے والے راستوں پر چلا اور ہمیں اپنی طرف لے جانے والے قریب ترین راستوں پر رواں دواں فرما جو دور ہے وہ ہمارے قریب لے آ اور جو مشکل اور کٹھن ہے وہ ہمارے لئے آسان فرمادے ہمیں اپنے ان بندوں سے ملحق کردے جو تیری طرف بڑھنے میں جلدی کرنے والے ہیں اور تیرے دروازۂ رحمت کو ہمیشہ کھٹکھٹاتے ہیں رات دن تیری عبادت میں مشغول رہتے ہیں اور تیرے دبدبہ سے خوف زدہ و ہراساں رہتے ہیں۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "سُبْحَانَكَ مَا اَضِيْقَ الطُّرُقَ عَلٰى مَنْ لَّمْ تَكُنْ دَلِيْلَهٗ وَمَا اَوْضَحَ الْحَقَّ عِنْدَ مَنْ هَدَيْتَهٗ سَبِيْلَهٗ۔ اِلٰهِىْ فَاسْلُكْ بِنَا سُبُلَ الْوُصُوْلِ اِلَيْكَ وَسَيِّرْنَا فِىْٓ اَقْرَبِ الطُّرُقِ لِلْوُفُوْدِ عَلَيْكَ قَرِّبْ عَلَيْنَا الْبَعِيْدَ وَسَهِّلْ عَلَيْنَا الْعَسِيْرَ الشَّدِيْدَ وَاَلْحِقْنَا بِعِبَادِكَ الَّذِيْنَ هُمْ بِالْبِدَارِ اِلَيْكَ يُسَارِعُوْنَ وَبَابَكَ عَلَى الدَّوَامِ يَطْرُقُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012352, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And worship Thee by night and by day, while they remain apprehensive in awe of Thee! Thou hast purified their drinking places, taken them to the objects of their desire, granted their requests, accomplished their wishes through Thy bounty, filled their minds with Thy love, and quenched their thirst with Thy pure drink.", "Gujarati": null, "RGujarati": null, "RUrdu": "Woh wahi hai jin ki seraabi ki jagaho’n ko Tu ne saaf kiya. Aur unhe unki chaahato’n tak pohonchaya hai. Unhe Apne maqaasid (maqsado’n) mein kamiyaab banaya, aur Apne karam se unki haajaat puri farmayi hai. Unke dilo’n ko Apni mohabbat se labrez kar diya hai aur unhe saaf o shaffaaf ghaat se seraab kiya hai. Woh Tujh se munajaat ki lazzat se Teri bargah mein pohonche hai, aur Tujh hi se unho ne apne tamaam maqaasid (aims) haasil kiye hai.", "Urdu": "وہ وہی ہیں جن کی سیرابی کی جگہوں کو تو نے صاف کیااور انہیں ان کی چاہتوں تک پہنچایا ہے انہیں اپنے مقاصد میں کامیاب بنایااور اپنے کرم سے ان کی حاجات پوری فرمائی ہیں ان کے دلوں کو اپنی محبت سے لبریز کر دیا ہے اور انہیں شفاف گھاٹ سے سیراب کیا ہے وہ تجھ سے مناجات کی لذت سے تیری بارگاہ میں پہنچے ہیں اور تجھی سے انہوں نے اپنے تمام مقاصد حاصل کیے ہیں۔", "RArabic": null, "ArabicText1": "وَاِيَّاكَ فِى اللَّيْلِ وَالنَّهَارِ يَعْبُدُوْنَ وَهُمْ مِنْ هَيْبَتِكَ مُشْفِقُوْنَ الَّذِيْنَ صَفَّيْتَ لَهُمُ الْمَشَارِبَ وَبَلَّغْتَهُمُ الرَّغَآئِبَ وَاَنْجَحْتَ لَهُمُ الْمَطَالِبَ وَقَضَيْتَ لَهُمْ مِنْ فَضْلِكَ الْمَآرِبَ وَمَلَاتَ لَهُمْ ضَمَآئِرَهُمْ مَنْ حُبِّكَ وَرَوَّيْتَهُمْ مِنْ صَافِىْ شَرِيْكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012353, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Through Thee have they reached the pleasure of whispered prayer to Thee, and in Thee have they achieved their furthest goals. O He who comes toward those who come toward Him and grants gifts and bestows bounty upon them through tenderness! He is compassionate and clement toward those heedless of His remembrance and loving and tender in drawing them to His door!", "Gujarati": null, "RGujarati": null, "RUrdu": "Pas Ay Woh Jo Apni taraf rukh karne waalo’n ki jaanib motawajjeh hai aur Apni maher-baani se unhe motawaatir neymat dene aur bakhsh ne waala hai, aur Apne zikr se ghaflat karne waalo’n par narm aur maher-baan hai, aur unhe Apne darwaaze par laane mein pyaar karne waala maher-baan hai.", "Urdu": "پس اے وہ جو اپنی طرف رخ کرنے والوں کی جانب متوجہ ہے اور اپنی مہربانی سے انہیں متواتر نعمت دینے اور بخشنے والا ہے اور اپنے ذکر سے غفلت کرنے والوں پر نرم اور مہربان ہے اور انہیں اپنے دروازے پر لانے میں پیار کرنے والا مہربان ہے۔", "RArabic": null, "ArabicText1": "فَبِكَ اِلٰى لَذِيْذِ مُنَاجَاتِكَ وَصَلُوْا وَمِنْكَ اَقْصٰى مَقَاصِدِهِمْ حَصَّلُوْا فَيَا مَنْ هُوَ عَلَى الْمُقْبِلِيْنَ عَلَيْهِ مُقْبِلٌ وَبِالْعَطْفِ عَلَيْهِمْ عَآئِدٌ مُفْضِلٌ۔ وَبِالْغَافِلِيْنَ عَنْ ذِكْرِهٖ رَحِيْمٌ رَّؤُفٌ وَبِجَذْبِهِمْ اِلٰى بَابِهٖ وَدُوْدٌ عَطُوْفٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012354, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I ask Thee to place me among those of them who have the fullest share from Thee, the highest station with Thee, the most plentiful portion of Thy love, and the most excellent allotment of Thy knowledge, for my aspiration has been cut off from everything but Thee and my desire has turned toward Thee alone.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Mabood! Mai Tujh se sawaal karta hu keh mujhe un logo’n mein rakh jo Tere yahan khush-qismat aur ziyadah naseeb-daar hai, aur Tere huzoor unka maqaam buland hai, aur unho ne Teri rehmat ka ziyadah hissa paaya hai, aur woh Teri maarefat mein se bohot ziyadah hissa le chuke hai.", "Urdu": "میں تجھ سے سوال کرتا ہوں کہ مجھے ان لوگوں میں رکھ جو تیرے ہاں زیادہ حصہ رکھتے ہیں اور تیرے حضور ان کا مقام بلند ہے اور انہوں نے تیری رحمت کا زیادہ حصہ پایا ہے اور وہ تیری معرفت میں سے بہت زیادہ حصہ لے چکے ہیں۔", "RArabic": null, "ArabicText1": "اَسْئَلُكَ اَنْ تَجْعَلَنِىْ مِنْ اَوْفَرِهِمْ مِنْكَ حَظًّا وَاَعْلَاهُمْ عِنْدَكَ مَنْزِلًا وَاَجْزَلِهِمْ مِنْ وُدِّكَ قِسْمًا وَاَفْضَلِهِمْ فِىْ مَعْرِفَتِكَ نَصِيْبًا فَقَدِ انْقَطَعَتْ اِلَيْكَ هِمَّتِىْ وَانْصَرَفَتْ نَحْوَكَ رَغْبَتِىْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012355, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Thou art my object, none other; to Thee alone belongs my waking and my sleeplessness. Meeting Thee is the gladness of my eye, joining Thee the wish of my soul. Toward Thee is my yearning, in love for Thee my passionate longing, in inclining toward Thee my fervent craving. Thy good pleasure is the aim I seek, vision of Thee my need, Thy neighbourhood my request, nearness to Thee the utmost object of my asking. In whispered prayer to Thee I find my repose and my ease.", "Gujarati": null, "RGujarati": null, "RUrdu": "Pas meri himmat Tujh tak aa kar qata ho (cut) gayi hai, aur mai ne apni chaahat Teri taraf pher di hai, Tu hi hai keh Tere siwa mera koi matloob nahi. Meri neend aur be-daari Tere hi liye hai, kisi aur ke liye nahi. Teri mulaqaat meri aankho’n ki thandak aur Tujh se milna meri dili aarzoo hai. Mujhe Tera hi shauq hai, aur Teri hi mohabbat ka junoon hai. Teri chaahat mera ishq hai, aur Teri raza mera maqsood hai, Tera nazaara hi meri zarurat hai, Tera saath meri talab hai. Tera qurb meri aakhri khwahish hai, aur Tujh se raaz o neyaaz mein meri khushi o musarrat hai.", "Urdu": "پس میری ہمت تجھ تک آکر قطع ہوگئی ہے اور میں نے اپنی چاہت تیری طرف پھیر دی ہے تو ہی ہے کہ تیرے سوا میرا کوئی مطلوب نہیں میری نیند اور بیداری تیرے ہی لئے ہے کسی اور کے لئے نہیں تیری ملاقات میری آنکھوں کی ٹھنڈک اور تجھ سے ملنا میری دلی آرزو ہے مجھے تیرا ہی شوق ہے اور تیری ہی محبت کا جنون ہے تیری چاہت میرا عشق ہے اور تیری رضا میرا مقصود ہے تیرا نظارہ ہی میری ضرورت ہے تیرا ساتھ میری طلب ہے تیری قربت میری انتہائی خواہش ہے اور تجھ سے راز و نیاز میں میری خوشی و مسرت ہے۔", "RArabic": null, "ArabicText1": "فَاَنْتَ لَا غَيْرُكَ مُرَادِىْ وَلَكَ لَا لِسِوَاكَ سَهَرِىْ وَسُهَادِىْ وَلِقَآئُكَ قُرَّةُ عَيْنِىْ وَوَصْلُكَ مُنٰى نَفْسِىْ وَاِلَيْكَ شَوْقِىْ وَفِىْ مَحَبَّتِكَ وَلَهِىْ۔ وَاِلٰى هَوَاكَ صَبَابَتِىْ وَرِضَاكَ بُغْيَتِىْ رُؤْيَتُكَ حَاجَتِىْ وَجِوَارُكَ طَلِبَتِيْ وَقُرْبُكَ غَايَةُ سُؤْلِىْ وَفِىْ مُنَاجَاتِكَ رُوْحِىْ وَرَاحَتِىْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012356, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "With Thee lies the remedy of my illness, the cure for my burning thirst, the coolness of my ardour, the removal of my distress. Be my intimate in my loneliness, the releaser of my stumble, the forgiver of my slip, the accepter of my repentance, the responder to my supplication, the patron of preserving me from sin, the one who frees me from my neediness! Cut me not off from Thee and keep me not far from Thee! O my bliss and my garden! O my this world and my hereafter! O Most Merciful of the merciful!", "Gujarati": null, "RGujarati": null, "RUrdu": "Tu hi meri bimaari o alaalat ki dawa, mere soze jigar (jalan) ki shifa, aur soze dil ki thandak hai, aur meri sakhti ka dur hona hai. Pas Tu meri tanhaayi ka saathi ban ja. Meri khataawo’n ko maaf karne waala, Meri kotaahiyo’n ko bakhsh ne waala. Meri taubah qabool karne waala. Meri dua soonne aur qabool karne waala. Meri nigheh-daari ka zimme-daar. Aur kami ko pura karne waala ban ja. Mujhe khud se alag na farma. Aur na khud se dur hata. Ay mere liye neymat, Ay meri Jannat, Ay meri duniya o aakherat. Ay sabse ziyadah rahem karne waale! (hamare haal par rahem farma) Aameen.", "Urdu": "تو ہی میری بیماری کی دوا میرے سوزِ جگر کی شفا سوزِ دل کی ٹھنڈک ہے اور میری سختی کادور ہونا ہے پس تو میری تنہائی کا ساتھی بن جا میری خطاؤں کو معاف کرنے والا میری کوتاہیوں کو بخشنے والا میری توبہ قبول کرنے والا میری دعا قبول کرنے والا میری نگہداری کا ذمہ داراور کمی کو پورا کرنے والا بن جا مجھے خود سے الگ نہ فرما اور نہ خود سے دور ہٹا اے میرے لئے نعمت اے میری جنت اے میری دنیا و آخرت اے سب سے زیادہ رحم کرنے والے۔", "RArabic": null, "ArabicText1": "وَعِنْدَكَ دَوَآءُ عِلَّتِىْ وَشِفَآءُ غُلَّتِىْ وَبَرْدُ لَوْعَتِىْ وَكَشْفُ كُرْبَتِىْ۔ فَكُنْ اَنِيْسِىْ فِىْ وَحْشَتِىْ وَمُقِيْلُ عَثْرَتِىْ وَغَافِرَ زَلَّتِىْ وَقَابِلَ تَوْبَتِىْ وَمُجِيْبَ دَعْوَتِىْ وَوَلِىَّ عِصْمَتِىْ وَمُغْنِيَ فَاقَتِىْ وَلَا تَقْطَعْنِىْ عَنْكَ وَلَا تُبْعِدْنِىْ مِنْكَ يَانَعِيْمِىْ وَجَنَّتِىْ وَيَا دُنْيَاىَ وَاٰخِرَتِىْ يَآاَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) choicest blessings be upon Mohammed and his holy progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar Tu rehmat naazil farma Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par.", "Urdu": "اے معبود! رحمت نازل فرما حضرت محمدؐ اور انکی آل ؑپر۔", "RArabic": "ALLAHUMMA SWALLE ALAA MUHAMMADIW WA AALE MUHAMMADIN", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRed