[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011724, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah make the first part of this day successful, the last have a happy ending and the middle be righteous. O Allah send blessings on Muhammad and his family, make us from among the one who turned repentantly to you so you answered him, and who relied on you so you sufficed him, who beseeched you so you had mercy on him.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Mere aaj ke din ke aaghaaz mein falah, aur uske ikhtetaam par kaamyaabi aur uske darmiyaan mein saadat-mandi ataa farma. Ay Parwardigaar! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par durood bhej, aur hamein un logo’n se qaraar de jo Teri baargah mein aaye aur Tu ne unhe qabool kar liya hai, pas unho ne Tujh par tawakkul kiya aur Tu hi unki kifaayat karta hai, aur woh Teri baargah mein aah o zaari se ilteja karte hai aur Tu ne unhe apni rehmat se nawaaza hai.", "Urdu": "اے پروردگار! میرے آج کے دن کے آغاز میں فلاح، اور اس کے اختتام پر کامیابی اور اس کے درمیان میں سعادت مندی عطا فرما۔ اے پروردگار! محمد و آل محمد پر درود بھیج، اور ہمیں ان لوگوں سے قرار دے جو تیری بارگاہ میں آئے اور تو نے انہیں قبول کر لیا ہے، پاس انہوں نے تجھ پرتوکل کیا ور تو ہی ان کی کفایت کرتا ہے، اور وہ تیری بارگاہ آہ و زاری سے التجا کرتے ہیں اور تو نے انہیں اپنی رحمت سے نوازا ہے۔", "RArabic": "ALLAAHUMMAJ A’L AWWALA YAWMEE HAAZAA FALAAHAN, WA AAKHERAHU NAJAAHAN, WA AWSATAHU SALAAHAN, ALLAAHUMMA SALLE A’LAA MOHAMMADIN WA AALE MOHAMMADIN, WAJ A’LNAA MIMMAN ANAABA ELAYKA FAQABILTAHU, WA TAWAKKALA A’LAYKA FAKAFAYTAHU, WA TAZARRA-A’ ELAYKA FARAHIMTAHU.", "ArabicText1": "اَللّٰہُمَّ اجْعَلْ اَوَّلَ یَوْمِیْ ہٰذَا فَلَاحًا، وَآخِرَہٗ نَجَاحًا، وَاَوْسَطَہٗ صَلَاحًا۔ اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّآلِ مُحَمَّدٍ، وَاجْعَلْنَا مِمَّنْ اَنَابَ اِلَیْکَ فَقَبِلْتَہٗ، وَتَوَکَّلَ عَلَیْکَ فَکَفَیْتَہٗ، وَتَضَرَّعَ اِلَیْکَ فَرَحِمْتَہٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicT