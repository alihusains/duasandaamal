[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018517, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! O the one to degrade every tyrant! O the one to honour the believers! You are my refuge when the paths tire me. My Lord You have created me and have obliged me although You were self sufficient of my existence. And if Your Mercy had not been thers I would have perished. You have sent protection against the enemies and without Your help I would have been in errors. O the one to send mercy from the mines of mercy. O the one to create blessings from the treasurers of blessings. O He who has made honour exclusively for Himself, then honoured His deputies with honour, in front of whom the whole creation stands eyes cast down and heads bowed down. I have hopes from that Great Lord. My Lord I ask You by Your position which You have exhibited by Your greatness and I ask You by Your Honour by which You are on Your throne and have created the entire universe. Now the whole creation is in Your presence heads bowed down send blessing on Mohammed (s.a.w.a) and his Progeny (a.s) (seek your desires after it).", "Gujarati": null, "RGujarati": null, "RUrdu": "Ya Allah! Ay har gardan faraaz (taaqatwar) o dushman ko ruswa karne waale, ay momino ko izzat dene waale, Tu us waqt meri panah hai, jab zahen (mind) thaka de. Ay Parwardigaar! Tu ne hi mujhe paiyda kiya tha aur sirf mujh par maher-baani ke liye, haala’n keh Tu meri takhleeq (paiydaaish) se be-parwa tha aur agar Teri rehmat na hoti to mai maadoom (na) hota, dushmano ke khilaaf Tu ne apni imdaad (madad) se kaamyaab farmaaya aur agar mujhe Teri madad na hoti to mai bad-kaaro’n mein hota. Ay rehmat ke khazaano se rehmat bhej-ne waale, ay barkat ki manzilo’n se barkat paiyda karne waale, ay Woh zaat jis ne apni zaat ko bulandi o sar-bulandi se makhsoos farmaaya hai, phir apne awliya ko apni izzat se moazziz (izzat-daar) farmaaya hai. Jis ke saamne shaahaan’e aalam ruswaiyo’n ke halqe (tauq) gardano mein daal kar sar jhuka rakkhe hai. Ab woh Khuda ki roob o jalaalat se hiraasa’n (dare huwe) hai. Ma’bood! Mai Teri us Parwardigaari ke sadqe mein sawaal karta hu, jise Tu ne apni kibriyaayi se zaahir farmaaya, aur Teri us izzat ke zariye sawaal karta hu jis ke saath apne arsh par ghaalib aa kar saari dunya ko paiyda kiya. Ab saari makhlooq Tere saamne sar’e tasleem jhukaaye hai. Khudaaya! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma.", "Urdu": "یا اللہ! اے ہر گردن فراز و دشمن کو رسوا کرنے والے، اے مومنوں کو عزت دینے والے، تو اس وقت میری پناہ ہے جب ذہن تھکا دیں۔ اے پروردگار! تونے ہی مجھے پیدا کیا تھا اور صرف مجھ پر مہربانی کے لئے، حالانکہ تو میری تخلیق سے بے پروا تھا، اور اگر تیری رحمت نہ ہوتی تو میں معددم (نہ) ہوتا، دشمنوں کے خلاف تونے اپنی امداد سے کامیاب فرمایا اور اگر مجھے تیری مدد نہ ہوتی تو میں بدکاروں میں ہوتا۔ اے رحمت کے خزانوں سے رحمت بھیجنے والے، اے برکت کی منزلوں سے برکت پیدا کرنے والے، اے وہ ذات جس نے اپنی ذت کو بلندی و سر بلندی سے مخصوص فرمایاہے، پھر اپنے اولیا کو اپنی عزّت سے معزز فرمایا ہے۔ جس کے سامنے شاہانِ عالم رسوائیوں کے حلقے گردنوں میں ڈال کر سر جھکا رکھے ہیں، اب وہ خد کی روب و جلالت سے ہراساں ہیں۔ معبود! میں تیری اس پروردگاری کے صدقے میں سوال کرتا ہوں، جسے تونے اپنی کبریائی سے ظاہر فرمایا، اور تیری اس عزّت کے ذریعے سوال کرتا ہوں جس کے ساتھ اپنے عرش پر غالب آکر ساری دنیا کو پیدا کیا، اب ساری مخلوق تیرے سامنے سرِ تسلیم جھکائے ہے۔ خدایا! محمدؐ و آل محمدؑ پر رحمت نازل فرما۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ یَا مُذِلَّ كُلِّ جَبَّارٍ عَنِیْدٍ یَا مُعِزَّ الْمُؤْمِنِیْنَ اَنْتَ كَهْفِیْ حَیْنَ تُعْیِیْنَی الْمَذَاهِبُ وَاَنْتَ یَا رَبِّ خَلَقْتَنِیْ رَحْمَۃً بِیْ وَقَدْ كُنْتَ عَنْ خَلْقِیْ غَنِیًّا وَلَوْ لَا رَحْمَتُكَ لَكُنْتُ مِنَ الْهَالِكِیْنَ اَنْتَ مُؤَیِّدِیْ بِالنَّصْرِ عَلٰی اَعْدَاۗئِیْ وَلَوْ لَا نَصْرُكَ اِیَّایَ لَكُنْتُ مِنَ الْمَقْبُوْ حِیْنَ یَا مُرْسِلَ الرَّحْمَۃِ مِنْ مَعَادِنِهَا وَیَا مُنْشِیَٔ الْبَرَكَۃِ مِنْ مَوَاضِعِهَا یَا مَنْ خَصَّ نَفْسَهٗ بِالسُّمُوِّ وَالرِّفْعَۃِ فَاَوْلِیَاۗؤُهٗ بِعِزَّتِهٖ یَتَعَزَّزُوْنَ یَا مَنْ خَضَعَتْ لَهُ الْمُلُوْكُ بِنِیَرِ الْمَذَلَّۃِ عَلٰی اَعْنَاقِهِمْ فَهُمْ مِنْ سَطَوَاتِهٖ خَاۗئِفُوْنَ اَسْئَلُكَ بِرُبُوْبِیَّتِكَ الَّتِی اشْتَقَقْتَهَا مِنْ كِبْرِیَاۗئِكَ وَاَسْئَلُكَ بِعِزَّتِكَ الَّتِیْ اسْتَوَیْتَ بِهَا عَلٰی عَرْشِكَ فَخَلَقْتَ بِهَا جَمِیْعَ خَلْقِكَ فَهُمْ لَكَ مُذْعِنُوْنَ اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّاَهْلِ بَیْتِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenS