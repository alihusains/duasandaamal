ull, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013793, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I obtain my dignity from following Your religion and I am honored because of You have guided me, but [so-and-so] is humiliating me by his evil, insulting me by harming me, imputing dishonor to me because I am loyal to Your Representatives, and charging me with false claims. I have come to the center of supplication and the guarantee of response. O Allah, (please) send blessings upon Muhammad and his Household and support me against him at this very hour! At this very hour!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mujhe Tere deen ke zariye izzat mili aur is rauze se sharaf mila lekin fulaan ne apni badi (buraayi) se mujhe khwaar (zaleel) kiya, apni izzat se mujhe ruswa kiya, Tere auliya ki wilaayat ke baais mujhe maayoob kiya (tohmat lagayi) aur na-rawa baato’n se mujhe mabhoot (khouf zadah) kar diya hai, ab mai dua maang ne us jagah aaya hu jahan par qabool karne ki Tu ne zamaanat di hai. Ay Ma’bood! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma aur mujhe us zaalim par ghalba de abhi isi waqt.", "Urdu": "اے معبود! مجھے تیرے دین کے ذریعے عزّت ملی اور اس روضہ سے شرف ملا لیکن فلاں نے اپنی بدی سے مجھے ذلیل و خوار کیااپنی اذیت سے مجھے رسوا کیاتیرے اولیاء کی ولایت کے باعث مجھے معیوب کیا اور ناروا باتوں سے مجھے مبہوت وحیران کر دیا ہے اب میں دعا مانگنے اس جگہ آیاہوں جہاں پر قبول کرنے کی تو نے ضمانت دی ہے اے معبود! محمدؐو آل محمدؑ پر رحمت نازل فرما اور مجھے اس ظالم پر غلبہ دے ابھی اسی وقت۔", "RArabic": "ALLAAHUMMA INNEE A-A’-TAZZO BE DEENEKA WA AKROMO BE HEDAAYATEKA WA FOLAANUN YOZILLONEE BE SHARREHI WA YOHEENUNEE BE-AZIYYATEHI WA YO-E’EBONEE BE WELAAAA-E AWLEYAAA-EKA WA YABHATONEE BEDA’-WAAHO WA QAD JEA-TO ELAA MAWZE-I’D DO-A’AA-E WA ZEMAANEKAL EJAABATA ALLAAHUMMA SALLE A’LAA MOHAMMADIN WA AALE MOHAMMADIN WA AA’-DENEE A’LAYHIS SAA-A’TAS SAA-A’TA.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَعْتَزُّ بِدِیْنِكَ وَاَكْرُمُ بِهِدَایَتِكَ وَفُلَانٌ یُذِلُّنِیْ بِشَرِّهٖ وَیُهِیْنُنِیْ بِاَذِیَّتِهٖ وَیُعِیْبُنِیْ بِوِلَآءِ اَوْلِیَآئِكَ وَیَبْهَتُنِیْ بِدَعْوَاهُ وَقَدْ جِئْتُ اِلٰی مَوْضِعِ الدُّعَآءِ وَضِمَانِكَ الْاِجَابَۃَ۔ اَللّٰهُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاَعْدِنِیْ عَلَیْهِ السَّاعَۃَ السَّاعَۃَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013794, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Then one should throw oneself on the grave and say this statement while repeating the last word (NASRA) as many times as one may take the breath…", "GujaratiDescription": null, "RUrduDescription": "Phir apne ko rauze par gira de aur is tarah kahe aur aakhri zikr (NASRA) ko saans ke tootne tak kehte rahe…", "UrduDescription": "پھر خود کو قبرِ مبارک پر گراکر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null