[{"Id": 1013792, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Shaykh Tusi in his book of Misbah al-Mutahajjid says, if one is oppressed or one who has been exposed to wronging by an oppressor is advised to pray Almighty Allah with this dua inside the Shrine…", "GujaratiDescription": null, "RUrduDescription": "Shaikh Tusi apni kitaab Misbah al-Mutahajjid mein farmate hai, keh agar kisi par zulm huwa hai ya koi zaalim se pareshaan hai, to usey chahiye keh woh is dua ko Imam ke haram mein padhe…", "UrduDescription": "شیخ طوسی اپنی کتاب مصبح المتھجد میں فرماتے ہے کہ اگر کسی پر ظلم ہوا ہے، یا کوئی ظالم سے پریشان ہے، تو اسے چاہیئے کہ وہ اس دُعا کو امامؑ کے حرم میں پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicB