[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015439, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to You O Sovereign in whose hands lies all affairs He who is not unable to do anything He wishes to do! Nothing is reduced of Him due to bestowing or adding O my God! If my Book of Deeds is black with sins I rely on You to wipe them off on these Bright Nights hoping forgiveness and pardoning that are in Your Hands If You do so, nothing will be reduced from You but I prosper If You do not, nothing will be added to You but I will be destroyed O my God! Please do so for my past good and sincere testimonies regarding what You have bestowed on me and I would not have realized this were it not due to Your Favors And give me refuge from Your Wrath, grant me Your Pleasure and Protection by it, and give me success to engage in deeds that You consider to be pure Please save me from frivolities and slippages as You blot out or confirm what You please and with You is the Mother of the Book Please bestow blessings on the Prophet Muhammad and his Progeny and greet them many times.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "SUNHAANA-KA AYYO-HAL MALEKUL QADEE-RUL LAZEE BE-YADE-HIL O-MOORO WA LAA YO’JEZO-HU MAA YOREE-DO WA LAA YAN-QOSO-HUL A’TAAA-O WAL MAZEEDO. ALLAAHUMMA IN KAANAT SAHEE-FATEE MUSWAD-DATAN (MOSAWWA-DATAN) BIZ-ZONOO-BE ILAIY-KA FA-INNEE O-A’W-WELO FEE MAHWE-HAA FEE HAAZE-HIL LAYAA-LIL BAIY-ZE A’LAIY-KA WA ARJOO MENAL GHUF-RAANE WAL A’FWE MAA HOWA NE-YADE-KA FA-IN JUDTA BEHI A’LAIYYA LAM YAN-QUS-KA WA FUZTO WA IN HARAM-TANEE-HE LAM YAZID-KA WA A’TIB-TO WA BE-MAA JUDTA BEHI A’LAIYYA MIN ZAALE-KA WA MAA KUNTO LE-A’RE-FAHU LAW LAA TAFAS-SOLO-KA WA ANIL-NEE BEHI REZAA-KA WA I’S-MATE-KA WA WAFFIQ-NEE LE-ISTE-NAAFE MAA YAZKOO LA-DAIY-KA MINAL A’MA-LE WA JANNIB-NIL HAFA-WAATE WAZ-ZALALA FA-INNA-KA TAMHOO MAA TASHAA-O WA TUS-BE-TO WA I’NDA-KA UMMUL KETAABE WA SALLAL-LAAHO A’LAA MOHAMMADIN NABIYYE WA AALE-HI WAS-SALLA-MA KASEE-RAN.", "ArabicText1": "سُبْحَانَكَ اَيُّهَا الْمَلِكُ الْقَدِيْرُ الَّذِيْ بِيَدِهِ الْاُمُوْرُ وَلَا يُعْجِزُهٗ مَا يُرِيْدُ وَلَا يَنْقُصُهُ الْعَطَاۗءُ وَالْمَزِيْدُ۔ اَللّٰهُمَّ اِنْ كَانَتْ صَحِيْفَتِيْ مُسْوَدَّةً (مُسَوَّدَةً) بِالذُّنُوْبِ اِلَيْكَ فَاِنِّيْ اُعَوِّلُ فِيْ مَحْوِهَا فِيْ هٰذِهِ اللَّيَالِي الْبَيْضِ عَلَيْكَ وَاَرْجُوْ مِنَ الْغُفْرَانِ وَالْعَفْوِ مَا هُوَ بِيَدِكَ فَاِنْ جُدْتَ بِهٖ عَلَيَّ لَمْ يَنْقُصْكَ وَفُزْتُ وَاِنْ حَرَمْتَنِيْهِ لَمْ يَزِدْكَ وَعَطِبْتُ وَبِمَا جُدْتَ بِهٖ عَلَيَّ مِنْ ذٰلِكَ وَمَا كُنْتُ لِاَعْرِفَهٗ لَوْ لَا تَفَضُّلُكَ وَاَنِلْنِيْ بِهٖ رِضَاكَ وَعِصْمَتَكَ ‌وَ وَفِّقْنِيْ لِاِسْتِئْنَافِ مَا يَزْكُوْ لَدَيْكَ مِنَ الْعَمَلِ وَجَنِّبْنِي الْهَفَوَاتِ وَالزَّلَلَ فَاِنَّكَ تَمْحُوْ مَا تَشَاۗءُ وَتُثْبِتُ وَعِنْدَكَ اُمُّ الْكِتَابِ وَصَلَّى اللهُ عَلٰى مُحَمَّدٍ النَّبِيِّ وَآلِهٖ وَسَلَّمَ كَثِيْرًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueS