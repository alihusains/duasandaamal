[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015547, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Him who shall not perish. Glory be to Him whose Dominion does not end. Glory be to Him from whom the hiding are not hidden! Glory be to Him without whose knowledge even a leaf does not fall! Not a grain grows in the darkness of the earth, nor anything fresh or dry but it is noted in a Clear Book and only with His Knowledge and Power.", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak o munazzah hai woh zaat jise maut nahin aati, paak o munazzah hai woh zaat jiski baadshaahi zaael nahin hoti, paak o munazzah hai jis se koi shai makhfi (chhupi) nahin, paak o munazzah hai woh zaat keh koi patta bhi girta hai to uska bhi ilm Usko hota hai, zameen ki taarikiyo’n (andhero’n) mein koi daana ya koi khusk o tar (dry and wet) aisa nahin hai jo kitaab’e mobeen ke andar mehfooz na ho, magar uska ilm aur qudrat uska ehaata kiye (ghere) huwe hai.", "Urdu": "پاک و منزہ ہے وہ ذات جسے موت نہیں آتی، پاک و منزہ ہے وہ ذات جس کی بادشاہی زائل نہیں ہوتی، پاک و منزہ ہے جس سے کوئی شئے مخفی نہیں، پاک و منزہ ہے وہ ذات کہ کوئی پتہ بھی گرتا ہے تو اس کا علم ہوتا ہے، زمین کی تاریکیوں میں کوئی دانہ یا کوئی خشک و تر ایسا نہیں ہے جو کتاب مبین کے اندر محفوظ نہ ہو، مگر اس کا علم اور قدرت اس کا احاطہ کئے ہوئے ہے۔", "RArabic": "SUBHAANA-MAN LAA YAMOO-TO, SUBHAANA MAN LAA YAZOO-LO MULKO-HU, SUBHAANA MAN LAA TAKH-FAA A’LAIY-HE KHAAFE-YATOON, SUBHAANA MAN LAA TAS-QOTO WA RAQA-TOON ILLAA YA’LAMO-HAA (BE-I’L-ME-HI) WA LAA HABBA-TIN FEE ZOLO-MAATIL ARZE WA LAA RAT-BIW WA LAA YAA BESIN ILLAA FEE KITAA-BIM MOBEE-NIN (YA’LAMO-HU WA QADDAR-HU) ILLAA BE-I’L-ME-HI WA BE-QUDRATE-HI.", "ArabicText1": "سُبْحَانَ مَنْ لَّا يَمُوْتُ، سُبْحَانَ مَنْ لَّا يَزُوْلُ مُلْكُهٗ، سُبْحَانَ مَنْ لَّا تَخْفٰى عَلَيْهِ خَافِيَةٌ، سُبْحَانَ مَنْ لَّا تَسْقُطُ وَرَقَةٌ اِلَّا يَعْلَمُهَا (بِعِلْمِهٖ) وَلَا حَبَّةٍ فِيْ ظُلُمَاتِ الْاَرْضِ وَلَا رَطْبٍ وَّلَا يَابِسٍ اِلَّا فِيْ كِتَابٍ مُّبِيْنٍ‌ (يَعْلَمُهٗ وَقَدَّرَهٗ) اِلَّا بِعِلْمِهٖ وَبِقُدْرَتِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlu