[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013002, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah send blessings on Hassan, Thy servant Thy dearest friend, the son of Thy Messenger, the offspring of “Mercy”, the prime leader of the people of the Paradise, much and more blessings than Thou had bestowed upon any of the sons of the Prophets and Messengers, O Allah send blessings on Hasan, the son of the Prophet-in-chief, and the successor of the Ameer ul Momeneen.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Imam Hasan (a.s) par durood bhej jo Tere banda'e mehboob Tere Rasool (s.a.w.a) ke bete, rehmat waale nawaase aur Jawaanaan'e Jannat ke sayyad o sardaar hai, un par be-htareen rehmat naazil farma, jaise rehmat Tu ne nabiyyo’n aur rasoolo’n ki aulaad mein se kisi par bheji ho. Ay Ma’bood! Imam Hasan (a.s) par durood bhej jo nabiyyo’n ke sardaar ke farzand aur momino ke ameer ke ja-nasheen hai.", "Urdu": "اے معبود! امام حسنؑ پر درود بھیج جو تیرے بندۂ محبوب تیرے رسولؐ کے بیٹے رحمت والے نواسے اور جوانان جنّت کے سید و سردار ہیں ان پر بہترین رحمت فرما جیسی رحمت تو نے نبیوں اور رسولوں کی اولاد میں سے کسی پر بھیجی ہو۔ اے معبود! امام حسنؑ پر درود بھیج جو نبیوں کے سردار کے فرزند ہیں اور مومنوں کے امیر کے جانشین ہیں۔", "RArabic": "ALLAAHUMMA SALLE A'LAL HASANE A'BDEKA WA WALIYYEKA WABNE RASOOLEKA WA SIBTIR RAHMATE WA SAYYEDE SHABAABE AHLIL JANNATE AFZALA MAA SALLAYTA A'LAA AHADIM MIN AWLAADIN NABIYYEENA WAL MURSALEENA ALLAAHUMMA SALLE A'LAL HASANIBNE SAYYEDIN NABIYYEENA WA WASIYYE AMEERIL MOMENEENA.", "ArabicText1": "اَللّٰہُمَّ صَلِّ عَلَی الْحَسَنِ عَبْدِكَ وَ وَلِیِّكَ وَابْنَ رَسُوْلِكَ وَسِبْطِ الرَّحْمَۃِ وَسَیِّدِ شَبَابِ اَھْلِ الْجَنَّۃِ اَفْضَلَ مَا صَلَّیْتَ عَلٰی اَحَدٍ مِّنْ اَوْلَادِ النَّبِیِّیْنَ وَالْمُرْسَلِیْنَ۔ اَللّٰہُمَّ صَلِّ عَلَی الْحَسَنِ بْنِ سَیِّدِ النَّبِیِّیْنَ وَ وَصِیِّ اَمِیْرِ الْمُؤْمِنِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013003, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on you, O the son of the Messenger of Allah! Peace be on you, O the son of the first of the successors! I bear witness that, verily, you (O the son of the Ameer ul Momineen), are the faithful trustee of Allah, just as your father is lived in the midst of mischief, intrigue and oppression, and departed from this world as a martyr. I bear witness that, verily, you are the rightly guided pure guide. O Allah send blessing on him, and let my heartfelt greetings and salutations reach him just now.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Rasool'e Khuda (.s.a.w.a) ke farzand, Aap par salaam ho ay awsiya ke sardaar ke farzand. Mai gawahi deta hu keh aap momino ke ameer ke farzand, Khuda ke amaanat-daar aue Uske ameen ke farzand hai, aap dunya mein mazloom jiye aur shahadat ow kar guzre. Mai gawahi deta hu keh aap Imam (a.s) hai, paak-shudah hidaayat dene waale hidaayat-yaafta thay. Ay Ma’bood! Un par rehmat naazil kar aur unki rooh aur unke jism ko meri taraf se is lamhe mein beh-tareen durood o salaam aur aadaab pohoncha de.", "Urdu": "آپ پر سلام ہو اے رسول خداؐ کے فرزند، آپ پر سلام ہو اے اوصیاء کے سردار کے فرزند۔ میں گواہی دیتا ہوں کہ آپ مومنوں کے امیر کے فرزند خدا کے امانتدار اور اس کے امین کے فرزند ہیں آپ دنیا میں مظلوم جیے اور شہید ہو کر گزرے میں گواہی دیتا ہوں کہ آپ امامؑ ہیں پاک شدہ ہدایت دینے والے ہدایت یافتہ تھے۔ اے معبود! ان پر رحمت نازل کر اور ان کی روح اور ان کے جسم کو میری طرف سے اس لمحے میں بہترین درود و سلام اور آداب پہنچا دے۔", "RArabic": "ASSALAAMO A'LAYKA YABNA RASOOLIL LAAHE. ASSALAAMO A'LAYKA YABNA SAYYEDIL WASIYYEENA ASH-HADO ANNAKA YABNA AMEERIL MOOMENEENA AMEENUL LAAHE WABNO AMEENEHI I'SHTA MAZLOOMAN WA MAZAYTA SHAHEEDAN WA ASH-HADO ANNAKAL EMAAMUZ ZAKIYYUL HAADIL MAHDIYYO ALLAAHUMMA SALLE A'LAYHE WA BALLIGH ROOHAHU WA JASADAHU A'NNEE FI HAAZEHIS SAA-A'TE AFZALAT TAHHIYYATE WAS-SALAAME.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا بْنَ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ سَیِّدِ الْوَصِیِّیْنَ۔ اَشْہَدُ اَنَّكَ یَابْنَ اَمِیْرِ الْمُؤْمِنِیْنَ اَمِیْنُ اللہِ وَابْنُ اَمِیْنِہٖ عِشْتَ مَظْلُوْمًا وَمَضَیْتَ شَہِیْدًا۔ وَاَشْہَدُ اَنَّكَ الْاِمَامُ الزَّكِیُّ الْہَادِیْ الْمَہْدِیُّ۔ اَللّٰہُمَّ صَلِّ عَلَیْہِ وَبَلِّغْ رُوْحَہٗ وَجَسَدَہٗ عَنِّیْ فِیْ ہٰذِہِ السَّاعَۃِ اَفْضَلَ التَّحِیَّۃِ وَالسَّلَامِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "Arab