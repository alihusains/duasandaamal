ign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000603, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, bless Muhammad and his Household and release me from a debt which makes me lose face, confuses my mind, disrupts my thinking, and prolongs my occupation with attending to it! I seek refuge in Thee, my Lord, from worry and thought about debt, from the distraction and sleeplessness of debt; so bless Muhammad and his Household and give me refuge from it! I seek sanctuary in Thee, my Lord, from debt’s abasement in life and its ill effects after death, so bless Muhammad and his Household and give me sanctuary from it through a bountiful plenty or a continually arriving sufficiency!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Hazrat Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur mujhe aise karz se mehfooz rakh jisse meri izzat aabru ko nuqsaan pohonche, aur mera zahen pareshaan aur fikr pareshaan-haal rahe, aur uski adaayegi ki fikr mein hamesha mashgul rahu. Ay mere Parwardigaar! Mai Tujh se panah maangta hu karz ke fikr, andeshe se aur pareshaaniyo’n se aur uski wajah se chain se na sone se. Tu Hazrat Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur mujhe karz se panah de, Parwardigaar mai Tujh se zindagi mein uski zillat aur marne ke baad uske bure anjaam se panah maangta hu. Pas Hazrat Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma, mujhe maal o daulat ki kasrat aur hamesha rizq pohonchane ke zariye se karz se chutkaara ataa kar.", "Urdu": "اے اللہ! محمد اور ان کی آل پر رحمت نازل فرما اور مجھے ایسے قرض سے نجات دے، جس سے تو میری آبرو پر حرف آنے دے اور میرا ذہن پریشان اور فکرپراگنده رہے اور اس ی فکر و تدبر میں ہمہ وقت مشغول رہوں۔ اے میرے پروردگار! میں تجھ سے پناہ مانگتا ہوں قرض کے فکرواندیشہ سے اور اس کے جھمیلوں سے اور اس کے باعث بے خوابی سے تو محمد ور ان کی آل پر رحمت نازل فرما۔ اور مجھے اس سے پناہ دے۔ پروردگار! میں تجھ سے زندگی میں اس کی ذلت اور مرنے کے بعد اس کے وبال سے پناہ مانگتا ہوں۔ تو محمد اور ان کی آل پر رحمت نازل فرما اور مجھے مال و دولت کی فراوانی اور پیہم رزق رسانی کے ذریعے اس سےچھٹکارا دے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِهٖ وَهَبْ لِيَ الْعَافِيَةَ مِنْ دَيْنٍ تُخْلِقُ بِهٖ وَجْهِيْ وَيَحَارُ فِيْهِ ذِهْنِيْ وَيَتَشَعَّبُ لَهٗ فِكْرِيْ وَيَطُوْلُ بِمُمَارَسَتِهٖ شُغْلِيْ وَاَعُوْذُ بِكَ يَا رَبِّ مِنْ هَمِّ الدَّيْنِ وَفِكْرِهٖ وَشُغْلِ الدَّيْنِ وَسَهَرِهٖ فَصَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِهٖ وَاَعِذْنِيْ مِنْهُ وَاَسْتَجِيْرُ بِكَ يَا رَبِّ مِنْ ذِلَّتِهٖ فِي الْحَيَاةِ وَمِنْ تَبِعَتِهٖ بَعْدَ الْوَفَاةِ فَصَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِهٖ وَاَجِرْنِيْ مِنْهُ بِوُسْعٍ فَاضِلٍ اَوْ كَفَافٍ وَاٰصِلٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001802, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, bless Muhammad and his Household prevent me from extravagance and excess, put me on the course of generous spending and moderation, teach me excellent distribution, hold me back through Thy gentleness from squandering, allow me to attain my provisions through lawful means, direct my spending toward the gateways of devotion, and take away from me any possession which will bring forth pride in me, lead to insolence, or drag me in its heels to rebellion!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Hazrat Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur mujhe fuzool kharchi aur israaf se bacha, aur mujhe sahih jagah par kharch karne aur darmiyaani raaste par qaayam rakh, aur mere liye halaal rozi ka saamaan mohayya kar aur mere maal ka istemaal nek kaamo mein qaraar de, aur us maal ko mujh se dur hi rakh jo mere andar guroor o takabbur paiyda kare ya uska natija zulm o ziyadahti sarkashi ho.", "Urdu": "اے اللہ محمد اور ان کی آل پر رحمت نازل فرما۔ اور مجھے فضول خرچی اور مصارف کی زیادتی سے روک دے اور عطا و میانہ روی کے ساتھ نقطہ اعتدال پر قائم رکھ اور میرے لۓ حلال طریقوں سےروزی کا سامان کر اور میرے مال کو مصرف امور خیر میں قرار دے اور اس مال کو مجھ سے دور ہی رکھ جو میرے اندر غرور و تمکنت پیدا کرے یا ظلم کی راہ پر ڈال دے یا اس کا نتیجہ طغیان وسرکشی ہو۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِهٖ وَاحْجُبْنِيْ عَنِ السَّرَفِ وَالْاِزْدِيَادِ وَقَوِّمْنِيْ بِالْبَذْلِ وَالْاِقْتِصَادِ وَعَلِّمْنِيْ حُسْنَ التَّقْدِيْرِ وَاقْبِضْنِيْ بِلُطْفِكَ عَنِ التَّبْذِيْرِ وَاَجْرِ مِنْ اَسْبَابِ الْحَلَالِ اَرْزَاقِيْ وَوَجِّهْ فِيْ اَبْوَابِ الْبِرِّ اِنْفَاقِيْ وَازْوِ عَنِّيْ مِنَ الْمَالِ مَا يُحْدِثُ لِيْ مَخِيْلَةً اَوْ تَاَدِّيًا اِلٰى بَغْيٍ اَوْ مَا اَتَعَقَّبُ مِنْهُ طُغْيَانًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001803, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, make me love the companionship of the poor and help me be their companion with excellent patience! Whenever Thou takest away from me the goods of this perishing world, store them for me in Thy abiding treasuries! Make this world’s broken pieces which Thou hast conferred upon me and its goods which Thou hast quickly granted to me a way to reach Thy neighbourhood, a link to Thy nearness, and a means to Thy Garden! Verily Thou art Possessor of bounty abounding, and Thou art the Munificent, the Generous.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Durwesho’n (fakiro’n, garibo’n) ke saath uthna baithna meri nazro’n mein pasandida bana, aur itmenaan waale sabr ke saath un sabse dosti karne mein meri madad farma, aur is khatm hone waali duniya ke saaz o saamaan mein se jo kuchh Tu ne mujh se rok liya hai usko mere liye apne baaqi rehne waale khazaane mein jama kar, aur jo kuchh Tu ne is duniya ki poonji mein se mujh ko marhamat (ataa) kiya hai usko apni bargah mein bulaate waqt hamara zaade-raaha (saamaan-e-safar) qaraar de aur apni bargah mein qabr ka zariya bana de, apni Jannat mein daakhil hone ka wasila qaraar de. Be-shak Tu bohot hi bade fazl waala aur Tu hi sakhaawat o karam waala hai.", "Urdu": "اے اللہ! درویشوں کی ہم نشینی میری نظروں میں پسندیدہ بنا دے اور اطمینان افزا صبر کے ساتھ ان کی رفاقت اختیار کرنے میں میری مدد فرما۔ دنیاۓ فانی کے مال میں سے جو تو نے مجھ سے روک لیا ہے۔ اسے اپنے باقی رہنے والے خزانوں میں میرے لۓ ذخیرہ کر دے اور اس کے سازو برگ میں سے جو تو نے دیا ہے اور اس کے سروسامان میں سے جو بہم پہنچایا ہے اسے اپنے جوار(رحمت) تک پہچنے کا زاد راہ، حصول تقرّب کا وسیلہ اور جنت تک رسائی کا ذریعہ قرار دے اس لۓ کہ تو فضل عظیم کا مالک اور سخی و کریم ہے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ حَبِّبْ اِلَيَّ صُحْبَةَ الْفُقَرَاۗءِ وَاَعِنِّيْ عَلٰى صُحْبَتِهِمْ بِحُسْنِ الصَّبْرِ وَمَا زَوَيْتَ عَنِّيْ مِنْ مَتَاعِ الدُّنْيَا الْفَانِيَةِ فَاذْخَرْهُ لِيْ فِيْ خَزَاۗئِنِكَ الْبَاقِيَةِ وَاجْعَلْ مَا خَوَّلْتَنِيْ مِنْ حُطَامِهَا وَعَجَّلْتَ لِيْ مِنْ مَتَاعِهَا بُلْغَةً اِلٰى جِوَارِكَ وَوُصْلَةً اِلٰى قُرْبِكَ وَذَرِيْعَةً اِلٰى جَنَّتِكَ اِنَّكَ ذُوالْفَضْلِ الْعَظِيْمِ وَاَنْتَ الْجَوَادُ الْكَرِيْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "Arab