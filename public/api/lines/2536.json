nSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1020384, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Oh Allah, I ask you for protection and faith and that I have faith in your Prophet Muhammad’e Mustafa (s.a.w.a), and that you protect me from all of the calamities, and that when you protect me from all of these calamities that I am thankful of what you have done, and that you protect me from people who are problematic. Oh Allah! For the sake of Muhammad (s.a.w.a) and Aale Muhammad (a.s) please accept my prayer.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Tujh se amn o Imaan aur Tere nabi Muhammad’e Mustafa (s.a.w.a) ki tasdeeq aur tamaam balaawo’n se najaat aur phir najaat par shukr aur sharer (sharaarati) logo’n se be-neyaazi ka sawaal karta hu. Khudaaya! Be-haqqe Muhammad (s.a.w.a) aur Aale Muhammad (a.s) qabool farmaaye.", "Urdu": "خدایا تجھ سے امن اور ایمان اور تیرے نبی محمد مصطفٰیؐ کی تصدیق اور تمام بلاؤں سے نجات اور پھر نجات پر شکر اور شریر لوگوں سے بے نیازی کا سوال کرتا ہوں خدایا بحق محمدؐ و آل محمدؑ قبول فرمائیے۔", "RArabic": "ALLAAHUMMA INNEE AS-ALO-KAL AMNA WAL IMAANA BEKA WAT TASDEE-QA BE-NABIYYE-KA WAL A’AFE-YATA MIN JAMEE’IL BALAAA-E WASH-SHUKRA A’LAL A’AFE-YATE WAL GHENAAA-E A’N SHARAA-RIN NAAS.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْٓ اَسْئَلُكَ الْاَمْنَ وَالْاِیْمَانَ بِكَ وَالتَّصْدِیْقَ بِنَبِیِّكَ وَالْعَافِیَۃَ مِنْ جَمِیْعِ الْبَلَاۗءِ وَالشُّكْرَ عَلَی الْعَافِیَۃِ وَالْغِنَاۗءِ عَنْ شَرَارِ النَّاسِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": n