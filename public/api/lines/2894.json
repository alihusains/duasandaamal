[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002286, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I am resorting to You with my needs, and I am putting in Your presence my poverty, my indigence, and my deprivation. Verily, I hope for Your forgiveness more than I rely on my deeds. Indeed, Your forgiveness and Your mercy are more inclusive than my sins are. So, (please) embark on settling all my needs out of Your power over them, out of the easiness for You to do that, and out of my urgent need for that. Verily, I have not gained any good thing save from You and none could ever repel evil from me save You. I hope for none to stand for me in my affairs of this world and the Next World and on the day of my poverty, when people will leave me alone in my hole (i.e. grave) and I will then confess of my sins before You, except You.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Apni haajat le kar Tere huzoor aaya hu aur aaj ke din Teri jaanib mai apne faqr o faaqa aur be-chaaragi ke saath haazir hu. To mai apne amal ke bajaaye Teri bakhshish par nazar rakhta hu aur Teri bakhshish o rehmat mere gunaho’n se ziyadah wus’at rakhti hai. Pas meri tamaam haajaat puri farma keh Tu aisa karne ki qudrat rakhta hai aur yeh Tere liye bohot hi aasaan hai aur meri mohtaji ke munaasib hai, khyu’n keh mai Teri taufiq ke bagair koi neki nahi kar sakta aur siwaaye Tere mujhe buraayi se bachane waala koi nahi hai aur mai apni duniya o aakherat ke baare mein siwaaye Tere kisi se ummeed nahi rakhta aur na us din jab log mujhe qabr mein akela chhod jaayenge mai apni be-chaargi aur apne gunaho’n mein Tere siwa kisi ko kaar-saaz nahi samajhta.", "Urdu": "اے معبود! اپنی حاجت لے کر تیرے حضور آیا ہوں اور آج کے دن تیری بارگاہ میں اپنے فقر و فاقہ اور بے چارگی کے ساتھ حا ضر ہوں تو اپنے عمل کے بجائے تیری بخشش و رحمت کی زیادہ امید رکھتا ہوں اور تیری بخشش و رحمت میرے گناہوں سے زیادہ وسعت رکھتی ہے پس میری تمام حاجات پوری فرماکہ تو ایسا کرنے کی قدرت رکھتا ہے اور یہ تیرے لئے بہت ہی آسان اور میری محتاجی کے مناسب ہے کیوں کہ میں تیری توفیق کے بغیر کوئی نیک کام نہیں کرسکتا اور تیرے سوا مجھے برائی سے بچانے والا کوئی نہیں ہے اور میں اپنی دنیاو آخرت اور غربت وتنہائی کے بارے میں تیرے علاوہ کسی سے امید نہیں رکھتا اور نہ اس دن جس دن مجھے لوگ قبر میں اکیلا چھوڑ جائیں گے اور میں اپنے گناہوں میں تیرے سوا کسی کو کارساز نہیں سمجھتا۔", "RArabic": "ALLAAHUMMA INNEE TA-A’MMAD-TO ILAIKA BE-HAAJA-TEE WA AN-ZALTO ILAI-KAL YAWMA FAQREE WA FAAQA-TEE WA MASKANA-TEE FA ANAA LE-MAGH-FERA-TEKA ARJAA MINNEE LE-A’MA-LEE WA LA-MAGH-FERA-TOKA WA RAHMATO-KA AWSE-O’ MIN ZONOO-BEE FA-TAWALLA QAZAA-A KULLE HAAJA-TIL LEE BE-QUDRATE-KA A’LAI-HAA WA TAIY-SEERE (TAYASSO-RE) ZAALEKA A’LAIKA WA LE-FAQREE ILAIKA FA-INNEE LAM O-SIB KHAIRAN QATTO ILAA MINKA WA LAM YASRIF A’NNEE SOO-A QATTO AHA-DOON SEWAA-KA WA LASTO (LAIY-SA) ARJOO LE-AAKHERA-TEE WA DUNYAA-YA WA LAA LE-YAWME FAQREE YAWMA YUFRE-DO-NIN NAASO FEE HUFRA-TEE WA UFZEE ILAIKA BE-ZANBEE SEWAA-KA.", "ArabicText1": "اَللّٰهُمَّ اِنِّيْ تَعَمَّدْتُ اِلَيْكَ بِحَاجَتِيْ وَاَنْزَلْتُ اِلَيْكَ الْيَوْمَ فَقْرِيْ وَفَاقَتِيْ وَمَسْكَنَتِيْ فَاَنَا لِمَغْفِرَتِكَ اَرْجٰى مِنِّيْ لِعَمَلِيْ وَلَمَغْفِرَتُكَ وَرَحْمَتُكَ اَوْسَعُ مِنْ ذُنُوْبِيْ فَتَوَلَّ قَضَآءَ كُلِّ حَاجَةٍ لِّيْ بِقُدْرَتِكَ عَلَيْهَا وَتَيْسِيْرِ (تَيَسُّرِ) ذٰلِكَ عَلَيْكَ وَلِفَقْرِيْ اِلَيْكَ فَاِنِّيْ لَمْ اُصِبْ خَيْرًا قَطُّ اِلَا مِنْكَ وَلَمْ يَصْرِفْ عَنِّيْ سُوْٓءَا قَطُّ اَحَدٌ سِوَاكَ وَلَسْتُ (لَيْسَ) اَرْجُوْ لِآخِرَتِيْ وَدُنْيَايَ وَلَا لِيَوْمِ فَقْرِيْ يَوْمَ يُفْرِدُنِي النَّاسُ فِيْ حُفْرَتِيْ وَاُفْضِيْ اِلَيْكَ بِذَنْبِيْ سِوَاكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17":