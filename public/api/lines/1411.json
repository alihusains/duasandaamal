[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000138, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My Allah, the Salaat (Namaz) I have just prayed, was not to put forth any demand before Thee, nor was there any self-seeking desire to reach Thee through it. It was nothing but praise, obedience and surrender unto Thee, in order to carry out that which Thou has commanded. My Allah, If there was a break of continuity (disturbance of mind) or shortcoming, while making the intention, or standing, while bowing down, or prostrating in adoration, do not catch hold of me, (but) have the kindness of bestowing a favour on me, by affording me through Thy mercy absolution and acceptance, O the Most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Khuda! Yeh meri namaz jise mai ne padha hai, Tujhe iski haajat nahi aur na hi Tujhe iski khwaaish aur iski taraf raghbat thi, lekin mai ne isko sirf Teri azmat wa ita’at wa farma-bardaari ke liye adaa kiya hai, kyu’n keh Tu ne mujhe iska hukm diya tha. Ay mere Khuda! Agar is mein koi khalal ya kami ho, iske ruku mein ya sujood mein, to mujh se baaz-purs na farma aur isey apne fazl o rehmat se qabool farma aur mujhe bakhsh de.", "Urdu": "اے اﷲ!جو میں نے نمازپڑھی ہے یہ نہ اس لئے ہے کہ تجھے اس کی حاجت تھی اور نہ اس لئے ہے کہ تجھے اس میں رغبت تھی ہاں یہ صرف تیری تعظیم واطاعت اور تیرے حکم کی اطاعت ہے جو تو نے مجھے دیا۔خداوندا! اگر اس نماز میں کوئی خلل یا اس کے رکوع وسجود میں کچھ کمی ہو تواس پر میری گرفت نہ فرما اور اس کی قبولیت اور بخشش کے ساتھ مجھ پر فضل وکرم کر دے۔", "RArabic": "ILAAHEE HAAZE-HI SALAA-TEE SAL-LAIY-TOHAA LAA LE-HAAJA-TAN MINKA E-LAIY-HAA WA LAA RAGH-BA-TIN MINKA FEE-HAA ILLAA TA’ZEE-MAN WA TAA-A’TAN WA EJAA-BATAN LAKA ILAA MAA AMAR-TA-NEE BEHI ILAA-HEE IN KAANA FEE-HAA KHALA-LOON AW NAQ-SOON MIN ROKOO-E’HAA AW SOJOODE-HAA FALAA TO-AA-KHIZ-NEE WA TAFAZ-ZAL A’LAIYYA BIL-QOBOO-LE WAL GHOF-RAANE BE-RAH-MATE-KA YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "اِلٰھِیْ ھٰذِہٖ صَلَاتِیْ صَلَّیْتُھَا لَا لِحَاجَۃٍ مِّنْکَ اِلَیْھَا وَلَا رَغْبَۃٍ مِّنْکَ فِیْھَا اِلَّا تَعْظِیْمًا وَّطَاعَۃً وَّاِجَابَۃً لَّکَ اِلٰی مَا اَمَرْتَنِیْ بِہٖ اِلٰھِیْ اِنْ کَانَ فِیْھَا خَلَلٌ اَوْ نَقْصٌ مِّنْ رُّکُوْعِھَا اَوْسُجُوْدِھَا فَلَا تُؤَاخِذْنِیْ وَتَفَضَّلْ عَلَیَّ بِالْقُبُوْلِ وَالْغُفْرَانِ بِرَحْمتِکَ یَااَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText