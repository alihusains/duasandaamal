[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016078, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Praise to Allah Who has honoured thee and exalted thee, Praise to Allah Who sent Muhammad as a prophet and designated Ali as Imam and the leader. O, Allah, Guide the best of Thy people to him, and keep the evil of Thy creatures away from him. Our Lord! grant us good in this world and good in the hereafter, and save us from the chastisement of the fire. (2:201)", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma aur unki kushaadgi mein jaldi kar de, ay Allah! Teri hi jaanib raahat aur kushaadgi aur sahet o slaamati hai, ay Allah! Be-shak mera emal kam hai, lehaaza isko mere liye ziyadah kar de aur mere har us gunah ko bakhsh de jis se Tu waaqif hai aur jo Tere makhlooq se poshidah hai, ay Allah! Be-shak mai Teri panah maangta hu aatish'e Jahannam se, pas mujhe panah de aur aisi wasee aur kaamil rehmat sy mujhe nawaaz keh jis zariye mein dunya aur aakherat ki neyki haasil karu, ay Allah! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma aur unki kushaadgi mein jaldi kar.", "Urdu": "اے اللہ! محمدؐ و آل محمدؑ پر رحمت نازل فرما اور ان کی کشادگی میں جلدی کر دے، اے اللہ! تیری ہی جانب سے راحت اور کشادگی اور صحت و سلامتی ہے، اے اللہ! بےشک میرا عمل کم ہے لہٰذا اس کو میرے لیئے زیادہ کر دے اور میرے ہر اس گناہ کو بخش دے جس سے تو واقف ہے اور جو تیری مخلوق سے پوشیدہ ہے، اے اللہ! بے شک میں تیری پناہ مانگتا ہوں آتش جہنم سے پس مجھے پناہ دے اور ایسی وسیع اور کامل رحمت سے مجھے نواز کہ جس کے ذریعہ میں دنیا اور آخرت کی نیکی حاصل کروں، اے اللہ! محمدؐ و آل محمدؑ پر رحمت نازل فرما اور ان کی کشادگی میں جلدی کر۔", "RArabic": "AL-HAMDO LILLAAHIL LAZEE SHARRAFAKE WA A’ZZAMAKE WAL-HAMDO LILLAAHIL LAZEE BA-A’SA MOHAMMADAN NABIYYAN WA JA-A’LA A’LIYYAN EMAAMAN ALLAAHUMMAH DE LAHU KHEYAARA KHALQEKA WA JANNIBHO SHERAARA KHALQEKA. RABBANAA AATENAA FID DUNYAA HASANATAWN WA FIL AAKHERATE HASANATAWN WAQENAA A’ZAABAN NAARE.", "ArabicText1": "اَلْحَمْدُ لِلہِ الَّذِیْ شَرَّفَكِ وَعَظَّمَكِ۔ وَالْحَمْدُ لِلہِ الَّذِیْ بَعَثَ مُحَمَّدًا نَبِیًّا وَجَعَلَ عَلِیًّا اِمَامًا۔ اَللّٰہُمَّ اہْدِ لَہٗ خِیَارَ خَلْقِكَ وَجَنِّبْہُ شِرَارَ خَلْقِكَ۔ رَبَّنَآ اٰتِنَا فِي الدُّنْيَا حَسَنَةً وَّفِي الْاٰخِرَةِ حَسَنَةً وَّقِنَا عَذَابَ النَّارِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null,