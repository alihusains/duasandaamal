[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016063, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "All praise to Allah who has graced me with clothes to cover my body, perform my duties, worship my Sustainer and reach where He has commanded me. All praise be to Allah who, when I directed my course towards Him, reached me; when I directed my intentions towards Him, assisted me, drew me closer and did not shatter me; when I sought His pleasure, granted me peace. He is my fort, refuge, protector, support, hope, salvation, saviour and my provider in times of hardship and comfort.", "Gujarati": null, "RGujarati": null, "RUrdu": "Us Khuda ki tamaam taarif hai jis ne mujhe woh cheez ataa ki jis ke zariye se mai apni izzat o aabroo ki pardah poshi kar sakta hu aur us mein apne farz'e ibaadat adaa kar sakta hu aur jiska Khuda ne hukm diya hai uski taraf pohonchta hu. Us Khuda ki hamd hai keh mai ne Uska qasad kiya to Us ne mujhe wahan tak pohoncha diya aur iraadah kiya to Usne meri madad ki aur qabool kiya, mujhe apne se alaaida (alag) nahi kiya aur mai ne Uski simt ka qasad kiya to mujhe salaamat rakkha. Pas Woh mera qala aur jaae panah hai, meri hifaazat, mera sahaara, meri ummeed, meri najaat ki jagah, mera zakhira aur mera saamaan hai meri sakhti mein aur meri faarighul baala (zimme-daari) mein.", "Urdu": "اس خدا کی تمام تعریف ہے جس نے مجھے وہ چیز عطا کی جس کے ذریعہ سے میں اپنی عزّت و آبرو کی پردہ پوشی کر سکتا ہوں اور اس میں اپنا فرض عبادت ادا کر سکتا ہوں اور جس کا خدا نے حکم دیا ہے اسکی طرف پہونچتا ہوں، اس خدا کی حمد ہے کہ میں نے اس کا قصد کیا تو اس نے مجھے وہاں تک پہونچا دیا اور ارادہ کیا تو اس نے میری مدد کی اور قبول کیا، مجھے اپنے سے علیحدہ نہیں کیا اور میں نے اسکی سمت کا قصد کیا تو مجھے سلامت رکھا۔ پس وہ میرا قلعہ اور جائے پناہ ہے۔ میری حفاظت، میرا سہارا، میری امید، میری نجات کی جگہ، میرا ذخیرہ اور میرا سامان ہے میری سختی میں اور میری فارغ البالی میں۔", "RArabic": "ALHAMDO LILLAAHIL LAZEE RAZAQANEE MAA OWAAREE BEHI A’WRATEE WA O-WADDEE FEEHE FARZEE WA A-A’BODO FEEHE RABBEE WA ANTAHEE FEEHE ELAA MAA AMARANEE AL-HAMDO LILLAAHIL LAZEE QASADTOHU FA-BALLAGHANEE WA ARID-TOHU FA-A-A’ANANEE WA QABELANEE WA LAM YAQTA’ BEE WA WAJHAHU ARADTO FA-SALLAMANEE FAHOWA HISNEE WA KAHFEE WA HIRZEE WA ZAHREE WA MALAAZEE WA RAJAAA-EE WA MANJAAYA WA ZUKHREE WA U’DDATEE FEE SHIDDATEE WA RAKHAAA-EE.", "ArabicText1": "اَلْحَمْدُ لِلہِ الَّذِیْ رَزَقَنِیْ مَا اُوَارِیْ بِہٖ عَوْرَتِیْ وَاُؤَدِّیْ فِیْہِ فَرْضِیْ وَاَعْبُدُ فِیْہِ رَبِّیْ وَاَنْتَہِیْ فِیْہِ اِلٰی مَا اَمَرَنِیْ۔ اَلْحَمْدُ لِلہِ الَّذِیْ قَصَدْتُہٗ فَبَلَّغَنِیْ وَاَرِدْتُہٗ فَاَعَانَنِیْ وَقَبِلَنِیْ وَلَمْ یَقْطَعْ بِیْ وَ وَجْہَہٗ اَرَدْتُ فَسَلَّمَنِیْ فَہُوَ حِصْنِیْ وَكَہْفِیْ وَحِرْزِیْ وَظَہْرِیْ وَمَلَاذِیْ وَرَجَآئِیْ وَمَنْجَایَ وَذُخْرِیْ وَعُدَّتِیْ فِیْ شِدَّتِیْ وَرَخَآئِیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": nu