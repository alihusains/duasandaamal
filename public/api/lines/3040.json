l, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1013193, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah (I begin), in Allah (I trust), on the way of Allah, and on the norm of the Messenger of Allah (I proceed), may Allah bless him and his Household. O Allah, (please do) forgive me for You are verily the Oft-Returning.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke naam se, Khuda ki zaat se, Khuda ki raah mein aur Khuda ke Rasool ke deen par, keh Khuda rehmat kare un par aur unki Aal (a.s) par. Ay Allah! Mujhe bakhsh de, mujh par rahem farma aur meri taubah qabool kar le, be-shak Tu bada taubah qabool karne waala maher-baan hai.", "Urdu": "خدا کے نام سے خدا کی ذات سے خدا کی راہ میں اور خدا کے رسولؐ کے دین پر کہ خدارحمت کرے ان پر اور ان کی آلؑ پراے اللہ!مجھے بخش دے مجھ پر رحم فرما اور میری توبہ قبول کر لے بے شک تو بڑا توبہ قبول کرنے والا مہربان ہے۔", "RArabic": "BISMIL-LAAHE WA BIL LAAHE WA FEE SABEELIL LAAHE WA A’LAA MILLATE RASOOLIL LAAHE SALLAL LAAHO A’LAIHE WA AALEHI. ALLAAHUM-MAGH-FIR LEE WAR-HAMNEE WA TUB A’LAYYA INNAKA ANTAT TAWWAA-BUR RAHEEMO.", "ArabicText1": "بِسْمِ اللہِ وَبِاللهِ وَفِیْ سَبِیْلِ اللہِ وَعَلٰی مِلَّۃِ رَسُوْلِ اللہِ صَلَّی اللہُ عَلَیْهِ وَ اٰلِهٖ۔ اَللّٰهُمَّ اغْفِرْ لِیْ وَارْحَمْنِیْ وَ تُبْ عَلَیَّ اِنَّكَ اَنْتَ التَّوَّابُ الرَّحِیْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "