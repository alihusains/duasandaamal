[{"Id": 1013188, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Now enter the canopy and enter with the right foot forward and standing at the door of the shrine recite…", "GujaratiDescription": null, "RUrduDescription": "Ab baraamde mein daakhil ho apna daayna (right) paiyr badha-te huwe aur zareeh ke darwaaze par khade ho kar kahe…", "UrduDescription": "پھر برآمدے میں داخل ہو اور اس وقت دایاں پاؤں آگے رکھے اور دروازۂ حرم پر کھڑے ہو کر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013189, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I bear witness that there is no god but Allah, alone without having any associate, and I bear witness that Muhammad is His servant and Messenger. He has conveyed the truth from Him and verified the (past) Messengers. Peace be upon you, O Messenger of Allah! Peace be upon you, O most-beloved of Allah and best of His beings!", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawahi deta hu keh Allah ke siwaaye koi ma’bood nahi woh yakta hai koi uska shareek nahi, aur gawahi deta hu Hazrat Muhammad (s.a.w.a) uske bande aur rasool hai jo uski taraf se haq le kar aaye aur rasoolo’n ki tasdeeq farmaayi. Aap par salaam ho ay Khuda ke Rasool. Aap par salaam ho ay Khuda ke dost aur uske makhlooq mein uske choone huwe hai.", "Urdu": "میں گواہی دیتا ہوں کہ اللہ کے سوا کوئی معبود نہیں وہ یکتا ہے کوئی اس کا شریک نہیں اورگواہی دیتا ہوں حضرت محمدؐ اس کے بندہ اوررسولؐ ہیں جو اس کی طرف سے حق لے کر آئے اور رسولوں کی تصدیق فرمائی آپ پر سلام ہو اے خدا کے رسولؐ آپ پرسلام ہو اے خدا کے دوست اور اس کی مخلوق میں اس کے چنے ہوئے ہیں۔", "RArabic": "ASHHADO AN LAA ILAAHA ILLAL LAAHO WAHDA-HU LAA SHAREEKA LAHU WA ASHHADO ANNA MOHAMMADAN AB’DOHU WA RASOOLO-HU JAAA-A BIL HAQQE MIN IN’DEHI WA SADDA-QAL MURSALEE-NA. AS-SALAAMO A’LAIKA YAA RASOOLAL LAAHE. AS-SALAAMO A’LAIKA YAA HABEE-BALLAA-HE WA KHEYA-RATAHU MIN KHALQE-HI.", "ArabicText1": "اَشْهَدُ اَنْ لَا اِلٰهَ اِلَّا اللهُ وَحْدَهٗ لَا شَرِیْكَ لَهٗ وَاَشْهَدُ اَنَّ مُحَمَّدًا عَبْدُهٗ وَرَسُوْلُهٗ جَآءَ بِالْحَقِّ مِنْ عِنْدِهٖ وَصَدَّقَ الْمُرْسَلِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَا رَسُوْلَ اللهِ۔ اَلسَّلَامُ عَلَیْكَ یَا حَبِیْبَ اللهِ وَ خِیْرَتَهٗ مِنْ خَلْقِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013190, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon the Commander of the Faithful: the servant of Allah and the brother of Allah’s Messenger. O master, O Commander of the Faithful! I, your slave and the son of your slave and your bondmaid, have come to you seeking the refuge of your protection, directing to your shrine, turning my face toward your place, and begging Almighty Allah in your name.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho Ameerul Momeneen (a.s) par jo Khuda ke bande aur uske Rasool ke bhai hai. Ay mere Aaqa, ay momino ke sardaar, aap ka ghulaam aap ke ghulaam aur aap ki kaneez ka beta, aap ki khidmat mein aaya, aap se panah lene, aap ke haram mein haazir huwa hai. Aap ke buland maqaam ke zariye Allah ke huzoor aap ko apna wasila bana raha hai.", "Urdu": "سلام ہو امیرالمومنینؑ پر جو خدا کے بندے اور اس کے رسولؐ کے بھائی ہیں اے میرے آقا اے مومنوں کے سردار آپ کا غلام آپ کے غلام اور آپ کی کنیز کا بیٹا آپ کی خدمت میں آیا آپ سے پناہ لینے آپ کے حرم میں حاضر ہوا ہے آپ کے مقام بلند کے ذریعے اللہ کے حضور آپ کو اپنا وسیلہ بنا رہا ہے۔", "RArabic": "AS-SALAAMO A’LAA AMEERIL MOMENEENA AB’DILLAAHE WA AKHEE RASOOLIL LAAHE YAA MAWLAAYA YAA AMEERAL MOMENEENA AB’DOKA WABNO AB’DEKA WABNO AMATEKA JAAA-AKA MUSTAJEE-RAN BE ZIMMATE-KA QAASE-DAN ILAA HARAME-KA MOTAWAJJE-HAN ILAA MAQAAME-KA MOTAWASSE-LAN ELAL LAAHE TA-AA’LAA BEKA.", "ArabicText1": "اَلسَّلَامُ عَلٰی اَمِیْرِ الْمُؤْمِنِیْنَ عَبْدِ اللهِ وَ اَخِیْ رَسُوْلِ اللهِ یَا مَوْلَايَ یَا اَمِیْرَ الْمُؤْمِنِیْنَ عَبْدُكَ وَابْنُ عَبْدِكَ وَابْنُ اَمَتِكَ جَآئَكَ مُسْتَجِیْرًۢا بِذِمَّتِكَ قَاصِدًا اِلٰی حَرَمِكَ مُتَوَجِّهًا اِلٰی مَقَامِكَ مُتَوَسِّلًا اِلَی اللهِ تَعَالٰی بِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013191, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "May I enter, O master? May I enter, O Commander of the Faithful? May I enter, O argument of Allah? May I enter, O trustee of Allah? May I enter, O angels of Allah who reside in this shrine? O master, may you permit me to enter in the best way of permission you have ever given to any of your devotees? If I am too little to deserve your permission, then You are too exalted to deprive me of it.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay mere Aaqa kya mai andar aa jaawu, ay momino ke sardaar kya mai andar aa jaawu, ay hujjat'e Khuda aaya mai andar aa jaawu? Ay ameen'e Khuda mai andar aawu. Ay Khuda ke farishto’n jo us baargah mein rehte hai kya mai andar daakhil ho jaawu. Ay mere Maula kya aap mujhe andar aane ki ijaazat dete hai. Us se behtar ijaazat jo aap ne apne kisi mohib ko di. Pas agar mai aisi ijaazat milne ka ahel nahi, aap to yeh ijaazat dene ke ahel hai.", "Urdu": "اے میرے آقا کیا میں اندر آجاؤں ؟اے مومنوں کے سردار کیا میں اندر آجاؤں؟ اے حجت ِخدا آیا میں اندر آجاؤں؟ اے امینِ خدا میں اندر آؤں؟ اے خدا کے فرشتو جو اس بارگاہ میں رہتے ہو کیا میں اندر داخل ہو جاؤں؟ اے میرے مولا کیا آپ مجھےاندر آنے کی اجازت دیتے ہیں؟ اس سے بہتر اجازت جو آپ نے اپنے کسی محب کو دی پس اگر میں ایسی اجازت ملنے کا اہل نہیں مگرآپ تو یہ اجازت دینے کے اہل ہیں۔", "RArabic": "A-ADKHOLO YAA MAWLAYA, A-ADKHOLO YAA AMEERUL MOMENEEN, A-ADKHOLO YAA HUJJATAL-LAAHE? A-ADKHOLO YAA AMEENAL LAAHE? A-ADKHOLO YAA MALAAA'e KATAL LAAHIL MOQEE-MEENA FEE HAAZAL MASHHADE? YAA MAWLAAYA ATAA-ZANO LEE BID-DOKHOO-LE AFZALA MAA AZINTA LE-AHA-DIM MIN AWLE-YAAA'e KA? FA-IN LAM AKUL LAHU AHLAN FA-ANTA AHLUN LE ZAALEKA.", "ArabicText1": "ءَاَدْخُلُ یَا مَوْلَایَ ءَاَدْخُلُ یَا اَمِیْرَالْمُؤْمِنِیْنَ ءَاَدْخُلُ یَا حُجَّۃَ اللهِ؟ ءَاَدْخُلُ یَا اَمِیْنَ اللهِ؟ ءَاَدْخُلُ یَا مَلَآئِكَۃَ اللهِ الْمُقِیْمِیْنَ فِیْ هٰذَا الْمَشْهَدِ؟ یَا مَوْلَايَ اَتَاذَنُ لِیْ بِالدُّخُوْلِ اَفْضَلَ مَا اَذِنْتَ لِاَحَدٍ مِّنْ اَوْلِیَآئِكَ؟ فَاِنْ لَمْ اَكُنْ لَّهٗٓ اَهْلًا فَاَنْتَ اَهْلٌ لِذٰلِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) choicest blessings be upon Mohammed and his holy progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwa