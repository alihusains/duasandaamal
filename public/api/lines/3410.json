[{"Id": 1014746, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "The following holy verses (48:1-2), <Surah Nasr> and statement may be written on a paper, which may be then hanged to the bewitched person (usually a man bewitched by a woman so as to make him marry her)…", "GujaratiDescription": null, "RUrduDescription": "Aise baandhe huwe shakhs ko kholne ke liye kisi kaaghaz par Surah Fatah ki pehli do (2) aayate’n (48:1-2), <Surah Nasr> aur in jumlo’n ko likhe. Pas yeh Taweez apne paas rakhe aur apni khwaab-gah ke upar latkaaye fula’n bin fula’n ki jagah mard ka aur uske baap ka naam le aur binte fula’n ki jagah aurat ka aur uski maa ka naam le…", "UrduDescription": "ایسے باندھے ہوئے شخص کوکھولنے کے لئے کسی کاغذ پر سورہ سورۂ فےح ۱۔۲ آیات اور، <سورۂ نصر> اور ذیل کی آیات لکھے۔ اب یہ تعویذ اپنے پاس رکھے اور اپنی خواب گاہ کے اوپر لٹکائے فلاں ابن فلاں کی جگہ مرد کا اور اس کے باپ کا نام لے اور بنت فلاں کی جگہ عورت کا اور اس کی ماں کا نام لے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "Arab