[{"Id": 1016640, "EnglishTitle": "PLEASE NOTE: Be it clear that the reason for presenting Translation is to understand Salaat and to recite in Arabic with concentration because reciting Salaat other than Arabic language (or Transliteration) is not correct.", "GujaratiTitle": null, "RUrduTitle": "Waazeh rahe keh tarjuma-e-namaz pesh karne ki asal wajah namaz samajh ke Arabi mein khuzoo aur tawajjoh ke saath namaz padhna hai. Kyu’n keh Arabi ya Roman-Arabi (Transliteration) ke siwa kisi aur zabaan mein namaz padhna sahih nahin hai.", "UrduTitle": "واضح رہے کہ ترجمۂ نماز پیش کرنے کی اصل غرض نماز سمجھ کے عربی میں خضوع اور توجہ کے ساتھ نماز پڑھنا ہے۔ کیوں کہ عربی کے سوا کسی اور زبان میں نماز پڑھنا صحیح نہیں ہے۔ اس لئے ہر ایک کے لئے نماز کی حد تک قرآن و عربی سیکھنا واجب ہے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016929, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It has been reported from the Holy Prophet (s): Whoever recites 20 rakat namaz in the form of 2x2 rakat, in each rakat after <Surah Fateha>, reciting <Surah Ikhlaas>, <Surah Kaafiroon> and  <Surah Falaq> 3 times each; Allah would reward him the reward of the thankful and the people who persevere and would raise his name amongst the truthful ones and for each letter that he says, Allah would grant him the reward of all the truthful ones and martyrs. It would be as if he recited the whole Quran during the month of Ramadhan. He will be welcomed by 70 angels once he leaves the grave. These angels will give him the glad tidings of Paradise and guide him to it.", "GujaratiDescription": null, "RUrduDescription": "Hazrat Rasool-e-Khuda (s) se riwaayat hai keh jo koi 20 rakat namaz 2x2 kar ke anjaam de keh jiski har rakat mein <Surah Fateha> ke baad <Surah Ikhlaas>, <Surah Kaafiroon> aur <Surah Falaq> har ek surah ko 3 martaba padhe to Allah (swt) usey Shukr guzaaro’n ka ajr ataa farmaayega aur uske naam ko saadeqeen (sachcho’n) mein shumaar karega aur har hurf (alphabet) ke badle mein jo us ne padha hai saadeqeen aur shaheedo’n jaisa ajr ataa farmaayega. Woh aisa hoga keh jaise us ne Mahe Ramazan mein pura Quran padha ho. Jab woh qabr se uthaaya jaayega to 70 farishte’n uska isteqbaal karenge aur usey Jannat ki bashaarat denge aur uski rehnumaayi karenge.", "UrduDescription": "حضرت رسول خداؐ سے روایت ہے کہ جو کوئی ۲۰ رکعت نماز دو دو کر کے انجام دے کہ جس کی ہر رکعت میں <سورۂ فاتحہ> کے بعد <سورۂ اخلاص>، <سورۂ کافرون> اور <سورۂ فلق> ہر ایک سورہ ۳ مرتبہ پڑھے تو اللہ تعلیٰ اسے شکر گزاروں کا اجر عطا فرمائیں گا اور اس کے نام کو صادقین میں شمار کرے گا اور ہر حرف کے بدلے میں جو اس نے پڑھا ہے صادقین اور شہیدوں جیسا اجر عطا فرمائیں گا، وہ ایسا ہو گا کہ جیسے اس نے ماہِ رمضان میں پرا قرآن پڑھا ہو۔ جب وہ قبر سے اٹھایا جائے گا تو ۷۰ فرشتے اس کا استقبال کریں گے اور اسے جنّت کی بشارت دیں گے اور اس کی رہنمائی بھی کرے گے۔ ", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSi