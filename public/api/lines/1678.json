[{"Id": 1011993, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "It is highly advisable to bath (Ghusl) oneself at the 1st night of Rajab. The Holy Prophet (s) says, “Whoever receives the month of Rajab and bathes himself in the first, middle, and last of it, will be released from all of his sins to return as pure as the day of his birth.”", "GujaratiDescription": null, "RUrduDescription": "Khaas taaqid hai keh 1st Rajab ki shab mein ghusl kare. Rasoole Khuda (s) farmate hai, “Jo koi Mahe Rajab ki awwal, wusta (middle) aur aakhri mein ghusl karega to woh gunaho’n se is tarah paak ho jaayega, jaise aaj hi shikame maadar se nikla hai.", "UrduDescription": "رجب کی پہلی رات میں غسل کرے۔ جیساکہ بعض علماء نے فرمایا ہے : رسول اﷲؐ کا فرمان ہے : جو شخص ماہِ رجب کو پائے اور اس کے اول، وسط اور آخر میں غسل کرے تو وہ گناہوں سے اس طرح پاک ہو جائے گا جیسے آج ہی شکم مادر سے نکلاہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "Arabic