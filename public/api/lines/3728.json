[{"Id": 1014447, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "The Holy Prophet (s) said, whoever goes from this world while having love of Ahlul-Bayt (a) is a martyr (shaheed) either he was sick or accidentally passed away.", "GujaratiDescription": null, "RUrduDescription": "Hazrat Rasool-e-Khuda (s) ne farmaya: jo koi is dunya se chala jaaye jab keh uske dil mein Ahle-Bait (a) ki mohabbat ho to woh shaheed hai, chahe uski maut bimaari ya haadse se huwi ho.", "UrduDescription": "حضرت رسول خداؐ  نے فرمایا: جو کوئی اس دنیا سے چلا جائے جب کہ اس کے دل میں اہل بیتؑ کی محبت ہو تو وہ شہید ہے چاہے اس کی موت بیماری یا حادثے سے ہوئی ہو۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": nul