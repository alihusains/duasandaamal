": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000677, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I have certainly obeyed You in the most beloved thing to You, which is Your Oneness. I have not disobeyed you in the most hateful thing to You, which is atheism. So, (please do) forgive me all that which lies between these two. O He to Whom is my alternative, (please do) secure me against that from which I have escaped to You.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai ne Teri ita’at ki us cheez mein jo Tujhe pasand hai aur woh Teri tauhid hai aur Teri na-farmani nahi ki us cheez mein jo Tujhe sakht na-pasand hai aur woh kufr hai. Pas bakhsh de jo kuchh in dono ke darmiyaan hai, ay woh jis tak meri daud hai mujhe amn (peace) de us se jiske darr se mai Teri taraf aaya hu.", "Urdu": "اے معبود ميں نے تيری اطاعت کی اس چيز ميں جو تجھے بہت پسند ہے اور وه تيری توحيد ہے اور تيری نافرمانی نہيں کی اس چيز ميں جو تجھے سخت ناپسند ہے اور وه کفر ہے پس بخش دے جو کچھ ان دونوں کے درميان ہے اے وه جس تک ميری دوڑ ہے مجھے امن دے اس سے جس کے ڈر سے ميں تيری طرف آيا ہوں۔", "RArabic": "ALLAAHUMMA INNEE A-TA’TOKA FEE AHABBIL ASHYAA-E ELAYKA WA HOWAT TAWHEEDO, WA LAM A-A’SEKA FEE ABGHAZIL ASYAA-E ELAYKA WA HOWAL KUFRO, FAG-FIR LEE MAA BAYNAHOMAA YAA MAN ELAYHE MAFARREE, AA-MINNEE MIMMAA FA-ZE’TO MINHO ELAYKA.", "ArabicText1": "اَللّٰھُمَّ اِنِّیْ اَطَعْتُكَ فِیْ اَحَبِّ الْاَشْیَآءِ اِلَیْكَ وَھُوَ التَّوْحِیْدُ، وَلَمْ اَعْصِكَ فِیْ اَبْغَضِ الْاَشْیَآءِ اِلَیْكَ وَھُوَ الْكُفْرُ، فَاغْفِرْ لِیْ مَا بَیْنَھُمَا یَامَنْ اِلَیْہِ مَفَرِّیْ، آمِنِّیْ مِمَّا فَزِعْتُ مِنْہُ اِلَیْكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002083, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, forgive me the many acts of disobedience to You that I have committed and accept from me the few acts of obedience to You that I have done. O my one and only expedient! O my Hope and my Reliance! O my Shelter and my Support! O One! O One and Only! O “Say: He, Allah, is One. Allah is He on Whom all depend. He begets not, nor is He begotten. And none is like Him.” I pray You, in the name of those whom You had selected from among Your beings after You never created their examples amongst all of Your beings, to bless Muhammad and his Household, and to do to me all that which suits You.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Maaf kar de jo mai ne Teri bohot si na-farmaniya ki hai aur qabool farma meri thodi ita’at jo mai ne ki hai. Ay zakhiro’n ke muqaabil mere zakhire’n aur ay meri ummeed-gah aur sahare, ay meri panah-gah aur tek (sahara) aur ay yagana, ay yekta, ay keh Teri shaan hai kaho’n Allah ek hai, Allah be-neyaaz hai, na koi uska beta hai aur na woh kisi ka farzand hai aur na koi Uska hamsar hai. Mai Tujh se sawaal karta hu uske waaste se jise Tu ne apni makhluq mein se chuhna hai aur apni khilqat mein se kisi ko waisa qaraar nahi diya keh Tu rehmat naazil farma Muhammad (s.a.w.a) aur unki Aal (a.s) par aur mujh se woh sulook kar jo Tere shaayaane shaan hai.", "Urdu": "اے معبود معاف کر دے جو ميں نے تيری بہت ہی نافرمانياں کی ہيں اور قبول فرما ميری تھوڑی اطاعت جو ميں نے کی ہے اے ذخيروں کے مقابل ميرے ذخيره اور ميری اميد گاه اور سہارے اے ميری پناه گاه اوراے پشت پناه اور اے يگانہ اے يکتا اے کہ تيری شان ہے کہو اللهايک ہے الله بے نياز ہے نہ کوئی اس کا بيٹا ہے اور نہ وه کسی کا فرزند ہے اور نہ اس کا کوئی ہمسر ہے ميں تجھ سے سوال کرتا ہوں اس کے واسطے سے جسے تو نے اپنی مخلوق ميں سے چنا ہے اور اپنی خلقت ميں سے کسی کو ويسا قرار نہيں دياکہ تو محمد(ص)(ص) اور ان کی آل(ع) پر رحمت فرما اور مجھ سے وه سلوک کر جو تيرے شايانِ شان ہے۔", "RArabic": "ALLAAHUMMAGH FIR LEYAL KASEERA MIN MA-A’ASEEKA, WAQBAL MINNIL YASEERA MIN TAA-A’TEKA, YAA U’DDATEE DOONAL A’DADE, WA YAA RAJAA-EE WAL MO’TAMADA, WA YAA KAHFEE WAS SANADA, WA YAA WAAHEDO, YAA AHADO, YAA QUL HOWALLAAHO AHADO, ALLAAHUS SAMADO, LAM YALID WA LAM YOOLAD, WA LAM YAKUN LAHU KOFOWAN AHAD, AS-ALOKA BE HAQQE MANIS-TAFAYTAHUM MIN KHALQEKA, WA LAM TAJ-A’L FEE KHALQEKA MISLAHUM AHADAN, AN TOSALLEYA A’LAA MOHAMMADIN WA AALEHI, WA TAF-A’L BEE MAA ANTA AHLOHU.", "ArabicText1": "اَللّٰھُمَّ اغْفِرْ لِیَ الْكَثِیْرَ مِنْ مَعَاصِیْكَ، وَاقْبَلْ مِنِّیْ اَلْیَسِیْرَ مِنْ طَاعَتِكَ، یَاعُدَّتِیْ دُوْنَ الْعُدَدِ، وَیَا رَجَآئِیْ وَالْمُعْتَمَدَ، وَیَاكَھْفِیْ وَالسَّنَدَ، وَیَا وَاحِدُ، یَااَحَدُ، یَاقُلْ ھُوَاللہُ اَحَدٌ، اَللہُ الصَّمَدُ، لَمْ یَلِدْ وَ لَمْ یُوْلَدْ، وَ لَمْ یَكُنْ لَّہٗ كُفُوًا اَحَدٌ۔ اَسْئَلُكَ بِحَقِّ مَنِ اصْطَفَیْتَھُمْ مِنْ خَلْقِكَ، وَلَمْ تَجْعَلْ فِیْ خَلْقِكَ مِثْلَھُمْ اَحَدًا، اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّآلِہٖ، وَتَفْعَلَ بِیْ مَااَنْتَ اَھْلُہٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002084, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I verily pray You in the name of the Grand Oneness, the White Mohammedanism, the Elevated Alawism, in the name of all that which You have used as arguments against Your servants, and in the Name that You have concealed from Your creatures and thus it has never left You save that under Your permission (I pray You by all these) to send blessings to Muhammad and his Household, make for me relief and exit as regarding my affair, and grant me sustenance from whence I expect and from whence I do not expect. Verily, You give sustenance to whom You please without measure.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai Tujh se sawaal karta hu Teri buzurg’e yaktaayi ke zariye aur Muhammadiyat ki taabaani ke zariye aur ulooiyyat (aala) ki bulandi ke aur un sab ke waaste se jin ko Tu ne hujjat qaraar diya apne bando’n par aur us naam ke waaste jo Tu ne apni makhluq se poshida rakkha. Pas woh zaahir na huwa Tujh se magar khud Tujhi par, rehmat naazil farma Muhammad (s.a.w.a) aur unki Aal (a.s) par aur mere kaam mein kushaadgi paiyda kar aur raasta bana de aur mujhe rizq de jahan se mujhe tawaqqo’n hai aur jahan se mujhe tawaqqo’n nahi hai. Be-shak Tu jise chahe be-hisaab rizq deta hai.", "Urdu": "اے معبود ميں تجھ سے سوال کرتا ہوں بواسطہ عظيم يکتائی کے اور بواسطہ محمديت کی تابانی اور علويت کی بلندی کے اور ان سب کے واسطے سے جن کو تو نے حجت قرار دياہے اپنے بندوں پر اور اس نام کے واسطے سے جو تونے اپنی مخلوق سے پوشيده رکھا پس وه ظاہرنہ ہوا وه تيرے سوا کسی پر محمد(ص) اور ان کی آل(ع) پر رحمت نازل فرما اور ميرے کام ميں کشادگی پيدا کر اور راستہ بنا دے اور مجھے رزق دے جہاں سے مجھے توقع ہے اور جہاں سے مجھے توقع نہيں ہے بے شک تو جسے چاہے بے حساب رزق ديتا ہے۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA BIL WAHDAANIYYATIL KUBRAA, WAL MOHAMMADIYYATIL BAYZAA-E, WAL A’LAVIYYATIL U’LYAA, WA JAMEE-E’ MAH-TAJAJTA BEHI A’LAA E’BAADEKA, WA BIL ISMIL LAZEE HAJABTAHU A’N KHALQEKA, FALAM YAKHRUJ MINKA ILLAA ELAYKA, SALLE A’LAA MOHAMMADIN WA AALEHI, WAJ-A’L LEE MIN AMREE FARAJAN WA MAKHRAJAN, WAR-ZUQNEE MIN HAYSO AH-TASEBO WA MIN HAYSO LAA AHTASEBO, INNAKA TARZOQO MAN TA-SHAAA-O BEGHAYRE HESAAB.", "ArabicText1": "اَللّٰھُمَّ اِنِّیْ اَسْئَلُكَ بِالْوَحْدَانِیَّۃِ الْكُبْرٰی، وَالْمُحَمَّدِیَّۃِ الْبَیْضَآءِ، وَالْعَلَوِیَّۃِ الْعُلْیَا، وَبِجَمِیْعِ مَااحْتَجَجْتَ بِہٖ عَلٰی عِبَادِكَ، وَبِالْاِسْمِ الَّذِیْ حَجَبْتَہٗ عَنْ خَلْقِكَ، فَلَمْ یَخْرُجْ مِنْكَ اِلَّا اِلَیْكَ، صَلِّی عَلٰی مُحَمَّدٍ وَّآلِہٖ، وَاجْعَلْ لِیْ مِنْ اَمْرِیْ فَرَجًا وَّمَخْرَجًا، وَّارْزُقْنِیْ مِنْ حَیْثُ اَحْتَسِبُ وَمِنْ حَیْثُ لَااَحْتَسِبُ، اِنَّكَ تَرْزُقُ مَنْ تَشَآءُ بِغَیْرِ حِسَابٍ۔", "ArabicGre