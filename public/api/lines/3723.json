[{"Id": 1010890, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "The person performing the prayer should have Wuzu, Ghusl, or Tayammum; and the recommended precaution is that he should perform tayammum only when it is not possible for him to perform wuzu or ghusl, or he fears that were he to perform wuzu or ghusl, he would not reach the prayer in time.", "GujaratiDescription": null, "RUrduDescription": "Jo shakhs namaz-e-mayyit padhe woh wuzu, ghusl ya tayammum kare. Aur ehtiyaat mein hai keh tayammum us waqt kare jab wuzu aur ghusl karna mumkin na ho ya usey khud sheh ho keh agar wuzu ya ghusl karega to namaz mein sharik na ho sakega.", "UrduDescription": "جو شخص نماز میت پڑھے وہ وضو، غسل یا تیمم کرے، اور احتیاط میں ہے کہ تیمم اس وقت کرے جب وضو اور غسل کرنا ممکن نہ ہو یا اسے خدشہ ہو کہ اگر وضو یا غسل کریگا تو نماز میں شریک نہ ہو سکےگا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText