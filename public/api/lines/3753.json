[{"Id": 1016640, "EnglishTitle": "PLEASE NOTE: Be it clear that the reason for presenting Translation is to understand Salaat and to recite in Arabic with concentration because reciting Salaat other than Arabic language (or Transliteration) is not correct.", "GujaratiTitle": null, "RUrduTitle": "Waazeh rahe keh tarjuma-e-namaz pesh karne ki asal wajah namaz samajh ke Arabi mein khuzoo aur tawajjoh ke saath namaz padhna hai. Kyu’n keh Arabi ya Roman-Arabi (Transliteration) ke siwa kisi aur zabaan mein namaz padhna sahih nahin hai.", "UrduTitle": "واضح رہے کہ ترجمۂ نماز پیش کرنے کی اصل غرض نماز سمجھ کے عربی میں خضوع اور توجہ کے ساتھ نماز پڑھنا ہے۔ کیوں کہ عربی کے سوا کسی اور زبان میں نماز پڑھنا صحیح نہیں ہے۔ اس لئے ہر ایک کے لئے نماز کی حد تک قرآن و عربی سیکھنا واجب ہے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1017057, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It has been reported from the Holy Prophet (s): Whoever recites 6 rakat namaz in the form of 2x2 rakat, reciting in each rakat after <Surah Fateha> <Surah Kausar> and <Surah Ikhlaas> 10 times each. Allah orders the angels – the Honorable Recorders (Kiraman Katibin) not to record any bad deeds for him for one year and only record his good deeds. I swear by Him who rightfully appointed me to the Prophethood that anyone who loves me and loves Allah and says this prayer – and if he cannot stand up he can pray sitting down – Allah takes pride in it near His angels and says, Indeed I forgive him.", "GujaratiDescription": null, "RUrduDescription": "Hazrat Rasool-e-Khuda (s) se riwaayat hai keh jo koi 30 rakat namaz 2x2 kar ke anjaam de keh jiski har rakat mein <Surah Fateha> ke baad <Surah Kausar> aur <Surah Ikhlaas> har ek surah 10 martaba padhe to Allah (swt) farishte (Kiraman Katebin) ko hukm deta hai keh is bande ke burey amaal ko ek saal tak nahi likhna aur sirf uske neyk amaal ko hi likhna. Qasam hai mujhe Uski jisne mujhe nabi banaya keh jo koi mujh se aur Allah se mohabbat karte huwe is namaz ko anjaam dega, agar-che khade nahi ho sakta hai to baiyth kar padhe to Allah (swt) farishto’n ke darmiyan fakhr karte huwe farmata hai keh mai ne isey bakhsh diya.", "UrduDescription": "حضرت رسول خداؐ سے روایت ہے کہ جو کوئی ۳۰ رکعت نماز دو دو کر کے انجام دے کہ جس کی ہر رکعت میں <سورۂ فاتحہ> کے بعد <سورۂ کوثر> اور <سورۂ اخلاص> ہر ایک سورہ ۱۰ مرتبہ پڑھے تو اللہ تعلیٰ فرشتے (کرامن کاتبین) کو حکم دیتا ہے کہ اس بندہ کے برے عمال کو ایک سال تک نہیں لکھنا اور سرف اس کے نیک عمال کو ہی لکھنا۔ قسم ہے مجھے اس کی جس نے مجھے نبی بنایا کہ جو کوئی مجھ سے اور اللہ سے محبت کرتے ہوئے اس نماز کو انجام دے گا، اگر چہ خڈے نہیں ہو سکتا ہے تو بیٹھ کر پڑھے تو اللہ تعلیٰ فرشتوں کے درمیان فخر کرتے ہوئے فرماتا ہے کہ میں نے اسے بخش دیا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": 