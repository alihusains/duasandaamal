[{"Id": 1000269, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is highly advisable to recite the Holy Qur’an very frequently at the first hours of Ramazan. Imam Ja’far Sadiq (a) used to say this dua before he would start reciting the Holy Qur’an…", "GujaratiDescription": null, "RUrduDescription": "Jab Mahe Ramazan aaye to is mahine mein bohot ziyadah Quraan ki tilaawat kare aur riwaayat mein hai keh Imam Jafar Sadiq (a) Quraan ki tilaawat shuru karne se pehle yeh dua padhte thay…", "UrduDescription": "جب ماہِ رمضان آئے تو اس مہینے میں بہت زیادہ قرآن کی تلاوت کرے اور روایت میں ہے کہ امام جعفر صادق  ؑتلاوت شروع کرنے سے پہلے یہ دعا پڑھتے تھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "A