[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002509, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, indeed I am directing my attention to good deeds once again and I wish to be excused for my shortcoming. This is the first night of the remaining twenty days of this month. In it I supplicate You through Your beautiful names and I seek refuge from Your never extinguishing fire (Hell). And I beg You to give me the strength to fast and pray in this month. Forgive me and have mercy on me. Indeed you do not break Your promise.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baare Ilaaha! Mai amale khair ki taraf dubaara mutawajjeh hota hu aur (taqseer ke liye) uzr (excuse) chahta hu, yeh raat Mahe Ramazan ki baqiya do-tihaayi (2/3) raato’n mein ki pehli, jis mein Tujhe Tere asma’e husna ke wasile se dua karta hu. Aur Teri na bujh ne waali aatishe Jahannam se panah chahta hu aur Tujh se sawaal karta hu keh Mahe Seyaam ke rozo’n aur namazo’n ki quwwat inaayat farma, mujhe bakhsh de aur mujh par rahem farma. Yaqeenan Tu waada khilaafi nahi karta.", "Urdu": "بار الہ! میں عمل خیر کی طرف دبارا متوجہ ہوتا ہو اور (تقصیر  کے لیے) ازر چاہتا ہو، یہ رات ماہ رمضان کی بقیہ دو تہائی راتوں میں کی پہلی، جس میں تجھے تیرے اسما حسن کے وسیلہ سے دعا کرتا ہو۔ اور تیری نہ بجھ نے والی آتش جہنم سے پناہ چاہتا ہو اور تجھ سے سوال کرتا ہو کہ ماہ سیام کے روضہ اور نمازوں کی قوت عنایت فرما، مجھے بخش دے اور مجھ پر رحم فرما۔ یقینًا تو وعدہ خلافی نہیں کرتا۔", "RArabic": "ALLAAHUMMA INNEE AS-TAANE-FUL A’MALA WA ARJUL A’FWA WA HAAZE-HI AWWALA LAIY-LATIM MIL-LAYAA-LEYAS SUL-SAIYNE AD-O’O-KA BE-ASMAAA-E-KAL HUSNAA WA AS-TAJEERO-BEKA MIN NAARE-KAL LATEE LAA TUT-FAO WA AS-ALOKA AN TO-QAWWE-YANEE A’LAA QEYAAME-HI WA SEYAAME-HI WA AN TAGH-FERA-LEE WA TAR-HAMA-NEE INNA-KA LA TUKHLE-FUL MEE-A’AD.", "ArabicText1": "اَللّٰھُمَّ اِنِّیْ اَسْتَآنِفُ الْعَمَلَ وَاَرْجُوالْعَفْوَ وَھٰذِہٖ اَوَّلَ لَیْلَۃٍ مِّنْ لَّیَالِیَ الثُّلْثَیْنِ اَدْعُوْکَ بِاَسْمَآئِکَ الْحُسْنٰی وَاَسْتَجِیْرُبِکَ مِنْ نَارِکَ الَّتِیْ لَا تُطْفَاُ وَاَسْئَلُکَ اَنْ تُقَوِّیَنِیْ عَلٰی قِیَامِہٖ وَصِیَامِہٖ وَاَنْ تَغْفِرَلِیْ وَتَرْحَمَنِیْ اِنَّکَ لَا تُخْلِفُ الْمِیْعَادِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002160, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, You encompass the things through Your mercy. You take to completion the good deeds. I rely upon only this mercy of Yours. You are needless. One who neither begets nor is He begotten and there is none like Him. Bless Muhammad and Aale Muhammad (a.s) and forgive me and have mercy on me and overlook my faults. Indeed You are the one who accepts repentance and one who is merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baare Ilaaha! Tu apne is rahem ke sabab se tamaam cheezo’n ko ghere huwe hai, nek umoore takmeel tak pohonchata hai, mai is Teri rehmat par bharosa karta hu. Tu woh be-neyaaz hai jiska na koi farzand hai na baap aur na uska koi hamsar hai. (Ay Allah) rehmat naazil farma Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par aur mujhe bakhsh de, mujh par rahem farma, mujh se dar-guzar kar kyu’n keh Tu hi bada taubah ka qabool karne waala maher-baan hai.", "Urdu": "بار الہ! تو اپنے اس رحم کے سبب سے تمام چیزوں کو گہرے ہو ئے ہے، نیک امور تکمیل تک پہنچاتا ہے، اس تیری رحمت پر بھروسہ کرتا ہو۔ تو وہ بے نیاز ہے جس کا نہ کوئی فرزند ہے نہ باپ اور نہ اس کا کوئی ہم سر ہے۔ (اے اللہ) رحمت نازل فرما محمدؐ اور آل محمدؑ پر اور مجھے بخش دے، مجھ پر رحم فرما، مجھ سے درگزر کر کیوں کہ تو ہی بڑا توبہ کا قبول کرنے والا ہے۔", "RArabic": "ALLAAHUMMA BE-RAHMATE-KAL LATEE WASE-A’T KULLA SHAIY-IN TOTIM-MUS SAALE-HAATE WA A’LAIY-HAA ITTA-KALTO WA ANTA SAMA-DUL LAZEE LAM YALID WA-LAM YOOLAD WA-LAM YAKUL-LAHU KOFO-WAN AHA-DOON SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WAGH-FIR-LEE WAR-HAM-NEE WA TAJAA-WAZ A’NNEE INNA-KA ANTAT TAWWAA-BUR RAHEEMO.", "ArabicText1": "اَللّٰہُمَّ بِرَحْمَتِکَ الَّتِیْ وَسِعَتْ کُلَّ شَیْٓءٍ تُتِمُّ الصَّالِحَاتِ وَعَلَیْہَا اِتَّکَلْتُ وَاَنْتَ صَمَدُالَّذِیْ لَمْ یَلِدْ وَلَمْ یُوْلَدْ وَلَمْ یَکُنْ لَّہٗ کُفُوًا اَحَدٌ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاغْفِرْلِیْ وَارْحَمْنِیْ وَتَجَاوَزْ عَنِّیْ اِنَّکَ اَنْتَ التَّوَّابُ الرَّحِیْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, 