[{"Id": 1013595, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "This place is near the shrine of Muslim Ibne Aqeel (a). Pray 2 rakats namaz. After reciting the Tasbeeh-e-Zahra (s), recite…", "GujaratiDescription": null, "RUrduDescription": "Yeh maqaam Muslim Ibne Aqeel (a) ke rauze ke paas hai. Yahan par 2 rakat namaz adaa kare aur Tasbeeh-e-Zahra (s) ke baad is tarah padhe…", "UrduDescription": "محراب کے اعمال کے بعد مقام امام جعفر صادق ؑ کی طرف جائے ( جوکہ حضرت مسلمؑ ابن عقیل ؑکے روضہ کی دیوار سے متصل ہے) وہاں د و رکعت نماز ادا کرے اور تسبیح فاطمۃ الزہراء ؑکے بعد یہ دعا پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013596, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He Who Makes all things made! O He Who sets all things broken! O He Who is present in all sessions held! O He Who witnesses all confidential meetings! O He Who knows about all things hidden! O He Who is always nearby and is never absent! O He Who always overcomes and is never defeated! O He Who is always nigh and is never far off! O He Who entertains each and every lonely one! O He Who existed when there was no other being exists! O He Who restores lives to the dead and causes the alive to die! O He Who watches every soul as to what it earns! There is no god save You. (Please do) send blessings upon Muhammad and the Household of Muhammad.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay har banaayi gayi cheez ke bana ne waale, ay tute huwe ko jodne waale, ay har giroh mein haazir rehne waale, ay har raaz ko dekh ne waale, ay har chhupi cheez ko jaanne waale aur ay woh haazir jo ghaayab nahi hota, ay woh baala-dast (quwwat waala) jo zere-dast (kamzor) nahi hota, ay woh qareeb jo dur nahi hota aur ay har tanha ke ham-dam, ay zindah rehne waale jab koi zindah na hoga, ay murdo’n ko zindah karne waale aur zindo’n ko maut dene waale, har nafs ko uske kirdaar ke saath baaqi rakhne waale, Tere siwa koi ma’bood nahi hai, Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma.", "Urdu": "اے ہر بنائی گئی چیز کے بنانے والے! اے ٹوٹے ہوئے کو جوڑنے والے اے ہرگروہ میں حاضر رہنے والے اے ہر راز کو دیکھنے والےاے ہر چھپی چیز کو جاننے والے اور اے وہ حاضر جو غائب نہیں ہوتا اے وہ غالب جو مغلوب نہیں ہوتا اے وہ قریب جو دور نہیں ہوتا اور اے ہر تنہا کے ہم دم اے زندہ رہنے والے جب کوئی زندہ نہ ہوگا اے مردوں کو زندہ کرنے والے اورزندوں کو موت دینے والے ہر نفس کو اس کے کردارکے ساتھ باقی رکھنے والے تیرے سوا کوئی معبود نہیں ہے محمدؐ وآل محمدؑ پررحمت نازل فرما۔", "RArabic": "YAA SAANE-A’ KULLE MASNOO-I’N WA YAA JAABERA KULLE KASEERIN WA YAA HAAZERA KULLE MALAA-IN WA YAA SHAAHEDA KULLE NAJWAA WA YAA A’ALEMA KULLE KHAFIYYATIN WA YAA SHAAHEDAN GHAYRA GHAAA-EBIWN WA YAA GHAALEBAN GHAYRA MAGHLOOBIWN WA YAA QAREEBAN GHAYRA BA-E’EDIWN WA YAA MOONESA KULLE WAHEEDIWN WA YAA HAYYAN HEENA LAA HAYYA GHAYROHU YAA MOHYEYAL MAWTAA WA MOMEETAL AHYAAA-IL QAAA-EMA A’LAA KULLE NAFSIM BEMAA KASABAT LAA ELAAHA ILLAA ANTA SALLE A’LAA MOHAMMADIWN WA AALE MOHAMMADIN.", "ArabicText1": "یَا صَانِعَ كُلِّ مَصْنُوْعٍ وَیَاجَابِرَ كُلِّ كَسِیْرٍ وَیَا حَاضِرَ كُلِّ مَلَاءٍ وَیَا شَاھِدَ كُلِّ نَجْوٰی وَیَا عَالِمَ كُلِّ خَفِیَّۃٍ وَیَا شَاھِدًا غَیْرَ غَآئِبٍ وَّیَا غَالِبًا غَیْرَ مَغْلُوْبٍ وَّیَا قَرِیْبًا غَیْرَ بَعِیْدٍ وَّیَا مُوْنِسَ كُلِّ وَحِیْدٍ وَّیَا حَیًّا حِیْنَ لَا حَیَّ غَیْرُهٗ یَا مُحْیِیَ الْمَوْتٰی وَمُمِیْتَ الْاَحْیَآءِ الْقَآئِمَ عَلٰی كُلِّ نَفْسٍ بِمَا كَسَبَتْ لَا اِلٰهَ اِلَّا اَنْتَ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15":