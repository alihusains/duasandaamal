[{"Id": 1010060, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Shaykh Kaf’ami, in Balad al-Amin, has mentioned a supplicatory prayer that is reported from Imam Ali Ameer al-Momineen (a) saying that no grief-stricken, worried, depressed, distressed, or aggrieved person recites it but that Almighty Allah will certainly take the edge off him. This supplication is as follows…", "GujaratiDescription": null, "RUrduDescription": "Shaikh Kafami ne Baladul Ameen mein ek dua Ameerul Momeneen (a) se riwaayat ki hai keh jab bhi koi museebat zadah, giraftaare gham aur khaaef is dua ko padhega to Allah (swt) uske liye faraj wa kashaaish farmaayega…", "UrduDescription": "شیخ کفعمیؒ نے بلدالامین میں ایک دعا امیرالمومنین ؑ سے روایت کی ہے : جب بھی کوئی مصیبت زدہ، گرفتار غم اور خوف زدہ اس دعا کو پڑھے گا تو حق تعالیٰ اسے نجات عطا فرمائے گا اور وہ دُعا یہ ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "A