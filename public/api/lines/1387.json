10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000668, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My Master, my Master! Thou art the Master and I the servant! Has anyone mercy upon the servant but the master? My Master, my Master! Thou art the Exalted and I the abased! Has anyone mercy upon the abased but the exalted? My Master, my Master! Thou art the Creator and I the creature! Has anyone mercy upon the creature but the creator?", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay mere Aaqa! Ay mere Maalik! Tu aaqa hai aur mai banda, to bande par aaqa ke siwa kaun rahem karega? Mere Maula! Mere Aaqa! Tu izzat waala hai aur mai zaleel, to zaleel par izzat-daar ke alaawa kaun rahem karega? Mere Maalik! Mere Maalik! Tu khaaliq hai aur mai makhluq, to makhluq par khaaliq ke siwa kaun taras khaayega?", "Urdu": "اے میرے آقا! اے میرے مالک! تو آقا ہے اور میں بندہ، اور بندے پر آ قا کے سوا کون رحم کھائے گا ؟ میرے مولا! میرے آقا! تو عزّت والا ہے اور میں ذلیل، اور ذلیل پر عزّت دار کے علاوہ اور کون رحم کرے گا؟ میرے مالک! میرے مالک! تو خالق ہے اور میں مخلوق، اور مخلوق پر خالق کے سوا کون ترس کھائے گا ؟", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "مَوْلَايَ مَوْلَايَ، اَنْتَ الْمَوْلٰى، وَاَنَا الْعَبْدُ، وَهَلْ يَرْحَمُ الْعَبْدَ اِلَّا الْمَوْلٰى۔ مَوْلَايَ مَوْلَايَ، اَنْتَ الْعَزِيْزُ، وَاَنَا الذَّلِيْلُ، وَهَلْ يَرْحَمُ الذَّلِيْلَ اِلَّا الْعَزِيْزُ۔ مَوْلَايَ مَوْلَايَ، اَنْتَ الْخَالِقُ، وَاَنَا الْمَخْلُوْقُ، وَهَلْ يَرْحَمُ الْمَخْلُوْقَ اِلَّا الْخَالِقُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002076, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My Master, My Master! Thou art the Giver and I the asker! Has anyone mercy upon the asker but the giver? My Master, My Master! Thou art the Helper and I the seeker of help! Has anyone mercy upon the seeker of help but the helper? My Master, My Master! Thou art the Subsistent and I the perishing! Has anyone mercy upon the perishing but the subsistent?", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Maula! Mere Maula! Tu ataa karne waala hai aur mai sawaali, to saayel (sawaal karne waale) par ataa karne waale ke alaawa kaun maher-baani karega? Mere Aaqa! Mere Aaqa! Tu madad-gaar hai aur mai madad ka taalib hu, to taalib ki madad-gaar ke alaawa kaun madad karega? Mere Aaqa! Mere Aaqa! Tu fariyaad-ras hai aur mai fariyaadi, to fariyaadi ki fariyaad-ras ke alaawa kaun fariyaad soonega?", "Urdu": "میرے مولا! میرے مولا! تو عطا کرنے والا ہے اور میں سوالی، اور سائل پر عطا کرنے والے کے علاوہ کون مہربانی کرے گا ؟ میرے آقا! میرے آقا! تو فریاد رس ہے اور میں فریادی، اور فریادی پر فریادرس کے علاوہ کون رحم کرے گا؟", "RArabic": null, "ArabicText1": "مَوْلَايَ مَوْلَايَ، اَنْتَ الْمُعْطِيْ وَاَنَا السَّائِلُ، وَهَلْ يَرْحَمُ السَّائِلَ اِلَّا الْمُعْطِيْ۔ مَوْلَايَ مَوْلَايَ، اَنْتَ الْمُغِيْثُ وَاَنَا الْمُسْتَغِيْثُ، وَهَلْ يَرْحَمُ الْمُسْتَغِيْثَ اِلَّا الْمُغِيْثُ۔ مَوْلَايَ مَوْلَايَ، اَنْتَ الْبَاقِيْ وَاَنَا الْفَانِيْ، وَهَلْ يَرْحَمُ الْفَانِي اِلَّا الْبَاقِيْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002077, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My Master, My Master! Thou art the Everlasting and I the vanishing! Has anyone mercy upon the vanishing but the everlasting? My Master, My Master! Thou art the Living and I the dead! Has anyone mercy upon the dead but the living? My Master, My Master! Thou art the Strong and I the weak! Has anyone mercy upon the weak but the strong?", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Maalik! Mere Maalik! Tu baaqi hai aur mai faani, to faani par daayem aur baaqi ke alaawa kaun tawajjoh karega? Mere Maula! Mere Maula! Tu zindah hai aur mai murda, to murde par zindah ke alaawa kaun taras khaayega? Mere Maalik! Mere Maalik! Tu taaqat-war hai aur mai kamzor, to kamzor ki taaqat-war ke alaawa kaun madad karega?", "Urdu": "میرے مالک! میرے مالک! تو باقی ہے اور میں فانی، اورفانی پر باقی کے علاوہ کون رحم کرے گا؟ میرے آقا! میرے آقا! تو دائم و جاوید ہے اور میں مٹ جانے والا، اور مٹ جانے والے پر دائم و جاوید کے علاوہ کون رحم کرے گا ؟ میرے مولا! میرے مولا! تو زندہ ہے اور میں مُردہ، اور مُردہ پر زندہ کے سوا کون ترس کھائے گا؟ میرے مالک! میرے مالک! تو طاقتور ہے اور میں کمزور، اور کمزور پر طاقتور کے علاوہ کون رحم کر ے گا؟", "RArabic": null, "ArabicText1": "مَوْلَايَ مَوْلَايَ، اَنْتَ الدَّائِمُ وَاَنَا الزَّائِلُ، وَهَلْ يَرْحَمُ الزَّائِلَ اِلَّا الدَّائِمُ۔ مَوْلَايَ مَوْلَايَ، اَنْتَ الْحَيُّ وَاَنَا الْمَيِّتُ، وَهَلْ يَرْحَمُ الْمَيِّتَ اِلَّا الْحَيُّ۔ مَوْلَايَ مَوْلَايَ، اَنْتَ الْقَوِيُّ وَاَنَا الضَّعِيْفُ، وَهَلْ يَرْحَمُ الضَّعِيْفَ اِلَّا الْقَوِيُّ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002078, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My Master, My Master! Thou art the Rich and I the poor! Has anyone mercy upon the poor but the rich? My Master, My Master! Thou art the Great and I the small! Has anyone mercy upon the small but the great? My Master, My Master! Thou art the Owner and I the owned! Has anyone mercy upon the owned but the owner?", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Maula! Mere Maalik! Tu gani hai aur mai faqeer, to faqeer ki gani ke alaawa kaun madad karega? Mere Aaqa! Mere Aaqa! Tu bada hai aur mai chhota, to chhote par bade ke siwa kaun nazr'e shafqat karega? Mere Maula! Mere Maula! Tu aaqa hai aur mai ghulam, to ghulam par aaqa ke siwa kaun lutf o karma farmaayega?", "Urdu": "میرے مولا! میرے مالک! تو غنی ہے اور میں تہی دست، اور تہی دست پرغنی کے علاوہ کون رحم کھائے گا ؟ میرے آقا! میرے آقا! تو بڑا ہے اور میں چھوٹا، اور چھوٹے پر بڑے کی سوا کون نظر شفقت کرے گا ؟ میرے مولا! میرے مولا! تو مالک ہے اور میں غلام، اور غلام پر مالک کے سوا کون مہربانی فرمائےگا۔", "RArabic": null, "ArabicText1": "مَوْلَايَ مَوْلَايَ، اَنْتَ الْغَنِيُّ وَاَنَا الْفَقِيْرُ، وَهَلْ يَرْحَمُ الْفَقِيْرَ اِلَّا الْغَنِيُّ مَوْلَايَ مَوْلَايَ، اَنْتَ الْكَبِيْرُ وَاَنَا الصَّغِيْرُ، وَهَلْ يَرْحَمُ الصَّغِيْرَ اِلَّا الْكَبِيْرُ۔ مَوْلَايَ مَوْلَايَ، اَنْتَ الْمَالِكُ وَاَنَا الْمَمْلُوْكَ، وَهَلْ يَرْحَمُ الْمَمْلُوْكَ اِلَّا الْمَالِكُ۔", "ArabicGreenSign1": null,