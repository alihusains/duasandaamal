[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018546, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! By the means of Your light I wish to hide from my enemies. By Your majesty and grandeur I wish to be hidden from the plans of my foes and by Your Supreme Power I seek refuge from every strength and from every evil power. And O my Lord I seek Your bounties and high rewards, why should I be scared of anyone when my hope is on Allah and why should anyone trouble me when my complete reliance is on You. I have entrusted my life and all my transactions to You. I have relied on You at all times.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ilaahi! Tere arsh ke noor ki ronaqo’n ke zariye apne dushmano se chhup-na chahta hu, aur Teri izzat ke intehaayi kamaal ke jabrooti o iqtedaar ki wajah se apne dushmano ki fareb kaariyo’n (karooto’n) se ru-poshi (hifaazat) chahta hu, aur Teri azeem quwwat ke sahaare har dushman ki taaqat aur sar-kash shaitaan ke shar se panah maangta hu, aur ay mere Mawla! Teri moayyan ne’mato’n aur bade bade inaamaat ka talab-gaar hu. Mai kisi se kyu’n daru’n jab keh Khuda meri ummeed hai, aur koi mujhe dhuk kya de, keh Teri (khuda ki) zaat par mera tawakkul hai, mai ne apni jaan aur apne maamelaat Tere supurd (hawaale) kar di hai, mai ne apne tamaam haalaat mein Tujh par tawakkul kiya hai.", "Urdu": "الٰہی! تیرے عرش کے نور کی رونقوں کے ذریعے اپنے دشمنوں سے چھپنا چاہتا ہوں اور تیری عزّت کے انتہائی کمال کے جبروتی و اقتدار کی وجہ سے اپنے دشمنوں کی فریب کاریوں سے رُو پوشی چاہتا ہوں، اور تیری عظیم قوت کے سہارے ہر دشمن کی طاقت اور ہر سرکش شیطان کے شر سے پناہ مانگتا ہوں، اور اے میرے مولا! تیری معیّن نعمتوں اور بڑے بڑے انعامات کا طلبگار ہوں۔ میں کسی سے کیوں ڈروں جبکہ خدا میری امید ہے اور کوئی مجھے دکھ کیا دے کہ تعری ذات پر میرا توکل ہے، میں نے اپنی جاں اور اپنے معاملات تیرے سپرد کر دی ہے، میں نے اپنے تمام حالات میں تجھ پر توکل کیا ہے۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ بِتَاَلِّقِ نُوَرِ بَهَاۗئِ عَرْشِكَ مِنْ اَعْدَاۗئِی اِسْتَتَرْتُ وَبِسِطْوَۃِ الْجَبَرُوْتِ مِنْ كَمَالِ عِزِّكَ مِمَّنْ یُكِیْدُنِیْ اِحْتَجَبْتُ وَبِسُلْطَانِكَ الْعَظِیْمِ مِنْ شَرِّ كُلِّ سُلْطَانٍِ عَنِیْدٍ وَشَیْطَانٍ مَرِیْدٍ اِسْتَعَذْتُ وَمِنْ فَوَاۗئِضِ نِعَمِكَ وَجَزِیْلِ عَطَاۗئِكَ یَا مَوْلَایَ طَلَبْتُ كَیْفَ اَخَافُ وَاَنْتَ اَمَلِیْ وَكَیْفَ اُضَامُ وَعَلَیْكَ مُتَّكِلِیْ اَسْلَمْتُ اِلَیْكَ نَفْسِیْ وَفَوَّضْتُ اِلَیْكَ اَمْرِیْ وَتَوَكَّلْتُ فِیْ كُلِّ اَحْوَالِیْ عَلَیْكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018547, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah send blessings on Mohammad (s.a.w.a) and his pure Progeny (a.s). And cure me of my troubles and grant me protection and those things, which wants to overpower me, make me overpower it, O the one who is never subdued. Chain the enemy who stares at me, every oppressor who oppresses, every jealous and every enemy. In the name of Allah the Beneficent the Merciful. Say He is Allah the one; Allah is He on whom all depend. He begets not, nor is He begotten. And none is like Him. Allah is sufficient for us and excellent guardian and a strong protector.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma aur mujhe shafa de, meri nigraani farma, jo mujh par ghaalib aana chahe us par mujhe ghalba de, ay Woh ghaalib jo maghloob nahin hota, har taak lagaane (mauqa talaash karne) waale dushman ko, har sar-kashi karne waale sarkash aur hasad karne waale haasid aur har dushmani karne waale dushman ko is waqt baandh diya, jab BISMILLAA-HIR RAHMAA-NIR RAHEEM. QUL-HO WALLAA-HO AHAD, ALLAA-HU-SAMAD, LAM YALEED WA-LAM YOO-LAD WA-LAM YA QULLA-HU QUFOO-WAN AHAD, padhe. Haa’n haa’n hamaara Parwardigaar aisa hi hai. Allah hamaare liye kaafi hai aur beh-tareen sar-parast aur intehaayi qawi madad gaar hai.", "Urdu": "خدایا! محمدؐ و آل محمدؑ پر رحمت نازل فرما، اور مجھے شفا دے، میری نگرانی فرما، جو مجھ پر غالب آنا چاہے اس پر مجھے غلبہ دے، اے وہ غالب جو مغلوب نہیں ہوتا، ہر تاک لگانے والا دشمن کو، ہر سرکش کرنے والے سرکش اور حسد کرنے والے حاسد اور ہر دشمنی کرنے والے دشمن کو اسی وقت باندھ دیا، جب بسم اللہ الرّحمٰن الرّحیم، قل ہو اللہ احد۔۔۔ (مکمل سورہ) پڑہے، ہاں ہاں ہمارا پروردگار ایسا ہی ہے۔ اللہ ہمارے لئے کافی ہے اور بہترین سرپرست اور انتہائی قوی مددگار ہے!", "RArabic": null, "ArabicText1": "صَلِّ عَلٰی مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَاَشْفِنِیْ وَاَكْفِنِیْ وَاغْلِبْنِیْ عَلٰی مَنْ غَلَبَنِیْ یَا غَالِبًاغَیْرَ مَغْلُوْبٍ زَجَرْتُ كُلَّ رَاصِدٍ رَصَدَ وَمَارِدٍ مَرَدَ وَحَاسِدٍ حَسَدَ وَعَانِدٍ عَنَدَ بِسْمِ اللهِ الرَّحْمٰنِ الرَّحِیْمِ قُلْ هُوَ اللهُ اَحَدٌ اَللهُ الصَّمَدُ لَمْ یَلِدْ وَلَمْ یُوْلَدْ وَلَمْ یَكُنْ لَّهٗ كُفُوًا اَحَدٌ كَذٰلِكَ اللهُ رَبُّنَا حَسْبُنَا اللهُ وَنِعْمَ الْوَكِیْلُ اَقْوٰی مُعِیْنٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": 