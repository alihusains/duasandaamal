": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002413, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O’ Allah the affliction is much, concealment has departed, the wrapper is uncovered, the Earth has become narrow while the Heaven become widen, O’ God unto You I laid complain, when in difficulties or comfort unto You I return, O’ Allah send blessing on Muhammad and the progeny of Muhammad, those whom You have commanded me to obey.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Museebat badh gayi hai aur ruswaayi ho chuki hai, pardah faash ho gaya hai, zameen tang ho gayi aur aasmaan mukhaalif ho gaya hai. Ay Parwardigaar Tere huzoor shikaayat laaya hu aur Tujhi par mera bharosa hai, tangi aur faraakhi mein.", "Urdu": "اے معبود! مصیبت بڑھ گئی ہے اور رسوائی ہوچکی ہے پردہ فاش ہو گیا ہے زمین تنگ ہوگئی اور آسمان مخالف ہو گیا ہے اے پروردگار! تیرے حضور شکایت لایا ہوں اور تجھی پر میرا بھروسہ ہے تنگی اوروسعت میں۔", "RArabic": "ALLAAHUMMA A’ZOMAL BALAAA-O, WA BARE-HAL KHAFAAA-O, WAN-KASHA-FAL GHETAAA-O, WA ZAAQATIL ARZO, BE-MAA WASE-A’TIS SAMAAA-O WA ILAIY-KA YAA RABBIL MUSHTA-KAA WA A’LAIY-KAL MO-A’WWALO FISH-SHIDDA-TE WAR RAKHAAA-E.", "ArabicText1": "اَللّٰہُمَّ عَظُمَ الْبَلٓائُ وَبَرِحَ الْخَفَاۗئُ وَانْکَشَفَ الْغِطَاۗئُ وَضَاقَتِ الْاَرْضُ بِمَا وَسِعَتِ السَّمَاۗئُ وَاِلَیْکَ یَا رَبِّ الْمُشْتَکٰی وَعَلَیْکَ الْمُعَوَّلُ فِی الشِّدَّۃِ وَالرَّخَاۗئِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002690, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O’ Allah, hasten the coming of the riser among them and manifest his honour, O’ Muhammad! O’ Ali! O’ Ali! O’ Muhammad! Suffice me, both of you are enough, O’ Muhammad! O’ Ali! O’ Ali! O’ Muhammad! Assist me (both) you (both) are enough as a helper.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma jin ki pairwi Tu ne ham par waajib ki hai, pas us tarah Tu ne unke martabe ki pehchaan karaayi unke haq ka waasta hai hamein kashaaish de, jaldi chashme zadan mein, ya usse kam waqt mein.", "Urdu": "اے معبود! محمدؐ اور ان کی آلؑ پر رحمت نازل فرما جن کی پیروی تو نے ہم پر واجب کی ہے پس اس طرح تو نے ان کے مرتبے کی پہچان کرائی ان کے حق کا واسطہ ہے ہمیں کشائش وآسائش دے جلدی پلک جھپکنے میں یا اس سے بھی کم وقت میں۔", "RArabic": "ALLAAHUMMA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN, AL-LAZEE-NA AMAR-TANAA BE-TAA-A’TE-HIM WA AJJE-LIL-LAAHUMMA FARAJA-HUM BE-QAAAE-ME-HIM WA AZ-HIR E’ZAAZA-HU, YAA MOHAMMADO YAA A’LIYYO, YAA A’LIYYO YAA MOHAMMADO, IKFE-YAANEE FA-INNAKO-MAA KAAFE-YAAYA. YAA MOHAMMADO YAA A’LIYYO, YAA A’LIYYO YAA MOHAMMADO, OON-SORAA-NEE FA-INNA-KOMAA NAASE-RAAYA.", "ArabicText1": "اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ اَلَّذِیْنَ اَمَرْتَنَا بِطَاعَتِہِمْ وَعَجِّلِ اللّٰہُمَّ فَرَجَہُمْ بِقَاۗئِمِہِمْ وَاَظْھِرْ اِعْزَازَہٗ یَا مُحَمَّدُ یَا عَلِیُّ یَا عَلِیُّ یَا مُحَمَّدُ اِکْفِیَانِیْ فَاِنَّکُمَا کَافِیَایَ، یَا مُحَمَّدُ یَا عَلِیُّ یَا عَلِیُّ یَ