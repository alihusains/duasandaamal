[{"Id": 1018623, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "When people gathered around Imam Ali (a) in battle of Siffin so then he recited this dua…", "GujaratiDescription": null, "RUrduDescription": "Jang’e Siffin mein jab logo’n ne mawla ko hujoom kar (gher) liya tha, to Mawla Ali (a) ne yeh farmaya…", "UrduDescription": "امام علیؑ کی یہ دعا بھی مذکورہ واقعہ (صفین) میں پڑھی تھی جب لوگوں نے ہجوم کر لیا تھا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018624, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Lord of the high skies which is hung and safe whom You have made a jungle for the Sun and Moon and a place for goodness and evil and in it You have made Angels, weak, who are never tired of Your worship. And O the Lord of the earth who has made it a resting place for man and animals and for small creatures who are known and unknown, seeing and unseeing and for big-big things. O Lord of the mountains whom You have made nails for the earth and treasure for the times, and O the owner of the seas who has covered the earth like a storm. And O the owner of the clouds, which are hanging between the earth and the skies. O the saviour of ships, which are used to carry profitable goods. If You make us overpower our enemies then save us from arrogance. Keep us on the right path and if You give the enemies victory over us then grant us martyrdom and save my other companions from mischief.", "Gujarati": null, "RGujarati": null, "RUrdu": "Us buland aasmaan ke Parwardigaar jo moallaq o mehfooz hai, jise Tu ne din o raat ka jangal (jungle), aur chaand o suraj ka raasta aur sawaabat o seyaar (chaand o taare) ki manzil banaaya, aur us mein un makhlooqaat’e malaaeka ko maskan guzeen (malaaeka ka thikaana) banaaya, jo Ibaadat se thak-te nahin, aur ay us zameen ke Parwardigaar jise insaano aur haiwaano aur chhoti chhoti makhlooqaat, maaloom na-maaloom, qaabil’e deed o na-qaabil mushaaheda (na dikhaayi dene waali) badi badi cheezo’n ke liye manzil’e qayaam banaaya, aur un pahaado’n ke Parwardigaar jinhe’n Tu ne zameen ke liye mekh (nail) aur dunya ke liye khazaana banaaya hai, aur ay toofaan khez saari dunya ko ghere huwe samandar ke maalik, aur ay un baadalo’n ke Parwardigaar jo aasmaan o zameen ke darmiyaan mein moallaq (latke huwe) hai, aur kashtiyo’n ke haafiz jo samandaro’n mein logo’n ke nafe-bakhsh saamaan le kar chalti hai, agar ham ko hamaare dushman par kaamyaab kar diya to takabbur se bachaana, raahe raast par bar-qaraar rakhna. Aur agar dushmano ko ham par kaamyaabi ataa kar di to hamein shahadat ataa farmana, aur mere baaqi saathiyo’n ko fitne se bachaana.", "Urdu": "اس بلند آسمان کے پروردگار جو معلّق و محفوظ ہے، جیسے تونے دن و رات کا جنگل اور چاند سورج کا راستہ اور ثوابت و سیار کی منزل بنایا، اور اس میں ان مخلوقات ملائکہ کو مسکن گزین بنایا، جو عبادت سے تھکتے نہیں، اور اے اس زمین کے پروردگار جسے انسانوں اور حیوانوں اور چھوٹی چھوٹی مخلوقات، معلوم نا معلوم، قابل دید و نا قابل مشاہدہ، بڑی بڑی چیزوں کے لئے منزل قیام بنایا، اور ان پہاڑوں کے پروردگار جنہیں تونے زمین کے لئے میخ اور دنیا کے لئے خزانہ بنایا ہے اور اے طوفان خیز ساری دنیا کو گھیرے ہوئے سمندر کے مالک، اور اے ان بادلوں کے پروردگار جو آسمان و زمین کے درمیان میں معلّق ہیں، اور کشتیوں کے حافظ جو سمندروں میں لوگوں کے نفع بخش سامان لے کر چلتی ہیں۔ اگر ہم کو ہمارے دشمن پر کامیاب کر دیا تو تکبر سے بچانا، راہ راست پر برقرار رکھنا، اور اگر دشمنوں کو ہم پر کامیابی عطا کر دی تو ہمیں شہادت عطا فرمانا، اور میرے باقی ساتھیوں کو فتنہ سے بچانا۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ رَبَّ هٰذَا السَّقْفِ الْمَرْفُوْعِ الْمَكْفُوْفِ الْمَحْفُوْظِ الَّذِیْ جَعَلْتَهٗ مَغِیْضَ اللَّیْلَ وَالنَّهَارِ وَجَعَلْتَ فِیْهَا مَجَارِیَ الشَّمْسِ وَالْقَمَرِ وَمَنَازِلَ الْكَوَاكِبِ وَالنُّجُوْمِ وَجَعَلْتَ سَاكِنَهٗ سِبْطًا مِنَ الْمَلٰٓئِكَۃِ لَا یَسْاَمُوْنَ الْعِبَادَۃَ وَرَبَّ هٰذِهِ الْاَرْضِ الَّتِیْ جَعَلْتَهَا قَرَارًا لِلنَّاسِ وَالْاَنْعَامِ وَالْهَوَامِّ وَمَا نَعْلَمُ وَمَا لَا نَعْلَمُ مِمَّا یُرٰی وَمِمَّا لَا یُرٰی مِنْ خَلْقِكَ الْعَظِیْمِ وَرَبِّ الْجِبَالِ الَّتِیْ جَعَلْتَهَا لِلْاَرْضِ اَوَ تَادًا وَلِلْخَلْقِ مَتَاعًا وَرَبَّ الْبَحْرِ الْمَسْجُوْرِ الْمُحِیْطِ بِالْعَالَمِ وَرَبَّ السَّحَابِ الْمُسَخَّرِ بَیْنَ السَّمَاۗئِ وَالْاَرْضِ وَالْفُلْكِ الَّتِیْ تَجْرِیْ فِی الْبَحْرِ بِمَا یَنْفَعُ النَّاسُ اِنْ اَظْفَرْتَنَا عَلٰی عَدُوِّنَا فَجَنِّبْنَا الْكِبَرَ وَسَدِّدْنَا لِلرُّشْدِ وَاَنْ اَظْفَرْتَهُمْ عَلَیْنَا فَارْزُقْنَا الشَّهَادَۃَ وَاَعْصِمْ بَقِیَّۃَ اَصْحَابِیْ مِنَ الْفِتْنَۃِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5":