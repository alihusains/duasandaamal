[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018527, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Whenever You bestow a bounty upon me, my thanks is always less and whenever You have tried me in calamities, my patience was always less. Then O the one who never made my thanks giving being low, and O the one who, when sent the calamities my patience was very less inspite of which He never deprived me of anything and O He who sees me doing sins but never degraded me. And O He who saw me openly committing sins but never punished me. Send blessings on Mohammad (s.a.w.a) and his Progeny (a.s), and grant me cure from this sickness without a speck of doubt You have power over all things.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Allah! Jab bhi Tu mujhe koi ne’mat ataa farmaata hai, hamesha uske liye meri shukr guzaari kam hoti hai, aur jab bhi Tu ne mujhe bala mein aazmaaya, us mauqe par mera sabr kam huwa. To ay Woh zaat jis ki naazil kardah ne’mato’n par mera shukr kam hone ke ba-wajood mujhe na-kaam na farmaaya, aur ay Woh zaat jis ki naazil kardah balaawo’n ke waqt mera sabr kam huwa, magar Us ne mujhe mehroom na rakkha, aur ay Woh zaat jo mujhe khataawo’n mein mubtela dekhti hai magar ruswa nahin hone deti, aur ay Woh zaat jo mujhe gunaho’n mein aaloodah dekhti hai magar saza nahin deti. Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmate’n naazil farma, aur mujhe is bimaari se tandurasti ataa farma, be-shak Tu har cheez par qudrat rakhne waala hai.", "Urdu": "میرے اللہ! جب بھی تو مجھے کوئی نعمت عطا فرماتا ہے، ہمیشہ اس کے لئے میری شکر گذاری ہوتی ہے، اور جب بھی تونے مجھے بلا میں آزمایا، اس موقع پر میرا صبر کم ہوا۔ تو اے وہ ذات جس کی نازل کردہ نعمتوں پر میرا شکر کم ہونے کے باوجود مجھے ناکام نہ فرمایا، اور اے وہ ذات جس کی نازل کردہ بلاؤں کے وقت میرا صبر کم ہوا، مگر اس نے مجھے محروم نہ رکھا، اور اے وہ ذات جو مجھے خطاؤں میں مبتلا دیکھتی ہے، مگر رسوا نہیں ہونے دیتی، اور اے وہ ذات جو مجھے گناہوں میں آلودہ دیکھتی ہے مگر سزا نہیں دیتی۔ محمدؐ و آل محمدؑ پر رحمتیں نازل فرما، اور مجھے اس بیماری سے تندرستی عطا کر، بلا شبہ تو ہر چیز پر قدرت رکھنے والا ہے۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اِلٰهِیْ كُلَّمَا اَنْعَمْتَ عَلَیَّ نِعْمَۃً قَلَّ لَكَ عِنْدَهَا شُكْرِیْ، وَكُلَّمَا ابْتَلَیْتَنِیْ بِبَلِیَّۃٍ قَلَّ لَكَ عِنَدَهَا صَبْرِیْ فَیَا مَنْ قَلَّ شُكْرِیْ عِنْدَ نِعْمَتِهٖ فَلَمْ یَحْرِمْنِیْ، وَیَا مَنْ قَلَّ صَبْرِیْ عِنْدَ بَلَٓائِهٖ فَلَمْ یَخْذُلْنِیْ، وَیَا مَنْ تَرَانِیْ عَلَی الْخَطَایَا فَلَمْ یَفْضَحْنِیْ، وَیَا مَنْ رَاۗنِیْ عَلَی الْمَعَاصِیْ فَلَمْ یُعَاقِبْنِیْ عَلَیْهَا، صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاغْفِرْلِیْ ذُنُوْبِیْ وَاشْفِنِیْ مِنْ مَرَضِیْ، اِنَّكَ عَلٰی كُلِّ شَیْءٍ قَدِیْرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": n