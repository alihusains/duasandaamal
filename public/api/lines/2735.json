[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011597, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, the Lord of the month of Ramadhan, the Revealer of the Qur’an This is the month of Ramadhan in which You revealed the Qur’an And revealed therein chapters of true guidance and distinction (between the right and the wrong). O Allah: make us observe fast in its days and remain awake in its nights to pray.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Ay Mahe Ramazan ke Parwardigaar, ay Qur’an ke utaar ne waale yeh Mahe Ramazan hai keh jis mein Tu ne Qur’an Kareem ko naazil kiya aur is mein hidaayat ki roshan nishaaniya naazil ki aur yeh haq o baatil ka farq hai. Ay Ma’bood! Hamein iske roze naseeb kar aur is mein ibaadat kar ne ki taufiq de.", "Urdu": " اے معبود! اے ماہِ رمضان کے پروردگار! اے قرآن کے اتارنے والے یہ ماہِ رمضان ہے کہ جس میں تو نے قرآن کریم کو نازل کیا اور اس میں ہدایت کی روشن نشانیاں نازل کیں اور یہ حق وباطل کا فرق ہے اے معبود! ہمیں اس کے روزے نصیب کر اور اس میں عبادت کرنے کی توفیق دے۔", "RArabic": "ALLAAHUMMA RABBA SHAHRE RAMAZAAN MO-NAZZE-LAL QURAANE HAAZAA SHAHRO RAMAZAA-NAL LAZEE AN-ZALTA FEEHIL QURAANA WA AN-ZALTA FEEHE AAYAA-TIN BAIYYE-NAATIM MENAL HODAA WAL FURQAANE. ALLAAHUMMAR ZUQNAA SEYAAMO-HU WA A-I’N-NAA A’LAA QEYAAME-HI.", "ArabicText1": "اَللّٰهُمَّ رَبَّ شَهْرِ رَمَضَانَ مُنَزِّلَ الْقُرْآنِ هٰذَا شَهْرُ رَمَضَانَ الَّذِيْ اَنْزَلْتَ فِيْهِ الْقُرْآنَ وَاَنْزَلْتَ فِيْهِ آيَاتٍ بَيِّنَاتٍ مِّنَ الْهُدٰى وَالْفُرْقَانِ۔ اَللّٰهُمَّ ارْزُقْنَا صِيَامَهٗ وَاَعِنَّا عَلٰى قِيَامِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011598, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah: let it be peaceful for us, keep us in sound condition for it, let it take upon itself the supervision of our affairs to give us ease and well-being and while taking decisions, From among Your inevitable decisions And from among that which You decide from the wise affairs, At the Grand Night From the act that is neither rejected nor altered, write my name in the list of those pilgrims of Your Sacred House whose pilgrimage receives Your approval, whose efforts are appreciated, whose sins are forgiven, whose wrongdoings are overlooked, and while making decisions and rendering possible things and events make possible for me long life, and enough lawful means of livelihood.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Hamein pura mahina naseeb kar aur is mein salaamati ataa farma isey ham se apni di huwi aasaani aur aafiyat ke saath qabool kar aur jin yaqeeni kaamo mein Teri bist wa kushaad (chhupi o zaahir) taiy ki jaati hai aur jin par hukumati maamlo’n ke faisle Tu Shab Qadr mein karta hai aur woh aise faisle hai keh jin mein koi radd o badal nahi hota un ke zimn mein mujhe apne Baitul Haraam Kaaba ke un haajiyo’n mein likh de keh jin ka Hajj qabool hai, un ki koshish pasandida, un ke gunah bakhshe huwe aur un ki buraaiya mita di gayi hai aur jin maamlo’n ki Tu bist wa kushaad karta hai un mein meri umr taweel kar de aur mere liye rizqe halaal mein kushaadgi wa faraakhi (izaafa) qaraar de.", "Urdu": "اے معبود! ہمیں پورا مہینہ نصیب کر اور اس میں سلامتی عطا فرما اسے ہم سے اپنی دی ہوئی آسانی اور عافیت کے ساتھ قبول کر اور جن یقینی کاموں میں تیری وسعت و تنگی طے کی جاتی ہے اور جن پُر حکمت معاملوں کے فیصلے تو شب ِقدر میں کرتا ہے اور وہ ایسے فیصلے ہیں کہ جن میں کوئی ردّوبدل نہیں ہو گا ان کے ضمن میں مجھے اپنے بیت الحرام کعبہ کے ان حاجیوں میں لکھ دے کہ جن کا حج قبول ہے، ان کی کوشش پسندیدہ، ان کے گناہ بخشے ہوئے اور ان کی برائیاں مٹا دی گئی ہیں اور جن معاملوں کی تو وسعت و تنگی کرتا ہے ان میں میری عمر طویل کر دے اور میرے لئے رزقِ حلال میں کشادگی و آسائش قرار دے۔", "RArabic": "ALLAAHUMMA SALLIM-HO LA-NAA WA SALLIM-NAA FEEHE WA TA-SALLAM-HO MINNAA FEE YUSREEM MINKA WA MOA’A-FAATIN WAJ-A’L FEE-MAA TAQZEE WA TO-QADDE-RO MENAL AMRIL MAH-TOOME WA FEE-MAA TAFRO-QO MENAL AMRIL HAKEE-ME FEE LAIY-LATIL QADRE MENAL QAZAA-IL LAZEE LAA YO-RADDO WA LAA YO-BADDA-LO AN TAKTO-BANEE MIN HUJJAA-JE BAIYTE-KAL HARAA-MIL MAB-ROORE HAJJO-HUM AL-MASH-KOORE SA’YO-HUM AL-MAGH-FOORE ZONOO-BO-HUM AL-MO-KAFFA-RE A’N-HUM SAIYYE-AATO-HUM WAJ A’L FEE-MAA TAQZEE WA TO-QADDE-RO AN TOTEE-LA LEE FEE U’MREE WA TO-WASSE-A’ A’LAIYYA MENAR RIZQIL HA-LAALE.", "ArabicText1": "اَللّٰهُمَّ سَلِّمْهُ لَنَا وَسَلِّمْنَا فِيْهِ وَتَسَلَّمْهُ مِنَّا فِيْ يُسْرٍ مِّنْكَ وَمُعَافَاةٍ وَاجْعَلْ فِيْمَا تَقْضِيْ وَتُقَدِّرُ مِنَ الْاَمْرِ الْمَحْتُوْمِ وَفِيْمَا تَفْرُقُ مِنَ الْاَمْرِ الْحَكِيْمِ فِيْ لَيْلَةِ الْقَدْرِ مِنَ الْقَضَاءِ الَّذِيْ لَا يُرَدُّ وَلَا يُبَدَّلُ اَنْ تَكْتُبَنِيْ مِنْ حُجَّاجِ بَيْتِكَ الْحَرَامِ الْمَبْرُوْرِ حَجُّهُمْ اَلْمَشْكُوْرِ سَعْيُهُمْ اَلْمَغْفُوْرِ ذُنُوْبُهُمْ اَلْمُكَفَّرِ عَنْهُمْ سَيِّئَاتُهُمْ وَاجْعَلْ فِيْمَا تَقْضِيْ وَتُقَدِّرُ اَنْ تُطِيْلَ لِيْ فِيْ عُمْرِيْ وَتُوَسِّعَ عَلَيَّ مِنَ الرِّزْقِ الْحَلَالِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSi