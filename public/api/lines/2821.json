نے والی بی بی آپ پر سلام ہو۔", "RArabic": "ASSALAAMO A’LAIKE YAA UMMAL MOAMENEENA. ASSALAAMO A’LAIKE YAA ZAWJATA SAYYEDIL MURSALEENA. ASSALAAMO A’LAIKE YAA UMMA FAATEMATAZ ZAHRAAA-E SAYYEDATE NESAAA-IL A’ALAMEENA. ASSALAAMO A’LAIKE YAA AWWALAL MOAMENAATE.", "ArabicText1": "اَلسَّلَامُ عَلَیْكِ یَا اُمَّ الْمُؤْمِنِیْنَ۔ اَلسَّلَامُ عَلَیْكِ یَا زَوْجَۃَ سَیِّدِ الْمُرْسَلِیْنَ۔ اَلسَّلَامُ عَلَیْكِ یَا اُمَّ فَاطِمَۃَ الزَّہْرَآئِ سَیِّدَۃِ نِسَآئِ الْعَالَمِیْنَ۔ اَلسَّلَامُ عَلَیْكِ یَا اَوَّلَ الْمُؤْمِنَاتِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012748, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay woh zaat jis ne sayyadul Ambiya ki nusrat mein apna maal o daulat kharch kar diya, aur jitni unhe isteta’at thi us qadar Allah ke Rasool (s.a.w.a) ki nusrat ki aur un se dushmano ko dur kiya, aap par salaam ho ay woh maghtumah jin par Jibareel (a.s) ne salaam kaha, aur Rabbe Jaleel ka salaam jin tak pohonchaaya to Allah ne jo fazl o karam aap ko diya woh aap ko gawara huwa aur aap par Allah ki rehmat o barkate’n aur salaam ho.", "Urdu": "سلام ہو آپ پر اے وہ ذات جس نے سید النبیاء کی نصرت میں اپنا مال و دولت خرچ کر دیا، اور جتنی انہیں استطاعت تھی اس قدر رسول اللہؐ کی نصرت کی اور ان سے دشمنوں کو دور کیا، آپ پر سلام ہو اے وہ مغطمہ جن پر جبرئیلؑ نے سلام کہا، اور رب جلیل کا سلام جن تک پہونچایا، تو اللہ نے جو فضل و کرم آپ کو دیا وہ آپ کو گوارا ہو اور آپ پر اللہ کی رحمت اور برکتیں ہوں اور سلام ہو۔", "RArabic": "ASSALAAMO A’LAIKE YAA MAN ANFAQAT MAALAHAA FEE NUSRATE SAYYEDIL AMBEYAAA-E WA NASARATHO MAS TA-TAA-A’T WA DAAFA-A’T A’NHUL A-A’DAA-A ASSALAAMO A’LAIKE YAA MAN SALLAMA A’LAYHAA JABRA-EELO WA BALLAGHAHAS SALAAMO MENAL LAAHIL JALEELE FAHANEE-AN LAKE BEMAA AWLAAKIL LAAHO MIN FAZLIN WAS SALAAMO A’LAIKE WA RAHMATUL LAAHE WA BARAKAATOHU.", "ArabicText1": "اَلسَّلَامُ عَلَیْكِ یَا مَنْ اَنْفَقَتْ مَالَہَا فِیْ نُصْرَۃِ سَیِّدِ الْاَنْبِیَآئِ وَنَصَرَتْہُ مَا اسْتَطَاعَتْ وَدَافَعَتْ عَنْہُ الْاَعْدَائَ۔ اَلسَّلَامُ عَلَیْكِ یَا مَنْ سَلَّمَ عَلَیْہَا جَبْرَئِیْلُ وَ بَلَّغَہَا السَّلَامُ مِنَ اللهِ الْجَلِیْلِ فَہَنِیْئًا لَكِ بِمَا اَوْلَاكِ اللهُ مِنْ فَضْلٍ وَالسَّلَامُ عَلَیْكِ وَرَحْمَۃُ اللهِ وَ بَرَكَاتُہٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "A