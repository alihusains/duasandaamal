LAATO WAS-SALAAMO A’LAIY-KA AYYO-HAL QAMA-RUL AN-WAARO WAL MISBAA-HUL AZ-HARO YAA QAASE-MAB-NAL IMAAME MOOSAB NA JA’FAREEN WA RAHMA-TUL-LAAHE WA BARA-KAATO-HU. ALLAAHUMMA BE-BAABE-KA WA QAFTO WA LE-ZIYAARA-TE MO-SHAA-HEDA AW-LIYAA-E-KA QASAD-TO FAS-ALO-KAL QOBOO-LA WAL-GHUF-RAANA INNA-KA AH-LUT TAQWAA WA AH-LUL MAGH-FERA-TE BE-RAH-MATE-KA YAA AR-HAMAR RAAHE-MEENA WAS-SALAA-TO WAS-SALAAMO A’LAA SAYYADA-NAA MOHAMMA-DIW WA AALE WA SOHO-BEHI AJMA-EE’NA.", "ArabicText1": "ءَاَدْخُلُ یَا قَاسِمَ الْعَطَایَا وَیَا سَلِیْلَ الْكَاظِمِ وَاَخَ الرِّضَا عَلَیْهِمُ السَّلَامُ، ءَاَدْخُلُ یَا مَلَاۗئِكَۃَ رَبِّ السَّمَاۗئِ الْمُحْدِقِیْنَ بِهٰذَ الْمَرْقَدِ الْاَعْلٰی وَالصَّلٰوۃُ وَالسَّلَامُ عَلَیْكَ اَیُّهَا الْقمَرُ الْاَنْوَارُ وَالْمِصْبَاحُ الْاَزْهَرُ یَا قَاسِمَ ابْنَ الْاِمَامِ مُوْسَی بْنَ جَعْفَرٍ وَرَحْمَۃُ اللهِ وَبَرَكَاتُهٗ۔ اَللّٰهُمَّ بِبَابِكَ وَقَفْتُ وَلِزِیَارَۃِ مُشَاهِدَ اَوْلِیَاۗئِكَ قَصَدْتُ فَاسْئَلُكَ الْقُبُوْلَ وَالْغُفْرَانَ اِنَّكَ اَهْلُ التَّقْوٰی وَاَهْلُ الْمَغْفِرَۃِ بِرَحْمَتِكَ یَا اَرْحَمَ الرَّاحِمِیْنَ وَالصَّلٰوۃُ وَالسَّلَامُ عَلٰی سَیِّدَنَا مُحَمَّدٍ وَّآلِهٖ وَصُحُبِهٖ اَجْمَعِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null