[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011148, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "For the sake of Yaseen, and the wise Qur’an. For the sake of TaHa and the mighty Qur’an. O One who has power over the needs of those who ask. O One who knows what is in the hearts. O One who comforts the distressed. O One who relieves the grief-stricken. O One who has mercy on the old. O One who provides for the young child. O One who does not need any explanation. Bless Muhammad and his family and conduct with me and do so and so.", "Gujarati": null, "RGujarati": null, "RUrdu": "Quraan'e Majeed aur Yaasin ke sadqe, Quraan'e Majeed aur Taaha ke sadqe, ay Woh zaat jo neyaaz-mando’n ki haajat-rawaai par qaadir hai, ay raazo’n ke jaanne waale, ay mushkilaat mein ghirey logo’n ki mushkilaat ko dur karne waale, ay gham o andoh mein mubtala logo’n ko gham se najaat dene waale, ay bhoodhe aur umr-raseedah (zaeef) logo’n par rahem karne waale, ay chhote bachche ko shikam'e maadar mein rozi dene waale, ay Woh jo kisi tafseer (explanation) ka mohtaaj nahi hai, Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par durood bhej aur (fula’n) kaam mere liye anjaam de (fula’n ki jagah par apni haajat bayaan kare).", "Urdu": "قرآن مجید اور سورہ یسیٰن کے صدقے، قرآن عظیم اور سورہ طہٰ کے صدقے، اے وہ ذات جو نیاز مندوں کی حاجت روائی پر قادر ہے، اے رازوں کے جاننے والے، اے مشکلات میں گھرے لوگوں کی مشکلات کو دور کرنے والے، اے غم و اندوہ میں پھنسے لوگوں کو غم سے نجات دینے والے، اے بوڑھے اور عمر رسیدہ لوگوں پر رحم کرنے والے، اے چھوٹے بچے کو کاشم مادر میں روزی دینے والے، اے وہ جو کسی تفسیر کا محتاج نہیں ہے، محمد و آل محمد پر درود بھیج، اور (فلاں) کام میرے لئے انجام دے۔", "RArabic": "BE-HAQQE YAA-SEEN WAL QUR-AANIL HAKEEME, WA BE-HAQQE TAAHAA WAL QUR-AANIL A’ZEEME. YAA MAN YAQDERO A’LAA HAWAA-EJIS SAA-ELEENA, YAA MAN YA’LAMO MAA FIZ ZAMEERE YAA MONAFFESAN A’NIL MAKROOBEENA, YAA MOFARREJAN A’NIL MAGMOOMEENA, YAA RAAHEMASH SHAY-KHIL KABEERE, YAA RAAZEQAT TIFLIS SAGHEERE, YAA MAN LAA YAHTAAJO ELAT TAFSEERE, SALLE A’LAA MOHAMMADIN WA AALE MOHAMMADIN, WAF A’L BEE KAZAA WA KAZAA.", "ArabicText1": "بِحَقِّ یٰس وَالْقُرْآنِ الْحَكِیْمِ، وَبِحَقِّ طٰهٰ وَالْقُرْآنِ الْعَظِیْمِ، یَا مَنْ یَقْدِرُ عَلٰی حَوَاۗءِجِ السَّاۗءِلِیْنَ، یَا مَنْ یَّعْلَمُ مَا فِی الضَّمِیْرِ، یَا مُنَفِّسًا عَنِ الْمَكْرُوْبِیْنَ، یَا مُفَرِّجًا عَنِ الْمَغْمُوْمِیْنَ، یَا رَاحِمَ الشَّیْخِ الْكَبِیْرِ، یَا رَازِقَ الطِّفْلِ الصَّغِیْرِ، یَا مَنْ لَا یَحْتَاجُ اِلَی التَّفْسِیْرِ، صَلِّ عَلٰی مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَافْعَلْ بِیْ كَذَا وَكَذَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign