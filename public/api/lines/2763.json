[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011639, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O the powerful one of the heavens and the powerful of the earths and one for whom is the kingdom of the heavens and the kingdom of the earths and the one who forgives the sins and the Hearing the knowing the forgiving the forbearing the merciful the needless the unique who has no likeness and no one is having authority on You. You are the Highest of the High and the most powerful of the powerful. And you are the one who accepts repentance and one who is merciful. I beg You to bless Muhammad and his progeny. And that You forgive me and have mercy on me. Indeed You are the most merciful of the merciful ones.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay aasmaano par tasallut (qabza) aur zameeno par iqtedaar rakhne waale, ay woh zaat keh jiske qabze mein aasmaano aur zameeno ki hukm-raani hai. Tu jo gunaho’n ko bakhsh ne waala hai bohot waaqif, bada bakhsh ne waala, burdbaar, raheem, be-neyaaz aur tanha hai. Tu aisa hai keh Tera koi shabi (replica) nahi hai aur na kisi ko haqe wilaayat o hukumat Tujh par haasil hai. Tu hi buland o bartar aur saahebe iqtedaar o qaadir hai aur Tu hi taubah qabool karne waala maher-baan hai. Mai Tujh se sawaal karta hu keh Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur mere gunah bakhsh de aur mujh par rahem kar, yaqeenan Tu tamaam rahem karne waalo’n mein sab se ziyadah rahem waala hai.", "Urdu": "اے آسمانوں پر تسلط اور زمینوں پر اقتدار  رکھنے والے، اے وہ ذات کہ جس کے قبضہ میں آسمانوں اور زمینوں کی حکمرانی ہے۔ تو جو گناہوں کو بخش نے والا ہے بہت واقف، بڑا بخش نے والا، بردبار، رحیم، بے نیاز اور تنہا ہے۔ تو ایسا ہے کہ تیرا کوئی شبھی نہیں ہے اور نہ کسی کو حق ولایت و حکومت تجھ ہر حاصل ہے۔ تو ہی بلند و برتر اور صاحب اقتدار و قدرت ہے اور تو ہی توبہ قبل کرنے والا مہربان ہے۔ میں تجھ سے سوال کرتا ہو کہ حضرت محمدؐ اور انکی آلؑ پر رحمت نازل فرما اور میرے گناہ بخش دے اور مجھ پر رحم کر، یقینًا تو تمام رحم کرنے والوں میں سب سے زیادہ رحم کرنے والا ہے۔", "RArabic": "YAA JABBAA-RAS SAMAA-WAATE WA JABBAA-RAL ARZEE-NA WA YAA MAL-LAHU MALA-KOO-TUS SAMAA-WAATE WA MALA-KOO-TUL AR-ZEENA WA GHAFFAA-RAZ ZONOO-BE WAS-SAMEE-U’L A’LEE-MUL GHAFOO-RUL HALEE-MUR RAHEE-MUS SAMA-DUL FAR-DUL LAZEE LAA SHABEE-HA LAKA WA LAA WALIYYA ANTAL A’LIYYUL A’LAA WAL QADEE-RUL QAADERO WA ANTAT TAWWAA-BUR RAHEEMO AS-ALOKA AN TO-SAL-LEYYA A’LAA MOHAMMADIW WA AALE-HI WA AN TAGH-FERA-LEE WA TAR-HAMA-NEE INNA-KA ANTA AR-HAMUR RAAHE-MEEN.", "ArabicText1": "یَاجَبَّارَ السَّمٰوٰتِ وَجَبَّارَ الْاَرْضِیْنَ وَیَا مَنْ لَّہٗ مَلَکُوْتُ السَّمٰوٰتِ وَمَلَکُوْتُ الْاَرْضِیْنَ وَغَفَّارَ الذُّنُوْبِ وَالسَّمِیْعُ الْعَلِیْمُ الْغَفُوْرُ الْحَلِیْمُ الرَّحِیْمُ الصَّمَدُ الْفَرْدُ الَّذِیْ لَاشَبِیْہَ لَکَ وَلَا وَلِیَّ لَکَ اَنْتَ الْعَلِیُّ الْاَعْلٰی وَالْقَدِیْرُ الْقَادِرُ وَاَنْتَ التَّوَّابُ الرَّحِیْمُ اَسْئَلُکَ اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّاٰلِہٖ وَاَنْ تَغْفِرَلِیْ وَتَرْحَمَنِیْ اِنَّکَ اَنْتَ اَرْحَمُ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "Arab