[{"Id": 1016516, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Ayatollah Sayyid Nasrullah Al-Mustanbit was honoured to meet with our master the legacy of Allah (may our souls be sacrifice for him) in the sanctuary of the commander of the faithful (peace be upon him) while he was praying, thus he listen to his recitations and heard the awaiting Imam (may our souls be sacrifice for him) reciting the following supplications in his Qunoot…", "GujaratiDescription": null, "RUrduDescription": "Marhoom Ayatullah Syed Nasrullah Mustabat Ameerul Momeneen (a) ke haram Hazrat Imam-e-Zamana (a) ko namaz ki haalat mein dekha aur Hazrat (a) ki dil-nasheen dua ko ghaur se soona to Hazrat apne qunoot mein is dua ko padh rahe thay…", "UrduDescription": "مرحوم آیت اللہ سید نصر اللہ مستنبط نے حرم امیرالمومنین میں حضرت حجت کو نماز کی حالت میں مشاہدہ کیا امام عصر کی دلنشین دعا کان میں سنائی دی آنحضرت قنوت میں یہ دعا پڑھتے تھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreen