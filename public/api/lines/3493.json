NOO-BAN NAHAA-RE WA ZONOO-BAS SIRRE WA ZONOO-BAL A’LAANE-YATE YAA QAADERO YAA WAAHEDO YAA AHADO YAA SAMADO YAA WADOODO YAA GHAFOORO YAA RAHEEMO.", "ArabicText1": "يَا صَانِعَ كُلِّ مَصْنُوْعٍ وَيَا جَابِرَ كُلِّ كَسِيْرٍ وَيَا شَاهِدَ كُلِّ نَجْوٰى وَيَا رَبَّاهُ وَيَا سَيِّدَاهُ اَنْتَ النُّوْرُ فَوْقَ النُّوْرِ(وَنُوْرُ كُلِّ نُوْرٍ فَيَا نُوْرَ كُلِّ نُوْرٍ) فَيَا نُوْرَ النُّوْرِ وَيَا نُوْرَ كُلِّ نُوْرٍ اَسْئَلُكَ بِحَقِّ مُحَمَّدٍ وَّآلِ مُحَمَّدٍ اَنْ تُصَلِّيَ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَاَنْ تَغْفِرَ لِيْ ذُنُوْبَ اللَّيْلِ وَذُنُوْبَ النَّهَارِ وَذُنُوْبَ السِّرِّ وَذُنُوْبَ الْعَلَانِيَةِ يَا قَادِرُ يَا قَدِيْرُ يَا وَاحِدُ يَا اَحَدُ يَا صَمَدُ يَا وَدُوْدُ يَا غَفُوْرُ يَا رَحِيْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14"