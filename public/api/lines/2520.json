: null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016433, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my great Allah: send them Your wrath and condemnation including your extreme punishments and hardship quickly, destroy them totally, completely, clean towns and cities from their existence, and remove their signs and beings from cities and towns, turn their habitats upside down and deny light in their homes. Destroy them with a destruction that: there will be none of them left for anyone to find, no sign of them for anyone to search, no place for them to hide or refuge, and no one to want them.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": "اَللّٰهُمَّ فَبَادِرْهُمْ بِقَوَاصِفِ سَخَطِكَ، وَعَوَاصِفِ تَنْكِیْلَاتِكَ، وَاجْتِثَاثِ غَضَبِكَ، وَطَهِّرِ الْبِلَادَ مِنْهُمْ، وَاعْفُ عَنْهَا آثَارَهُمْ، وَاحْطُطْ مِنْ قَاعَاتِهَا وَمَظَانِّهَا مَنَارَهُمْ، وَصْظَلِمْهُمْ بِبَوَارِكَ حَتّٰی لَا تُبْقِ مِنْهُمْ دِعَامَۃً لِنَاجِمٍ، وَلَا عَلَمًا لِاَمٍّ، وَلَا مَنَاصًا لِقَاصِدٍ، وَلَا عَائِدًا لِمُرْتَادٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign