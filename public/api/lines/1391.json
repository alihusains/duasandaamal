t17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000698, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah bless Muhammad and his family O Allah, on this night the seekers have sought You and the aspirers have aspired for You and the searchers have hoped for Your blessings and grace For You have in this night, hidden bounties and rewards and presents and gifts which You bestow upon whom you please from Your servants and You deny them to one who has not reached Your regard Here I am,Your abject servant in need of You hopeful of Your blessings and grace.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baare Ilaaha! Darkhwaast karne waale is shab mein Tujh se darkhwaast kar rahe hai, qasad karne waalo’n ne is shab me Teri (bargah ka) qasad kiya hai, aur talab karne waale Tere fazl o ehsaan ke ummeed-waar hai. Is raat mein Teri taraf se raahate, ataaye, bakhshishe aur inaayate hai jo Tu ataa karta hai apne bando’n mein se unko jin ko Tu chahta hai, aur jin par Teri maher-baani nahi hai un se in (neymato’n ko) rok leta hai aur is waqt Tera yeh mohtaaj banda Tere fazl o karam ka ummeed-waar hai.", "Urdu": "میرے معبود! طلب کرنے والوں نے آج رات خود کو تیرے ہی سامنے پیش کیا ہے ارادہ کرنے والوں نے تیری ہی بارگاہ کا ارادہ کیا ہےاور حاجت مندوں نے تیرے ہی فضل و احسان سے امید باندھی ہوئی ہے آج کی رات تیری مہربانیاں، تیری بخشش، تیری عطائیں اور تیرے ہی انعام ہیں کہ تو اپنے بندوں میں سے جس پر چاہے ان سے احسان فرمائے اور جس پر تیری توجہ اور عنایت نہ ہوئی ہو اس سے روک لے اور یہ میں ہوں تیراحقیر بندہ کہ تیرا محتاج ہوں اور تیرے فضل و احسان کا امید وار ہوں۔", "RArabic": "ILAAHI TA-A’RRAZA LAKA FEE HAAZAL LAIY-LIL MOTA-A’RRE-ZOON WA QASADA-KA FEE-HIL QAASE-DOONA WA A’MMALA FAZLAKA WA MA’ROOFA-QAT TAALE-BOON WA LAKA FEE HAAZAL LAIY-LE NAFAHAA-TUN WA JAWAAA-E-ZO WA A’TAA-YAA WA MA-WAAHE-BO TAMUN-NO BEHAA A’LAA MAN TASHAAA-O MIN E’BAADE-KA WA TAMNA-O’HAA MAN LAM TASBE-KA LAHUL E’NAAYA-TO MINKA WA HAA ANAA-ZAA O’BAIYDO-KAL FAQEE-RO ELAIY-KAL MO-AMME-LO FAZLA-KA WA MA’ROOFA-KA.", "ArabicText1": "اِلٰھِیْ تَعَرَّضَ لَكَ فِیْ ھٰذَا اللَّیْلِ الْمُتَعَرِّضُوْنَ وَقَصَدَكَ الْقَاصِدُوْنَ وَاَمَّلَ فَضْلَكَ وَمَعْرُوْفَكَ الطَّالِبُوْنَ وَلَكَ فِیْ ھٰذَا اللَّیْلِ نَفَحَاتٌ وَّجَوَآئِزُ وَعَطَایَا وَمَوَاھِبُ تَمُنُّ بِھَا عَلٰی مَنْ تَشَآءُ مِنْ عِبَادِكَ وَتَمْنَعُھَا مَنْ لَّمْ تَسْبِقُ لَہُ الْعِنَایَۃُ مِنْكَ وَھَا اَنَاذَا عُبَیْدُكَ الْفَقِیْرُ اِلَیْكَ الْمُؤَمِّلُ فَضْلَكَ وَمَعْرُوْفَكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002154, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "So, O my Master if You have bestowed blessings on this night on anyone of Your creatures and turned to him with affection then bless Muhammad and his family the pure, the purified, the virtuous ones the excellent ones and favor me with Your grace and bounty.", "Gujarati": null, "RGujarati": null, "RUrdu": "Pas ay mere Maalik! Raat mein agar Tu ne apne kisi bande par maher-baani ki hai, aur kisi ke liye apni neymat moaiyyan ki hai to apne fazl o karam se Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par apni rehmat naazil farma jo paak o paakeeza, aur behtareen makhlooq aur saahebaane fazl o sharaf hai aur ay tamaam jahan ke Paalne waale apne ataa o karam se muhje bhi ataa farma.", "Urdu": "پس اے میرے مولا! اگر آج کی رات میں تو اپنی مخلوق میں کسی پر فضل و کرم کرے اور اس کو انعام عطا فرمائے اور وہ انعام عطا فرمائے جو تیری مہربانی کے ساتھ ہو تو محمدؐ و آل محمدؑ پر رحمت نازل فرما جوپاکیزہ ہیں، نیکو کار ہیں اور با فضیلت ہیں اور اپنے فضل اور احسان سے مجھ پر بخشش کر اے جہانوں کے پالنے والے۔", "RArabic": "FA IN KUNTA YAA MAWLAAYA TA-FAZZAL-TA FEE HAAZE-HIL LAIYLA-TE A’LAA AHA-DIM MIN KHALQE-KA WA OO’D-TA A’LAY-HE BE A’A-E-DATIM MIN A’T-FEKA FA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADE-NIT TAIYYE-BEE-NAT TAAHE-REE-NAL KHAYYE-REE-NAL FAAZE-LEE-NA WA-JUD A’LAIYYA BE-TAWLE-KA WA MA’ROOFE-KA.", "ArabicText1": "فَاِنْ كُنْتَ یَامَوْلَایَ تَفَضَّلْتَ فِیْ ھٰذِہِ اللَّیْلَۃِ عَلٰٓی اَحَدٍ مِّنْ خَلْقِكَ وَعُدْتَ عَلَیْہِ بِعَآئِدَۃٍ مِّنْ عَطْفِكَ فَصَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمّدٍ الطَّیِّبِیْنَ الطَّاھِرِیْنَ الْخَّیِّرِیْنَ الْفَاضِلِیْنَ وَجُدْ عَلَیَّ بِطَوْلِكَ وَمَعْرُوْفِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002155, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Lord of the worlds and send blessings on Muhammad the seal of the Prophets and his family, the Purified and salute them with a perfect salutation Surely Allah is praiseworthy, Glorious O Allah I have supplicated to You as You have commanded then answer me as You have promised Surely You do not break Your promises.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur ay Allah Tu rehmat naazil kar Muhammad (s.a.w.a) par jo khaatemun nabiyyin hai aur unki paak o taahir Aal (a.s) par, aisi Aal ke jin se Allah ne har aiyb o buraayi ko dur kiya, aur aisa taahir kiya keh jaisa tahaarat ka haq tha, ba-tehqeeq Khuda saza waar’e hamd aur saahebe buzurg hai. Khudaaya! Mai Tujhe pukaarta hu jis tarah keh Tu ne hukm diya hai, lehaaza Tu apne waade ke mutaabiq meri dua qabool farma, is liye keh yaqeenan Tu waada khilaafi nahi karta.", "Urdu": "اور محمدؐ پر اﷲ کی رحمت ہوجو نبیوں میں آخری نبیؐ ہیں اور ان کی آلؑ پر جو پاکیزہ ہیں اور سلام ہو بہت سلام بے شک اللہ خوبی والااور شان والا ہے اے معبود! میں تجھ سے دعا کرتا ہوں جیسے تو نے حکم دیا تو اپنے وعدے کے مطابق اسے قبول فرما کیوں کہ تو اپنے وعدے کی خلاف ورزی نہیں کرتا۔", "RArabic": "YAA RABBAL AA’LAMEENA WA SALLAL LAAHO A’LAA MOHAMMADIN KHAATE-MIN NABIYYEE-NA WA AALE-HIT TAAHE-REENA WA SALLAMA TASLEE-MAN INNAL LAAHA HAMEE-DOON MAJEE-DOON. ALLAAHUMMA INNEE AD-OO’KA KAMAA AMAR-TA FASTA-JIB LEE KAMAA WA-A’D-TA INNA-KA LAA TUKHLE-FUL MEE-AA’DA.", "ArabicText1": "یَارَبَّ الْعَالَمِیْنَ وَصَلَّی اللہُ عَلٰی مُحَمَّدٍ خَاتَمِ النَّبِیِّیْنَ وَاٰلِہِ الطَّاھِرِیْنَ وَسَلَّمَ تَسْلِیْمًا اِنَّ اللہَ حَمِیْدٌ مَّجِیْدٌ۔ اَللّٰھُمَّ اِنِّیْ اَدْعُوْكَ كَمَآ اَمَرْتَ فَاسْتَجِبْ لِیْ كَمَا وَعَدْتَ اِنَّكَ لَا تُخْلِفُ الْمِیْعَادَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4