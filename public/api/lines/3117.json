lueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013656, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He Who is nearer to me than my life-vein! O He Who does whatever He wills! O He Who intervenes between man and his heart! Please do) send blessings upon Muhammad and his Household and intervene between us and those who intend harm to us, in the name of Your might and power. O He Who saves from all things and nothing can ever save from Him! (Please do) relieve us from whatever aggrieves us from our worldly and religious affairs. O most merciful of all those who show mercy!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay woh keh jo meri sheh-rag (jugular vein) se bhi ziyadah qareeb hai, ay woh jo chahta hai kar deta hai, ay woh jo insaan ke aur uske dil ke darmiyaan haael hai Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur hamare aur hamein aziyyat dene waalo’n ke darmiyaan haael ho ja apni harkat o quwwat ke saath, ay har cheez se be-neyaaz karne waale jis se koi cheez be-neyaaz nahi kar sakti, duniya o aakherat mein pesh aane waali mushkilo’n mein hamari madad farma, ay sab se ziyadah rahem waale.", "Urdu": "اے وہ کہ جو میری شہ رگ سے بھی زیادہ قریب ہے اے وہ جو چاہتا ہے کردیتا ہے اے وہ جو انسان کے اور اس کے دل کے درمیان حائل ہے محمدؐ اور ان کی آلؑ پر رحمت نازل فرما اور ہمارے اور ہمیں اذیت دینے والوں کے درمیان حائل ہو جا اپنی طاقت وقوت کے ساتھ اے ہر چیز سے بے نیاز کرنے والے جس سے کوئی چیز بے نیاز نہیں کرسکتی دنیاوآخرت میں پیش آنے والی مشکلوں میں ہماری مدد فرما اے سب سے زیادہ رحم کرنے والے۔", "RArabic": "YAA MAN HOWA AQRABO ELAYYA MIN HABLIL WAREEDE YAA FA’-A’ALAL LEMAA YOREEDO YAA MAYN YAHOOLO BAYNAL MAR-E WA QALBEHI SALLE A’LAA MOHAMMADIWN WA AALEHI WA HUL BAYNANAA WA BAYNA MAYN YOOZEENAA BE-HAWLEKA WA QUWWATEKA YAA KAAFEE MIN KULLE SHAY-IWN WA LAA YAKFEE MINHO SHAYUN IKFENAL MOHIMMA MIN AMRID DUNYAA WAL AAKHERATE YAA ARHAMAR RAAHEMEEN.", "ArabicText1": "یَا مَنْ ھُوَ اَقْرَبُ اِلَیَّ مِنْ حَبْلِ الْوَرِیْدِ یَا فَعَّالًا لِّمَا یُرِیْدُ یَا مَنْ یَّحُوْلُ بَیْنَ الْمَرْءِ وَقَلْبِهٖ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِهٖ وَحُلْ بَیْنَنَا وَبَیْنَ مَنْ یُّؤْذِیْنَا بِحَوْلِكَ وَقُوَّتِكَ یَا كَافِیْ مِنْ كُلِّ شَیْءٍ وَّلَا یَكْفِیْ مِنْهُ شَیْءٌ اِكْفِنَا الْمُھِمَّ مِنْ اَمْرِ الدُّنْیَا وَالْاٰخِرَۃِ یَآ اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": nu