RedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010994, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Holy and most Holy is the Lord of the Angels and spirits. Glory be to Allah, the Possessor of lofty and sublime honor. Glory be to Allah, the Possessor of lofty and sublime honor. Glory be to Allah, the Possessor of splendid and mighty majesty. Glory be to Allah, the Possessor of the ancient and magnificent kingdom. Glory be to He, who wore the apparel of splendor and beauty. Glory be to He, who put on the garment of light and dignity. Glory be to He, who sees the traces of the ant on the stone.", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai Woh zaat jo saaheb'e izzat aur sar-buland o sarfaraaz hai. Paak hai Woh zaat jo jalaalat aur buzurgi ka maalik hai. Paak hai Woh zaat jiski baadshaahi hamesha rehne waali hai. Paak hai Woh hasti jisne khud ko khubsurat-tareen libaas pehna rakha hai. Paak hai Woh zaat jisne khud ko noor aur waqaar ke saath chhipa rakha hai. Paak hai Woh zaat jo choonti ke qadmo’n ke nisahaan sakht patthar par dekhta hai.", "Urdu": "پاک ہے وہ ذات جو صاحب عزّت اور سر بلند و سرفراز ہے۔ پاک ہے وہ ذات جو جلالت اور بزرگی کی مالک ہے۔ پاک ہے وہ ذات جس کی بادشاہی ہمیشہ رہنے والی ہے۔ پاک ہے وہ ہستی جس نے خود کو خوبصورت ترین لباس پہنا رکھا ہے۔ پاک ہے وہ ذات جس نے خود کو نور اور وقار کے ساتھ چھپا رکھا ہے۔ پاک ہے وہ ذات جو چیونٹی کے قدموں کے نشان سخت پتھر پر دیکھتی ہے۔", "RArabic": "SUBBOO-HOON QUDDOO-SOON RABBUL MALAA'e KATE WAR ROOHE, SUBHAANA ZIL I’ZZISH SHAAME-KHIL MONEEFE, SUBHAANA ZIL JALAA-LIL BAAZE-KHIL A’ZEEME, SUBHAANA ZIL MUL-KIL FAAKHE-RIL QADEEME, SUBHAANA MAN LABE-SAL BAH-JATE WAL JAMAALE, SUBHAANA MAN TA-RADDA BIN-NOORE WAL WAQAARE, SUBHAANA MAN YARAA ASARAN NAMLE FIS-SAFAA.", "ArabicText1": "سُبُّوْحٌ قُدُّوْسٌ رَبُّ الْمَلَائِكَۃِ وَالرُّوْحِ، سُبْحَانَ ذِی الْعِزِّ الشَّامِخِ الْمُنِیْفِ، سُبْحَانَ ذِی الْجَلَالِ الْبَاذِخِ الْعَظِیْمِ، سُبْحَانَ ذِی الْمُلْكِ الْفَاخِرِ الْقَدِیْم، سُبْحَانَ مَنْ لَبِسَ الْبَہْجَۃِ وَالْجَمَالِ، سُبْحَانَ مَنْ تَرَدّٰی بِالنُّوْرِ وَالْوَقَارِ، سُبْحَانَ مَنْ یَرٰی اَثَرَ النَّمْلِ فِی الصَّفَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010995, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to He, who sees the falling of the bird in the air. Glory be to He, who is thus, and no-one else is like this. Glory be to He, who knows the extremities of the hearts. Glory be to He, who calculates the number of sins. Glory be to He, before whose greatness, everything is subservient. Glory be to He. Glory be to You, O owner of majesty and nobility, which You have conducted with the needful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai Woh zaat'e giraami jo hawa mein taiyr (oodne) waale parindo’n ko dekhta hai. Paak hai Woh zaat jo us tarah hai keh koi bhi us tarah nahi. Paak hai Woh zaat jiski hukumat tamaam-tar ifte-khaaraat ke saath hamesha rehne waali hai. Paak hai Woh zaat jo jalaalat o azmat ka maalik hai. Paak hai Woh zaat jo khubsurati aur zebaai (zeenat) ka maalik hai. Paak hai Woh hasti jisne khud ko noor aur waqaar ke parde mein chhipa rakha hai.", "Urdu": "پاک ہے وہ ذات گرامی جو ہوا میں تیرنے والے پرندوں کو دیکھتی ہے۔ پاک ہے وہ ذات جو اس طرح ہے کہ کوئی بھی اس طرح نہیں۔ دوسری روایت میں نقل ہے۔ پاک ہے وہ ذات جس کی حکومت تمام تر افتخارات کے ساتھ ہمیشہ رہنے والی ہے۔ پاک ہے وہ ذات جو جلالت و عظمت کی مالک ہے۔ پاک ہے وہ ذت جو خوبصورتی اور زیبائی کی مالک ہے۔ پاک ہے وہ ہستی جس نے خود کو نور اور وقار کے پردے میں چھپا رکھا ہے۔", "RArabic": "SUBHAANA MAN YARAA WAQ-A’T-TAIYRE FIL HAWAAA-E, SUBHAANA MAN HOWA HAAKA-ZAA, WALAA HAAKA-ZAA GHAIRO-HU, SUBHAANA MAN YA’LAMO JAWAARE-HAL QOLOO-BE, SUBHAANA MAN YOHSEE, SUBHAANA MAN TAWAAZA-A’ KULLO SHAIY-IN LE-A’ZAMATE-HI, SUBHAANA SUBHAANA-KA YAA ZAL-JALAALE WAL IKRAAME, MAA FA-A’LTA BIL GHAREE-BIN.", "ArabicText1": "سُبْحَانَ مَنْ یَرٰی وَقْعَ الطَّیْرِ فِی الْہَوَاۗءِ، سُبْحَانَ مَنْ ہُوَ ہٰكَذَا، وَلَا ہٰكَذَا غَیْرُہٗ، سُبْحَانَ مَنْ یَعْلَمُ جَوَارِحَ الْقُلُوْبِ، سُبْحَانَ مَنْ یُحْصِیْ، سُبْحَانَ مَنْ تَوَاضَعَ كُلُّ شَیْءٍ لِعَظَمَتِہٖ، سُبْحَانَ سُبْحَانَكَ یَا ذَا الْجَلَالِ وَالْاِكْرَامِ، مَا فَعَلْتَ بِالْغَرِیْبٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "Arabi