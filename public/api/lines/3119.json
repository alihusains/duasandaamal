[{"Id": 1013662, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Masjid of Zaid bin Sawhaan is near to Masjid-e-Sahla. He was a very loyal companion of Hazrat Ali (a) and was martyred in the Battle of Jamal. When you enter the mosque recite as follow…", "GujaratiDescription": null, "RUrduDescription": "Yeh Masjid Zaid bin Sawhaan ke naam se hai jo Masjid’e Sahla ke qareeb hai. Woh Hazrat Ali (a) ke buzurg as-haab mein se thay jo Jange Jamal mein shaheed huwe. Jab Masjid mein daakhil ho to is tarah se padhe…", "UrduDescription": "مؤلف کہتے ہیں : مسجد زیدؒ کوفہ کی مساجد میں سے ایک ہے اور زید ابن صوحان کی طرف منسوب ہے۔ زید ابن صوحان امیر المومنینؑ کے بزرگ اصحاب میں سے تھے اور ان کو ابدال  تصور کیا جاتا ہے۔ وہ جنگ ِجمل میں امیر المومنینؑ کی نصرت کرتے ہوئے مقام ِشہادت پر سرفراز ہوئے۔ جب مسجد میں داکھل ہو تو اس طرح سے پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "Arabi