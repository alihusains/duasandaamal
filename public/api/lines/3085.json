[{"Id": 1013497, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "After entering through Baab al-Feel, stand and recite…", "GujaratiDescription": null, "RUrduDescription": "Baab al-Feel se daakhil hone ke baad, khade ho kar is tarah se padhe…", "UrduDescription": "اس کے بعد مسجد میں باب الفیل سے داخل ہو کر یہ کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013498, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah is the Most Great. Allah is the Most Great. Allah is the Most Great. This is the situation of him who seeks refuge with Allah, with Muhammad the most beloved by Allah, may Allah’s peace be upon him and his Household, with the (Divinely commissioned) leadership of the Commander of the Faithful, and with the Imams; the well- guided, the veracious, the spokesmen (of Allah), the orthodox, from whom Allah removed filth and He purified them with thorough purification.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda buzurg-tar hai, Khuda buzurg-tar hai, Khuda buzurg-tar hai, yeh Uske khade hone ki jagah hai jo Khuda ki aur Khuda ke habib Hazrat Muhammad (s.a.w.a) ki panah leta hai, neez panah leta hai momino ke Ameer (a.s) ke wilaayat ki aur un Aimma (a.s) ki wilaayat ki jo rehbar hai, sachh bole ne waale, haq kehne waale aur seedhe raaste waale hai jin se Khuda ne har najaasat ko dur rakkha aur unko paak rakkha jaisa keh paak rakhne ka haq hai.", "Urdu": "خدا بزرگ تر ہے خدا بزرگ تر ہے خدا بزرگ تر ہے یہ اس کے کھڑے ہونے کی جگہ ہے جو خدا کی اور خدا کے حبیب حضرت محمد ؐ کی پناہ حاصل کرتا ہے نیز پناہ حاصل کرتا ہے مومنوں کے امیرؑ کی ولایت کی اور ان ائمہؑ کی ولایت کی جو رہبر ہیں سچ بولنے والے حق کہنے والے اور سیدھے راستے والے ہیں جن سے خدا نے ہر نجاست کو دور رکھا اور ان کو پاک رکھا جیسا کہ پاک رکھنے کا حق ہے۔", "RArabic": "ALLAAHO AKBARO ALLAAHO AKBARO ALLAAHO AKBARO HAAZAA MAQAAMUL A’AA-EZE BILLAAHE WA BE MOHAMMADIN HABEEBIL LAAHE SALLAL LAAHO A’LAIHE WA AALEHI WA BEWELAAYATE AMEERIL MOMENEENA WAL A-IMMATIL MAHDIYYEENAS SAADEQEENAN NAATEQEENAR RAASHEDEENAL LAZEENA AZHABAL LAAHO A’NHOMUR RIZSA WA TAHHARAHUM TATHEERAN.", "ArabicText1": "اَللهُ اَكْبَرُ اَللهُ اَكْبَرُ اَللهُ اَكْبَرُ هٰذَا مَقَامُ الْعَآئِذِ بِاللہِ وَبِمُحَمَّدٍ حَبِیْبِ اللہِ صَلَّی اللہُ عَلَیْهِ وَاٰلِهٖ وَبِوِلَایَۃِ اَمِیْرِ الْمُؤْمِنِیْنَ وَالْاَئِمَّۃِ الْمَهْدِیِّیْنَ الصَّادِقِیْنَ النَّاطِقِیْنَ الرَّاشِدِیْنَ الَّذِیْنَ اَذْهَبَ اللہُ عَنْهُمُ الرِّجْسَ وَطَهَّرَهُمْ تَطْهِیْرًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013499, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I accept them as leaders, guides, and masters. I succumb to the acts of Allah. I associate none with Him and I do not betake any master other than Allah. Truly liars are those who set up equals with Allah as they have certainly strayed off in remote error. Sufficient for me are Allah and the saints of Allah.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai khush hu keh woh mere Imam, rehbar aur sardaar hai, mai hukm’e Khuda ko maanta hu, Uske saath kisi ko shareek nahi karta aur siwaaye Khuda ke kisi ko apna wali nahi banata, woh log jhoote hai jo Khuda se phir gaye aur gumrahi mein bohot dur tak ja pade, mere liye kaafi hai Khuda aurKhuda ke auliya.", "Urdu": "میں خوش ہوں کہ وہ میرے امام رہبر اور سردار ہیں میں حکم ِخداکو مانتا ہوں اس کے ساتھ کسی کو شریک نہیں کرتا اورسوائے خدا کے کسی کو اپنا ولی نہیں بناتا وہ لوگ جھوٹے ہیں جو خدا سے پھر گئے اور گمراہی میں بہت دورتک جا پڑے میرے لئے کافی ہے خدا اور خدا کے اولیاء۔", "RArabic": "RAZEETO BEHIM A-IMMATAWN WA HODAATAWN WA MAWAALIYYA SALLAMTO LE-AMRIL LAAHE LAAA USHREKO BEHI SHAY-AWN WA LAA ATTAKHEZO MA-A’L LAAHE WALIYYAN KAZABAL A’A-DELOONA BILLAAHE WA ZALLOO ZALAALAM BA-E’EDAN HASBEYAL LAAHO WA AWLEYAAUL LAAHE.", "ArabicText1": "رَضِیْتُ بِهِمْ اَئِمَّۃً وَّهُدَاۃً وَّمَوَالِیَّ سَلَّمْتُ لِاَمْرِ اللہِ لَآ اُشْرِكُ بِهٖ شَیْئًا وَّلَا اَتَّخِذُ مَعَ اللہِ وَلِیًّا كَذَبَ الْعَادِلُوْنَ بِاللہِ وَضَلُّوْا ضَلَالًاۢ بَعِیْدًا حَسْبِیَ اللہُ وَاَوْلِیَآءُ اللہِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013500, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I bear witness that there is no god but Allah, alone without having any partner. And I bear witness that Muhammad is His servant and Messenger, may Allah’s blessings be upon him and his Household, and that Ali and the well- guided Imams from his progeny, peace be upon them all, are my masters and the arguments of Allah against His created beings.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawahi deta hu keh Allah ke siwa koi ma’bood nahi, Woh yagana hai, Uska koi shareek nahi aur mai gawahi deta hu keh Hazrat Muhammad (s.a.w.a) Uske bande aur Rasool hai, neez yeh keh Imam Ali (a.s) aur unki aulaad mein se hidaayat yaafta Aimma (a.s) un par salaam ho, woh mere wali aur Khuda ki makhlooq par hujjat hai.", "Urdu": "میں گواہی دیتا ہوں کہ اﷲکے سوا کوئی معبود نہیں وہ یگانہ ہے اس کا کوئی شریک نہیں اور میں گواہی دیتا ہوں کہ حضرت محمد ؐ اس کے بندے اور رسولؐ ہیں نیز یہ کہ امام علیؑ اور ان کی اولاد میں سے ہدایت یافتہ ائمہؑ ان پر سلام ہو وہ میرے ولی اور خدا کی مخلوق پر حجت ہیں۔", "RArabic": "ASH-HADO AN LAA ELAAHA ILLAL LAAHO WAHDAHU LAA SHAREEKA LAHU WA ASH-HADO ANNA MOHAMMADAN A’BDOHU WA RASOOLOHU SALLAL LAAHO A’LAIHE WA AALEHI WA ANNA A’LIYYAWN WAL A-IMMATAL MAHDIYYEENA MIN ZURRIYYATEHI A’LAIHEMUS SALAAMO AWLEYAAA-EE WA HUJJATUL LAAHE A’LAA KHALQEHI.", "ArabicText1": "اَشْهَدُ اَنْ لَّآ اِلٰهَ اِلَّا اللہُ وَحْدَهٗ لَا شَرِیْكَ لَهٗ وَاَشْهَدُ اَنَّ مُحَمَّدًا عَبْدُهٗ وَرَسُوْلُهٗ صَلَّی اللہُ عَلَیْهِ وَاٰلِهٖ وَاَنَّ عَلِیًّا وَّالْاَئِمَّۃَ الْمَهْدِیِّیْنَ مِنْ ذُرِّیَّتِهٖ عَلَیْهِمُ السَّلَامُ اَوْلِیَآئِیْ وَحُجَّۃُ اللہِ عَلٰی خَلْقِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRed