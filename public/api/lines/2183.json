[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011741, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, the people have carelessly neglected Your remembrance, let us remember you and when they turn to your remembrance, let us thank you. Let us speak from the depths of our hearts whatever we say by our tongue. O Allah, verily the plenteousness of your forgiveness has enough room to absorb our sins, and we rely more on your mercy than on our good deeds. O Allah, send blessings on Muhammad and on his children and enable us to do good deeds worthy of rewards.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Hamein logo’n ki ghaflat ke muqaable mein zikr karne waala aur logo’n ke zikr ko hamare liye shukr qaraar de, aur hamari zabaan se achchhi aur beh-tareen cheezo’n ke jaari hone ko hamari dili niyyato’n se muttasil (mila huwa) farma. Ay Parwardigaar! Hamare gunaho’n se Teri bakhshish wasee-tar, aur hamare amaal se Teri rehmat ziyadah ummeed dila ne waali hai, Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par durood bhej, aur hamein neyk aur amal'e saaleh baja laane ki taufeeq ataa farma.", "Urdu": "اے پروردگار! ہمیں لوگوں کی غفلت کے مقابلے میں ذکر کرنے والا اور لوگوں کے ذکر کو ہمارے لئے شکر قرار دے۔ اور ہماری زبان سے اچھی اور بہترین چیزوں کے جاری ہونے کو ہماری دلی نیتوں سے متصل فرما۔ اے پروردگار! ہمارے گناہوں سے تیری بخشش وسیع تر، اور ہمارے اعمال سے تیری رحمت زیادہ امید دلانے والی ہے، محمد و آل محمد پر درود بھیج، اور ہمیں نیک اور اعمالِ صالح بجا لانے کی توفیق عطا فرما۔", "RArabic": "ALLAAHUMMAJ A’L GHAFLATAN NAASE LANAA ZIKRAN, WAJ A’L ZIKRAHUM LANAA SHUKRAN, WAJ A’L SAALEHA MAA NAQOOLO BE-ALSENATENAA NIYYATAN FEE QOLOOBENAA, ALLAAHUMMA INNA MAGHFERATAKA AWSA-O’ MIN ZONOOBENAA, WA RAHMATAKA ARJAA I’NDANAA MIN A-A’MAALENAA, ALLAAHUMMA SALLE A’LAA MOHAMMADIN WA AALE MOHAMMADIN, WA WAFFIQNAA LE-SAALEHIL A-A’MAALE WAS SAWAABE MENAL FE-A’ALE.", "ArabicText1": "اَللّٰہُمَّ اجْعَلْ غَفْلَۃَ النَّاسِ لَنَا ذِکْرًا، وَاجْعَلْ ذِکْرَہُمْ لَنَا شُکْرًا، وَاجْعَلْ صَالِحَ مَا نَقُوْلُ بِاَلْسِنَتِنَا نِیَّۃً فِیْ قُلُوْبِنَا۔ اَللّٰہُمَّ اِنَّ مَغْفِرَتَکَ اَوْسَعُ مِنْ ذُنُوْبِنَا، وَرَحْمَتَکَ اَرْجٰی عِنْدَنَا مِنْ اَعْمَالِنَا۔ اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّآلِ مُحَمَّدٍ، وَ وَفِّقْنَا لِصَالِحِ الْاَعْمَالِ وَالصَّوَابِ مِنَ الْفِعَالِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "Arab