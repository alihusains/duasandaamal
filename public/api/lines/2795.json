[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011690, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, You have ordered us to supplicate You and You have guaranteed its acceptance. Thus we have supplicated You and we are Your servants and the sons of Your servants and we are in Your control. And you are our Lord and we are Your servants. No man has asked from anything which is like You, because You are incomparable. And we have reposed hopes only in You and the creatures never turn to anyone who is like You, because there is no one like You.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baare Ilaaha! Tu ne dua maangne ka hukm diya aur usey qabool karne ki Tu ne zamaanat li, pas ham ne Tujh se dua ki aur ham log to Tere bande hai aur Tere hi bando’n ke farzand hai aur Tere qabze qudrat mein hai. Tu hi hamara Parwardigaar hai aur ham sab Tere na-cheez ghulaam hai. Kisi insaan ne aisi zaat se sawaal nahin kiya jo Tujh se milti julti ho (Kyu’n keh Tu be-misl wa be-nazir hai) aur ham to Tujh se hi lav lagaate hai aur kabhi makhlooqaat kisi aise ki taraf tawajjoh nahin karta jo Tera misl ho (is liye keh Tera koi misl hai hi nahin).", "Urdu": "بار الہ! تو نے دعا مانگنے کا حکم دیا اور اسے قبول کرنے کی تو نے ضمانت لی، پس ہم نے تجھ سے دعا کی اور ہم لوگ تو تیرے بندے ہے اور تیرے ہی بندوں کے فرزند ہے اور تیرے قبضہ قدرت میں ہے۔ تو ہی ہمارا پروردگار ہے اور ہم سب تیرے نہ چیز غلام ہے۔ کسی انسان نے ایسی ذات سے سوال نہیں کیا جو تجھ سے ملتی جلتی ہو (کیوں کہ تو بے مثل و بے نظر  ہے) اور ہم تو تجھ سے ہی لو لگاتے ہے اور کبھی مخلوقات کسی ایسے کی طرف توجہ نہیں کرتا جو تیرے مثل ہو (اس لئے کہ تیرا کوئی مثل ہے ہی نہیں)۔ ", "RArabic": "ALLAAHUMMA ANTA AMAR-TA BADDO-A’A-E WA ZAMIN-TAL IJAA-BA-TA FADA-A’W-NAAKA WA NAHNO E’BAA-DOKA WA BANOO IMAA-E-KA NAWAA-SEENAA BE-YADE-KA WA ANTA RABBO-NAA WA NAHNO E’BAA-DOKA WA LAM YAS-A-LIL E’BAADO MISLA-KA WA NAR-GHABO ILAIY-KA WA LAM YAR-GHABIL KHALAA-E-QO ILAA MISLE-KA.", "ArabicText1": "اَللّٰھُمَّ اَنْتَ اَمَرْتَ بَالدُّعَآئِ وَضَمِنْتَ الْاِجَابَۃَ فَدَعَوْنَاکَ وَنَحْنُ عِبَادُکَ وَبَنُوْا اِمَآئِکَ نَوَاصِیْنَا بِیَدِکَ وَاَنْتَ رَبُّنَا وَنَحْنُ عِبَادُکَ وَلَمْ یَسْئَلِ الْعِبَادُ مِثْلَکَ وَنَرْغَبُ اِلَیْکَ وَلَمْ یَرْغَبِ الْخَلَآئِقُ اِلٰی مِثْلِکَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011691, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O the place where those who are in need complain. And the last station of those who become attentive. O the owner of the power and dominance, O the owner of force and greatness. O the living and the everlasting, O one who does good and one who is merciful. O the most favoring and the most generous. O the creator of the heavens and the earth. O the owner of majesty and nobility. And O the giver of bounties and favors; One who cannot be reached. Bless Muhammad and Aale Muhammad (a.s) and have mercy on me. Indeed You are the forgiving and merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay saahebaan’e haajat ke shikwa karne ki jagah aur ay tawajjoh karne waalo’n ki aakhri manzil, ay saahebe buzurgi o iqtedaar, ay saahebe ghalba o izzat, ay zindah, ay qaaem rehne waale, ay neki karne waale, ay rahem karne waale, ay maher-baan, ay ehsaan karne waale, ay aasmaano aur zameeno ki ijaad (ko khalq) karne waale, ay saahebe izzat o sharaf, ay aisi neymat o satwat (dab-daba) ke maalik jin ka qasd na kiya ja sake’n. Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur mere gunah maaf kar de, yaqeenan Tu bada bakhsh ne waala aur raheem hai.", "Urdu": "اے صاحبان حاجت کے شکوہ کرنے کی جگہ اور اے توجہ کرنے والوں کی آخری منزل، اے صاحب بزرگ و اقتدار، اے صاحب غلبہ و عزّت، اے زندہ، اے قائم رہنے والے، اے نیکی کرنے والے، اے رحم کرنے والے، اے مہربان، اے احسان کرنے والے، اے آسمانوں اور زمینوں کی ایجاد کرنے والے، اے صاحب عزّت و شرف، اے ایسی نعمت و سطوت کے مالک جن کا قصد نہ کیا جا سکے۔ حضرت محمدؐ اور ان کی آلؑ پر رحمت نازل فرما اور میرے گناہ معاف کر دے، یقینًا تو بڑا بخش نے والا اور رحیم ہے۔", "RArabic": "YAA MAWZE-A’ SHAK-WAS-SAA-E-LEENA WA MUNTA-HAA HAAJA-TIR RAAGHE-BEENA WA YAA ZAL-JABA-ROOTE WAL-MALA-KOOTE WA YAA ZAS-SULTAANE WAL-I’ZZE YAA HAIYYO YAA QAIY-YOOMO YAA BARRO YAA RAHEEMO YAA HANNAANO YAA MANNAANO YAA BADEE-U’S SAMAA-WAATE WAL-ARZE YAA ZAL-JALAALE WAL-IKRAAME YAA ZANNE-A’ME WAT-TAW-LIL LAZEE LAA YORAA-MO SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WAGH-FIR-LEE INNA-KA ANTAL GHAFOO-RUR RAHEEMO.", "ArabicText1": "یَامَوْاضِعَ شَکْوَی السَّآئِلِیْنَ وَمُنْتَھٰی حَاجَۃِ الرَّاغِبِیْنَ وَیَا ذَالْجَبَرُوْتِ وَالْمَلَکُوْتِ وَیَا ذَالسُّلْطَانِ وَالْعِزِّ یَاحَیُّ یَاقَیُّوْمُ یَابَارُّ یَارَحِیْمُ یَاحَنَّانُ یَامَنَّانُ یَابَدِیْعُ السَّمٰوٰتِ وَالْاَرْضِ یَاذَالْجَلَالِ وَالْاِکْرَامِ یَاذَالنِّعَمِ وَالطَّوْلِ الَّذِیْ لَا یُرَامُ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاغْفِرْلِیْ اِنَّکَ اَنْتَ الْغَفُوْرُالرَّحِیْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2"