[{"Id": 1009975, "EnglishTitle": "ARABIC NOT AVAILABLE PLEASE READ THE TRANSLATION", "GujaratiTitle": null, "RUrduTitle": "ARABIC NAHI HAI BARA-E-KARAM TARJUMA PADHE", "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "The event of Mubahila took place on 24th Zilhijjah in the 9th year of Hijra. A deputation of 14 Christian (najran) scholars came to discuss the truth of Islam with the Holy Prophet (s). Arguments were put forward by both sides. Several days went by. The Christians did not listen to reason. Then Allah (swt) revealed the following verses…", "Gujarati": null, "RGujarati": null, "RUrdu": "Waaqeya’e Mubahila 24th Zilhijjah 9th Hijri mein huwa. 14 Isaiyo’n (najraan) ke ulama’o ka ek giroh Islam ke mutaaliq Rasoole Khuda (s) se ghuftagu karne aaye thay. Dono taraf se daleele’n pesh ki gayi aur kuchh din guzar gaye. Jab Isaiyo’n ne haq ko tasleem nahi kiya, to Allah (swt) ne yeh aayate’n naazil ki…", "Urdu": "مشہور روایت کے مطابق۲۴ ذی الحجہ عیدِ مباہلہ کا دن ہے اس دن حضرت رسول ؐ نے نصاریٰ نجران سے مباہلہ کیا تھاوہ واقعہ یوں ہے کہ حضرت رسول ؐنے اپنی عبا اوڑھی،پھر امیرالمؤمنین ؑ،جناب فاطمہ ؑاور حضرت حسنؑ و حسین ؑکو اپنی عبا میں لے کر فرمایا : یا اللہ! ہر نبی کے اہل بیت ؑہوتے ہیں اور یہ میرے اہل بیتؑ ہیں۔", "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009976, "EnglishTitle": "ARABIC NOT AVAILABLE PLEASE READ THE TRANSLATION", "GujaratiTitle": null, "RUrduTitle": "ARABIC NAHI HAI BARA-E-KARAM TARJUMA PADHE", "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "“Verily, the likeness of Isa (Jesus) with Allah is as the likeness of Adam. He created him of dust, then He said unto him:” Be, and he was” (This is) the truth from your Lord (O Muhammad), so be not of those who doubt. And whoso disputes with you concerning him after the knowledge which has come unto you, say (unto them): “Come we will summon our sons and you your sons, and our women and you your women, and our ‘selfs’ and your ‘selfs’, and then will pray humbly (to the Lord) and invoke the curse of Allah upon those who lie.” (Qur’an 3:59-61)", "Gujarati": null, "RGujarati": null, "RUrdu": "Isa (a) ki misaal Allah ke nazdeek Aadam (a) jaisi hai keh inhe mitti se paiyda kiya aur phir kaha “hoja” aur woh ho gaya. Haq tumhaare Parwardigaar ki taraf se aa chuka hai lehaaza khabar-daar! Ab tumhaara shumaar shak karne waalo’n mein na hona chahiye. Paighambar ilm ke aa jaaane ke baad jo log tum se kat-hujjati kare (akde rahe) un se kahe dijiye keh aawo ham log apne apne farzand, apni apni aurto’n aur apne apne nafso’n ko bulaaye aur phir Khuda ki baargah mein dua kare aur jootho’n par Khuda ki laanat qaraar de. (Qur’an 3:59-61)", "Urdu": "لہٰذا ان سے ہر قسم کی ظاہری و باطنی برائی کو دور رکھ اور ان کو اس طرح پاک رکھ جیسے پاک رکھنے کا حق ہے،اس وقت جبرائیل امینؑ آیت تطہیر لے کر نازل ہوئے اس کے بعد حضرت رسول خدا ؐ نے ان چار ہستیوں کو اپنے ساتھ لیا اور مباہلہ کے لئے نکلے،نصاریٰ نجران نے آپ کو اس شان سے آتے دیکھا،اور علاماتِ عذاب کا مشاہدہ کیا تو مباہلہ سے دست بردار ہو کر مصالحت کر لی اور جزیہ (ٹیکس) دینے پر آمادہ ہو گئے۔", "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009977, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "The Holy Prophet took with him Hassan & Hussain (for sons), Fatima (as women) & Ali as (Self/Nafs) (a) thus proving the exalted position of the 5 personalities who represented Islam as Truthful. Upon seeing them the Najran accepted defeat & did not enter into the encounter.", "Gujarati": null, "RGujarati": null, "RUrdu": "Yeh aayato’n ke naazil hone par Rasoole Khuda (s) ne Imam Hasan (a) aur Imam Husain (a) ko (farzand), Bibi Fatema (s) ko (aurto’n) aur Imam Ali (a) ko (nafso’n) ke taur par le gaye, is waaqiye se yeh waazeh hai keh Islam ki sachchayi aur haqeeqat ki numayendegi karne ke liye Allah (swt) ne in 5 aala shaksiyat ko muntakhab kiya. In 5 azeem shaksiyat ko dekhte hi un Isaiyo’n ne apni haar maan li, mubahila (debate) karne se mana kar diya aur jizya (tax) dene par raazi ho gaye.", "Urdu": "آج ہی کے دن امیرالمؤمنین ؑ نے حالتِ نماز میں سائل کو انگوٹھی عطا فرمائی۔اور آپ کی شان میں آیۂ مبارکہ ’’اِنَّمَاْ وَلِیُّکُمُ اللہ۔۔۔‘‘ نازل فرمائی۔", "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009978, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Also, on the 24th of Zil-hijjah, Ameerul Momineen (a) gave his ring to a beggar while in ruku (bowing down in prayer) and the following verse was revealed: Only Allah is your Guardian and His Apostle and those who believe, those who keep up prayers and pay the poor-rate while they bow. (Qu’ran 5:55)", "Gujarati": null, "RGujarati": null, "RUrdu": "Aaj hi ke din Imam Ali (a) ne haalat namaz (ruku) saayel ko angooti ataa ki aur aap ki shaan mein aayat mubaraka naazil huwi: “Imaan waalo’n bas tumhaara wali Allah hai aur uska Rasool aur woh saahebaane imaan jo Namaz qaaem karte hai aur haalate ruku mein zakaat dete hai.” (Qur’an 5:55)", "Urdu": "خلاصۂ    کلام یہ کہ یوم ِمباہلہ بڑی عظمت اور اہمیت کا حامل ہے اور اس میں چند اعمال ہیں۔", "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 4, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "Eng