[{"Id": 1011961, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is recommended to observe fast on this day to express gratitude to Almighty Allah for His marvelous favor of having saved the Holy Prophet (s) and Imam Ali (a).", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh is din shukraane ka roza rakkhe aur aaj ke din Rasoole Khuda (s) aur Imam Ali (a) ki ziyarat bhi padhe.", "UrduDescription": "علماء کرام کا فرمان ہے : اس دن رسول اکرمؐ اور امیرالمؤمنینؑ کی جانیں بچ جانے پر شکرانے کا روزہ رکھنا مستحب ہے اور آج کے دن ان دونوں ہستیوں کی زیارت پڑھنا بھی مستحب ہے۔ سیدؒ نے کتاب اقبال میں آج کے دن کی دعا بھی نقل کی ہے،شیخ ؒو کفعمیؒ کے بقول آج ہی کے دن امام حسن عسکری ؑکی شہادت ہوئی،لیکن قولِ مشہور یہ ہے کہ آپ کی شہادت اس مہینے کی آٹھویں کو ہوئی، لہٰذا ممکن ہے کہ پہلی کو آپ کے مرض کی ابتدا ہوئی ہو۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicG