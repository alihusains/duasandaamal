[{"Id": 1012685, "EnglishTitle": "Battle of Badr (2H)", "GujaratiTitle": null, "RUrduTitle": "Jang-e-Badr (2H)", "UrduTitle": "جنگ بدر ۲؁ھ", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012686, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "The Prophet (s) and his small army of 313 Muslims were far outnumbered as compared to the army of polytheists of Makkah. The Prophet (s) prayed to Allah (s.w.t) for victory despite the great odds against the Muslim army, and Allah sent his help (8:9)…", "GujaratiDescription": null, "RUrduDescription": "Rasoole Khuda (s) aur unki chhoti si fauj jis mein 313 musalmaan thay jo mushrike Makkah (dushman) ke muqaable kaafi kam thay. Allah ke Nabi (s) ne fateh hone ki dua ki, jab keh dushman kaseer ta’daad mein thay, aur Allah (swt) ne madad bheji (8:9)…", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1004214, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 9, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "When you sought aid from your Lord, so He answered you: I will assist you with a thousand of the angels following one another.", "Gujarati": null, "RGujarati": null, "RUrdu": "Jab tum Parwardigaar se faryaad kar rahe thay to Us ne tumhaari faryaad soon-li keh mai ek hazaar malaayeka se tumhaari madad kar raha hu jo bara-bar ek ke peechhe ek aa rahe hai.", "Urdu": "جب تم پروردگار سے فریاد کررہے تھے تو اس نے تمہاری فریاد سن لی کہ میں ایک ہزار ملائکہ سے تمہاری مدد کررہا ہوں جو برابر ایک کے پیچھے ایک آرہے ہیں۔", "RArabic": "IZ-TAS-TAGHEE-SOONA RABBA-KUM FASTA-JAABA LA-KUM ANNEE MO-MIDDO-KUM BE-ALFIN MENAL MALAA-E-KATE MURDE-FEEN.", "ArabicText1": "اِذْ تَسْتَغِيْثُوْنَ رَبَّكُمْ فَاسْتَجَابَ لَكُمْ اَنِّيْ مُمِدُّكُمْ بِاَلْفٍ مِّنَ الْمَلٰۗئِكَةِ مُرْدِفِيْنَ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012687, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "A seemingly impossible and hopeless situation became a great victory for the Muslims. Thus the impossible became possible through dua. Therefore on this night, pray for seemingly impossible wishes, and inshallah (god willing) they shall be fulfilled. In view of that, it is highly recommended to give alms and thank Almighty Allah. Besides this, performing Ghusl (spiritual bath) and to practice acts of worship at this night achieve a great reward.", "GujaratiDescription": null, "RUrduDescription": "Yeh badi ba-barkat raat hai keh is mein lashkar’e Islaam wa fauj’e Kuffaar mein aamna saamna huwa aur 17th Ramazan ke din Jang’e Badr huwi, jis mein musalmaano ko fatah wa nusrat naseeb huwi, yeh Islaam ki azeem tareen fateh thi. Is zimn mein ulma ka farmaan hai keh har momin is roz sadqa de aur Khuda ka shukr baja laaye. Is raat mein ghusl karna aur naafela padhna baais’e fazilat hai.", "UrduDescription": "یہ بڑی بابرکت رات ہے کہ اس میں لشکرِ اسلام و فوجِ کفر میں مقابلہ ہوا اور ۱۷رمضان کے دن جنگ ِبدر واقع ہوئی، جس میں مسلمانوں کو فتح ونصرت نصیب ہوئی یہ اسلام کی عظیم ترین فتح تھی۔ اس ضمن میں علماء اعلام کا فرمان ہے : ہر مومن اس روز صدقہ دے اور خدا کا شکربجالائے، اس رات میں غسل کرنا اور نوافل پڑھنا باعثِ فضیلت ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012688, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "According to numerous narrations, the Holy Prophet (s) asked his companions, at the night before the Battle of Badr, to go to Badr Spring and bring some water. All the companions kept silent and none of them had the courage to undertake this mission. Imam Ali (a), therefore, went towards that spring for getting some water. It was so murky, bitterly cold, and windy night. When Imam Ali (a) reached that dark, deep spring, he could not find a bucket to carry water. He therefore had to step down that spring and fill in the skin with water.", "GujaratiDescription": null, "RUrduDescription": "Bohot si riwaayat mein aaya hai keh Hazrat Rasoole Khuda (s) ne as’haab se farmaaya keh aaj ki raat tum mein se kaun hai jo kuwe’n se paani laaye? Us par sab khaamosh rahe aur kisi ne koi jawaab na diya. Tab Ameerul Momeneen (a) ne mashkiza liya aur chal diye, woh nehaayat taarik (andheri) aur sard (thandi) raat thi aur thandi hawaae’n chal rahi thi. Aap (a) kuwe’n par pohonche jo bohot taarik aur gehra tha. Phir wahan dol aur rassi waghaira bhi na thi.", "UrduDescription": "مؤلف کہتے ہیں: بہت سی روایات میں آیا ہے کہ حضرت رسول اﷲؐنے اصحاب سے فرمایا : آج کی رات تم میں سے کون ہے جو کنویں سے پانی لائے؟ تو سب خاموش رہے اور کسی نے کوئی جواب نہ دیا۔ تو امیرالمومنین ؑنے مشکیزہ لیا اور چل دیئے، وہ نہایت تاریک اور سرد رات تھی اور ٹھنڈی ہوائیں چل رہی تھیں۔ آپؑ کنوئیں پر پہنچے جوبہت تاریک اور گہرا تھا۔ پھر وہا ں ڈول اوررسّی وغیرہ بھی نہ تھی۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012689, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "On his way back to the Holy Prophet’s camp, he faced such a strong storm that made him sit on the ground. When it calmed down, he continued marching. Then, another storm that was as intense as the first blew so heavily that he had to sit on the ground. When it calmed down, he continued marching. Again, a third storm that was as intense as the previous ones blew so heavily that he had to sit on the ground. When it calmed down, he continued marching until he reached the Holy Prophet (s) who, then, asked why he had been late. “I faced three heavy storms that made me sit to the ground three times. I therefore had to wait until they would calm down,” explained Imam Ali (a).", "GujaratiDescription": null, "RUrduDescription": "Pas Hazrat kuwe’n mein utre, mashkiza bhara aur waapas chale to achaanak hawa ka ek tez jhonka aaya, Hazrat ruk gaye aur thodi der ke baad chalne ka iraada kiya to phir waisa hi sakht jhonka aaya aur Hazrat ruk gaye. Phir utthay lekin sakht hawa ke baais ruk gaye aur yu’n-hi rukte chalet huwe Rasoole Khuda (s) ki khidmat mein aa pohonche. Aan Hazrat (s) ne farmaya: “Ay Ali! Bohot der laga di?” Arz kiya keh, “hawa bohot tez aur sard thi, is liye teen (3) dafa ruk-ruk kar chalna pada”.", "UrduDescription": "پس حضرت کنوئیں میں اترے، مشکیزہ بھرا اور واپس چلے تو اچانک ہوا کاایک تیز جھونکا آیا، حضرت ؑ رک گئے اور تھوڑی دیر کے بعد چلنے کا ارادہ کیا تو پھر ویسا ہی سخت جھونکا آیا اور حضرتؑ رک گئے۔ پھراٹھے لیکن سخت ہوا کے سببب سے رک گئے اور یوں ہی رکتے چلتے ہوئے رسول اﷲؐکی خدمت میں آپہنچے۔ آنحضرت ؐ نے فرمایا: یاعلی ؑ! بہت دیر لگا دی!عرض کی: ہوا بہت تیز اور سرد تھی۔ اس لئے تین دفعہ رک رک کر چلنا پڑا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012690, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "“Did you know what these three storms were, Ali?” asked the Holy Prophet (s). As Imam Ali (a) answered in the negative, the Holy Prophet (s) explained, “The first storm was Archangel Jibraeel with one thousand angels who, altogether, came to greet you. The second storm was Archangel Mikaaeel with one thousand angels who, altogether, came to greet you. The third storm was Archangel Israfeel with one thousand angels who, altogether, came to greet you. All these angels descended to the earth to back us.”", "GujaratiDescription": null, "RUrduDescription": "Aap (s) ne pooncha, “Ya Ali! Aaya tumhe maaloom hai yeh kya maajra tha?” Aap hi bata de. Aap (s) ne farmaya, “pehli hawa Hazrat Jibraeel (a) ki ek hazaar (1000) farishto’n ke saath aamad ki thi keh un sab ne aap ko salaam kiya, dusri martaba hazaar (1000) farishto’n ke saath Mikaail (a) aaye aur un sab ne aap ko salaam kiya aur aakhir mein hazaar (1000) farishto’n ke saath Israafil (a) aaye aur unho ne bhi aap ko salaam kiya, haa’n to yeh sab farishte’n kal ki jang mein musalmaano ki madad karenge.”", "UrduDescription": "آپؐ نے پوچھا : یاعلی ؑ! آیا تمہیں معلوم ہے یہ کیا ماجرا تھا؟عرض کیا: آپ ہی بتا دیں ؟ فرمایا پہلی ہوا حضرت جبرائیلؑ کی ایک ہزارفرشتوں کے ساتھ آمد کی تھی کہ ان سب نے آپ کوسلام کیا، دوسری مرتبہ ہزارفرشتوں کے ساتھ میکائیل ؑ آئے اور ان سب نے آپ ؑ کو سلام کیا اور آخر میں ہزار فرشتوں کے ساتھ اسرافیل ؑ آئے اور انہوں نے بھی آپ ؑ کو سلام کیا،ہاں تو یہ سب فرشتے کل کی جنگ میں مسلمانوں کی مدد کریں گے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012691, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "To this event has a scholar referred, saying, Imam Ali (a) had 3000 merits in a single night. Similarly, Sayyid Himyari, the famous poet, composed a few laudatory poetic verses immortalizing this event…", "GujaratiDescription": null, "RUrduDescription": "Mo’allaf kehte hai keh ek buzurg ka kahena hai keh Ameerul Momeneen (a) ke liye ek raat teen hazaar (3000) manqabate’n hai, pas mumkin hai keh is qoul mein Badr ki raat ke isi waaqye ki taraf ishaara kiya gaya hai…", "UrduDescription": "مؤلف کہتے ہیں : ایک بزرگ کا قول ہے کہ امیرالمومنین ؑکے لئے ایک رات میں تین ہزارتین منقبتیں ہیں،لہٰذا ممکن ہے کہ اس قول میں بدر کی رات کے اسی واقعہ کی طرف اشارہ کیا گیا ہو۔ سید حمیریؒ اپنے اشعار میں امیرالمومنین ؑکی مدح کرتے ہوئے کہتے ہیں۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012692, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda aur uski neymato’n ki qasam, Insaan apne qoul ka jawaab-deh hai, Be-shak, Ail ibne Abi Talib (a.s), neki wa parhez-gaari par paiyda kiye gaye. Jab naizeh lehra ne se jang tez huwi, aur bade-bade bahaadur ruk jaate, Ali (a) muqaable ki taraf badhte unke haath mein, saiqal ki huwi tez talwaar hoti. Jaise sher apne bachcho’n mein chalta hai, ta-keh shikaar se unhe bacha le, Ali (a) woh hai salaam kiya ek raat us par Mikaaeel (a) wa Jibraeel (a) ne. Mikaaeel (a) ek hazaar farishto’n Jibraeel (a) ek hazaar farishto’n mein Israafil (a) bhi, Jang Badr ki shab madad ke liye aaye, jaise Abaabilo’n ke jhund ho.", "Urdu": "خدا اور اس کی نعمتوں کی قسم انسان اپنے قول کا جواب دہ ہے، بے شک علی ابن ابی طالبؑ نیکی و پرہیزگاری پر پیدا کیے گئے، جب نیزے لہرانے سے جنگ تیز ہوتی اور بڑے بڑے بہادر رک جاتے، علیؑ مقابل کی طرف بڑھتے ان کے ہاتھ میں صیقل کی ہوئی تیز تلوار ہوتی، جیسے شیر اپنے بچوں میں چلتا ہے تا کہ شکار سے انہیں بچالے، علیؑ وہ ہے سلام کیا ایک رات اس پر میکائیل وجبرائیل نے، میکائیل ایک ہزار فرشتوں میں جبرائیل ایک ہزار فرشتوں میں اسرافیل بھی، جنگِ بدر کی شب مدد کے لئے آئے جیسے ابابیلوں کے جھنڈ ہوں۔", "RArabic": "UQSE-MO BIL-LAAHE WA AALAA-E-HE WAL-MAR-O-A’MMAA QAALA MAS-OO-LOON, INNA A’LIYYIB-NE ABEE TAALE-BIN A’LAT-TOQAA WAL BARRE MAJBOO-LOON, KAANA EZAL-HARBO MARAT-HAL QANAA WA AH-JAMAT A’N-HAL BAHAA-LEEL, YAM-SHEE ILAL QAREENE WA FEE KAFFE-HE AB-YAZO MAA-ZIL HADDE MASQOO-LOON, MASH-YAL A’FAR-NAA BAIYNA ASH-BAALE-HE AB-RAAZA-HU LIL-QANA-SIL GHEE-LO, ZAA-KAL LAZEE SALLAMA FEE LAIYLA-TIN A’LAIY-HE MEEKAA-LOON WA JIBREE-LOON, MEEKAA-LO FEE ALFIN WA JIBREE-LO FEE AL-FIN WA YATLOO-HUM SARAA-FEELO LAIY-LATA BADRIN MADA-DAN UNZE-LOO KA-ANNA-HUM TAIY-ROON ABAA-BIL.", "ArabicText1": "اُقْسِمُ بِاللهِ وَآلَائِهِ وَالْمَرْءُ عَمَّا قَالَ مَسْئُوْلٌ، اِنَّ عَلِيِّ بْنَ اَبِيْ طَالِبٍ عَلَى التُّقٰى وَالْبِرِّ مَجْبُوْلٌ، كَانَ اِذَا الْحَرْبُ مَرَتْهَا الْقَنَاوَاَحْجَمَتْ عَنْهَا الْبَهَالِيْلُ، يَمْشِيْ اِلَى الْقِرْنِ وَفِيْ كَفِّهِ اَبْيَضُ مَاضِي الْحَدِّ مَصْقُوْلٌ، مَشْيَ الْعَفَرْنَا بَيْنَ اَشْبَالِهِ اَبْرَزَهُ لِلْقَنَصِ الْغِيْلُ، ذَاكَ الَّذِيْ سَلَّمَ فِيْ لَيْلَةٍعَلَيْهِ مِيْكَالٌ وَجِبْرِيْلٌ، مِيْكَالُ فِيْ اَلْفٍ وَجِبْرِيْلُ فِيْ اَلْفٍ وَيَتْلُوْهُمْ سَرَافِيْلُ لَيْلَةَ بَدْرٍ مَدَدًا اُنْزِلُوْاكَ اَنَّ هُمْ طَيْرٌ اَبَابِيْلُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, 