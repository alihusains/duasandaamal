[{"Id": 1016329, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "INSHA-ALLAH COMING SOON", "GujaratiDescription": null, "RUrduDescription": "Jis tarah Aan Hazrat (s.a) ki poori zindagi namoonah hai shauhar ke ghar bhi be-nazeer zindagi guzaari. Usi tarah unke shauhar, baap aur farzand namoonah thay.", "UrduDescription": "جس طرح آنحضرتؐؐ کی پوری زندگی نمونہ ہے شوہر کے گھر میں بھی بے نظیر زندگی گزاری۔ بعینہ اسی طرح ان کے شوہر باپ، اور فرزند نمونہ تھے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016330, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": "Hazrat Imam Ali (a.s) aur Hazrat Fatema Zahra (s.a) ki ba-hamee (aapas ki) zindagi Paighambar-e-Islaam (s.a.w.a) ke irshaadaat ke saaye mein guzri. Woh dono zindagi ke maamlaat mein ek dusre se taawoon (co-operate) karte thay. maamoolan maali mushkilaat unke daaman-gir rahe’n. Hatta keh khidmat-guzaar aur naukar rakhne ke liye maali wasaael (finance) na thay. Jo Hazrat Imam Ali (a.s) ko mushkil aur sakht kaamo mein madad de, aisa bohot kam huwa hai keh yeh shafeeq aur maher-baan miya-biwi khank aur chhote bistar par sardee ki wajah se chain se so sakey, agar odhni ko paaw par daale’n to sar khaali aur agar sar ko chaadar mein kare to paawu nange ho jaate, Hazrat Zahra (s.a) tabiyyatan be-neyaaz aur pur-sukoon thi. Unho ne apne waalid-e-giraami se soon rakha tha keh haqeeqat mein be-neyaazi sarwat (maal) se nahi hoti bal-keh be-neyaazi insaan ki tabiyyat aur nafs ke ghani hone mein poshida hai.", "UrduDescription": "حضرت امام علی اور حضرت زہرا کی باہمی زندگی پیغمبراسلام کے ارشادات کے سائے میں گزری۔ وہ دونوں زندگی کے معاملات میں ایک دوسرے سے تعاون کرتے تھے۔ معمولاً معاشی مشکلات ان کے دامن گیر رہیں۔ حتی کہ خدمت گذار اور نوکر رکھنے کے لئے مالی وسائل نہ تھے۔ جو حضرت امام علی کو مشکل اور سخت کاموں میں مدد دے، ایسا بہت کم ہوا ہے کہ یہ شفیق اور مہربان میاں بیوی خنک اور چھوٹے بستر پر سردی کی وجہ سے چین سے سو سکے، اگر اوڑھنی کو پاؤں پر ڈالیں تو سر خالی اور اگر سر کو چادر میں کریں تو پاؤں ننگے ہو جاتے، حضرت زہرا طبیعتاً بے نیاز اور پرسکون تھیں۔ انہوں نے اپنے والد گرامی سے سن رکھاتھا کہ حقیقت میں بے نیازی ثروت سے نہیں ہوتی بلکہ بے نیازی انسان کی طبیعت اور نفس کے غنی ہونے میں مضمر ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016331, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": "Isi tarah apne waalid-e-giraami se soon rakha tha keh Khuda-wand-e-quddoos chahta tha keh Makkah keh bayaa-baano ko soney se bhar kar mujhe de, lekin mai ne arz kiya, Parwardigaar mai pasand karta hu keh ek deen khaali peyt rahu to dusre din seyr ho kar khaawu, ta-keh jis din khaali peyt rahu Teri baargah mein tazarro (girya) aur arz-e-neyaaz (dua) karu aur jis din seyr hu Teri hamd o sana aur ne’mato’n par shukr baja laawu.", "UrduDescription": "اسی طرح اپنے والد گرامی سے سن رکھا تھاکہ خداوند قدوس چاہتا تھا کہ مکہ کے بیابانوں کو سونے سے بھر کر مجھے دے، لیکن میں نے عرض کیا، پروردگار میں پسند کرتا ہوں کہ ایک دن خالی پیٹ رہوں تو دوسرے دن سیر ہو کر کھاؤں، تاکہ جس دن خالی پیٹ رہوں تیری بارگاہ میں تضرع اور عرض نیاز کروں اور جس دن سیر ہوں تیری حمد و ثنا اور نعمتوں پر شکر بجالاؤں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "A