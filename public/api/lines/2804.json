[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011701, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I beg You and I place You under oath by the names which belong to You whether it is one with which a creature has addressed You or You have kept it especially for Your hidden knowledge. And I beg You by Your great names which are having such a position that if someone calls You through them You will definitely respond. I beg you to bless Muhammad and Aale Muhammad (a.s) and that You give me such felicity in this night that I never incline to evil ever after that, O the most merciful of the merciful ones.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baare Ilaaha! Mai Tujh se hi sawaal karta hu aur Tujh ko qasam deta hu un naamo ki jo Tere hi hai, chaahe is naam se kisi makhlooq ne Tujh ko pukaara ya usko apne ilm’e ghaib ke liye makhsoos kar rakkha ho aur Tujh se Tere us ism’e aazam ke zariye se sawaal karta hu keh jiski qadr o manzelat Tere nazdik utni hai keh agar uske zariye se koi shakhs Tujh se dua kare to Tu zaroor qabool karta hai. Mai yeh chahta hu keh Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil ki jaaye aur isi shab mujh ko ek aisi saadat se musharaf kar diya jaaye keh phir iske baad kabhi shaki na ho jaawu, ay rahem karne waalo’n mein sab se ziyadah raheem.", "Urdu": "بار الہ! میں تجھ سے ہی سوال کرتا ہو اور تجھ کو قسم دیتا ہو ان ناموں کی جو تیرے ہی ہے، چاہے اس نام سے کسی مخلوق نے تجھ کو پکارا یا اس کو اپنے علم غیب کے لئے مخصوص کر رکھا ہو اور تجھ سے تیرے اس اسم عازم  کے ذریعہ سے سوال کرتا ہو کہ جس کی قدر و منزلت تیرے نزدیک اتنی ہے کہ اگر اس کے ذریعہ سے کوئی شخص تجھ سے دعا کرے تو تو ذرور قبول کرتا ہے۔ میں یہ چاہتا ہو کہ محمدؐ اور آل محمدؑ پر رحمت نازل کی جائے اور اسی شب مجھ کو ایک ایسی سعادت سے مشرف کر دیا جائے کہ پھر اس کے بعد کبھی شکی نہ ہو جاؤں، اے رحم کرنے والوں میں سب سے زیادہ رحیم۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA WA UQ-SEMO A’LAIY-KA BE-KULLE ISMIN HOWA LAKA SAMMAA-KA BEHI AHA-DOON MIN KHALQE-KA A-WISTAA SARTA BEHI FEE I’L-MIL GHAIY-BE I’N-DAKA WA AS-ALOKA BE-ISME-KAL A’ZAMIL LAZEE HAQQOON A’LAIY-KA AN TOJEE-BA MAN DA-A’A-KA BEHI AN TO-SALLE-YA A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA AN TUS-E’DANEE FEE JAAZE-HIL LAIY-LATE SA-A’A-DATAN LAA ASH-QAA BA’DA-HAA ABA-DAN YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "اَللّٰھُمَّ اِنِّیْ اَسْئَلُکَ وَاُقْسِمُ عَلَیْکَ بِکُلِّ اِسْمٍ ھُوَ لَکَ سَمَّاکَ بِہٖ اَحَدٌ مِّنْ خَلْقِکَ اَوِاسْتَا ثَرْتَ بِہٖ فِیْ عِلْمِ الْغَیْبِ عِنْدَکَ وَاَسْئَلُکَ بِاِسْمِکَ الْاَعْظَمِ الَّذِیْ حَقٌّ عَلَیْکَ اَنْ تُجِیْبَ مَنْ دَعَاکَ بِہٖ اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاَنْ تُسْعِدَنِیْ فِیْ ھٰذِہِ اللَّیْلَۃِ سَعَادَۃً لَّا اَشْقٰی بَعْدَھَا اَبَدً یَااَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign