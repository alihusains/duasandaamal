[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011809, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Render us among the nearest of those who seek nearness to You and the most illustrious of those who turn to You and the most successful of those who ask from You and beseech You. O Allah render us among those who it as if they see you until the day of Judgment when they will meet You And do not let us die except with your pleasure. O Allah render us among those who demonstrate their sincerity towards You in their actions and those who love you (the most) among Your creation.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Hamein aise logo’n ki qaraabat naseeb farma jinho ne Teri qurbat haasil ki, aur aise izzat-daaro’n se qaraar de jo Teri baargah mein qareeb huwe hai, aur hamein un kaamyaab logo’n se qaraar de jo Tere huzoor darkhwaast karte hai aur girya karte hai. Ay Parwardigaar! Hamein aise logo’n se qaraar de jo qayaamat ke din (jo Tere deedaar ka din hai) Tera deedaar karenge, aur hamein us waqt tak maut na de jab tak Teri zaat raazi na ho jaaye. Ay Parwardigaar! Hamein aise logo’n se qaraar de jo amal mein mukhlis aur Teri tamaam makhlooqaat se ziyadah Tujhe dost rakhte hai.", "Urdu": "اے پروردگار! ہمیں ایسے لوگوں کی قرابت نصیب فرما جنہوں نے تیری قربت حاصل کی، اور ایسے عزّت داروں سے قرار دے جو تیری بارگاہ میں مقرب ہوئے ہیں، اور ہمیں ان کامیاب لوگوں سے قرار دے جو تیرے حضور درخواست کرتے ہیں اور گریہ کرتے ہیں۔ اے پروردگار! ہمیں ایسے لوگوں سے قرار دے جو قیامت کے دن (جو تیرے دیدار کا دن ہے) تیرا دیدار کریں گے، اور ہمیں اس وقت تک موت نہ دے جب تک تیری ذات راضی نہ ہوجائے۔ اے پروردگار! ہمیں ایسے لوگوں سے قرار دے جو عمل میں مخلص اور تیری تمام مخلوقات سے زیادہ تجھے دوست رکھتے ہوں۔", "RArabic": "ALLAAHUMMAJ A’LNAA MIN AQRABE MAN TAQARRABA ELAYKA, WA AWJAHE MAN TAWAJJAHA ELAYKA WA ANJAHE MAN SA-ALAKA WA TAZARRRA-A’ ELAYKA, ALLAAHUMMAJ A’LNAA MIMMAN KA-ANNAHU YARAAKA ELAA YAWMIL QEYAAMATIL LAZEE FEEHE YALQAAKA, WA LAA TOMITNAA ILLAA A’LAA REZAAKA. ALLAAHUMMA WAJ A’LNAA MIMMAN AKHLASA LAKA BE-A’MALEHI, WA AHABBAKA FEE JAMEE-E’ KHALQEKA.", "ArabicText1": "اَللّٰہُمَّ اجْعَلْنَا مِنْ اَقْرَبِ مَنْ تَقَرَّبَ اِلَیْکَ، وَاَوْجَہِ مَنْ تَوَجَّہَ اِلَیْکَ، وَاَنْجَحِ مَنْ سَاَلَکَ وَتَضَرَّعَ اِلَیْکَ۔ اَللّٰہُمَّ اجْعَلْنَا مِمَّنْ کَاَنَّہٗ یَرَاکَ اِلٰی یَوْمِ الْقِیَامَۃِ الَّذِیْ فِیْہِ یَلْقَاکَ، وَلَا تُمِتْنَا اِلَّا عَلٰی رِضَاکَ۔ اَللّٰہُمَّ وَاجْعَلْنَا مِمَّنْ اَخْلَصَ لَکَ بِعَمَلِہٖ، وَاَحَبَّکَ فِیْ جَمِیْعِ خَلْقِکَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011823, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah bless Muhammad and his family and forgive us with a resolute forgiving after which we do not return to committing any sins, mistakes or errors. O Allah bless Muhammad and his family with a blessing that is increasing, eternal, pure, consecutive and continuous by Your mercy O the most merciful of those who display mercy.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par durood bhej, aur hamein aisi hatmee aur qatee (laazmi) bakhshish se nawaaz jis ke baad na ham gunah anjaam de aur na hi khata (galti) aur ishtebah ka irtekaab (shak o Shubha) kare. Ay Parwardigaar! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par durood bhej, aisa durood jo rushd (kamaal) o hidaayat karne waale, hamesha rehne waala ho, paakeezah aur paaye-dar paaye ho, aur bara-bar ho, Tujhe apni rehmato’n ka waasta ay rahem karne waale.", "Urdu": "اے پروردگار! محمد و آل محمد پر درود بھیج، اور ہمیں ایسی حتمی اور قطعی بخشش سے نواز جس کے بعد نہ ہم گناہ انجام دیں اور نہ ہی خطا اور اشتباہ کا ارتکاب کریں۔ اے پروردگار! محمد و آل محمد پر درود بھیج، ایسا درود جو رشد و ہدایت کرنے والا، ہمیشہ رہنے والاہو، پاکیزہ اور پے در پے ہو، اور برابر ہو، تجھے اپنی رحمتوں کا واسطہ اے رحم کرنے والے۔", "RArabic": "ALLAAHUMMA SALLE A’LAA MOHAMMADIN WA AALE MOHAMMADIN, WAGH FIR LANAA MAGHFERATAN JAZMAN HATMAN LAA NAQTAREFO BA’DAHAA ZANBAN, WA LAA NAKTASEBO KHATEE-ATAN WA LAA ISMAN. ALLAAHUMMA SALLE A’LAA MOHAMMADIN WA AALE MOHAMMADIN, SALAATAN NAAMEYATAN DAA-EMATAN ZAAKEYATAN MOTATABE-A’TAN MOTAWAASELATAN MOTARAADEFATAN, BE-RAHMATEKA YAA ARHAMAR RAAHEMEEN.", "ArabicText1": "اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّآلِ مُحَمَّدٍ، وَاغْفِرْ لَنَا مَغْفِرَۃً جَزْمًا حَتْمًا لَا نَقْتَرِفُ بَعْدَہَا دَنْبًا، وَلَا نَکْتَسِبُ خَطیْئَۃً وَلَا اِثْمًا۔ اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّآلِ مُحَمَّدٍ، صَلَاۃً نَامِیَۃً دَاۗئِمَۃً، زَاکِیَۃً مُّتَتَابِعَۃً، مُتَوَاصِلَۃً مُتَرَادِفَۃً، بِرَحْمَتِکَ یَا اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "Arabic