[{"Id": 1016499, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Sayyid (r) reported it in Mahji Dda'wah and Kafa'ami in Balad Al-Ameen that our master, the leader of the time observes this supplication in his Qunoot…", "GujaratiDescription": null, "RUrduDescription": "Sayyid ne Mahji Dda’wah aur Kafami ne Balad Al-Ameen mein riwaayat ki hai keh Imam-e-Asr (a) apne Qunoot mein is dua ko padhte thay…", "UrduDescription": "سید ابن طاؤس نے کتاب مهج الدعوات اور کعفمی نے کتاب البلد الأمين روایت کی ہے کہ امام عصرؑ قنوت میں اس دُعا کو پڑھتے تھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016500, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Bless Muhammad and the family of Muhammad, honor all Your good friends by fulfilling Your promise and let them perceive their hope in Your assistance and prevent them from the agony of those who has put up controversy on You and has revolted against Your prohibition by going against You, he use Your favour to vanquish Your bound and he intended to deceit You with Your hands, he is fully aware that You can publicly hold him responsible and to eradicate him base on superiority.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma, aur apne awliya ko apna waada poora karte huwe moazziz (izzat-daar) farma, aur Tujh se jis nusrat ke woh ummeed-waar hai usey un tak pohoncha, jo Tera dushman Teri mukhaalefat par kamar-basta (datey huwe) hai, jo Tere mohremaat (haraam) ko anjaam deta hai aur Tere ahkaam ki mukhaalefat karta hai aur Teri hado’n ko todne mein Tujh se iste-aanad o madad talab karta hai, aur Tujh hi se apne ba-dast (keh jise taaqat ataa ki hai) makr o faryeb karne ka iraadah karta hai. Tera hilm phir bhi uske shaamil'e haal rehta hai aur jo maghroor ho jaata hai usko un se dur rakhta hai ta-keh Tu usey aashkaar kar ke apni giraft mein le-le.", "Urdu": "اے پروردگار! محمدؐ و آل محمدؑ پر رحمت نازل فرما اور اپنے اولیا کو اپنا وعدہ پورا کرتے ہوئے معزّز فرما اور تجھ سے جس نصرت کے وہ امیدوار ہیں اسے ان تک پہنچا جو تیرا دشمن تیری مخالفت پر کمربستہ ہے۔ جو تیرے محرّمات کو انجام دیتا ہے اور تیرے احکام کی مخالفت کرتا ہے اور تیری حدوں کو توڑنے میں تجھ سے استعانت و مدد طلب کرتا ہے اور تجھ ہی سے اپنے بدست (کہ جسے طاقت عطا کی ہے) مکر و فریب کرنے کا ارادہ کرتا ہے۔ تیرا حلم پھر بھی اس کے شاملِ حال رہتا ہے اور جو مغرور ہو جاتا ہے اس کو ان سے دور رکھتا ہے تا کہ تو اسے آشکار کر کے اپنی گرفت میں لے لے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ، وَاَكْرِمْ اَوْلِيَاۗئَكَ بِاِنْجَازِ وَعْدِكَ، وَبَلِّغْهُمْ دَرْكَ مَا يَاْمُلُوْنَهُ مِنْ نَصْرِكَ، وَاكْفُفْ عَنْهُمْ بَاْسَ مَنْ نَصَبَ الْخِلَافَ عَلَيْكَ، وَتَمَرَّدَ بِمَنْعِكَ عَلٰى رُكُوْبِ مُخَالَفَتِكَ، وَاسْتَعَانَ بِرِفْدِكَ عَلٰى فَلِّ حَدِّكَ، وَقَصَدَ لِكَيْدِكَ بِاَيْدِكَ، وَوَسِعْتَهُ حِلْمًا لِتَاْخُذَهُ عَلٰى جَهْرَةٍ، وَتَسْتَاْصِلَهُ عَلٰى عِزَّةٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016501, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, You said and You have said the fact (The parable of the life of this world is that of water which We send down from the sky. It mingles with the earth's vegetation from which humans and cattle eat. When the earth puts on its luster and is adorned, and, its inhabitants think they have power over it, Our edict comes to it, by night or day, whereat We turn it into a mown field, as if it did not flourish the day before. Thus we do elaborate the signs for a people who reflect). And You said: (So when they roused Our wrath, We took vengeance on them).", "Gujarati": null, "RGujarati": null, "RUrdu": "Pas ay mere Allah! Be-shak Tera yeh farmaan hai jo yaqeenan haq hai “yahan tak-keh jab zameen sabz o shadaab hogi aur zameen waale yeh gumaan karne lagey keh woh is (ke zewaraat se istefaadah karne) par qaadir hai, to raat ya din hamaara amr aa gaya, pas ham ne usey neest o naabood kar diya goya kal tak kuchh sabza tha hi nahi. Isi tarah fakr karne waali qaum ke liye aayaat (nishaaniyo’n) ko mufassil (tafseel ke saath) bayaan karte hai.”", "Urdu": "پس اے میرے اللہ! بےشک تیرا یہ فرمان ہے جو یقینًا حق ہے، یہاں تک کہ جب زمین سبز و شاداب ہو گئی اور زمین والے یہ گمان کرنے لگے کہ وہ اس (کے زیورات سے استفادہ کرنے) پر قادر ہیں تو رات یا دن میں ہمارا امر آگیا پس ہم نے اسے نیست و نابود کر دیا گویا کل تک کچھ سبزہ تھا ہی نہیں۔ اسی طرح ہم فکر کرنے والی قوم کے لئے آیات کو مفصّل بیان کرتے ہیں۔", "RArabic": null, "ArabicText1": "فَاِنَّكَ اللّٰهُمَّ قُلْتَ وَقَوْلُكَ الْحَقُّ (حَتّٰى اِذَا اَخَذَتِ الْاَرْضُ زُخْرُفَهَا وَازَّيَّنَتْ وَظَنَّ اَهْلُهَا اَنَّهُمْ قَادِرُوْنَ عَلَيْهَا اَتَاهَا اَمْرُنَا لَيْلًا اَوْ نَهَارًا فَجَعَلْنَاهُمْ حَصِيْدًا كَاَنْ لَمْ تَغْنَ بِالْاَمْسِ كَذٰلِكَ نُفَصِّلُ الْاٰيَاتِ لِقَوْمٍ يَتَفَكَّرُوْنَ)۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016502, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Verily our aim has come to an end, and Your annoyance is our annoyance, we are illiberal in helping the fact, we are eager for the coming of your command, we are anticipating to implement Your promise and we are expecting the advent of Your threat to Your enemies.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur Tu ne farmaaya hai: “Jab Ham ghazab-naak huwe to ham ne un se inteqaam (badla) liya aur be-shak hamare yahan aakhri fursat bhi ikhtetaam ko pohonchi.” Aur ham Tere (ajra'e hukm ke liye) ghazab-naak, haq ke nusrat ke liye hama-hang (saath-saath), Tera farmaan aane ke mushtaaq, Tera waada poora hone ke muntazir aur Tere dushman par Tera azaab naazil hone ke matawaqqe (yaqeenan) hai.", "Urdu": "اور تونے فرمایا ہے: جب ہم غضب ناک ہوئے تو ہم نے ان سے انتقام لیا، اور بے شک ہمارے یہاں آخری فرصت بھی اختتام کو پہنچی اور ہم تیرے (اجرائے حکم کے لیے) غضب ناک، حق کے نصرت کے لئے ہم آہنگ، تیرا فرمان آنے کے مشتاق، تیرا وعدہ پورا ہونے کے منتظر اور تیرے دشمنوں پر تیرا عذاب نازل ہونے کے متوقع ہیں۔", "RArabic": null, "ArabicText1": "وَقُلْتَ (فَلَمَّا اٰسَفُوْنَا انْتَقَمْنَا مِنْهُمْ)، وَاِنَّ الْغَايَةَ عِنْدَنَا قَدْتَنَاهَتْ، وَاِنَّا لِغَضَبِكَ غَاضِبُوْنَ، وَاِنَّا عَلٰى نَصْرِ الْحَقِّ مُتَعَاصِبُوْنَ، وَاِلٰى وُرُوْدِ اَمْرِكَ مُشْتَاقُوْنَ، وَلِاِنْجَازِ وَعْدِكَ مُرْتَقِبُوْنَ، وَلِحُلُوْلِ وَعِيْدِكَ بِاَعْدَاۗئِكَ مُتَوَقِّعُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016503, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, permit that and open his ways and make his reappearance at ease and pave his path, commence his legitimate course and assist him with his helper and soldiers and initiate Your affliction to the group of oppressors and spread the sword of Your wrath against Your enemies in taking revenge, verily You are artful and openhanded.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Unhe’n (Imam'e Zamaana (a.t.f.s) ko) izn (ijaazat) de-de, unki raaho’n ko khol de, unke zahoor ko aasaani farma, unhe’n usey tay karne ke wasaael faraa-ham farma, unke raasto’n ko unke liye khol de, unke lashkaro’n aur madad-gaaro’n ko nusrat farma, zaalimo’n par apna azaab jald naazil farma, adaawat (dusmani) rakhne waale dushmano ke saro’n par apne azaab ki talwaar latka de aur khoon ka inteqaam le-le. Be-shak! Tu bohot sakhi aur tadbeer karne waala hai.", "Urdu": "خدایا! انہیں اذن دے دے، ان کی راہوں کو کھول دے، ان (امام زمانہؑ) کے ظہور کو آسان فرما، انہیں اسے طے کرنے وسائل فراہم فرما، ان کے راستوں کو ان کے لئے کھول دے، ان کے لشکر والوں اور مددگاروں کی نصرت فرما، ظالموں پر اپنا عذاب جلد نازل فرما، عداوت رکھنے والے دشمنوں کے سروں پر اپنے عذاب کی تلوار لٹکا دے اور خون کا انتقام لے لے۔ بےشک! تو بہت سخی اور تدبیر کرنے والا ہے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ فَاْذَنْ بِذٰلِكَ، وَافْتَحْ طُرُقَاتِهِ، وَسَهِّلْ خُرُوْجَهُ، وَوَطِّاْ مَسَالِكَهُ، وَاَشْرِعْ شَرَاۗئِعَهُ، وَاَيِّدْ جُنُوْدَهُ وَاَعْوَانَهُ، وَبَادِرْ بَاْسَكَ الْقَوْمَ الظَّالِمِيْنَ، وَابْسُطْ سَيْفَ نَقِمَتِكَ عَلٰى اَعْدَاۗئِكَ الْمُعَانِدِيْنَ، وَخُذْ بِالثَّارِ، اِنَّكَ جَوَادٌ مَكَّارٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "Arabi