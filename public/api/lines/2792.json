[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002511, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He Who is intrinsic though He is evident, and He Who is evident though He is intrinsic; O He Who is intrinsic that is not missed and He Who is evident but He cannot be seen; O He Who is described, but neither any other described thing nor can any boundary attain His Being; O He Who is absent but not lost, and He Who is present but not witnessed. When He is sought, He shall be obtained, and neither the heavens, nor the earth nor can anything that is between them be empty of Him. He cannot be realized by asking ‘How is He?’ and His place cannot be identified by asking, ‘Where is He?’ or ‘What is His place?’ You are verily the light of all lights and the Lord of all lords. You have comprehended all things. Glory be to Him Whose like is nonexistent, and He is the All-hearing, the All-seeing. Glory be to Him Who is in this state and nothing else can be ever in his state.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Woh jo apne zahoor mein bhi baatin hai aur ay Woh jo baatin rahe kar bhi zaahir hai, ay Woh baatin keh jo poshida nahi hai aur Woh zaahir jo nazar nahi aata, ay Woh mausoof keh tausif jis ki haqeeqat tak nahi pohonchti aur na uski hadd muqarrar kar sakti hai, ay Woh ghaayab jo goom nahi hai aur Woh haazir jo dikhaayi nahi deta jise dhond ne waala pa leta hai aur Uske wujood se aasmaan aur zameen aur jo kuchh unke darmiyaan hai pal-bhar ke liye us se khaali nahi hai, Uski kaifiyat na koi jagah hai jahan Woh saakin ho, na koi simt keh jidhar Woh ho, Tu noor ko roshan karne waala, paalne waalo’n ka Paalne waala aur tamaam umoor par haawi hai. Paak hai woh jis ki maanind koi cheez nahi aur Woh soon ne waala aur dekhne waala hai, paak hai Woh jo aisa hai aur uske siwa koi aisa nahi hai.", "Urdu": "  اے وہ جو اپنے ظہور میں بھی باطن ہے اور اے وہ جو وہ باطن رہ کر بھی ظاہر ہے اے وہ باطن کہ جو پوشیدہ نہیں ہے اور وہ ظاہر جو نظر نہیں آتا اے وہ موصوف کہ توصیف جس کی حقیقت تک نہیں پہنچتی اور نہ اس کی حد مقرر کر سکتی ہے اے وہ غائب جو گم نہیں ہے اور وہ حاضر جو دکھائی نہیں دیتا جسے ڈھونڈنے والا پالیتا ہے اور اس کے وجود سے آسمان اور زمین اور جو کچھ ان کے درمیان ہے پل بھرکے لئے اس سے خالی نہیں ہے اس کی کیفیت نہ کوئی جگہ ہے جہاں وہ ساکن ہو نہ کوئی سمت کہ جدھر وہ ہو تو نور کوروشن کرنے والا پالنے والوں کا پالنے والا اور تمام امور پر حاوی ہے پاک ہے وہ جس کے مانند کوئی چیز نہیں اور وہ سننے والا اور دیکھنے والا ہے پاک ہے وہ جو ایسا ہے اور اس کے سوا کوئی ایسا نہیں ہے۔", "RArabic": "YAA BAATE-NAN FEE ZOHOO-REHI WA YAA ZAAHE-RAN FEE BOTOO-NEHI WA YAA BAATE-NAN LAIY-SA YAKH-FAA WA YAA ZAAHE-RAN LAIY-SA YORAA YAA MAWZOO-FAN LAA YAB-LO-GHO BE-KAIY-NOO-NATE-HI MAWZOO-FOON WA LAA HADDOON MAHDOO-DOON WA YAA GHAA-E-BAN GHAIRA MAF-QOO-DIN WA YAA SHAAHE-DAN GHAIRA MASH-HOO-DIN YUT-LABO FA-YOSAA-BO WA LAA YAKH-LOO MIN-HUS SAMAA-WAATO WAL-ARZO WA MAA BAIYNA-HOMAA TUR-FATA A’IY-NIN LAA YUD-RAKO BE-KAIY-FIN WA LAA YO-AIYYA-NO BE-AIY-NIN WA LAA BE-HAB-SIN ANTA NOOROON NOORE WA RABBUL AR-BAABE A-HATTA BE-JAMEE-I’L OMOO-RE SUBHAANA MAN LAIY-SA KAMIS-LEHI SHAIY-OON WA HOWAS SAMEE-U’L BASEERO SUBHAANA MAN HOWA HAKA-ZAA WA LAA HAKA-ZAA GHAIRO-HU.", "ArabicText1": "يَا بَاطِنًا فِيْ ظُهُوْرِهٖ وَيَا ظَاهِرًا فِيْ بُطُوْنِهٖ وَيَا بَاطِنًا لَيْسَ يَخْفٰى وَيَا ظَاهِرًا لَيْسَ يُرٰى يَا مَوْصُوْفًا لَا يَبْلُغُ بِكَيْنُوْنَتِهٖ مَوْصُوْفٌ وَلَا حَدٌّ مَحْدُوْدٌ وَيَا غَائِبًا غَيْرَ مَفْقُوْدٍ وَيَا شَاهِدًا غَيْرَ مَشْهُوْدٍ يُطْلَبُ فَيُصَابُ وَلَا يَخْلُوْ مِنْهُ السَّمَاوَاتُ وَالْاَرْضُ وَمَا بَيْنَهُمَا طُرْفَةَ عَيْنٍ لَا يُدْرَكُ بِكَيْفٍ وَلَا يُؤَيَّنُ بِاَيْنٍ وَلَا بِحَيْثٍ اَنْتَ نُوْرُ النُّوْرِ وَرَبُّ الْاَرْبَابِ اَحَطْتَ بِجَمِيْعِ الْاُمُوْرِ سُبْحَانَ مَنْ لَيْسَ كَمِثْلِهٖ شَيْ‏ءٌ وَهُوَ السَّمِيْعُ الْبَصِيْرُ سُبْحَانَ مَنْ هُوَ هَكَذَا وَلَا هَكَذَا غَيْرُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "Ara