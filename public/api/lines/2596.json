ٰهُمَّ اِنِّیْ اُشْهِدُكَ وَاُشْهِدُ مَلَائِكَتَكَ وَاَنْۢبِیَاۗئَكَ وَرُسُلَكَ وَجَمِیْعَ خَلْقِكَ بِاَنَّكَ اَنْتَ اللهُ رِبِّیْ، وَالْاِسْلَامُ دِیْنِیْ، وَمُحَمَّدٌ نَبِیِّیْ، وَعَلِیٌّ وَلِیِّیْ، وَالْحَسَنُ وَالْحُسَیْنُ وَعَلِیُّ بْنُ الْحُسَیْنِ وَمُحَمَّدُ بْنُ عَلِیٍّ وَجَعْفَرُ بْنُ مَحَمَّدٍ وَمُوْسَی بْنُ جَعْفَرٍ وَعَلِیُّ بْنُ مُوْسٰی وَمُحَمَّدُبْنُ عَلِیٍّ وَعَلِیُّ بْنُ مُحَمَّدٍ وَالْحَسَنُ بْنُ عَلِیٍّ وَالْكَلَفُ الصَّالِحُ صَلَوَاتُكَ عَلَیْهِمْ اَئِمَّتِیْ، بِهِمْ اَتَوَلّٰی، وَمِنْ عَدُوِّهِمْ اَتَبَرَّئُ۔ اَللّٰهُمَّ اِنِّیْ اُنْشِدُكَ دَمَ الْمَظْلُوْمِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": 