 "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016975, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, if it may be Your will and Your destiny to favor upon the nation of Your Prophet (peace be upon him) through the reappearance of Your Guardian and the son of Your Prophet’s daughter, then hasten it, and make it easy and complete it, and show me a verse through which I can comprehend Your command and perform my deed, or if You forbid me, I shall not perform it, (or for that which I seek Your will), so that this deed shall be performed with peace and safety.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اِنْ كَانَ مِنْ قَضَائِكَ وَقَدَرِكَ اَنْ تَمُنَّ عَلٰی اُمَّۃِ نَبِیِّكَ، بِظُوْرِ وَلِیِّكَ وَابْنِ بِنْتِ نَبِیِّكَ، فَعَجِّلْ ذَالِكَ، وَسَهِّلْهُ وَیَسِّرْهُ وَ