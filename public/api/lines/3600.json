[{"Id": 1016004, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "One should remain in Mina during the days of Tashreeq i.e., 11th, 12th and 13th of Zilhajj. It is better than going to Mecca and performing recommended circumambulations.", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh Haaji ayyaam-e-Tashreeq yaani 11st, 12th aur 13th Zilhijjah ko Mina mein rahe, un ayyaam (dino) mein Mina mein qayaam, Makkah ja kar mustahebi tawaaf karne se behtar hai.", "UrduDescription": "مستحب ہے کہ حاجی ایامِ تشریق یعنی گیارہ، بارہ، تیرہ ذی الحجہ کو منٰی میں رہے، ان ایام میں منٰی میں قیام، مکّہ جا کر مستحبی طواف کرنے سے پہتر ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": n