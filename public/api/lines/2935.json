[{"Id": 1012782, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Badr is between the illuminated Medina and the Holy Mecca. Fourteen companions of the Holy Prophet (s) were martyred here in the Great Battle of Badr. There is Masjid-e-A’reesh near the martyrs of Badr. Perform two rakats prayer then recite the Ziyarat of the martyrs of Badr in the following manner…", "GujaratiDescription": null, "RUrduDescription": "Badr, Madina aur Makkeh ke darmiyaan mein hai. Rasool-e-Khuda (s) ke 14 sahaabi is azeem Jang-e-Badr mein shaheed huwe. Shohoda-e-Badr ke qareeb Masjid-e-Areesh hai jahan par 2 rakat namaz adaa kare aur phir ziyarat Shohoda-e-Badr is tarah se anjaam de…", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedS