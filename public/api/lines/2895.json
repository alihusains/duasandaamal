[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002287, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) choicest blessings be upon Mohammed and his holy progeny. O Conferrer of boon amply! O Repeller of troubles! O Maker of souls! O Sublime in determinations! O Coverer [of daylight] with darkness! O Lord of magnanimity and nobility! O Remover of harm and pains! O Entertainer of those lonely in darkness! O All-knowing Who never needs teaching! (Please) send blessings to Muhammad and the Household of Muhammad and do to me all that which befits You. O He Whose Name is remedy, the remembrance of Whom is cure, and the obedience to Whom is sufficiency, (please) have mercy upon him whose wealth is only hope [for You] and whose weapon is only weeping. Glory be to You. There is no god save You. O All-tender, O All-Bestower, O Fashioner of the heavens and the earth, O Lord of majesty and honor.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay kaamil neymato’n waale, ay museebato’n ko dur karne waale, ay jaan-daaro’n ke paiyda karne waale, ay buland himmato’n waale, ay taarikiya (andhero’n) ko dur karne waale, ay ataa o bakhshish ke maalik, ay dard o gham ko dur karne waale, ay taarikiyo’n mein khouf-zada logo’n ka saath dene waale, ay woh aalim jisne ilm haasil nahi kiya, rehmat farma Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par aur mujh se woh bartaaw kar jo Tere shaayaan’e shaan hai, ay woh jiska naam dawa hai, jiska zikr shifa hai, jiski ita’at tawang giri hai us par rahem farma jiski poonji bas ummeed aur jiska hatyaar (arms) girya hai. Tu paak hai, nahi koi ma’bood siwaaye Tere, ay maher-baani karne waale, ay ehsaan karne waale, ay aasmaano aur zameen ke ijaad karne waale, ay jalaalato’n aur buzurgi ke maalik.", "Urdu": " اے کامل نعمتوں والے! اے مصائب دور کرنے والے اے جان داروں کے پیدا کرنے والے اے بلند ہمتوں والے اے تاریکیاں دور کرنے والے اے عطا و بخشش کے مالک اے درد وغم کو دور کرنے والے اے تاریکیوں میں خوف زدہ لوگوں کا ساتھ دینے والے اے وہ عالم جس نے علم حا صل نہیں کیا محمدؐ و آلِ محمدؐ پر رحمت فرما اور مجھ سے وہ برتاؤ کر کہ جو تیرے شایان ِشان ہے اے وہ جس کا نام دوا ہے جس کا ذکر شفا ہے جس کی اطاعت مال داری ہے اس پر رحم فرما جس کی پونجی اُمید اورجس کا ہتھیار گریہ ہے تو پاک ہے تیرے سوا کوئی معبود نہیں اے مہربانی کرنے والے اے آسمانوں اور زمین کے ایجاد کرنے والے اے جلالت و بزرگی کے مالک۔", "RArabic": "YAA SAABE-GHAN NEA’ME YAA DAAFE-A’N NEQA-ME YAA BAARE-AN NASA-ME YAA A’LIYYAL HAMA-ME YAA MUGH-SHE-YAZ ZOLA-ME YAA ZAL JOODE WAL KARA-ME YAA KAASHE-FAZ ZURRE WAL ALA-ME YAA MOONE-SAL MUSTAW-HE-SHEENA FIZ ZOLA-ME YAA AA’LE-MAN LAA YO-A’LLAMO SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WAF-A’L BEE MAA ANTA AHLO-HU YAA MANIS MO-HU DAWAAA-OON WA ZIKRA-HU SHEFAAA-OON WA TAA-A’TO-HU GHANAAA-OON (GHE-NAN) IRHAM MAR-RAASO MAALE-HIR RAJAAA-O WA SELAAHO-HUL BAKAAA-O SUBHAANA-KA LAA ILAAHA ILLAA ANTA YAA HANNAA-NO YAA MANNAA-NO YAA BADEE-A’S SAMAA-WAATE WAL ARZE YAA ZAL JALAALE WAL IKRAAME.", "ArabicText1": "يَاسَابِغَ النِّعَمِ يَادَافِعَ النِّقَمِ يَابَارِئَ النَّسَمِ يَاعَلِيَّ الْهِمَمِ يَامُغْشِيَ الظُّلَمِ يَاذَا الْجُوْدِ وَالْكَرَمِ يَاكَاشِفَ الضُّرِّ وَالْاَلَمِ يَامُوْنِسَ الْمُسْتَوْحِشِيْنَ فِي الظُّلَمِ يَاعَالِمًا لَّا يُعَلَّمُ صَلِّ عَلٰى مُحَمَّدٍ وَآلِ مُحَمَّدٍ وَّافْعَلْ بِيْ مَا اَنْتَ اَهْلُهٗ يَامَنِ اسْمُهٗ دَوَآءٌ وَّذِكْرُهٗ شِفَآءٌ وَّطَاعَتُهٗ غَنَآءٌ (غِنًى) اِرْحَمْ مَنْ رَّاسُ مَالِهِ الرَّجَآءُ وَسِلَاحُهُ الْبُكَآءُ سُبْحَانَكَ لَا اِلٰهَ اِلَّا اَنْتَ يَاحَنَّانُ يَامَنَّانُ يَابَدِيْعَ السَّمَاوَاتِ وَالْاَرْضِ يَاذَا الْجَلَالِ وَالْاِكْرَامِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "A