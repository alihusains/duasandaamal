[{"Id": 1016788, "EnglishTitle": "Rescue from difficulties and protection from Bandits.", "GujaratiTitle": null, "RUrduTitle": "Mushkilaat se najaat aur choro’n se mehfooz.", "UrduTitle": "مشکلات سے نجات اور چوروں سے محفوظ کی دُعا۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016789, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Late Ayatullah Sheikh Ali Akbar Nahavandi writes: Sheikh Ali Akbar Tehrani, who lives in Mashhad, narrated an incident for us saying: The pious cleric, Sheikh Mohammad Taqi Turbati, who was one of the great scholars and clerics of Islamic Ethics and a student of Allama Mirza Habibullah Rashti and had is permission of jurisprudence, said: One of my religious god-fearing students, who were among the Sayyids of the city of Turbat, narrated for me that: On returning from the Ziyarat of the holy shrines, I left Khaniqeen along with a student and went walking behind a caravan towards the Qasr e Shireen. We were weakened as a result of immense thirst and hunger, and with great difficulty, we managed to reach the caravan. We saw that the caravan was looted by bandits and all their wealth was robbed, their men were injured and were found lying in the desert, their carriers were broken and fallen on the ground. We moved towards a corner out of fear and went on top of a hill. All of a sudden, we saw a dignified Sayyid standing next to us. He greeted us with Salam, then gave us seven dates of Zahidi and said: eat four dates and give the remaining three to the Sheikh. When we eat the dates, our thirst vanished. Then he said: Recite this supplication for deliverance from difficulties and protection from the evil of thieves…", "GujaratiDescription": null, "RUrduDescription": "Marhoom Ayatullah Shaikh Ali Akbar Nehawandi likhte hai Shaikh Ali Akbar Tehrani (saakin Mashhad-e-Muqaddas) ne ham se ek waaqeya bayaan kiya; Muttaqi o parhez-gaar aaleem-e-deen Shaikh Muhammad Taqi Turbati ne jo Karbala ke buzurg ulma-e-akhlaaq aur Allama Mirza Habeebullah Rashti ke shaagrid thay aur unka ejaaza bhi unko haasil tha, farmaya; mera ek mutadeen shaagrid jo shaher-e-Turbat ke saadaat mein se tha, us ne mujh se bayaan kiya; A’tebaat Aaliyah ki ziyarat se waapsi mein ek taalib-e-ilm ke saath nikla aur qaafelah ke peechhe-peechhe Qasr-e-Shireen ki taraf chal pada pyaas ki shiddat aur thakaan se nidhaal tha badi mushkil se apne ko qaafelah tak pohonchaya, qaafelah ko choro’n ne loot liya tha aur logo’n ko zakhmi kar diya tha woh baya-baan mein pade huwe thay, ham khouf se ek bulandi ke upar chale gaye keh itne mein ek buzurg sayed ko apne paas khade dekha, us ne hamein salaam kiya phir saat (7) zaahadi khurram hamein ataa kiya aur farmaya; chaar (4) khurme khud khaawo aur teen (3) us Shaiikh ko de do, chunaan-che khurram khaane ke baad hamari pyaas khatm ho gayi, phir farmaya is dua ko mushkilaat se najaat aur choro’n ke shar se mehfooz rehne ke liye padhe…", "UrduDescription": "مرحوم آیة اللہ شیخ علی اکبر نھاوندی لکھتے ہیں شیخ علی اکبر طہرانی ساکن مشہد مقدس نے ہمارے لئے ایک واقعہ بیان کیا اور کہا عالم متقی شیخ محمد تقی تربتی فضلاء اور علماء میں سے تھے اور علامہ میرزا حبیب رشتی کے شاگردوں میں سے تھے ان کی طرف سے اجازت نامہ بھی تھا فرمایا کہ میرے متدین شاگردوں میں سے ایک جو شہر تربت کے سادات میں سے تھے اس نے میرے لئے بیان کیا اور کہا کہ میں زیارت عتبات عالیات سے واپس آرہا تھا طلباء کے ہمراہ خانقین سے خارج ہوا اور پیادہ قافلہ کے پیچھے قصر شیرین کے طرف جارہا تھا تشنگی اور تھکاوٹ کی وجہ سے کمزور ہوچکا تھا بہت زیادہ زحمت کے ساتھ اپنے آپ کو قافلہ تک پہنچایا چوروں نے قافلہ کے مال کو لوٹ لیا تھا۔ بعض زخمی ہوئے تھے اور بیابان میں پڑے تھے اور محمل ٹوٹے ہوئے تھے اور زمین پر پڑے ہوئے تھے ہم ڈر کے مارے دور گئے اور ایک ٹیلے پر چڑھ کر کھڑے ہوگئے اچانک دیکھا کہ ایک سید بزرگوار ہمارے پاس کھڑا ہے ہمیں سلام کیا اس کے بعد سات زاھدی کرمہ کے دانے مجھے دیا اور فرمایا چار دانہ خود کھالیں ان میں تین دانہ کھجور شیخ کو دے دیں جب ہم نے خرمہ کھایا تو ہماری پیاس دور ہوگئی اور فرمایا اس دعا کو سختی سے رہائی اور چوروں کے شر سے محفوظ رہنے کے لئے پڑھو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": 