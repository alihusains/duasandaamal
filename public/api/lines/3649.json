[{"Id": 1010986, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Shaikh Mufeed narrates in Muqniah that it is recommended to recite salawaat on Rasool-e-Khuda (s) in the month of Ramazan, minimum 100 times daily and if one recites more than this act is much great.", "GujaratiDescription": null, "RUrduDescription": "Muqniah mein Shaikh Mufeed ne farmaya; Mahe Ramazan ki sunnato’n mein se ek Hazrat Rasool-e-Khuda (s) par salawaat bhejna hai keh rozaana 100 martaba salawaat bheje aur agar us se ziyadah bheje to yeh afzal amal hai.", "UrduDescription": "مقنعہ میں شیخ مفید ؒ نے فرمایا : ماہِ رمضان کی سنتوں میں سے ایک حضرت رسول ؐپر صلوات بھیجنا ہے کہ روزانہ سو مرتبہ صلوات بھیجے اور اگر اس سے زیادہ بھیجے تو یہ افضل عمل ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreen