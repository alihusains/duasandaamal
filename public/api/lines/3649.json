اگر ممکن ہو تو ہر رات ۱۰۰ مرتبہ <سورۂ دخان> پڑھے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010989, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 4, "EnglishDescription": "It is narrated that if a person in the night of Mahe Ramazan recite <Surah Fatah> in his naafela namaz then he will be safe from all calamities in that year.", "GujaratiDescription": null, "RUrduDescription": "Riwaayat mein hai keh Mahe Ramazan ki har raat ki naafela namaz mein <Surah Fatah> padhe to woh us saal mein har bala se mehfooz rahega.", "UrduDescription": "روایت میں ہے کہ ماہ رمضان کی ہر رات کی نافلہ نماز میں <سورۂ فتح> پڑھے تو وہ اس سال میں ہر بلا سے محفوظ رہے گا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010990, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 5, "EnglishDescription": "Ibne Qirat has narrated that according to Imam Muhammad Taqi (a) and also Shaikh Mufeed has recorded in Al Ghariya wa Al-Ashraaf which is the famous narration that one should complete 1000 rakats of namaz in the form of 2x2 rakats in the whole month of Ramazan. In the first 2/3 of Mahe Ramazan he should recite 20 rakats of namaz in such a way that after Namaz-e-Maghrib he should recite 8 rakat namaz and after Namaz-e-Isha he should recite 12 rakats. In the last 1/3 of Mahe Ramazan he should recite 30 rakats of namaz in such a way that after Namaz-e-Maghrib he should recite 8 rakat namaz and after Namaz-e-Isha he should recite 22 rakats. The remaining 300 rakats should be divided into three and each 100 rakats should be recite in each Shab-e-Qadr (ie. 19th, 21st & 23rd).", "GujaratiDescription": null, "RUrduDescription": "Ibne Qirat ki riwaayat ke mutaabiq Imam Muhammad Taqi (a) ka farmaan hai ke jise Shaikh Mufeed ne apni kitaab Al Ghariya wa Al-Ashraaf mein naql kiya hai jo qaul-e-mashhoor bhi hai aur woh yeh hai keh Mahe Ramazan mein 1000 rakat 2x2 kar ke adaa kare keh jiske pehle aur dusre ashre (shuru ke 20 dino) mein 20 rakat namaz is tarah se padhe keh 8 rakat Namaz-e-Maghrib ke baad aur 12 rakat Namaz-e-Isha ke baad baja laaye, phir Mahe Ramazan ke aakhri ashre mein 30 rakat namaz padhe keh 8 rakat Namaz-e-Maghrib ke baad aur 22 rakat Namaz-e-Isha ke baad adaa kare. Baaqi 300 rakat is tarah se poori kare keh 100 rakat har (19th, 21st aur 23rd) Shab-e-Qadr mein baja laaye. Is tarah kul 1000 rakat poori ho jaayegi.", "UrduDescription": "واضح ہو کہ ماہِ رمضان کی رات کے اعمال میں۱۰۰۰ رکعت نماز بھی ہے جو اس پورے مہینے میں پڑھی جائے گی، بزرگ علماء نے کتب فقہ اور کتب عبادات میں اس کا ذکر کیا ہے تاہم اس کی ترکیب کے سلسلے میں مختلف حدیثیں وارد ہوئی ہیں۔ لیکن ابن قرۃ کی روایت کے مطابق امام محمد تقی ؑکا فرمان ہے،جسے شیخ مفید ؒنے اپنی کتاب الغریہ ٖو الاشراف میں نقل کیا ہے جو قول مشہوربھی ہے اور وہ یہ ہے کہ ماہِ رمضان کے پہلے اور دوسرے عشرے میں ہر رات دو دو رکعت کر کے نماز پڑھے ان میں سے ۸ رکعت نماز مغرب کے بعد اور ۱۲ رکعت عشا کے بعد بجا لائے پھر ماہ رمضان کے آخری عشرے میں ہر رات ۳۰ رکعت نماز مذکورہ ترتیب سے اس طرح پڑھے کہ ۸ رکعت نماز مغرب کے بعد اور ۲۲ رکعت عشا کے بعد ادا کرے۔باقی ۳۰۰ رکعت اس طرح پوری کرے کہ ۱۰۰ رکعت انیس کی شب، ۱۰۰ رکعت اکیس کی شب اور ۱۰۰ رکعت تیئیس کی شب میں بجا لائے تومجموعی طور پر ایک ہزار رکعت پوری ہو جائے گی۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText