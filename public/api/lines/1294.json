[{"Id": 1000463, "EnglishTitle": "The Whispered Prayer of the Complainers (Shakeen)…", "GujaratiTitle": null, "RUrduTitle": "Shikwa karne waalo’n ki Munajaat…", "UrduTitle": "دوسری مناجات مناجاتِ شاکّین۔۔۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000464, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, to Thee I complain of a soul commanding to evil, rushing to offenses, eager to disobey Thee, and exposing itself to Thy anger. It takes me on the roads of disasters, it makes me the easiest of perishers before Thee; many its pretexts, drawn out its expectations; when evil touches it, it is anxious, when good touches it, grudging; inclining to sport and diversion, full of heedlessness and inattention, it hurries me to misdeeds and makes me delay repentance.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Mabood! Mai Tujh se apne nafs ki shikaayat (complain) karta hu jo buraayi par uksaane waala aur khata ki taraf jald badh ne waala hai. Woh Teri na-farmani ka shayeq (shauq rakhne waala) aur Teri na-raazgi se takkar leta hai (na-raazgi ka saamna karta hai). Woh mujhe tabahi ki raaho’n par le jaata hai aur us ne mujhe Tere saamne zaleel aur bad-haal (khasta-haal) bana diya hai. Yeh bada bahaana-saaz aur lambi ummeedo’n waala hai. Agar usey takleef ho to fariyaad karta hai, aur agar aaraam pohonche to chup rehta hai. Woh khel-tamaashe ki taraf ziyadah maael aur ghaflat o bhool-chuk se bhara pada hai. Mujhe tezi se gunah ki taraf le jaata hai aur taubah karne mein taakhir (der) karta hai.", "Urdu": "خدا کے نام سے شروع جو بڑا مہربان نہایت رحم والا ہے۔ اے معبود! میں تجھ سے اپنے نفس کی شکایت کرتا ہوں جو برائی پر اکسانے والا اور خطاکی طرف بڑھنے والا ہے وہ تیری نافرمانی کا شوقین اور تیری ناراضگی سے ٹکر لیتا ہے وہ مجھے تباہی کی راہوں پر لے جاتا ہے اور اس نے مجھے تیرے سامنے ذلیل اور تباہ حال بنادیا ہے یہ بڑا بہانہ ساز اور لمبی امیدوں والا ہے اگر اسے تکلیف ہو تو چلّاتا ہے اور اگر آرام پہنچے تو چپ رہتا ہے وہ کھیل تماشے کی طرف زیادہ مائل اورغفلت اور بھول چوک سے بھرا پڑا ہے مجھے تیزی سے گناہ کی طرف لے جاتاہے اور توبہ کرنے میں تاخیرکرتا ہے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اِلٰهِىْ اِلَيْكَ اَشْكُوْ نَفْسًۢا بِالسُّوْٓءِ اَمَّارَةً وَاِلَى الْخَطِيْٓئَةِ مُبَادِرَةً وَبِمَعَاصِيْكَ مُوْلَعَةً وَ لِسَخَطِكَ مُتَعَرِّضَةً۔ تَسْلُكُ بِىْ مَسَالِكَ الْمَهَالِكِ وَتَجْعَلُنِىْ عِنْدَكَ اَهْوَنَ هَالِكٍ كَثِيْرَةَ الْعِلَلِ طَوِيْلَةَ الْاَمَلِ اِنْ مَسَّهَا الشَّرُّ تَجْزَعُ وَاِنْ مَسَّهَا الْخَيْرُ تَمْنَعُ مَيَّالَةً اِلَى اللَّعَبِ وَاللَّهْوِ مَمْلُوَّةًۢ بِالْغَفْلَةِ وَالسَّهْوِ تُسْرِعُ بِىْ اِلَى الْحَوْبَةِ وَتُسَوِّفُنِىْ بِالتَّوْبَةِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012330, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, I complain to Thee of an enemy who misguides me and a satan who leads me astray. He has filled my breast with tempting thoughts, and his suggestions have encompassed my heart. He supports caprice against me, embellishes for me the love of this world, and separates me from obedience and proximity!", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Mabood! Mai Tujh se shikaayat karta hu us dushman (shaitaan) ki jo gumrah karta hai aur Shaitaan (iblis) ki jo behkaata hai, us ne mere sineh (chest) ko boore khayaalo’n se bhar diya, uski khwahisho’n (chaahato’n) ne mere dil ko gher liya hai. Buri khwahisho’n ki takmil mein madad karta hai aur duniya ki mohabbat ko achcha bana kar dikhaata hai. Woh mere aur Teri bandagi aur taqarrub ke darmiyaan haayel ho gaya hai.", "Urdu": "میرے معبود میں تجھ سے شکایت کرتا ہوں اس دشمن کی جو گمراہ کرتا ہے اور شیطان کی جو بہکاتا ہے اس نے میرے سینے کو برے خیالوں سے بھردیا اس کی خواہشوں نے میرے دل کو گھیرلیا ہے بری خواہشوںمیں مدد کرتا ہے اوردنیاکی محبت کواچھا بنا کر دکھاتا ہے وہ میرے اور تیری بندگی اور قربت کے درمیان حائل ہوگیاہے۔", "RArabic": null, "ArabicText1": "اِلٰهِىْٓ اَشْكُوْ اِلَيْكَ عَدُوًّا يُضِلُّنِىْ وَشَيْطَانًا يُغْوِنِىْ۔ قَدْ مَلَاَ بِالْوَسْوَاسِ صَدْرِىْ وَاَحَاطَتْ هَوَاجِسُهٗ بِقَلْبِىْ۔ يُعَاضِدُ لِىَ الْهَوٰى وَيُزَيِّـنُ لِىْ حُبَّ الدُّنْيَا وَيَحُوْلُ بَيْنِىْ وَبَيْنَ الطَّاعَةِ وَالزُّلْفٰى۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012331, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, to Thee I complain of a heart that is hard, turned this way and that by tempting thoughts, clothed in rust and the seal, and of an eye too indifferent to weep in fear of Thee and eagerly seeking that which gladdens it! My God, there is no force and no strength except in Thy power, and no deliverance for me from the detested things of this world save through Thy preservation.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Mabood! Mai Tujh se dil ki sakhti ki shikaayat karta hu aur musalsal (continuously) was-waso’n ki shikaayat karta hu. Jo zang o teerghi se aaluda hai. Us aankh ki shikaayat karta hu jo Tere khouf mein girya nahi karti aur jo cheez achchi laghe us se khush hai. Ay Mabood! Nahi hai mere liye koi chaara (taaqat) o quwat magar jo Teri qudrat se milti hai. Mai bachh nahi sakta duniya ki buraaiyo’n se magar sirf Teri nighah-daasht (security) se.", "Urdu": "اے معبود! میں تجھ سے دل کی سختی کی شکایت کرتا ہوں اورمسلسل وسواسوں کی شکایت کرتا ہوں جورنگ و تیرگی سے آلودہ ہے اس آنکھ کی شکایت کرتا ہوں جو تیرے خوف میں گریہ نہیں کرتی اور جوچیز اچھی لگے اس سے خوش ہے اے معبود! نہیں میری قوت اور نہیں طاقت مگر جو تیری قدرت سے ملتی ہے میں دنیا کی برائیوں سے بچ نہیں سکتا مگرصرف تیری نگہداشت سے۔", "RArabic": null, "ArabicText1": "اِلٰهِىْٓ اِلَيْكَ اَشْكُوْ قَلْبًا قَاسِيًا مَّعَ الْوَسْوَاسِ مُتَقَلِّبًا وَبِالرَّيْنِ وَالطَّبْعِ مُتَلَبِّسًا وَعَيْنًا عَنِ الْبُكَآءِ مِنْ خَوْفِكَ جَامِدَةً وَاِلٰى مَا يَسُرُّهَا طَامِحَةً۔ اِلٰهِىْ لَا حَوْلَ وَلَا قُوَّةَ اِلَّا بِقُدْرَتِكَ وَلَا نَجَاةَ لِىْ مِنْ مَكَارِهِ الدُّنْيَا اِلَّا بِعِصْمَتِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012332, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "So I ask Thee by Thy far-reaching wisdom and Thy penetrating will not to let me expose myself to other than Thy munificence and not to turn me into a target for trials! Be for me a helper against enemies, a coverer of shameful things and faults, a protector against afflictions, a preserver against acts of disobedience! By Thy clemency and mercy, O Most Merciful of the merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Pas Tujh se sawaal karta hu Teri gaheri (deep) hikmat aur Teri puri hone waali marzi ke waaste se, keh mujhe apni bakhshish ke siwa kisi taraf na jaane de. Aur mujhe fitno ka hadaf (target) na banne de. Aur dushmano ke muqaabil mera madad-gaar ban, mere aiybo’n aur ruswaaiyo’n ki parda-poshi farma. Mujh se museebate’n dur kar. Aur gunaho’n se bachaaye rakh, Apni rehmat o nawazish se, Ay sabse ziyadah rahem karne waale.", "Urdu": "پس تجھ سے سوال کرتا ہوں تیری گہری حکمت اور تیری پوری ہونے والی مرضی کے واسطے سے کہ مجھے اپنی بخشش کے سوا کسی طرف نہ جانے دے اور مجھے فتنوں کا ہدف نہ بننے دے اور دشمنوں کے مقابل میرا مددگار بن میرے عیبوں اور رسوائیوں کی پردہ پوشی فرما مجھ سے مصیبتیں دور کر اور گناہوں سے بچائے رکھ اپنی رحمت و نوازش سےاے سب سے زیادہ رحم کرنے والے۔", "RArabic": null, "ArabicText1": "فَاَسْئَلُكَ بِبَلَاغَةِ حِكْمَتِكَ وَنَفَاذِ مَشِيَّتِكَ اَنْ لَّا تَجْعَلَنِىْ لِغَيْرِجُوْدِكَ مُتَعَرِّضًا وَلَا تُصَيِّرَنِىْ لِلْفِتَنِ غَرَضًا۔ وَكُنْ بِىْ عَلَى الْاَعْدَآءِ نَاصِرًا وَّعَلَى الْمَخَازِىْ وَالْعُيُوْبِ سَاتِرًا وَّمِنَ الْبَلَآءِ وَاقِيًا وَعَنِ الْمَعَاصِىْ عَاصِمًۢا بِرَافَتِكَ وَرَحْمَتِكَ يَآاَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRed