[{"Id": 1010881, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Ibn Qulwayh (r) has narrated on the authority of Ahmad Ibn Muhammad Ibn Abi Nasr that he said: I requested Imam Reza (a) about expressing salutation on the holy grave of Messenger of Allah (s). Imam Reza (a) said: You should say…", "GujaratiDescription": null, "RUrduDescription": "Ibne Qulwayh (r) ne riwaayat ki hai Ahmad Ibne Muhammad Ibne Abi Nasr se keh unho’n ne Imam Ali Reza (a) se arz kiya; namaz ke baad mai Hazrat Rasool-e-Khuda (s) par kis tarah salaam bheju? Aap (a) ne farmaya; yu’n kaho’n…", "UrduDescription": "ابن قلویہ نے احمد ابن محمد ابن ابی نصر نے امام علی رضا ؑسے عرض کیا:نماز کے بعد میں حضرت رسول ؐ پر کس طرح سلام بھیجوں؟ آپؑ نے فرمایا : یوں کہو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010103, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O Rasoolullah. His bounties and blessings, be on you, Peace be upon you, O Muhammad son of Abdullah! Peace be upon you, O best of Allah’s! creations! Peace be upon you, O Friend of Allah! Peace be upon you, O selected one of Allah! Peace be upon you, O Trustee of Allah! I bear witness that you are undoubtedly the Prophet of Allah and I bear witness that you are undoubtedly, Muhammad Son of Abdullah. And I bear witness that you gave advice to your followers and that you made sacrifices for the sake of your Creator, and that you prayed to Him until you passed away. O Rasoole Khuda, may Allah give you rewards better than those given to other Prophets by their followers. O Allah! Bestow Thy blessings on Muhammad & His Progeny, better blessings than those bestowed on Ibrahim and his Progeny. Undoubtedly Thou art worthy of praise and Thou art revered.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay Rasoole Khuda (s.a.w.a) aur Khuda ki rehmat o barkat ho aap par. Salaam ho aap par ay Hazrat Muhammad bin Abdullah. Salaam ho aap par ay Khuda ke barguzida. Salaam ho aap par ay Habib’e Khuda. Salaam ho aap par ay Parwardigaar ke mukhlis dost. Salaam ho aap par ay Khuda ki wahi ke ameen. Mai gawahi deta hu keh aap Allah ke Rasool hai. Aap hi Hazrat Muhammad bin Abdullah hai. Aur mai gawahi deta hu keh aap ne apni ummat ko nasihat ki hai, raahe Khuda mein jihad kiya hai aur ta-hayaat uski ibaadat karte rahe hai. Ya Rasool-Allah! Khuda aap ko woh behtareen jaza de jo kisi nabi ko uski ummat ki taraf se di gayi hai. Khudaaya! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par woh behtareen rehmat naazil farma jo Tu ne Ibrahim aur Aale Ibrahim par naazil ki hai keh Tu saahebe majd o buzurg waari hai.", "Urdu": "آپ پر سلام ہو اے اللہ کے رسولؐ اور اللہ کی رحمت اور اس کی برکتیں ہوں۔ آپ پر سلام ہو اے محمدؐ ابن عبداﷲؑ، آپ پر سلام ہو اے پسندیدۂ خدا، آپ پر سلام ہو اے حبیبِؐ خدا !آپ پر سلام ہو اے خدا کے منتخب، آپ پر سلام ہو اے خدا کے امانت دار۔ میں گواہی دیتاہوں کہ آپ خدا کے رسولؐ ہیں اور گواہی دیتا ہوں کہ آپ محمدؐ ابن عبداﷲؑہیں۔ میں گواہی دیتا ہوں کہ آپ نے اپنی امت کی خیر خواہی کی اور اپنے رب کی راہ میں جہاد کیا اور اس کی عبادت کرتے رہے حتی کہ وقت ِموت آگیااب اے خدا کے رسولؐ وہ آپ کو جزا دے وہ بہترین جزا جو نبیؐ کو اپنی امت سے مل سکتی ہے اے معبود! محمدؐ وآل محمدؑ پر رحمت فرما بہترین رحمت جو تو نے حضرت ابراہیم ؑاور آل ابراہیم ؑ پرفرمائی بے شک تو لائق ِحمد اور شان والا ہے۔", "RArabic": "AS-SALAAMO A’LAIKA YAA RASOOLAL LAAHE WA RAHMA-TUL LAAHE WA BARA-KAATO-HU. AS-SALAAMO A’LAIKA YAA MOHAMMADAB-NO A’BDIL LAAHE. AS-SALAAMO A’LAIKA YAA KHAIRA-TAL LAAHE. AS-SALAAMO A’LAIKA YAA HABEE-BAL LAAHE. AS-SALAAMO A’LAIKA YAA SIFWA-TAL LAAHE. AS-SALAAMO A’LAIKA YAA AMEE-NAL LAAHE. ASH-HADO ANNA-KA RASOOLUL LAAHE. WA ASH-HADO ANNA-KA MOHAMMADAB-NO A’BDIL LAAHE. WA ASH-HADO ANNA-KA QAD NA-SAHTA LE-UMMATE-KA WA JAA-HADTA FEE SABEE-LE RABBE-KA WA A’BAD TAHU HATTAA ATAA-KAL YAQEE-NO. FA-JAZAA-KAL LAAHO YAA RASOOLAL LAAHE AF-ZALA MAA JAZAA NAIYYAN A’N UMMATE-HI. ALLAAHUMMA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN AF-ZALA MAA SAL-LAIY-TA A’LAA IBRAA-HEEMA INNA-KA HAMEE-DOON MAJEE-DOON.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ یَارَسُوْلَ اللہِ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہٗ۔ اَلسَّلَامُ عَلَیْکَ یَامُحَمَّدَابْنُ عَبْدِاللہِ۔ اَلسَّلَامُ عَلَیْکَ یَاخِیَرَۃَ اللہِ۔ اَلسَّلَامُ عَلَیْکَ یَاحَبِیْبَ اللہِ۔ اَلسَّلَامُ عَلَیْکَ یَاصِفْوَۃَ اللہِ۔ اَلسَّلَامُ عَلَیْکَ یَااَمِیْنَ اللہِ۔ اَشْھَدُ اَنَّکَ رَسُوْلُ اللہِ۔ وَاَشْھَدُ اَنَّکَ مُحَمَّدَابْنُ عَبْدِاللہِ وَاَشْھَدُ اَنَّکَ قَدْ نَصَحْتَ لِاُمَّتِکَ وَجَاھَدْتَ فِیْ سَبِیْلِ رَبِّکَ وَعَبَدْ تَہٗ حَتّٰی اَتَاکَ الْیَقِیْنُ فَجَزَاکَ اللہُ یَارَسُوْلَ اللہِ اَفْضَلَ مَاجَزٰی نَبِیًّا عَنْ اُمَّتِہٖ۔ اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ اَفْضَلَ مَا صَلَّیْتَ عَلٰی اِبْرَاھِیْمَ وَاٰلِ اِبْرَاھِیْمَ اِنَّکَ حَمِیْدٌ مَّجِیْدٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3