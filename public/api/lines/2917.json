[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002515, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Glorious! O One an Only! O All-generous! I turn my face towards You in the name of Muhammad, Your Prophet, the Prophet of Mercy, Allah’s blessings be upon him and his Household; O Muhammad! O Allah’s Messenger! I turn my face in your name towards Allah, my and your Lord and the Lord of all things. I thus beseech You, O Allah, to send blessings upon Muhammad and his Household, and I beseech You to grant me one of Your generous gifts, an easy opening, and expansive sustenance by which I can put together my scattered things, settle my debts, and have the ability to cover the needs of my dependants.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay buzurg waale, ay yagaana, ay ataa karne waale mai ne Teri taraf rukh kiya hai Tere Nabiye Rehmat Muhammad (s.a.w.a) ke wasile ke waaste se. Ya Muhammad, ya Rasoolallah be-shak mai ne aap ke wasile se Allah ki taraf rukh kiya hai jo mera Rab, aap ka Rab aur har cheez ka Rab hai. Sawaal karta hu ay Ma’bood! yeh keh Tu rehmat naazil farma Muhammad (s.a.w.a) aur unke Ahlebait (a.s) par aur sawaal karta hu Tujh se keh Tere altaaf kareemaana mein se lutfe khaas se ba-aasaani kaamyaabi aur wasee rizq ka sawaal hai jis se meri pareshaani dur ho aur mera qarz adaa ho jaaye aur uske zariye apne ayaal ki kifaalat karu.", "Urdu": "اے بزرگی والے اے یگانہ اے عطا کرنے والے میں نے تیری طرف رخ کیا ہے تیرے نبی نبی ِرحمت محمدؐکے وسیلے سے یا محمدؐیا رسول اﷲؐبے شک میں نے آپ کے وسیلے سے اللہ کی طرف رخ کیا ہے جو میرا رب آپ کا رب اور ہر چیز کا رب ہے سوال کرتا ہوں اے معبود!یہ کہ تو رحمت نازل فرما محمدؐاور ان کے اہل بیتؑ پر اور سوال کرتا ہوں تجھ سے کہ تیرے الطاف ِکریمانہ میں سے لطف ِخاص کا بآسانی کامیابی اوروسیع رزق کا سوال ہے جس سے میری پریشانی دور ہو اور میرا قرض ادا ہو جائے اور اس کے ذریعے اپنے اہل وعیال کی کفالت کروں۔", "RArabic": "YAA MAAJE-DO YAA WAAHE-DO YAA KAREE-MO ATA WAJJA-HU ILAIKA BE-MOHAMMADIN NABIYYE-KA NABIYYIR RAHMATE SALLAL LAAHO A’LAIHE WA AALE-HI YAA MOHAMMADO YAA RASOOLAL LAAHE INNEE ATA-WAJJA-HU BEKA ILAL LAAHE RABBEE WA RABBE-KA WA RABBE KULLE SHAI-IN WA AS-ALOKAL LAA-HUMMA AN TO-SALLE-YA A’LAA MOHAMMADIN WA AHLE-BAIYTE-HI WA AS-ALOKA NAF-HATAN KAREE-MATAN MIN NAFA-HAATE-KA WA FAT-HAN YASEE-RAN WA RIZQAN WAASE-A’N A-LUMMO BEHI SHA-A’SEE WA AQZEE BEHI DAIY-NEE WA ASTA-EE’NO BEHI A’LAA E’YAA-LEE.", "ArabicText1": "يَا مَاجِدُ يَا وَاحِدُ يَا كَرِيْمُ اَتَوَجَّهٗ اِلَيْكَ بِمُحَمَّدٍ نَبِيِّكَ نَبِىِّ الرَّحْمَةِ صَلَّى اللهُ عَلَيْهِ وَآلِهٖ يَا مُحَمَّدُ يَا رَسُوْلَاللهِ اِنِّىْ اَتَوَجَّهٗ بِكَ اِلَى اللهِ رَبِّىْ وَرَبِّكَ وَرَبِّ كُلِّ شَيْ ئٍ وَاَسْئَلُكَ اللّٰهُمَّ اَنْ تُصَلِّىَ عَلٰى مُحَمَّدٍ وَاَهْلِ بَيْتِهٖ وَاَسْئَلُكَ نَفْحَةً كَرِيْمَةً مِنْ نَفَحَاتِكَ وَفَتْحًا يَسِيْرًا وَرِزْقًا وَاسِعًا اَلُمُّ بِهٖ شَعَثِىْ وَاَقْضِىْ بِهٖ دَيْنِىْ وَاَسْتَعِيْنُ بِهٖ عَلٰى عِيَالِىْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": nu