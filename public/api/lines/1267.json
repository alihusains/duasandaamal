[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000261, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O The Foremost Beneficent! O Object of Love! O He Who see every unseen! O He Who is near without being away (from any other thing)! O He Who (always) prevails (but) is never overpowered! O He Whom no one knows how He is, Except He! O He Whose authority no one can challenge! I beseech Thee, O My Allah, In Thy name, well guarded, treasured, concealed, From whom Thou wills, Pure, Purified, Holy, Pure Light, Everliving, Everlasting, Greatest, Light of the Heavens, And Light of the earths, Knower of the unseen, All-Aware, Highest, Sublime, Glorious! Send blessings on Muhammad and on the children of Muhammad.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay neku-kaar, ay milne waale, ay har ghaayab ke dekhne waale, ay woh qareeb jo dur nahi hota aur ay woh ghaalib jo maghloob nahi hota, ay woh jise koi nahi jaanta magar woh khud, ay woh jiski qudrat tak rasaayi (pohonch) nahi hoti. Ay Ma’bood mai sawaal karta hu Tere usi poshida aur mehfooz aur makhfi naam ke zariye jis se Tu chahe paak, paakeeza, muqaddas, noor, kaamil, zinda nighehbaan, azeem, aasmaano ko roshan karne waala aur zameeno ko roshan karne waala, zaahir aur baatin ka jaanne waala, buzurg-waar, buland, azeem keh Tu rehmat farma Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par.", "Urdu": "اے نیکی کروانے والے! اے ملنے والے اے ہر غائب کے دیکھنے والے اے وہ قریب جو دور نہیں ہوتا اور اے وہ غالب جو مغلوب نہیں ہوتا اے وہ ذات جسے تیرے اپنے سوا کوئی نہیں جانتاکہ کیسا ہے اے وہ جس کی قدرت تک رسائی نہیں ہوتی اے معبود! میں تجھ سے سوال کرتا ہوں تیرے اس نام کے واسطے جو پوشیدہ، محفوظ اور مخفی ہے جس سے تو چا ہے۔ تو پاک وپاکیزہ و مقدس، نورِ کامل، زندہ، نگہبان، عظیم، آسمانوں کو روشن کرنے والا اور زمینوں کو روشن کرنے والا ہے ظاہر اور باطن کا جاننے والا بزرگوار، بلند اورعظیم ہے کہ تو محمدؐ و آلِ محمدؐ پر رحمت فرما۔", "RArabic": "YAA BAAARRO YAA WASOOLO YAA SHAAHEDA KULLE GHAAA-EBIN WA YAA QAREEBO GHAYRA BA-E’EDIN WA YAA GHAALEBO GHAYRA MAGHLOOBIN WA YAA MAN LAA YA’LAMO KAYFA HOWA ILLAA HOWA YAA MAN LAA TUBLAGHO QUDRATOHU AS-ALOKAL LAAHUMMA BISMEKAL MAKNOONIL MAKHZOONIL MAKTOOME A’MMAN SHE’TAT TAAHERIL MOTAHHARIL MOQADDASIN NOORIT TAAAM-MIL HAYYIL QAYYOOMIL A’ZEEME NOORIS SAMAAWAATE WA NOORIL ARZEENA A’ALEMIL GHAYBE WASH-SHAHAADATIL KABEERIL MOTA-A’ALIL A’ZEEME SALLE A’LAA MOHAMMADIWN WA AALE MOHAMMAD.", "ArabicText1": "يَابَارُّ يَاوَصُوْلُ يَاشَاهِدَ كُلِّ غَآئِبٍ وَّيَا قَرِيْبُ غَيْرَ بَعِيْدٍ وَّيَا غَالِبُ غَيْرَ مَغْلُوْبٍ وَّيَا مَنْ لَّا يَعْلَمُ كَيْفَ هُوَ اِلَّا هُوَ يَامَنْ لَّا تُبْلَغُ قُدْرَتُهٗ اَسْاَلُكَ۔ اَللّٰهُمَّ بِاسْمِكَ الْمَكْنُوْنِ الْمَخْزُوْنِ الْمَكْتُوْمِ عَمَّنْ شِئْتَ الطَّاهِرِ الْمُطَهَّرِ الْمُقَدَّسِ النُّوْرِ التَّامِّ الْحَيِّ الْقَيُّوْمِ الْعَظِيْمِ نُوْرِ السَّمَاوَاتِ وَنُوْرِ الْاَرَضِيْنَ عَالِمِ الْغَيْبِ وَالشَّهَادَةِ الْكَبِيْرِ الْمُتَعَالِ الْعَظِيْمِ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3":