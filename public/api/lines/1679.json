null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012007, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 4, "EnglishDescription": "Shaikh Tusi has narrated on the authority of Bashir al-Dahhan that Imam Ja’far Sadiq (a) said, “Whoever visits (Imam) Husain (a) and recite <1st Rajab Ziyarat>, Almighty Allah will forgive him all his sins.\"", "GujaratiDescription": null, "RUrduDescription": "Shaikh Tusi ne Bashir al-Dahhan se riwaayat ki hai keh Imam Sadiq (a) ne farmaya, “Jo koi Imam Husain (a) ke rauze par <1st Rajab Ziyarat> padhe, to Allah (swt) uske saare gunah bakhsh dega.”", "UrduDescription": "حضرت امام حسین ؑکی <۱؍رجب کی زیارت> پڑھے، جیسا کہ شیخ ؒنے بشیر دھان سے اور انہوں نے امام جعفر صادق ؑسے روایت کی ہے کہ فرمایا: پہلی رجب کے دن امام حسین ؑ کی زیارت کرنے والے کو خدائے تعالیٰ یقینًا بخش دے گا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSig