[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011118, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, Lord of the seven heavens and the Lord of the great Throne. O our Lord and the Lord of everything, revealer of the Taurat, Injeel and Furqan, splitter of the seed and grain. I seek your refuge from everything, whose control is in your hands. You are the first, there is nothing before You; and You are the last and there is nothing after You. You are the apparent and there is nothing above You; and You are the concealed and there is nothing nearer than You, facilitate the repayment of my debt and make me needless from poverty.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay aasmaano ke aur arsh'e azeem ke Rab, hamare aur har cheez ke Rab, ay Tauraat o Injeel aur Quraan ke naazil karne waale, aur gutliyo’n se daane nikaalne waale, ay saatho’n (7) aasmaano ke Rab, har cheez se jiski zindagi ka ikhteyaar Tere haatho’n mein hai, panah maangti hu, Tu Woh awwal hai jis se pehle kuchh bhi na tha, aur Tu Woh aakhir hai jiske baad bhi koi cheez nahi hai, aur Tu Woh zaahir hai jis se baahar koi cheez nahi, aur Tu Woh baatin hai jiske alaawa koi cheez nahi, mere qarz ko adaa farma aur faqr o mohtaaji se rehaayi ataa farma.", "Urdu": "اے پروردگار! ہمارے اور ہر جیز کے رب، تورات، انجیل اور قرآن کے نازل کرنے والے، شگوفوں کو دانے سے شگافتہ کرنے والے، ہر چوپائے کے شر سے کہ اس کی زندگی تیرے اختیار میں ہے، تیری پناہ کی طلب گار ہوں۔ تو وہ اول ہے جس سے پہلے کوئی چیز نہیں تھی، اور تو وہ آخر ہے جس کے بعد بھی کوئی چیز نہیں ہو گی، اور تو وہ ظاہر ہے جس سے بالاتر کوئی چیز نہیں، اور تو وہ باطن ہے جس کے علاوہ کوئی دوسرا باطن نہیں۔ محمد و آل محمد پر درود بھیج، اور ان پر اور ان کے اہل بیت پر سلام ہو، اور میرے قرض کو ادا فرما، اور مجھے محتاجی سے رہائی عطافرما، اور تمام کاموں کو میرے لئے آسان فرما، اے بہترین رحم کرنے والے۔", "RArabic": "ALLAAHUMMA RABBAS SAMAAWAATIS SAB-E’ WA RABBAL A’RSHIL A’ZEEME. RABBANAA WA RABBA KULLE SHAYIN, MUNZELAT TAWRAATE WAL INJEELE WAL FURQAANE, FAALEQAL HABBE WAN NAWAA, A-O’OZO BEKA MIN KULLE SHAY-IN ANTA AAKHEZUN BE-NAASEYATEHI. ANTAL AWWALO FALAYSA QABLAKA SHAY-UN, WA ANTAL AAKHERO FA-LAYSA BA’DAKA SHAY-UN WA ANTAZ ZAAHERO FA-LAYSA FAWQAKA SHAY-UN, WA ANTAL BAATENO FA-LAYSA DOONAKA SHAY-UN IQZE A’NNEYAD DAYNA, WA AGHNENEE MENAL FAQRE.", "ArabicText1": "اَللّٰہُمَّ رَبَّ السَّمٰوَاتِ السَّبْعِ وَرَبَّ الْعَرْشِ الْعَظِیْمِ۔ رَبَّنَا وَرَبَّ كُلِّ شَيْءٍ، مُنْزِلَ التَّوْرَاةِ وَالْاِنْجِیْلِ وَالْفُرْقَانِ، فَالِقَ الْحَبِّ وَالنَّوٰی، اَعُوْذُ بِكَ مِنْ كُلِّ شَیْءٍ اَنْتَ اٰخِذٌ بِنَاصِیَتِہٖ۔ اَنْتَ الْاَوَّلُ فَلَیْسَ قَبْلَكَ شَيْءٌ، وَاَنْتَ الْآخِرُ فَلَیْسَ بَعْدَكَ شَیْءٌ وَاَنْتَ الظَّاہِرُ فَلَیْسَ فَوْقَكَ شَیْءٌ، وَاَنْتَ الْبَاطِنُ فَلَیْسَ دُوْنَكَ شَیْءٌ اِقْضِ عَنِّی الدَّیْنَ، وَاَغْنِنِیْ مِنَ الْفَقْرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null,