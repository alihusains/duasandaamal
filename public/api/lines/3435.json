[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012624, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Teri rehmat ki wus’at ne mujhe gunaho’n ki maafi maangne ka madad di hai, Teri taraf se mohallat aur narmi ki ummeed ne mujhe Tujh se amaan lene aur maafi maangne ka hausla diya hai, Parwadiqaar! Mere gunah aise hai jinke saamne inteqaam ka chehra hai, meri aisi khataaye’n hai jo mujhe giraft mein lene par tayyaar hai, jinke baais mai Tere adl ke pesh'e nazar sakht azaab ke qaabil hu.", "Urdu": "اے معبود تيری رحمت کی وسعت نے مجھے گناہوں کی معافی مانگنے کا يارا ديا ہے تيری طرف سے مہلت اور نرمی کی اميد نے مجھے تجھ سے امان لينے اور معافی مانگنے کا حوصلہ ديا اے پروردگار ميرے گناه ايسے ہيں جن کے سامنے انتقام کا چہره ہے ميری ايسی خطائيں ہيں جو اچک لينے پر تيار ہيں جن کے باعث ميں تيرے عدل کے پيش نظر سخت عذاب کے قابل ہوں۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اِنَّ الرَّجَاۗءَ لِسَعَةِ رَحْمَتِكَ اَنْطَقَنِىْ بِاِسْتِقَالَتِكَ وَالْاَمَلَ لِاَنَاتِكَ وَرِفْقِكَ شَجَّعَنِىْ عَلٰى طَلَبِ اَمَانِكَ وَعَفْوِكَ وَلِىْ يَا رَبِّ ذُنُوْبٌ قَدْ وَاجَهَتْهَا اَوْجُهُ الْاِنْتِقَامِ وَخَطَايَا قَدْ لَا حَظَتْهَا اَعْيُنُ الْاِصْطِلَامِ وَاسْتَوْجَبْتُ بِهَا عَلٰى عَدْلِكَ اَلِيْمَ الْعَذَابِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012625, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Aur Teri taraf se sakht saza ka mustahaq ban chuka hu, mujhe darr hai keh yeh qabooliyat'e dua mein der karaaengi aur haajate’n poori hone mein rukaawat banegi ba-wajah meri talab karne, faiyda banaane aur mere shauq ko kam karne ke, kyu’n keh gunaho’n aur khataawo’n ke bojh se meri kamar jhuki huwi hai aur mai majboori se unka bojh uthaaye hu, lekin ay Parwardigaar! Jab mai ne khata-kaaro’n se Teri narmi, gunah-gaaro’n ke baare mein Teri maafi o dar-guzar.", "Urdu": "اور تيری طرف سے سخت سزا کا مستحق بن چکا ہوں مجھے ڈر ہے کہ يہ قبوليت دعا ميں دير کرائيں گی اور حاجتيں بر آنے ميں رکاوٹ بنيں گی بوجہ ميری طلب کرنے، فائده بنانے اور ميرے شوق کو کم کرنے کے کيونکہ گناہوں اور خطاؤں کے بوجھ سے ميری کمر جھکی ہوئی ہے اور ميں مجبوری سے ان کا بوجھ اٹھائے ہوئے ہوں ليکن اے پروردگار جب ميں نے خطا کاروں سے تيری نرمی، گنہگاروں کے بارے ميں تيری معافی و در گزر۔", "RArabic": null, "ArabicText1": "وَاسْتَحْقَقْتُ بِاِجْتِرَاحِهَا مُبِيْرَ الْعِقَابِ وَخِفْتُ تَعْوِيْقَهَا لِاِِجَابَتِىْ وَرَدَّهَا اِيَّاىَ عَنْ قَضَاۗءِ حَاجَتِىْ بِاِبْطَالِهَا لِطَلِبَتِىْ وَقَطْعَهَا لِاَسْبَابِ رَغْبَتِىْ مِنْ اَجَلٍ مَا قَدْ اَنْقَضَ ظَهْرِىْ مِنْ ثِقْلِهَا وَبَهَظَنِىْ مِنَ الْاِسْتِقْلَالِ بِحَمْلِهَا ثُمَّ تَرَاجَعْتُ رَبِّ اِلٰى حِلْمِكَ عَنِ الْخَاطِئِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedS