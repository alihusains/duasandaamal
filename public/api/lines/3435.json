ull, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Aur na-farmaano par Teri maher-baani ko dekha to mai Tujh par etemaad ke saath Teri taraf badha aur khud ko Tere aastaane par daal diya, Tujh se apna dard'e dil kehte huwe aisi cheez ka sawaal kiya jiska ahel nahi hu, yaani andeshe mitaaye jaane ka aur woh jiska haqdaar nahi hu yaani gham dur kiye jaane ka Tujh se dar-guzar ka taalib hu mere Mawla mujhe Tujhi par bharosa hai.", "Urdu": "اور نافرمانوں پر تيری مہربانی کو ديکھا تو ميں تجھ پر اعتماد کے ساتھ تيری طرف بڑھا اور خود کو تيرے آستانے پر ڈال ديا تجھ سے اپنا درد دل کہتے ہوئے ايسی چيز کا سوال کيا جس کا اہل نہيں ہوں يعنی انديشے مٹائے جانے کا اور وه جس کا حقدار نہيں ہوں يعنی غم دور کيے جانے کا تجھ سے در گزر کا طالب ہوں ميرے مولا مجھے تجھی پر بھروسہ ہے۔", "RArabic": null, "ArabicText1": "وَعَفْوِكَ عَنِ الْمُذْنِبِيْنَ وَرَحْمَتِكَ لِلْعَاصِيْنَ فَاَقْبَلْتُ بِثِقَتِىْ مُتَوَكِّلًا عَلَيْكَ طَارِحًا نَفْسِىْ بَيْنَ يَدَيْكَ شَاكِيًا بَثِّىْ اِلَيْكَ سَاۗئِلًا مَّالَا اَسْتَوْجِبْهٗ مِنْ تَفْرِيْجِ الْهَمِّ وَلَا اَسْتَحِقُّهٗ مِنْ تَنْفِيْسِ الْغَمِّ مُسْتَقِيْلًا لَكَ اِيَّاىَ وَاثِقًا مَّوْلَاىَ بِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012627, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Pas mujh par ehsaan farma kar kasaaish de mushkilo’n se aasaani ke saath nikaal, apni maher-baani se meri rehnumaayi kar, seedhe raah ki taraf aur apni qudrat se mujhe gumrahi ke raaste se hata le, apni dar-guzar se kaam le kar mujhe dukho’n ki qaid se chhuda de, apni rehmat se meri aseeri ko khatm kar de, apni khushnoodi ataa farma, mujh par apna ehsaan o karam kar.", "Urdu": "اے معبود پس مجھ پر احسان فرما کر کشائش دے مشکلوں سے آسانی کے ساتھ نکال اپنی مہربانی سے ميری رہنمائی کر سيدھی راه کی طرف اور اپنی قدرت سے مجھے گمراہی کے راستے سے ہٹا لے اپنی در گزر سے کام لے کر مجھے دکھوں کی قيد سے چھڑا دے اپنی رحمت سے ميری اسيری کو ختم کر دے اپنی خشنودی عطا فرما مجھ پر اپنا احسان و کرم کر۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ فَامْنُنْ عَلَىَّ بالْفَرَجِ وَتَطَوَّلْ بِسُهُوْلَةِ الْمَخْرَجِ وَادْلُلْنِىْ بِرَاْفَتِكَ عَلٰى سَمْتِ الْمَنْهَجِ وَاَزْلِقْنِىْ بِقُدْرَتِكَ عَنِ الطَّرِيْقِ الْاَعْوَجِ وَخَلِّصْنِىْ مِنْ سِجْنِ الْكَرْبِ بِاِقَالَتِكَ وَاَطْلِقْ اَسْرِىْ بِرَحْمَتِكَ وَطُلْ عَلَىَّ بِرِضْوَانِكَ وَجُدْ عَلَىَّ بِاِحْسَانِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14