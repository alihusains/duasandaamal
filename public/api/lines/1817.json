[{"Id": 1012153, "EnglishTitle": "This Namaz is just a Kaffaara and not the substitute of Qaza Namaz.", "GujaratiTitle": null, "RUrduTitle": "Yeh Namaz sirf Kaffaara hai, na keh Qaza Namaz ki badal.", "UrduTitle": "یہ نماز سرف قضا نمازوں کا کفارہ ہے نہ کے قضا نماز کی بدل۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012154, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "The book Manhaj Da’waat, in which it is quoted from Imam Ali (a.s) whose-so-ever’s namaz has elapsed (qaza) excessively then he should offer this namaz on the last Friday (Jumatul Wida) of the month of Ramazan as atonement. Recite 4 rakat namaz, in the form of (2x2). In each rakat after <Surah Fateha>, recite <Surah Ikhlaas> 25 times, <Aayatul Kursi> once and <Surah Kausar> 15 times and after Namaz recite this dua…", "GujaratiDescription": null, "RUrduDescription": "Kitaab Manhaj Da’waat mein Imam Ali (a.s) se riwaayat hai, keh jis kisi ki waajib namaz qaza hai, usey chahiye keh is namaz ko Mahe Ramazan ke aakhari Juma ke din mein, kaffaare ke taur par adaa kare aur baad mein apni qaza namaz ko bhi baja laaye. Yeh 4 rakat namaz ko (2x2) karke padhe, jiski har rakat mein <Surah Fateha>, ke baad 25 martaba <Surah Ikhlaas>, 1 martaba <Aayatul Kursi> aur 15 martaba <Surah Kausar> padhe. Namaz ke baad is tarah se kahe…", "UrduDescription": "کتاب منحاج دعوات میں امیر المومنینؑ سے روایت ہے کہ انہوں نے ارشاد فرمایا ؛ جس شخص کی نمازیں قضا ہو گئی ہوں اسے چاہیے کہ اس نماز کو ماہِ رمضان کے آخری جمعہ کے دن کفارہ کے تور پر بجا لائے اور بعد میں اپنی قضا نماز بھی ادا کریں۔ یہ ۴ رکعت نماز دو دو کرکے انجام دے، جس کی ہر رکعت میں <سورۂ فاتحہ> کے بعد ۲۵ مرتبہ <سورۂ اخلاص>، ایک مرتبہ <آیت الکرسی> اور ۱۵ مرتبہ <سورۂ کوثر> پڑھے۔ نماز کے بعد کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1015302, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Tu Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma. Nahin hai koi ma’bood siwaaye Allah ke, Muhammad (s.a.w.a) Allah ke Rasool hai aur Ali (a.s) Allah ke Wali hai.", "Urdu": "اے معبود! رحمت نازل فرما حضرت محمدؐ اور انکی آل ؑپر، نہی کوئی معبود سوائے اللہ کے، محمدؐ اللہ کے رسول ہے اور علیؑ اللہ کے ولی ہے۔", "RArabic": "ALLAHUMMA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN, LAA ILAAHA ILLAL LAAHO MOHAMMADUR RASOOLULLA-HE ALIYYUN WALIY-YULLAA-HE.", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمّدٍ لَا اِلٰهَ اِلَّا اللهُ مُحَمَّدٌ رَّسُوْلَ اللهِ عَلِیٌّ وَّلِیُّ اللهِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": n