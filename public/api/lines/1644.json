 null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1011813, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 3, "EnglishDescription": "A 2 rakat Namaz, in each rakat after <Surah Fateha> recite <Surah Ikhlaas> 11 times. The Holy Prophet (s) is reported to have said that whoever offers this prayer at this night and observes fasting the next day, which is the first day in the new year, the new year will be wholly good for him, and he will be saved throughout the year, and if he dies, he will be allowed to enter Paradise.", "GujaratiDescription": null, "RUrduDescription": "2 Rakat namaz, har rakat mein <Surah Fateha> ke baad 11 martaba <Surah Ikhlaas> padhe. Riwaayat mein hai keh Rasool-e-Khuda (s) ne farmaya: “Jo shakhs is raat 2 rakat namaz adaa kare aur uski subh jo keh saal ka pehla din hai roza rakkhe to woh us shakhs ki maanind hoga jo saal bhar tak amaale khair baja laata raha, woh shakhs is saal mehfooz rahega aur agar usey maut aa jaaye to woh behisht (Jannat) mein daakhil ho jaayega.", "UrduDescription": "۲رکعت نماز جس کی ہر رکعت میں <سورۂ فاتحہ> کے بعد گیارہ مرتبہ <سورۂ اخلاص> پڑھے۔ روایت نقل ہوئی ہے کہ رسول خداؐنے فرمایا : جو شخص اس رات میں ۲ رکعت نماز ادا کرے اور اس کی صبح جو سال کا پہلا دن ہے روزہ رکھے تو وہ اس شخص کے مانند ہو گا جو سال بھر تک اعمالِ خیر بجا لاتا رہا،وہ شخص اس سال محفوظ رہے گا اور اگر اسے موت آجائے تو وہ بہشت میں داخل ہو جائے گا،مزید سید ؒنے محرم کا چاند دیکھنے کے وقت کی ایک طویل دعا بھی نقل فرمائی ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "