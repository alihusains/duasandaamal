[{"Id": 1013851, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Mu’awiyah ibn Ammar has reported that he asked Imam Sadiq (a) what to do when visiting Imam Husain (a)’s tomb. The Imam (a) taught him to say the following words…", "GujaratiDescription": null, "RUrduDescription": "Muawiyah ibn Ammar se naql hai keh unho ne Imam Sadiq (a) se arz kiya keh jab mai Imam Husain (a) ki ziyarat karne jaawu to wahan kya padhu? Aap (a) be farmaaya keh jab tum Hazrat ki qabre mubarak par jaawo to wahan yeh ziyarat padho…", "UrduDescription": "معاویہ ابن عمار سے نقل ہوا ہے کہ انہوں نے امام جعفر صادق ؑسے عرض کی :جب میں امام حسینؑ کی زیارت کرنے جاؤں تو وہاں کیا پڑھوں؟ آپ نے فرمایا : جب تم حضرتؑ کی قبر مبارک پر جاؤ تو وہاں یہ زیارت پڑھو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "