Text5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013852, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on you, O Abu Abdullah, may Allah bless you, O Abu Abdullah. May Allah have mercy on you, O Abu Abdullah. May Allah curse the one who killed you and was a partner in spilling your blood and may Allah curse the one who heard about it and remained satisfied with it. I disassociate myself from them in front of Allah.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Abu Abdillah. Khuda aap par durood bheje ay Abu Abdillah. Khuda aap par rehmat farmaaye ay Abu Abdillah. Khuda laanat kare us par jis ne aap ko qatl kiya. Khuda laanat kare us par jo aap ka khoon bahaane mein sharik huwa. Khuda laanat kare us par jo aap ki shahadat ki khabar soon kar khush huwa. Mai Khuda ke saamne us jurm se izhaare be-zaari karta hu.", "Urdu": "آپ پر سلام ہو اے ابو عبداؑﷲ! خدا آپ پر درود بھیجے اے ابو عبداﷲؑ،خدا آپ پر رحمت فرمائے اے ابو عبد اﷲؑ، خدا لعنت کرے اس پر جس نے آپ کو قتل کیا خدا لعنت کرے اس پر جو آپ کا خون بہانے میں شریک ہواخدا لعنت کرے اس پر جو آپ کی شہادت سن کر خوش ہوا میں خدا کے سامنے اس جرم سے اظہار ِبے زاری کرتا ہوں۔", "RArabic": "AS-SALAAMO A’LAIKA YAA ABAA A’BDIL LAAHE SALLAL LAAHO A’LAIKA YAA ABAA A’BDIL LAAHE RAHEMAKAL LAAHO YAA ABAA A’BDIL LAAHE LA-A’NAL LAAHO MAN QATALAKA WA LA-A’NAL LAAHO MAN SHAREKA FEE DAMEKA WA LA-A’NAL LAAHO MAN BALAGAHU ZAALEKA FARAZEYA BEHI ANAA ELAL LAAHE MIN ZAALEKA BAREEE-UN.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَآ اَبَا عَبْدِ اللہِ صَلَّی اللہُ عَلَیْكَ یَا اَبَا عَبْدِ اللہِ رَحِمَكَ اللہُ یَا اَبَا عَبْدِ اللہِ لَعَنَ اللہُ مَنْ قَتَلَكَ وَلَعَنَ اللہُ مَنْ شَرِكَ فِیْ دَمِكَ وَلَعَنَ اللہُ مَنْ بَلَغَهٗ ذٰلِكَ فَرَضِیَ بِهٖ اَنَا اِلَی اللہِ مِنْ ذٰلِكَ بَرِیْءٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicG