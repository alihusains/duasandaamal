[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016070, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I beseech You by Your name which makes possible motion in the darkness of water as it does on land. I beseech You by Your Name which makes Your Arsh (Throne) swing. I beseech You by Your Name which puts in motion the feet of Your angels. I beseech You by Your name by which Moosa (Moses) supplicated to You on Mount Sinai and You granted his supplication and met him with love. I beseech You by Your name by which You granted immunity from sins to Muhammad and completed Your bounty on him, treat me with…", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Mai Tere us naam se sawaal karta hu jiske zariye paani ki sateh par chala jaata hai usi tarah jis tarah hamwaar zameen par chala jaata hai. Mai Tere us ism ke waaste se sawaal karta hu jiske khouf se arsh kaanpata (larazta) hai aur us ism ke waaste se sawaal karta hu jiske khouf se Tere malaayeka ke qadam larazte hai aur us naam ke waaste se jis ke zariye se Janabe Moosa (a.s) ne kohe Toor ke kinaare Tujh se dua ki aur Tu ne unki dua qabool ki, aur apni taraf se un par mohabbat naazil ki. Aur mai Tere us naam ke zariye sawaal karta hu jiske zariye se Tu ne Hazrat Muhammad (s.a.w.a) ko bakhsh diya, unke jo bhi guzishta o aaindah gunah thay aur un par apni neymat tamaam ki, Tu mere saath aisa aisa sulook kar…", "Urdu": "اے پروردگار! میں تیرے اس نام سے سوال کرتا ہوں جن کے ذریعہ پانی کی سطع پر چلا جاتا ہے اسی طرح جس طرح ہموار زمین پر چلا جاتا ہے۔ میں تیرے اس اسم کے واسطہ سے سوال کرتا ہوں جس کے کوف سے عرش کانپتا ہے اور اس اسم کے واسطہ سے سوال کرتا ہوں جس کے خوف سے تیرے ملائکہ کے قدم لرزتے ہیں اور اس نام کے واسطہ سے جس کے ذریعہ سے جناب موسٰیؑ نے کوہ طور کے کنارے تجھ سے دُعا کی اور تونے ان کی دُعا قبول کی، اور اپنی طرف سے ان پر محبت نازل کی، اور میں تیرے اس نام کے ذریعہ سے سوال کرتا ہوں جس کے ذریعہ سے تو نے حضرت محمدؐ کو بخش دیا، انکے جو بھی گزشتہ و ّئندہ گناہ تھے، اور ان پر اپنی نعمت تمام کی، تو میرے ساتھ ایسا ایسا سلوک کر۔۔۔", "RArabic": "ALLAAHUMMA INNEE ASALOKA BISMEKAL LAZEE YUMSHAA BEHI A’LAA TALALIL MAAA-E KAMAA YUMSHEE BEHI A’LAA JODADIL ARZE WA ASALOKA BISMEKAL LAZEE YAHTAZZO LAHU A’RSHAKA WA ASALOKA BISMEKAL LAZEE TAHTAZZO LAHU AQDAAMO MALAAA-EKATEKA WA ASALOKA BISMEKAL LAZEE DA-A’AKA BEHI MOOSAA MIN JAANEBIT TOORE FASTAJABTA LAHU WA ALQAYTA A’LAYHE MAHABBATAM MINKA WA ASALOKA BISMEKAL LAZEE GHAFARTA BEHI LEMOHAMMADIN SALLAL LAAHO A’LAYHE WA AALEHI MAA TAQADDAMA MIN ZAMBEKA WA MAA TA-AKHKHARA WA ATMAMTA A’LAYHE NE’MATAKA AN TAF-A’LA BEE KAZAA WA KAZAA…", "ArabicText1": "اَللّٰہُمَّ اِنِّیْ اَسْئَلُكَ بِاسْمِكَ الَّذِیْ یُمْشٰی بِہٖ عَلٰی ظَلَلِ الْمَآئِ كَمَا یُمْشٰی بِہٖ عَلٰی جُدَدِ الْاَرْضِ۔ وَاَسْئَلُكَ بِاسْمِكَ الَّذِیْ یَہْتَزُّ لَہٗ عَرْشُكَ۔ وَاَسْئَلُكَ بِاسْمِكَ الَّذِیْ تَہْتَزُّ لَہٗ اَقْدَامُ مَلَآئِكَتِكَ۔ وَاَسْئَلُكَ بِاسْمِكَ الَّذِیْ دَعَاكَ بِہٖ مُوْسٰی مِنْ جَانِبِ الطُّوْرِ فَاسْتَجَبْتَ لَہٗ وَاَلْقَیْتَ عَلَیْہِ مَحَبَّۃً مِّنْكَ۔ وَاَسْئَلُكَ بِاسْمِكَ الَّذِیْ غَفَرْتَ بِہٖ لِمُحَمَّدٍ صَلَّی اللہُ عَلَیْہِ وَآلِہٖ مَا تَقَدَّمَ مِنْ ذَنْبِہٖ وَمَا تَاَخَّرَ وَاَتْمَمْتَ عَلَیْہِ نِعْمَتَكَ اَنْ تَفْعَلَ بِیْ كَذَا وَكَذَا۔۔۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage"