[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011699, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah You are the Most-High, the Mighty. Possessor of; the ancient kingdom and great favors and a generous countenance there is no god but You the most-High, the Mighty Guardian of the complete words and the answered prayers remove what has happened to… (name of the person who is sick).", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Tere alaawa koi ma’bood nahi, Tu buland aur azeem-ul-martaba hai, hamesha se qaaem baadshahi waala hai, aur azeem ehsaan waala, aur bohot ziyadah ba-karaamat hai, Tere alaawa koi ma’bood nahi Tu buland aur azeem-ul-martaba hai, mukammal kalemaat ke maalik aur duwaa’o ko qabool karne waala hai fula’n (fula’n ki jagah par mushkil mein phanse huwe shakhs ka naam le) ki mushkilaat ko hal farma.", "Urdu": "اے پروردگار تیرے علاوہ کوئی معبود نہیں تو بلند اور عظیم المرتبہ ہے، ہمیشہ سے قائم بادشاہی والا ہے، اور عظیم احسان والا، اور بہت زیادہ باکرامت ہے، تیرے علاوہ کوئی معبود نہیں تو بلند اور عظیم المرتبہ ہے، مکمل کلمات کے مالک اور دعاؤں کو قبول کرنے والا ہے، فلاں (مشکل میں پھنسے شخص کا نام لیں) کی مشکلات کو حل فرما۔", "RArabic": "ALLAAHUMMA LAA ILAAHA ILLAA ANTAL A’LYYUL A’ZEEMO, ZUS SULTAA-NIL QADEEME, WAL MANNIL A’ZEEME, WAL WAJHIL KAREEKE, LAA ILAAHA ILLAA ANTAL A’LIYYUL A’ZEEMO, WALIYYUL KALEMAA-TIT TAMMAATE, WADDA-A’WAA-TIL MUSTAJA-BAATE, HALLE MAA AS-BAHA BE-FOLAA-NIN.", "ArabicText1": "اَللّٰهُمَّ لَا اِلٰهَ اِلَّا اَنْتَ الْعَلِیُّ الْعَظِیْمُ، ذُو السُّلْطَانِ الْقَدِیْمِ، وَالْمَنِّ الْعَظِیْمِ، وَالْوَجْهِ الْكَرِیْكِ، لَا اِلٰهَ اِلَّا اَنْتَ الْعَلِیُّ الْعَظِیْمُ، وَلِیُّ الْكَلِمَاتِ التَّامَّاتِ، وَالدَّعَوَاتِ الْمُسْتَجَابَاتِ، حَلِّ مَا اَصْبَحَ بِفُلَانٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "Ar