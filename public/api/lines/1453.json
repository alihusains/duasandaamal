[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014119, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon the Messenger of Allah, Muhammad ibn Abdullah, the seal of Prophets. Peace be upon the Commander of the Faithful, the chief of the successors. Peace be on the infallible, rightly guided Imams. Peace be upon the archangels. Peace be upon you, O companion of the trusted Messenger of Allah! Peace be upon you, O friend of the Commander of the Faithful! Peace be on you, O repository of the secrets of the Blessed Masters! Peace be on you, O remnant of Allah from among the preceding pious ones! Peace be upon you, O Aba Abdillah! May divine mercy and His blessings be upon you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho Khuda ke Rasool Hazrat Muhammad bin Abdullah (s.a.w.a) par jo khaatemul Ambiya hai. Salaam ho momino ke Ameer par jo ausiya ke sardaar hai. Salaam ho maasoom Imamo par jo hidaayat dene waale hai. Salaam ho Khuda ke muqarrab farishto’n par. Salaam ho aap par ay Khuda ke ameen Rasool (s.a.w.a) ke sahaabi o saathi. Aap par salaam ho ay Ameerul Momeneen (a.s) ke dost. Aap par salaam ho keh jin ko ba-barkat aqaawo’n ne saahebe israar banaya. Salaam ho aap par ke zamaane maazi ke neku-kaaro’n mein se Khuda ke makhsoos hai. Aap par salaam ho ay Abu Abdillah (a.s). Khuda ki rehmat ho aur uski barkaat ho.", "Urdu": "سلام ہو خدا کے رسول ؐ حضرت محمد ابن عبداللہ پر جو خاتم الانبیاء ہیں سلام ہو مومنوں کے امیر پر جو اوصیاء کے سردار ہیں سلام ہو معصوم اماموں پر جو ہدایت دینے والے ہیں سلام ہو خدا کے مقرب فرشتوں پر سلام ہو آپ پر اے خدا کے امین رسولؐ کے صحابی و ساتھی۔ آپ پر سلام ہو اے امیر المومنینؑ کےدوست آپ پر سلام ہوکہ جن کو بابرکت آقاؤں نے صاحب ِاسرار بنایا سلام ہو آپ پر کہ زمانۂ ماضی کے نیکو کاروں میں سےخدا کے مخصوص ہیں آپ پر سلام ہو اے ابو عبداللہؑ !خدا کی رحمت ہو اور اس کی برکات ہوں۔", "RArabic": "AS-SALAAMO A'LAA RASOOLIL LAAHE MOHAMMAD IBNE A'BDIL LAAHE KHAATAMIN NABIYYEENA AS-SALAAMO A'LA AMEERIL MOMENEENA WA SAYYEDIL WASIYYEENA AS-SALAAMO A'LAL AIMMATIL MASOOMEENAR RAASHEDINA AS-SALAAMO A'LAL MALAEKATIL MOQARRABINA AS-SALAAMO A’LAIKA YA SAAHEBA RASOOLIL LAAHIL AMEENE. AS-SALAAMO A’LAIKA YAA VALIYYA AMEERIL MOMENEENA AS-SALAAMO A’LAIKA YAA MOODA-A' ASRAARIS SAADAATIL MAYAAMEENA AS-SALAAMO A’LAIKA YAA BAQIYATAL LAAHE MENAL BARARATIL MAAZEENA AS-SALAAMO A’LAIKA YAA ABA ABDIL LAAHE WA RAHMATUL LAAHE WA BARAKAATOHU.", "ArabicText1": "اَلسَّلَامُ عَلٰی رَسُوْلِ اللہِ مُحَمَّدِ ابْنِ عَبْدِ اللہِ خَاتَمِ النَّبِیِّیْنَ۔ اَلسَّلَامُ عَلٰی اَمِیْرِ الْمُؤْمِنِیْنَ وَسَیِّدِ الْوَصِیِّیْنَ۔ اَلسَّلَامُ عَلَی الْاَئِمَّۃِ الْمَعْصُوْمِیْنَ الرَّاشِدِیْنَ۔ اَلسَّلَامُ عَلَی الْمَلٰٓئِكَۃِ الْمُقَرَّبِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَا صَاحِبَ رَسُوْلِ اللہِ الْاَمِیْنِ۔ اَلسَّلَامُ عَلَیْكَ یَا وَلِیَّ اَمِیْرِ الْمُؤْمِنِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَا مُوْدَعَ اَسْرَارِ السَّادَاتِ الْمَیَامِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَا بَقِیَّۃَ اللہِ مِنَ الْبَرَرَۃِ الْمَاضِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَا اَبَا عَبْدِ اللہِ وَرَحْمَۃُ اللہِ وَبَرَكَاتُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "Arab