enSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1021066, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Lord! Whatever intention I have for that you are well aware of it, see if it is good in terms of religion, worldly and the hereafter then make it easy for me and if it is bad for me in terms of religion, worldly and the hereafter then reject it whether I feel good or I feel bad, because You know everything and I don’t know anything (and why not) You are the knower of the unseen.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Mai ne jo iraadah kar rakkha hai Tu us se zaroor waaqif hai, dekh agar woh deeni o dunyawi o ukhrawi (aakherat) haisiyat se mere liye beh-tareen hai to sahel o aasaan farma de, aur agar Teri haqeeqat mein nazar se deeni o dunyawi o ukhrawi haisiyat se mere liye bura hai to radd farma de chahe mujhe achchha lagey chahe bura lagey, kyu’n keh Tu sab jaanta hai aur mai kuchh nahin jaanta (aur kyu’n na ho) Tu hi zaati taur par ghaib ka jaanne waala hai.", "Urdu": "خدایا میں نے جو ارادہ کر رکھا ہے تو اس سے ضرور واقف ہے دیکھ اگر وہ دینی و دنیاوی و اخروی حیثیت سے میرے لئے بہترین ہے تو سہل و آسان فرما دے اور اگر تیری حقیقت میں نظر سے دینی و دنیاوی و اخروی حیثیت سے میرے لئے بُرا ہے تو رد فرما دے چاہے مجھے اچھا لگے چاہے بُرا لگے کیونکہ تو سب جانتا ہے اور میں کچھ نہیں جانتا (اور کیوں نہ ہو) تو ہی ذاتی طور پر غیب کا جاننے والا ہے۔", "RArabic": "ALLAAHUMMA QAD HA-MAMTO BE-AMRIN QAD A’LIM-TAHU FA-IN KUNTA TA’LAMO ANNA-HU KHAI-ROON LEE FEE DEENI WA DUNYAA-YA WA AAKHE-RATEE FA-YASSIR-LEE A-IN KUNTA TA’LAMO ANNA-HU SHARROON LEE FEE DEENI WA DUNYAA-YA WA AAKHE-RATEE FA-ASRIF-HO A’NNEE KE-RAHTO ZAALE-KA AW AH-BABTO FA-INNA-KA TA’LAMO WA LAA A’LAMO WA ANTA A’LLAA-MUL GHO-YOOB.", "ArabicText1": "اَللّٰهُمَّ قَدْ هَمَمْتُ بِاَمْرٍ قَدْ عَلِمْتَهٗ فَاِنْ كُنْتَ تَعْلَمُ اَنَّهٗ خَیْرٌ لِّیْ فِیْ دِیْنِیْ وَ دُنْیَایَ وَآخِرَتِیْ فَیَسِّرْلِیْ اَاِنْ كُنْتَ تَعْلَمُ اَنَّهٗ شَرٌّ لِّیْ فِیْ دِیْنِیْ وَدُنْیَایَ وَآخِرَتِیْ فَاَصْرِفْهُ عَنِّیْ كِرَهْتُ ذٰلِكَ اَوْ اَحْبَبْتُ فَاِنَّكَ تَعْلَمُ وَلَآ اَعْلَمُ وَاَنْتَ عَلَّامُ الْغُیُوْبِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "Arabi