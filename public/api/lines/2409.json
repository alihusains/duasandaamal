": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019055, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, include me with the inhabitants of Paradise whose stuffing is blessing and whose constructors are the angels with our Prophet Muhammad, peace of Allah be upon him and his Household, and our father (his father) Abraham, peace be upon him.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mujhe Jannat waalo’n mein se qaraar de jisko barkat ne pur kiya huwa hai, jisko aabaad karne waale farishte aur unke saath hamare nabi Hazrat Muhammad (s.a.w.a) aur hamare baap (unke baap) Ibrahim (a.s) hai.", "Urdu": "اے معبود! مجھے جنت والوں میں سے قرار دے جس کو برکت نے پُر کیا ہوا ہے جس کو آباد کرنے والے فر شتے اور ان کے ساتھ ہمارے نبی حضرت محمد ؐ اور ہمارے باپ (ان کے باپ) ابراہیم  ؑہیں۔", "RArabic": "ALLAAHUMMA AJ-A’LNEE MIN AHLIL JANNA-TIL LATEE HASHWO-HAL BARAKATO WA U’MMAARO-HAL MALAA-E-KATO MA-A’ NABIYYE-NAA MOHAMMADIN SALLAL LAAHO A’LAIHE WA AALE-HI WA ABEE-NAA (ABIHEE) IBRAA-HEEMA A’LAI-HIS SALAAMO.", "ArabicText1": "اَللّٰهُمَّ اَجْعَلْنِيْ مِنْ اَهْلِ الْجَنَّةِ الَّتِيْ حَشْوُهَا الْبَرَكَةُ وَعُمَّارُهَا الْمَلَآئِكَةُ مَعَ نَبِيِّنَا مُحَمَّدٍ صَلَّى اللهُ عَلَيْهِ وَآلِهٖ وَاَبِيْنَا (اَبِیْہِیْ) اِبْرَاهِيْمَ عَلَيْهِ السَّلَامُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10":