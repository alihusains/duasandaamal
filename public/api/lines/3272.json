[{"Id": 1014343, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "It has been narrated by infallible Imams (a) who said: When you decide to go for the Ziyarat of Imam Ali Reza (a), before you begin your journey from home, perform Ghusl and while doing recite…", "GujaratiDescription": null, "RUrduDescription": "Aimma’e Masoomeen (a) se riwaayat hai keh woh farmate hai: Imam Ali Raza (a) ki ziyarat ki garaz se jab tum ghar se nikalo to pehle Ghusl karo aur ghusl karte waqt is dua ko padho…", "UrduDescription": "ائمہ معصومینؑ سے روایت ہے کہ وہ فرماتے ہیں: جب امام علی رضا  ؑ کی زیارت کا ارادہ ہو تو گھر سے سفر ِزیارت پر جانے سے قبل غسل کرے اور غسل کرتے وقت یہ پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign1