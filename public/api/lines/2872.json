[{"Id": 1009972, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "The Holy Prophet (s) established brotherhood between every two members of his companions. Therefore, it is worth doing so with one’s brothers in-faith. One should put his right palm on the right hand of his brother in-faith, and say…", "GujaratiDescription": null, "RUrduDescription": "Nabiye Akram (s) ne is din 2 afraad ke darmiyan bhai-chaargi qaaem ki, to momin ko chahiye keh woh bhi apna daaya haath ki hateli ko apne momin bhai ke daayne haath par rakkhe aur kahe…", "UrduDescription": "ہمارے شیخ ؒصاحب ِمستدرک ا لوسائل نے زادالفردوس سے عقدِ اخوّت کی کیفیت یوں نقل کی ہے کہ اپنا دایاں ہاتھ اپنے برادرِ مومن کے داہنے ہاتھ پر رکھ کر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1010019, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I declare my brotherhood with you for the sake of Allah, I establish friendly terms with you for the sake of Allah, I shake hands with you for the sake of Allah, I promise Allah, His angels, His Books, His Messengers, His Prophets, and the Infallible Imams, peace be upon them, that if I will be an inhabitant of Paradise, allowed to intercede for others, and if I will be allowed Paradise, I will not enter it unless you accompany me therein.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai bhai bana tumhara raahe Khuda mein, mai mukhlis huwa tumhara raahe Khuda mein, mai haath milaaya tum se raahe Khuda mein aur ahed karta hu Khuda se, Uske farishto’n se, Uski kitaabo’n, Uske Rasoolo’n, Uske nabiyyo’n aur Aimma’e Masoomeen (a.s) se is baat ka agar mai ho jaawu, mai behisht (Jannat) waalo’n aur shifa’at karne waalo’n mein aur mujhe Jannat mein daakil hone ka hukm huwa, to nahi daakhil hunga Jannat mein tujhe saath liye bagair.", "Urdu": "میں بھائی بنا تمہارا راہِ خدا میں،میں تمہارا مخلص ہوا راہِ خدا میں میں ہاتھ ملایا تم سے راہِ خدا میں اور عہد کرتا ہوں خدا سے اس کے فرشتوں سے اس کی کتابوں اور اس کے رسولوں اس کے نبیوں سے اور ائمہ معصومین ؑسے اس بات کا کہ اگر میں ہو جاؤں بہشت والوں اور شفاعت حاصل کرنے والوں میں اور مجھے جنت میں داخلے کا حکم ہوا تو جنت میں تجھے ساتھ لئے بغیر نہیں داخل ہوں گا۔", "RArabic": "WA AAKHAYTOKA FIL LAAHE WA SAAFAYTOKA FIL LAAHE WA SAAFAHTOKA FIL LAAHE WA A'AHADTUL LAAHA WA MALAAA-EKATAHU WA KOTOBAHU WA ROSOLAHU WA AMBEYAAA-AHU WAL AIMMATAL MA'SOOMEENA A'LAYHEMUS SALAAMO A'LAA ANNE IN KUNTO MIN AHLIL JANNATE WASH SHAFAA-A'TE WA OZENA LEE BE-AN ADKHOLAL JANNATA LAA ADKHOLOHAA ILLAA WA ANTA MA-E'YA.", "ArabicText1": "اٰخَيْتُكَ فِي اللهِ وَصَافَيْتُكَ فِي اللهِ وَصَافَحْتُكَ فِي اللهِ وَعَاهَدْتُ اللهَ وَمَلَائِكَتَهٗ وَكُتُبَهٗ وَرُسُلَهٗ وَاَنْبِيَاءَهٗ وَالْاَئِمَّةَ الْمَعْصُوْمِيْنَ عَلَيْهِمُ السَّلَامُ عَلٰى اَنِّيْ اِنْ كُنْتُ مِنْ اَهْلِ الْجَنَّةِ وَالشَّفَاعَةِ وَاُذِنَ لِيْ بِاَنْ اَدْخُلَ الْجَنَّةَ لَا اَدْخُلُهَا اِلَّا وَاَنْتَ مَعِيْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicT