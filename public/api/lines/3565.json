O-RO WA AN-SAFA FALAA YAHEE-FO WA KAIY-FA YAJOO-RO WA YAHEE-FO A’LAA MAN SAMMAA-HO BIZ-ZA’FE WA QARA-A’HO BIL-FAQRE WA NABBA-HAHO A’LAL GHENAA-IL AKBARE MIN RIZ-WAANE-HI WA DA-A’A-HO ILAL HAZZIL AW-FARE MIN GHUF-RAANE-HI WA ASHRA-A’ LAHU ILAA ZAALE-KAS SABEE-LA WA AMARA-HU AIY-YALE-JAHAA BE-SAALE-HIL A’MALE LAM YUTTA-HAM BISH-SHAQ-WATE MIN AMARA BIR-RAHMATE WA BIL-JAWRE A’LAL A’BEE-DE BAL AWJA-BAL E’QAABA A’LAA FAASE-QE-HIM WAS-SAWAABA LEMAN NAHAA HUM MAN HOWA ASH-FAQO A’LAIY-HIM MIN UMMIL FOROO-KHE A’LAA FARKHE-HAA TA-A’A-LAL LAAHO A’MMAA YAQOO-LUZ ZAALE-MOONA O’LOO-WAN KABEE-RAN.", "ArabicText1": "اَلْحَمْدُ لِلهِ الَّذِيْ خَلَقَ بَدَاۗئِعَهُ بِقُدْرَتِهٖ وَمَلَكَ الْاُمُوْرَ بِعِزَّتِهٖ وَعَدَلَ فَلَا يَجُوْرُ وَاَنْصَفَ فَلَا يَحِيْفُ وَكَيْفَ يَجُوْرُ وَيَحِيْفُ عَلٰى مَنْ سَمَّاهُ بِالضَّعْفِ وَقَرَعَهُ بِالْفَقْرِ وَنَبَّهَهُ عَلَى الْغِنَاۗءِ الْاَكْبَرِ مِنْ رِضْوَانِهٖ وَدَعَاهُ اِلَى الْحَظِّ الْاَوْفَرِ مِنْ غُفْرَانِهٖ وَاَشْرَعَ لَهٗ اِلٰى ذٰلِكَ السَّبِيْلَ وَاَمَرَهٗ اَن يَّلِجَهَا بِصَالِحِ الْعَمَلِ لَمْ يُتَّهَمْ بِالشَّقْوَةِ مَنْ اَمَرَ بِالرَّحْمَةِ وَبِالْجَوْرِ عَلَى الْعَبِيْدِ بَلْ اَوْجَبَ الْعِقَابَ عَلٰى فَاسِقِهِمْ وَالثَّوَابَ لِمَنْ نَهَاهُمْ مَنْ هُوَ اَشْفَقُ عَلَيْهِمْ مِنْ اُمِّ الْفُرُوْخِ عَلٰى فَرْخِهَا تَعَالَى اللهُ عَمَّا يَقُوْلُ الظَّالِمُوْنَ عُلُوًّا كَبِيْرًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null