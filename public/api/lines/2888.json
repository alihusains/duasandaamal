[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002277, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I pray the forgiveness of Allah; there is no god but He, the Ever-living, the Self-Subsisting, and I repent to Him as a slave who is submissive, acquiescent, and poor, not controlling for himself any harm or profit, or benefit or damage and not controlling death nor life, nor raising (the dead) to life. May Allah send peace upon Muhammad and his Household; the pure, the immaculate, the choicest, and the pious; and may He spread thorough blessings over them.", "Gujarati": null, "RGujarati": null, "RUrdu": "Us Khuda se taalib’e maghferat hu jiske siwa koi ma’bood nahi jo zindah o paayenda hai mai uske huzoor aise bande ki tarah tauba karta hu jo zaleel, mohtaj aur be-chaara hai. Jo apne kaar o baar aur nafa o nuqsaan ka maalik nahi. Apni maut, zindagi aur Qayamat ke din apne hashr o nashr par kuchh ikhteyaar nahi rakhta aur Khuda ki rehmat ho Muhammad (s.a.w.a) aur unki paak o paakeeza aur nek o paak Aal (a.s) par aur salaam ho jo salaam ka haq hai.", "Urdu": "اس خدا سے طالب ِمغفرت ہوں جس کے سوا کوئی معبود نہیں جو زندہ وپائندہ ہے میں اس کے حضور ایسے بندے کی طرح توبہ کرتا ہوں جو ذلیل، محتاج اور بے چارہ ہے جو اپنے کاروبار، دفاع اور نفع ونقصان کا مالک نہیں اپنی موت زندگی اور قیامت کے دن اپنے حشر و نشر پر کچھ اختیار نہیں رکھتا اور محمدؐ اور ان کی پاک و پاکیزہ اور نیک و پاک باز آل پر خدا کی رحمت اور سلام ہو جس طرح ان پر سلام کا حق ہے۔", "RArabic": "AS-TAGH-FERUL LAAHAL LAZEE LAA ILAAHA ILLAA HOWAL HAIYYUL QAIYYUMO WA ATOOBO ILAIHE TAWBA-TA A’BDIN KHAAZE-I’N MISKEE-NIN MUSTAKEE-NIN LAA YASTA-TEE-O’ LE NAFSE-HI SAR-FAN WA LAA NAF-A’N WA LAA ZARRAN WA LAA HAYAA-TAN WA LAA MAWTAN WA LAA NO-SHOORAN WA SALLAL LAAHO A’LAA MOHAMMADIW WA I’TRATE-HIT TAIYYE-BEE-NAT TAAHE-REE-NAL AKHYAA-RIL ABRAARE WA SALLAMA TASLEE-MAN.", "ArabicText1": "اَسْتَغْفِرُ اللهَ الَّذِيْ لَا اِلٰهَ اِلَّا هُوَ الْحَيُّ الْقَيُّوْمُ وَاَتُوْبُ اِلَيْهِ تَوْبَةَ عَبْدٍ خَاضِعٍ مِّسْكِيْنٍ مُّسْتَكِيْنٍ لَّا يَسْتَطِيْعُ لِنَفْسِهٖ صَرْفًا وَلَا عَدْلًا وَلَا نَفْعًا وَلَا ضَرًّا وَلَا حَيَاةً وَّلَا مَوْتًا وَلَا نُشُوْرًا وَصَلَّى اللهُ عَلٰى مُحَمَّدٍ وَّعِتْرَتِهِ الطَّيِّبِيْنَ الطَّاهِرِيْنَ الْاَخْيَارِ الْاَبْرَارِ وَسَلَّمَ تَسْلِيْمًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "Arab