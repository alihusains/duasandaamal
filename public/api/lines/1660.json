[{"Id": 1011967, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Birthday of Prophet Muhammad (s) (1st Aamulfil ie. The Elephants Year).", "GujaratiDescription": null, "RUrduDescription": "Hazrat Muhammad (s) ki wilaadat (1st Aamulfil, yaani Haathiyo’n waala saal).", "UrduDescription": "علماء شیعہ امامیہ میں یہ قول مشہور و معروف ہے کہ یہ رسول اللہ ؐکا یوم ولادت ہے اور ان کے درمیان یہ بات بھی مسلّم ہے کہ آپ کی ولادت باسعادت روزِ جمعہ طلوعِ فجر کے وقت اپنے گھر میں ہوئی جب کہ عام الفیل کا پہلا سال اور نوشیرواں عادل کا زمانۂ حکومت تھا۔ آج کے دن مسلمانوں کو خاص طور پر خوشی منانی چاہیے،وہ اس دن کی بہت تعظیم کریں،صدقہ و خیرات دیں اور مومنین کو خوش کریں۔نیز ائمۂ طاہرینؑ کے روضہ ہائے مقدسہ کی زیارت کریں سیدؒ نے کتاب اقبال میں آج کے دن کی تعظیم و تکریم کا تفصیلی تذکرہ کیا اور فرمایا ہے : عیسائیوں اور مسلمانوں کا ایک گروہ حضرت عیسٰی ؑکی ولادت کے دن کی بہت یاد کرتے ہیں، لیکن مجھے ان پر تعجب ہوتا ہے کہ کیوں وہ آنحضرتؐ کے یوم ِولادت کی تعظیم نہیں کرتے جو حضرت عیسٰی ؑکی نسبت بلند مرتبہ ہیں اور ان سے بڑھ کر فضیلت رکھتے ہیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGr