[{"Id": 1020287, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "This Ziyarat has been narrated by Sayed Ibn Taaoos (r) and Ibne Mashhadi (r) (author of al-Mazaar al-Kabeer). They say: It has been narrated by infallible Imams (a): “Whenever you travel for pilgrimage then while making the intention say…", "GujaratiDescription": null, "RUrduDescription": "Yeh ziyarat Sayed Ibne Taaoos (r) aur Ibne Mashhadi (r) (jinho ne kitaab Mazaar Al-Kabeer likkhi hai). Farmate hai: Yeh ziyarat Aimma’e Masoomeen (a) se riwaayat ki gai hai: Jab bhi tum ziyarat par jaawo to niyyat karte huwe is tarah se kaho…", "UrduDescription": "یہ زیارت سید ابن طاؤس اور ابن مشہدی (جنہوں نے کتاب مزار الکبیر لکھی ہے) فرماتے ہیں: یہ زیارت ائمہ معصومینؑ سے روایت کی گئی ہے: جب بھی تم زیارت پر جاؤ تو نیت کرتے ہوئے اس طرح سے کہو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "Ar