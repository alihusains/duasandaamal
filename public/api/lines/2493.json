abicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1020290, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I entrust You with my religion, myself and all my comrades. O Allah! You are the companion in the journey and the representative in my family, wealth and progeny. O Allah! I seek refuge in You from bad companionship and unsuccessful return. O Allah! Make smooth for us grief which is far but we imagine it to be near and make easy on us plenty of our travel (in day and night), verily You are powerful over all thing.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": "ALLAAHUMMA INNEE ASTAWDE-O’KA DEENEE WA NAFSEE WA JAMEE-A’ HOZAANATEE. ALLAAHUMMA ANTAS SAAHEBO FIS SAFARE WAL KHALEEFATO FIL AHLE WAL MAALE WAL WALADE. ALLAAHUMMA INNEE A-O’OZO BEKA MIN SOOO-IS SOHBATE WA IKHFAAQIL AWBATE. ALLAAHUMMA SAHHIL LANAA HUZNA MAA NATA-GHAWWALO WA YASSIR A’LAYNAA MUSTAGHZARA MAA NAROOHO WA NAGHTOO LAHU INNAKA A’LAA KULLE SHAY-IN QADEER.", "ArabicText1": "اَللّٰهُمَّ اِنِّيْ اَسْتَوْدِعُكَ دِيْنِيْ وَنَفْسِيْ وَجَمِيْعَ حُزَانَتِي۔ اَللّٰهُمَّ اَنْتَ الصَّاحِبُ فِيْ السَّفَرِ وَالْخَلِيْفَةُ فِيْ الْاَهْلِ وَالْمَالِ وَالْوَلَدِ۔ اَللّٰهُمَّ اِنِّيْ اَعُوْذُ بِكَ مِنْ سُوْٓءِ الصُّحْبَةِ وَاِخْفَاقِ الْاَوْبَةِ۔ اَللّٰهُمَّ سَهِّلْ لَنَا حُزْنَ مَا نَتَغَوَّلُ وَيَسِّرْ عَلَيْنَا مُسْتَغْزَرَ مَا نَرُوْحُ وَنَغْدُوْ لَهٗ اِنَّكَ عَلٰى‏ كُلِّ شَيْءٍ قَدِيرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null,