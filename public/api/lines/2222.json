ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016198, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I ask You for the sake of Muhammad al-Mustafa and his longing for me, for the sake of my husband, Ali al Murtadha and his grief for me, for the sake of Hasan al-Mujtaba and his weeping over me, for the sake of Husayn al-Shaheed and his sadness over me, for the sake of my daughters, the two Fatimahs and their sorrow over me that You have mercy and forgive the sinners of the Ummah of Muhammad and make them enter Heaven. Surely You are the most Generous of those who are asked and the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar! Muhammad'e Mustafa (s.a.w.a) aur unke mujh se ishteyaaq (chaahat) aur mohabbat ke waaste, aur mere shauhar Ali'e Murtaza (a.s) aur unke gham khaane ka waasta, Hasan'e Mujtaba (a.s) ke mujh par girya karne ka waasta, Husain'e Shaheed (a.s) aur unke ghamgeen hone ka waasta aur mere farzando’n aur unke mujh par hasrat karne ka waasta, keh Paighambar'e Islaam (s.a.w.a) ki ummat ke gunaho’n se dar-guzar farma, aur un par rahem farma, aur unko daakhil'e Behisht (Jannat) farma, aur meri betiyo’n ka waasta aur unka mujh par hasrat (gham-zadah) hone ka waasta keh Paighambar'e Islaam (s.a.w.a) ki ummat ke gunah-gaaro’n ki maghferat farma aur un par rahem aur unko Jannat mein daakhil farma, kyu’n keh Tu sab se bada maswool (zimmedaar) aur beh-tareen rahem karne waala hai.", "Urdu": "پروردگار! محمد مصطفےٰ اور ان کے مجھ سے اشتیاق اور پیار کے واسطے اورمیرے شوہر علی المرتضےٰ اور ان کے غم کھانے کا واسطہ حسن مجتبیٰ کے مجھ پر گریہ کرنے کا واسطہ،حسین شہید اور ان کے غمگین ہونے کا واسطہ اور میرے فرزندوں اور ان کے مجھ پر حسرت کرنے کا واسطہ کہ پیغمبر اسلامؐ کی امت کے گناہوں سے درگذر فرما، اور ان پر رحم فرما، اور ان کو داخل بہشت فرما، اور میری بیٹیوں کا واسطہ اور ان کے پرحسرت ہونے کا واسطہ کہ پیغمبر اسلامؐ کی امت کے گناہگاروں کی مغفرت فرما اور ان پر رحم کر اور ان کو جنت میں داخل فرما، کیونکہ توسب سے بڑا مسئول اور بہترین رحم کرنے والا ہے۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA BE-MOHAMMADENIL MUSTAFAA WA SHAWQEHI ELAYYA, WA BE-A’LIYYENIL MURTAZAA WA HUZNEHI A’LAYYA, WA BIL-HASANIL MUJTABAA WA BOKAA-EHI A’LAYYA, WA BIL-HUSAYNISH SHAHEEDE WA KA-AA-BETEHI A’LAYYA, WA BE-BANAATEYAL FAATEMIYYATE WA TAHASSOREHINNA A’LAYYA, AN TARHAMA WA TAGHFERA LIL-O’SAATE MIN UMMATE MOHAMMADIN, WA TUD-KHELAHOMUL JANNATA, INNAKA AKRAMUL MAS-OOLEENA WA ARHAMAR RAAHEMEEN.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَسْئَلُكَ بِمُحَمَّدِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": " نِ", "ArabicText2": "الْمُصْطَفٰی وَشَوْقِهٖ اِلَیَّ، وَبِعَلِیِّ", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": " نِ", "ArabicText3": "الْمُرْتَضٰی وَحُزْنِهٖ عَلَیَّ، وَبِالْحَسَنِ الْمُجْتَبٰی وَبُكَاۗئِهٖ عَلَیَّ، وَبِالْحُسَیْنِ الشَّهِیْدِ وَكَآبَتِهٖ عَلَیَّ، وَبِبَنَاتِیَ الْفَاطِمِیَّاتِ وَتَحَسُّرِهِنَّ عَلَیَّ اِنْ تَرْحَمَ وَتَغْفِرَ لِلْعُصَاۃِ مِنْ اُمَّۃِ مُحَمَّدٍ، وَتُدْخِلُهُمُ الْجَنَّۃَ، اِنَّكَ اَكْرَمُ الْمَسْؤُوْلِیْنَ، وَاَرْحَمُ الرَّاحِمِیْنَ۔", "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "Ara