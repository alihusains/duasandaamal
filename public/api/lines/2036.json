[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018595, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And how many acts of Allah are concealed. Whose understanding is above the Heavens and the earth. And so many easiness have come after the troubles. By which the sorrow from the sorrowful heart diseases. So many things, which brings grief in the morning but by evening it turns into joy. If any time the situation troubles you, then put your trust on the Lord, the One, the Unique. Take the help of the Prophet because all the problems by his intercession becomes easy. Whenever big calamities befall you do not become restless, as many of Allah's action are concealed. O Allah! My Lord always send blessings on the people of Mecca and the guide. O Ali Murtaza one glance of mercy. I have come to you afraid of my position. O my master! Save me from the things, which I am scared of. O Ali! O Ali! O Ali.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur Allah ke kitne hi aise posheedah karam hai, jin ki baareekiya’n aadmiyo’n ke zaheen ki samajh se baala (baahar) hai, aur kitni aasaaniya’n hai jo dush-waariyo’n ke baad aayi, jin ki wajah se dukhi dil ki takleefe’n dur ho gayi, aur kitni hi aisi baate’n hai, jo subh ko dukh deti hai, magar shaam ke waqt musarrate (khushi) laati hai. Agar kisi din haalaat tumhe’n pareshaan wa tang kare, to waaheed o yekta aur maalik’e bulandi par bharosa karo. Nabi (s.a.w.a) se sahaara lo, kyu’n keh har museebat nabi ke waseele ke baad halki ho jaati hai. Jab koi badi bala aaye to be-qaraari na dekha, kyu’n keh Allah ke bohot se karam na-deed (nahin dikhaayi dene waale) bhi hai. Allah Tera Parwardigaar har waqt Nabi’e Makki aur haadi’e bar-haq par rehmat naazil kare. Ay Ali’e Murtaza ek nigah’e karam, apne dushman se sehma (dara) huwa aaya hu. Ay jis se darr raha hu bachaaye? Ya Ali ya Ali ya Ali.", "Urdu": "اور اللہ کے کتنے ہی ایسے پوشیدہ کرم ہیں جن کی باریکیاں ذہین آدمیوں کی سمج سے بالا ہیں، اور کتنی آسانیاں ہیں جو دشواریوں کے بعد آئیں، جن کی وجہ سے دکھی دل کی تکلیفیں دور ہو گئیں،  اور کتنی ہی ایسی باتیں ہیں جو صبح کو دکھ دیتی ہیں مگر شام کے وقت مسرّتیں لاتی ہیں۔ اگر کسی دن حالات تمہیں پریشان و تنگ کریں تو واحد و یکتا اور مالک بلندی پر بھروسہ کروں۔ نبیؐ سے سہارا لو، کیونکہ ہر مصیبت نبی کے وسیلے کے بعد ہلکی ہو جاتی ہے۔ جب کوئی بڑی بلا آئے تو بے قراری نہ دکھا، کیونکہ اللہ کے بہت سے کرم نادید بھی ہیں۔ اللہ تیرا پروردگار ہر وقت نبی مکی اور ہادی برحق پر رحمت نازل کرے، اے علی مرتضٰیؑ ایک نگاہ کرم، اپنے دشمن سے سہما ہوا آیا ہوں، اے جس سے ڈر رہا ہوں بچائے، یا علی، یا علی، یا علی۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "وَكَمْ لِلهِ مِنْ لُطْفٍ خَفِیِّ، یَدُقُّ خَفَاهُ عَنْ فَهْمِ الزَّكِیِّ، وَكَمْ یُسْرٍ اَتٰی مِنْ بَعْدِ عُسْرٍ، فَفَرَّجَ كُرْبَۃَ الْقَلْبِ الشَّجِیِّ، وَكَمْ اَمْرٍ تُسَاۗئُ بِهٖ سَبَاحًا، وَتَاتِیْكَ الْمَسَرَّۃُ بِالْعَشِیِّ، اِذَا ضَاقَتْ بِكَ الْاَحْوَالُ یَوْمًا، فَثِقْ بِلْوَاحِدِ الْفَرْدِ الْعَلِیِّ، تَوَسَّلْ بِالنَّبِیِّ فَكُلُّ خَطْبٍ، یَهُوْنُ اِذَا تُوُسِّلَ بَالنَّبِیِّ، وَلَا تَجْزَعْ اِذَا مَا نَابَ خَطْبٌ، فَكَمْ لِلهِ مِنْ لُطْفٍ خَفِیِّ، وَصَلَّی اللهُ رَبِّیْ كُلَّ حِیْنٍ، عَلَی الْهَادِی النَّبَیِّ الْاَبَطَهِیِّ، یَا عَلِیُّ الْمُرْتَضٰی اُنْظُرْ اِلَیَّ، قَدْ آتَیْتُ خَاۗئِفًا مِمَّا لَدَیَّ، یَا وَلِیُّ نَجِّنِیْ مِمَّا اَخَافُ، یَا عَلِیُّ یَا عَلِیُّ یَا عَلِیُّ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "Ar