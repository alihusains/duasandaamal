[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011658, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my Chief, You are the one who is truly merciful. O my master, You are the one who bestows gifts. O my Chief, You are the noble. O my master, You are forgiving. O my Chief, You are the forbearing. O my master, You are the giver. O my Chief, You are the powerful. O my master, You are the Near. O my Chief, You are the One. O my master, You are the forceful. O my Chief, You are the needless. O my master, You are the powerful. Bless Muhammad and his progeny, forgive me and have mercy on me and overlook my mistakes. Indeed You are the most majestic and the most great.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay mere Aaqa Tu hi haqeeqi maher-baan hai, ay mere Maula Tu hi ehsaan karne waala hai, ay Aaqa Tu hi kareem hai, ay Maula Tu hi bakhsh ne waala hai, ay Aaqa Tu hi burdbaar hai, ay Maula Tu hi bohot ataa karne waala hai, ay Aaqa Tu hi izzat waala hai, ay Aaqa Tu hi nazdik hai. Ay Aaqa bas Tu hi yakta hai, ay Maula Tu hi to ghaalib hai, ay Aaqa Tu be-neyaaz hai, ay Maula Tu hi izzat-daar hai. Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur mujh se dar-guzar farma, Tu hi sab se buzurg o azeem hai.", "Urdu": "اے میرے آقا تو ہی حقیقی مہربان ہے، اے میرے مولا تو ہی احسان کرنے والا ہے، اے آقا تو ہی کریم ہے، اے مولا تو ہی بخش نے والا ہے، اے آقا تو ہی بردبار ہے، اے مولا تو ہی بہت عطا کرنے والا ہے، اے آقا تو ہی عزّت والا ہے، اے آقا تو ہی نزدیک ہے۔ اے آقا بس تو ہی یکتا ہے، اے مولا تو ہی غالب ہے، اے آقا تو بے نیاز ہے، اے مولا تو ہی عزّت دار ہے، محمدؐ اور آل محمدؑ پر رحمت نازل فرما اور مجھ سے درگزر فرم، تو ہی سب سے بزرگ و عظیم ہے۔", "RArabic": "AL-HANNAA-NO ANTA SAYYADIL MANNAA-NO ANTA MAWLAA-YAL KAREEMO ANTA SAYYEDIL GHAFOORO ANTA MAWLAA-YAL HALEEMO ANTA SAYYEDIL WAHHAA-BO ANTA MAWLAA-YAL A’ZEEZO ANTA SAYYEDIL QAREEBO ANTA MAWLAA-YAL WAAHE-DO ANTA SAYYEDIL QAAHE-RO ANTA MAWLAA-YAS SAMADO ANTA SAYYEDIL A’ZEEZO ANTA MAWLAA-YA SALLE A’LAA MOHAMMADIW WA AALE-HI WAGH-FIR-LEE WAR-HAM-NEE WA TAJAA-WAZ A’NNEE INNA-KA ANTAL AJAL-LUL A’ZAM.", "ArabicText1": "اَلْحَنَّانُ اَنْتَ سَیَّدِی الْمَنَّانُ اَنْتَ مَوْلَایَ الْکَرِیْمُ اَنْتَ سَیِّدِی الْغَفُوْرُاَنْتَ مَوْلَایَ الْحَلِیْمُ اَنْتَ سَیِّدِی الْوَھَّابُ اَنْتَ مَوْلَایَ الْعَزِیْزُ اَنْتَ سَیِّدِی الْقَرِیْبُ اَنْتَ مَوْلَایَ الْوَاحِدُ اَنْتَ سَیِّدِی الْقَاہِرُ اَنْتَ مَوْلَایَ الصَّمَدُ اَنْتَ سَیِّدِی الْعَزِیْزُ اَنْتَ مَوْلَایَ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِہٖ وَاغْفِرْلِیْ وَارْحَمْنِیْ وَتَجَاوَزْ عَنِّیْ اِنَّکَ اَنْتَ الْاَجَلُّ الْاَعْظَمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "Ar