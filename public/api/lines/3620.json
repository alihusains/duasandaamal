[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016084, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! forgive all my sins whenever I may have committed them and if I repeat them, forgive me again, for You are Forgiving and Merciful. O Allah! deal with me as it befits You and if You would do so, You would have mercy on me. You are free from any need to punish me but I am in need of Your mercy, have mercy on me.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay mere Allah! Mere har gunah ko bakhsh de jisko mai ne zaroor kiya hai to agar mai uske baad gunah ki taraf lautu to Tu dubaara maghferat farma kyu’n keh Tu yaqeenan ziyadah bakhshne waala aur rahem karne waala hai. Khudaaya! Mere saath woh sulook kar jiska Tu ahel hai kyu’n keh agar woh sulook karega jiska Tu ahel hai to mujh par rahem karega, aur agar Tu mujh ko azaab dega to Tu azaab dene se be-neyaaz hai aur mai Teri rehmat ka mohtaaj hu. Pas ay woh Khuda jiski rehmat ka mai mohtaaj hu mujh par rahem farma.", "Urdu": "اے میرے اللہ! میرے ہر گناہ کو بخش دے جس کو میں نے ضرور کیا ہے، تو اگر میں اس کے بعد گناہ کی طرف لوٹوں تو تو دوبارہ مغفرت فرما کیونکہ تو یقینًا زیادہ بخشنے والا اور رحم کرنے والا ہے۔ خدایا! میرے ساتھ وہ سلوک کر جس کا تو اہل ہےکیونکہ اگر وہ سلوک کرے گا جس کا تو اہل ہے تو مجھ پر رحم کرے گا، اور اگر تو مجھ کو عذاب دے گا تو تو عذاب دینے سے بے نیاز اور میں تیری رحمت کا محتاج ہوں، پس اے وہ خدا جس کی رحمت کا میں محتاج ہوں مجھ پر رحم فرما۔", "RArabic": "ALLAAHUMMAGH FIR LEE KULLA ZANBIN AZNABTOHU QATTUN FA-IN U’DTA FA-U’D A’LAYYA BIL-MAGHFERATE FA-INNAKA ANTAL GHAFOORUR RAHEEMO ALLAAHUMMAF A’L BEE MAA ANTA AHLOHU FA-INNAKA AN TAF-A’L BEE MAA ANTA AHLOHU TARHAMNEE WA IN TO-A’ZZIBNEE FA-ANTA GHANIYYUN A’N A’ZAABEE WA ANAA MOHTAAJUN ELAA RAHMATEKA FAYAA MAN ANAA MOHTAAJUN ELAA RAHMATEHI IRHAMNEE.", "ArabicText1": "اَللّٰہُمَّ اغْفِرْ لِیْ كُلَّ ذَنْۢبٍ اَذْنَبْتُہٗ قَطُّ فَاِنْ عُدْتُ فَعُدْ عَلَیَّ بِالْمَغْفِرَۃِ فَاِنَّكَ اَنْتَ الْغَفُوْرُ الرَّحِیْمُ۔ اَللّٰہُمَّ افْعَلْ بِیْ مَا اَنْتَ اَھْلُہٗ فَاِنَّكَ اِنْ تَفْعَلْ بِیْ مَا اَنْتَ اَھْلُہٗ تَرْحَمْنِیْ وَاِنْ تُعَذِّبْنِیْ فَاَنْتَ غَنِیٌّ عَنْ عَذَابِیْ وَاَنَا مُحَتَاجٌ اِلٰی رَحْمَتِكَ فَیَا مَنْ اَنَا مُحْتَاجٌ اِلٰی رَحْمَتِہٖ اِرْحَمْنِیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016085, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! do not deal with me as I deserve, for if You do so, You will punish me without being unjust to me. I fear Your justice but have no fear of injustice from You. O One who is absolutely Just, have mercy on me.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Mere saath woh sulook na kar jiska mai ahel hu kyu’n keh agar Tu woh sulook karega jiska mai ahel hu to Tu mujh par azaab karega lekin phir bhi woh Tera zulm na hoga. Khudaaya! Mai aisa hogaya hu ke Tere adl se darta hu, lekin Tere zulm se nahi darta, to ay woh Khuda jo aadil hai, jo zulm nahi karta, mere upar rahem farma.", "Urdu": "خدایا! میرے ساتھ وہ سلوک نہ کر جس کا میں اہل ہوں کیونکہ اگر تو وہ سلوک کرے گا جس کا میں اہل ہوں تو تو مجھ پر عذاب کرے گا لیکن پھر بھی وہ تیرا ظلم نہ ہوگا۔ خدایا! میں ایسا ہوگیا ہوں کہ تیرے عدل سے ڈرتا ہوں لیکن تیرے ظلم سے نہیں ڈرتا، تو اے وہ خدا جو عادل ہے، جو ظلم نہیں کرتا، میرے اوپر رحم فرما۔", "RArabic": "ALLAAHUMMA LAA TAF-A’L FEE MAA ANAA AHLOHU FA-INNAKA IN TAF-A’LA BEE MAA ANAA AHLOHU TOA’ZZIBNEE WA LAM TAZLIMNEE ASBAHTO ATTAQEE A’DLAKA WA LAA AKHAAFO JAWRAKA FAYAA MAN HOWA A’DLUN LAA YAJOORO IRHAMNEE.", "ArabicText1": "اَللّٰہُمَّ لَا تَفْعَلْ بِیْ مَا اَنَا اَھْلُہٗ فَاِنَّكَ اِنْ تَفْعَلْ بِیْ مَا اَنَا اَھْلُہٗ تُعَذِّبْنِیْ وَلَمْ تَظْلِمْنِیْ اَصْبَحْتُ اَتَّقِیْ عَدْلَكَ وَلَا اَخَافُ جَوْرَكَ فَیَا مَنْ ہُوَ عَدْلٌ لَا یَجُوْرُ اِرْحَمْنِیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "Ar