[{"Id": 1014856, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Sayyid Ali ibn Fazlullah Husaini Rawandi has mentioned the following incident in his book entitled Nathr La’ali: When a man complained to Prophet Jesus the son of Mary, peace be upon them, about the debts, Prophet Jesus (a) taught him to say this supplicatory prayer, adding, “If your debts are filling the globe, Almighty Allah will certainly help you to settle them after you say this supplicatory prayer constantly.” This is the supplicatory prayer involved…", "GujaratiDescription": null, "RUrduDescription": "Sayyed Saeed Ali bin Fazlullah Husain Raawandi ki kitaab Nasar La’ali se manqool hai keh ek shakhs ne Hazrat Eesa (a) se apne maqrooz (qarz-daar) hone ki shikaayat ki to Aan Janaab (a) ne farmaaya keh yeh dua padha karo…", "UrduDescription": "سید سعید علی ابن فضل اﷲحسینی راوندی کی کتاب ’’نثرا للئا لی ‘‘ سے منقول ہے کہ ایک شخص نے حضرت عیسیٰ ؑ سے اپنے مقروض ہونے کی شکایت کی تو انھوں نے فرمایا کہ یہ دعا پڑھا کرو۔ پس اگر زمین کے ہم وزن سونے جتنا قرضہ بھی ہو تو خدا ئے تعالی ٰاسے ادا کردے گا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "Arab