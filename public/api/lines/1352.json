, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000595, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, bless Muhammad and his Household and attend to me with Thy best attending in my neighbours and friends who recognize our right and war against our enemies!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Hazrat Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma aur meri is baare mein behtareen madad farma, keh mai apne ham-saayo’n aur un dosto’n ke huqooq ka khayaal rakkhu, jo hamare haq ko pehchaanne waale aur hamare dushmano ke mukhaalif hai.", "Urdu": "اے اللہ! محمد اوران کی آل پر رحمت نازل فرما۔ اور میری اس سلسلہ میں بہترین نصرت فرما کہ میں اپنے ہمسایوں اوران دوستوں کے حقوق کا لحاظ رکھوں جو ہمارے حق کے پہچاننے والے اورہمارے دشمنوں کے مخالف ہیں۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِهٖ وَتَوَلَّنِيْ فِيْ جِيْرَانِيْ وَمَوَالِيَّ الْعَارِفِيْنَ بِحَقِّنَا وَالْمُنَابِذِيْنَ لِاَعْدَاۗئِنَا بِاَفْضَلِ وَلَايَتِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001780, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Give (my neighbours and friends) success in performing Thy prescriptions and taking on the beauties of Thy courtesy through acting gently with their weak, remedying their lacks, visiting their sick, guiding their seeker of right guidance, giving good counsel to their seeker of advice, attending to the one among them who returns from travel, hiding their secrets, covering over their shameful things, helping their wronged, sharing kindly with them in goods, turning toward them with wealth and bestowal of bounty, and giving what is due to them before they ask!", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur unhe apne tariqo’n ke qaayam karne aur unda akhlaaq wa aadaab se aaraasta hone ki taufiq ataa kar, is tarah se keh woh kamzoro’n ke saath narmi barte’n aur faqr o faaqe mein unki madad kare. Marizo’n ki ayaadat, hidaayat chahne waalo’n ki hidaayat, mashwera karne waalo’n ki bhalaayi aur mehmaano ka khayaal aur unke raazo’n ko chupaaye, aiybo’n par parde daale’n, mazloom ki madad aur gharelu zarooriyat ke zariye achcha salook bakhshish o inaam se faaida pohonchaaye aur sawaal karne se pehle ataa karne ki taufiq de.", "Urdu": "اور انہیں اپنے طریقوں کے قائم کرنے اور عمدہ اخلاق وآداب سے آراستہ ہونے کی توفیق دے۔ اس طرح کہ وہ کمزوروں کے ساتھ نرم رویہ رکھیں اوران کے فقر کا مداوا کریں۔ مریضوں کی بیمار پرسی، طالبان ہدایت کی ہدایت، مشورہ کرنے والوں کی خیر خواہی اورتازہ وارد سے ملاقات کریں۔ رازوں کو چھپائیں۔ عیبوں پر پردہ ڈالیں۔ مظلوم کی نصرت اور گھریلو ضروریات کے ذریعہ حسن مواسات کریں اور بخشش وانعام سے فائدہ پہنچائیں اورسوال سے پہلے ان کے ضروریات مہیا کریں۔", "RArabic": null, "ArabicText1": "وَ وَفِّقْهُمْ لِاِقَامَةِ سُنَّتِكَ وَالْاَخْذِ بِمَحَاسِنِ اَدَبِكَ فِيْ اِرْفَاقِ ضَعِيْفِهِمْ وَسَدِّ خَلَّتِهِمْ وَعِيَادَةِ مَرِيْضِهِمْ وَهِدَايَةِ مُسْتَرْشِدِهِمْ وَمُنَاصَحَةِ مُسْتَشِيْرِهِمْ وَتَعَهُّدِ قَادِمِهِمْ وَكِتْمَانِ اَسْرَارِهِمْ وَسَتْرِ عَوْرَاتِهِمْ وَنُصْرَةِ مَظْلُوْمِهِمْ وَحُسْنِ مُوَاسَاتِهِمْ بِالْمَاعُوْنِ وَالْعَوْدِ عَلَيْهِمْ بِالْجِدَةِ وَالْافْضَالِ وَاِعْطَاۗءِ مَا يَجِبُ لَهُمْ قَبْلَ السُّؤَالِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001781, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Let me, O God, repay their evildoer with good doing, turn away from their wrongdoer with forbearance. have a good opinion of every one of them, attend to all of them with devotion, lower my eyes before them in continence, make mild my side toward them in humility, be tender toward the afflicted among them in mercy, make them happy in absence through affection, love that they continue to receive favour through good will, grant them what I grant my next of kin, and observe for them what I observe for my special friends!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Mujhe aisa bana keh mai un mein se buro’n ke saath bhi bhalaayi karu aur zaalim se aankho’n ko bandh kar ke dar-guzar karu aur un sab ke baare mein husne-zan yaani achche ghumaan se kaam lu, aur neki aur ehsaan ke saath sab ki khabar-giri karu aur parhez-gaari paak-daamani ki bina par unke (oyub) se aankhe bandh rakkhu, tawaazoh farotani (narm rawayya) inkesaari ke saath un se pesh aawu, aur shafaqqat o mohabbat ki bina par museebat-zadah ki dil-joyi aur madad karu, unki na-maujoodgi mein bhi unki mohabbat ko dil mein qaayam rakkhu aur khulus ki bina par unke paas hamesha neymato’n ka rehna pasand karu aur jo cheeze’n apne khaas qareebi logo’n ke liye zaroori samjhu, unke liye bhi zaroori samajhu, aur jo imdaad o madad apne khaas chahne waalo’n se karu wahi imdaad un se bhi karu.", "Urdu": "اے اللہ! مجھے ایسا بنا کہ میں ان میں سے برے کے ساتھ بھلائی سے پیش آؤں اور ظالم سے چشم پوشی کرکے درگزر کروں اوران سب کے بارے میں حسن ظن سے کام لوں۔اور نیکی اور احسان کے ساتھ سب کی خبر گیری کروں۔ اور پرہیز گاری وعفت کی بنا پر ان (کے عیوب) سے آنکھیں بند رکھوں۔ تواضع وفروتنی کی رو سے ان سے نرم رویہ اختیار کروں اورشفقت کی بنا پر مصیبت زدہ کی دل جوئی کروں۔ ان کی غیبت میں بھی ان کی محبت کو دل میں لئے رہوں اورخلوص کی بنا پر ان کے پاس سدا نعمتوں کا رہنا پسند کروں اور جو چیزیں اپنے خاص قریبیوں کے لئے ضروری سمجھوں ان کے لئے بھی ضروری سمجھوں۔ اور جو مراعات اپنے مخصوصین سے کروں وہی مراعات ان سے بھی کروں۔", "RArabic": null, "ArabicText1": "وَاجْعَلْنِي اللّٰهُمَّ اَجْزِيْ بِالْاِحْسَانِ مُسِيْۗئَهُمْ وَاَعْرِضُ بِالتَّجَاوُزِ عَنْ ظَالِمِهِمْ وَاَسْتَعْمِلُ حُسْنَ الظَّنِّ فِيْ كَاۗفَّتِهِمْ وَاَتَوَلّٰى بِالْبِرِّ عَاۗمَّتَهُمْ وَاَغُضُّ بَصَرِيْ عَنْهُمْ عِفَّةً وَاُلِيْنُ جَانِبِيْ لَهُمْ تَوَاضُعًا وَاَرِقُّ عَلٰى اَهْلِ الْبَلَاۗءِ مِنْهُمْ رَحْمَةً وَاُسِرُّ لَهُمْ بِالْغَيْبِ مَوَدَّةً وَاُحِبُّ بَقَاۗءَ النِّعْمَةِ عِنْدَهُمْ نُصْحًا وَاُوْجِبُ لَهُمْ مَا اُوْجِبُ لِحَاۗمَّتِيْ وَاَرْعٰى لَهُمْ مَا اَرْعٰى لِخَاۗصَّتِي۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "