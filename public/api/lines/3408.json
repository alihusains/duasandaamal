[{"Id": 1014587, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Recite the last four verses of Surah <Hashr (59:21-24)> with ponderation while you are ceremonially pure after you have performed the ritual ablution (wudu’) before and after an obligatory prayer. The swelling will then vanish, Allah willing.", "GujaratiDescription": null, "RUrduDescription": "Riwaayat mein aaya hai keh jab badan par kahin waram aa jaaye to waajib namaz ke liye wuzu karne ke baad Surah <Hashr (59:21-24)> ki aayate’n padhe. Namaz ke baad bhi usey padhe aur us par khoob ghaur kare insha-Allah waram jaata rahega.", "UrduDescription": "روایت میں آیا ہے : جب بدن پر کہیں ورم آجائے توفریضہ نماز کے لئے وضو کرنے کے بعد سورۂ <حشر:۲۱۔۲۴> آیتیں پڑھے، پھر نماز کے بعد بھی اسے پڑھے اور اس پر خوب غور کرے انشاء اللہ ورم ختم ہوجائے گا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": nul