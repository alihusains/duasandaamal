[{"Id": 1010814, "EnglishTitle": "Eve of 15th Shaban", "GujaratiTitle": null, "RUrduTitle": "15th Shaban ki Shab", "UrduTitle": "۱۵؍شعبان کی شب میں زیارتِ امام حسین (ع)", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010511, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "It has been narrated from Imam Sajjad (a) and Imam Sadiq (a) that One who desires to shake hands with 124000 prophets should perform the Ziyarat of Abu Abdillah Husain (a) on 15th Shaban. Stand at the head side of the grave of Imam Husain (a) and recite…", "GujaratiDescription": null, "RUrduDescription": "Agar koi chahta hai keh woh 124000 paighambaro se musaafiya kare to usey chahiye ke woh Imam Husain (a) ki ziyarat par 15th Shaban ko jaaye. Qabr Imam Husain (a) ke sarhaane (head side) ki jaanib khade ho kar is tarah kahe…", "UrduDescription": "جاننا چاہیے کہ پندرہ شعبان کو امام حسینؑ کی زیارت کرنے کی فضلیت میں بہت سی احادیث وارد ہوئی ہیں اس بارے میں بس اتنا ہی کافی ہے کہ بہت سی قابلِ اعتبار اسناد کے ساتھ امام زین العابدین ؑاور امام جعفر صادق ؑ سے نقل ہوا ہے : جو شخص یہ چاہے کہ ایک لاکھ چوبیس ہزار پیغمبر اس سے مصافحہ کریں تو پندرہ شعبان کو ابی عبدا للہ الحسینؑ کی زیارت کرے کیوں کہ اس دن فرشتے اور ارواحِ انبیاؑء خدا سے اجازت لے کرحضرتؑ کی زیارت کے لئے آتی ہیں لہٰذا نیک بخت ہے وہ شخص جوان سے مصافحہ کرے اور وہ اس سے مصافحہ کریں۔ جب کہ ان میں پانچ اولو العزم پیغمبر یعنی حضرت نوحؑ، حضرت ابراہیمؑ، حضرت موسیٰؑ، حضرت عیسیٰؑ اور حضرت محمد ؐ شامل ہیں۔ راوی کا بیان ہے : میں نے پوچھا: کیوں ان کو اولو العزم کہا جاتا ہے؟ آپ نے فرمایا: اس کی وجہ یہ ہے کہ ان کو مشرق و مغرب اورجن وانس کے لئے بھیجا گیا ہے۔ اس زیارت کے الفاظ دو طریقوں سے نقل ہوئے ہیں،چنانچہ ایک متن وہ ہے جو یکم رجب کے لئے نقل ہو چکا ہے اور دوسرا متن وہ ہے جس کو شیخ کفعمیؒ نے کتاب بلد الامین میں امام جعفر صادق ؑ سے روایت کیا ہے کہ امام حسینؑ کی ضریح پاک کے نزدیک کھڑے ہو کر یوں کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010155, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "All praise be to Allah; the Most High, the All-great. Peace be upon you; O the righteous, pure servant (of Allah). I entrust with you a testimony of mine that takes me near you on the day of your intercession (for some people). I bear witness that although you were slain, you have not died; Rather the hearts of your adherents (Shia) are living on the hope of your being alive; And by the light of your illumination have those seeking you been guided (to the right path).", "Gujarati": null, "RGujarati": null, "RUrdu": "Hamd hai Khuda ke liye jo buland o buzurg hai aur salaam ho aap par ay Khuda ke banda’e khush kirdaar aur paakeeza. Mai apni taraf se ek gawahi aap ke supurd (hawaale) karta hu ta-keh woh mujhe aap ke qareeb kare jis din aap shafa’at karte honge. Mai gawahi deta hu keh aap qatl huwe to aap marey nahi bal-keh aap ke zindah hone ke tasawwur se aap ke pairo-kaaro’n ke dil zindah hai aur aap ki roshni ki kirano (rays) ke zariye chaha ne waale aap tak pohonchte hai.", "Urdu": "حمد ہے خداکے لئے جو بلند و بزرگ ہے اور آپ پر سلام ہو اے خدا کے بندۂ خوش کردار وپاکیزہ،میں اپنی طرف سے ایک گواہی آپ کے سپردکرتا ہوں تاکہ وہ مجھے آپ کے قریب کرے جس دن آپ شفاعت کرتے ہوں گے میں گواہی دیتاہوں کہ آپ قتل ہوئے تو آپ مرے نہیں بلکہ آپ کے زندہ ہونے کے تصور سے آپ کے پیروکاروں کے دل زندہ ہیں اور آپ کی روشنی کی کرنوں کے ذریعے چاہنے والےآپ تک پہنچتے ہیں۔", "RArabic": "AL-HAMDO LILLAAHIL A’LIYYIL A’ZEEME WAS-SALAAMO A’LAIKA AYYOHAL A’BDUS SAALEHUZ ZAKIYYO OODE-O’KA SHA-HAADATAM MINNEE LAKA TOQARREBONEE ILAIKA FEE YAWME SHA-FAA-A’TEKA ASH-HADO ANNAKA QOTILTA WA LAM TAMUT BAL BE-RAJAAA-E HAYAATEKA HAYEYAT QOLOOBO SHEE-A’TEKA WA BE-ZEYAAA-E NOOREKA EHTA-DAT TAALEBOONA ELAYKA.", "ArabicText1": "اَلْحَمْدُ لِلهِ الْعَلِيِّ الْعَظيْمِ وَالسَّلَامُ عَلَيْكَ اَيُّهَا الْعَبْدُ الصَّالِحُ الزَّكيُّ۔ اُوْدِعُكَ شَهَادَةً مِّنِّيْ لَكَ تُقَرِّبُنِيْ اِلَيْكَ فِيْ يَوْمِ شَفَاعَتِكَ، اَشْهَدُ اَنَّكَ قُتِلْتَ وَلَمْ تَمُتْ بَلْ بِرَجَاءِ حَيَاتِكَ حَيِيَتْ قُلُوْبُ شِيْعَتِكَ، وَبِضِيَاءِ نُوْرِكَ اِهْتَدَى الطَّالِبُوْنَ اِلَيْكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010156, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And I bear witness that you are verily the Light of Allah that has not and shall never be extinguished. And you are verily the Face of Allah that has not and shall never be perishing. And I bear witness that this soil is yours, And this holy precinct is yours. And this death is the death of your body only, While you have never been humiliated since Allah is the One Who is pouring honor upon you And you have never been defeated since Allah is the One Who is supporting you. I would like you to keep this testimony of mine with you up to the day when my soul will be grasped in the presence of you. Peace and Allah’s mercy and blessings be upon you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawahi deta hu keh aap Khuda ka woh noor hai jo mit-ta nai aur na hi yeh kabhi mitega aur be-shak aap Khuda ka woh jalwa hai jo khatm nahi hota aur na hi yeh kabhi khatm hoga. Mai gawahi deta hu keh yeh qabr aap ki qabr hai, yeh rauza aap ka rauza aur yeh qatl-gah aap ke badan ki qatl-gah hai. Aap pastt (kamtar) nahi, keh Khuda ne aap ko izzat di, aur aap maghloob nahi, keh Khuda ne aap ki madad farmayi. Yeh hai aap ke saamne meri gawahi us din tak jab aap ki maujoodgi mein meri rooh qabz hogi aur salaam ho aap par Khuda ki rehmat ho aur uski barkaat ho.", "Urdu": "میں گواہی دیتا ہوں کہ آپ خدا کا وہ نور ہیں جو بجھتا نہیں اور نہ ہی وہ کبھی بجھے گا اور بے شک آپ خدا کا وہ چہرہ ہیں جو ختم نہیں ہوتا اور نہ ہی یہ کبھی ختم ہو گا میں گواہی دیتا ہوں کہ یہ قبر آپ کی قبر ہے یہ روضہ آپ کا روضہ ہے اور یہ قتل گاہ آپ کے بدن کی قتل گاہ ہے آپ پست نہیں کہ خدا نے آپ کو عزّت دی اور آپ شکست خوردہ نہیں ہیں کہ خدا نے آپ کی مدد فرمائی آپ کے سامنے میری گواہی اس دن تک ہے جب آپ کی موجودگی میں میری روح قبض ہوگی اور آپ پر سلام ہو خدا کی رحمت ہو اور اس کی برکات ہوں۔", "RArabic": "WA ASH-HADO ANNAKA NOORUL LAAHIL LAZEE LAM YUTFA WA LAA YUT-FA-O ABDAN WA ANNAKA WAJHUL LAAHIL LAZEE LAM YAHLEK WA LAA YOHLAKO ABADAN WA ASH-HADO ANNA HAAZEHIT TURBATA TURBATOKA WA HAAZAL HARAMA HARAMOKA WA HAAZAL MASRA-A’ MASRA-O’ BADANEKA LA ZALEELA WALLAAHE MO-I’ZZOKA WA LAA MAGHLOOBA WALLAAHE NAASEROKA HAAZEHI SHA-HAADATUN LEE I’NDAKA ILAA YAWME QABZE ROOHEE BE-HAZRATEKA WAS-SALAAMO A’LAIKA WA RAHMATUL LAAHE WA BARAKAATOHU.", "ArabicText1": "وَاَشْهَدُ اَنَّكَ نُوْرُ اللهِ الَّذِيْ لَمْ يُطْفَا وَلَا يُطْفَاُ اَبَدًا، وَاَنَّكَ وَجْهُ اللهِ الَّذِيْ لَمْ يَهْلِكْ وَلَا يُهْلَكُ اَبَدًا، وَاَشْهَدُ اَنَّ هٰذِهِ التُّرْبَةَ تُرْبَتُكَ، وَهٰذَا الْحَرَمَ حَرَمُكَ، وَهٰذَا الْمَصْرَعَ مَصْرَعُ بَدَنِكَ لَا ذَلِيْلَ وَاللهِ مُعِزُّكَ وَلَا مَغْلُوْبَ وَاللهِ نَاصِرُكَ، هٰذِهٖ شَهَادَةٌ لِيْ عِنْدَكَ اِلٰى يَوْمِ قَبْضِ رَوُحِيْ بِحَضْرَتِكَ، وَالسَّلَامُ عَلَيْكُمْ وَرَحْمَةُ اللهِ وَبَرَكَاتُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSi