[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000511, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah send Thy “the best” blessings on Muhammad and on his children, the chosen successors, and on all Thy Prophets and Messengers; also glorify them with Thy “the best” commendations; and in addition, sanctify their bodies and souls.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Rehmat naazil farma Sarkar Muhammad (s.a.w.a) par aur unki Aal (a.s) par jo pasand kiye huwe ausiya hai aur rehmat naazil kar apne tamaam nabiyo’n aur rasoolo’n par apni behtareen rehmat se aur unhe barkat de apni behtareen barkato’n se aur rehmat farma unki rooho’n par aur unke jismo’n par.", "Urdu": "اے معبود! محمدؐ و آلؑ محمدؐ پر رحمت نازل فرما جو پسند کیے ہوئے اوصیاء ؑہیں اور اپنے تمام نبیوں اور رسولوں پر رحمت نازل کر اپنی بہترین رحمت سے اور انہیں برکت دے اپنی بہترین  برکتوں سے اور ان کی روحوں پر اور ان کے جسموں پر رحمت فرما۔", "RArabic": "ALLAAHUMMA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADE-NIL AWSIYAA-IL MARZI-YEENAA WA A’LAA JAMEE-E’ AMBIYAA-E-KA WA ROSOOLE-KA BE-AFZALE SALAWAATE-KA WA BAARIK A’LAIY-HIM BE-AFZALE BARAKATE-KA WA SALLE A’LAA AR-WAAHE-HIM WA AK-SAADE-HIM.", "ArabicText1": "اَللّٰھُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": " نِ", "ArabicText2": "الْاَوْصِیَآئِالْمَرْضِیِّیْنَ وَعَلٰی جَمِیْعِ اَنْبِیَآئِكَ وَرُسُلِكَ بِاَفْضَلِ صَلَوٰاتِكَ وَبَارِكْ عَلَیْهِمْ بِاَفْضَلِ بَرَكَتِكَ وَصَلِّ عَلٰی اَرْوَاحِهِمْ وَاَكْسَادِهِمْ۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002152, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah multiply Thy blessings send on Muhammad and on the children of Muhammad, and give us more and more in this day, which has been rendered superior, chosen for bestowing bounties, distinguished, and whose superabundant generosity is deemed very important. O Allah multiply Thy blessings for me in the bounties Thou bestows on me, through it, till I do not have to flatter anyone else other than Thee, and add more and more to my means of livelihood, O the Owner of might and majesty!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Barkat naazil kar Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par aur barkat de hamein aaj ke din jisko Tu ne badaayi di, izzat di, bulandi di aur usey unchi shaan ataa ki. Ay Ma’bood! Barkat de mujhe us neymat mein jo Tu ne mujhe ataa ki hai itni keh siwaaye Tere kisi ka shukr guzar na rahu aur mere rizq mein farawaani farma ay jalaalat aur buzurgi ke Maalik.", "Urdu": "اے معبود! محمدؐ و آلؑ محمدؐ پر برکت نازل کر اور ہمیں آج کے دن برکت دے جس کو تو نے بڑائی دی عزّت دی بلندی دی اور اسے اونچی شان عطا کی اے معبود! برکت دے مجھے اس نعمت میں جو تو نے مجھے عطاکی ہے اتنی کہ سوائے تیرے کسی کا شکر گزار نہ ہوں اور میرے رزق میں فراوانی عطا فرما اے جلالت اور بزرگی کے مالک۔", "RArabic": "MOHAMMADIN WA BAARIK LANAA FEE YAW-MENAA HAAZAL LAZEE FAZZAL-TAHU WA KARRAM-TAHU WA SHARRAF-TAHU WA A’ZZAM-TAHU. ALLAAHUMMA BAARIK LEE FEE-MAA AN-A’M-TA BEHI A’LAIYYA HATTAA LAA ASH-KORA AHA-DAN GHAIRA-KA WA WASSE’A’LAIYYA FEE RIZQEE YAA ZAL-JALAALE WAL IKRAAME.", "ArabicText1": "اَللّٰهُمَّ بَارِكْ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَّبَارِكْ لَنَا فِیْ یَوْمِنَا حٰذَا الَّذِیْ فَضَّلْتَهٗ وَكَرَّمْتَهٗ وَ شَرَّفْتَهٗ وَعَظَّمْتَ خَطَرَهٗ۔ اَللّٰهُمَّ بَارِكْ لِیْ فِیْمَا اَنْعَمْتَ بِهٖ عَلَیَّ حَتّٰی لَا اَشْكُرَ اَهَدًا غَیْرَكَ وَوَسِّعْ عَلَیَّ فِیْ رِزْقِیْ یَاذَالْجَلَالِ وَالْاِكْرَامِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002153, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah let it not be that what has been escaping me may also render Thy support and protection unavailable, and let it not be that which I have lost may also make me miss sorely Thy help, so that I may not take pains in the matter of that which I do not need, O Owner of might and majesty.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Jo kuchh mujh se ghaayab hota hai woh ho jaaye lekin Teri madad aur Teri hifaazat mujh se hargiz ghaayab na ho aur meri jo cheez ghum hoti hai woh ho jaaye, lekin Teri madad o himayat mujh se kabhi ghum na ho yahan tak-keh jis cheez ki zarurat nahi uske liye ranj na karu, ay jalaalat aur buzurgi ke Maalik.", "Urdu": "اے معبود! جو کچھ مجھ سے غائب ہو سو ہو جائے لیکن تیری مدد اور تیری حفاظت مجھ سے ہرگز غائب نہ ہو اور میری جو چیز گم ہو سو ہو جائے لیکن تیری مدد وحمایت مجھ سے کبھی بھی گم نہ ہو یہاں تک کہ جس چیز کی ضرورت نہیں اس کے لئے رنج نہ کروں اے جلالت اور بزرگی کے مالک۔", "RArabic": "ALLAAHUMMA MAA GHAABA A’NNEE FALAA YAGHEE-BANNA A’NNEE FALAA YAGHEE-BANNA A’NNEE A’W-NOKA WA HIFZO-KA WA MAA FA-QADTO MIN SHAI-IN FALAA TUF-QID-NEE A’W-NAKA A’LAIY-HE HAIYYAA LAA AN-KALLA-FO MAA LAA AH-TAAJO ILAIY-HE YAA ZAL-JALAALE WAL IKRAAME.", "ArabicText1": "اَللّٰهُمَّ مَا غَابَ عَنِّیْ فَلَا یَغِیْبَنَّ عَنِّیْ فَلَا یَغِیْبَنَّ عَنِّیْ عَوْنُكَ وَحِفْظُكَ وَمَا فَقَدْتُ مِنْ شَیْٓءٍ فَلَا تُفْقِدْنِیْ عَوْنَكَ عَلَیْهِ حَیّٰی لَا اَتَكَلَّفُ مَا لَا اَحْتَاجُ اِلَیْهِ یَاذَالْجَلَالِ وَالْاِكْرَامِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSig