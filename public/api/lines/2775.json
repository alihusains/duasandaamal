[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011665, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Praise be to Allah, Who honored us with this month who revealed in it the Holy Quran and made us recognize His right. And praise be to Allah, who gave the religious insight. Thus for the sake of the effulgence of Your face, O our God and the God of our foremost ancestors. Give us the taufeeq for repentance in this month and do not leave us to our devices and do not act against the good expectation we have with regard to You. Indeed You the most majestic and the most powerful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Hamd hai Usi Allah ke liye keh jisne ham ko is mahine ke zariye buzurg kiya aur is mahine mein hamare liye Qur’an naazil kiya aur ham ko uske (is mahine mein Qur’an ke) haq se aagah kiya aur hamd hai Allah ki basirate deeni inaayat farmane par. Pas Tujhe apni zaat ki nooraaniyat ka waasta, ay hamare Khuda aur ay hamare pehle buzurgo’n ke Khuda ham ko taubah ki is mahine mein taufiq inaayat kar aur ham ko hamare haal par na chhod dena aur hamare us husn-zan, keh jo Tere saath wa-basta hai uske khilaaf na kar, yaqeenan Tu zabardast o jaleel hai.", "Urdu": "حمد ہے اسی اللہ کے لئے جس نے ہم کو اس مہینے کے ذریعہ بزرگ کیا اور اس مہینے میں ہمارے لئے قرآن نازل کیا اور ہم کو اس کے (قرآن کے) حق سے آگا کیا اور حمد ہے اللہ کی بصیرت دینی عنایت فرمانے پر۔ پس تجھے اپنی ذات کی نورانیت کا واسطہ اے ہمارے خدا اور اے ہمارے پہلے بزرگوں کے خدا ہم کو توبہ کی اس مہینے میں توفیق عنایت کر اور ہم کو ہمارے حال پر نہ چھوڑ دینا اور ہمارے اس حسن زن کہ جو تیرے ساتھ وابستہ ہے اس کے خلاف نہ کر، یقینًا تو زبردست و جلیل ہے۔", "RArabic": "AL-HAMDO LILLAA-HIL TAZEE AKRA-MANAA BE-SHAH-RENAA HAAZAA WA AN-ZALA A’LAIY-NAA FEE-HIL QURAANA WA A’RRA-FANAA HAQQA-HU WAL-HAMDO LILLAA-HE A’LAL BA-SEERA-TE FABE-NOORE WAJHE-KA YAA ELAA-HANAA WA ELAA-HA ABAA-E-NAL AWWA-LEENAA UR-ZUQNAA FEE-HIT TAWBA-TA WA LAA TAKH-ZULNAA WA LAA TUKH-LIF ZANNA-NAA BEKA INNA-KA ANTAL JA-LEE-LUL JABBAA-RO.", "ArabicText1": "اَلْحَمْدُ لِلہِ الَّذِیْ اَکْرَمَنَا بِشَھْرِنَا ھٰذَا وَاَنْزَلَ عَلَیْنَا فِیْہِ الْقُرْاٰنَ وَعَرَّفَنَا حَقَّہٗ۔ وَالْحَمْدُ لِلہِ عَلَی الْبَصِیْرَۃِ فَبِنُوْرِ وَجْھِکَ یَااِلٰھَنَا وَاِلٰہَ اَبَآئِنَا الْاَوَّلِیْنَ اُرْزُقْنَا فِیْہِ التَّوْبَۃَ وَلَا تَخْذُلْنَا وَلَا تُخْلِفْ ظَنَّنَا بِکَ اِنّکَ اَنْتَ الْجَلِیْلُ الْجَبَّارُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null