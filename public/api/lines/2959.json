[{"Id": 1012839, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is also advisable to repeat the following words that Imam Ali (a) mentioned in one of his sermons on Friday, as is cited in the book of Rawzah min Kafi, representing an invocation of Allah’s blessings upon the Holy Prophet (s)…", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh us alfaaz ko dauraawo jo Imam Ali (a) ne Juma ke khutbe mein bayaan farmaya tha. Kitaab Rawzah min Kafi mein Allah (swt) ki taraf se Rasool-e-Khuda (s) par durood…", "UrduDescription": "بہتر ہے کہ آنحضرتؐ پر وہ صلوات پڑھی جائے جو امیرالمومینن ؑ نے جمعہ کے ایک خطبہ میں پڑھی اور وہ روضۂ کافی میں اس طرح نقل ہوئی ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012840, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "“Lo! Allah and His angels shower blessings on the Prophet. O you who believe, ask blessings on him and salute him with a worthy salutation.” O Allah, send peace upon Muhammad and the Household of Muhammad, send blessings upon Muhammad and the Household of Muhammad, have compassion upon Muhammad and the Household of Muhammad, and send benedictions upon Muhammad and the Household of Muhammad as much as You have sent peace, blessings, mercy, compassion, and benedictions upon (Prophet) Abraham and the Household of Abraham. You are verily Owner of praise, Owner of glory.", "Gujarati": null, "RGujarati": null, "RUrdu": "“Be-shak Allah aur Uske farishte Nabi (s.a.w.a) par durood bhejte hai, ay imaan waalo tum hi Aan Hazrat (s.a.w.a) par durood o salaam bhejo jaise salaam ka haq hai.” Ay Ma’bood! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma, aur barkat ataa farma Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par, aur Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par maher-baani farma, Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par salaam bhej jaise Tu ne Ibrahim (a.s) aur Aale Ibrahim (a.s) par behtareen durood bheja, barkat ataa ki, rehmat naazil ki, maher-baani farmaayi aur salaam bheja, be-shak Tu taarif waala buzurg-waar hai.", "Urdu": "بے شک اﷲاور اس کے فرشتے نبیؐ پر درود بھیجتے ہیں اے ایمان والو! تم بھی آنحضرتؐ پر درود وسلام بھیجو جیسے سلام کا حق ہے اے معبود! محمدؐ و آل محمدؐ پر رحمت نازل فرما اور برکت عطا فرما محمدؐ وآل محمدؐ پر اور محمدؐ و آل محمدؐ پر مہربانی فرما محمدؐ وآل محمدؐ پر سلام بھیج جیسے تو نے ابراہیم ؑاور آل ِابراہیم ؑپر بہترین درود بھیجابرکت عطا کی رحمت نازل کی مہربانی فرمائی اور سلام بھیجا بے شک تو تعریف والا بزرگوار ہے۔", "RArabic": "INNALLAAHA WA MALAA-E-KATA-HU YU-SALLOO-NA A’LAN NABIYYE YAA AYYO-HAL LAZEENA AA-MANOO SALLOO A’LAIHE WA SALLE-MOO TASLEE-MAN. ALLAAHUMMA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA BAARIK A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA TA-HANNAN A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA SALLIM A’LAA MOHAMMADIW WA AALE MOHAMMADIN KA-AFZALE MAA SALLAI-TA WA BAA-RAKTA WA TARAH-HAMTA WA TA-HANNAN-TA WA SALLAM-TA A’LAA IBRAAHEEM WA AALE IBRAAHEEM INNAKA HAMEEDOOM MAJEEDOON.", "ArabicText1": "اِنَّ اللهَ وَمَلَائِكَتَهٗ يُصَلُّوْنَ عَلَى النَّبِيِّ يَا اَيُّهَا الَّذِيْنَ آمَنُوْا صَلُّوْا عَلَيْهِ وَسَلِّمُوْا تَسْلِيْمًا۔ اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَبَارِكْ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَتَحَنَّنْ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَسَلِّمْ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ كَاَفْضَلِ مَا صَلَّيْتَ وَبَارَكْتَ وَتَرَحَّمْتَ وَتَحَنَّنْتَ وَسَلَّمْتَ عَلٰى اِبْرَاهِيْمَ وَآلِ اِبْرَاهِيْمَ اِنَّكَ حَمِيْدٌ مَّجِيْدٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012841, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, give Muhammad (the right of) mediation, honor, virtue, and noble rank. O Allah, make Muhammad and the Household of Muhammad to be the most honored of all Your creatures on the Resurrection Day, the closest to You in position, the most notable with You on the Resurrection Day, and the most favorable in title and status.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Hazrat Muhammad (s.a.w.a) ko wasila sharaf aur fazilat aur kareem manzelat ataa farma. Khudaaya Muhammad (s.a.w.a) wa Aale Muhammad (a.s) ko qayaamat ke din saari makhlooq mein se sab se ziyadah sharaf aur maqaam waala bana, unko apne qareeb-tar jagah par qaraar de kar aur roz’e qayaamat unko apne yahan ziyadah izzat daar bana aur martaba wa hisse ke lehaaz se afzal wa barkat qaraar de.", "Urdu": "اے معبود! حضرت محمدؐ کو وسیلۂ شرف اور فضیلت اور کریم منزلت عطا فرما خدایا! محمدؐ وآل محمدؐ کو قیامت کے دن ساری مخلوق میں سے سب سے زیادہ شرف اور مقام والا بنا ان کو اپنے قریب تر جگہ پر قرار دے کر اور روزِقیامت ان کو اپنے ہاں زیادہ عزّت دار بنا اور مرتبہ و حصہ کے لحاظ سے افضل و برتر قرار دے۔", "RArabic": "ALLAAHUMMA A’TE MOHAMMADA NIL-WASEE-LATA WASH-SHARAFA WAL FAZEE-LATA WA MAZE-LATAL KAREEMA-TA. ALLAAHUMMAJ A’L MOHAMMADAW WA AALA MOHAMMADIN A’ZA-MAL KHALAA-E-QE KULLE-HIM SHARA-FAN YAWMAL QEYAAMATE WA AQRABA-HUM MINKA MAQ-A’DAN WA AW-JAHA-HUM I’NDA-KA YAWMAL QEYAAMATE JAAHAN WA AFZALA-HUM I’NDAKA MANZELA-TAN WA NASEE-BAN.", "ArabicText1": "اَللّٰهُمَّ اَعْطِ مُحَمَّدَا", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": " نِ", "ArabicText2": "الْوَسِيْلَةَ وَالشَّرَفَ وَالْفَضِيْلَةَ وَالْمَنْزِلَةَ الْكَرِيْمَةَ۔ اَللّٰهُمَّ اجْعَلْ مُحَمَّدًا وَّآلَ مُحَمَّدٍ اَعْظَمَ الْخَلَائِقِ كُلِّهِمْ شَرَفًا يَوْمَ الْقِيَامَةِ وَاَقْرَبَهُمْ مِنْكَ مَقْعَدًا وَاَوْجَهَهُمْ عِنْدَكَ يَوْمَ الْقِيَامَةِ جَاهًا وَاَفْضَلَهُمْ عِنْدَكَ مَنْزِلَةً وَنَصِيْبًا۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012842, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, give Muhammad the most honorable position, the most abundant salutation, and the intercession of Islam. O Allah, join us to him while we are neither disgraced, nor violating, nor regretful, nor distorting. O God of all worlds, respond to us.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Hazrat Muhammad (s.a.w.a) ko buland tareen maqaame sulah wa neki ka ajr aur tableeghe Islaam ka silah (badla) ataa farma. Ay Ma’bood! Hamein Aan Hazrat (s.a.w.a) se mila de is tarah keh na ham ruswa ho na ahed shikani kare (ahed tode), na sharmindagi uthaaye’n aur na ehkaam ko badle, ay sachche Khuda is dua ko qabool farma.", "Urdu": "اے معبود! حضرت محمدؐ کو بلند ترین مقام صلح و نیکی کا اجر اور تبلیغِ اسلام کا صلہ عطا فرما اے معبود!ہمیں آنحضرتؐ سے ملا دے اس طرح کہ نہ ہم رسوا ہوں نہ عہدشکنی کریں نہ شرمندگی اٹھائیں اور نہ احکام کوبدلیں اے سچے خدا اس دعا کو قبول فرما۔", "RArabic": "ALLAAHUMMA A’TE MOHAMMADAN ASHRA-FAL MAQAA-ME WA HEBAA-AS SALAAME WA SHAFAA-A’TAL ISLAAME. ALLAAHUMMA WA AL-HIQNAA BEHI GHAIRA KHAZAA-YAA WA LAA NAAKE-SEENA WA LAA MO-BADDE-LEENA ILAA-HAL HAQQE AAMEENA.", "ArabicText1": "اَللّٰهُمَّ اَعْطِ مُحَمَّدًا اَشْرَفَ الْمَقَامِ وَحِبَاءَ السَّلَامِ وَشَفَاعَةَ الْاِسْلَامِ۔ اَللّٰهُمَّ وَاَلْحِقْنَا بِهٖ غَيْرَ خَزَايَا وَلَا نَاكِثِيْنَ وَلَا نَادِمِيْنَ وَلَا مُبَدِّلِيْنَ اِلٰهَ الْحَقِّ آمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign