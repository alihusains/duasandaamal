[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011663, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, this is the month of Ramazan, in which You have revealed the Quran and ordered the building of Masjids. And ordered supplication and fasting and prayers and guaranteed to us their acceptance. So we also struggled as per our ability and You also helped us. So forgive us in it and do not make it to be our last Ramazan and forgive us. Indeed You are our Lord; have mercy on us. Indeed You are our Chief and make us of those who are going to turn to Your forgiveness and pleasure. Indeed You are the most majestic and the greatest.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baare Ilaaha! Yeh Mahe Ramazan hai keh jis mein Tu ne Qur’an naazil kiya aur Tu ne is maah (month) mein aabaadiye Masajid aur dua’o aur rozo’n aur namazo’n ka hukm diya aur Tu ne qabooliyate dua ki zamaanat di is maah mein to ham ne bhi ba-qadre imkaan (jitna ho sake’n) koshish ki aur Tu ne hamari madad ki. Pas bakhsh de is mahine mein hamare gunaho’n ko aur is Mahe Ramazan ko hamari zindagi ka aakhri Ramazan na qaraar dena, bakhsh de haamari khataawo’n ko. Yaqeenan! Tu hi hamara Parwardigaar hai, rahem farma ham par yaqeenan Tu hi hamara Aaqa hai aur ham ko un logo’n mein se qaraar de, keh jo Teri khushnoodiye maghferat ki taraf palat kar jaane waale hai, yaqeenan Tu hi ba-izzat o ba-azmat waala hai.", "Urdu": "بار الہ! یہ ماہ رمضان ہے کہ جس میں تو نے قرآن نازل کیا اور تو نے اس ماہ میں آبادی مساجد اور دعاؤں اور روضوں اور نمازوں کا حکم دیا اور تو نے قبولیت دعا کی ضمانت دی اس ماہ میں تو ہم  نے بھی بہ قدر امکان کشیش کی اور تو نے ہماری مدد کی۔ پس بخش دے اس مہینے میں ہمارے گناہوں کو اور اس ماہ رمضان کو ہماری زندگی کا آخری رمضان نہ قرار دینا، بخش دے ہماری خطاؤں کو۔ یقینًا! تو ہی ہمارا پروردگار ہے، رحم فرما ہم پر یقینًا تو ہی ہمارا آقا ہے اور ہم کو ان لوگوں میں سے قرار دے کہ جو تیری خشنودی مغفرت کی طرف پلٹ کر جانے والے ہے، یقینًا تو ہی بہ عزّت و بہ عزمت والا ہے۔", "RArabic": "ALLAAHUMMA HAAZAA SHAHRO RAMAZAA-NAL LAZEE ANZAL-TA FEEHIL QURAANE WA AMAR-TA BE-E’MAA-RATIL MASAA-JEDA FEEHE WAD DO-A’AA-E WAS-SEYAAME WA ZAMEEN-TA LANAA-FEEHIL IJAA-BATA FA-QAD IJTA-HADNA WA ANTA A-A’N-TANAA FAGH-FIR-LANAA FEEHE WA LAA TAJ-A’LA-HU AAKHE-RAL -A’H-DE MINNAA WA’FO A’NNAA FA-INNA-KA RABBO-NAA WAR-HAMNAA FA-INNA-KA SAYYE-DONAA MIMMAN YAN-QALE-BO ILAA MAGH-FERATE-KA WA RIZWAANE-KA FA INNA-KA ANTAL AJAL-LUL A’ZAMO.", "ArabicText1": "اَللّٰھُمَّ ھٰذَا شَھْرُ رَمَضَانَ الَّذِیْ اَنْزَلْتَ فِیْہِ الْقُرْاٰنَ وَاَمَرْتَ بِعِمَارَۃِ الْمَسَاجِدَ فِیْہِ وَالدُّعَآئِ وَالصِّیَامِ وَالْقِیَامِ وَضَمِنْتَ لَنَافِیْہِ الْاِجَابَۃَ فَقَدْ اِجْتَھَدْنَا وَاَنْتَ اَعَنْتَنَا فَاغْفِرْ لَنَا فِیْہِ وَلَا تَجْعَلَہٗ اٰخِرَالْعَھْدِ مِنَّا وَاعْفُ عَنَّا فَاِنَّکَ رَبُّنَا وَارْحَمْنَا فَاِنَّکَ سَیِّدُنَا وَاجْعَلْنَا مِمَّنْ یَّنْقَلِبُ اِلٰی مَغْفِرَتِکَ وَرِضْوَانِکَ فَاِنَّکَ اَنْتَ الْاَجَلُّ الْاَعْظَمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": n