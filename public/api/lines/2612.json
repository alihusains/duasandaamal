[{"Id": 1016797, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Supplication of Imam Zamaan (a) for protection from his enemy and to be hidden from their eyes….", "GujaratiDescription": null, "RUrduDescription": "Imam-e-Zamana (a) ki hifaazat unke dushmano se aur unki aankho’n se ojal (chhupe) rehne ki dua…", "UrduDescription": "امام زماناؑ کی حفاظت ان کے دشمنوں سے اور انکی آنکھوں سے اؤجل رہنے کی دُعا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016798, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, hide me from the eyes of my enemies, and gather me with my friends, and fulfill that which You have promised me, and protect me in my occultation until You permit me for reappearance, and revive through me those obligations and recommendations which have turned old, and hasten in my relief, and ease my exit.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaara! Mujhe dushmano ki aankho’n se o-jhal rakh, mujhe apne dosto’n ke saath rakh, mere saath jo Tu ne waada kiya hai usey poora farma aur meri ghaibat mein meri hifaazat farma, yahan tak-keh Tu mujhe zahoor ki ijaazat farmaye. Mere zariye apne mahuh-shuda (mita huwa) faraaez o sunan (sunnat) ko zindah farma, mere zahoor ko nazdeek farma, mere zahoor ko aasaan farma.", "Urdu": "پروردگارا! مجھے دشمنوں کی آنکھوں سے اُوجھل رکھ، مجھے اپنے دوستوں کے ساتھ رکھ، میرے ساتھ جو تو نے وعدہ کیا ہے پورا فرما اور میری غیبت میں میری حفاظت فرما یہاں تک کہ تو مجھے ظہور کی اجازت فرمائے۔ میرے ذریعہ اپنے محو شدہ فرائض و سنّن کو زندہ فرما، میرے ظہور کو نزدیک فرما، میرے ظہور کو آسان فرما۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اجْجُبْنِیْ عَنْ عُیُوْنِ اَعْدَانِیْ، وَاجْمَعْ بَیْنِیْ وَبَیْنَ اَوْلِیَائِیْ، وَاَنْجِزْلِیْ مَا وَعَدْتَنِیْ، وَاحْفَظْنِیْ فِیْ غَیْبَتِیْ اِلٰی اَنْ تَاذَنَ لِیْ فِیْ ظُهُوْرِیْ، وَاَحْیِ بِیْ مَا دَرَسَ مِنْ فُرُوْضِكَ وَسُنَنِكَ، وَعَجِّلْ فَرَجِیْ، وَسَهِّلْ مَخْرَجِیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016799, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And allocate a dominating support for me from Your threshold, and help me succeed with an apparent victory, and guide me to the straight path, and protect me from all those transgressors I fear, and conceal me from the eyes of those who have grudge against me, those who hold enmity against the household of Your Prophet, and do not let anyone reach me with their wickedness.", "Gujarati": null, "RGujarati": null, "RUrdu": "Apne yahan se mujhe qudrat o nusrat ataa farma, mujhe waaze kaamyaabi naseeb farma aur mujhe seedhe raaste ki taraf hidaayat karne ki taufiq ataa farma. Mujhe hirasa’n karne (daraane) waalo’n se mehfooz farma. Mujhe apne Nabi (s.a.w.a) ke khaandaan ke saath bughz o adaawat rakhe waalo’n ki aankho’n se posheeda rakh ta-keh un mein se koi mujhe nuqsaan na pohoncha sakey.", "Urdu": "اپنے یہاں سے مجھے قدرت و نصرت عطا فرما، مجھے واضح کامیابی نصیب فرما اور مجھے سیدھے راستے کی طرف ہدایت کرنے کی توفیق عطا فرما۔ مجھے ہراساں کرنے والوں سے محفوظ فرما۔ مجھے اپنے نبیؐ کے خاندان کے ساتھ بغض و عداوت رکھنے والوں کی آنکھوں سے پوشیدہ رکھ تا کہ ان میں سے کوئی مجھے نقصان نہ پہنچا سکے۔", "RArabic": null, "ArabicText1": "وَاجْعَلْ لِیْ مِنْ لَدُنْكَ سُلْطَانًا نَصِیْرًا، وَافْتَحْ لِیْ فَتْحًا مُبِیْنًا، وَاهْدِنِیْ صِرَاطًا مُّسْتَقِیْمًا، وَقِنِیْ جَمِیْعَ مَا اُحَاذِرُهٗ مِنَ الظَّالِمِیْنَ، وَاحْجُبْنِیْ عَنْ اَعْیُنِ الْبَاغِضِیْنَ، اَلنَّاصِبِیْنَ الْعَدَاوَۃِ لِاَهْلِ بَیْتِ نَبِیِّكَ، وِلَا یَصِلْ مِنْهُمْ اِلَیَّ اَحَدٌۢ بَسُوْئٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016800, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Thus when you permit my reappearance, strengthen me with Your army, and support those who follow me for supporting Your religion, and those who fight in Your path, and make them victorious over those who have wicked intentions for me and for them, a help me succeed in the establishment of Your regulations, and support me against those who trespass Your boundaries.", "Gujarati": null, "RGujarati": null, "RUrdu": "Phir jab Tu mujhe zahoor ki ijaazat de to apne lashkar waalo’n ke saath meri madad farma. Meri pairwai karne waalo’n ko apne deen ka haami o naasir aur mujaahid fee sabee-lillah qaraar de. Mere aur un (lashkar waalo’n) ke dushmano ke khilaaf meri aur un lashkar waalo’n ki madad farma. Mujhe apne ahkaam ko qaaem karne ki taufiq ataa farma aur jo shakhs Teri hado’n se tajaawuz kare (aaghe badh jaaye) unke muqaable mein meri madad farma.", "Urdu": "پھر جب تو مجھے ظہور کی اجازت دے تو اپنے لشکر والوں کے ساتھ میری مدد فرما۔ میری پیروی کرنے والوں کو اپنے دین کا حامی و ناصر اور مجاہد فی سبیل اللہ قرار دے۔ میرے اور ان (لشکر والوں) کے دشمنوں کے خلاف میری اور ان لشکر والوں کی مدد فرما۔ مجھے اپنے احکام کو قائم کرنے کی توفیق عطا فرما اور جو شخص تیری حدوں سے تجاوز کرے ان کے مقابلے میں میری مدد فرما۔", "RArabic": null, "ArabicText1": "فَاِذَا اَذِنْتَ فِیْ ظُهُوْرِیْ فَاَیِّدْنِیْ بِجُنُوْدِكَ، وَاجْعَلْ مَنْ یَّتَّبِعُنِیْ لِنُصْرَۃِ دِیْنِكَ مُؤَیَّدِیْنَ، وَفِیْ سَبِیْلِكَ مُجَاهِدِیْنَ، وَعَلٰی مَنْ اَرَادَنِیْ وَاَرَادَهُمْ بِسُوْئٍ مَنْصُوْرِیْنَ، وَ وَفِّقْنِیْ لِاِقَامَۃِ حُدُوْدِكَ، وَانْصُرْنِیْ عَلٰی مَنْ تَعَدّٰی مَحْدُوْدَكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016801, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And help the truth, and defeat the evil, indeed evil is ending, and bring near me those Shias and companions whose vision cools my eyes, and strengthen my back, and regard them in Your protection and safety, with Your mercy, O the most Merciful of the merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur haq ko kaamyaab aur baatil ko naabood farma. Be-shak baatil naabood hone waala hai. Mujhe aise Shiya aur ansaar o madad-gaar ataa farma keh jinke zariye aankho’n ko thandak pohonche aur pusht mazboot ho aur unhe’n apni rehmat ke saath apne hifz o amaan mein rakh. Ay rahem karne waalo’n mein sab se ziyadah rahem karne waale.", "Urdu": "اور حق کو کامیاب اور باطل کو نابود فرما۔ بےشک باطل نابود ہونے والا ہے۔ مجھے ایسے شیعہ اور انصار و مددگار عطا فرما کہ جن کے ذریعہ آنکھوں کو ٹھنڈک پہنچے اور پشت مضبوط ہو اور انہیں اپنی رحمت کے ساتھ اپنے حفظ و امان میں رکھ۔ اے رحم کرنے والوں میں سب سے زیادہ رحم کرنے والے!", "RArabic": null, "ArabicText1": "وَانْصُرِ الْحَقَّ، وَاَزْهِقِ الْبَاطِلَ، اِنَّ الْبَاطِلَ كَانَ زَهُوْقًا، وَاَوْرِدْ عَلَیَّ مِنْ شِیْعَتِیْ وَاَنْصَارِیْ مَنْ تَقَرُّبِهِمُ الْعَیْنُ، وَیَشُدُّبِهِمُ الْاَزْرُ، وَاجْعَلْهُمْ فِیْ حِرْزِكَ وَاَمْنِكَ، بِرَحْمَتِكَ یَا اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) choicest blessings be upon Mohammed and his holy progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar Tu rehmat naazil farma Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par.", "Urdu": "اے معبود! رحمت نازل فرما حضرت محمدؐ اور انکی آل ؑپر۔", "RArabic": "ALLAHUMMA SWALLE ALAA MUHAMMADIW WA AALE MUHAMMADIN", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016802, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Honorable Sayyid Ali bin Taoos states in his book Muhajud Dawaat, after mentioning the supplication of concealment and other concealments, that: These concealments are among those things whose recitation has been revealed upon us when a flood arrived and resulted in the drowning of a number of people, and water had spread everywhere. It was extremely difficult to save one’s life in such a condition. The intensity of the flood resulted in the devastation of several flood-prone areas. The acceptance of these supplications made it possible for us to live there and repel all the difficulties, becoming the guarantor of our safety from these happenings. We thank God for it.", "GujaratiDescription": null, "RUrduDescription": "Sayed Ali Ibne Tawoos Muhajud Dawaat mein is Hijaab ke hamrah digar hijaab ka zikr karne ke baad farmate hai; ek zamaane mein bohot bada seylaab aaya, har jagah paani bhar gaya uski zid mein jo makaan thay munhadim hone lage amn o amaan khatm ho gaya aur zindagi mushkil ho gayi, us waqt mujhe is dua ke padhne ka ilhaam huwa, haqeeqat yeh hai keh in mushkilaat mein jine ka imkaan sirf unhe duwaa’o ki ejaabat ki surat mein tha, yeh hijaab thay jinho ne un rukaawat ko dur kiya aur un na-gawaar haadso’n mein hamare zaamin rahe, ham Parwardigaar-e-aalam ki is ne’mat par Uske shukr-guzaar hai.", "UrduDescription": "سید بزرگوار علی بن طاؤوس مھج الدعوات میں اس حجات کے ذکر اور دوسرے حجات کے بعد فرماتے ہیں ایک دن بہت زیادہ سیلاب آیا اور ہر جگہ پانی آیا تھا اور جو مکان سیلاب کے راستے میں تھے زیادہ سیلاب آنے کی وجہ سے مکان منھدم ہوچکے تھے اس روز انسان کی سلامتی خطرے میں پڑگئی اور زندگی سخت ہوئی مجھے ان دنوں میں ان حجات کے پڑھنے کے لئے الہام ہوا تھا واقعاً اس دوران زندگی صرف دعا کے قبول ہونے میں منحصر تھی یہ حجاب تھے کہ جس نے ان موانع کو دور کیا اور ان ناگوار حوادث کے دور گزرنے کے ضامن یہ حجاب تھے پس میں نے اس نعمت پر خدا کا شکر ادا کیا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9"