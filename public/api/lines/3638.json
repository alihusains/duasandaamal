[{"Id": 1015705, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "HAJJ-E-TAMATTO: It is the duty for those who are at a distance of more than 48 miles (16 farsakhs). Hajj-e-Tamatto is with Umrah-e-Tamatto.", "GujaratiDescription": null, "RUrduDescription": "HAJJ-E-TAMATTO: Yeh un logo’n par waajib hota hai jo Makkeh se 48 miles (taqriban 86 kilometer) duri par rehte hai. Hajje Tamatto ke saath Umrah-e-Tamatto kiya jaata hai.", "UrduDescription": "حج تمتع: یہ ان لوگوں پر واجب ہوتا ہے جو مکّہ سے ۴۸ میل (تقریبًا ۸۶ کلو میٹر) دوری پر رہتے ہوں۔ حج تمتع کے ساتھ عمرۂ تمتع کیا جاتا ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "