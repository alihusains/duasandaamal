[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018620, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And there is no strength or Power except with Allah the great and high. O Allah we worship You and from You only we seek help. O Allah! O Merciful! O Compassionate! O the One! O the Eternal! O Lord of Mohammad Mustafa! (peace of Allah be on him and his progeny). In Your Domain feets are moving ahead and with the presence of heart, eyes are awaiting, necks are stretched high, where desires are asked after, lifting of hands. O Allah! You judge between us and our nation with truth, as You are the best of the judges.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur koi quwwat o taaqat imdaad’e Khuda wand buzurg o bartar ke alaawah mumkin nahin. Khuda wanda! Teri hi ibaadat karta hu aur Tujhi se madad chahta hu. Ay Allah ay maher-baan, ay rahem karne waale, ay yakta, ay be-neyaaz, ay Muhammad’e Mustafa (s.a.w.a) ke Allah Teri hi baargah mein qadam badh-te aur dil haazir huwe. Aankhe’n rukh karti aur gardane’n uthti, zaroorate’n maangi jaati, haath uthaaye jaate hai. Khuda wanda! Hamaare aur hamaari qaum ke darmiyaan mein haq ke saath faisla farma keh Tu beh-tareen kushaadgi (wus’at) ataa farmaane waala hai.", "Urdu": "اور کوئی قوت و طاقت امداد خدا وند بزرگ و برتر کے علاوہ ممکن نہیں۔ خدا وندا! تیری ہی عبادت کرتا ہیں اور تجھی سے مدد مانگتا ہیں۔ اے اللہ! اے مہربان، اے رحم کرنے والے، اے یکتا، اے بے نیاز، اے محمد مصطفٰیؐ کے اللہ تیری ہی بارگاہ میں قدم بڑھتے اور دل حاضر ہوئے، آنکھیں رخ کرتی اور گردنیں اُڑھتی، ضرورتیں مانگی جاتی، ہاتھ اُٹھائے جاتے ہیں۔ خدا وندا! ہمارے اور ہماری قوم کے درمیان میں حق کے ساتھ فیصلہ فرما کہ تو بہترین کشادگی عطا فرمانے والا ہے۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "وَلَا حَوْلَ وَلَا قُوَّۃَ اِلَّا بِاللهِ الْعَلِیِّ الْعَظِیْمِ۔ اَللّٰهُمَّ اِیَّاكَ نَعْبُدُ وَاِیَّاكَ نَسْتَعِیْنُ یَا اَللهُ یَا رَحْمٰنُ یَا رَحِیْمُ یَا اَحَدُ یَا صَمَدُ یَا اِلٰهَ مُحَمَّدٍ اِلَیْكَ نُقِلَتِ الْاَقْدَامُ وَاَفَضَتِ الْقُلُوْبُ وَشَخَصَتِ الْاَبْصَارُ وَمُدَّتِ الْاَعْنَاقُ وَطُلِبَتِ الْحَوَاۗئِجُ وَرُفِعَتِ الْاَیْدِیْ۔ اَللّٰهُمَّ افْتَحْ بَیْنَنَا بَیْنَ قَوْمِنَا بِالْحَقِّ وَاَنْتَ خَیْرُ الْفَاتِحِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "Ara