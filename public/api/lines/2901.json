[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002196, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Tell him who is concealed under the layers of soil: If you can hear my scream and my call. If the misfortunes that have been poured on me. Were poured on days, they should turn to black nights! Under the shadow of Muhammad, I used to be sheltered I did not anticipate any grievance since he was my haven But today I am made subservient to the lowly, suffering grievances. And I have to ward off the wrongdoer with my dress. If a turtledove weeps on a branch in eves. Out of grief, I will weep in morns. I shall betake grief, after you, as my entertainment. And I shall betake shedding tears, for you, as my sash.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khaak ke pardho’n mein gaayab hone waale se koi kahe, Tu meri faryaad aur pukaar soon raha hai? Mujh par woh museebate’n padi hai keh agar woh dino par aati to woh kaali raate’n ban jaati. Mai Muhammad (s.a.w.a) ki himaayat ke saaye mein thi mujhe kisi ke zulm ka dar na tha unki panah mein. Lekin aaj pastt logo’n ke saamne haazir hu, zulm ka khouf hai apni chaadar se zaalim ko hataati hu. Raat ki taariki mein jab qamri shaakh par rowey, mai shaakh par subh ke waqt roti hu. Aap ke gham mein ashko’n ke haar puroti hu.", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "QUL LIL MO-GHAIYYE-BE AT-BAAQIS SARAA IN KUNTA TASMA-O’ SAR-KHATEE WA NEDAA-E-YAA. SUBBAT A’LAIYYA MASAA-E-BO LAW ANNA-HAA SUBBAT A’LAL AYYAAME SIRNA LAYAA-LEYAA. QAD KUNTO ZAATA HEMAN BE-ZILLE MOHAMMADIN LAA AKH-SHA MIN ZAIY-MEEM WA KAANA HEMA-YAN LEYAA. FAL-YAWMA AKHZAA-O’ LIZ-ZALEELE WA ATTA-QEE-ZAIYMEE WA ADFA-O’ ZAALEMEE BE-REDAA-E-YAA. FA-EZAA BA-KAT QUM-RIYYA-TOON FEE LAIYLE-HAA SHAJA-NAN A’LAA GHUS-NIN BA-KAIYTO SABAAHE-YAA. FALA-AJ-A’LAN-NAL HUZNA BA’DAKA MOONE-SEE WAL-AJ-A’LA-NAD DAM-A’ FEE-KA WE-SHAAHE-YAA.", "ArabicText1": "قُلْ لِلْمُغَيَّبِ تَحْتَ اَطْبَاقِ الثَّرٰى اِنْ كُنْتَ تَسْمَعُ صَرْخَتِيْ وَنِدَائِيَا۔ صُبَّتْ عَلَيَّ مَصَائِبُ لَوْ اَنَّهَاصُبَّتْ عَلَى الْاَيَّامِ صِرْنَ لَيَالِيَا۔ قَدْ كُنْتُ ذَاتَ حِمًى بِظِلِّ مُحَمَّدٍ لَا اَخْشَ مِنْ ضَيْمٍ وَكَانَ حِمَیً لِيَا۔ فَالْيَوْمَ اَخْضَعُ لِلذَّلِيْلِ وَاَتَّقِيْضَيْمِيْ وَاَدْفَعُ ظَالِمِيْ بِرِدَائِيَا۔ فَاِذَا بَكَتْ قُمْرِيَّةٌ فِيْ لَيْلِهَا شَجَنًا عَلٰى غُصْنٍ بَكَيْتُ صَبَاحِيَا۔ فَلَاَجْعَلَنَّ الْحُزْنَ بَعْدَكَ مُوْنِسِيْ وَلْاَجْعَلَنَّ الدَّمْعَ فِيْكَ وِشَاحِيَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicTex