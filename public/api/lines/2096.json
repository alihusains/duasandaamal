[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018709, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I wish to seek proximity to You by Your grace and generosity and by Your special servant Mohammed peace be on him and his progeny and through You and through the angels who are near to You. O Allah self sufficiency belongs to You and for me is the dependency in Your presence You are rich and I am indigent forgive my laxities, conceal my sins, and today fulfil my desires, and whatever sins You are aware of, don't chastise me, but put me in Your mercy and generosity.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Mai Tere jood o karam ke zariye Teri baargah mein taqarrub (nazdiki) haasil karna chahta hu, aur Tere banda’e khaas aur rasool Hazrat Muhammad (s.a.w.a) aur Aal (a.s) ke zariye taqarrub (nazdiki) haasil karta hu, aur khud Tere zariye Tere qareeb tareen farishto’n aur rasoolo’n ke zariye qurbat haasil karna chahta hu. Khuda wanda! Tere liye be-neyaazi hai aur mere liye Teri baargah mein neyaaz mandi, Tu ghani hai aur mai Tera faqeer, meri laghzishe (khataawo’n ko) maaf farma de, mere gunaho’n ki pardah poshi farma, aur aaj meri tamannaye’n poori kar de, meri jo bad-kaariyo’n ko Tu jaanta hai us par azaab na karna, bal-keh Tere jood o afwo mein meri behar-haal gunjaaish hai.", "Urdu": "با خدایا! میں تیرے جود و کرم کے ذریعے تیری بارگاہ میں تقرب حاصل کرنا چاہتا ہوں اور تیرے بندۂ خاص اور رسول حضرت محمدؐ اور آلؑ کے ذریعے تقرب حاصل کرتا ہوں، اور خود تیرے ذریعے، تیرے قریب ترین فرشتوں اور رسولوں کے ذریعے قریب حاصل کرنا چاہتا ہوں۔ خدا وندا! تیرے لئے بے نیازی ہے اور میرے لئے تیری بارگاہ میں نیاز مندی، تو غنی ہے میں تیرا فقیر، میری لغزشیں معاف فرما دے، میرے گناہوں کی پردہ پوشی فرما، اور آج میری تمنّائیں پوری کر دے، میری جو بدکاریوں تو جانتا ہے اس پر عذاب نہ کرنا، بلکہ تیرے جود و عفو میں میری بہر حال گنجائش ہے۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَتَقَرَّبُ اِلَیْكَ بِجُوْدِكَ وَكَرَمِكَ وَاَتَقَرَّبُ اِلَیْكَ بِمُحَمَّدٍ عَبْدِكَ وَرَسُوْلِكَ (وَاَتَقَرُّبُ اِلَیْكَ بِمُحَمَّدٍ عَبْدِكَ وَرَسُوْلِكَ) وَاَتَقَرُّبُ اِلَیْكَ بِمَلَاۗئِكَتِكَ الْمُقَرَّبِیْنَ وَاَنْۢبِیَاۗئِكَ الْمُرْسَلِیْنَ وَبِكَ۔ اَللّٰهُمَّ لَكَ الْغِنٰی عَنِّیْ وَبِیَ الْفَاقَۃُ اِلَیْكَ اَنْتَ الْغَنِیُّ وَاَنَا الْفَقِیْرُ اِلَیْكَ اَقِلْنِیْ عَثْرَتِیْ وَاسْتُرْ عَلَیَّ ذُنُوْبِیْ وَاقْضِ الْیَوْمَ حَاجَتِیْ وَلَا تُعَذِّبْنِیْ بِقَبِیْحِ مَا تَعْلَمُ مِنِّیْ بَلْ عَفْوُكَ یَسَعُنِیْ وَجُوْدُكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRed