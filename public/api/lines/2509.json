[{"Id": 1020341, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Kulaini (r) narrates on the authority of Bazanti who said: I asked Imam Reza (a): How should I offer salutation on the holy grave of the Messenger of Allah (s)? He (a) said: Say…", "GujaratiDescription": null, "RUrduDescription": "Kulaini riwaayat karte hai Bazanti se keh unho’n ne farmaya: Mai ne Imam Reza (a) se poochha: Kis tarah se salaam karu jab mai Rasool’e Khuda (s) ki qabr par jaawu? Imam (a) ne farmaya: kaho…", "UrduDescription": "کلینی روایت کرتے ہیں بزنتی سے کہ اُنہوں نے فرمایا: میں نے امام رضاؑ سے پوچھا: کس طرح سے سلام کروں جب میں رسول خداؐ کی قبر مبارک پر جاؤں؟ امامؑ نے فرمایا: کہو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1020342, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O Allah’s Messenger. Peace be upon you, O most-beloved of Allah. Peace be upon you, O choicest of Allah. Peace be upon you, O trustee of Allah. I bear witness that you are the messenger of Allah and I bear witness that you are Muhammad, the son of Abdullah. And I bear witness that you have truly well-wished for your nation, striven hard in the way of your Lord, and worshipped Him until death came upon you. May Allah reward you, O Allah’s Messenger, with the best of that with which He has ever rewarded a Prophet on behalf of his people. O Allah, (please) send blessings to Muhammad and the Household of Muhammad with the best blessings You have ever conferred upon Abraham and the Household of Abraham. Verily, You are All-laudable, All-glorious.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Allah ke Rasool (s.a.w.a), aap par salaam ho ay Habeeb-e-Khuda (s.a.w.a), aap par salaam ho ay Khuda ke amaanat-daar. Mai gawahi deta hu keh aap Khuda ke Rasool hai, aur gawahi deta hu keh aap Muhammad ibne Abdullah (s.a.w.a) hai. Mai gawahi deta hu keh aap ne apni ummat ki khair-khwaahi ki, aur apne Rab ki raah mein jehaad kiya, aur Uski ibaadat karte rahe hatta keh waqt-e-maut aa gaya, ab ay Khuda ke Rasool (s.a.w.a) woh aap ko jaza de woh beh-tareen jaza jo Nabi (s.a.w.a) ko apni ummat se mil sakti hai, ay Ma’bood! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma, beh-tareen rehmat jo Tu ne Hazrat Ibrahim (a.s) aur Aale Ibrahim (a.s) par naazil ki ho, be-shak Tu laayaqe hamd aur shaan waala hai.", "Urdu": "آپ پر سلام ہو اے اللہ کے رسولؐ ، آپ پر سلام ہو اے حبیبِؐ خدا !آپ پر سلام ہو اے خدا کے منتخب، آپ پر سلام ہو اے خدا کے امانت دار۔ میں گواہی دیتاہوں کہ آپ خدا کے رسولؐ ہیں اور گواہی دیتا ہوں کہ آپ محمدؐ ابن عبداﷲؑہیں، میں گواہی دیتا ہوں کہ آپ نے اپنی امت کی خیر خواہی کی اور اپنے رب کی راہ میں جہاد کیا اور اس کی عبادت کرتے رہے حتی کہ وقت ِموت آگیااب اے خدا کے رسولؐ وہ آپ کو جزا دے وہ بہترین جزا جو نبیؐ کو اپنی امت سے مل سکتی ہے اے معبود! محمدؐ وآل محمدؑ پر رحمت فرما بہترین رحمت جو تو نے حضرت ابراہیم ؑاور آل ابراہیم ؑ پرفرمائی بے شک تو لائق ِحمد اور شان والا ہے۔", "RArabic": "AS-SALAAMO A’LAIYKA YAA RASOO-LAL-LAAHE, AS-SALAAMO A’LAIYKA YAA HABEE-BAL-LAAHE, AS-SALAAMO A’LAIYKA YAA SIFWA-TAL-LAAHE, AS-SALAAMO A’LAIYKA YAA AMEE-NAL-LAAHE, ASH-HADO ANNA-KA RASOO-LUL-LAAHE, WA ASH-HADO ANNA-KA MOHAMMA-DUBNO ABDIL-LAAHE. WA ASH-HADO ANNA-KA QAD NASAH-TA LE-UMMATE-KA, WA JAA-HADTA FEE SABEELE RABBE-KA, WA A’BAD-TAHU HATTAA ATAA-KAL YAQEENO, FA-JAZAA-KAL-LAAHO YAA RASOO-LAL-LAAHE AF-ZALA MAA JAZAA NABIYYAN A’N UMMATE-HI. ALLAAHUMMA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN, AF-ZALA MAA SAL-LAIY-TA A’LAA IBRAAHIM WA AALE IBRAAHIM INNA-KA HAMEE-DOON MAJEE-DOON.", "ArabicText1": "اَلسَّلَامُ عَلَيْكَ يَا رَسُوْلَ اللهِ، اَلسَّلَامُ عَلَيْكَ يَا حَبِيْبَ اللهِ، اَلسَّلَامُ عَلَيْكَ يَا صِفْوَةَ اللهِ، اَلسَّلَامُ عَلَيْكَ يَا اَمِيْنَ اللهِ، اَشْهَدُ اَنَّكَ رَسُوْلُ اللهِ، وَاَشْهَدُ اَنَّكَ مُحَمَّدُ بْنُ عَبْدِ اللهِ وَاَشْهَدُ اَنَّكَ قَدْ نَصَحْتَ لِاُمَّتِكَ، وَجَاهَدْتَ فِىْ سَبِيْلِ رَبِّكَ، وَعَبَدْتَهٗ حَتّٰى اَتَاكَ الْيَقِيْنُ، فَجَزَاكَ اللهُ يَا رَسُوْلَ اللهِ اَفْضَلَ مَا جَزٰى نَبِيًّا عَنْ اُمَّتِهٖ، اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ، اَفْضَلَ مَا صَلَّيْتَ عَلٰى اِبْرَاهِيْمَ وَآلِ اِبْرَاهِيْمَ اِنَّكَ حَمِيْدٌ مَّجِيْدٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicTex