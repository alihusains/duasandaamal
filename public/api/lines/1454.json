[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010128, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Salam of the Grand Allah be on you! Salam of His dear Angels, Prophets, Messengers, respected Imams, His holy beings and all the Martyrs and True ones on you! May the purest Durood (blessings of Allah) be on you morning and evening, O Muslim Ibne Aquil Ibne Abu Talib! Salam on you, O good being of Allah! O obedient of Allah, His Rasool and Amirul Momeneen, Hasan and Husain, who may all receive blessings of Allah! I bear witness that you were not behind (in helping Allah), that you did not retreat, that you left this world with the utmost knowledge that you were obedient to those who performed good deeds, Prophets and Messengers. So may Allah gather us and you and our friends in the place of the magnanimous, indubitably, He is a grand Meherban.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "SALAAMUL LAAHIL A’LIYYIL A’ZEEME WA SALAAMO MALAA-E-KATE-HIL MO-QARRA-BEENA WA AMBIYAA-E-HIL MUR-SALEENA, WA AIMMA-TE-HIL MUN-TAJE-BEENA, WA E’BAADE-HIS SAALE-HEENA, WA JAMEE-A’SH SHOHADAA-E WAS SIDEE-QEENA, WAZ ZAAKE-YAA-TUT TAIYYE-BAATO FEE MAA TAGH-TA-DEE WA TAROO-HO A’LAIKA YAA MUSLE-MIB-NA A’QEE-LIB-NE ABEE TAALE-BIN. AS-SALAAMO A’LAIKA AYYO-HAL A’B-DUS SAALE-HUL MOTEE-O’ LILAAHE WALE RASOOLE-HI WALE AMEERIL MO-MENEENA WAL HASANE WAL HUSAINE SALAWAA-TUL LAAHE A’LAI-HIM AJMA-EE’NA. ASH-HADO ANNA-KA LAM TA-HIN WA LAM TAN-KUL, WA INNA-KA QAD MAZEE-TA A’LAA BA-SEERA-TIN MIN AMRE-KA MUQTA-DE-YAN BIS SAALE-HEENA WA MUTTA-BE-A’N LIN NABIY-YEENA, FA-JAMA-A’L LAAHO BAIYNA-NAA WA BAIYNA-KA WA BAIYNA RASOOLE-HI WA AWLE-YAA-E-HI, FEE MA-NAAZE-LIL MUKH-BE-TEENA FA-INNA-HU AR-HAMUR RAAHE-MEENA.", "ArabicText1": "سَلَامُ اللہِ الْعَلِیِّ الْعَظِیْمِ وَسَلَامُ مَلٰٓئِکَتِہِ الْمُقَرَّبِیْنَ وَاَنْۢبِیَآئِہِ الْمُرْسَلِیْنَ‘ وَاَئِمَّتِہِ الْمُنْتَجِبِیْنَ‘ وَعِبَادِہِ الصّٰلِحِیْنَ‘ وَجَمِیْعَ الشُّہَدَآئِ وَالصِّدِّیْقِیْنَ‘ وَالزَّاکِیَاتُ الطَّیِّبَاتُ فِیْ مَا تَغْتَدِیْ وَتَرُوْحُ عَلَیْکَ یَامُسْلِمَ ابْنَ عَقِیْلِ ابْنِ اَبِیْ طَالِبٍ۔ اَلسَّلَامُ عَلَیْکَ اَیُّھَاالْعَبْدُ الصَّالِحُ الْمُطِیْعُ لِلہِ وَلِرَسُوْلِہٖ وَلِاَمِیْرِالْمُؤْمِنِیْنَ وَالْحَسَنِ وَالْحُسَیْنِ صَلَوَاتُ اللہِ عَلَیْھِمْ اَجْمَعِیْنَ۔ اَشْھَدُ اَنَّکَ لَمْ تَھِنْ وَلَمْ تَنْکُلْ‘ وَاِنَّکَ قَدْ مَضَیْتَ عَلٰی بَصِیْرَۃٍ مِّنْ اَمْرِکَ مُقْتَدِ یًا بِالصّٰلِحِیْنَ وَمُتَّبِعًا لِلنَّبِیِّیْنَ‘ فَجَمَعَ اللہُ بَیْنَنَا وَبَیْنَکَ وَبَیْنَ رَسُوْلِہٖ وَاَوْلِیَآئِہٖ‘ فِیْ مَنَازِلِ الْمُخْبِتِیْنَ فَاِنَّہٗ اَرْحَمُ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null