l, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1005312, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 109, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Say: If the sea were ink for the words of my Lord, the sea would surely be consumed before the words of my Lord are exhausted, though We were to bring the like of that (sea) to add there to.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap kahe dijiye keh agar mere Parwardigaar ke kalemaat ke liye samandar bhi roshnaayi (ink) ban jaaye to kalemaat'e Rab ke khatm hone se pehle hi saare samandar khatm ho jaayenge chahe unki madad ke liye ham waise hi samandar aur bhi le aaye.", "Urdu": "آپ کہہ دیجئے کہ اگر میرے پروردگار کے کلمات کے لئے سمندر بھی روشنی جائیں تو کلماتِ رب کے ختم ہونے سے پہلے ہی سارے سمندر ختم ہوجائیں گے چاہے ان کی مدد کے لئے ہم ویسے ہی سمندر اور بھی لے ائیں۔", "RArabic": "QUL LAW KAANAL BAHRU MIDAADAL LI KALIMAATI RABBEE LANAFIDAL BAHRU QABLA AN TANFADA KALIMAATU RABBEE WA LAW JI’NAA BIMISLIHEE MADADAA.", "ArabicText1": "قُل لَّوْ كَانَ الْبَحْرُ مِدَادًا لِّكَلِمٰتِ رَبِّيْ لَنَفِدَ الْبَحْرُ قَبْلَ اَنْ ت