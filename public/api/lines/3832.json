[{"Id": 1020767, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "To get immediate acceptance of your supplication, in less time than the flash of an eye, recite this dua’a 100 times, preferably on Thursday, after praying 2 rakat salat, and 15 durood (salawat) before and at the end of this dua’a, and beseech the almighty Allah to fulfill your legitimate desires, wants and needs.", "GujaratiDescription": null, "RUrduDescription": "Shaikh Kafami ne Balad al-Amin mein ek dua Imam Sajjad (a) se naql ki aur kaha keh yeh dua aan Janab (a) se Maqaatil bin Salmaan ne riwaayat ki aur saath hi yeh bhi kaha hai keh agar koi shakhs is dua ko 100 martaba padhe aur uski dua qabool na ho to Maqaatil par laanat bheje aur woh dua yeh hai…", "UrduDescription": "شیخ کفعمی ؒنے بلدالامین میں ایک دعا امام سجادؑسے نقل کی اور کہا ہے : یہ دعا حضرتؑ سے مقاتل ابن سلیمان نے روایت کی اورساتھ ہی یہ بھی کہا ہے : اگر کوئی شخص اس دعا کو سومرتبہ پڑھے اور اس کی دعا قبول نہ ہو تو مقاتل پر لعنت بھیجے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1020768, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God how can I call on You (for help) for I am me (a sinful servant)? How can I cut off hope from You for You are You (the merciful lord)? My God (even) when I did not beseech You, You gave me. So who is he who gives if I beseech him? My God (even) when I did not call out, You fulfilled my desire. So who is he who satisfies if I call him? My God (even) when I did not humbly solicit, You took pity on me. So who is he who shows mercy i’ll solicit him? My God I beseech You that just as You parted as under the sea for Musa (peace be on him) to save him, send blessings on Muhammad and on the children of Muhammad, and come to my rescue, and deliver me (from these troubles), and disperse (afflictions), and do it quickly, without delay, through Your kindness, through Your mercy, O the most merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Ma’bood! Mai Tujhe kaise pukaaru aur mai to mai hu aur kyu’n kar Tujh se apni ummeed tod du jab keh Tu Tu hai. Mere Ma’bood! Jab mai Tujh se nahi maangta tab bhi Tu mujhe ataa karta hai to aur kaun hai jis se maangu to woh mujhe dega. Mere Ma’bood! Jab mai Tujh se dua na karu to meri dua qabool farmata hai aur kaun hai jis se dua karu to woh meri dua qabool karega. Mere Ma’bood! Jab mai Tere huzoor zaari (girya) na karu tab bhi Tu mujh par rahem karta hai aur kaun hai jis ke aaghe zaari karu to woh mujh par rahem karega.", "Urdu": "میرے معبود! میں تجھے کیسے پکاروں اور میں تو میں ہوں اور کیوں کر تجھ سے اپنی امید توڑوں جب کہ تو تو ہی ہے میرے معبود جب میں تجھ سے نہ مانگوں پھر بھی تو مجھے عطا کرتا ہے اور کون ہے جس سے مانگوں تو وہ مجھے کچھ دے گا میرے معبود جب میں تجھ سے دعا نہ کروں تو میری دعا قبول فرماتا ہے اور کون ہے جس سے دعا کروں تو وہ میری دعاقبول کرے گا میرے معبود جب میں تیرے حضورگریہ وزاری نہ کروں تب بھی تو مجھ پر رحم کرتا ہے اور کون ہے جس کے آگےگریہ و زاری کروں تو وہ مجھ پر رحم کرے گا۔", "RArabic": "ILAAHI KAI-FA AD-OO’KA WA ANAA, ANAA WA KAI-FA AQTA-O’ RAJAAA-EE MINKA WA ANTA, ANTA ILAA-HEE IZAA LAM AS-ALOKA FA-TO’TE-YANEE FA-MAN ZAL-LAZEE AS-ALOHU FA-YU’TEE-NEE ILAA-HEE IZAA LAM AD-O’KA (AD-OO’KA) FA-TAS-TA-JEEBA LEE FA-MAN ZAL-LAZEE AD-OO’HO FA-YASTA-JEEBO LEE.", "ArabicText1": "اِلٰهِيْ كَيْفَ اَدْعُوْكَ وَاَنَا اَنَا وَكَيْفَ اَقْطَعُ رَجَاۗئِيْ مِنْكَ وَاَنْتَ اَنْتَ اِلٰهِيْ اِذَا لَمْ اَسْئَلُكَ فَتُعْطِيَنِيْ فَمَنْ ذَا الَّذِيْ اَسْئَلُهٗ فَيُعْطِيْنِيْ‏ اِلٰهِيْ اِذَا لَمْ اَدْعُكَ (اَدْعُوْكَ) فَتَسْتَجِيْبَ لِيْ فَمَنْ ذَا الَّذِيْ اَدْعُوْهُ فَيَسْتَجِيْبُ لِيْ‏۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1020769, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God I beseech You that just as You parted as under the sea for Musa (peace be on him) to save him, send blessings on Muhammad and on the children of Muhammad, and come to my rescue, and deliver me (from these troubles), and disperse (afflictions), and do it quickly, without delay, through Your kindness, through Your mercy, O the most merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Ma’bood! Jaise Tu ne dariya ko shighaafta kiya (raasta banaya) Moosa (a.s) ke liye aur unhe najaat di, to mai bhi Tujh se sawaal karta hu keh Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur mujhe najaat de us mushkil se jis mein mai giraftaar hu aur mujhe kushaadgi ataa farma jald-tar, keh us mein der (delay) na ho apne fazl se aur apni rehmat se, ay sabse ziyadah rahem karne waale.", "Urdu": "میرے معبود جیسے تونے دریا کو شگافتہ کیا موسٰؑی کے لئے اور انہیں نجات دی تھی تو میں بھی تجھ سے سوال کرتا ہوں کہ محمدؐ وآل ؑ محمد پر رحمت نازل فرما اور مجھے نجات دے اس مشکل سے جس میں گرفتارہوں اور مجھے کشادگی عطا فرماجلد تر کہ اس میں دیر نہ ہو اپنے فضل سے اور اپنی رحمت سے اے سب سے زیادہ رحم کرنے والے۔", "RArabic": "ILAA-HEE EZAA LAM ATA-ZARRA’ ILAIY-KA FA-TAR-HAMA-NEE FA-MAN ZAL-LAZEE ATA-ZARRA-O’ ILAIY-HE FA-YAR-HAMO-NEE ILAA-HEE FA-KAMAA FA-LAQ-TAL BAHRA LE-MOOSAA A’LAIY-HIS SALAAMO WA NAJ-JAYTA-HU AS-ALOKA AN TO-SALLEYA A’LAA MOHAMMADIW WA AALE-HI WA AN TO-NAJJE-YANEE MIMAA ANAA FEEHE WA TO-FARRE-JA A’NNEE FARA-JAN A’AJE-LAN GHAIRA AAJE-LIN BE-FAZLE-KA WA RAHMATE-KA YAA AR-HAMAR RAAHE-MEEN.", "ArabicText1": "اِلٰهِيْ اِذَا لَمْ اَتَضَرَّعْ اِلَيْكَ فَتَرْحَمَنِيْ فَمَنْ ذَا الَّذِيْ اَتَضَرَّعُ اِلَيْهِ فَيَرْحَمُنِيْ‏ اِلٰهِيْ فَكَمَا فَلَقْتَ الْبَحْرَ لِمُوْسٰى عَلَيْهِ السَّلَامُ وَنَجَّيْتَهٗ‏ اَسْئَلُكَ اَنْ تُصَلِّيَ عَلٰى مُحَمَّدٍ وَّآلِهٖ‏ وَاَنْ تُنَجِّيَنِيْ مِمَّا اَنَا فِيْهِ وَتُفَرِّجَ عَنِّيْ فَرَجًا عَاجِلًا غَيْرَ آجِلٍ بِفَضْلِكَ وَرَحْمَتِكَ يَااَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "Arab