jaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, truly, I beseech You. O He who is beyond the visual range of created beings on account of the splendor of His light. O he was demonstrates Himself through His majesty and might, and makes known His purity and holiness by doing good (to His creation). O He who is high and exalted in glory and greatness, having no equal in distinction and eminence. O He who separates the good from the bad, in all affairs, how much intricate or remote they may be, for readily they lay bare every secret, in no time, on receiving His command.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اِنِّي اَسْاَلُكَ يَا مَنِ احْتَجَبَ بِشُعَاعِ نُوْرِهٖ عَنْ نَوَاظِرِ خَلْقِهٖ۔ يَا مَنْ تَسَرْبَلَ بِالْجَلَالِ وَالْعَظَمَةِ وَاشْتَهَرَ بِالتَّجَبُّرِ فِيْ قُدْسِهٖ۔ يَا مَنْ تَعَالٰى بِالْجَلَالِ وَالْكِبْرِيَاءِ فِيْ تَفَرُّدِ مَجْدِهٖ۔ يَا مَنِ انْقَادَتِ الْاُمُوْرُ بِاَزِمَّتِهَا طَوْعًا لِاَمْرِهٖ۔ يَا مَنْ قَامَتِ السَّمَاوَاتُ وَالْاَرَضُوْنَ مُجِيْبَاتٌ لِدَعْوَتِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002342, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He in answer to whose call stood firm the heavens and the earths. O He who made the skies more beautiful by decorating it with twinkling stars, also a (useful) guide for the people wandering in (darkness). O He who, very kindly, with delicate fineness, gave brightness to the moon, to spread soft light I the gloomy dark night. O He who filled the sun with radiating luminous energy, to make easy, for mankind, pursuit of economic activity, and also a sure sign, separating night form the day by His ever-dominating authority. O He to who (alone) we must bow down to show gratitude in return of the inundating downpour of His favors and bounties.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": "يَا مَنْ زَيَّنَ السَّمَاءَ بِالنُّجُوْمِ الطَّالِعَةِ وَجَعَلَهَا هَادِيَةً لِـخَلْقِهٖ۔ يَا مَنْ اَنَارَ الْقَمَرَ الْمُنِيْرَ فِيْ سَوَادِ اللَّيْلِ الْمُظْلِمِ بِلُطْفِهٖ۔ يَا مَنْ اَنَارَ الشَّمْسَ الْمُنِيرَةَ وَجَعَلَهَا مَعَاشًا لِخَلْقِهٖ وَجَعَلَهَا مُفَرِّقَةً بَيْنَ اللَّيْلِ وَالنَّهَارِ بِعَظَمَتِهٖ۔ يَا مَنِ اسْتَوْجَبَ الشُّكْرَ بِنَشْرِ سَحَائِبِ نِعَمِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002343, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I beseech You, in the name of the intricate, strongly tied, hard to understand glory of Your arsh (seat of divine authority); (in the name of) the utmost mercy of Your book, and (in the name) of all names, which are Yours, (You) referred to Yourself, or You chose for Yourself, but kept in Your transcendental wisdom; (In the name of) all Your names, which are Yours, (You) revealed in Your book, or (those name which are) firmly and permanently learnt by heart by the pure ever prostrating (angles) all over Your arsh; and from their secret thoughts comes to the forefront sincere expression of unique and incomparable oneness of Allah (monotheism); and sure affirmation of Your singleness (without an equal), sharing together, with total submissiveness to You.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": "اَسْاَلُكَ بِمَعَاقِدِ الْعِزِّ مِنْ عَرْشِكَ وَمُنْتَهَى الرَّحْمَةِ مِنْ كِتَابِكَ وَبِكُلِّ اسْمٍ هُوَ لَكَ سَمَّيْتَ بِهٖ نَفْسَكَ اَوِ اسْتَاْثَرْتَ بِهٖ فِيْ عِلْمِ الْغَيْبِ عِنْدَكَ وَبِكُلِّ اسْمٍ هُوَ لَكَ اَنْزَلْتَهٗ فِيْ كِتَابِكَ اَوْ اَثْبَتَّهٗ فِيْ قُلُوْبِ الصَّافِّيْنَ الْحَافِّيْنَ حَوْلَ عَرْشِكَ فَتَرَاجَعَتِ الْقُلُوْبُ اِلَى الصُّدُوْرِ عَنِ الْبَيَانِ بِاِخْلَاصِ الْوَحْدَانِيَّةِ وَتَحْقِيْقِ الْفَرْدَانِيَّةِ مُقِرَّةً لَكَ بِالْعُبُوْدِيَّةِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": nu