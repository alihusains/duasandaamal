[{"Id": 1002340, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Sayyid ibni Tawus in Mahajul Da’wat writes many merits of this dua. If this dua is recited for a person in trance or unconsciousness or temporary insanity, he or she shall become normal. It is also recited to make a woman give birth to a living child if there were several miscarriages. To seek forgiveness of sins and to get enough sustenance, recite this dua on 40 consecutive Fridays, after sunset…", "GujaratiDescription": null, "RUrduDescription": "Sayyed Ibne Tawus, Mahajul Da’wat mein farmate hai keh, is dua ko agar koi be-hosh ya diwaane par padhi jaaye to woh us bala se baahar aa jayega. Yeh dua un aurto’n keh liye bhi hai jinhe hamal nahi thairta. Gunah ki bakhshish aur rozi mein izaafe ke liye musalsal 40 Juma guroob’e Aftaaf (sunset) ke baad is dua ko padhe…", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign1