gn6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016171, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, this Fatima is the daughter of your Prophet, who is distressed by hunger, and this Ali Ibne Abi Talib is the cousin of your Prophet, who is distressed by hunger; so O God, send down upon us from the heavens a table of food like You sent upon Bani Israel, but they adopted denial, but I would remain faithful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar! Be-shak Fatema (s.a) Tere Nabi (s.a.w.a) ki beti bhook se pareshaan hai. Yeh Ali (a.s) Tere Nabi (s.a.w.a) ke chacha-zaad bhai bhook se ni-dhaal hai. Pas ham par aasmaan se Maaedah (ghiza) naazil farma, jis tarah nabi'e Israaeel par farmaaya to unho ne inkaar kiya aur ham iqraar karne waale hai.", "Urdu": "پروردگار بیشک فاطمہ تیرے نبی کی بیٹی بھوک سے پریشان ہے۔ یہ علی تیرے نبی کے چچا زاد بھائی بھوک سے نڈھال ہے۔ پس ہم پر آسمان سے مائدہ نازل فرما۔ جس طرح بنی اسرائیل پر فرمایا تو انہوں نے انکار کیا اور ہم اقرار کرنے والے ہیں۔", "RArabic": "ALLAAHUMMA INNA FAATEMATA BINTA NABIYYEKA QAD AZARRA BEHAL JOO-O’, WA HAAZAA A’LIYYUBNO ABEE TAALIBIN IBNO A’MME NABIYYEKA QAD AZARRA BEHIL JOO-O’, FA-ANZELIL LAAHUMMA A’LAYNAA MAA-EDATAN MENAS SAMAA-E, KAMAA ANZALTAHAA A’LAA BANEE ISRAA-EELA FA-KAFAROO, WA INNAA MOAMENOON.", "ArabicText1": "اَللّٰهُمَّ اِنَّ فَاطِمَۃَ بِنْتَ نَبِیِّكَ قَدْ اَضَرَّ بِهَا الْجُوْعُ، وَهٰذَا عَلِیُّ بْنُ اَبِیْ طَالِبٍ اِبْنُ عَمِّ نَبِیِّكَ قَدْ اَضَرَّ بِهِ الْجُوْعُ، فَاَنْزِلِ اللّٰهُمَّ عَلَیْنَا مَاۗئِدَۃً مِنَ السَّمَاۗئِ كَمَا اَنْزَلْتَهَا عَلٰی بَنِیْ اِسْرَاۗئِیْلَ فَكَفَرُوْا وَاِنَّا مُؤْمِنُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": n