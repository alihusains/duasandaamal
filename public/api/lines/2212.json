[{"Id": 1016168, "EnglishTitle": "Dua for the request of a Maedah descent from the sky.", "GujaratiTitle": null, "RUrduTitle": "Aasmaan se Maaedah (food) Talab karte huwe.", "UrduTitle": "آسمان سے مائدہ طلب کرتے ہوئے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016169, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is narrated from Ibne Abbas, in a lengthy traditional report that when once the Holy Prophet (s) came to the house of Lady Fatima Zahra (s) he found her pale faced and her eyes sunken. He asked: My dearest one, why are you so pale and emaciated? She replied: We have not eaten since the last three days. He offered some advice and Fatima went into the room and prayed two units of prayer; and then raising her hands to the heavens said…", "GujaratiDescription": null, "RUrduDescription": "Ibne Abbas ne ek taweel hadees mein riwaayat ki hai. Ek din Nabi-e-Akram (s) Hazrat Fatema (s) ke paas tashreef laaye to dekha keh aap ka chehra zard hai. Aan Hazrat (s) ne sabab daryaaft kiya to arz kiya keh teen (3) din se koi ghiza nahi khaayi. Us waqt ek kamre mein gayi aur Ja-Namaaz bichhaayi aur 2 rakat namaz adaa farmaayi aur haatho’n ko aasmaan ki taraf buland kiya, aur arz kiya…", "UrduDescription": "ابن عباس نے ایک طویل حدیث میں روایت کی ہے۔ ایک دن نبی اکرم حضرت فاطمہ کے پاس تشریف لائے تودیکھا کہ آپ کا چہرہ زرد ہے۔ آنحضرتؐ نے سبب دریافت کیا تو عرض کیا کہ تین دنوں سے کوئی غذا نہیں کھائی۔ اس وقت ایک کمرے میں گئیں اور جائے نماز بچھائی اور ۲ رکعت نماز ادا فرمائی اور ہاتھوں کی ہتھیلیوں کو آسمان کی طرف بلند کیا، اور عرض کیا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, 