[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011717, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, this month of Ramadhan in which You revealed the Qur’an is about to come to its end. I seek refuge with Your Noble Face, O Lord, that it dawns tonight or the month of Ramadhan elapses but I am still liable to an offense or a sin that You want to punish me for committing it when I will meet You.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Yeh Mahe Ramazan ul Mubarak hai jis mein Tu ne Qur’an Kareem naazil farmaaya aur woh mahina khatm ho gaya hai aur panah leta hu mai Teri zaat’e kareem ki. Ay Parwardigaar! Is se keh aaj ki raat khatm ho aur subh ho jaaye ya Ramazan ul Mubarak ka mahina guzar jaaye aur mujh par Teri koi saza baaqi ho ya koi gunah ho keh Tu mujhe us par azaab dena chahta ho jis din mai Tere baargah mein haazir kiya jaawunga.", "Urdu": "اے معبود! یہ ماہ رمضان المبارک ہے جس میں تو نے قرآن کریم نازل فرمایا اور وہ مہینہ ختم ہو گیا ہے اور پناہ حاصل کرتا ہوں میں تیری ذات کریم کی اے پروردگار اس سے کہ آج کی رات ختم ہو اور صبح ہو جائے یا رمضان مبارک کا مہینہ گزر جائے اور مجھ پر تیری کوئی سزا باقی ہو یا کوئی گناہ ہو کہ تو مجھے اس پر عذاب دینا چاہتا ہو جس دن میں پیش ہوں گا۔", "RArabic": "ALAAHUMMA HAAZAA SHAHRO RAMAZAA-NAL LAZEE AN-ZALTA FEE-HIL QUR-AANA WA QAD TASAR-RAMA WA A-O’OZO BE-WAJHE-KAL KAREE-ME YAA RABBE AN YATLO-A’L FAJRO MIN LAIY-LATEE HAAZE-HI AW YATA-SARRA-MA SHAHRO RAMAZAANA WA LAKA QABA-LEE TABE-A’TUN AW ZAMBUN TOREE-DO AN TO-A’ZZE-BANEE BEHI YAWMA AL-QAAKA.", "ArabicText1": "اَللّٰهُمَّ هٰذَا شَهْرُ رَمَضَانَ الَّذِيْ اَنْزَلْتَ فِيْهِ الْقُرْآنَ وَقَدْ تَصَرَّمَ وَاَعُوْذُ بِوَجْهِكَ الْكَرِيْمِ يَا رَبِّ اَنْ يَّطْلُعَ الْفَجْرُ مِنْ لَيْلَتِيْ هٰذِهٖ اَوْ يَتَصَرَّمَ شَهْرُ رَمَضَانَ وَلَكَ قِبَلِيْ تَبِعَةٌ اَوْ ذَنْۢبٌ تُرِيْدُ اَنْ تُعَذِّبَنِيْ بِهٖ يَوْمَ اَلْقَاكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": nu