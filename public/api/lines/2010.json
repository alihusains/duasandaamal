[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018520, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He Who is continuously obedient, the One to ordain destiny the one to reach the heights of the actions, and whispers. I have faith in Him, the one Who turned darkness into light by Your help and illuminated darkness, considered Your power as one of Your signs, tested You by growing, lessening, swallowing, drowing, shining and at eclipse. In all these You were obedient to Allah and strictly followed the commands. How pure is Allah, how much amazing laws He has passed for You. How the wise creation was created by Him and appointed you as a moon for every new month. May Allah appoint you among the safe, and faithful and peaceful moons. That moon from which there is safety from deviation and protection from evils. O Allah! Make me the most guided one among all those upon whom it shone. Make it the most pious for all those who see, and blessings of Allah be on Mohammed (s.a.w.a) and his Progeny (a.s).", "Gujarati": null, "RGujarati": null, "RUrdu": "garda’n (chakkar lagaata) rehta hai. Mai Us zaat par imaan la chuka hu, jis ne Tere zariye taareekiyo’n ko roshan kiya, andhero’n ko munawwar kar diya, Tujhe apni iqtedaar ki nishaaniyo’n mein se ek nishaani qaraar diya. Tujhe badh-ne, ghat-ne, nikal-ne, doob-ne, chamkaane aur gehnaane (grahan) se aazmaaya, tu un tamaam manzilo’n mein Khuda ka mutee (farma’n bardaar), Uske hukm baja laane mein chust o tez hai. Woh Khuda kitna paak hai, kis qadar hairat angez tadbeere’n tere maamle mein farmaayi hai. Kis qadar hakeemaana makhlooq apni saltanat mein paiyda ki, aur Tujhe to Allah naye (new) mahine ke naye waaqe-aat ka chaand banaaya hai. Khuda Tujhe aman o imaan, salaamati aur Islaam ka chaand qaraar de, woh chaand jis mein ruswaaiyo’n se itmeenaan, bad-qaraariyo’n se hifaazat rahe. Khudaaya! Jin par yeh chamka hai un mein se mujhe sab se ziyadah hidaayat yaafta qaraar de, aur usey dekhne waalo’n mein sab se ziyadah paakeezah bana, aur Allah ki rehmate’n ho Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par.", "Urdu": "اے وہ مخلوق جو لگاتار فرماں بردار، تقدیر کی معیّن کردہ منزلوں اور تدبیر کے آسمانوں پر آتا جاتا اور سرگرداں رہتا ہے، میں اس ذات پر ایمان لا چکا ہوں، جس نے تیرے ذریعے تاریکیوں کو روشن کیا، اندھیروں کو منوّر کر دیا، تجھے اپنی اقتدار کی نشانیوں میں سے ایک نشانی قرار دیا۔ تجھے بڑھنے، گھٹنے، نکلنے، ڈوبنے، چمکانے اور گہنانے سے آزمایا، تو ان تمام منزلوں میں خدا کا مطیع، اس کے حکم بجا لانے میں چست و تیز ہے۔ وہ خدا کتنا پاک ہے، کس قدر حیرت انگیز تدبیریں تیرے معاملے میں فرمائی ہیں، کس قدر حکیمانہ مخلوق اپنی سلطنت میں پیدا کی، اور تجھے تو اللہ نئے مہینے کے نئے واقعات کا چاند بنایا ہے۔ خدا تجھے امن و ایمان، سلامتی اور اسلام کا چاند قرار دے، وہ چاند جس میں رسوائیوں سے اطمینان، بدکاریوں سے حفاظت رہے۔ خدایا! جن پر یہ چمکا ہے ان میں سے مجھے سب سے زیادہ ہدایت یافتہ قرار دے، اور اسے دیکھنے والوں میں سب سے زیادہ پاکیزہ بنا، اور اللہ کی رحمتیں ہوں محمدؐ اور آل محمدؑ پر۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَیُّهَا الْخَلْقُ الْمُطِیْعُ الدَّاۗئِبُ السَّرِیْعُ الْمُتَرَدِّدُ فِیْ فَلَكِ التَّدْبِیْرِ الْمُتَصَرِّفُ فِیْ مَنَازِلِ التَّقْدِیْرِ اٰمَنْتُ بِمَنْ نَوَّرَ بِكَ الظُّلَمَ وَاَوْضَحَ بِكَ الْبُهَمَ وَجَعَلَکَ اٰیَۃً مِنْ اٰیَاتِ سُلْطَانِهٖ وَامْتَحَنَكَ بِالزِّیَادَۃِ وَالنُّقْصَانِ وَالطُّلُوْعِ وَالْاُفُوْلِ وَالْاِنَارَۃِ وَالْكُسُوْفِ فِیْ كُلِّ ذٰلِكَ اَنْتَ لَهٗ مُطِیْعٌ وَاِلٰی اِرَادَتِهٖ سَرِیْعٌ سُبْحَانَهٗ مَا اَحْسَنَ مَا دَبَّرَ وَاَتْقَنَ مَا صَنَعَ فِیْ مُلْكِهٖ وَجَعَلَكَ اللهُ هِلَالَ شَهْرٍ حَادِثٍ لِاَمْرٍ حَادِثٍ جَعَلَكَ اللهُ هَلَالَ اَمْنٍ وَاِیْمَانٍ وَسَلَامَۃٍ وَاِسْلَامٍ هِلَالَ اَمَنَۃٍ مِنَ الْعَاهَاتِ وَسَلَامَۃٍ مِنَ السَّیِّئَاتِ۔ اَللّٰهُمَّ اجْعَلْنَا اَهْدٰی مَنْ طَلَعَ عَلَیْهِ وَاَزْكٰی مَنْ نَظَرَ اِلَیْهِ وَصَلَّی اللهُ عَلٰی مُحَمَّدٍ وَّاٰلِهٖ وَافْعَلْ بِیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null