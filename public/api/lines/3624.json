[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016097, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah is great, Allah is great, and praise belongs to Allah; O Allah! I ask Thee the best that Thou knowest, and I take refuge in Thee from the most evil that Thou knowest, and I ask Thee to pardon me all that Thou knowest, truly Thou knowest all that is hidden. There is no god have save Allah, the undoubtedly right lord Muhammad is the Prophet of Allah, the true in his promise, the trustworthy.", "Gujarati": null, "RGujarati": null, "RUrdu": "Allaho Akbar, Allaho Akbar, bas saari hamd usi Allah ke liye hai. Ay Parwardigaar! Mai Tujh se apne liye us khair ka talab-gaar hu jise Tu jaanta hai aur panah talab karta hu us sharr se jise Tu jaanta hai aur isteghfaar karta hu har us cheez se jo Tere ilm mein hai keh Tu hi ghaib ka jaanne waala hai. Koi ma’bood nahi hai siwaaye us Allah ke jis ki farmaan-rawaayi ba-haq aashkaar hai aur Muhammad (s.a.w.a) Allah ke Rasool waade ke sachche aur ameen hai.", "Urdu": "اللہ اکبر، اللہ اکبر بس ساری حمد اسی اللہ کے لئے ہے۔ اے پروردگار!میں تجھ سے اپنے لئے خیر کا طلبگار ہوں جسے توجانتا ہے اور پناہ طلب کرتا ہوں اس شر سے جسے تو جانتا ہے اور استغفار کرتا ہوں ہر اس چیز سے جو تیرے علم میں ہے کہ توہی غیب کا جاننے والا ہے۔ کوئی معبود نہیں ہے سوائے اس اللہ کے جس کی فرمانروائی بہ حق آشکار ہے اور محمدؐ اللہ کے رسول، وعدے کے سچے اور امین ہے۔", "RArabic": "ALLAAHO AKBARO ALLAAHO AKBARO, ALLAAHO AKBARO WA LILLAA-HIL HAMDO, ALLAAHUMMA INNEE AS-ALOKA MIN KHAIRE MAA TA’LAMO, WA A-OO’ZO BEKA MIN SHARRE MAA TA’LAMO, WA AS-TAGH-FERO-KA MIN KULLE MAA TA’LAMO, INNA-KA ANTA A’LLAA-MUL GHOYOO-BE, LAA ILAAHA ILLAL LAAHUL MALE-KUL HAQQUL MOBEE-NO, MOHAMMADUR RASOOLIL LAAHIS SAADEQUL WA’DAL AMEENO.", "ArabicText1": "اَللہُ اَكْبَرُ اَللہُ اَكْبَرُ، اَللہُ اَكْبَرُ وَلِلهِ الْحَمْدُ۔ اَللّٰهُمَّ اِنِّیْ اَسْئَلُكَ مِنْ خَیْرِ مَا تَعْلَمُ، وَاَعُوْذُ بِكَ مِنْ شَرِّ مَا تَعْلَمُ، وَاَسْتَغْفِرُكَ مِنْ كُلِّ مَا تَعْلَمُ، اِنَّكَ اَنْتَ عَلَّامُ الْغُیُوْبِ، لَآ اِلٰهَ اِلَّا اللهُ الْمَلِكُ الْحَقُّ الْمُبِیْنُ، مُحَمَّدٌ رَّسُوْلِ اللهِ الصَّادِقُ الْوَعْدَ الْاَمِیْنُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016098, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! As Thou hast guided me to Islam, I ask Thee not to take it away from me so that when Thou take back my soul I may die and I am a Muslim. O Allah! Let there be light in my heart, and light in my ears, and light in my eyes. O Allah and my Lord! Expand my chest, and make easy my affair, and I take refuge in Thee from the evil of the temptations of the heart and the division of the affairs, and the ordeal of the grave.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar! Mai Tujh se sawaal karta hu keh jaise Tu ne islaam ki jaanib meri rehnumaayi farmaayi hai, marte dam tak mujh se usey na chheen-na, yahan tak-keh meri maut islaam par waaqe ho. Parwardigaar! Mere dil mein ek noor qaraar de aur meri samaa’at mein ek noor qaraar de aur meri basaarat mein ek noor qaraar de. Baar'e Ilaaha! Mere Parwardigaar mere seene (chest) ko kushaadah farma aur mere kaam ko mere liye aasaan kar de. Mai Tujh se panah maangta hu qalb ke was-waso ke sharr se aur kaamo’n ki paraa-gandagi se aur azaab'e qabr ki sakhti se.", "Urdu": "پروردگار! میں تجھ سے سوال کرتا ہوں کہ جیسے تونے اسلام کی جانب میری رہنمائی فرمائی ہے، مرتے دم تک مجھ سے اسے نہ چھیننا، یہاں تک کہ میری موت اسلام پر واقع ہو۔ پروردگار! میرے دل میں ایک نور قرار دے اور میری سماعت میں ایک نور قرار دےاور میری بصارت میں ایک نور قرار دے۔ بار الٰہا! میرے پروردگار میرے سینے کو کشادہ فرما اور میرے کام کو میرے لئے آسان کر دے۔ میں تجھ سے پناہ مانگتا ہوں قلب کے وسوسوں کے شر سے اور کاموں کی پراکند گی سے اور عذابِ قبر سے۔ ", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA KAMAA HADAIY-TANEE LIL-ISLAAME AN LAA TANZE-A’HU MINNEE HATTAA TATA-WAFFAA NEE A’LAIHE WA ANAA MUSLE-MOON. ALLAAHUM-MAJ A’L FEE QALBEE NOORAN, WA FEE SAM-EE’ NOORAN, WA FEE BASA-REE NOORAN. ALLAAHUMMA RAB-BISH RAHLEE SADREE WA YASSIR LEE AMREE, WA A-OO’ZO BEKA MIN SHARRE WA SAAWE-SIS SADRE WA SHATAA-TIL AMRE, WA FITNA-TIL QABRE.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَسْئَلُكَ كَمَا هَدَیْتَنِیْ لِلْاِسْلَامِ اَنْ لَا تَنْزِعَهٗ مِنِّیْ حَتّٰی تَتَوَفَّا نِیْ عَلَیْهِ وَاَنَا مُسْلِمٌ۔ اَللّٰهُمَّ اجْعَلْ فِیْ قَلْبِیْ نُوْرًا، وَفِیْ سَمْعِیْ نُوْرًا، وَفِیْ بَصَرِیْ نُوْرًا۔ اَللّٰهُمَّ رَبِّ اشْرَحْ لِیْ صَدْرِیْ وَیَسِّرْ لَیْ اَمْرِیْ، وَاَعُوْذُ بِكَ مِنْ شَرِّ وَسَاوِسِ الصَّدْرِ وَشَتَاتِ الْاَمْرِ، وَفِتْنَۃِ الْقَبْرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016099, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I take refuge in Thee from the evil that enters the night and the evil that enters the day, and all evil that the winds come with, surely Thou art the most Merciful. O Allah! Glory be to Thee, truly we have not worshiped Thee as Thou must be worshipped. O Allah! Glory be to Thee, truly we have not remembered Thee as Thou must be remembered. O Lord! Forgive and have mercy and pardon and be gracious and excuse what Thou knowest, surely Thou knowest what we do not know, verily Thou art Allah, the All-mighty, the most Generous.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baar'e Ilaaha! Mai har us sharr se Teri panah talab karta hu jo raat ko aata hai aur har us sharr se jo din ko aata hai aur us (sharr) se jiske sabab balaawo’n ki hawaaye’n chalti hai. Ay sabse ziyadah rahem karne waale! Paak o munazzah hai Tu. Ham ne us tarah Teri ibaadat nahi ki jis tarah Teri ibaadat ka haq tha. Ay Allah! Paak hai Tu ham ne us tarah Tujhe yaad nahi rakkha jaisa Tujhe yaad karne ka haq tha. Ay Allah, Ay Parwardigaar! Hamein Maaf kar de, ham par rahem farma, hamein bakhsh de aur un cheezo’n se dar-guzar farma jinhe Tu ne ham mein paaya hai kyu’n keh Tu woh kuchh jaanta hai jo ham nahi jaante keh Tu intehaayi saaheb'e izzat aur buzurg-waar hai.", "Urdu": "بارالٰہا! میں ہر اس شر سے تیری پناہ طلب کرتا ہوں جو رات کو آتا ہے اور ہر اس شر سے جو دن کو آتا ہے اور اس (شر) سے جس کے سبب بلاؤں کی ہوائیں چلتی ہیں۔ اے سب سے زیادہ رحم کرنے والے! پاک و منزہ ہے تو،ہم نے اس طرح تیری عبادت نہیں کی جس طرح تیری عبادت کا حق تھا۔ اے اللہ! پاک ہے تو ہم نے اس طرح تجھے یاد نہیں رکھا جیسا تجھے یاد رکھنے کا حق تھا۔ اے اللہ! اے پروردگار! ہمیں معاف کر دے، ہم پر رحم فرما، ہمیں بخش دے اور ان چیزوں سے درگزر فرما، جنہیں تونے ہم میں پایا ہے کیونکہ تو وہ جانتا ہے جو ہم نہیں جانتے کہ تو انتہائی صاحب عزت اور بزرگوار ہے۔ ", "RArabic": "ALLAAHUMMA INNEE A-OO’ZO BEKA MIN SHARRE MAA YALE-JO FIL LAIYLE WA MIN SHARRE MAA YALE-JO FIN-NAHAARE, WA MIN SHARRE MAA TAHA-BO BE-HIR REYAA-HO, YAA AR-HAMAR RAAHE-MEENA. SUBHAANA-KA MAA A’BAD-NAAKA HAQQA E’BAADA-TEKA YAA ALLAAHO. SUBHAANA-KA MAA ZAKAR-NAAKA HAQQA ZIKRE-KA YAA ALLAAHO. RABBIGH FIR WAR-HAM WA’FO WA TA-KARRAM WA TAJAA-WAZ A’MMAA TA’LAMO, INNA-KA TA’LAMO MAA LAA NA’LAMO, INNA-KA ANTAL LAAHUL A-A’ZZUL AKRAMO.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَعُوْذُ بِكَ مِنْ شَرِّ مَا یَلِجُ فِا الَّیْلِ وَمِنْ شَرِّ مَا یَلِجُ فِیْ النَّهَارِ، وَمِنْ شَرِّ مَا تَهَبُ بِهِ الرِّیَاحُ، یَا اَرْحَمَ الرَّاحِمِیْنَ، سُبْحَانَكَ مَا عَبَدْنَاكَ حَقَّ عِبَادَتِكَ یَا اَللهُ، سُبْحَانَكَ مَا ذَكَرْنَاكَ حَقَّ ذِكْرِكَ یَا اَللهُ، رَبِّ اغْفِرْ وَارْحَمْ وَاعْفُ وَتَكَرَّمْ وَتَجَاوَزْ عَمَّا تَعْلَمُ، اِنَّكَ تَعْلَمُ مَا لَا نَعْلَمُ، اِنَّكَ اَنْتَ اللهُ الْاَعَزُّ الْاَكْرَمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1003199, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 158, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Surely the Safa and the Marwa are among the signs appointed by Allah; so whoever makes a pilgrEnglishImage to the House or pays a visit (to it), there is no blame on him if he goes round them both; and whoever does good spontaneously, then surely Allah is Grateful, Knowing.", "Gujarati": null, "RGujarati": null, "RUrdu": "Be-shak Safa aur Marwa dono pahaadiya Allah ki nishaniyo’n mein se hai lehaaza jo shakhs bhi hajj ya umrah kare uske liye koi harj nahi hai keh un dono pahaadiyo’n ka chakkar lagaaye aur jo mazeed khair karega to Khuda uske amal ka qadr-daan aur us se khoob waaqif hai.", "Urdu": "بے شک صفا اور مروہ دونوں پہاڑیاں اللہ کی نشانیوں میں ہیں لہٰذاجو شخص بھی حج یا عمرہ کرے اس کے لئے کوئی حرج نہیں ہے کہ ان دونوں پہاڑیوں کا چکر لگائے اور جو مزید خیر کرے گا تو خدا اس کے عمل کا قدر دان اوراس سے خوب واقف ہے۔", "RArabic": "INNAS SAFAA WAL-MARWATA MIN SHA’AAA’IRIL LAAHI FAMAN HAJJAL BAITA AWI’TAMARA FALAA JUNAAHA ’ALAIHI AI YATTAWWAFA BIHIMAA; WA MAN TATAWWA’A KHAIRAN FA INNAL LAAHA SHAAKIRUN’ALEEM.", "ArabicText1": "اِنَّ الصَّفَا وَالْمَرْوَةَ مِنْ شَعَآئِرِ اللهِ", 