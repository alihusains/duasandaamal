[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012997, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on you, O son of the Messenger of the Lord of the Worlds! Peace be on you, O son of the Commander of the Believers! Peace be on you, O son of Fatima, the luminous lady! Peace be on you, O beloved of Allah! Peace be on you, O choice of Allah! Peace be on you, O trustee of Allah!", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay Rasool'e Khuda (s.a.w.a) ke farzand. Salaam ho aap par ay Nabiye Khuda ke farzand. Salaam ho aap par ay Ameerul Momeneen (a.s) ke farzand. Salaam ho aap par ay Fatema Zahra (s.a) ke farzand. Salaam ho aap par ay Khadijatul Kubra (s.a.) ke farzand Salaam ho aap par ay Allah ke habib. Salaam ho aap par ay Khuda ke bar-guzidah. Salaam ho aap par ay Khuda ke ameen.", "Urdu": "سلام ہو آپ پر اے رسول خداؐ کے فرزند، سلام ہو آپ پر اے نبی خداؐ کے فرزند، سلام ہو آپ پر اے امیر المومنینؑ کے فرزند، سلام ہو آپ پر اے فاطمہ زہراؑ کے فرزند، سلام ہو آپ پر اے خدیجۃ الکبریٰ کے فرزند، سلام ہو آپ پر اے اللہ کے حبیب، سلام ہو آپ پر اے خدا کے برگزیدہ، سلام ہو آپ پر اے خداکے امین۔", "RArabic": "ASSALAAMO A’LAYKA YABNA RASOOLIL LAAHE ASSALAAMO A’LAYKA YABNA NABIYYIL LAAHE ASSALAAMO A’LAYKA YABNA AMEERIL MOA-MENEENA ASSALAAMO A’LAYKA YABNA FAATEMATAZ ZAHRAAA-E ASSALAAMO A’LAYKA YABNA KHADEEJATAL KUBRAA ASSALAAMO A’LAYKA YAA HABEEBAL LAAHE ASSALAAMO A’LAYKA YAA SAFWATAL LAAHE ASSALAAMO A’LAYKA YAA AMEENAL LAAHE.", "ArabicText1": "اَلسَّلَامُ عَلَيْكَ يَابْنَ رَسُوْلِ رَبِّ لْعَالَمِيْنَ۔ اَلسَّلَامُ عَلَيْكَ يَابْنَ اَمِيْرِ الْمُؤْمِنِيْنَ۔ اَلسَّلَامُ عَلَيْكَ يَابْنَ فَاطِمَةَ الزَّهْرَاءِ۔ اَلسَّلَامُ عَلَيْكَ يَا حَبِيْبَ اللهِ۔ اَلسَّلَامُ عَلَيْكَ يَا صِفْوَةَ اللهِ۔ اَلسَّلَامُ عَلَيْكَ يَا اَمِيْنَ اللهِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012998, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on you, O Argument of Allah! Peace be on you, O Light of Allah! Peace be on you, O Path of Allah! Peace be on you, O elucidation of the rule of Allah! Peace be on you, O supporter of the religion of Allah! Peace be on you, O pure master!", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay Hujjat’e Khuda. Salaam ho aap par ay Allah ke noor. Salaam ho aap par ay seerat’e mustaqeem. Salaam ho aap par ay hikmat’e Khuda ki zabaan. Salaam ho aap par ay deen’e Khuda ke naasir. Salaam ho aap par ay sayyad o sardaar aur paakeeza.", "Urdu": "سلام ہو آپ پر اے حجّتِ خدا، سلام ہو آپ پر اے اللہ کے نور، سلام ہو آپ پر اے صراطِ مستقیم، سلام ہو آپ پر اے حکمتِ خدا کی زبان، سلام ہو آپ پر اے دین خدا کے ناصر، سلام ہو آپ پر اے سیّد و سردار اور پاکیزہ۔", "RArabic": "ASSALAAMO A’LAYKA YAA HUJJATAL LAAHE ASSALAAMO A’LAYKA YAA NOORAL LAAHE ASSALAAMO A’LAYKA YAA SERAATAL LAAHE ASSALAAMO A’LAYKA YAA LESAANA HIKMATIL LAAHE ASSALAAMO A’LAYKA YAA NAASERA DEENIL LAAHE ASSALAAMO A’LAYKA AYYOHAS SAYYEDUZ ZAKIYYO.", "ArabicText1": "اَلسَّلَامُ عَلَيْكَ يَا حُجَّةَ ا