[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011710, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I rely on my Chief whom no one can suppress. I rely on the powerful one whom none can subdue. I rely on the powerful and the merciful one who is watching my movements in my standings and prostrations among all those who prostrate. I rely on the one who is living who never dies and I have relied on one in whose control all the creatures are. I have relied on the living one who is not the one to make haste. I have relied on the deity who is never unjust. I relied on the needless who begets not nor is He begotten. I relied on One, the powerful, the subduer, the High and the needless.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai ne aise sardaar par bharosa kiya keh jise koi maghloob (shikast) nahin kar sakta. Mai ne aise zabardast par bharosa kiya jise koi maamur nahin kar (hukm nahin de) sakta. Mai ne aise maher-baan o zabardast par bharosa kiya jiske liye maut nahin. Mai ne Us par bharosa kiya tamaam bande jiske qabze qudrat mein hai. Mai ne us zindagi waale par bharosa kiya jo jald-baaz nahin. Mai ne us Ma’bood par tawakkul kiya jo zulm nahin karta. Mai ne Us be-neyaaz par bharosa kiya jiski na koi aulaad hai aur na yeh kisi se paiyda huwa. Qudrat waale, ghalbe waale, buzurg martaba, be-neyaaz par mai ne bharosa kiya.", "Urdu": "میں نے ایسے سردار پر بھروسہ کیا کہ جسے کوئی مغلوب نہیں کر سکتا۔ میں نے ایسے زبردست پر بھروسہ کیا جس کو مامور نہیں کر سکتا۔ میں ایسے مہربان و زبردست پر بھروسہ کیا جس کے لئے موت نہیں۔ میں نے اس پر بھروسہ کیا تمام بندے جس کے قبضہ قدرت میں ہے۔ میں نے اس زندگی والے پر بھروسہ کیا جو جلد باز نہیں۔ میں نے اس معبود پر توکل کیا جو زلم نہیں کرتا۔ میں نے اس بے نیاز پر بھروسہ کیا جس کی نہ کوئی اولاد ہے اور نہ یہ کسی سے پیدا ہوا۔ قدرت والے، غلبہ والے، بزرگ مرتبہ، بے نیاز پر میں نے بھروسہ کیا۔", "RArabic": "TAWAKKAL-TO A’LAS SAIYYE-DIL LAZEE LAA YAGH-LEBO-HU AHA-DOON. TAWAKKAL-TO A’LAL JABBAA-RIL LAZEE LAA YAQ-HARO-HU AHA-DOON. TAWAKKAL-TO A’LAL A’ZEE-ZIR RAHEE-MIL LAZEE YARAA-NEE HEENA A-QOOMO WA TA-QALLO-BEE FIS-SAAJE-DEENA. TAWAKKAL-TO A’LAL HAIYYIL LAZEE LAA YAMOO-TO. TAWAKKAL-TO A’LAA MAM-BE-YADE-HI NAWAASE-UL E’BAADE. TAWAKKAL-TO A’LAL HAIYYIL LAZEE LAA YA’JALO. TAWAKKAL-TO A’LAL A’BOO-DIL LAZEE YAJOO-RO. TAWAKKAL-TO A’LAS SAMA-DIL LAZEE LAM YALID WA LAM YOOLAD. TAWAKKAL-TO A’LAL QAADE-RIL QAAHE-RIL A’LIY-YIS SAMADE.", "ArabicText1": "تَوَکَّلْتُ عَلَی السَّیِّدِ الَّذِیْ لَا یَغْلِبُہٗ اَحَدٌ۔ تَوَکَّلْتُ عَلَی الْجَبَّارِالَّذِیْ لَا یَقْھَرُہٗ اَحَدٌ۔ تَوَکَّلْتُ عَلَی الْعَزِیْزِ الرَّحِیْمِ الَّذِیْ یَرَانِیْ حِیْنَ اَقُوْمُ وَتَقَلُّبِیْ فِی السَّاجِدِیْنَ۔ تَوَکَّلْتُ عَلَی الْحَیِّ الَّذِیْ لَا یَمُوْتُ۔ تَوَکَّلْتُ عَلٰی مَنْۢ بِیَدِہٖ نَوَاصِیُ الْعِبَادِ۔ تَوَکَّلْتُ عَلَی الْحَیِّ الَّذِیْ لَا یَعْجَلُ۔ تَوَکَّلْتُ عَلَی الْمَعْبُوْدِ الَّذِیْ لَا یَجُوْرُ۔ تَوَکَّلْتُ عَلَی الصَّمَدِ الَّذِیْ لَمْ یَلِدْ وَلَمْ یُوْلَدُ۔ تَوَکَّلْتُ عَلَی الْقَادِرِ الْقَاہِرِ الْعَلِیِّ الصَّمَدِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "A