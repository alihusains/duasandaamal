ai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1021168, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda wanda! Mai Tujh se is liye sawaal karta hu keh Tu hi hamaara Ma’bood hai. Ay zindah aur ay aalam ko sanbhaal-ne (universe ko maintain karne) waale, pas Tu hi (Khuda) hai, Tu paak o paakeezah hai, Tu hi aasmaano aur zameeno ka noor hai, Tu hi ghaib aur saamne ki baato’n ka jaanne waala hai, Tu hi buzurg o bartar hai, Tu hi mannaan (ataa karne waala) (aur) azmat o buzurgi ka maalik hai. (Khudaaya) Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur hamaare in dili maqsado’n ko pura farma.", "Urdu": "خداوندا میں تجھ سے اس لئے سوال کرتا ہوں کہ تو ہی ہمارا معبود ہے، اے زندہ اور اے عالم کو سنبھالنے والے بس تو ہی (خدا) ہے، تو پاک و پاکیزہ ہے، تو ہی آسمانوں اور زمینوں کا نور ہے، تو ہی غیب اور سامنے کی باتوں کا جاننے والا ہے، تو ہی بزرگ (اور) برتر ہے، تو ہی منان (اور) عظمت و بزرگی کا مالک ہے، (خدایا) محمدؐ و آل محمدؑ پر رحمت نازل فرما اور ہمارے ان دلی مقاصد کو پورا فرما۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA BE-ANNA-KA ANTAL LAAHE LAA ILAAHA ILLAA ANTAL HAYYUL QAYYOOMO AT-TAAHE-RUL MOTAH-HARO NOO-RUS SAMAA-WAATE WAL AR-ZEENA A’ALE-MUL GHAI-BE WASH-SHAHAA-DATIL KABEE-RUL MOTA-A’A-LIL MANNAA-NO ZUL-JALAALE WAL-IKRAA-ME AN TO-SALLE-YA A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA AN TAF-A’L BEE KAZAA WA KAZAA.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْٓ اَسْئَلُكَ بِاَنَّكَ اَنْتَ اللهِ لَآ اِلٰهَ اِلَّآ اَنْتَ الْحَیُّ الْقِیُّوْمُ اَلطَّاهِرُ الْمُطَهَّرُ نُوْرُ السَّمٰوٰتِ وَالْاَرْضِیْنَ عَالِمُ الْغَیْبِ وَالشَّهَادَۃِ الْكَبِیْرُ الْمُتَعَالِ الْمَنَّانُ ذُواالْجَلَالِ وَالْاِكْرَامِ اَنْ تُصَلِّیَ عَلٰی مُهَمَّدٍ وَّآلِ مُحَمَّدٍ وَاَنْ تَفْعَلْ بِیْ كَذَا وَكَذَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19"