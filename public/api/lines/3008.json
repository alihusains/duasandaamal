[{"Id": 1013071, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Haleemah Sadiyyah was the foster mother of the Holy Prophet (s). She took the Holy Prophet (s) from his grandfather, Abdul Muttalib (a) to her tribe outside Mecca. She nursed him and brought him up there. She was a very kind and affectionate lady. She had the esteemed honour of being the foster mother of the Messenger of Allah (s). The Holy Prophet (s) also used to respect her. The Ziyarat of this respectable lady is recited in the following words…", "GujaratiDescription": null, "RUrduDescription": "Haleemah sadiyyah, Rasool-e-Khuda ki daaya thi, jinho ne Rasool (s) ko dudh pilaaya tha. Woh Rasool (s) ko unke Jadd Abdul Muttalib (a) se apne qabile le gayi. Unho ne Rasool (s) ko dudh pilaaya aur unki achchi khidmat ki. Woh Rasool (s) ko bohot chahati thi aur Rasool (s) bhi unka ehteraam kiya karte thay. Is mohatarma ki ziyarat is tarah se hai…", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10":