gn7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000140, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Him who does not treat the citizens of His Kingdom unjustly and harshly, Glory be to Him who does not let torment and pain come suddenly upon mankind, Glory be to the Compassionate, the Merciful. O Allah fill my heart and mind with true enlightenment, discerning intelligence, quick understanding and knowledge, Verily Thou art able to do all things.", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak o monazzah (be-aiyb) hai woh zaat jo apne ahle-mamlekat (hukumat mein rehne waalo’n) par zulm o sitam (ziyadati) nahi karta. Paak o monazzah hai woh zaat jo ahle-zameen ko mukhtalif qism ke azaab mein mubtela nahi karta. Paak o monazzah hai woh zaat jo rauf (shafeeq) o rahim hai. Ay Mabood! Tu mere dil mein noor o baseerat (maarefat) aur fahem (samajh) o ilm ataa farma. Be-shak Tu har shai par qaadir hai.", "Urdu": "پاک ہے وہ خد اجو اپنی مملکت میں رہنے والوں پر زیادتی نہیں کرتا، پاک ہے وہ خدا جو طرح طرح کے عذاب سے اہل ِزمین پر گرفت نہیں کرتا۔پاک ہے وہ خدا جو مہربان رحم کرنے والا ہے۔اے معبود!میرے قلب میں نور، بصیرت، فہم اور علم کو جگہ دے بے شک تو ہر چیز پر قدرت رکھنے والا ہے۔ ", "RArabic": "SUBHAANA MAN LAA YA’TADEE A’LAA AHLE MAMLAKATE-HI SUBHAANA MAN LAA YA’KHOZO AHLAL ARZE BE ALWAANIL A’ZAA-BE SUBHAANAR RAOO-FUR RAHEEM. ALLAAHUMMAJ-A’L FEE QALBEE NOORAWN WA BASARAWN WA FAHMAWN WA I’LMAA INNAKA A’LAA KULLE SHAI-IN QADEER.", "ArabicText1": "سُبْحَانَ مَنْ لَّا یَعْتَدِیْ عَلٰی اَھْلِ مَمْلَکَتِہٖ سُبْحَانَ مَنْ لَّایَاخُذُ اَھْلَ الْاَرْضِ بِاَلْوَاْنِ الْعَذَاْبِ سُبْحَاْنَ الرَّؤُفِ الرَّحِیْمِ۔ اَللّٰھُمَّ اجْعَلْ لِّیْ فِیْ قَلْبِیْ نُوْرًا وَّبَصَرًا وَّفَھْمًا وَّعِلْمًا اِنَّکَ عَلٰی کُلِّ شَىْٓءٍ قَدِیْرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicB