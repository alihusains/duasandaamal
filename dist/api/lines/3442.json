rabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012657, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Aur Tere liye hamd hai Tere bohot ziyadah ehsaan par, Teri josh maarti khair par, Teri taraf se aasaan fareeze (ahkaam) par aur tangi dur rakhne par, aur Tere liye hamd hai ay Rab keh Tu thode se shukr ka phal (ajr) deta hai, Tere liye hamd hai keh ziyadah ajr ataa karta hai, gunaho’n ka bojh utaar deta hai, be-mauqe sa uzr (excuse) bhi qabool karta hai, Tu sakht fareeze ka bojh utaar-ta hai, Tu dushwaari ke maqaam ko aasaan karta hai aur dil hila dene waale umoor ko roke huwe hai.", "Urdu": "اور تیرے لئے حمد ہے تیرے بہت زیادہ احسان پر تیری جوش مارتی خیر پر تیری طرف سے آسان فریضے پر اور تنگی دور رکھنے پر اور تیرے لئے حمد ہے اے رب کہ توتھوڑے سے شکر کا پھل دیتا ہے تیرے لئے حمد ہے کہ زیادہ اجر عطا کرتا ہے گناہوں کا بوجھ اتار دیتا ہے بے موقع سا عذر بھی قبول کرتا ہے تو سخت فریضے کا بوجھ اتارتا ہے تو دشواری کے مقام کو آسان کرتا ہے اوردل ہلا دینے والے امور کو روکے ہوئے ہے۔", "RArabic": null, "ArabicText1": "وَلَكَ الْحَمْدُ عَلٰى اِحْسَانِكَ الْكَثِيْرِ وَخَيْرِكَ الْغَزِيْرِ وَتَكْلِيْفِكَ الْيَسِيْرِ وَدَفْعِ الْعَسِيْرِ وَلَكَ الْحَمْدُ يَا رَبِّ عَلٰى تَثْمِيْرِكَ قَلِيْلَ الشُّكْرِ وَاِعْطَاۗئِكَ وَافِرَ الْاَجْرِ وَحَطِّكَ مُثْقَلَ الْوِزْرِ وَقَبُوْلِكَ ضَيِّقَ الْعُذْرِ وَ وَضْعِكَ بَاهِضَ الْاِصْرِ وَتَسْهِيْلِكَ مَوْضِعَ الْوَعْرِ وَمَنْعِكَ مُفْظِعَ الْاَمْرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012658, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Tere liye hamd hai us par jo bala tal chuki hai, neyki mein izaafe par, khouf dur hone par, sar-kashi ko raam karne (rokne) par, aur Tere liye hamd hai kam fariza aaed (laazim) karne par aur us mein ziyadah kami karne par, kamzor ko quwwat dene par aur be-kasi ki faryaad-rasi par.", "Urdu": "تیرے لئے حمد ہے اس پر جو بلا ٹل چکی ہے نیکی میں اضافے پر خوف دور ہونے پر سر کشی کو رام کرنے پر اور تیرے لئے حمد ہے کم فریضہ عائد کرنے پر اور اس میں زیادہ کمی کرنے پر کمزور کو قوت دینے پراور بے کس کی فریاد رسی پر۔", "RArabic": null, "ArabicText1": "وَلَكَ الْحَمْدُ عَلَى الْبَلَّاءِ الْمَصْرُوْفِ وَ وَافِرِ الْمَعْرُوْفِ وَدَفْعِ الْمَخُوْفِ وَاِذْلَالِ الْعَسُوْفِ وَلَكَ الْحَمْدُ عَلٰى قِلَّةِ التَّكْلِيْفِ وَكَثْرَةِ التَّخْفِيْفِ وَتَقْوِيَةِ الضَّعِيْفِ وَاِغَاثَةِ اللَّهِيْفِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "Arabi