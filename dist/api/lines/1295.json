abicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000466, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, what thinkest Thou? Wilt Thou chastise me after my faith in Thee, drive me far away after my love for Thee, deprive me while I hope for Thy mercy and forgiveness, forsake me while I seek sanctuary in Thy pardon? How could Thy generous face disappoint me?! Would that I knew - Did my mother bear me for wretchedness? Did she nurture me for suffering? Would then that she had not borne me and had not nurtured me!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Mere Mabood! Kya Tujhe aisa samjhu keh Tujh par imaan rakhne ke ba-wujood mujhe azaab dega. Ya Tujh se mohabbat karu tab bhi mujhe apne se dur karega. Ya Teri rehmat o chashm-poshi (ignore) ki ummeed rakkhu to bhi mehroom karega. Ya Tere afvo ki panah lu to bhi mujhe aag ke hawaale karega. Nahi! Teri zaat karim hai. Bayeed (na-mumkeen) hai keh Tu mujhe na-ummeed kare, Ay kaash mai jaan sakta keh, aaya meri maa ne mujhe bad-bakhti ke liye janm diya ya dukh ke liye paala. Kaash woh mujhe janm (birth) na di hoti aur na paali hoti.", "Urdu": "خدا کے نام سے شروع جو بڑا مہربان نہایت رحم والا ہے۔میرے معبود! کیا تجھے ایسا سمجھوں کہ تجھ پر ایمان رکھنے کے باوجود مجھے عذاب دے گا یا تجھ سے محبت کروں تو بھی مجھے دورکرے گویا تیری رحمت و درگزرکرنے کی امید رکھوں تو بھی محروم کرے گا یا تیرے عفوودرگزروبخشش کی پناہ لوں تو بھی مجھے آگ کے سپرد کرے گانہیں تیری ذات کریم ہے بعید ہے کہ مجھے نا امید کرے کاش میں جان سکتا کہ آیا میری ماں نے مجھے بدبختی کے لئے جنا یا دکھ کے لئے پالا کاش وہ مجھے نہ جنتی اور مجھے نہ پالتی۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اِلٰهِىْ اَتَرَاكَ بَعْدَ الْاِيْمَانِ بِكَ تُعَذِّبُنِىْ اَمْ بَعْدَ حُبِّىْٓ اِيَّاكَ تُبَعِّدُنِىْ اَمْ مَعَ رَجَآئِىْ لِرَحْمَتِكَ وَصَفْحِكَ تَحْرِمُنِىْ اَمْ مَعَ اسْتِجَارَتِىْ بِعَفْوِكَ تُسْلِمُنِىْ حَاشَا لِوَجْهِكَ الْكَرِيْمِ اَنْ تُخَيِّبَنِىْ لَيْتَ شِعْرِىْ اَ لِلشَّقَآءِ وَلَدَتْنِىْ اُمِّىْ اَمْ لِلْعَنَآءِ رَبَّتْنِىْ فَلَيْتَهَا لَمْ تَلِدْنِىْ وَلَمْ تُرَبِّنِىْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012333, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Would that I had knowledge - Hast Thou appointed me one of the people of felicity? Hast Thou singled me out for Thy nearness and neighborhood? Then would my eyes be gladdened, and in that my soul reach serenity. My God, dost Thou blacken faces which fall down in prostration before Thy mightiness? Dost Thou strike dumb tongues which speak in laudation of Thy glory and majesty?", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur kaash mujhe yeh ilm hota keh, aaya Tu ne mujhe nek-bakhto’n (khush-naseebo’n) mein qaraar diya. Aur qurb o nazdiki ke liye mujhe khaas kiya hai. To us se meri aankhe’n roshan aur dil mutmaeen ho jaata. Mere Mabood! Aaya (kya) Tu un chehro’n ko siyaah (kaala) kar dega jo Teri azmat ko sajdeh karte hai. Ya un zabaano ko gungh (dumb) karega jo Teri unchi shaan aur jalaalat ki taarif mein tar (naatiq) hai.", "Urdu": "اور کاش مجھے یہ علم ہوتا کہ آیاتو نے مجھے نیک بختوں میں قرار دیا اور قربت و نزدیکی کے لئے مجھے خاص کیا ہے تو اس سے میری آنکھیں روشن اور دل مطمئن ہوجاتا میرے معبود آیا توان چہروں کو سیاہ کردے گا جو تیری عظمت کو سجدے کرتے ہیں یا ان زبانوں کو گنگ کرے گا جو تیری اونچی شان اور جلالت کی تعریف میں تر ہیں۔", "RArabic": null, "ArabicText1": "وَلَيْتَنِىْ عَلِمْتُ اَ مِنْ اَهْلِ السَّعَادَةِ جَعَلْتَنِىْ وَبِقُرْبِكَ وَجِوَارِكَ خَصَصْتَنِىْ فَتَقَرَّ بِذٰلِكَ عَيْنِىْ وَتَطْمَئِنَّ لَهٗ نَفْسِىْ۔ اِلٰهِىْ هَلْ تُسَوِّدُ وُجُوْهًا خَرَّتْ سَاجِدَةً لِعَظَمَتِكَ اَوْ تُخْرِسُ اَلْسِنَةً نَطَقَتْ بِالثَّنَآءِ عَلٰى مَجْدِكَ وَجَلَالَتِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012334, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Dost Thou seal hearts which harbor Thy love? Dost Thou deafen ears which take pleasure in hearing Thy remembrance according to Thy will? Dost Thou manacle hands which expectations have raised to Thee in hope of Thy clemency? Dost Thou punish bodies which worked to obey Thee until they grew thin in struggling for Thee? Dost Thou chastise legs which ran to worship Thee?", "Gujarati": null, "RGujarati": null, "RUrdu": "Ya un dilo’n par mohar lagaayega jo apne andar Teri mohabbat liye huwe hai. Ya un Kaano (ears) ko behra karega jo Tera zikr soonne ka sharaf haasil karte hai. Ya un haatho’n ko baandhe-ga jin ko Teri rehmat ki ummeed ne Tere huzoor phailaaya hai. Ya un badano (jismo) ko azaab dega jinho’n ne Teri ita’at ki. Yahan tak keh us koshish mein laagar (kamzor/weak) ho gaye. Ya un paawo’n ko azaab mein daal dega jo Teri ibaadat ke liye daudte-bhaagte hai.", "Urdu": "یا ان دلوں پر مہر لگائے گا جو اپنے اندر تیری محبت لئے ہوئے ہیں یا ان کانوں کو بہرا کرے گاجو تیرا ذکر سننے کا شرف حاصل کرتے ہیں یاان ہاتھوں کو باندھے گاجن کو تیری رحمت کی امید نے تیرے حضور پھیلایا ہے یا ان بدنوں کوعذاب دے گا جنہوں نے تیری اطاعت کی حتیٰ کہ اس کوشش میں لاغر ہوگئے یا ان پاؤں کو عذاب کرے گا جو عبادت کے لئے دوڑتے ہیں۔", "RArabic": null, "ArabicText1": "اَوْ تَطْبَعُ عَلٰى قُلُوْبٍ انْطَوَتْ عَلٰى مَحَبَّتِكَ اَوْ تُضِمُ اَسْمَاعًا تَلَذَّذَتْ بِسِمَاعِ ذِكْرِكَ فِىْٓ اِرَادَتِكَ اَوْ تَغُلُّ اَكُفًّا رَفَعَتْهَا الْآمَالُ اِلَيْكَ رَجَآءَ رَافَتِكَ اَوْ تُعَاقِبُ اَبْدَانًا عَمِلَتْ بِطَاعَتِكَ حَتّٰى نَحِلَتْ فِىْ مُجَاهَدَتِكَ اَوْ تُعَذِّبُ اَرْجُلًا سَعَتْ فِىْ عِبَادَتِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012335, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, lock not toward those who profess Thy Unity the doors of Thy mercy, and veil not those who yearn for Thee from looking upon the vision of Thy beauty! My God, a soul which Thou hast exalted by its professing Thy Unity - how wilt Thou burn it in the heat of Thy fires?", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Mabood! Un par apne rehmat ke darwaaze bandh na kar jo Tere tauhid-parast hai. Aur jo Tera shauq’e didaar rakhte hai unko apni tajalliyo’n par nazar karne se mehroom na karna. Mere Mabood! Jis jaan ko Tu ne apni tauhid par imaan ki izzat di kyu’n kar usey hijr (judaayi) ki ehaanat se zaleel karega. Aur jis dil mein Teri mohabbat samaayi huwi hai usko Apni aag ki tapish mein kis-tarah jalaayega.", "Urdu": "میرے معبود جو تیری توحید کے پرستار ہیں ان پر رحمت کے دروازے بند نہ کر اور جو تیرا شوق ِدیدار رکھتے ہیں ان کو اپنی تجلیوں پر نظر کرنے سے محروم نہ کرنا میرے معبود جس جان کو تو نے اپنی توحید پر ایمان کی عزّت دی کیوں کراسے اپنی جدائی کی اہانت سے ذلیل کرے گا اور جس دل میں تیری محبت سمائی ہوئی ہے اس کو اپنی آگ کی تپش میں کس طرح جلائے گا۔", "RArabic": null, "ArabicText1": "اِلٰهِىْ لَا تُغْلِقْ عَلٰى مُوَحِّدِيْكَ اَبْوَابَ رَحْمَتِكَ وَلَا تَحْجُبْ مُشْتَاقِيْكَ عَنِ النَّظَرِ اِلٰى جَمِيْلِ رُؤْيَتِكَ۔ اِلٰهِىْ نَفْسٌ اَعْزَزْتَهَا بِتَوْحِيْدِكَ كَيْفَ تُذِلُّهَا بِمَهَانَةِ هِجْرَانِكَ وَ ضَمِيْرٌ انْعَقَدَ عَلٰى مَوَدَّتِكَ كَيْفَ تُحْرِقُهٗ بِحَرَارَةِ نِيْرَانِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012336, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, give me sanctuary from Thy painful wrath and Thy mighty anger! O All-loving, O All-kind! O Compassionate, O Merciful! O Compeller, O Subduer! O All-forgiver, O All-covering! Deliver me through Thy mercy from the chastisement of the Fire and the disgrace of shame when the good are set apart from the evil, forms are transformed, terrors terrify, the good-doers are brought near, the evildoers taken far, and every soul is paid in full what it has earned, and they shall not be wronged.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Mabood! Mujhe dard-naak ghazab aur sakht na-raazgi se bachana. Ay mohabbat waale, ay ehsaan waale, ay maher-baan, ay rahem karne waale, ay zabardast ghalabe waale, ay bakhsh ne waale, ay parda-posh (aiybo’n ko chhupa ne waale) Mujhe apni rehmat se azaab’e Jahannam se najaat de, ruswaai par sharmindaghi se bacha. Jab nek log alag honge boore logo’n se, Jab haalaat digar-goon (boore) hoge, aur khouf o khatra gher lenge, achchhe log qareeb kiye jaayenge, aur boore log dhutkaare jaayenge, aur har nafs ne jo kiya woh pura pura paayega. Aur un par (kisi tarah ka) zulm nahi hoga.", "Urdu": "میرے معبود مجھے دردناک غضب اور سخت ناراضگی سے بچانا اے محبت والے اے احسان والے اے مہربان اے رحم والے اے زبردست اے غلبے والے اے بخشنے والے اے پردہ پوش مجھے اپنی رحمت سے عذاب ِجہنم سے نجات دے رسوائی پر شرمندگی سے بچا جب نیک لوگ الگ ہوں گے برے لوگوں سے جب حالات بدلے ہوں گے اور خوف و خطر گھیر لیںگے اچھے لوگ قریب کیے جائیں گے اور برے لوگ دھتکارے جائیں گے اور ہر نفس نے جو کیا وہ پورا پورا پائے گا اور ان پر ظلم نہیں ہوگا۔", "RArabic": null, "ArabicText1": "اِلٰهِىْ اَجِرْنِىْ مِنْ اَلِيْمِ غَضَبِكَ وَعَظِيْمِ سَخَطِكَ۔ يَاحَنَّانُ يَامَنَّانُ يَارَحِيْمُ يَارَحْمٰنُ يَاجَبَّارُ يَاقَهَّارُ يَاغَفَّارُ يَاسَتَّارُ نَجِّنِىْ بِرَحْمَتِكَ مِنْ عَذَابِ النَّارِ وَفَضِيْحَةِ الْعَارِ اِذَا امْتَازَ الْأَخْيَارُ مِنَ الْأَشْرَارِ وَحَالَتِ الْاَحْوَالُ وَهَالَتِ الْاَهْوَالُ وَقَرُبَ الْمُحْسِنُوْنَ وَبَعُدَ الْمُسِيْئُوْنَ وَوُفِّيَتْ كُلُّ نَفْسٍ مَّا كَسَبَتْ وَهُمْ لَا يُظْلَمُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9":