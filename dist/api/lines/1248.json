[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010030, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah; Send Your blessings upon Your proof on Your earth and Your representative in Your cities, and the one who invites towards Your path and the upright one with Your justice and successful one by Your commands, master of the believers and the destroyer of the apostates and enlightener of darkness and the illuminator of truth.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Rehmat farma zameen mein apni hujjat par aur shahero’n mein apne khalifa o naayab par jo Tere raaste ki taraf bula ne waale, Tere usool'e adl par kaar-band aur Tere hukm se kaamiyaab hai, woh momino ke sar-parast, kaafiro’n ko naabood karne waale, taariki mein roshni karne waale, haq ko ayaa’n karne waale aur daanish mandi, behtareen nasihat aur sachchaayi ke saath farz nibhaane waale hai.", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "ALLAAHUMMA SALLE A’LAA HUJJATEKA FEE ARZEKA WA KHALEEFATEKA FEE BELAADEKAD DAA-E’E ILAA SABEELEKA WAL-QAAA-EME BE-QISTEKA WAL-FAAA-EZE BE-AMREKA WALIYYIL MOMENEENA WA MOBEERIL KAAFEREENA WA MOJALLIZ ZULMATE WA MONEERIL HAQQE WAS-SAA-DE-E’ BIL-HIKMATE WAL-MAW-E’ZATIL HASANATE WAS-SIDQE.", "ArabicText1": "اَللّٰہُمَّ صَلِّی عَلٰی حُجَّتِکَ فِیْ اَرْضِکَ، وَخَلِیْفَتِکَ فِیْ بِلَادِکَ، اَلدّٰاعِیْ اِلٰی سَبِیْلِکَ، وَالْقَآئِمِ الصّٰادِعِ بِالْحِکْمَۃِ، وَالْمَوْعِظَۃِ الْحَسَنَۃِ وَالصِّدْقِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010031, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And the manifestor with wisdom and virtuous exhortations and truth and Your word, Your treasurer and Your eyes in Your earth, the fearful, the awed, the guardian, the admonisher, the ark of salvation and the flag of guidance and (the) light of people’s vision, the best one who will clothe and shroud, the one who will avenge the oppressed, (the) reliever of difficulties, (the) abolisher of sorrows and the eliminator of calamities.", "Gujarati": null, "RGujarati": null, "RUrdu": "Woh Tera kalma, Tera ganjina (khazaana) aur zameen mein Teri chashm-bina hai, woh mehwe (markaz) intezaar hai, harasa’n (dar), khair-khwa, sar-parast, kashti'e najaat, nishan'e hidaayat aur makhluq ki aankho’n ka noor hai woh libaas pehne huwo mein sabse behtar, inteqaam lene waale, mushkil hal karne waale, pareshani dur karne waale aur museebat hataane waale hai.", "Urdu": null, "RArabic": "WA KALEMATEKA WA A’YBATEKA WA A’YNEKA FEE ARZEKAL MOTARAQQEBIL KHAAA-EFIL WALIYYIN NAASEHE SAFEENATIN NAJAATE WA A’LAMIL HODAA WA NOORE ABSAARIL WARAA WA KHAYRE MAN TAQAMMASA WAR-TADAA WAL-WITRIL MAWTOORE WA MOFARREJAL KARBE WA MOZEELIL HAMME WA KAA-SE-FIL BALWAA.", "ArabicText1": "وَکَلِمَتِکَ وَعَیْبَتِکَ وَعَیْنِکَ فِیْ اَرْضِکَ، اَلْمُتَرَقِّبِ الْخَآئِفِ، اَلْوَلِیِّ النَّاصِحِ، سَفِیْنَۃِ النَّجَاۃِ، وَعَلَمِ الْھُدٰی، وَنُوْرِ اَبْصَارِ الْوَرٰی، وَخَیْرِ مَنْ تَقَمَّصَ وَارْتَدٰی، وَالْوِتْرِ الْمَوْتُوْرِ، وَمُفَرِّجِ الْکَرْبِ، وَمُزِیْلِ الْھَمِّ، وَکَاشِفِ الْبَلْوٰی۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010032, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Blessings of Allah be upon him and his fathers, the guiding Imams, the prosperous leaders, till the stars of the dawn shine and the trees bring forth leaves and the fruits ripen and the nights and days follow each other and till the birds sing. O Allah! give us of his love and gather us in his army and beneath his flag. O God of truth, Ameen! Lord of the worlds.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ki rehmate’n ho un par aur unke buzurgaan par jo hidaayat dene waale Imam aur ba-barkat peshwa hai, jab tak subah ke taare’n chamak-te rahe, darakhto’n par patte aate rahe, phal pakte rahe, din aur raat aaghe-peeche hote rahe aur parinde chahe-chahate (whispering karte) rahe. Ay Ma’bood! Hamein unki mohabbat se nafa de aur hamein unke giroh mein aur unke parcham ke niche mehshoor farma, aisa hi ho ay sachche Ma’bood, ay jahano ke Parwardigaar.", "Urdu": null, "RArabic": "SALAWAATUL LAAHE A’LAIHE WA A’LAA AABAA-EHIL A-IMMATIL HAADEENA WAL-QAADATIL MAYAAMEENA WA TA-LA-A’T KAWAAKEBUL AS-HAARE WA AW-RA-QA-TIL ASH-JAARO WA AY-NA-A’TIL ASMAARO WAKH-TALAKAL LAYLO WAN-NAHAARO WA GHARRADATIL ATYAARO ALLAAHUMMAN FA’NAA BE-HUBBEHI WAHSHURNAA FEE ZUMRATEHI WA TAHTA LEWAA-EHI ELAAHAL HAQQE AAMEENA RABBAL A’ALAMEENA.", "ArabicText1": "صَلَوَاتُ اللہِ عَلَیْہِ وَعَلٰی آبَآئِہِ الْاَئِمَّۃِ الْھَادِیْنَ، وَالْقَادَۃِ الْمَیَامِیْنَ، مَاطَلَعَتْ کَوَاکِبُ الْاَسْحَارِ، وَاَوْرَقَتِ الْاَشْجَارُ، وَاَیْنَعَتِ الْاَثْمَارُ، وَاخْتَلَفَ اللَّیْلُ وَالنَّھَارُ، وَغَرَّدَتِ الْاَطْیَارُ۔ اَللّٰہُمَّ انْفَعْنَا بِحُبِّہٖ، وَاحْشُرْنَا فِیْ زُمْرَتِہٖ وَتَحْتَ لِوَآئِہٖ، اِلٰہَ الْحَقِّ آمِیْنَ رَبَّ الْعَالَمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "Guj