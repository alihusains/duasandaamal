[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018460, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I ask You as all the praise belongs to You. There is no lord other than You, You are the one to bestow favours. You are the possessor of honour and majesty for the Heavens and the Earth. I am poor and indigent repent and seek forgiveness. O Allah send blessings on Mohammad and his progeny and forgive all my sins whether they are old or new. All those sins which I have performed. O Allah don't make my problems difficult for me and don't give my enemies an opportunity to mock at me because there is no one other than You to ward off the difficulties and ease the hardships.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ya Allah! Mai Tujh se sawaal karta hu, kyu’n keh hamd Tere hi liye hai, Tere siwa koi ma’bood nahin, Tu hi ehsaan karne waala hai. Tu hi zameeno aur aasmaano ka mujid (banaane waala) aur saaheb’e jalaal o ehsaan hai, mai saael (sawaali) bhi hu faqeer o khouf zadah o panah talab, taubah bhi karta hu aur maghferat bhi talab karta hu. Khudaaya! Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma, aur mere tamaam gunaho’n ko bakhsh de khwah (chahe) woh puraane ho ya naye, gharz har woh gunah jo mai baja laaya hu. Khudaaya! Meri museebat ko ziyadah sakht na banana, mere dushmano ko mujh par hans-ne ka mauqa na dena, kyu’n keh museebato’n ko dur karne aur rokne waala Tere siwa koi nahin.", "Urdu": "یا اللہ! میں تجھ سے سوال کرتا ہوں، کیونکہ حمد تیرے ہی لئے ہے، سوائے تیرے کوئی اللہ نہیں، توہی احسان کرنے والا ہے، توہی زمینوں اور آسمانوں کا موجد اور صاحبِ جلال و احسان ہے، میں سائل بھی ہوں فقیر و خوف زدہ و پناہ طلب، توبہ بھی کرتا ہوں اور مغفرت بھی طلب کرتا ہں۔ خدایا! محمدؐ اور ان کی اولادؑ پر رحمت نازل فرما، اور میرے تمام گناہوں کو بخش دے خواہ وہ پرانے ہوں یا نئے، غرض ہر وہ گناہ جو میں بجا لایا ہوں۔ خدایا! میری مصیبت کو زیادہ سخت نہ بنا، میرے دشمنوں کو مجھ پر ہنسنے کا موقعہ نہ دینا، کیونکہ مصیبتوں کو دور کرنے اور روکنے والا تیرے سوا کوئی نہیں۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَسْئَلُكَ بِاَنَّ لَكَ الْحَمْدُ لَا اِلٰهَ اِلَّا اَنْتَ الْمَنَّانُ بَدِیْعُ السَّمٰوٰتِ وَالْاَرْضِ ذُو الْجَلَالِ وَالْاِكْرَامِ اِنِّیْ سَائِلٌ فَقِیْرٌ وَخَاۗئِفٌ مُسْتَجِیْرٌ وَتَاۗئِبٌ مُسْتَغْفِرٌ۔ اَللّٰھُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاغْفِرْلِیْ ذُنُوْبِیْ كُلَّهَا قَدِیْمَهَا وَحَدِیْثَهَا وَكُلَّ ذَنْۢبٍ اَذْنَبْتُهٗ۔ اَللّٰهُمَّ لَا تَجْتَهَدْ بَلَائِیْ وَلَا تُشْمِتْ بِیْ اَعْدَائِیْ فَاِنَّهٗ لَا دَافِعَ وَلَا مَانِعَ اِلَّا اَنْتَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": nul