[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000260, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O My Allah! Lord of the fleeting frail souls, And perishable bodies! I beseech Thee, In the name of Thy word summoning all of them before Thy court of justice, to hear and learn from them what actually they did; and the whole created beings standing before Thee waiting for Thy decisive judgement, Hoping for Thy mercy, afraid of Thy punishment, to send blessings on Muhammad and on the children of Muhammad, and make me see things clearly and discern, Have sure belief in truth, Remember Thee, day and night, And live a virtuous life, Free of sins.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Tu fanah hone waali rooho’n aur poshida jismo ka paalne waala hai. Mai sawaal karta hu apne jismo ki taraf palat ne waali rooho’n ki bandagi ke waaste se aur apni ragho’n ke saath milne waale jismo ki bandagi ke waaste se aur un mein naafiz hone waale Tere hukm ke waaste se aur un se haq lene ke waaste se jab keh makhluqaat Tere huzoor, Tere atal (final) faisle ki muntazir khadi hogi aur Teri rehmat ki ummeed-waar aur Tere azaab se darti hogi, mera sawaal hai keh Tu Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat farma, meri aankho’n mein noor aur mere dil mein yaqeen paiyda kar de aur Tera zikr shab o roz mein meri zabaan par ho aur mujhe nek amal karne ki taufiq de.", "Urdu": "اے معبود! تو فنا ہونے والی روحوں اور بوسیدہ جسموں کا پالنے والا ہے تجھ سے میں سوال کرتا ہوں اپنے جسموں کی طرف پلٹنے والی روحوں کی بندگی کے واسطے سے اور اپنی رگوں کے ساتھ ملنے والے جسموں کی بندگی کے واسطے سے اور ان میں نافذ ہونے والے تیرے حکم کے واسطے سے اور ان سے حق لینے کے واسطے سے جب کہ مخلوقات تیرے حضور تیرے اٹل فیصلے کی منتظر کھڑی ہوں گی اور تیری رحمت کی اُمیدوار اور تیرے عذاب سے ڈری ہوئی ہوں گی میرا سوال ہے کہ محمدؐ و آلِ محمدؐ پر رحمت فرما میری آنکھوں میں نور اور میرے دل میں یقین پیدا کردے اور تیرا ذکر شب و روز میری زبان پر ہو اور مجھے نیک عمل کرنے کی تو فیق دے۔", "RArabic": "ALLAAHUMMA RABBAL ARWAAHEIL FAANEYATE WAL AJSAADIL BAALEYATE AS-ALOKA BE-TAA-A’TIL ARWAAHIR RAAJE-A’TE ELAA AJSAADEHAA WA BE-TAA-A’TIL AJSAADIL MOL-TA-EMATE BE-O’ROOQEHAA WA BE KALEMATEKAN NAAFEZATE BAYNAHUM WA AKHZEKAL HAQQA MINHUM WAL KHALAAA-EQO BAYNA YADAYKA YANTAZEROONA FASLA QAZAAA-EKA WA YARJOONA RAHMATAKA WA YAKHAAFOONA E’QAAA-BAKA SALLE A’LAA MOHAMMADIWN WA AALE MOHAMMADIWN WAJ-A’LIN NOORA FEE BASAREE WAL YAQEENA FEE QALBEE WA ZIKRAKA BIL-LAYLE WAN NAHAARE A’LAA LESAANEE WA A’MALAN SAALEHAN FAR-ZUQNEE.", "ArabicText1": "اَللّٰهُمَّ رَبَّ الْاَرْوَاحِ الْفَانِيَةِ وَالْاَجْسَادِ الْبَالِيَةِ اَسْاَلُكَ بِطَاعَةِ الْاَرْوَاحِ الرَّاجِعَةِ اِلٰى اَجْسَادِهَا (اَحِبَّآئِهَا) وَبِطَاعَةِ الْاَجْسَادِ الْمُلْتَئِمَةِ بِعُرُوْقِهَا وَبِكَلِمَتِكَ النَّافِذَةِ بَيْنَهُمْ وَاَخْذِكَ الْحَقَّ مِنْهُمْ وَالْخَلَآئِقُ بَيْنَ يَدَيْكَ يَنْتَظِرُوْنَ فَصْلَ قَضَآئِكَ وَيَرْجُوْنَ رَحْمَتَكَ وَيَخَافُوْنَ عِقَابَكَ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَّاجْعَلِ النُّوْرَ فِيْ بَصَرِيْ وَالْيَقِيْنَ فِيْ قَلْبِيْ وَذِكْرَكَ بِاللَّيْلِ وَالنَّهَارِ عَلٰى لِسَانِيْ وَعَمَلًا صَالِحًا فَارْزُقْنِيْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "Arab