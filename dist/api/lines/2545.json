[{"Id": 1012565, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Imam Jafar Sadiq (a) in the book Jamaali Saaleheen said; among our rights on our Shia is that they should place their hands on their chin after the obligatory prayers and recite the following 3 times…", "GujaratiDescription": null, "RUrduDescription": "Kitaab Jamaalis Saaleheen mein Imam Jafar Sadiq (a) se nakal kiya gaya hai keh Hazrat ne farmaaya; hamaare Shio’n par hamaare huqooq mein se ek yeh hai keh har waajib namaz ke baad apne haath se thooddi (chin) ko pakad kar 3 martaba kahe…", "UrduDescription": "کتاب جمال الصالحین میں امام صادقؑ سے نقل ہوا ہے کہ حضرت نے فرمایا: شیعوں پر ہمارا حق یہ ہے کہ ہر واجب نماز کے بعد اپنے ہاتھ سے ٹھڈی پکڑ کر ۳ مرتبہ کہیں۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "