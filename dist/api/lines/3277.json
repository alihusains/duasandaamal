[{"Id": 1014389, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "After completing the Ziyarat one should curse (recite La’nat) on the killers and oppressors of Ahle Bayt (a) in the following way…", "GujaratiDescription": null, "RUrduDescription": "Ziyarat mukammal karne ke baad Ahlebait (a) ke qaatilo’n aur zaalimo par laanat is tarah se bheje…", "UrduDescription": "یہ بات بھی واضح رہنی چاہیے کہ ائمہ ؑکے قاتلوں پر جس زبان میں بھی لعنت کی جائے وہ درست ہے۔ ذیل کے جملے جو بعض دعاؤں سے ماخوذ ہیں اگر ائمہؑ کے قاتلوں پر لعنت کرنے میں یہ جملے دہرائے جائیں تو زیادہ بہتر ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1014390, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, pour curses on the slayers of the Commander of the Faithful, the slayers of Hasan and Husain (a), peace be upon them, and the slayers of the members of Your Prophet’s Household. O Allah, curse the enemies and slayers of Muhammad’s family members, add up chastisement to the chastisement that You decide for them, add up humility to the humility that You decide for them, add up disgrace to the disgrace that You decide for them, and add up ignominy to the ignominy that You decide for them. O Allah, thrust them into Hellfire with disdainful thrusting, cast them down in the painful torment of You with violent casting, and drive them and their followers to Hell in groups.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Ameerul Momeneen (a.s) ke qaatilo’n par laanat bhej aur Hasan (a.s) wa Husain (a.s) ke qaatilo’n par laanat bhej aur apne Nabi ke Ahlebait (a.s) ke qaatilo’n par laanat bhej. Ay Ma’bood! Aale Muhammad (a.s) ke dushmano aur unke qaatilo’n par laanat bhej, unke liye azaab par azaab badha, khwaari par khwaari, zillat par zillat aur ruswaayi par ruswaayi de. Ay Ma’bood! Unko aag mein sakhti se jhonk de aur unhe sakht azaab mein undhe mooh daal de aur unko aur unke pairo-kaaro’n ko Jahannam mein ikhatta kar de.", "Urdu": "اے معبود! امیر المومنینؑ کے قاتلوں پر لعنت بھیج اور حسنؑ و حسینؑ کے قاتلوں پر لعنت بھیج اور اپنے نبیؐ کے اہل بیتؑ کے قاتلوں پر لعنت بھیج اے معبود!آلؑ محمدؐ کے دشمنوں اور ان کے قاتلوں پر لعنت بھیج ان کے لئے عذاب پر عذاب بڑھا خواری پر خواری ذلت پر ذلت اور رسوائی پر رسوائی دے اے معبود! ان کو آگ میں سختی سے جھونک دے اور انہیں سخت عذاب میں اوندھے منہ ڈال دے اور ان کو اور ان کے پیروکاروں کو جہنم میں اکٹھا کر دے۔", "RArabic": "ALLAAHUMMAL A’N QATALATA AMEERIL MOMINEENA WA QATALATAL HASANE WAL HUSAYNE A’LAYHEMUS AAMO WA QATALATA AHLE BAYTE NABIYYEKA ALLAAHUMMAL A’N A-A’DAAA-A AALE MOHAMMADIN WA QATALATAHUM WA ZIDHUM A’ZAABAN FAWQAL A’ZAABE WA HAWAANAN FAWQA HAWAANIN WA ZULLAN FAWQA ZULLIN WA KHIZYAN FAWQA KHIZYIN ALLAAHUMMA DO’-A’HUM ELAL NAARE DA’-A’N WA ARKISHUM FEE ALEEME A’ZAABEKA RAKSAN WAH-SHURHUM WA ATBAA-A’HUM ELAA JAHANNAMA ZOMARAN.", "ArabicText1": "اَللّٰہُمَّ الْعَنْ قَتَلَۃَ اَمِیْرِ الْمُؤْمِنِیْنَ وَقَتَلَۃَ الْحَسَنِ وَالْحُسَیْنِ عَلَیْہِمُ السَّلَامُ وَقَتَلَۃَ اَہْلِ بَیْتِ نَبِیِّکَ۔ اَللّٰہُمَّ الْعَنْ اَعْدَآئَ اٰلِ مُحَمَّدٍ وَقَتَلَتَہُمْ وَزِدْہُمْ عَذَابًا فَوْقَ الْعَذَابِ وَہَوَانًا فَوْقَ ہَوَانٍ وَذُلًّا فَوْقَ ذُلٍّ وَخِزْیًا فَوْقَ خِزْیٍ۔ اَللّٰہُمَّ دُعَّہُمْ اِلَی النَّارِ دَعًّا وَاَرْکِسْہُمْ فِیْ اَلِیْمِ عَذَابِکَ رَکْسًا وَاحْشُرْہُمْ وَاَتْبَاعَہُمْ اِلٰی جَہَنَّمَ زُمَرًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenS