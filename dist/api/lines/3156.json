 mufeed hai.", "UrduDescription": "صاحب کلام ہونے اور مومنین کی محبت و دوستی پانے کے لئے روزانہ 111 مرتبہ ’’یَا اَعْلٰی‘‘ کا ذکر مفید ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1017847, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 3, "EnglishDescription": "For fulfillment of needs for continuous 10 days perform ablution (wuzu) recite 110 times salawaat and dedicate to the soul of Ameerul Momeneen (a) then recite 2 rakat namaz like fajr and then say YAA A’LIYYO 110 times then again recite YAA A’LIYYO 1570 times and at the end recite salawaat 3 times.", "GujaratiDescription": null, "RUrduDescription": "Haajaat ke pura hone ke liye 10 raate’n musalsal (without gap) ba-wuzu 110 martaba salawaat padhe’n aur usey rooh’e Hazrat Ameerul Momeneen (a) ko isaal (gift) kare, us ke baad 2 rakat namaz (fajr ki tarah) padhe us ke baad 110 martaba YAA A’LIYYO ka vird kare. Phir dobaara (phir se) 1570 martaba YAA A’LIYYO ka vird kare aur aakhir mein 3 martaba salawaat padhe.", "UrduDescription": "حاجات کی برآوری کے لئے 10 راتیں متواتر باوضو 110مرتبہ صلوات پڑھیں اور اسے روح حضرت امیر المومنین ؑ کو ایصال کریں اس کے بعد ۲ رکعت نماز مثل نماز صبح پڑھیں اس کے بعد 110 مرتبہ ’’یَاعَلِیُّ‘‘ کا ورد کریں اور آخر میں 3 مرتبہ درود شریف پڑھیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "A