ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002837, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "You may then put your right cheek on the ground and repeat the same 100 times, then put your left cheek on the ground and repeat the same 100 times, and return to the normal position of prostration and repeat the same 110 times. You may then say the following dua…", "GujaratiDescription": null, "RUrduDescription": "Phir daayna rukhsaar (right cheek) zameen par rakh kar 100 martaba wohi zikr dauraaye, phir baaya rukhsaar (left cheek) zameen par rakh kar usi ko 100 martab dauraaye aur phir se Sajdeh mein sar rakh kar 110 phir se usi zikr ko dauraaye aur phir yeh dua padhe…", "UrduDescription": "پھر دایاں رخسار زمین پر رکھ کر ۱۰۰ مرتبہ یہی کہو پھر بایاں رخسار زمین پر رکھ کر ۱۰۰ مرتبہ یہی کہو اب دوبارہ سجدے میں سر رکھ کر ۱۱۰ مرتبہ یہی کہو اور پھریہ دعا پڑھو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedS