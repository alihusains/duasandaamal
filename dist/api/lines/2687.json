[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002211, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah: I beseech You in the name of those who were born in Rajab, Muhammad ibn Ali II and his son Ali ibn Muhammad, the divinely selected. And I seek nearness to You through both of them for they are the best means of nearness to You. O He from Whom favors are sought, and what He possesses is desired.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mahe Rajab mein matawallad (paiyda) hone waale do mauloodo’n ke waaste se sawaal karta hu jo Muhammad bin Ali saani (2nd) Imam Muhammad Taqi (a.s) aur unke farzand Ali ibne Muhammad, Imam Ali Naqi (a.s) buland nasab waale hai, un dono ke waaste se Tera behtareen taqarrub chahta hu.", "Urdu": "اے معبود! ماہ رجب میں متولد ہونے والے دو مولودوں کے واسطے سے سوال کرتا ہوں جو محمد ؑابن علی ثانی (امام محمد ؑتقی)اور ان کے فرزند علی ؑ ابن محمد ؑ(امام علی نقیؑ) بلند نسب والے ہیں ان دونوں کے واسطے سے تیری بہترین قربت چاہتا ہوں۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اِنِّيْ اَسْئَلُكَ بِالْمَوْلُوْدَيْنِ فِيْ رَجَبٍ مُحَمَّدِ بْنِ عَلِيٍّ الثَّانِيْ وَابْنِهٖ عَلِيِّ بْنِ مُحَمَّدٍ الْمُنْتَجَبِ وَاَتَقَرَّبُ بِهِمَا اِلَيْكَ خَيْرَ الْقُرَبِ يَا مَنْ اِلَيْهِ الْمَعْرُوْفُ طُلِبَ وَفِيْمَا لَدَيْهِ رُغِبَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002212, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I beseech You with the entreaty of him whom is enchained by his sins and is bound by his defects; therefore, he devoted himself to offenses and disasters have attacked him heavily. He is now begging You for accepting his repentance; and for good return from You; and for redeeming from punishment; and for releasing from Hellfire; and for overlooking the sins that are hanged to him. Certainly, You, O my Master, the greatest hope and desire that He has.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay woh zaat jis se ehsaan wa karam talab kiya jaata hai aur jo uske paas hai uski khwaaish ki jaati hai, mai sawaal karta hu Tujh se us gunah-gaar ka sa sawaal jise gunaho’n ne tabah kar diya aur aiybo’n ne jakad liya hai. Pas gunaho’n par uski aadat pukhta ho chuki aur balaawo’n se mushkile’n badh gayi hai. Ab woh sawaal karta hai Tujh se taufiqe taubah aur behtareen baaz-gasht ka gunaho’n se kinaara kashi aur aatishe Jahannam se chhut kaare ka khwaaish mand hai. Woh apne sabhi gunaho’n ki maafi chahta hai, pas Tu mera woh Maula hai jis par ummeed o etemaad hai.", "Urdu": "اے وہ ذات جس سے احسان وکرم طلب کیاجاتا ہے اور جواس کے پاس ہے اس کی خواہش کی جاتی ہے میں سوال کرتا ہوں تجھ سے اس گناہ گار کا سا سوال جسے گناہوں نے تباہ کر دیا اور عیبوں نے جکڑ لیا ہے پس گناہوں پر اس کی عادت پختہ ہو چکی اور بلاؤں سے مشکلیں بڑھ گئیں ہیں اب وہ سوال کرتا ہے تجھ سے توفیق ِتوبہ اور بہترین بازگشت کا گناہوں سے کنارہ کشی اور آتش ِجہنم سے چھٹکارے کا خواہش مند ہے وہ اپنے سبھی گناہوں کی معافی چاہتا ہے پس تو میرا وہ مولا ہے جس پر امید و اعتماد ہے۔", "RArabic": null, "ArabicText1": "اَسْئَلُكَ سُؤَالَ مُقْتَرِفٍ مُذْنِبٍ قَدْ اَوْبَقَتْهُ ذُنُوْبُهٗ وَاَوْثَقَتْهٗ عُيُوْبُهٗ فَطَالَ عَلَى الْخَطَايَا دُءُوْبُهٗ وَمِنَ الرَّزَايَا خُطُوْبُهٗ يَسْاَلُكَ التَّوْبَةَ وَحُسْنَ الْاَوْبَةِ وَالنُّزُوْعَ عَنِ الْحَوْبَةِ وَمِنَ النَّارِ فَكَاكَ رَقَبَتِهٖ وَالْعَفْوَ عَمَّا فِي رِبْقَتِهٖ فَاَنْتَ مَوْلَايَ اَعْظَمُ اَمَلِهٖ وَثِقَتِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002213, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And, O Allah, I beg You by all the holy means that You admit and by all the elevated courses that take to You, that You, in this month, encompass me with vast mercy of You, with abundant favors, and with satisfaction with what You have decided for myself until I am put in my final hole, which is my abode to the Hereafter and the Final Fate.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai Tujh se sawaal karta hu Tere paak maamlo’n, Tere buland wasilo’n ke waaste se keh is mahine mein apni wasee rehmat aur bakhshi jaane waali neymato’n ko ataa farma aur jo rozi Tu ne di us par mere nafs ko qaane farma ta waqti keh woh qabr mein jaaye aur manzile aakhir par pohonche aur jiski taraf uski baaz-gasht us tak pohonche.", "Urdu": "اے معبود! میں تجھ سے سوال کرتا ہوں تیرے پاک معاملوں تیرے بلند وسیلوں کے واسطے سے کہ اس مہینے میں اپنی وسیع رحمت اور بخشی جانے والی نعمتوں کو عطا فرما۔اور جو روزی تو نے دی اس پر میرے نفس کو قانع فرما تا وقتیکہ وہ قبر میں جائے اور منزلِ آخر پر پہنچےاور جس کی طرف اس کی بازگشت ہے اس تک پہنچے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ وَاَسْئَلُكَ بِمَسَائِلِكَ الشَّرِيْفَةِ وَ وَسَائِلِكَ الْمُنِيْفَةِ اَنْ تَتَغَمَّدَنِيْ فِيْ هٰذَا الشَّهْرِ بِرَحْمَةٍ مِنْكَ وَاسِعَةٍ وَنِعْمَةٍ وَازِعَةٍ وَنَفْسٍ بِمَا رَزَقْتَهَا قَانِعَةٍ اِلٰى نُزُوْلِ الْحَافِرَةِ وَمَحَلِّ الْآخِرَةِ وَمَا هِيَ اِلَيْهِ صَائِرَةٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": n