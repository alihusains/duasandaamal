[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000256, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my Allah! I beseech Thee. O Gentle and Considerate, Who is Tolerant, and gives respite; Forgiving, Loving, Overlooks my mistakes. Good that I have is from Thee, And that which Thou bestows on me from Thy free gifts makes me act. Thou encourages me and guides me while I make efforts in obedience to Thy commands and Thy Messenger’s instructions; and what Thou gives me freely from Thy bounties is Thy kindest favour.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Ay burdbaar, ay saheb'e rafq (narmi), bakhshish waale, dost-daari waale mai Tujh se sawaal karta hu keh mere gunaho’n se dar-guzar farma aur jo kuchh mere paas hai Tujh se hi hai, mujhe itna ataa farma jis mein mere liye wus’at o farakhi (khushi) ho, jo kuchh mujhe de us mein Apni aur apne Rasool ki ita’at o pairawi ke liye amal ki taufiq bhi marhamat farma. Mujh se aisa afv o dar-guzar farma keh jis se mai Tere fazl o karam ke laayaq ho jaawu.", "Urdu": "اے معبود! اے بردبار! اے صاحب ِ بخشش! اے محبت کرنے والے میں تجھ سے سوال کرتا ہوں کہ میرے گناہوں سے درگزر فرما اور جو کچھ میرے پاس ہے تجھی سے ہے اور مجھے اپنی عطا سے اتنا دے کہ جس میں میرے لئے وسعت ہو اور جو کچھ مجھے دے اس میں اپنی اور اپنے رسولؐ کی اطاعت وپیروی کے لئے توفیق ِعمل بھی مرحمت فرما اور مجھ سے ایسا عفوودرگزر فرما جس سے میں تیرے فضل وکرم کے لائق ہو جاؤں۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA YAA HALEEMO ZOO ANAATIN GHAFOORUN WADOODUN AN TA-TAJAAWAZA A’N SAYYEAATEE WA MAA I’NDEE BE HUSNE MAA I’NDEKA WA AN TOA’TEYANEE MIN A’TAAA-EKA MAA YASA-O’NEE WA TUL-HEMANEE FEEMAA A-A’TAYTANIL A’MALA FEEHE BE TAA-A’TEKA WA TAA-A’TE RASOOLEKA WA AN TA’TEYANEE MIN A’FWEKA MAA ASTAWJEBO BEHI KARAAMATAKA.", "ArabicText1": "اَللّٰهُمَّ اِنِّي اَسْاَلُكَ يَاحَلِيْمُ ذُوْ (ذَا) اَنَاةٍ غَفُوْرٌ وَّدُوْدٌ اَنْ تَتَجَاوَزَ عَنْ سَيِّئَاتِيْ وَمَا عِنْدِيْ بِحُسْنِ مَا عِنْدَكَ وَاَنْ تُعْطِيَنِيْ مِنْ عَطَآئِكَ مَا يَسَعُنِيْ وَتُلْهِمَنِيْ فِيْمَا اَعْطَيْتَنِي الْعَمَلَ فِيْهِ بِطَاعَتِكَ وَطَاعَةِ رَسُوْلِكَ وَاَنْ تُعْطِيَنِيْ مِنْ عَفْوِكَ مَا اَسْتَوْجِبُ بِهٖ كَرَامَتَكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001334, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O My Allah! Give me that which befits Thee. Do not do that which I deserve. Only that I am Your slave. Do not make me ever run after anything desirable except it comes from Thee. O The Best of all those who hear and pay attention! O The Best of All Those who exercise authority and judge!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mujh par woh ataa kar jiska Tu ahel hai aur mujh se woh bartaa’o na kar keh mai jiska ahel hu. Pas mai Teri wajah se zinda hu aur mujhe Tere siwa kisi se bhalaayi nahi mil sakti. Ay dekhne waalo’n se badh kar dekhne waale aur ay soonne waalo’n se badh kar soonne waale, aur ay haakimo’n se badh kar hukm karne waale aur ay panah dene waalo’n ki panah-gah aur ay be-chaaro’n ki dua qabool karne waale Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat farma.", "Urdu": "اے معبود! مجھ پر وہ عطا کر جس کا تو اہل ہے اور مجھ سے وہ برتاؤ نہ کر کہ جس کا میں اہل ہوں پس میں تیری وجہ سے زندہ ہوں اور مجھے تیرے سوا کسی سے بھلائی نہیں مل سکتی اے دیکھنے والوں سے بڑھ کر دیکھنے والے اورسننے والوں سے بڑھ کر سننے والے اور حاکموں سے بڑھ کر حکم کرنے والے اور اے پناہ دینے والوں کی پناہ گاہ اور لاچاروں کی دعا قبول کرنے والے محمدؐ وآل محمدؐ پر رحمت فرما۔", "RArabic": "ALLAAHUMMA A-A’TENEE MAA ANTA AHLOHU WA LAA TAF-A’L BEE MAA ANAA AHLOHU FA-INNAMAA ANAA BEKA WA LAM OSIB KHAYRAN QATTO ILLAA MINKA YAA ABSARAL ABSAREENA WA YAA ASMA-A’S SAAME-E’ENA WA YAA AHKAMAL HAAKEMEENA WA YAA JAARAL MUSTAJEEREENA YAA MOJEEBA DA’WATIL MUZTARREENA SALLE A’LAA MOHAMMADIWN WA AALE MOHAMMAD.", "ArabicText1": "اَللَّهُمَّ اَعْطِنِيْ مَا اَنْتَ اَهْلُهٗ وَلَا تَفْعَلْ بِيْ مَا اَنَا اَهْلُهٗ فَاِنَّمَا اَنَا بِكَ وَلَمْ اُصِبْ خَيْرًا قَطُّ اِلَا مِنْكَ يَااَبْصَرَ الْاَبْصَرِيْنَ وَيَا اَسْمَعَ السَّامِعِيْنَ وَيَا اَحْكَمَ الْحَاكِمِيْنَ وَيَا جَارَ الْمُسْتَجِيْرِيْنَ وَيَا مُجِيْبَ دَعْوَةِ الْمُضْطَرِّيْنَ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSi