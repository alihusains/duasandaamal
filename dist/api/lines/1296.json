[{"Id": 1000467, "EnglishTitle": "The Whispered Prayer of the Hopeful (Rajeen)…", "GujaratiTitle": null, "RUrduTitle": "Ummeed-waaro’n ki Munajaat…", "UrduTitle": "چوتھی مناجات مناجاتِ راجین۔۔۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000468, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He who gives to a servant who asks from Him, takes him to his wish when he expectantly hopes for what is with Him, brings him near and close when he approaches Him, covers over his sin and cloaks it when he shows it openly, and satisfies and suffices him when he has confidence in Him!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay woh keh jab banda us se maange to usey ataa karta hai aur jab woh kisi cheez ki ummeed rakkhe to uski aarzoo puri karta hai. Jab woh uski taraf badhe to usey qareeb kar leta hai. Jab woh khullam-khula (openly) na-farmani kare to uske gunah par parda daalta aur chhupa leta hai aur jab woh us par bharosa kare to uski zarurat puri karta hai.", "Urdu": "خداکے نام سے شروع جو بڑا مہربان نہایت رحم والا ہے۔اے وہ کہ جب بندہ اس سے مانگے تو اسے دیتا ہے اور جب وہ کسی چیز کی امید رکھے تو اس کی آرزو پوری کرتا ہے جب وہ اس کی طرف بڑھے تو اسے قریب کرلیتا ہے جب وہ کھلم کھلا نافرمانی کرے تو اس کے گناہ پر پردہ ڈالتا اور چھپا لیتاہے اور جب وہ اس پر بھروسہ کرے تو اس کی ضرورت پوری کرتا ہے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "يَامَنْ اِذَا سَئَلَهٗ عَبْدٌ اَعْطَاهُ وَاِذَا اَمَّلَ مَا عِنْدَهٗ بَلَّغَهٗ مُنَاهُ وَاِذَا اَقْبَلَ عَلَيْهِ قَرَّبَهٗ وَاَدْنَاهُ وَاِذَا جَاهَرَهٗ بِالْعِصْيَانِ سَتَرَ عَلٰى ذَنْۢبِهٖ وَغَطَّاهُ وَاِذَا تَوَكَّلَ عَلَيْهِ اَحْسَبَهٗ وَكَفَاهُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012337, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My God, who is the one who has come before Thee seeking hospitality, and whom Thou hast not received hospitably? Who is the one who has dismounted at Thy door hoping for magnanimity, and to whom Thou hast not shown it? Is it good that I come back from Thy door, turned away in disappointment, while I know of no patron qualified by beneficence but Thee?", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Mabood! Kaun hai jo Teri bargah mein mehmaani ka taalib ho to Tu uski mehmaani (mezbaani) na kare? Kaun hai jo bakhshish ki aas (ummeed) le kar Tere darwaaze par aaye to Tu us par ehsaan na kare? Kya yeh munaasib hai keh mai Tere darwaaze se mayoosi ke saath palat jaawu jab-keh Mai Tere siwa koi maula nahi paata jo ehsaan o karam karne waala ho.", "Urdu": "میرے معبود کون ہے جو تیری بارگاہ میں مہمانی کا طالب ہو تو تو اس کی مہمانی نہ کرے؟ کون ہے جو بخشش کی آس لے کر تیرے دروازے پرآئے تو تو اس پر احسان نہ کرے کیا یہ مناسب ہے کہ میں تیرے دروازے سے مایوسی کے ساتھ پلٹ جاؤں جب کہ میں تیرے سوا کوئی مولا نہیں پاتا جو احسان و کرم کرنے والا ہو۔", "RArabic": null, "ArabicText1": "اِلٰهِىْ مَنِ الَّذِىْ نَزَلَ بِكَ مُلْتَمِسًا قِرَاكَ فَمَا قَرَيْتَهٗ وَمَنِ الَّذِىْ اَنَاخَ بِبَابِكَ مُرْتَجِيًا نَدَاكَ فَمَا اَوْلَيْتَهٗ اَ يَحْسُنُ اَنْ اَرْجِعَ عَنْۢ بَابِكَ بِالْخَيْبَةِ مَصْرُوْفًا وَلَسْتُ اَعْرِفُ سِوَاكَ مَوْلًى بِالْاِحْسَانِ مَوْصُوْفًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012338, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "How should I have hope in other than Thee, when the good - all of it - is in Thy hand? How should I expect from others, when Thine are the creation and the command? Should I cut off my hope for Thee, when Thou hast shown me of Thy bounty that for which I have not asked? Wouldst Thou make me have need for my like? But I hold fast to Thy cord!", "Gujarati": null, "RGujarati": null, "RUrdu": "Phir kyu’n Tere siwa kisi se ummeed rakkhu, jab-keh har bhalaayi (khair o khoobi) Tere haath mein hai aur kyu’n Tere siwa kisi se aarzoo karu jab-keh Tu hi khalq-wo-amr ka maalik hai. Aaya Tujh se ummeed tod lu jab-keh Tu Mujhe bin maange hi apne karam se har cheez ataa farmata hai. To Kya Tu mujh jaise shakhs ko kisi ka mohtaj karega? Jab-keh mai Tera daaman pakde hu.", "Urdu": "پھر کیوں تیرے سوا کسی سے امید رکھوں جب کہ ہر بھلائی تیرے ہاتھ میں ہے اور کیوں تیرے سوا کسی سے آرزو کرو ں جب کہ تو ہی خلق و امر کا مالک ہے آیا تجھ سے امید توڑلوں جب کہ تو مجھے بن مانگے ہی اپنے کرم سے ہر چیز عطا فرماتا ہے تو کیا تو مجھ جیسے شخص کوکسی کا محتاج کرے گا جب کہ میں تیرادامن پکڑے ہوں۔", "RArabic": null, "ArabicText1": "كَيْفَ اَرْجُوْ غَيْرَكَ وَالْخَيْرُ كُلُّهٗ بِيَدِكَ وَكَيْفَ اُؤَمِّلُ سِوَاكَ وَالْخَلْقُ وَالْاَمْرُ لَكَ اَاَقْطَعُ رَجَآئِىْ مِنْكَ وَقَدْ اَوْلَيْتَنِيْ مَا لَمْ اَسْاَلْهُ مِنْ فَضْلِكَ اَمْ تُفْقِرُنِيْ اِلٰى مِثْلِىْ وَاَنَا اَعْتَصِمُ بِحَبْلِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012339, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He through whose mercy the strivers reach felicity and through whose vengeance the seekers of forgiveness are not made wretched! How should I forget Thee, while Thou never ceasest remembering me? How should I be diverted from Thee while Thou art my constant watcher? My God, I have fastened my hand to the skirt of Thy generosity, I have stretched forth my expectation toward reaching Thy gifts, so render me pure through the purest profession of Thy Unity, and appoint me one of Thy choice servants!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Woh jisne apni rehmat se qasd karne waalo’n ko bhalaayi ataa ki aur jo maafi maangne waalo’n ko apne inteqaam se tanghi nahi deta. Kaise Tujhe bhul sakta hu, jab-keh Tere zikr mein laga rehta hu. Kaise Tujh se ghaafil rahe sakta hu jab-keh Tu mera nighehbaan (khayaal rakhne waala) hai. Mere Mabood! Mai apne haath se Tere daaman’e rehmat ko pakda huwa hu aur Teri ataawo’n ki aarzoo liye huwe hu. Pas mujhe apni tauhid ke sachche parastaaro’n (maanne waalo’n) mein shaamil kar le, aur mujhe apne chuninda (selected) bando’n mein se qaraar de.", "Urdu": "اے وہ جس نے اپنی رحمت سے قصد کرنے والوں کو بھلائی عطا کی اور جو معافی مانگنے والوں کو اپنے انتقام سے تنگی نہیں دیتا کیسے تجھے بھول سکتا ہوں جب کہ تیرے ذکر میں لگا رہتا ہوں کیسے تجھ سے غافل رہ سکتا ہوں جب کہ تو میرا نگہبان ہے میرے معبود میں نے اپنے ہاتھ سے تیرے دامنِ کرم کو پکڑ لیا ہوا ہے اور تیری عطاؤں کی آرزو کیے ہوئے ہوں پس مجھے اپنی توحید کے سچے پرستاروں میں شامل کرلے اور مجھے اپنے چنے ہوئے بندوں میں سے قرار دے۔", "RArabic": null, "ArabicText1": "يَامَنْ سَعِدَ بِرَحْمَتِهِ الْقَاصِدُوْنَ وَلَمْ يَشْقَ بِنِقْمَتِهِ الْمُسْتَغْفِرُوْنَ كَيْفَ اَنْسٰيكَ وَلَمْ تَزَلْ ذَاكِرِىْ وَكَيْفَ اَلْهُوْ عَنْكَ وَاَنْتَ مُرَاقِبِىْ۔ اِلٰهِىْ بِذَيْلِ كَرَمِكَ اَعْلَقْتُ يَدِىْ وَلِنَيْلِ عَطَايَاكَ بَسَطْتُ اَمَلِىْ فَاَخْلِصْنِىْ بِخَالِصَةِ تَوْحِيْدِكَ وَاجْعَلْنِىْ مِنْ صَفْوَةِ عَبِيْدِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012340, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He who is the asylum of every fleer, the hope of every seeker! O Best Object of hope! O Most Generous Object of supplication! O He who does not reject His asker or disappoint the expectant! O He whose door is open to His supplicators and whose veil is lifted for those who hope in Him!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Woh keh har bhaag kar aane waala jiski panah leta hai aur har saayel jis se ummeed rakhta hai. Ay behtareen ummeed bar lane waale. Ay behtareen pukaare jaane waale, Ay Woh jo saayel ko rad nahi karta, aur Woh aarzoo-mand ko maayoos nahi karta. Ay Woh jiska darwaza pukaarne waalo’n ke liye (har-waqt) khula hai aur ummeed-waar ke liye parda utha huwa hai.", "Urdu": "اے وہ کہ ہر بھاگ کر آنے والا جس کی پناہ حاصل کرتا ہے اور ہر سائل جس سے امید رکھتا ہے اے بہترین امید پوری کرنے والے اے بہترین پکارے جانے والے اے وہ جو سائل کو نہیں ہٹاتا اور وہ آرزومند کو مایوس نہیں کرتااے وہ جس کادروازہ پکارنے والے کے لئے کھلا ہے اور امیدوار کے لئے پردہ اٹھا ہوا ہے۔", "RArabic": null, "ArabicText1": "يَامَنْ كُلُّ هَارِبٍ اِلَيْهِ يَلْتَجِءُ وَكُلُّ طَالِبٍ اِيَّاهُ يَرْتَجِىْ يَاخَيْرَ مَرْجُوٍّ وَيَآ اَكْرَمَ مَدْعُوٍّ وَيَا مَنْ لَّا يَرُدُّ سَآئِلَهٗ وَلَا يُخَيَّبُ اٰمِلَهٗ يَامَنْۢ بَابُهٗ مَفْتُوْحٌ لِدَاعِيْهٖ وَحِجَابُهٗ مَرْفُوْعٌ لِرَاجِيْهِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012341, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I ask Thee by Thy generosity to show kindness toward me through Thy gifts, with that which will gladden my eye, through hope in Thee, with that which will give serenity to my soul, and through certainty with that which will make easy for me the afflictions of this world and lift from my insight the veils of blindness! By Thy mercy, O Most Merciful of the merciful!", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai Tere karam ke waaste se sawaal karta hu keh, mujh par apni ataa se aisa ehsaan farma jis se meri aankhe’n thandi ho jaaye. Aur aisi ummeed de keh jis se mere dil ko chain aa jaaye. Aisa yaqeen ataa kar keh jis se duniya ki museebate’n mere liye halki (aasaan) ho jaaye aur meri samajh-boojh par se na-daani ke parde hat (dur ho) jaaye Teri rehmat ke waaste se ay sabse ziyadah rahem karne waale!", "Urdu": "میں تیرے کرم کے واسطے سے سوال کرتا ہوں کہ مجھ پر اپنی عطا سے ایسا احسان فرما جس سے میری آنکھیں ٹھنڈی ہوجائیں اور ایسی امید دے کہ جس سے میرے دل کو چین آجائے ایسا یقین عطا کر کہ جس سے دنیا کی مصیبتیں میرے لئے ہلکی ہوجائیں اور میری سمجھ بوجھ پرسے نادانی کے پردے دور ہوجائیں تیری رحمت کے واسطے سے اے سب سے زیادہ رحم کرنے والے۔", "RArabic": null, "ArabicText1": "اَسْئَلُكَ بِكَرَمِكَ اَنْ تَمُنَّ عَلَىَّ مِنْ عَطَآئِكَ بِمَا تَقِرُّ بِهٖ عَيْنِىْ وَمِنْ رَجَآئِكَ بِمَا تَطْمَئِنُّ بِهٖ نَفْسِىْ وَمِنَ الْيَقِيْنِ بِمَا تُهَوِّنُ بِهٖ عَلَىَّ مُصِيْبَاتِ الدُّنْيَا وَتَجْلُوْ بِهٖ عَنْ بَصِيْرَتِىْ غَشَوَاتِ الْعَمٰى بِرَحْمَتِكَ يَآاَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle"