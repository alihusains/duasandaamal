[{"Id": 1016640, "EnglishTitle": "PLEASE NOTE: Be it clear that the reason for presenting Translation is to understand Salaat and to recite in Arabic with concentration because reciting Salaat other than Arabic language (or Transliteration) is not correct.", "GujaratiTitle": null, "RUrduTitle": "Waazeh rahe keh tarjuma-e-namaz pesh karne ki asal wajah namaz samajh ke Arabi mein khuzoo aur tawajjoh ke saath namaz padhna hai. Kyu’n keh Arabi ya Roman-Arabi (Transliteration) ke siwa kisi aur zabaan mein namaz padhna sahih nahin hai.", "UrduTitle": "واضح رہے کہ ترجمۂ نماز پیش کرنے کی اصل غرض نماز سمجھ کے عربی میں خضوع اور توجہ کے ساتھ نماز پڑھنا ہے۔ کیوں کہ عربی کے سوا کسی اور زبان میں نماز پڑھنا صحیح نہیں ہے۔ اس لئے ہر ایک کے لئے نماز کی حد تک قرآن و عربی سیکھنا واجب ہے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009866, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "PLEASE NOTE: Be it clear that in this Friday 4 rakat namaz Surah HAA MEEM SAJDAH has to be recited, as the Verse-37 in this surah is the verse of obligatory Prostration (waajib sajdah aayat), so whenever you recite this verse you should immediately do the prostration (sajdah) and then standup and complete the surah (this Verse-37 has to be recited slowly so that no one can hear or else the one who hears this verse, prostration (sajdah) will be compulsory on him).", "GujaratiDescription": null, "RUrduDescription": "WAAZEH RAHE keh is Friday ke din ki 4 rakat namaz ki har rakat mein Surah HAA MEEM SAJDAH padhne ka hukm hai keh jis ki Aayat-37 mein waajib sajdah hai, lehaaza jitni martaba bhi is aayat ko padhe to fauran sajdah kare aur phir khade ho kar Surah mukammal kare (is Aayat-37 ko khaamoshi se padha jaaye ta-keh koi soonne na paaye warna soonne waale par bhi sajdah waajib ho jaayega).", "UrduDescription": "واضح رہے کہ اس جمعہ کے دن کی ۴ رکعت نماز کی ہر رکعت میں سورۂ حم سجدہ پڑھنے کا حکم ہے کہ جس کی آیت ۳۷ میں واجب سجدہ ہے، لہذا جتنی مرتبہ بھی اس آیت کو پڑھے تو فورًا سجدہ کر لے اور پھر کھڑے ہو کر سورہ مکمل کرے (اس آیت ۳۷ کو خاموشی سے پڑھا جائے تاں کہ کوئی سننے نہ پائے ورنہ سننے والے پر بھی سجدہ واجب ہو جائے گا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010956, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is narrated from the Messenger of Allah (s) that one who recites 4 rakats prayer on Friday and in each rakat after <Surah Fateha> recites <Surah Mulk> and <Surah Ha Meem Sajdah> the Almighty would admit him into Paradise and would accept his intercession for his family members and keep him safe from the squeeze of the grave and the punishment of Qiyamat. The narrator asked the Messenger of Allah (s) regarding the time of these prayers. He (s) replied: After sunrise and before noon. That is in between the two.", "GujaratiDescription": null, "RUrduDescription": "Sayed ibne Tawoos ne Imam Hasan Askari (a) se riwaayat ki hai keh, jo shakhs Juma ke din 4 rakat namaz 2x2 rakat kar ke padhe keh jis ki har rakat mein <Surah Fateha> ke baad <Surah Mulk> aur <Surah Ha Meem Sajdah> ki tilaawat kare to Haq taala usey Behisht (Jannat) mein daakhil jarega, uske ahle khaandaan ke liye uski shafaat qabool farmaaega aur uski qabr ko tangi aur hashr ke khatraat se mehfooz rakhega, raawi ne Hazrat (a) se poonchha: yeh namaz din ke kisi waqt adaa ki jaaye? Aap ne farmaya: tuloo-e-aftaab (sunrise) se zawaal-e-aaftaab (before noon) tak keh darmiyaan adaa ki ja sakti hai.", "UrduDescription": "سید ابن طاؤسؒ نے امام حسن عسکری ؑ سے روایت کی ہے کہ آپؑ کا فرمان ہے: جو شخص جمعہ کے دن ۴ رکعت نماز پڑھے کہ ہر رکعت میں <سورۂ فاتحہ>، <سورۂ ملک> اور <سورۂ حم سجدہ> کی تلاوت کرے تو حق تعالیٰ اسے بہشت میں داخل کرے گا اس کے اہل ِخاندان کے لئے اس کی شفاعت قبول فرمائے گا اور اس کی قبر کو تنگی اور حشر کے خطرات سے محفوظ رکھے گا راوی نے حضرت ؑ سے پوچھا :یہ نماز دن کے کس وقت بجا لائی جائے؟ آپ نے فرمایا: طلوعِ آفتاب سے زوال ِآفتاب تک کے درمیانی اوقات میں ادا کی جائے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGre