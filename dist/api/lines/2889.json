[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002278, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, You are my Lord; there is no god save You; You have created me, and I am Your slave and the son of Your bondmaid; and I am in Your grip; and my forehead is in Your Hand; I come to observe my covenant and promise to You as much as I can. I take refuge in Your pleasure against the evil of my deeds. I acknowledge Your favors and confess of my sins. So, (please) forgive my sins, for none can forgive sins save You.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Tu hi mere Rab hai, Tere siwa koi ma’bood nahi, Tu ne hi mujhe paiyda kiya aur mai Tera banda aur Teri kaneez ka beta hu aur Tere qaabu mein hu. Meri mehaar Tere dast’e qudrat mein hai. Mai apni taaqat ke mutabiq Tere ahed o paimaan par qaayem raha hu jo buraayi karta hu us mein Teri raza ki panah chahta hu. Teri neymat ka baar (wazn) aur mere gunah ka bojh mere kandeh (shoulder) par hai. Pas mere gunah maaf kar de keh Tere siwa koi gunaho’n ko maaf nahi kar sakta.", "Urdu": "اے معبود! تو ہی میرا رب ہے تیرے سوا کوئی معبود نہیں تو نے ہی مجھے پیدا کیا اور میں تیرا بندہ اور تیری کنیز کا بیٹا ہوں اورتیرے قبضے میں ہوں میری مہار تیرے دستِ قدرت میں ہے میں اپنی طاقت کے مطابق تیرے عہدوپیمان پر رات گزاری جتنا ہو سکے میں تیری رضا کی پناہ چاہتاہوں اس کے شر سے جو میں نے انجام دیا ہے تیری نعمت کا بار اور میرے گناہ کا بوجھ میرے کندھے پر ہے پس میرے گناہ معاف فرما دے تیرے سوا کوئی گناہوں کو معاف نہیں کر سکتا۔", "RArabic": "ALLAAHUMMA ANTA RABBEE LAA ILAAHA ILLAA ANTA KHALAQ-TANEE WA ANAA A’BDO-KA WABNA AMATE-KA WA FEE QAB-ZATE-KA WA NAASE-YATEE BE-YADEKA AM-SAIY-TO A’LAA A’HDE-KA WA WA’DEKA MAS TATA’TO A-OO’ZO BE-REZAA-KA MIN SHARRE MAA SANA’TO ABOO-O BE-NE’MATE-KA (BE-A’MALEE) WA ABOO-O BE-ZANBEE (BE-ZONOO-BEE) FAGH-FIR LEE ZONOO-BEE INNA-HU LAA YAGH-FERUZ ZONOO-BE ILLAA ANTA.", "ArabicText1": "اَللّٰهُمَّ اَنْتَ رَبِّيْ لَا اِلٰهَ اِلَّا اَنْتَ خَلَقْتَنِيْ وَاَنَا عَبْدُكَ وَابْنُ اَمَتِكَ وَفِيْ قَبْضَتِكَ وَنَاصِيَتِيْ بِيَدِكَ اَمْسَيْتُ عَلٰى عَهْدِكَ وَوَعْدِكَ مَا اسْتَطَعْتُ اَعُوْذُ بِرِضَاكَ مِنْ شَرِّ مَا صَنَعْتُ اَبُوْٓءُ بِنِعْمَتِكَ (بِعَمَلِيْ) وَاَبُوْٓءُ بِذَنْبِيْ (بِذُنُوْبِيْ) فَاغْفِرْ لِيْ ذُنُوْبِيْ اِنَّهٗ لَا يَغْفِرُ الذُّنُوْبَ اِلَّا اَنْتَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "Ar