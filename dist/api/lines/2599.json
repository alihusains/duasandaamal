 hereafter, and be his Guardian and Supporter and Leader, protector and concealer, until You reside him on Your Land desirably, and help him benefit from it for a long period of time, O the most beneficent of the beneficent, and there is not movement or Power without Your source O Allah Almighty, thus Allah will suffice You from them, and he is the Hearer and the Knower.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": "اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ، وَاَنْ تَفْعَلَ بِیْ كَذَا وَكَذَا، وَاَنْ تُدَارِ كَنِیْ بِهٖ، وَتُنْضِیَنِیْ مَمَّا اَخَافُهٗ وَاَحْبَرُهٗ، وَاَلْبِسْنِیْ بِهٖ عَافِیَتَكَ وَعَفْوَكَ فِی الدُّنْیَا وَالْآخِرَۃِ، وَكُنْ لَهٗ وَلِیَّا وَّحَافِظًا، وَنَاصِرًا وَقَائِدًا، وَكَالِئًا وَسَاتِرًا، حَتّٰی تُسْكِنَهٗ اَرْضَكَ طَوْعًا، وَتُمَتِّعَهٗ فِیْهَا طَوِیْلًا، یَا اَرْحَمَ الرَّاحِمِیْنَ، وَلَا حَوْلَ وَلَا قُوَّۃَ اِلَّا بِاللهِ الْعَلِیِّ الْعَطِیْمِ، فَسَیَكْفِیْكَهُمُ اللهُ وَهُوَ السَّمِیْعُ الْعَلِیْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": nul