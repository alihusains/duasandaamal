[{"Id": 1016601, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is narrated from our Master, Jafar bin Mohammad (a), who narrated from his forefathers that: whoever recites the following salawaat 10 times after the Friday prayer, will become a companion of Imam Mahdi (a)…", "GujaratiDescription": null, "RUrduDescription": "Hazrat Imam Sadiq (a) apne ajdaad se naql karte huwe farmate hai keh jo bhi Namaz-e-Juma ke baad 10 martaba is tarah salawaat padhe to uska shumaar Aan Hazrat (a) ke as-haab mein hoga…", "UrduDescription": "حضرت امام صادقؑ نے اپنے آباء و اجداد سے نقل کیا ہے اور فرماتے ہیں کہ جو بھی نماز جمعہ کے بعد ۷ مرتبہ اس طرح سے کہے تو یہ شخص حضرت کے اصحاب اور مددگاروں میں شامل ہوجاتاہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null,