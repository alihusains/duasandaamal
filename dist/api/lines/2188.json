[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011998, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "All Praise is for Allah, the Sufficient. Glory be to Allah the most High. Sufficient is Allah, and He is enough, whatever Allah wills, happens. Allah hears one who calls to Him, there is no refuge from Allah nor is there any recourse beyond Him. Indeed I have put my trust in Allah, my Lord and your Lord, there is no living creature except that He holds it by its forelock, surely my Lord is on a straight path (11:56) All Praise is for Allah who has not taken a son, has no partner in the Kingdom, has no friend to protect him from humiliation, so magnify Him with a great magnificence.", "Gujarati": null, "RGujarati": null, "RUrdu": "Tamaam taarife’n Us zaat ke saath makhsoos hai jo kifaayat karne waala hai, paak hai Woh zaat jo buland-tar hai, mere liye Khuda kaafi hai, wohi anjaam paayega jo Khuda chahega, pukaarne waale ki awaaz Khuda soonta hai, Khuda ke alaawa na panah-gah hai aur na koi madad-gaar hai, mai ne apne aur tumhare Khuda'e wahdahu la-shareek par tawakkul kiya hai, tamaam cho-paayo’n (4 paau waale) ki lagaam Allah ke haath mein hai. Tamaam taarife’n Us zaat se makhsoos hai, jiski koi awlaad nahi hai, aur baadshahi mein koi Uska shareek nahi hai, aur Woh kabhi kisi ki sar-parasti mein na tha aur Uski baargah mein Uski badhaayi ziyadah bayaan karo.", "Urdu": "تمام تعریفیں اس ذات کے ساتھ مخصوص ہیں جو کفایت کرنے والا ہے، پاک ہے وہ ذات جو بلند تر ہے، میرے لئے خدا کافی ہے، وہی انجام پائے گا جو خدا چاہے گا، پکارنے والے کی آواز خدا سنتا ہے، خدا کے علاوہ نہ پناہگاہ ہے اور نہ کوئی ملجاء ماویٰ ہے، میں نے اپنے اور تمہارے خدائے وحدہ لاشریک پر توکل کیا ہے، تمام چوپایوں کی لگام اللہ کے ہاتھ میں ہے۔ تمام تعریفیں اس ذات سے مخصوص ہیں، جس کی کوئی اولاد نہیں ہے، اور بادشاہی میں کوئی اس کا شریک نہیں ہے، اور وہ کبھی کسی کی سرپرستی میں نہ تھا اور اس کی بارگاہ میں اس کی بڑھائی زیادہ بیان کرو۔", "RArabic": "AL-HAMDO LILLAAHIL KAAFEE, SUBHAANAL LAAHIL A-A’LAA, HASBEYAL LAAHO WA KAFAA, MAA SHAA ALLAHO QAZAA, SAME-A’L LAAHO LEMAN DA-A’A, LAYSA MENAL LAAHE MALJA-UN, WA LAA WARAA ALLAHE MULTAJA-UN. TAWAKKALTO A’LAL LAAHE RABBEE WA RABBEKUM, MAA MIN DAABBATIN ILLAA HOWA AAKHEZUN BE-NAASEYATEHAA, INNA RABBEE A’LAA SERAATIM MUSTAQEEM. AL-HAMDOLIL LAAHIL LAZEE LAM YATTAKHIZ WALADANW WA LAM YAKUL LAHU SHAREEKUN FIL MULKE WA LAM YAKUL LAHU WALIYYUM MENAZ ZULLE WA KABBIRHO TAKBEERAA.", "ArabicText1": "اَلْحَمْدُ لِلهِ الْكَافِیْ، سُبْحَانَ اللهِ الْاَعْلٰی، حَسْبِیَ اللهُ وَكَفٰی، مَاشَآءَ اللهُ قَضٰی، سَمِعَ اللهُ لِمَنْ دَعَا، لَیْسَ مِنَ اللهِ مَلْجَاٌ، وَلَا وَرَاۗءَ اللهِ مُلْتَجَاٌ۔ تَوَكَّلْتُ عَلَی اللهِ رَبِّیْ وَرَبِّكُمْ مَا مِنْ دَابَّۃٍ اِلَّا هُوَ آخِذٌ بِنَا صِیَتِهَا، اِنَّ رَبِّیْ عَلٰی صِرَاطٍ مُّسْتَقِیْمٍ۔ اَلْحَمْدُ لِلهِ الَّذِیْ لَمْ یَتَّخِذْ وَلَدًا، وَلَمْ یَكُنْ لَّهٗ شَرِیْكٌ فِی الْمُلْكِ، وَلَمْ یَكُنْ لَّهٗ وَلِیٌّ مِنَ الذُّلِّ، وَكَبِّرْهُ تَكْبِیْرًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlu