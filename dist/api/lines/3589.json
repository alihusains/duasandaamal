[{"Id": 1015897, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "It is recommended to do Saee on foot and try to weep and cry and supplicate as much as possible during Saee. He should recite…", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh paiydal Saee kare. Saee ke dauraan girya karna ya kam az kam girya o zaari ki koshish karna aur dua-e-maangna mustahab hai, neez yeh dua bhi padhe…", "UrduDescription": "مستحب ہے کہ پیدل سعی کرے اور صفا سے منارۂ میانہ تک جائے اور وہاں سے بازار عطاران تک ہرولہ کرے یعنی اونٹ کی مانند تیز رفتاری سے چلے (منارہ میانہ اور بازار عطاران کے درمیانی فاصلہ کو آجکل سبز روشنی کے ذریعہ مشخص و معین کر دیا گیا ہے)، اور اگر پیدل چلنے کے بجائے سواری پر سعی کر رہا ہو تب بھی اس فاصلہ کو تیزی سے طے کرے، عورتوں کے لئے ہرولہ مناسب نہیں ہے۔ ہرولہ کے دوران یہ دُعا پڑھنا مستحب ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015898, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Mai Tujh se har haal mein husne-zan rakhne, Tujh par bharosa rakhne aur sidq (sachchi) niyyat rakhne ka sawaal karta hu.", "Urdu": "اللہ کے نام سے، اللہ کے ذریعہ سے اور اللہ بزرگ ہے، محمدؐ اور ان کے اہل بیتؑ پر خدا کا درود و سلام ہو۔ اے میرے اللہ! مجھے بخش دے اور جو گناہ تو جانتا ہے اس سے درگزر فرما، یقینًا تو زیادہ عزّت والا، زیادہ بزرگ اور زیادہ کریم ہے، مجھے اس راستہ کی ہدایت فرما جو بہت درست اور سیدھی ہے۔ خدایا! یقینًا میرا عمل کمزور ہے تو اس میں اضافہ فرما کر اسے مجھ سے قبول کر لے۔ اے میرے اللہ! یہ سعی تیرے لئے ہے اور تیرے ذریعہ سے میری طاقت و قوت ہے، تو میرا عمل قبول کر، اور متقین کے عمل کو قبول کرلے۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA HUSNAZ ZANNE BEKA A’LAA KULLE HAALIN WA SIDQIN NIYYATE FIT TAWAKKULE A’LAYKA.", "ArabicText1": "اَللّٰہُمَّ اِنِّیْ اَسْئَلُكَ حُسْنَ الظَّنِّ بِكَ عَلٰی كُلِّ حَالٍ وَصِدْقَ النِّیَّۃِ فِی التَّوَكُّلِ عَلَیْكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015899, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "Whenever one pass from Minaare Miyanah till Bazar-e-Ataraan a distance marked by green lights, he should walk fast and speed up if he is riding. There is no ’Harvalah’ for women. It is recommended to say this while passing through the green light area…", "GujaratiDescription": null, "RUrduDescription": "Jab bhi Minaare Miyanah par pohonche to Bazaar-e-Ataraan tak “Harwale” kare, yaani tez raftaari se chahle. Minaare Miyanah aur Bazaar-e-Ataraan ke darmiyaani faasle ko sabz roshni (green light) ke zariye nishaandeh kiya gaya hai. Aur agar paiydal chalne ke bajaaye sawaari (wheelchair) par Saee kare tab bhi us faasle ko tezi se taiy kare. Aurto’n ke liye Harwala (tez chalna) munaasib nahi. Harwala ke dauraan is dua ka padhna mustahab hai…", "UrduDescription": "جب اس مقام سے گزر جائے تو کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015900, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Allah ke naam se, Allah ke zariye se aur Allah buzurg hai, Muhammad (s.a.w.a) aur unke Ahlebait (a.s) par Khuda ka durood o salaam ho. Ay mere Allah! Mujhe bakhsh de aur jo gunah Tu jaanta hai us se dar-guzar farma. Yaqeenan Tu ziyadah izzat waala, ziyadah buzurg aur ziyadah kareem hai, mujhe us raaste ki hidaayat farma jo bohot durust aur seedha. Khudaaya! Yaqeenan mera amal kamzor hai Tu us mein izaafa farma kar usey mujh se qabool kar le. Ay mere Allah yeh saee (koshish) Tere liye hai aur Tere zariye se meri taaqat o quwwat hai, Tu mera amal qabool kar, aur mutaqeen ke amal ko qabool kar le.", "Urdu": "اے وہ خدا جو احسان کرنے والا ہے، فضل و کرم والا ہے، نعمتوں اور سخاوت والا ہے، میرے گناہوں کو بخش دے کیونکہ میرے گناہوں کو تیرے سوا کوئی نہیں بخشے گا۔", "RArabic": "BISMIL LAAHE WA BILLAAHE WAL LAAHO AKBARO WA SALLAL LAAHO A’LAA MOHAMMADIWN WA AHLE BAYTEHI ALLAAHUMMAGH FIR WAR-HAM WA TAJAAWAZ A’MMAA TA’LAMO INNAKA ANTAL A-A’ZZUL A-JALLUL AKRAMO WAH-DENEE LILLATEE HEYA AQWAMO ALLAAHUMMA INNA A’MALEE ZA-E’EFUN FA-ZAA-I’FHO LEE WA TAQABBALHO MINNEE ALLAAHUMMA LAKA SA’YEE WA BEKA HAWLEE WA QUWWATEE TAQABBAL MINNEE A’MALEE YAA MAYN YAQBALO A’MALAL MUTTAQEENA.", "ArabicText1": "بِسْمِ اللہِ وَبِاللہِ وَاللہُ اَكْبَرُ وَصَلَّی اللہُ عَلٰی مُحَمَّدٍ وَاَھْلِ بَیْتِہٖ۔ اَللّٰہُمَّ اغْفِرْ وَارْحَمْ وَتَجَاوَزْ عَمَّا تَعْلَمُ اِنَّكَ اَنْتَ الْاَعَزُّ الْاَجَلُّ الْاَكْرَمُ وَاہْدِنِیْ لِلَّتِیْ ہِیَ اَقْوَمُ۔ اَللّٰہُمَّ اِنَّ عَمَلِیْ ضَعِیْفٌ فَضَاعِفْہُ لِیْ وَتَقَبَّلْہُ مِنِّیْ۔ اَللّٰہُمَّ لَكَ سَعْیِیْ وَبِكَ حَوْلِیْ وَقُوَّتِیْ تَقَبَّلْ مِنِّیْ عَمَلِیْ یَا مَنْ یَّقْبَلُ عَمَلَ الْمُتَّقِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6"