[{"Id": 1010071, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Sayyid Ibn Tawus, in Muhaj al-Da’awat, has narrated on the authority of Imam Baqir (a) that angle Jibraeel, once came to the Holy Prophet (s) and said, “O Allah’s Prophet, indeed, I have never loved any prophets as much as I loved you. You thus may repeat the following zikr as many times as possible”…", "GujaratiDescription": null, "RUrduDescription": "Sayyad Ibne Tawus ne Muhaj al-daawat mein naql kiya hai keh Imam Baqir (a) ne farmaya: Ek baar Jibraeel (a) Rasoole Khuda (s) ki khidmat aaye aur kaha, “Ay Allah ke Rasool (s) mai ne kisi paighambar ko itna nahi chaha jitna Aap (s) ko. Tumhe chahiye ke is zikr ko ba-kasrat padha kare”…", "UrduDescription": "سید ابن طاؤسؒ نے مہج الدعوات میں امام محمد باقر ؑسے نقل کیا ہے: جبرائیل ؑ نے رسول اﷲؐ سے عرض کیا : میں کسی پیغمبر کو آپ سے بڑھ کر دوست نہیں رکھتا لہٰذا آپ کثرت سے یہ پڑھا کریں۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, 