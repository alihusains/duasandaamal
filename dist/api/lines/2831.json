[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011772, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I have passed the evening as a very humble servant of Thee. I have no control over the gains and losses for my person. I cannot remove any evil from myself. I depose against my conscience. I admit my weakness and inability of managing my affairs. Bestow Thy blessings on Mohammad (saw.) and his Family. Whatever Thou hast given me or promised, fulfill that. Verily! I am Thy humble, weak and destitute servant.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Be-shak mai ne shaam ki is haal mein keh Tera aastaan-boos (chaukhat ka) banda hu, na apne nafe ka maalik hu aur na nuqsaan ka aur na buraayi ko is se dur kar sakta hu, mai apne nafs par khud hi gawah hu aur Tere saamne eteraaf karta hu apni kamzori, be-chaargi aur be-basi ka. Pas Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma aur apna woh maghferat ka waada pura farma jo is raat mein mere liye aur tamaam momeneen o momenaat ke liye jo Tu ne umoomi (aam) taur par kar rakkha hai aur mujh par apni ataaye wa rehmat puri farma de keh be-shak mai Tera be-kas, na-chaar (be-sahaara), be-taaqat, mohtaaj aur past-tareen banda hu.", "Urdu": "اے معبود!بے شک میں نے شام کی اس حال میں کہ تیرا آستاں بوس بندہ ہوں نہ اپنے نفع کا مالک ہوں اورنہ نقصان کا اور نہ برائی کو اس سے دور کر سکتا ہوں میں اپنے نفس پر خود ہی گواہ ہوں اور تیرے سامنے اعتراف کرتا ہوں اپنی کمزوری بے چارگی اور بے بسی کا پس محمدؐ وآل محمدؑ پر رحمت نازل فرما اور اپنا وہ مغفرت کا وعدہ پورا فرما جو اس رات میں میرے لئے اور تمام مومنین ومومنات کے لئے جو تونے عمومی طور پر کر رکھا ہے اور مجھ پر اپنی عطاورحمت پوری فرما دے کہ بے شک میں تیرا بے کس،ناچار، بے طاقت، محتاج اور پست ترین بندہ ہوں۔", "RArabic": "ALLAAHUMMA INNEE AM-SAIY-TO LAKA A’BDAN DAAKHE-RAN LAA AMLE-KO LE-NAFSEE NAF-A’N WA LAA ZARRAN WA LAA ASRE-FO A’N-HAA SOO-AN, ASH-HADO BE-ZAALEKA A’LAA NAFSEE WA A’TARE-FO LAKA BE-ZA’FE QUWWA-TEE WA QILLA-TE HEE-LATEE FA-SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA ANJIZ LEE MAA WA-A’D-TANEE WA JAMEE-A’L MOME-NEENA WAL MOME-NAATE MENAL MAGH-FE-RATE FEE HAAZE-HIL LAIY-LATE WA AT-MIM A’LAIY-YA MAA AA-TAIY-TANEE FA-INNEE A’B-DOKAL MISKEE-NUL MUS-TAKEE-NUZ ZA-E’E-FUL FAQEE-RUL MAHEE-NO.", "ArabicText1": "اَللّٰهُمَّ اِنِّيْ اَمْسَيْتُ لَكَ عَبْدًا دَاخِرًا لَا اَمْلِكُ لِنَفْسِيْ نَفْعًا وَلَا ضَرًّا وَلَا اَصْرِفُ عَنْهَا سُوْءًا، اَشْهَدُ بِذٰلِكَ عَلٰى نَفْسِيْ وَاَعْتَرِفُ لَكَ بِضَعْفِ قُوَّتِيْ وَقِلَّةِ حِيْلَتِيْ فَصَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَاَنْجِزْ لِيْ مَا وَعَدْتَنِيْ وَجَمِيْعَ الْمُؤْمِنِيْنَ وَالْمُؤْمِنَاتِ مِنَ الْمَغْفِرَةِ فِيْ هٰذِهِ اللَّيْلَةِ وَاَتْمِمْ عَلَيَّ مَا آتَيْتَنِيْ فَاِنِّيْ عَبْدُكَ الْمِسْكِيْنُ الْمُسْتَكِيْنُ الضَّعِيْفُ الْفَقِيْرُ الْمَهِيْنُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011773, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Let me not forget the blessings that Thou hast bestowed on me and let me not be forgetful about Thy kindness. Do not deny me Thy acceptance though it may be delayed, may it pertain to sorrow or happiness, and may it be connected with peace and tranquility or hardship and vicissitudes or pertaining to blessings. Thou hears and accepts invocations in every condition.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mujhe aisa na bana keh Teri ataawo’n ke zikr ko bhul jaawu, Tere ehsaanaat se ghaflat karu aur Teri taraf se qaboole dua se maayoos ho jaawu agar-che mai ghaflat shaar (barat ne waala) hu. Khushi o gham mein, ya sakhti o aasoodgi mein, ya aasaani o tangi mein, ya mehroomi o neymat mein, be-shak Tu dua ka soon ne waala hai.", "Urdu": "اے معبود! مجھے ایسا نہ بنا کہ تیری عطاؤں کے ذکر کو بھول جاؤں تیرے احسانات سے غفلت کروں اور تیری طرف سے قبولِ دعا سے مایوس ہو جاؤں اگرچہ میں غفلت شعار ہوں خوشی وغم میں یا سختی وآسودگی میں یا آسانی وتنگی میں یامحرومی و نعمت میں بے شک تو دعا کا سننے والا ہے۔", "RArabic": "ALLAAHUMMA LAA TAJ-A’L-NEE NAASE-YAN LE-ZIKRE-KA FEE-MAA AWLEE-TANEE WA LAA (GHAAFE-LAN) LE-EH-SAANE-KA FEE-MAA A’TAIY-TANEE WA LAA AAYE-SAN MIN EJAA-BATEKA WA IN ABTA-AT A’NNEE FEE SARRAA-A (KUNTO) AW-ZARRAA-A AW-SHIDDA-TIN AW-RAKHAA-IN AW-A’AFE-YATIN AW-BALAA-IN AW-BOO-SIN AW-NA’MAA-A INNA-KA SAMEE-U’D DOAA’-E.", "ArabicText1": "اَللّٰهُمَّ لَا تَجْعَلْنِيْ نَاسِيًا لِذِكْرِكَ فِيْمَا اَوْلَيْتَنِيْ وَلَا (غَافِلًا) لِاِحْسَانِكَ فِيْمَا اَعْطَيْتَنِيْ وَلَا آيِسًا مِنْ اِجَابَتِكَ وَاِنْ اَبْطَاَتْ عَنِّيْ فِيْ سَرَّاءَ (كُنْتُ) اَوْ ضَرَّاءَ اَوْ شِدَّةٍ اَوْ رَخَاءٍ اَوْ عَافِيَةٍ اَوْ بَلَاءٍ اَوْ بُؤْسٍ اَوْ نَعْمَاءَ اِنَّكَ سَمِيْعُ الدُّعَاءِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "A