[{"Id": 1013740, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "It is highly recommended to enter the Holy shrine through Eastern door. When you reach the gate of the shrine, stop there and recite…", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh Rauze mein purvi darwaaze (eastern door) se daakhil ho. Jab aap darwaaze par pohonche to wahan khade ho kar yeh padhe…", "UrduDescription": "جب حرم ِ مبارک کے دروازے پر پہنچے تو یہ کلمات کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1013741, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah is most great and abundant praise is for Allah and I glorify Allah morning and evening. All praise for Allah, the one who guided us and we would not have been guided had Allah not guided us. Certainly the Apostle of our Lord brought the truth.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda buzurg-tar hai. Khuda ke liye bohot ziyadah hamd o sana hai aur Khuda paak o munazzah hai, har subh o shaam hamd hai Khuda ke liye jis ne hamein yeh raah dikhlaayi aur ham raah na paatey agar Khuda hamein raasta na dikhlaata. Be-shak Khuda ke Rasool (s.a.w.a) haq ke saath hai.", "Urdu": "خدا بزرگ تر ہے خدا کے لئے بہت زیادہ حمدو ثنا ہے اور خدا پاک ومنزہ ہے ہر صبح و شام حمد ہے خدا کے لئے جس نے ہمیں یہ راہ دکھائی اور ہم راہ نہ پاتے اگر خدا ہمیں راستہ نہ دکھاتابے شک خدا کے رسولؐ حق کے ساتھ آئے۔", "RArabic": "ALLAAHO AKBARO KABEERAN WAL-HAMDO LILLAAHE KASEERAN WA SUBHAANAL LAAHE BUKRATAWN WA ASEELAN ALHAMDO LILLAAHIL LAZEE HADAANAA LE-HAAZAA WA KUNNA LE-NAHTADEYA LAWLAA AN HADAANAL LAAHO LAQAD JAA-AT ROSOLO RABBENAA BIL-HAQQE.", "ArabicText1": "اَللهُ اَكْبَرُ كَبِیْرًا وَالْحَمْدُ لِلهِ كَثِیْرًا وَسُبْحَانَ اللہِ بُكْرَۃً وَّاَصِیْلًا۔ اَلْحَمْدُ لِلهِ الَّذِیْ هَدَانَا لِهٰذَا وَمَا كُنَّا لِنَهْتَدِیَ لَوْلَا اَنْ هٰدَانَا اللہُ لَقَدْ جَائَتْ رُسُلُ رَبِّنَا بِالْحَقِّ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013742, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "Then recite…", "GujaratiDescription": null, "RUrduDescription": "Phir padhe…", "UrduDescription": "پھر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013743, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on you, O the Apostle of Allah. Peace be on you, O the Prophet of Allah. Peace be on you, O the last of the Prophets. Peace be on you, O the chief of the Apostles. Peace be on you, O the beloved of Allah. Peace be on you, O the commander of the faithful. Peace be on you, O the leader of the vicegerents.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Khuda ke Rasool (s.a.w.a). Salaam ho aap par ay Khuda ke Nabi (s.a.w.a). Aap par salaam ho ay nabiyyo’n ke khaatim. Aap par salaam ho ay rasoolo’n ke sardaar. Aap par salaam ho ay Khuda ke habib. Salaam ho aap par ay momino ke ameer. Aap par salaam ho ay ausiya ke sardaar.", "Urdu": "آئے آپ پر سلام ہو اے خدا کے رسولؐ،سلام ہو آپ پر اے خدا کے نبیؐ،آپ پر سلام ہو اے نبیوں کے خاتم،آپ پر سلام ہو اے رسولوں کے سردار، آپ پر سلام ہو اے خدا کے حبیب،سلام ہو آپ پر اے مومنوں کے امیر،آپ پر سلام ہو اے اوصیاء کے سید و سردار۔", "RArabic": "AS-SALAAMO A’LAIKA YAA RASOOLAL LAAHE AS-SALAAMO A’LAIKA YAA NABIYYAL LAAHE AS-SALAAMO A’LAIKA YAA KHATAMAN NABIYYEENA AS-SALAAMO A’LAIKA YAA SAYYEDAL MURSALEENA AS-SALAAMO A’LAIKA YAA HABEEBAL LAAHE AS-SALAAMO A’LAIKA YAA AMEERAL MOMENEENA AS-SALAAMO A’LAIKA YAA SAYYEDAL WASIYYEENA.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا رَسُوْلَ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا نَبِیَّ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا خَاتَمَ النَّبِیِّیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَا سَیِّدَ الْمُرْسَلِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَا حَبِیْبَ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا اَمِیْرَ الْمُؤْمِنِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَا سَیِّدَ الْوَصِیِّیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013744, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on you, O the guide of those with radiant forbade. Peace be on you, O the son of Fatima, the leader of the women of the Universe. Peace be on you, on the leaders from your progeny. Peace be on you, O the vicegerent of the commander of the faithful. Peace be on you, O the truthful, the martyr.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay chamakte huwe chehro’n waalo’n ke peshwa. Aap par salaam ho ay Fatema Zahra (s.a) ke farzand jo tamaam aurto’n ki sardaar hai. Aap par salaam ho aur un Aimma (a.s) par jo aap ki aulaad se hai. Salaam ho aap par ay Ameerul Momeneen (a.s) ke ja-nasheen. Aap par salaam ho jo keh siddiq o shaheed hai.", "Urdu": "آپ پر سلام ہو اے چمکتے ہوئے چہروں والوں کے پیشوا، آپ پر سلام ہو اے فاطمہ زہراؑء کے فرزند جو تمام عورتوں کی سردار ہیں آپ پر سلام ہواور ان ائمہؑ پر جو آپ کی اولاد سے ہیں سلام ہو آپ پر اے امیر المومنینؑ کے جانشین آپ پر سلام ہوجو صدیق و شہید ہیں۔", "RArabic": "AS-SALAAMO A’LAIKA YAA QAA-EDAL GHURRIL MOHAJJALEENA AS-SALAAMO A’LAIKA YABNA FAATEMATA SAYYEDATE NESAAA-IL A’ALAMEENA AS-SALAAMO A’LAIKA WA A’LAL A-IMMATE MIN WULDEKA AS-SALAAMO A’LAIKA YAA WASIYYA AMEERIL MOMENEENA AS-SALAAMO A’LAIKA AYYOHAS SIDDEEQUSH SHAHEEDO.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا قَائِدَ الْغُرِّ الْمُحَجَّلِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ فَاطِمَۃَ سَیِّدَۃِ نِسَآءِ الْعَالَمِیْنَ۔ اَلسَّلَامُ عَلَیْكَ وَعَلَی الْاَئِمَّۃِ مِنْ وُلْدِكَ۔ اَلسَّلَامُ عَلَیْكَ یَا وَصِیَّ اَمِیْرِ الْمُؤْمِنِیْنَ۔ اَلسَّلَامُ عَلَیْكَ اَیُّهَا الصِّدِّیْقُ الشَّهِیْدُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013745, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on you, O the angels of Allah stationed at this esteemed place. Peace be on you, O the angels of my Lord, who encircle the grave of Imam Husain (a.s). Peace be on you, always till the time I exist and the night and the day exist.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Khuda ke farishto jo us ba-barkat maqaam par rehte ho. Aap par salaam ho ay Khuda ke woh farishto jo qabre Husain (a.s) ke ird-gird khade ho. Salaam ho us Imam par, salaam ho Tum par meri taraf se jab tak zindah hu aur jab tak din o raat baaqi hai.", "Urdu": "آپ پر سلام ہو اے خدا کے فرشتو جو اس بابرکت مقام پر رہتے ہو آپ پر سلام ہو اے خدا کے وہ فرشتو جو قبرِ حسینؑ کے ارد گرد کھڑے ہو سلام ہو اس امام پر سلام ہو تم پر میری طرف سے جب تک زندہ ہوں اور جب تک دن رات باقی ہیں۔", "RArabic": "AS-SALAAMO A’LAYKUM YAA MALAAA-EKATAL LAAHIL MOQEEMEENA FEE HAAZAL MAQAAMAISH SHAREEFE ASSALAMO A’LAYKUM YAA MALAAA-EKATA RABBEYAL MOHDEQEENA BE-QABRIL HUSAYNE A’LAYHIS SALAAMO AS-SALAAMO A’LAYKUM MINNEE ABADAM MAA BAQEETO WA BAQEYAL LAYLO WAN NAHAARO.", "ArabicText1": "اَلسَّلَامُ عَلَیْكُمْ یَا مَلٓاَئِكَۃَ اللہِ الْمُقِیْمِیْنَ فِیْ هٰذَا الْمَقَامِ الشَّرِیْفِ۔ اَلسَّلَامُ عَلَیْكُمْ یَا مَلٓاَئِكَۃَ رَبِّیْ الْمُحْدِقِیْنَ بِقَبْرِ الْحُسَیْنِ عَلَیْهِ السَّلَامُ۔ اَلسَّلَامُ عَلَیْكُمْ مِّنِّیْ اَبَدًا مَّا بَقِیْتُ وَبَقِیَ اللَّیْلُ وَالنَّهَارُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013746, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 3, "EnglishDescription": "Then recite…", "GujaratiDescription": null, "RUrduDescription": "Phir padhe…", "UrduDescription": "پھر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013747, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on you, O Abu Abdullah. Peace be on you, O the son of the Apostle of Allah. Peace be on you, O the son of the commander of the faithful. I am your servant and the son of your servant and the son of your maid. I affirm to your servitude and deny opposing you and I am a friend of your friends and an enemy to your enemies.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Abu Abdillah (a.s). Aap par salaam ho ay Rasool'e Khuda ke farzand. Aap par salaam ho ay Ameerul Momeneen (a.s) ke farzand. Aap ka ghulaam aap ke ghulaam ka beta aur aap ki kaneez ka beta, ghulaami ka iqraar karta hai aur aap ki mukhaalefat tark kar raha hai, yeh aap ke dosto’n ka dost aur aap ke dushmano ka dusman hai.", "Urdu": "  آپ پر سلام ہو اے ابو عبداﷲؑ آپ پر سلام ہو اے رسولِ خداؐ کے فرزند آپ پر سلام ہو اے امیر المومنینؑ کے فرزند آپ کا غلام آپ کے غلام کا بیٹا اور آپ کی کنیز کابیٹا غلامی کا اقرار کرتا ہے اور آپ کی مخالفت ترک کر رہا ہے یہ آپ کے دوستوں کا دوست اور آپ کے دشمنوں کادشمن ہے۔", "RArabic": "AS-SALAAMO A’LAYA YAA ABAA A’BDIL LAAHE AS-SALAAMO A’LAIKA YABNA RASOOLIL LAAHE AS-SALAAMO A’LAIKA YABNA AMEERIL MOMENEENA A’BDOKA WABNO A’BDEKA WABNO AMATEKAL MOQIRRO BIR-RIQQE WAT-TAAREKO LIL-KHELAAFE A’LAYKUM WAL-MOWAALEE LE-WALIYYEKUM WAL-MO-A’ADEE LE-A’DUWWEKUM.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا اَبَا عَبْدِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ اَمِیْرِ الْمُؤْمِنِیْنَ عَبْدُكَ وَابْنُ عَبْدِكَ وَابْنُ اَمَتِكَ الْمُقِرُّ بِالرِّقِّ وَالتَّارِكُ لِلْخِلَافِ عَلَیْكُمْ وَالْمُوَالِیْ لِوَلِیِّكُمْ وَالْمُعَادِیْ لِعَدُوِّكُمْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013748, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I have come to your sanctuary and sought refuge in your tomb and seek proximity to Allah by your visitation. Do I enter, O the Apostle of Allah? Do I enter, O the Prophet of Allah? Do I enter, O the commander of the faithful? Do I enter, O the chief of the vicegerents? Do I enter, O Fatima, the leader of the women of the Universe? Do I enter, O my master, O Abu Abdullah? Do I enter, O my master, O the son of Apostle of Allah?", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap ke aastaan par aaya aur aap ke rauze ki panah liye huwe hai, aap ke qareeb huwa hai, aap ki tamanna karte huwe kya andar aa jaawu? Ay Khuda ke Rasool (s.a.w.a) kya mai andar aa jaawu. Ay Nabi kya mai andar aa jaawu? Ay momino ke ameer kya andar aa jaawu? Ay ausiya ke sardaar kya andar aa jaawu? Ay Fatema (s.a) do jahano ki aurto’n ki sardaar kya andar aa jaawu? Ay mere Aaqa ay Abu Abdillah (a.s) kya andar aa jaawu? Ay mere Maula ay Rasool'e Khuda (s.a.w.a) ke farzand.", "Urdu": "آپ کے آستانے پر آیااور آپ کے روضہ کی پناہ لئے ہوئے ہے آپ کے قریب ہوا ہے آپ کی تمنا کرتے ہوئے کیا اندرآجاؤں اے خدا کے رسولؐ ؟کیا میں اندر آجاؤں اے نبیؐ؟ کیا میں اندر آجاؤں اے مومنوں کے امیر؟ کیا اندر آ جاؤں اے اوصیاء کے سردار ؟کیا اندر آ جاؤں اے فاطمہؑ دو جہانوں کی عورتوں کی سردار؟ کیا اندر آ جاؤں اے میرے آقااے ابو عبداﷲؑ ؟کیا اندر آ جاؤں اے میرے مولا اے رسولؐ خداکے فرزند؟", "RArabic": "QASADA HARAMAKA WAS-TAJAARA BE-MASH-HADEKA WA TAQARRABO ILAIKA BE-QASDEKA A-ADKHOLO YAA RASOOLAL LAAHE? A-ADKHOLO YAA FAATEMATO SAYYEDATA NESAAA-IL A’ALAMEENA? A-ADKHOLO YAA MAWLAAYA YAA ABAA A’BDIL LAAHE? A-ADKHOLO YAA MAWLAAYA YABNA RASOOLIL LAAHE?", "ArabicText1": "قَصَدَ حَرَمَكَ وَاسْتَجَارَ بِمَشْهَدِكَ وَتَقَرَّبَ اِلَیْكَ بِقَصْدِكَ ءَاَدْخُلُ یَا رَسُوْلَ اللہِ؟ ءَاَدْخُلُ یَا فَاطِمَۃُ سَیِّدَۃَ نِسَآءِ الْعَالَمِیْنَ؟ ءَاَدْخُلُ یَا مَوْلَایَ یَا اَبَا عَبْدِ اللہِ؟ ءَاَدْخُلُ یَا مَوْلَایَ یَابْنَ رَسُوْلِ اللہِ؟", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013749, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 4, "EnglishDescription": "Then if tears come out from your eyes it means you have got the permission to enter. While enter the shrine, enter from Imam (a)’s head side and say…", "GujaratiDescription": null, "RUrduDescription": "Phir agar aankho’n se aasoo’n jaari ho to iska matlab yeh hai keh ijaazat hai. Imam Husain (a) ki qabr mubarak mein sar ki taraf se daakhil ho aur kahe…", "UrduDescription": "اس وقت اگر زائر کے دل میں خشوع و خضوع اور آنکھوںمیں آنسو آجائیں تو اس کو داخل ہونے کی اجازت تصور کرے اور حرم مبارک کے اندر داخل ہوتے ہوئے یہ کلمات کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1013750, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "All praise belongs to Allah, the One, the Unique, the Matchless, the Self-sufficient, the one who guided me to your mastership and distinguished me by your visitation and made easy my journey to you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ki hamd hai jo yakta hai, yagana hai, akela hai, be-neyaaz hai, jis ne mujhe aap ki wilaayat ka raasta bataaya, mujh ko aap ki ziyarat ke liye makhsoos kiya aur aap ki taraf aane mein sahulat (aasaani) di.", "Urdu": "خدا کی حمد ہے جو یکتا ہے یگانہ ہے اکیلا ہے بے نیاز ہے جس نے مجھے آپ کی ولایت کا راستہ بتایا مجھ کو آپ کی زیارت کے لئے مخصوص کیا اور آپ کی طرف آنے میں سہولت دی ۔", "RArabic": "ALHAMDO LILLAAHIL WAAHEDIL AHADIL FARDIS SAMADIL LAZEE HADAANEE LE-WELAAYATEKA WA KHASSANEE BE-ZEYAARATEKA WA SAHHALA LEE QAS-DAKA.", "ArabicText1": "اَلْحَمْدُ لِلهِ الْوَاحِدِ الْاَحَدِ الْفَرْدِ الصَّمَدِ الَّذِیْ هَدَانِیْ لِوِلَایَتِكَ وَخَصَّنِیْ بِزِیَارَتِكَ وَسَهَّلَ لِیْ قَصْدَكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null,