[{"Id": 1016326, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "INSHA-ALLAH COMING SOON", "GujaratiDescription": null, "RUrduDescription": "Jab se aasmaan-e-risaalat se Khursheed-e-rukh (roshan chehra) Zahra (s.a) namudaar (zaahir) huwa aur phir jalaalat o azmat ke ofuq par kaamil huwa, to tamaam logo’n ki fikre’n aur nighahe’n aap ki taraf thi.", "UrduDescription": "جب سے آسمان رسالت سے خورشید رخ \"زہرا\" نمودار ہوا اور پھر جلالت و عظمت کے افق پر کامل ہوا، تو تمام لوگوں کی فکریں اور نگاہیں آپ کی طرف تھیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016327, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": "As-haab-e-Paighambar chun-keh aap ki ehmiyat se waaqif thay aur jaante thay is liye darwaaza-e-risaalat par shaadi ke paighaam bhejte, lekin Paighambar har baar taal dete thay. Kafoo (shohar) ki tashkhees (chunna) koi maamooli kaam nahi bal-keh insaan usko samajh ne se aajiz hai, faqat woh zaat jo logo’n ke zameero’n se aagaah hai, jaante hai keh kaun kis ka kafoo hai aur maujoodaat aalam mein koun kis ke bara-bar hai. Is hawaale se Hazrat Fatema (s.a) ka intekhaab Ameerul Momeneen (a.s) ke liye ek Ilaahi intekhaab hai, Zahra (s.a) ke liye shauhar aur kafoo (partner) khud zaat-e-Khuda ne chuna, us aasmaani nikah ka khutba khud Parwardigaar ne padha, aur is azdawaaj-e-muqaddas ke gawah zaat-e-Paighambar-e-giraami aur Jibraeel (a.s) aur khud farishte hai.", "UrduDescription": "اصحاب پیغمبر چونکہ آپ کی اہمیت سے واقف تھے اور جانتے تھے اس لئے دروازہ رسالت پر شادی کے پیغام بھیجے، لیکن پیغمبر ہر بار ٹال جاتے تھے۔کفو کی تشخیص کوئی معمولی کام نہیں بلکہ انسان اس کو سمجھنے سے عاجز ہے فقط وہ ذات جو لوگوں کے ضمیروں سے آگاہ ہے جانتا ہے کہ کون کس کا کفو ہے اور موجودات عالم میں کون کس کے برابر ہے۔ اس حوالے سے حضرت فاطمہ کا انتخاب امیر المومنین کے لئے ایک الٰہی انتخاب ہے، زہرا کیلئے شوہر اور کفو خود ذات احدیت نے چنا، اس آسمانی نکاح کاخطبہ خود پروردگار نے پڑھا، اور اس ازدواج مقدس کے گواہ ذات پیغمبر گرامی اور حضرت جبرئیل اور خود فرشتے ہیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": 