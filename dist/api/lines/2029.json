[{"Id": 1018541, "EnglishTitle": "His supplication on the deer's skin to avert black magic.", "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018542, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the name of Allah and by Allah, glorified is Allah in the name of Allah and there is no power or strength except Allah the most high, the great. Moosa (a.s) said to them: What you have brought is description, surely Allah will make it naught, surely Allah does not make the work of mischief makers to thrive and Allah will show the truth to be the truth by His words, though the guilty may be averse to it. So the truth was established and what they did became null. Thus they were vanquished there and they went back abused. (Qur’an 10 : 81-82 and 7 : 118-119)", "Gujarati": null, "RGujarati": null, "RUrdu": "Allah ke naam aur Allah ki zaat se, Allah ke naam se har iraadah Allah ka iraadah hai, buzurg o bartar Allah ke alaawah koi saaheb’e taaqat o quwwat nahin, Moosa (a.s) ne kaha; “Yeh saher (jadoo) to tum pesh kar rahe ho, be-shak Allah bohot jald be-kaar kar dega. Allah fasaadiyo’n ke amal ki islaah nahin karta, aur Allah haq ko apne kalemaat se saabit karta hai, chahe mujrimo ko na-gawaar guzre, lehaaza haq saabit huwa aur jo kuchh woh kaafir kar rahe thay, woh baatil ho gaya, woh saaher (jaadoo-gar) wahin haar kar haqeero’n ki tarah waapas ho gaye.", "Urdu": "اللہ کے نام اور اللہ کی ذات سے، اللہ کے نام سے ہر ارادہ اللہ کا ارادہ ہے، بزرگ و برتر اللہ کے علاوہ کوئی صاحبِ طاقت و قوت نہیں، موسٰیؑ نے کہا: یہ سحر تو تم پیش کر رہے ہو، بلا شبہ اللہ بہت جلد بیکار کردے گا، اللہ فسادیوں کے عمل کی اصلاح نہیں کرتا، اور اللہ حق کو اپنے کلمات سے ثابت کرتا ہے، چاہے مجرموں کو ناگوار گذرے، لہذا حق ثابت ہوا اور جو کچھ وہ کافر کر رہے تھے وہ باطل ہوگا، وہ ساحر و ہیں ہار کر حقیروں کی طرح واپس ہو گئے۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "بِسْمِ اللهِ وَبِاللهِ بِسْمِ اللهِ مَاشَاۗئَ اللهُ بِسْمِ اللهِ وَلَا حَوْلَ وَلَا قُوَّۃَ اِلَّا بِاللهِ الْعَلِیِّ الْعَظِیْمِ قَالَ مُوْسٰی مَا جِئْتُمْ بِهِ السِّحْرُ اِنَّ اللهَ سَیُبْطِلُهٗ اِنَّ اللهَ لَا یُصْلِحُ عَمَلَ الْمُفْسِدِیْنَ وَ یُحِقُّ اللهُ الْحَقَّ بِكَلِمَاتِهٖ وَلَوْ كَرِهَ الْمُجْرِمُوْنَ فَوَقَعَ الْحَقُّ وَبَطَلَ مَا كَانُوْا یَعْمَلُوْنَ فَغُلِبُوْا هُنَالِكَ وَانْقَلَبُوْا صَاغِرِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null,