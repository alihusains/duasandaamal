[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011619, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O the God of the formers and the laters and O the God of those who remain and the God of those who pass away. O Lord of the seven heavens and whatever is in them. O one who breaks the day and One who made the night as the time of repose and One who made the Sun and the Moon as a way of calculating the time. Praise is for You and thankfulness is for You. And only You are the beneficent and the giver of bounties. You are the One, the Unique, the self-sufficient. I ask you for the sake of Your majesty O my Chief and for the sake of Your beauty O my Master that You bless Muhammad and Aale Muhammad (a.s) and forgive me and have mercy on me and overlook my faults. Indeed You are the forgiving and merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay pehlo’n aur peechhlo’n ke Khuda, ay maujood rehne waalo’n ke Khuda aur ay guzar jaane waalo’n ke Khuda, ay saat (7) aasmaano aur un mein basne (rehne) waalo’n ke Khuda, ay subh ki paw (twilight) phaad ne waale, ay raat ko baaise sukoon qaraar dene waale. Ay chaand aur suraj ko auqaat (waqt) shumaari ka zariya bana ne waale. Tere hi liye hamd hai aur Tere hi liye shukr hai aur Tu hi karam o ehsaan ka maalik hai aur Tu hi taaqat o quwwat waala aur Tu hi akela be-neyaaz wa be-aiyb hai. Ay mere Aqa o Maula mai Tujh se Teri buzurgi aur Tere kamaale husn o sifaat ke wasile se sawaal karta hu, keh Tu Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur mere gunaho’n ko bakhsh de aur mujh par rahem kar aur mujh ko meri khataawo’n se dar-guzar farma, yaqeenan Tu bakhsh ne waala aur rahem karne waala hai.", "Urdu": "اے پہلوں اور پچھلوں کے خدا، اے موجود رہنے والوں کے خدا اور اے گزر جانے والوں کے خدا، اے سات آسمانوں اور ان میں بسنے والوں کے خدا، اے صبح کی پو پھاڑ نے والے، اے رات کو باعث سکون قرار دینے والے۔ اے چاند اور سرج کو اوقات شوماری کا ذریعہ بنانے والے۔ تیرے ہی لئے حمد ہے اور تیرے ہی لئے شکر ہے اور تو ہی کرم و احسان کا مالک ہے اور تو ہی طاقت و قوت والا اور تو ہی اکلا بے نیاز و بے عیب ہے۔ اے میرے آقا و مولا میں تجھ سے تیری بزرگی اور تیرے کمال حسن و صفات کے وسل سے سوال کرتا ہو، کہ تو محمدؐ اور ان کی آلؑ پر رحمت نازل فرما اور میرے گناہوں کو بخش دے اور مجھ پر رحم کر اور مجھ کو میری خطاؤں سے درگزر فرما، یقینًا تو بخش نے والا اور رحم کرنے والا ہے۔", "RArabic": "YAA ILAA-HAL AWWA-LEENA WAL AAKHE-REENA WA ILAAHA MAN BAQE-YA WA ILAAHA MAN MAZAA RABBIS SAMAA-WAATIS SAB-E’ WA MAN FEE HINNA FAALE-QAL AS-BAAHA WA JAA-E’LAL LAIY-LE SAKA-NAN WASH SHAMSE WAL QAMARE HUSBAA-NAN LA-KAL HAMDO WA LA-KASH SHUKRO WA LA-KAL MANNO WA LA-KAT TAWLO WA ANTALWAAHE-DUL AHA-DUS SAMADO AS-ALOKA BE-JALAALE-KA SAYYEDEE WA JAMAALE-KA MAWLAAYA AN TO-SALLEY-YA A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA AN TAGH-FERA-LEE WA TAR-HAMNEE BE-TAJAA-WAZ A’NNEE INNA-KAL GHAFOO-RUR RAHEEM.", "ArabicText1": "یَااِلٰہَ الْاَوَّلِیْنَ وَالْاٰخِرِیْنَ وَاِلٰہَ مَنْ بَقِیَ وَاِلٰہَ مَنْ مَضٰی رَبِّ السَّمٰوٰتِ السَّبْعِ وَمَنْ فِیْہِنَّ فَالِقَ الْاَصْبَاحِ وَجَاعِلَ اللَّیْلِ سَکَنًا وَّالشَّمْسِ وَالْقَمَرِ حُسْبَانًا لَکَ الْحَمْدُ وَلَکَ الشُّکْرُ وَلَکَ الْمَنُّ وَلَکَ الطَّوْلُ وَاَنْتَ الْوَاحِدُ الْاَحَدُالصَّمَدُ اَسْئَلُکَ بِجَلَالِکَ سَیِّدِیْ وَجَمَالِکَ مُوْلَایَ اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاَنْ تَغْفِرَلِیْ وَتَرْحَمْنِیْ وَتَجَاوَزْ عَنِّیْ اِنَّکَ الْغَفُوْرُالرَّحِیْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "Ar