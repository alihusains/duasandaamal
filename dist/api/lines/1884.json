: null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1002922, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Lord of favoring and magnanimity! O Lord of favoring and bounty! O He Who has selected Muhammad, peace of Allah be upon him and his Household, (please do) send blessings to Muhammad and his Household.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Saahebe ehsaan o karam, ay maalik'e jud o ataa, ay Paighambar ko muntakhab karne waale. Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma aur hamari tamaam haajato’n ko pura kar de.", "Urdu": "اے احسان و عطا والے! اے احسان وبخشش والے اے حضرت محمدؐ کو منتخب وبرگزیدہ کرنے والے محمدؐ اور ان کی آلؑ پر رحمت نازل فرما اور میرے لئے یہ اور یہ کردے۔", "RArabic": "YA ZAL MANNE WAL JOODE YA ZAL MANNE WATTAULE YA MUSTAFEYA MUHAMMADIN SALLALLAAHU ALAIHE WA AALEHI SALLE ALAA MUHAMMADIW WA AALEHI WAF’AL BI KAZA KAZA.", "ArabicText1": "یَاذَالْمَنِّ وَالْجُوْدِ یَاذَالْمَنِّ وَالطَّوْلِ یَامُصْطَ