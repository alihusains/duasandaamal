[{"Id": 1016155, "EnglishTitle": "Dua for the gratitude of her right on the day of Judgment.", "GujaratiTitle": null, "RUrduTitle": "Roz-e-Qayaamat ke din mein apne haq ki pehchaan ke liye.", "UrduTitle": "قیامت کے دن میں اپنے حق کی پہچان کیلئے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016156, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is narrated that Jabir requested Imam Muhammad Baqir (a): May my parents be sacrificed on you, please mention a tradition for me regarding the excellence of your grandmother, Lady Fatima Zahra (s), so that I may narrate among your Shia and they may be elated by it. Till he said: Almighty Allah will call out: O people of gathering, I have appointed all nobility for Muhammad, Ali, Hasan, Husain and Fatima. O people of gathering, bow down your heads and cast down your glances as Fatima is moving to the Paradise till he said: When she reaches at the gate of Paradise, she would turn back. Allah will ask: O daughter of my beloved, why are you looking back, I have already commanded you to enter Paradise. She would reply…", "GujaratiDescription": null, "RUrduDescription": "Riwaayat mein hai keh Hazrat Jaabir ne Imam Muhammad Baqir (a) se arz kiya, ay farzand-e-Rasool (s) aap par fida, apni jaddah Hazrat Fatema Zahra (s) ke fazaael ke baare mein koi aisi hadees bayaan farmaaye keh agar usey mai Shio’n mein bayaan karu, to woh khoosh ho jaaye, phir Imam (a) ne farmaya; Khuda-wand tabarak o taala farmata hai; ay Ahle-Maheshar mai ne Muhammad, Ali, Hasan, Husain aur Fatema ko kaise ba-izzat qaraar diya hai, ay Ahle-Behist (Jannat waalo’n) apne saro’n ko jhuka lo aur aankhe’n bandh kar lo, yeh Fatema hai jo Behisht (Jannat) ki taraf ja rahi hai, phir woh Jannat ke kinaare pohonch kar khadi rahengi, Awaaz-e-Parwardigaar aayegi; ay mere habeeb ki beti kyu’n ruk gayi ho, jab-keh Mai ne hukm diya hai keh Jannat mein daakhil ho jaawo, itne mein Hazrat Zahra (s) arz karengi…", "UrduDescription": "روایت میں ہے کہ حضرت جابر نے امام محمد باقر علیہ السلام سے عرض کیا، اے فرزند رسول آپ پر فدا اپنی جدہ حضرت فاطمہ زہرا کے فضائل کے بارے میں کوئی ایسی حدیث بیان فرمائیں کہ اگر اسے میں شیعوں میں بیان کروں، تو وہ خوش ہوجائیں، پھر امام علیہ السلام نے فرمایا، خداوند تبارک و تعالیٰ فرماتا ہے اے اہل محشر میں نے محمد، علی، حسن، حسین اور فاطمہ کو کیسے باعزت قرار دیا ہے اے اہل بہشت اپنے سروں کو جھکالو اور آنکھیں بند کرلو، یہ فاطمہ ہے جو بہشت کی طرف جارہی ہیں پھر وہ جنت کے کنارے پہنچ کر توقف کریں گی، آواز پروردگار آئے گی اے میرے حبیب کی بیٹی کیوں رک گئی ہو جبکہ میں نے حکم دیا ہے کہ جنت میں داخل ہو جاؤ، اتنے میں حضرت زہرا عرض کریں گی۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": nul