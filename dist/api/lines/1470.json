[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010106, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O best amongst the Momins, the son of the one who proclaimed Islam first! And, how can it not be so when you are the guide to the path of His advice, you are the piety and a companion of the Kisa. You were fed by the “hand” of Rehmat and you were brought up in the lap of Islam. You drank milk from the bosom of Imaan (faith), Your life was pure and so was your death. But people are not happy over separation from you, although they do not doubt your eternal life. May Allah’s blessings be on you!", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay Baqi’e momeneen aur musalmaano mein sab se pehle musalmaan ke farzand, aur aap unhi jaise kyu’n na hote jab keh aap bhi raahe hidaayat hai. Aur saaheb’e paakeezgi o tahaarat hai aur saahebaan’e kisa ke fard hai. Aap ne rehmat ke haatho’n ghiza haasil ki aur aap ne parwarish paayi Islaam ki aaghosh mein aur aap ne imaan ki chhaati (pistaan) se doodh piya. Pas aap zindagi mein bhi achchhe rahe aur maut bhi achchhayi par huwi. Agar-che digar nafoos aap ki judaayi par gham-zadah huwe aur aap ki zindagi bhar aap se koi shaaki na huwa. Allah aap par apni rehmate’n naazil farmaaye.", "Urdu": "سلام ہو آپ پر اے بقیع کے مومینین اور مسلمانوں میں سب سے پہلے مسلمانوں کے فرزند، اور آپ اُنہی جیسے کیوں نا ہوتے جب کہ آپ بھی راہے حدایت ہے، اور صاحبِ پاکیزگی و طہارت ہے اور صاحبِ کسا کے فرد ہے، آپ نے رحمت کے ہاتھوں غذا حاصل کی اور آپ نے پرورش پائی اسلام کی آغوش میں اور آپ نے ایمان کی چھاتی (پستان) سے دودھ پیا۔ پس آپ زندگی میں بھی اچھے رہے اور موت بھی اچھائی پر ہوئی، اگرچہ دگر نفوس آپ کی جدائی پر غم زدہ ہوئے اور آپ کی زندگی بھر آپ سے کوئی شاکی نہ ہوا، اللہ آپ پر اپنی رحمتیں نازل فرمائے۔", "RArabic": "AS-SALAAMO A’LAIKA YAA BAQEEYA-TAL MO-MENEENA WABNA AWWA-LIL MUSLE-MEENA, WA KAIFA LAA TAKOO-NO KA-ZAALE-KA WA ANTA SABEE-LUL HODAA WA HALEE-FUT TOQAA WA AS-HAA-BUL KESA-AA-E A’Z-ZATKA YADUR RAHMA-TEWA RUBBEE-TA FEE HIJRIL ISLAAME WA ROZE’TA MIN SADYIL EE-MAANE FA-TIBTA HAYYAN WA TIBTA MAYYE-TAN GHAIRA ANNAL AN-FOSA GHAIRA TAIYYE-BATIN BE-FARAA-QE-KA, WA LAA SHAAK-KATIN FIL HAYAATE LAKA, YAR-HAMO-KAL LAAHO.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ یَابَقِیَّۃَ الْمُؤْمِنِیْنَ وَابْنَ اَوَّلِ الْمُسْلِمِیْنَ‘ وَکَیْفَ لَا تَکُوْنُ کَذٰلِکَ وَاَنْتَ سَبِیْلُ الْہُدٰی وَحَلِیْفُ التُّقٰی وَاَصْحَابُ الْکِسَآئِ عَذَّتْکَ یَدُ الرَّحْمَۃِ وَرُبِّیْتَ فِیْ حِجْرِ الْاِسْلَامِ وَرُضِعْتَ مِنْ ثَدْیِ الْاِیْمَانِ فَطِبْتَ حَیًّا وَطِبْتَ مَیِّتًا غَیْرَ اَنَّ الْاَنْفُسَ غَیْرَ طَیِّبَۃٍ بِفِرَاقِکَ‘ وَلَاشَاکَّۃٍ فِیْ الْحَیٰوۃِ لَکَ‘ یَرْحَمُکَ اللہُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6"