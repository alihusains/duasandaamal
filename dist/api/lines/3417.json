: null, "RGujarati": null, "RUrdu": "Allah ki har cheez ke saath panah leta hu, Khuda ke dar-guzar ki panah leta hu, Khuda ki bakhshish ki panah leta hu, Khuda ke Rasool (s.a.w.a) ki panah leta hu aur Aimma (a.s) ki panah leta hu…", "Urdu": "اللہ کی ہرچیز کے ساتھ پناہ لیتا ہوں خدا کے درگزر کی پناہ لیتا ہوں خداکی بخشش کی پناہ لیتا ہوں خدا کےرسولؐ کی پناہ لیتا ہوں اورائمہ کی پناہ لیتا ہوں۔۔۔", "RArabic": "BE-KUL-LIL LAAHE WA AOO’ZO BE-A’F-WIL LAAHE WA AOO’ZO BE-GHUFRAA-NIL LAAHE WA AOO’ZO BE-RASOO-LIL LAAHE WA AOO’ZO BIL AIMMATE…", "ArabicText1": "بِكُلِّ اللهِ وَاَعُوْذُ بِعَفْوِ اللهِ وَاَعُوْذُ بِغُفْرَانِ اللهِ وَاَعُوْذُ بِرَسُوْلِ اللهِ وَاَعُوْذُ بِالْاَئِمَّةِ۔۔۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "Ar