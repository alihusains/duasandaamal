[{"Id": 1014798, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "For those suffering from eye aches, many traditions have recommended saying the following supplicatory prayer after the ritual obligatory prayers of dawn (fajr) and sunset (maghrib)…", "GujaratiDescription": null, "RUrduDescription": "Bohot si riwaayat mein hai keh aankh ka dard khatm karne ke liye Fajr aur Maghrib ki namaz ke baad yeh dua padhe…", "UrduDescription": "بہت سی روایات میں ہے کہ آنکھ کا درد ختم کرنے کے لئے فجر اور مغرب کی نماز کے بعد یہ دعا پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014799, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I beseech You in the name of the right of Muhammad and the Household of Muhammad that is incumbent upon You to bless Muhammad and the Household of Muhammad and to place light in my sight, insight in my faith, certitude in my heart, sincerity in my deeds, safety in myself, opulence in my sustenance, and thanks for You forever as long as You keep me alive.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai sawaal karta hu Muhammad (s.a.w.a) aur Aale Muhammad (a.s) ke us haq ke waaste se jo Tujh par hai, keh Tu rehmat naazil farma Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par aur yeh keh meri aankho’n mein roshni qaraar de, mere deen mein samajh ataa kar, mere dil mein yaqeen paiyda farma, amal mein khuloos de, mere dil ko mutmaeen rakh, mere rizq mein kushaadgi de aur jab tak zindah hu mujhe apna shukr-guzaar banaaye rakh.", "Urdu": "اے معبود! میں سوال کرتا ہو ں محمدؐ وآل محمد ؐکے اس حق کے واسطے سے جو تجھ پر ہے کہ تو رحمت فرما ئے محمدؐاور آلؑ محمدؐ پر اور یہ کہ میری آنکھوں میں روشنی قرار دے میرے دین میں سمجھ عطا کر میرے دل میں یقین پیدا فرما عمل میں خلوص دے میرے دل کو مطمئن رکھ میرےرزق میں کشادگی دے اور جب تک زندہ ہوں مجھے اپنا شکر گزار بنائے رکھ۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA BE-HAQQE MOHAMMADIW WA AALE MOHAMMADIN A’LAIKA AN TO-SALLE-YA A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA AN TAJ-A’LAN NOORA FEE BASA-REE WAL BASEE-RATA FEE DEENEE WAL YAQEE-NA FEE QALBEE WAL IKH-LAASA FEE A’MA-LEE WAS SALAA-MATA FEE NAFSEE WAS SA-A’TA FEE RIZQEE WASH SHUKRA LAKA ABA-DAN MAA ABQAI-TANEE.", "ArabicText1": "اَللّٰهُمَّ اِنِّىْ اَسْئَلُكَ بِحَقِّ مُحَمَّدٍ وَّآلِ مُحَمَّدٍ عَلَيْكَ اَنْ تُصَلِىَّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَاَنْ تَجْعَلَ النُّوْرَ فِىْ بَصَرِىْ وَالْبَصِيْرَةَ فِىْ دِيْنِىْ وَالْيَقِيْنَ فِىْ قَلْبِىْ وَالْاِخْلَاصَ فِىْ عَمَلِىْ وَالسَّلَامَةَ فِىْ نَفْسِىْ وَالسَّعَةَ فِىْ رِزْقِىْ وَالشُّكْرَ لَكَ اَبَدًا مَا اَبْقَيْتَنِىْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014800, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "Al-Bizanti reported Yunus Ibne Zabyan to have said: One day, we visited Imam Sadiq (a) and found him tensely sore-eyed; therefore, we were depressed. The next morning, we visited him while he was completely healed. Surprised by this, we asked him, “May Allah accept us as ransoms for you! Have you treated your eyes with a certain medicine?” The Imam answered, “Yes, I have, I have treated them with the best of all medicines.” “What is that?” we asked. The Imam (a) answered, “It is a supplicatory amulet.” We therefore wrote down that supplicatory amulet, which is as follows…", "GujaratiDescription": null, "RUrduDescription": "Neez Bizanti ne Yunus bin Zabyan se riwaayat ki hai keh ham Imam Jafar Sadiq (a) ki khidmat mein haazir huwe to dekha keh Aap (a) ki aankho’n mein shadeed dard tha yeh haalat dekh kar ham bohot ghamgeen huwe magar dusre roz jab ham Aap (a) ke paas aaye to dekha aankhe’n bilkul thik ho chuki hai ham ne arz kiya, ham Aap (a) par qurbaan ho jaaye Aap ne kisi cheez se aankho’n ka ilaaj kiya hai? Aap (a) ne farmaaya: ham ne ek beh-tareen cheez se iska ilaaj kiya hai, ham ne poochha keh woh kya hai, farmaaya ke woh ek taweez hai, jise ham ne unke bayaan karne par likha aur wa yeh hai…", "UrduDescription": "نیز بزنطی نے یونس ابن ظبیان سے روایت کی ہے : ہم امام جعفر صادق ؑ کی خدمت میں حاضر ہوئے تو دیکھا کہ آپؑ کی آنکھوں میں شدید درد تھا یہ حالت دیکھ کر ہم بہت غمگین ہوئے مگر دوسرے روز جب ہم آپؑ کے پاس آئے تو دیکھا آنکھیں بالکل ٹھیک ہوچکی ہیں ہم نے عرض کی: ہم آپؑ پر قربان ہوجائیں! آپؑ نے کس چیز سے آنکھوں کا علاج کیا ہے؟ فرمایا: ہم نے معالجے کی چیزوں میں سے ایک چیز سے علاج کیا ہے ہم نے پو چھا کہ وہ کیا ہے؟ فرمایا : وہ ایک تعویذ تھا جسے ہم نے لکھا اور وہ یہ ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014801, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I pray the protection of Allah’s almightiness, I pray the protection of Allah’s all-powerfulness, I pray the protection of Allah’s omnipotence, I pray the protection of Allah’s light, I pray the protection of Allah’s grandeur, I pray the protection of Allah’s majesty, I pray the protection of Allah’s beauty, I pray the protection of Allah’s splendor, I pray the protection of Allah’s wholeness.", "Gujarati": null, "RGujarati": null, "RUrdu": "Panah leta hu Khuda ki izzat ki, panah leta hu Khuda ki quwwat ki, panah leta hu Khuda ki qudrat ki, panah leta hu Khuda ke noor ki, panah leta hu Khuda ki buzurgi ki, Khuda ke dab-dabe ki, panah leta hu Khuda ki taabaani ki aur panah leta hu Khuda ke sab kuchh ki.", "Urdu": "پنا ہ لیتا ہوں خدا کی عزّت کی پناہ لیتاہوں خدا کی قوت کی پناہ لیتا ہوں خدا کی قدرت کی پناہ لیتا ہوں خدا کے نور کی پناہ لیتا ہوں خدا کی بزرگی کی خدا کے دبدبے کی پناہ لیتا ہوں خدا کی زیبائی کی پناہ لیتا ہوں خدا کی تابانی کی اور پناہ لیتا ہوں خدا کے سب کچھ کی۔", "RArabic": "AOO’ZO BE-I’ZZA-TIL LAAHE WA AOO’ZO BE-QUWWA-TIL LAAHE WA AOO’ZO BE-QUDRA-TIL LAAHE WA AOO’ZO BE-NOO-RIL LAAHE WA AOO’ZO BE-A’ZAMA-TIL LAAHE WA AOO’ZO BE-JALAA-LIL LAAHE WA AOO’ZO BE-JAMAA-LIL LAAHE WA AOO’ZO BE-BAHAAA-IL LAAHE WA AOO’ZO BE-JAM-IL LAAHE.", "ArabicText1": "اَعُوْذُ بِعِزَّةِ اللهِ وَاَعُوْذُ بِقُوَّةِ اللهِ وَاَعُوْذُ بِقُدْرَةِ اللهِ وَاَعُوْذُ بِنُوْرِ اللهِ وَاَعُوْذُ بِعَظَمَةِ اللهِ وَاَعُوْذُ بِجَلَالِ اللهِ وَاَعُوْذُ بِجَمَالِ اللهِ وَاَعُوْذُ بِبَهَاۗءِ اللهِ وَاَعُوْذُ بِجَمْعِ اللهِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": nu