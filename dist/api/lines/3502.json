l, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of God, Most Compassionate, Most Merciful. Glory be to God! Praise be to Him. Muhammad is His Prophet. O my God! Please bestow Your Blessings on Muhammad and his Progeny and accept my fasting. Do not make me ashamed in front of Muhammad and his Progeny while they delivered the message and advised me. O my God! Please bestow Your Blessings on Muhammad and his Progeny. Please resurrect me with faith in You, and acknowledging Your Book and Your Prophet.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": "بِسْمِ اللهِ الرَّحْمٰنِ الرَّحِيْمِ‌ سُبْحَانَ اللهِ وَبِحَمْدِهٖ مُحَمَّدٌ رَسُوْلُ اللهِ صَلَّى اللهُ عَلَيْهِ وَآلِهٖ۔ اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَتَقَبَّلْ صَوْمِيْ وَلَا تُنَكِّسْ بِرَاْسِيْ بَيْنَ يَدَيِ مُحَمَّدٍ وَّآلِهٖ صَلَوَاتُكَ عَلَيْهِمْ وَقَدْ بَلَغُوْا وَ نَصَحُوْا لِيْ۔ اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَابْعَثْنِيْ عَلَى الْاِيْمَانِ بِكَ وَالتَّصْدِيْقِ بِكِتَابِكَ وَرَسُوْلِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "