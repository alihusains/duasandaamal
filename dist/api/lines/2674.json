[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002188, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, You are my trust in every distress, and my hope in every difficulty and You are for me in every matter that descends on me, a support and preparation. Then how many are the sorrows that weaken the hearts and the lack of solutions and all the near ones desert and the enemies taunt by it and all the affairs become helpless. I leave all of it on You and I complain about it to You, and I refer it to You. Who else is there besides You? Make it easy and take it away from me. And You are sufficient for it. Then You are the giver of all the bounties and the fulfiller of all the needs and the aim of all entreaties. Then exceeding praise is for You... and for You the best of the mercies.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Tu har museebat mein mera sahara hai, har sakhti mein Tu hi meri ummeed ki jagah hai, har tangi jo mujh par aati hai us mein Tu hi mera aasra aur poonji hai, kitni hi mushkile’n hai jin se mera dil kamzor ho jaata hai, tadbeere’n na-kaam ho jaati hai aur apne be-gaane saath chhod jaate hai, dushman taane dete hai aur har kaam pada rahe jaate hai jab Tere huzoor aata hu Tujh se arz karta hu Tere siwa dusro’n se mooh moud leta hu, pas Tu mushkil hal karta hai, sakhti dur karta hai aur meri sar-parasti karta hai aur Tu hi har neymat ka maalik hai, har haajat mein madad-gaar hai aur har khwaaish puri karne waala hai, pas Tere liye hamd hai bohot bohot aur Tu hi ehsaan mein badha huwa hai.", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "ALLAAHUMMA ANTA SEQA-TEE FEE KULLE KARBIN WA RAJAA-EE FEE SHADEEDA-TIN WA ANTA LEE FEE KULLE AMREEN NAZALA BEE SEQA-TOON WA U’DDA-TOON KAM MIN KARBIN YAZ-A’FO FEE-HIL FO-AADO WA TAQQE-DO FEE-HIL WA YUKH-ZALO FEE-HIL QAREEBO WA YASH-MOTO FEE-HIL A’DOOWO WA AN-ZALTA-HU BEKA WA SHA-KAWTA-HU ILAIKA RAGH-BA-TAN FEEHE ILAIKA A’MMAN SEWAA-KA FA-FARRAJA-TAHU WA KA-SHAFTA-HU WA KAFA-TANEE-HE FA-ANTA WALIYYO KULLE NE’MATIN WA SAAHEBO KULLE HASANA-TIN WA MUNTA-HAA KULLE RAGH-BA-TIN FA-LAKAL HAMDO KASEE-RAN WA LAKAL MANNO FAAZE-LAN. ALLAAHUMMA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA SAHHIL LEE MEHNA-TEE WA YASSIR ERAADA-TEE WA AW-SILNEE ILAA BUGH-YATEE SAREE-A’N AA’JE-LAN WAQZE A’NNEE DEENEE YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "اَللّٰہُمَّ اَنْتَ ثِقَتِیْ فِیْ کُلِّ کَرْبٍ وَّرَجَآئِیْ فِیْ کُلِّ شَدِیْدَۃٍ وَّاَنْتَ لِیْ فِیْ کُلِّ اَمْرٍ نَزَلَ بِیْ ثِقَۃٌ وَّعُدَّۃٌ کَمْ مِنْ کَرْبٍ یَّضْعَفُ فِیْہِ الْفُؤَادُ وَتَقِّدُ فِیْہِ الْحِیْلَۃُ وَیُخْذَلُ فِیْہِ الْقَرِیْبُ وَیَشْمُتُ فِیْہِ الْعَدُوُّ وَاَنْزَلْتُہٗ بِکَ وَشَکَوْتُہٗ اِلَیْکَ رَغْبَۃً فِیْہِ اِلَیْکَ عَمَّنْ سِوَاکَ فَفَرَّجَتَہٗ وَکَشَفْتَہٗ وَکَفَتَنِیْہِ فَاَنْتَ وَلِیُّ کُلِّ نِعْمَۃٍ وَّصَاحِبُ کُلِّ حَسَنَۃٍ وَّمُنْتَہٰی کُلِّ رَغْبَۃٍ فَلَکَ الْحَمْدُ کَثِیْرًا وَّلَکَ الْمَنُّ فَاضِلًا۔ اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَّسَھِّلْ لِّیْ مِحْنَتِیْ وَیَسِّرْ اِرَادَتِیْ وَبَلِّغْنِیْ اُمْنِیَّتِیْ وَاَوْصِلْنِیْ اِلٰی بُغْیَتِیْ سَرِیْعًا عَاجِلًا وَاقْضِ عَنِّیْ دَیْنِیْ یَااَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1"