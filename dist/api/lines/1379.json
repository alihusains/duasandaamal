abicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000652, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My Lord, my sins have silenced me, and my words have been cut off. I have no argument, for I am the prisoner of my own affliction, the hostage to my works, the frequenter of my own offense, the confused in my intended way, the thwarted. I have brought myself to a halt in the halting place of the abased sinners, the halting place of the wretched and insolent, those who think lightly of Thy promise.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay mere Parwardigaar! Mere gunaho’n ne mujhe (apni baat pesh karne se) khaamosh kar diya hai, meri ghuftagu bhi dam tod chuki hai, to ab mai koi uzr o hujjat nahi rakhta, is tarah mai apne ranj o museebat mein giraftaar, apne aamaal ke haatho’n mein girwi, apne gunaho’n mein hairaan o pareshaan, maqsad mein sargarda’n aur manzil se dur pada hu, mai ne apne ko zaleel gunah-gaaro’n ki jagah par la khada kiya hai aur un bad-bakhto’n ke jagah par jo Tere muqaable mein jur’at o himmat dikhane waale aur Tere waade ko maamuli samajh ne waale hai.", "Urdu": "اے میرے پروردگار! میرے گناہوں نے مجھے (عذر خواہی سے) چپ کر دیا ہے، میری گفتگو بھی دم توڑ چکی ہے۔ تو اب میں کوئی عذر وحجت نہیں رکھتا۔ اس طرح میں اپنے رنج و مصیبت میں گرفتار اپنے اعمال کے ہاتھوں میں گروی، اپنے گناہوں میں حیران و پریشان، مقصد سے سرگرداں اور منزل سے دور افتادہ ہوں۔ میں نے اپنے کو ذلیل گنہگاروں کے موقف پر لا کھڑا کیا ہے ان بد بختوں کے موقف پر جو تیرے مقابلہ میں جرات دکھانے والے اور تیرے وعدہ کو سرسری سمجھنے والے ہیں۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "رَبِّ اَفْحَمَتْنِيْ ذُنُوْبِيْ وَانْقَطَعَتْ مَقَالَتِيْ فَلَا حُجَّةَ لِيْ فَاَنَا الْاَسِيْرُ بِبَلِيَّتِي الْمُرْتَهَنُ بِعَمَلِي الْمُتَرَدِّدُ فِيْ خَطِيْئَتِي الْمُتَحَيِّرُ عَنْ قَصْدِي الْمُنْقَطَعُ بِيْ قَدْ اَوْقَفْتُ نَفْسِيْ مَوْقِفَ الْاَذِلَّاۗءِ الْمُذْنِبِيْنَ مَوْقِفَ الْاَشْقِيَاۗءِ الْمُتَجَرِّينَ عَلَيْكَ الْمُسْتَخِفِّيْنَ بِوَعْدِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002053, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Thee! What insolence I have insolently shown toward Thee! What delusion with which I have deluded myself! My Master, have mercy on my falling flat on my face, the slipping of my foot, grant me my ignorance through Thy clemency, and my evildoing through Thy beneficence, for I admit my sin and I confess my offense: Here are my hand and my forelock! I am resigned to retaliation against my soul! Have mercy on my white hair, the depletion of my days, the nearing of my term, my frailty, my misery, and the paucity of my stratagems!", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai Teri zaat, mai ne kis jur’at o himmat ke saath jur’at ki hai, aur kis tabahi wa barbaadi ke saath apni halaaqat ka saamaan kiya hai. Ay mere Maalik! Mere mooh keh bal girna aur kadmo ke thokar khaane par rahem farma aur apne hilm se meri jehaalat wa na-daani ko aur apne ehsaan se meri khata wa bad-aamaalo’n ko bakhsh de, is liye keh mai apne gunaho’n ka iqraar aur apni khataawo’n ka bhi iqraar karta hu, yeh mera haath aur yeh peshaani ke baal (Tere qabza’e qudrat mein) hai, mai ne na-tawaani aur kamzori ke saath khud ko Teri bargah mein kisaas (badle) ke liye pesh kar diya hai.", "Urdu": "پاک ہے تیری ذات، میں نے کس جرات و دلیری کے ساتھ تیرے مقابلہ میں جرات کی ہے اور کس تباہی وبربادی کے ساتھ اپنی ہلاکت کا سامان کیا ہے۔ اے میرے مالک! میرے منہ کے بل گرنے اور قدموں کے ٹھوکر کھانے پر رحم فرما اور اپنے حلم سے میری جہالت ونادانی کو اور اپنے احسان سے میری خطاء و بداعمالی کو بخش دے اس لۓ کہ میں اپنے گناہوں کا مقر اور اپنی خطاؤں کا معترف ہوں یہ میرا ہاتھ اور یہ میری پیشانی کے بال (تیرے قبضۂ قدرت میں) ہیں۔ میں نے عجز و سرافگندگی کے ساتھ اپنے کو قصاص کے لۓ پیش کر دیا ہے۔", "RArabic": null, "ArabicText1": "سُبْحَانَكَ اَيَّ جُرْاَةٍ اجْتَرَاتُ عَلَيْكَ وَاَيَّ تَغْرِيْرٍ غَرَّرْتُ بِنَفْسِيْ مَوْلَايَ ارْحَمْ كَبْوَتِيْ لِحُرِّ وَجْهِيْ وَزَلَّةِ قَدَمِيْ وَعُدْ بِحِلْمِكَ عَلٰى جَهْلِيْ وَبِاِحْسَانِكَ عَلٰى اِسَاۗءَتِيْ فَاَنَا الْمُقِرُّ بِذَنْبِي الْمُعْتَرِفُ بِخَطِيْئَتِيْ وَهٰذِهٖ يَدِيْ وَنَاصِيَتِيْ اَسْتَكِيْنُ بِالْقَوَدِ مِنْ نَفْسِيْ اِرْحَمْ شَيْبَتِيْ وَنَفَادَ اَيَّامِيْ وَاقْتِرَابَ اَجَلِيْ وَضَعْفِيْ وَمَسْكَنَتِيْ وَقِلَّةَ حِيْلَتِيْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": nul