[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002214, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I beseech You in the name of Your being the King, having absolute power over all things, and whatever matter You want to happen shall happen. O Allah, I turn my face towards You asking You in the name of Your Prophet, Muhammad, the Prophet of mercy, may Allah’s blessings be upon him and his Household. O Muhammad! O Messenger of Allah! I seek Your intercession for me with Allah, your and my Lord, so that He may respond to my request. O Allah, I beseech You in the name of Your Prophet Muhammad and the Imams from his household, peace be upon him and them, to respond to my request.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai Tujh se maangta hu keh Tu baadshah hai aur be-shak Tu har cheez par iqtedaar rakhta hai, neez jo kuchh bhi chahta hai woh ho jaata hai. Ay Ma’bood! Mai Tere huzoor aaya hu Tere Nabi Muhammad (s.a.w.a) waaste jo Nabiye Rehmat hai, Khuda ki rehmat ho un par aur unki Aal (a.s) par. Ya Muhammad (s.a.w.a), ay Khuda ke Rasool (s.a.w.a) mai aap ke waaste se Khuda ke huzoor aaya hu jo aap ka aur mera Rab hai ta-keh aap ki khaatir woh meri haajat puri farmaaye. Ay Ma’bood! Ba-waasta apne Nabi Muhammad (s.a.w.a) aur unke Ahlebait (a.s) mein se Aimma (a) ke.", "Urdu": "اے معبود! میں تجھ سے مانگتا ہوں کہ تو بادشاہ ہے اور بے شک تو ہر چیز پر اقتدار رکھتا ہے مزید تو جو کچھ بھی چاہتا ہے وہ ہو جاتا ہےاے معبود! میں تیرے حضور آیا ہوں تیرے نبی محمدؐ کے واسطے جو نبی رحمتؐ ہیں خدا کی رحمت ہو ان پر ان کی آلؑ پر یا محمدؐاے خدا کے رسولؐ میں آپ کے واسطے سے خدا کے حضور آیا ہوں جو آپ کا اور میرا رب ہے تاکہ آپ کی خاطر وہ میری حاجت پوری فرمائےاے معبود! اپنے نبی محمدؐ اور ان کے ائمۂ اہل بیتؑ کے واسطے سے آنحضرت ؐ پر اور ان سب پر خدا کی رحمت ہو میری حاجت پوری فرما۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ اِنِّي اَسْاَلُكَ بِاَنَّكَ مَلِكٌ وَاَنَّكَ عَلٰى كُلِّ شَيْ‏ءٍ مُقْتَدِرٌ وَاَنَّكَ مَا تَشَاءُ مِنْ اَمْرٍ يَكُوْنُ۔ اَللّٰهُمَّ اِنِّيْ اَتَوَجَّهٗ اِلَيْكَ بِنَبِيِّكَ مُحَمَّدٍ نَبِيِّ الرَّحْمَةِ صَلَّى اللهُ عَلَيْهِ وَآلِهٖ يَا مُحَمَّدُ يَا رَسُوْلَ اللهِ اِنِّيْ اَتَوَجَّهٗ بِكَ اِلَى اللهِ رَبِّكَ وَرَبِّيْ لِيُنْجِحَ بِكَ طَلِبَتِيْ۔ اَللّٰهُمَّ بِنَبِيِّكَ مُحَمَّدٍ وَّالْاَئِمَّةِ مِنْ اَهْلِ بَيْتِهٖ صَلَّى اللهُ عَلَيْهِ وَعَلَيْهِمْ اَنْجِحْ طَلِبَتِيْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSi