[{"Id": 1019071, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "In the book ‘Fee Ziyarat wa al-Adiyyah’ it is written that: If anybody wants to offer prayer of Ziyarat on deputation of any particular person then after determining the Ziyarat, recite the following in deputation of that person…", "GujaratiDescription": null, "RUrduDescription": "Kitaab ‘Fee Ziyarat wa al-Adiyyah’ mein likkha huwa hai keh agar kisi shakhs ko namaz’e ziyarat padhni hai kisi ki niyaabat mein, to us shakhs ki niyaabat mein is tarah se ziyarat ke jumlo’n ko adaa kare…", "UrduDescription": "کتاب فی زیارت و الادیہ میں لکھا ہوا ہے کہ اگر کسی شخص کو نمازِ زیارت پڑھنی ہے کسی کی نیابت میں، تو اُس شخص کی نیابت میں اس طرح سے زیارت کے جملوں کو ادا کرے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "A