[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012600, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke naam se jo bada rahem waala maher-baan hai. Khuda ke naam se Khuda ki zaat se mai ne mooh bandh kar diya hai Jinno, insaano, shaitaano aur jadoo-garo’n ka aur Ibleeso’n ka jo jinn o insaano aur haakimo mein se hai, aur jo unki panah mein hai Allah ke saath jo ghaalib aur ghaalib-tar hai aur Allah ke saath jo buzurg aur buzurg-tar hai.", "Urdu": "خدا کے نام سے جو بڑا رحم والا مہربان ہے خدا کے نام سے خدا کی ذات سے میں نے منہ بند کر دیاہے جنوں انسانوں شیطانوں اور جادو گروں کااور ابلیسوں کا جو جنوں انسانوں اور حاکموں میں سے ہیں اور جو ان کی پناہ میں ہیں اﷲ کے ساتھ جو غالب اور غالب تر ہے اور اﷲ کے ساتھ جو بزرگ اور بزرگ تر ہے۔", "RArabic": "BISMILLAAHE WA BILLAAHE SA-DADTO AFWAA-HAL JINNE WAL INSE WASH-SHAYAA-TEENE WAS-SAHARA-TE WAL ABAALE-SATE MINAL JINNE WAL INSE WAS-SALAA-TEENE WA MAN YALOO-ZO BE-HIM BILLAA-HIL A’ZEE-ZIL A-A’ZZE WA BILLAA-HIL KABEE-RIL AKBARE.", "ArabicText1": "بِسْمِ اللهِ وَبِاللهِ سَدَدْتُ اَفْوَاهَ الْجِنِّ وَالْاِنْسِ وَالشَّيَاطِيْنِ وَالسَّحَرَةِ وَالْاَبَالِسَةِ مِنَ الْجِنِّ وَالْاِنْسِ وَالسَّلَاطِيْنِ وَمَنْ يَلُوْذُ بِهِمْ بِاللهِ الْعَزِيْزِ الْاَعَزِّ وَبِاللهِ الْكَبِيْرِ الْاَكْبَرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012601, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke us naam se jo zaahir wa baatin aur posheedah khazaane hai jis se Us ne aasmaano aur zameeno aur zameen ko qaaem farmaya, phir arsh ki taraf mutawajjeh huwa. Khuda ke naam se jo bada rahem waala maher-baan hai aur un par hukm'e azaab pura ho gaya keh Woh zaalim thay phir woh bol bhi na sakenge. Khuda farmaayega us mein ja padho aur zabaan na kholo aur sab ke chehre Usi zindah o paindah ki taraf jhuk gaye.", "Urdu": "خدا کے اس نام سے جو ظاہر وباطن اور پوشیدہ خزانہ ہے جس سے اس نے آسمانوں اور زمین کو قائم فرمایا پھر عرش کی طرف متوجہ ہوا خدا کے نام سے جو بڑا رحم والا مہربان ہے اور ان پرحکمِ عذاب پورا ہو گیا کہ وہ ظالم تھے پھر وہ بول بھی نہ سکیں گے خدا فرمائے گا اس میں جا پڑو اور زبان نہ کھولو اور سب کے چہرے اسی زندہ و پائندہ کی طرف جھک گئے۔", "RArabic": "BISMILLAA-HIZ ZAAHE-RIL BAATE-NIL MAKNOO-NIL MAKHZOO-NIL LAZEE A-AQAAMA BEHIS SAMAAWAATE WAL ARZA SUMMAS TAWAA A’LAL A’RSHE. BISMILLAA-HIR RAHMAA-NIR RAHEEME WA WAQA-A’L QAWLO A’LAIY-HIM BE-MAA ZALA-MOO FA-HUM LAA YANTE-QOONA QAA-LAKH SAOO FEEHAA WA LAA TOKALLE-MOONA, WA A’NA-TIL WOJOO-HO LIL-HAYYIL QAYYOO-ME.", "ArabicText1": "بِسْمِ اللهِ الظَّاهِرِ الْبَاطِنِ الْمَكْنُوْنِ الْمَخْزُوْنِ الَّذِىْ اَءَقَامَ بِهِ السَّمٰوَاتِ وَالْاَرْضَ ثُمَّ اسْتَوٰى عَلَى الْعَرْشِ بِسْمِ اللهِ الرَّحْمٰنِ الرَّحِيْمِ وَ وَقَعَ الْقَوْلُ عَلَيْهِمْ بِمَا ظَلَمُوْا فَهُمْ لَايَنْطِقُوْنَ قَالَ اخْسَؤُا فِيْهَا وَلَاتُكَلِّمُوْنَ، وَعَنَتِ الْوُجُوْهُ لِلْحَىِّ الْقَيُّوْمِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012602, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Woh na-kaam raha jo zulm ka bojh laaya, awaaze’n larza’n hai Khudaaye rehmaan ke saamne. Pas Tu nahi soonega magar gungunaahat aur rakh diye Ham ne unke dilo par sar-posh ta-keh samajh na paaye aur kaano ko behra kar diya jab tum Qur’an mein apne yakta Khuda ka zikr kiya karte ho to kaafir log nafrat se ulte paaw bhaag jaate hai aur jab tum Qur’an padhte ho to Ham tumhare aur unke darmiyaan jo aakherat par imaan nahi rakhte ek bhaari pardah daal dete hai.", "Urdu": "وہ ناکام رہا جو ظلم کا بوجھ لایا آوازیں لرزاں ہیں خدائے رحمٰن کے سامنے۔ پس تو نہیں سنے گا مگر گنگناہٹ اور رکھ دیے ہم نے ان کے دلوں پر سرپوش تاکہ سمجھ نہ پائیں اور کانوں کو بہرا کردیا جب تم قرآن میں اپنے یکتا خدا کا ذکر کیا کرتے ہو تو کافر لوگ نفرت سے الٹے پاؤں بھاگ جاتے ہیں اور جب تم قرآن پڑھتے ہو تو ہم تمہارے اور ان کے درمیان جو آخرت پر ایمان نہیں رکھتے ایک بھاری پردہ ڈال دیتے ہیں۔", "RArabic": "WA-QAD KHAABA MAN HAMALA ZULMAN WA KHASHA-A’TIL AS-WAATO LIR-RAHMAANE FA-LAA TASMA-O’ ILLAA HAMSANWA JA-A’LNAA A’LAA QOLOOBE-HIM AKIN-NATAN AN YAFQA-HOOHO WA FEE AZAANE-HIM WAQ-RAN WA IZAA ZA-KARTA RABBA-KA FIL QUR’AANE WAHDA-HU WAL LAW A’LAA AD-BAARE-HIM NOFOO-RAN WA IZAA QARAA-TAL QUR’AANA JA-A’LNAA BAIYNA-KA WA BAIY-NAL LAZEENA BIL AAKHERATE HEJAA-BAN MASTOO-RAN.", "ArabicText1": "وَقَدْ خَابَ مَنْ حَمَلَ ظُلْمًا وَخَشَعَتِ الْاَصْوَاتُ لِلرَّحْمٰنِ فَلَا تَسْمَعُ اِلَّا هَمْسًا وَجَعَلْنَا عَلٰى قُلُوْبِهِمْ اَكِنَّةً اَنْ يَّفْقَهُوْهُ وَفِىْ اَذَانِهِمْ وَقْرًا وَاِذَا ذَكَرْتَ رَبَّكَ فِى الْقُرْآنِ وَحْدَهٗ وَلَّوْا عَلٰى اَدْبَارِهِمْ نُفُوْرًا وَاِذَا قَرَاْتَ الْقُرْآنَ جَعَلْنَا بَيْنَكَ وَبَيْنَ الَّذِيْنَ لَا يُؤْمِنُوْنَ بِالْآخِرَةِ حِجَابًا مَسْتُوْرًا۔", 