ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010041, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My Allah, irretrievable is our plight, our helplessness causes pain and trouble, (now our) urgency has been laid bare (before Thee), (all) hopes have been cut off, the (plentiful) earth has shrunk (with very little to spare) for us the heavenly blessings have been withheld, we call upon Thee for help, we refer our grief and sorrow to Thee, we have full faith in Thee, in the time of distress as well as in good fortune.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Ma’bood! Museebat badh gayi hai, chhupi huwi baat khul gayi hai, parda phaash (open) ho gaya hai, ummeed tut gayi hai, zameen tangh ho gayi hai, aur aasmaan ne rukawat daal di hai, Ab Tu hi madad-gaar hai aur Tujh se hi shikaayat ho sakti hai aur tanghi o aasaani mein sirf Tu hi sahara (madadgaar) ban sakta hai.", "Urdu": "میرے معبود! مصیبت بڑھ گئی ہے چھپی بات کھل گئی ہے پردہ فاش ہو گیا ہے امید ٹوٹ گئی ہے زمین تنگ ہوگئی ہے اور آسمان نے رکاوٹ ڈال دی ہے تو ہی مدد کرنے والا ہے اور تجھی سے شکایت ہو سکتی ہے اور تنگی وآسانی میں صرف تو ہی سہارا بن سکتا ہے۔", "RArabic": "ILAAHI A’ZOMAL BALAAA-O WA BAREHAL KHAFAAA-O WAN KASHAFAL GHETAAA-O WAN QATA-A’R RAJAAA-O WA ZAAQATIL ARZO WA MONE-A’TIS SAMAAA-O WA ANTAL MUSTA-A’ANO WA ELAYKAL MUSHTAKAA, WA A’LAYKAL MO-A’WWALO FISH-SHIDDATE WAR RAKHAAA-E.", "ArabicText1": "اِلٰہِیْ عَظُمَ الْبَلَآئُ وَبَرِحَ الْخَفَآئُ، وَانْکَشَفَ الْغِطآئُ وَانْقَطَعَ الرَّجآئُ وَضآقَتِ الْارْضُ وَمُنِعَتِ السَّمآئُ، وَاَنْتَ الْمُسْتَعآنُ وَاِلَیْکَ الْمُشْتَکٰی وَعَلَیْکَ الْمُعَوَّلُ فِی الشِّدَّۃِ وَالرَّخآئِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010042, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, send blessings on Muhammad and on the progeny of Muhammad, the Ulil Amr (authority) obedience to whom has been made obligatory, through which their high status has been made known. Therefore let there be joy after sorrow for us for their sake, right away, in the twinkle of an eye more rapidly.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma jo sahebaan'e amr hai. Wahi hai jin ki ita’at Tu ne ham par farz (waajib) ki hai aur is tarah hamein unke martabe ki pehchaan karaayi hai. Pas unke sadqe mein hamein aasoodgi (takleefo’n se najaat) ataa farma, jald-tar, nazdik-tar (jaldi aur bohot jaldi) goya palak jhapak ne (aankh jhapak ne ki miqdaar) ya us se bhi pehle.", "Urdu": "اے معبود! محمدؐ و آل محمدؑ پر رحمت نازل فرما جو صاحبان ِامر ہیں وہ وہی ہیں جن کی اطاعت تو نےہم پر فرض کی ہے اور اس طرح ہمیں ان کے مرتبہ کی پہچان کرائی ہے پس ان کے صدقے میں ہمیں آسودگی عطا فرما جلد تر نزدیک تر گویا آنکھ جھپکنے کی مقدار یا اس سے بھی پہلے۔", "RArabic": "ALLAAHUMMA SALLE A’LAA MOHAMMADIWN WA AALE MOHAMMADIN OLIL AMRIL LAZEENA FARAZTA A’LAYNAA TAA-A’TAHUM WA A’RRAFTANAA BE ZAALEKA MANZELATAHUM FA FARRIJ A’NNAA BE HAQQEHIM FARAJAN A-A’JELAN QAREEBAN KALAM-HIL BASARE AW HOWA AQRABO.", "ArabicText1": "اَللّٰھُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ اُوْلِی الْاَمْرِ الَّذِیْنَ فَرَضْتَ عَلَیْنَا طَاعَتَھُمْ وَعَرَّفْتَنَا بِذٰلِکَ مَنْزِلَتَھُمْ فَفَرِّجْ عَنَّا بِحَقِّهِمْ فَرَجًا عَاجِلًا قَرِیْبًا کَلَمْحِ الْبَصَرِ اَوْھُوَ اَقْرَبُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010043, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Muhammad O Ali, O Ali O Muhammad, Give me enough because both of you provide sufficiently and help me because both of you help and protect. O Our Master O the Authority of our times (Saahibaz Zamaan) Help! Help! Help! Come to my help, Come to my help, Come to my help, in this hour, in this hour, in this hour, Be quick, Be quick, Be quick, O the most Merciful! For the sake of Muhammad and his pure progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ya Muhammado (s.a.w.a) Ya Ali (a.s) Ya Aliyyo (a.s) Ya Muhammad (s.a.w.a) meri sarprasti (guidance) farmaiye, keh aap dono hi kaafi hai. Meri madad farmaiye keh aap dono hi mere madad-gaar hai. Ay hamare aaqa, ay Sahebaz Zamaan (a.t.f.s) fariyaad hai, fariyaad hai, fariyaad hai. Meri madad kijiye, meri madad kijiye, meri madad kijiye, isi waqt, isi lamhe, isi ghadi, jald-tar, jald az-jald, jaldi se-jaldi. Ay sabse ziyadah rahem karne waale Tujhe waasta hai Muhammad (s.a.w.a) aur unke paakeeza tareen Aal ka (Aameen).", "Urdu": "یامحمدؐ یاعلیؑ یاعلیؑ یامحمدؐ میری سرپرستی فرمائیے کہ آپ دونوں ہی کافی ہیں میری مدد فرمائیے کہ آپ دونوں ہی میرے مددگا رہیں اے ہمارے آقا اے صاحب الزمان ؑفریاد کو پہنچیں فریاد کو پہنچیں فریاد کو پہنچیں میری مدد کریں میری مدد کریں میری مددکریں اسی وقت اسی لمحے اسی گھڑی جلد تر جلد تر جلد تر اے سب سے زیادہ رحم کرنے والے واسطہ ہے محمدؐ کااور ان کی پاک آلؑ کا۔", "RArabic": "YAA MOHAMMADO YAA A’LIYYO YAA A’LIYYO YAA MOHAMMADO IKFEYAANI FA INNAKOMAA KAAFEYAANE WAN SORAANEE FA INNAKOMAA NAASERAANE YAA MAWLAANAA YAA SAAHEBAZ ZAMAANE. AL-GHAWS AL-GHAWS AL-GHAWS ADRIKNEE ADRIKNEE ADRIKNEE. AS-SAA-A’TE AS-SAA-A’TE AS-SAA-A’TE AL-A’JAL AL-A’JAL AL-A’JAL YAA ARHAMAR RAAHEMEEN. BE HAQQE MOHAMMADIWN WA AALEHIT TAAHEREEN.", "ArabicText1": "یَامُحَمَّدُ یَاعَلِیُّ، یَاعَلِیُّ یَامُحَمَّدُ، اِکْفِیَانِیْ فَاِنَّکُمَا کَافِیَانِ، وَانْصُرَانِیْ فَاِنَّکُمَا نَاصِرَانِ یَامَوْلَانَا یَاصَاحِبَ الزَّمَانِ، اَلْغَوْثَ اَلْغَوْثَ اَلْغَوْثَ اَدْرِکْنِیْ اَدْرِکْنِیْ اَدْرِکْنِیْ اَلسَّاعَۃَ اَلسَّاعَۃَ اَلسَّاعَۃَ، اَلْعَجَلَ اَلْعَجَلَ اَلْعَجَلَ، یَآاَرْحَمَ الرَّاحِمِیْنَ بِحَقِّ مُحَمَّدٍ وَّاٰلِہِ الطَّاھِرِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20"