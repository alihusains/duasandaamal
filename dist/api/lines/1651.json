[{"Id": 1011936, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Martyrdom of Prophet Muhammad (s) (11H) and Imam Hasan (a) (50H).", "GujaratiDescription": null, "RUrduDescription": "Shahadat Hazrat Rasoole Khuda (s) (11H) aur Imam Hasan (a) (50H).", "UrduDescription": "۱۱؁ ھ ۲۸ صفر سوموار(دوشنبہ) کے دن رسول اکرمؐکی وفات ہوئی،جب کہ آپ کی عمرمبارک ۶۳ سال تھی۔ شہید اور کفعمی کے بقول ۵۰؁ھ میں اٹھائیسویں صفر کو امام حسنؑ کی شہادت ہوئی جب کہ جعدہ بنت اشعث نے معاویہ کے اشارے پرآپ کو زہردے دیا تھا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1011831, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It has been narrated that Anas ibn Malik said, “As soon as we accomplished the ceremonies of burying the Holy Prophet (s), Lady Fatima (s) came to me and said, ‘How could you be bold enough to pile up soil on the face of the Messenger of Allah?’ She then wept and shouted, ‘Oh for my father whose prayers were responded by the Lord! Oh for my father; how nigh he is from his Lord!’…etc.”", "GujaratiDescription": null, "RUrduDescription": "Riwaayat mein hai keh Anas ibne Malik ne kaha, “Jaise hi Rasool-e-Khuda (s) ki tatfeen poori huwi, Bibi Fatema (s) mere qareeb aayi aur farmaaya: Ay Anas! Tumhaare dilo’n ne yeh kis tarah gawaarah kiya keh jasd mubaarak par mitti daali jaaye.” Phir Aap (s) ne rote huwe farmaaya: “Baba jaan ne Rab ki awaaz par labbaik kaha, baba jaan aap apne Rab ke kitne qareeb hai.”", "UrduDescription": "انس ابن مالک سے روایت ہے : رسول اللہؐکے دفن کے بعد جناب سیدہ فاطمہ ؑ میرے قریب آئیں اور فرمایا :اے انس! تمہارے دلوں نے یہ کس طرح گوارا کیا کہ آنحضرتؐ کے بدنِ مبارک پر مٹی ڈالی جائے۔پھر آپ نے روتے ہوئے فرمایا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1011830, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "The Holy Prophet (s) was 63 years old when he departed. At the age of 40, he was commissioned, by Almighty Allah, to convey the Divine Mission; and Archangel Gabriel began conveying to him the commandments of Almighty Allah and the Divine Revelation. At Makkah, he invited people to follow the religion of monotheism for 13 years. He then immigrated to Madina at the age of 53. He departed life in the 11th year after his immigration. Imam Ali (a) did the funeral rituals and then offered the ritual Prayer of the Dead for his soul. Imam Ali (a) buried him in the holy room where he departed life.", "GujaratiDescription": null, "RUrduDescription": "Rasool-e-Khuda (s) 63 saal ke thay jab woh is duniya se rukhsat huwe. 40 saal ki umr mein Aap (s) tableegh-e-Risaalat ke liye mab’oos huwe, is ke baad 13 saal ke baad Makkah Mo’zama se Madina Munawwara ki taraf hijrat farmaayi aur phir unke 10 saal baad Aap (s) is duniya faani se rukhsat huwe. Ameerul Momeneen (a) ne Aap (s) ko ghusl diya, hunoot kiya, Namaz-e-Janaaza padhi aur dafn kiya Aap (s) ko aap ke hujre mein.", "UrduDescription": "چالیس سال کی عمر میں آپ تبلیغِ رسالت کے لئے مبعوث ہوئے،اس کے بعد تیرہ سال تک مکۂ معظمہ میں لوگوں کو خدا پرستی کی دعوت دیتے رہے ۵۳ برس کی عمر میں آپ نے مکہ معظمہ سے مدینۂ منورہ کی طرف ہجرت فرمائی اور پھر ان کے دس سال بعد آپ نے اس دنیاء فانی سے رحلت فرمائی امیرالمؤمنین ؑنے بنفس نفیس آپ کو غسل و کفن دیا حنوط کیا اور آپ کی نمازِ جنازہ پڑھی پھر دوسرے لوگوں نے بغیر کسی امام کے گروہ در گروہ آپ کا جنازہ پڑھا، بعد میں امیرالمؤمنینؑ نے آنحضرتؐکو اسی حجرے میں دفن کیا، جس میں آپ کی وفات ہوئی تھی۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1011832, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "According to a considerable narration, Lady Fatima (s) took a handful of the soil of the Holy Prophet’s tomb, put it between her eyes, and said…", "GujaratiDescription": null, "RUrduDescription": "Riwaayat mein hai keh, Bibi Fatema (s) ne Aan Hazrat (s) ki qabr mubaarak ki thodi si mitti le kar aankho’n se lagaayi aur farmaaya…", "UrduDescription": "ایک معتبر روایت کے مطابق بی بی ؑ نے آنحضرتؐ کی قبرِ مبارک کی تھوڑی سی مٹی لے کر آنکھوں سے لگاکر فرمایا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1011833, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Indeed! If one who smells the soil of Ahmed’s tomb. Shall never smell any perfume anymore! If the misfortunes that have been poured on me. Were poured on days, they should turn to black nights!", "Gujarati": null, "RGujarati": null, "RUrdu": "Jo Ahmed Mujtaba ki turbat (qabr ki mitti) ki khusboo soonghe, woh ta zindagi dusri khushboo na soonghega. Mujh par woh museebate’n padi hai agar woh dino par aati to woh kaali raate’n ban jaate.", "Urdu": "جو احمدمجتبیٰؐ کی تربت کی خوشبو سونگھے وہ تا زندگی دوسری خوشبو نہ سونگھے گا مجھ پر وہ مصیبتیں پڑی ہیں اگر وہ دنوں پر آتیں تو وہ کالی راتیں بن جاتے۔", "RArabic": "MAAZAA A’LAL MUSH-TAMME TURBATA AHMADA AN LAA YA-SHAMMA MADAZ ZAMAANE GHAWAA-LEYAA. SUBBAT A’LAIYYA MASAA-E-BO LAW ANNA-HAA SUBBAT A’LAL AYYAAME SIRNA LAYAA-LEYAA.", "ArabicText1": "مَاذَا عَلَى الْمُشْتَمِّ تُرْبَةَ اَحْمَدَ اَنْ لَا يَشَمَّ مَدَى الزَّمَانِ غَوَالِيَا۔ صُبَّتْ عَلَيَّ مَصَائِبُ لَوْ اَنَّهَاصُبَّتْ عَلَى الْاَيَّامِ صِرْنَ لَيَالِيَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicG