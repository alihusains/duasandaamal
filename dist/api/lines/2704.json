[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002487, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my Allah! I am, before Thee a needy, afraid of Thy displeasure, but hopeful of receiving Thy protection. O my Allah do not substitute my name (from the list of the faithful), nor let my body (material aspects) undergo a change, nor put me to severe test and trial, nor subject me to the enemy’s ridicule. I take refuge with Thy forgiveness to avoid Thy retribution, I take refuge with Thy mercy to avoid Thy punishment, I take refuge with Thy indulgence to avoid Thy displeasure, I take refuge with Thee from Thee, Glorious and sublime is Thy praise as Thou praises Thyself, but above and beyond that which the best orators say.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai Tera mohtaaj hu aur Tere azaab se khouf khaata hu aur us se panah dhondta hu. Ay Ma’bood! Mera naam tabdil na kar aur mere jism ko digar-go’n (paara paara) na farma, meri azmaaish ko sakht na bana aur mere dushmano ko mujh par khushi na de, mai panah leta hu Tere afvo ki, Tere azaab se mai panah leta hu Teri rehmat ki, Teri saza se mai panah leta hu Teri raza ki Teri na-raazgi se, aur chahta hu Tujh se Tere hi zariye se keh Teri taarif roshan hai jaisa keh Tu ne khud hi apni taarif ki hai jo taarif karne waalo’n ke qoul se buland-tar hai.", "Urdu": "اے معبود! میں تیرا محتاج ہوں اور تیرے عذاب سے خوف کھاتا ہوں اور اس سے پناہ ڈھونڈتا ہوں اے معبود! میرا نام تبدیل نہ کراور میرے جسم کو تبدیل نہ فرما میری آزمائش کو سخت نہ بنا اور میرے دشمنوں کو مجھ پر خوشی نہ دے میں پناہ حاصل کرتا ہوں تیرے عفوودرگزر کی، تیرے عذاب سے میں پناہ حاصل کرتا ہوں تیری رحمت کی، تیری سزا سے میں پناہ حاصل کرتا ہوں تیری رضا کی، تیری ناراضگی سے اور چاہتا ہوں تجھ سے تیرے ہی ذریعے سے کہ تیری تعریف روشن ہے جیسا کہ تو نے خود ہی اپنی تعریف کی ہے جو تعریف کرنے والوں کے قول سے بلند تر ہے۔", "RArabic": "ALLAAHUMMA INNEE ILAIY-KA FAQEE-RUN WA MIN A’ZAA-BEKA KHAA-E-FUN MUSTA-JEERUN. ALLAAHUMMA LAA TO-BADDIL ISMEE WA LAA TO GHAIYYIR JISMEE WA LAA TAJHAD BALAA-EE WA LAA TUSH-MIT BEE A’OO-ZO BE-A’F-WEKA MIN E’QAABE-KA WA AOO’ZO BE-RAH-MATE-KA MIN A’ZAA-BEKA WA AOO’ZO BE-REZAA-KA MIN SA-KHATE-KA WA AOO’ZO MINKA JALLA SANAA-OKA ANTA KAMAA AS-NAIY-TA A’LAA NAFSE-KA WA FAWQA MAA YAQOO-LUL QAA-E-LOONA.", "ArabicText1": "اَللّٰهُمَّ اِنِّيْ اِلَيْكَ فَقِيْرٌ وَّمِنْ عَذَابِكَ خَآئِفٌ مُّسْتَجِيْرٌ۔ اَللّٰهُمَّ لَا تُبَدِّلْ اِسْمِيْ وَلَا تُغَيِّرْ جِسْمِيْ وَلَا تَجْهَدْ بَلَآئِيْ وَلَا تُشْمِتْ بِيْ اَعْدَآئِيْ اَعُوْذُ بِعَفْوِكَ مِنْ عِقَابِكَ وَاَعُوْذُ بِرَحْمَتِكَ مِنْ عَذَابِكَ وَاَعُوْذُ بِرِضَاكَ مِنْ سَخَطِكَ وَاَعُوْذُ بِكَ مِنْكَ جَلَّ ثَنَآؤُكَ اَنْتَ كَمَا اَثْنَيْتَ عَلٰى نَفْسِكَ وَفَوْقَ مَا يَقُوْلُ الْقَآئِلُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5