[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011706, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "“And to Him belongs whatever dwells in the night and the day; and He is the Hearing, the Knowing.” O Umme Muldam! If you believe in Allah and His Messenger, the honorable, then do not make the bones decay, do not eat the flesh and do not drink the blood. Go out from the bearer of this writing to one, who does not believe in Allah, the Mighty and His honorable Messenger and his progeny, Muhammad and Ali and Fatima and al-Hasan and al-Husain (peace be upon them all).", "Gujarati": null, "RGujarati": null, "RUrdu": "Shab o roz mein aaraam karne waale Usi ke dam se hai, jo soonne waala aur jaanne waala hai, ay bukhaar agar to Khuda ki buzurgi aur uske giraami-qadr Rasool par imaan rakhta hai to phir haddiyo’n ko chur-chur na kar, aur gosht ko na kha, aur khoon na pee. Is taaweez ke haamil ko chhod kar kisi aise ki taraf ja, jo Khudaayi buzurg, aur giraami qadr Paighambar'e Akram aur un ke khaandaan yaani Muhammad (s.a.w.a), Ali (a.s), Fatema (s.a), Hasan (a.s), Husain (a.s) par imaan na rakhta hu.", "Urdu": "شب و روز میں آرام کرنے والے اسی کے دم سے ہیں، جو سننے والا اور جاننے والا ہے، اے بخار اگر تو خدا کے بزرگ اور اس کے گرامی قدر رسول پر ایمان رکھتا ہے تو پھر ہڈیوں کو چور چور نہ کر، اور گوشت کو نہ کھا، اورخون نہ پی۔ اس تعویذ کے حامل کو چھوڑ کر کسی ایسے کی طرف جا، جو خدائی بزرگ، اور گرامی قدر پیغمبر اکرم اور ان کے خاندان، یعنی محمد، علی، فاطمہ، حسن، حسین، پر ایمان نہ رکھتا ہو۔", "RArabic": "WA LAHU MAA SAKAN FIL LAYLE WAN NAHAAR, WA HOWAS SAMEE-U’L A’LEEM. YAA UMMA MULDAMIN IN KUNTE AAMANTE BIL-LAAHIL A’ZEEME WA RASOOLEHIL KAREEME, FALAA TAHSHEMIL A’ZMA, WA LAA TAAKOLIL LAHMA, WA LAA TASHRABID DAMA, UKROJEE MIN HAAMELE KETAABEE HAAZAA ELAA MAA LAA YOAMENO BIL-LAAHIL A’ZEEME WA RASOOLEHIL KAREEME WA AALEHI, MOHAMMADIN WA A’LIYYIN WA FAATEMATA WAL HASANE WAL HUSAYNE A’LAYHEMUS SALAAMO.", "ArabicText1": "وَلَهٗ مَا سَكَنَ فِی اللَّیْلِ وَالنَّهَارِ وَهُوَ السَّمِیْعُ الْعَلِیْمُ، یَا اُمَّ مُلْدَمٍ اِنْ كُنْتِ اَمَنْتِ بِاللهِ الْعَظِیْمِ وَرَسُوْلِهِ الْكَرِیْمِ، فَلَا تَهْشِمِی الْعَظْمَ، وَلَا تَا كُلِی اللَّحْمَ، وَلَا تَشْرِبِی الدَّمَ، اُخْرُجِیْ مِنْ حَامِلِ كِتَابِیْ هٰذَا اِلٰی مَنْ لَا یُؤْمِنُ بِاللهِ الْعَظِیْمِ وَرَسُوْلِهِ الْكَرِیْمِ وَآلِهٖ، مُحَمَّدٍ، وَعَلِیٍّ، وَفَاطِمَۃَ، وَالْحَسَنِ، وَالْحُسَیْنِ عَلَیْهِمُ السَّلَامُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": 