[{"Id": 1013269, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Shaykh Kulayni has reported that Imam Ali ibn Muhammad Naqi (al-Hadi) instructed to say the following at the tomb of Amir al-Momeneen (a)…", "GujaratiDescription": null, "RUrduDescription": "Shaikh Kulayni ne Imam Ali Naqi (a) se riwaayat ki hai keh Aap (a) ne farmaya keh Ameerul Momeneen (a) ki zareeh mubarak ke paas khade ho kar is tarah ziyarat padhe…", "UrduDescription": "شیخ کلینیؒ نے امام علی نقی ؑ سے روایت کی ہے کہ آپ نے فرمایا : حضرت امیرالمومنینؑ کی ضریح ِمبارک کے نزدیک کھڑے ہو کر یہ زیارت پڑھا کرو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013270, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O intimate servant of Allah. You are the first to have been oppressed and the first to have had his right usurped. You, nevertheless, acted patiently, seeking the reward of Allah, until death came upon you. I thus bear witness that you met Allah as martyr. May Allah torture him who killed you with the various kinds of torture and may He renew torture for him ceaselessly.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Khuda ke Wali, keh aap pehle momin hai jin ka haq cheehna gaya us par aap ne sabr kiya aur hausle se kaam liya yahan tak keh aap ki shahadat ho gayi. Mai gawah hu keh aap Khuda se ja miley hai aur aap woh shaheed hai keh jis ke qaatil ko Khuda ne tarah tarah ke azaab diye aur Woh usey ek par dusra azaab diya hai.", "Urdu": "آپ پر سلام ہو اے خدا کے ولی کہ آپ پہلے مظلوم ہیں اور پہلے مومن ہیں جن کا حق چھینا گیا اس پر آپ نے صبر کیا اور حوصلے سے کام لیا یہاں تک کہ آپ کی شہادت ہو گئی میں گواہ ہوں کہ آپ خدا سے جا ملے ہیں اور آپ وہ شہید ہیں کہ جس کے قاتل کو خدا نے طرح طرح کے عذاب دیئے اور وہ اسے ایک پر دوسراعذاب دیتا ہے۔", "RArabic": "AS-SALAAMO A’LAIKA YAA WALIYYAL-LAAHE ANTA AWWALO MAZLOO-MIN WA AWWALO MAN GHO-SEBA HAQQO-HU SABAR-TA WAH-TASAB-TA HATTAA ATAA-KAL YAQEENO FA-ASH-HADO ANNA-KA LAQEE-TAL LAAHA WA ANTA SHAHEE-DOON A’ZZA-BAL LAAHO QAATELA-KA BE-ANWAA-I’L A’ZAABE WA JADDADA A’LAI-HIL A’ZAABA.", "ArabicText1": "اَلسَّلَامُ عَلَيْكَ يَا وَلِيَّ اللهِ اَنْتَ اَوَّلُ مَظْلُوْمٍ وَاَوَّلُ مَنْ غُصِبَ حَقُّهٗ صَبَرْتَ وَاحْتَسَبْتَ حَتّٰى اَتَاكَ الْيَقِيْنُ فَاَشْهَدُ اَنَّكَ لَقِيْتَ اللهَ وَاَنْتَ شَهِيْدٌ عَذَّبَ اللهُ قَاتِلَكَ بِاَنْوَاعِ الْعَذَابِ وَجَدَّدَ عَلَيْهِ الْعَذَابَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013271, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I have come to you, recognizing your right, acknowledging your position, and bearing enmity against your enemies and against those who wronged you. I, by Allah’s willing, will meet my Lord carrying these principles. O intimate servant of Allah, I have (committed) numerous sins; so, (please) intercede for me before your Lord, for you verily enjoy a famous rank with Allah and you have verily enjoyed a high status and intercession with Allah. Allah, the All-exalted, has said (in this respect), “And they do not intercede except for him whom He accepts.”", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai haazir aap ke haq ko pehchaante huwe aap ke martabe ko jaante huwe, mai aap ke dushmano ka dushman hu aur jinho ne aap par zulm kiya unka dushman hu. Insha-Allah mai isi aqeede par apne Rab ke huzoor jaaunga. Ay Waliye Khuda be-shak mere gunah bohot ziyadah hai, pas apne Rab ke yahan meri sifaarish kare. Be-shak aap Khuda ke nazdik numaaya maqaam rakhte hai. Khuda ke yahan aap ki badi izzat aur shafa’at ka haq hai aur yaqeenan Allah (swt) ne farmaaya hai: “Aur shafa’at nahi karenge magar woh jis se Khuda raazi hai.”", "Urdu": "میں حاضر ہوں آپ کے حق کو پہنچانتے ہوئے آپ کے مرتبے کو جانتے ہوئے میں آپ کے دشمنوں کا دشمن ہوں اور جنہوں نے آپ پر ظلم کیا ان کا دشمن ہوں انشاء اللہ میں اسی عقیدے پر اپنے رب کے حضور جاؤں گا اے ولیِ خدا بے شک میرے گناہ بہت زیادہ ہیں پس اپنے رب کے ہاں میری سفارش کریں بے شک آپ خدا کے دربار میں نمایاں مقام رکھتے ہیں خدا کے ہاں آپ کی بڑی عزّت اور شفاعت کا حق ہے اور یقینًا اللہ تعالی نے فرمایا ہے:اور شفاعت نہیں کریں گے مگر وہ جس سے خدا راضی ہو۔", "RArabic": "JEHTO-KA AA’RE-FAN BE-HAQQE-KA MUSTABSE-RAN BE-SHAANE-KA MO-AA’DE-YAN LE-A’DAA-E-KA WA MAN ZALAMA-KA ALQAA A’LAA ZAALEKA RABBEE INSHAA-ALLAAHO YAA WALIYYAL-LAAHE INNA LEE ZONOO-BAN KASEERA-TAN FASH-FA’ LEE ILAA RABBE-KA FA-INNA LAKA I’NDAL LAAHE MAQAA-MAN MA’LOO-MAN WA INNA LAKA I’NDAL LAAHE JAAHAN WA SHAFAA-A’TAN WA QAD QAALAL-LAAHO TA-AA’LAA WA LAA YASHFA-OO’NA ILLAA LE-MANIR TAZAA.", "ArabicText1": "جِئْتُكَ عَارِفًا بِحَقِّكَ مُسْتَبْصِرًا بِشَأْنِكَ مُعَادِيًا لِاَعْدَائِكَ وَمَنْ ظَلَمَكَ اَلْقٰى عَلٰى ذٰلِكَ رَبِّيْ اِنْ شَاءَ اللهُ يَا وَلِيَّ اللهِ اِنَّ لِيْ ذُنُوْبًا كَثِيْرَةً فَاشْفَعْ لِيْ اِلٰى رَبِّكَ فَاِنَّ لَكَ عِنْدَ اللهِ مَقَامًا مَعْلُوْمًا وَاِنَّ لَكَ عِنْدَ اللهِ جَاهًا وَشَفَاعَةً وَقَدْ قَالَ اللهُ تَعَالٰى وَلَا يَشْفَعُوْنَ اِلَّا لِمَنِ ارْتَضٰى۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "