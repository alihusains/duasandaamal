 ہو کر عبادت اور تہجد میں مشغول رہیں اور پھر پیغمبر اسلامؐ خداوند حکیم کے حکم کے مطابق چالیس دن تک خدیجہ کے گھر نہیں گئے، اس عرصے میں پیغمبر اسلامؐ راتوں کو نماز اور عبادت میں مصروف ہو تے اور دن میں روزے رکھتے۔ جیسے ہی چالیس دن پورے ہوئے فرشتہ آیا اور جنت سے لائی ہوئی غذا پیش کرتے ہوئے عرض کی آج رات اس بہشتی غذا سے تناول فرمانا، رسول خدا نے ان ہی جنتی اور روحانی غذاؤں سے روزہ افطار کیا، جیسے ہی پیغمبر اسلامؐ نماز کیلئے اٹھے، جبرئیل آئے اور عرض کی، کہ اے رسول خدا آج رات مستجی نمازوں کو چھوڑ کر حضرت خدیجہ کے گھر جائیں، کیونکہ خدا نے ارادہ کیا ہے کہ آپ کی صلب سے ایک پاکیزہ اولاد پیدا کرے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016308, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": "Ek roz Jibraeel (a.s) naazil huwe aur arz kiya keh Khuda-wand tabaarak o taala ne salaam bheja hai aur farmaya hai keh chaalees (40) din aur chaalees (40) raate’n Khadijah se alag ho kar ibaadat aur tahjud mein mashghool rahe aur phir Paighambar-e-Islaam (s.a.w.a) Khuda-wand-e-hakeem ke hukm ke mutaabiq chaalees (40) din tak Khadijah (s.a) ke ghar nahi gaye, is arse mein Paighambar-e-Islaam (s.a.w.a) raato’n ko namaz aur ibaadat mein masroof hote aur din mein roze rakhte. Jaise hi chaalees din poore huwe to ek farishta aaya aur Jannat se laayi huwi ghiza pesh karte huwe arz ki; aaj raat is Behisht ghiza tanaawul farmana (khaana), Rasool-e-Khuda (s.a.w.a) unhi Jannati aur roohaani ghizaawo’n se roza iftaar kiya, jaise hi Paighambar-e-Islaam (s.a.w.a) namaz ke liye utthay, Jibraeel (a.s) aaye aur arz ki, keh ay Rasool-e-Khuda (s.a.w.a) aaj raat mustahbi namazo’n ko chhod kar Hazrat Khadijah (s.a) ke ghar jaawo’n, kyu’n-keh Khuda ne iraadah kiya hai keh aap ki sulb se ek paakeezah aulaad paiyda kare.", "UrduDescription": "امام جعفرصادق فرماتے ہیں جب سے خدیجہ نے رسول خدا سے عقد کیا، مکہ کی عورتوں نے آپ سے قطع تعلق کر لیا تھا اور آپ کے گھر آنا جانا بند کردیا تھا، وہ اس وجہ سے غمگین رہتی تھیں، لیکن جیسے ہی حضرت فاطمہ سے حاملہ ہوئیں تو تنہائی کے غم سے نجات پاگئیں اور اپنے شکم میں موجود بچے سے مانوس ہوگئیں اور اس سے باتیں کرتی رہتیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016309, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": "Imam Jafar Sadiq (a.s) farmate hai, keh jab se Khadijah (s.a) ne Rasool-e-Khuda (s.a.w.a) se aqd kiya, Makkeh ki aurto’n ne aap se qat-e-taaluq kar liya (rishta tod diya) tha, aur aap ke ghar aana-jaana bandh kar diya tha, woh is wajah se gham-geen rehti thi, lekin jaise hi Hazrat Fatema (s.a) se haamela huwi to tanhaayi ke gham se najaat pa gayi aur apne shikam mein maujooda bachche se maanoos (lagaaw) ho gayi aur us se baate’n karti rehti. Jibraeel (a.s) Paighambar-e-Islaam (s.a.w.a) aur Hazrat Khadija (s.a) ko khush-khabri soona ne ke liye aaye aur kaha keh; ay Paighambar-e-Islaam (s.a.w.a) Khadijah (s.a) ke rahem mein ek aisi beti hai jis se tumhari nasl chalegi, woh deen-e-paighambar ke peshwaawo’n aur imaamo ki maa hogi jo wahee ke munqata (wahee ka silsila khatm) ho jaane se tumhare Ja-nasheen honge, jaise hi Paighambar-e-Islaam (s.a.w.a) ne Parwardigaar-e-jahan ka paiygaam Khadijah (s.a) ko pohonchaaya to woh bohot khush huwi.", "UrduDescription": "جبرئیل پیغمبر اسلامؐ اور حضرت خدیجہ کو خوشخبری سنانے کیلئے آئے اور کہا کہ اے پیغمبر اسلامؐ خدیجہ کے رحم میں ایک ایسی بیٹی ہے جس سے تیری نسل چلے گی، وہ پیغمبر دین کے پیشواؤں اور اماموں کی ماں ہوگی جو وحی کے منقطع ہوجانے سے تیرے جانشین ہوں گے، جیسے ہی پیغمبر اسلامؐ نے پروردگار جہاں کا پیام خدیجہ کو پہنچایا تو وہ بہت خوش ہوئیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "Arabic