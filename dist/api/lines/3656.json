[{"Id": 1016303, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "INSHA-ALLAH COMING SOON", "GujaratiDescription": null, "RUrduDescription": "Kisi bhi shakhsiyat ka ziyadah talluq khaandaan, waaledain aur maashre se hota hai. Waaledain apni godh se hi awlaad asaas o bunyaad tashkeel (bana) deti hai aur usko apne roohaani aur akhlaaqi saanche mein dhaal kar maashre ke hawaale karte hai.", "UrduDescription": "کسی بھی شخصیت کا زیادہ تعلق خاندان، والدین اور معاشرے سے ہوتا ہے۔ والدین اپنی گود سے ہی اولاد کی اساس اور بنیاد تشکیل دیتے ہیں اور اس کو اپنے روحانی اور اخلاقی سانچے میں ڈھال کر معاشرے کے حوالے کرتے ہیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": 