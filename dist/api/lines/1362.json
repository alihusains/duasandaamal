[{"Id": 1000614, "EnglishTitle": "His Supplication upon Hearing Thunder", "GujaratiTitle": null, "RUrduTitle": "Jab baadal aur bijlee ko dekhte aur kadak ki awaaz soonte to yeh dua padhte…", "UrduTitle": "جب بادل اور بجلی کو دیکھتے اور رعد کی آواز سنتے تو یہ دعاء پڑھتے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000615, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, these are two of Thy signs and these are two of Thy helpers. They rush to obey Thee with beneficial mercy or injurious vengeance, so rain not down upon us from them the evil rain and clothe us not through them in the garment of affliction!", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Be-shak yeh dono (baadal aur bijlee) Teri nishaaniyo’n mein se do nishaaniya’n hai aur Tere paiyda kiye huwe khidmat guzaaro’n mein se do khidmat guzaar hai jo nihaayat furti ke saath Teri farma-bardaari karte hai (unke aane mein do hi raaz hai) faaida pohonchane waali rehmat ka paighaam ban kar aate hai ya nuqsaan dene waali saza ban kar chha jaate hai, pas (ay Raheem) Tu un dono ke zariye aisi baarish na barsa jo nuqsaan ki wajah ho, na unki wajah se hamein bala o museebat ka libaas pehna.", "Urdu": "بارالہا! یہ (ابر وبرق)تیری نشانیوں میں سے دو نشانیاں اورتیرے خدمتگزاروں میں سے دو خدمتگزار ہیں جو نفع رساں رحمت یا ضرر رساں عقوبت کے ساتھ تیرے حکم کی بجا آوری کے لئے رواں دواں ہیں۔ تو اب ان کے ذریعہ ایسی بارش نہ برسا جو ضرر و زیاں کا باعث ہو اور نہ ان کی وجہ سے ہمیں بلا ومصیبت کا لباس پہنا۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اِنَّ هٰذَيْنِ اٰيَتَانِ مِنْ اٰيَاتِكَ وَهٰذَيْنِ عَوْنَانِ مِنْ اَعْوَانِكَ يَبْتَدِرَانِ طَاعَتَكَ بِرَحْمَةٍ نَافِعَةٍ اَوْ نَقِمَةٍ ضَارَّةٍ فَلَا تُمْطِرْنَا بِهِمَا مَطَرَ السَّوْۗءِ وَلَا تُلْبِسْنَا بِهِمَا لِبَاسَ الْبَلَاۗءِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001848, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, bless Muhammad and his Household, send down upon us the benefit of these clouds and their blessing, turn away from us their harm and their injury, strike us not through them with blight, and loose not upon our livelihoods any bane! O God, if Thou hast incited them as vengeance and loosed them in anger, we seek sanctuary with Thee from Thy wrath and implore Thee in asking Thy pardon! So incline with wrath toward the idolaters and set the millstone of Thy vengeance turning upon the heretics!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur us baadal ki barkat aur uska faaida ham par naazil farma aur uski takleef ko hamse dur kar de aur ham ko uski wajah se kisi aafat mein giraftaar na kar aur rizq o rozi mein koi khalal uske zariye se na bhej. Khudaaya! Agar Tu ne us baadal ko ba-taur’e azaab bheja ho ya ghazab ke tariqe par rawaana kiya ho to ham Tere gusse o ghazab se Teri hi panah maangte hai aur nihaayat aajezi ke saath ham Teri maafi ki Tujh se darkhwaast karte hai. Pas Tu apne us gusse ko kaafiro’n ki taraf pher de aur apne azaab ki chakki mulhido’n (naastik logo’n) ki taraf bhej de.", "Urdu": "اے اللہ! محمد اور ان کی آل پر رحمت نازل فرما اور ان بادلوں کی منفعت وبرکت ہم پر نازل کر اور ان کے ضرروآزار کا رخ ہم سے موڑ دے اور ان سے ہمیں کوئی گزند نہ پہنچانا اور نہ ہمارے سامان معیشت پر تباہی وارد کرنا۔ بارالہا! اگر ان گھٹاؤں کو تو نے بطور عذاب بھیجا ہے اور بصورت غضب روانہ کیا ہے تو پھر ہم تیرے غضب سے تیرے ہی دامن میں پناہ کے خواستگار ہیں اور عفو ودرگزر کے لئے تیرے سامنے گڑ گڑا کر سوال کرتے ہیں۔ تو مشرکوں کی جانب اپنے غضب کا رخ موڑدے اورکافروں پر آسیائے عذاب کو گردش دے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِهٖ وَاَنْزِلْ عَلَيْنَا نَفْعَ هٰذِهِ السَّحَاۗئِبِ وَبَرَكَتَهَا وَاصْرِفْ عَنَّا اَذَاهَا وَمَضَرَّتَهَا وَلَا تُصِبْنَا فِيْهَا بِاَفَةٍ وَلَا تُرْسِلْ عَلٰى مَعَايِشِنَا عَاهَةً۔ اَللّٰهُمَّ وَاِنْ كُنْتَ بَعَثْتَهَا نَقِمَةً وَاَرْسَلْتَهَا سَخْطَةً فَاِنَّا نَسْتَجِيْرُكَ مِنْ غَضَبِكَ وَنَبْتَهِلُ اِلَيْكَ فِيْ سُؤَالِ عَفْوِكَ فَمِلْ بِالْغَضَبِ اِلَى الْمُشْرِكِيْنَ وَاَدِرْ رَحٰى نَقِمَتِكَ عَلَى الْمُلْحِدِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001849, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, take away the barrenness of our lands with Thy watering, dislodge the malice from our breasts with Thy providing, distract us not from Thee through other than Thee, and cut none of us off from the stuff of Thy goodness, for the rich is he to whom Thou hast given riches, and the safe he whom Thou hast protected!", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur Ay Ma’bood hamare shahero’n ka qahet (famine) apni baaraan’e rehmat se dur kar aur hamare dilo’n ka gussa apni inaayat-karda rozi ke zariye bar-taraf kar de aur apne siwa ham ko kisi gair ka mohtaaj na kar aur hamse apne ehsaan ki rassi na kaat-na kyu’n keh gani wohi hai jis ko Tu gani kare aur salaamat wohi hai jisko Tu bachaaye.", "Urdu": "اے اللہ!ہمارے شہروں کی خشک سالی کو سیرابی کے ذریعہ دور کر دے اور ہمارے دل کے وسوسوں کو رزق کے وسیلہ سے برطرف کر دے اور اپنی بارگاہ سے ہمارا رخ موڑ کر ہمیں دوسروں کی طرف متوجہ نہ فرما اور ہم سب سے اپنے احسانات کا سرچشمہ قطع نہ کر کیونکہ بے نیاز وہی ہے جسے تو بے نیاز کرے اور سالم ومحفوظ وہی ہے جس کی تونگہداشت کرے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ اَذْهِبْ مَحْلَ بِلَادِنَا بِسُقْيَاكَ وَاَخْرِجْ وَحَرَ صُدُوْرِنَا بِرِزْقِكَ وَلَا تَشْغَلْنَا عَنْكَ بِغَيْرِكَ وَلَا تَقْطَعْ عَنْ كَاۗفَّتِنَا مَادَّةَ بِرِّكَ فَاِنَّ الْغَنِيَّ مَنْ اَغْنَيْتَ وَاِنَّ السَّالِمَ مَنْ وَقَيْتَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001850, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "No one has any defense against Thee, nor any means to bar Thy penalty. Thou decidest what Thou wilt for whom Thou wilt and Thou decreest what Thou desirest for any whom Thou desirest! So to Thee belongs praise for protecting us from affliction and to Thee belongs thanks for conferring upon us blessings, a praise which will leave behind the praise of the praisers, a praise which will fill the earth and the heaven!", "Gujarati": null, "RGujarati": null, "RUrdu": "Tere siwa kisi ek ke paas bhi bachaaw ka zariya nahin, na kisi ke paas Tere hamle se bachne ki taaqat hai, Tu jo chahta hai, jis par chahta hai hukm karta hai aur jiske baabat jaisa iraada karta hai waisa hi jaari kar deta hai. Pas sirf aur sirf Tere hi liye taarif hai is bina par keh Tu ne ham ko balaawo’n se bachaaya aur Tera shukr hai keh Tu ne ham ko neymate’n ataa farmaayi, Teri taarif aisi hai jo tamaam taarif karne waalo’n ki taarifo’n ko apne peechhe chhod de, aisi taarif jo zameen o aasmaan ko bhar de.", "Urdu": "اس لئے کہ تیرے علاوہ کسی کے پاس (مصیبتوں کا)دفعیہ اورکسی کے ہاں تیری سطوت وہیبت سے بچاؤ کا سامان نہیں ہے تو جس کی نسبت جو چاہتا ہے حکم فرماتا ہے اور جس کے بارے میں جو فیصلہ کرتا ہے وہ صادر کر دیتا ہے تیرے ہی لئے تمام تعریفیں ہیں کہ تو نے ہمیں مصیبتوں سے محفوظ رکھا اور تیرے ہی لئے شکر ہے کہ تو نے ہمیں نعمتیں عطا کیں۔ ایسی حمد جو تمام گزاروں کی حمد کو پیچھے چھوڑ دے۔ ایسی حمد جو خدا کے آسمان وزمین کی فضاؤں کو چھلکا دے۔", "RArabic": null, "ArabicText1": "مَا عِنْدَ اَحَدٍ دُوْنَكَ دِفَاعٌ وَلَا بِاَحَدٍ عَنْ سَطْوَتِكَ امْتِنَاعٌ تَحْكُمُ بِمَا شِئْتَ عَلٰى مَنْ شِئْتَ وَتَقْضِيْ بِمَا اَرَدْتَ فِيْمَنْ اَرَدْتَ فَلَكَ الْحَمْدُ عَلٰى مَا وَقَيْتَنَا مِنَ الْبَلَاۗءِ وَلَكَ الشُّكْرُ عَلٰى مَا خَوَّلْتَنَا مِنَ النَّعْمَاۗءِ حَمْدًا يُخَلِّفُ حَمْدَ الْحَامِدِيْنَ وَرَاۗءَهٗ حَمْدًا يَمْلَاُ اَرْضَهُ وَسَمَاۗءَهُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001851, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Surely Thou art the All-kind through immense kindnesses, the Giver of abounding favours, the Accepter of small praise, the Grateful for little gratitude, the Beneficent, the Benevolent, Possessor of graciousness! There is no god but Thou; unto Thee is the homecoming.", "Gujarati": null, "RGujarati": null, "RUrdu": "Bade bade ehsaano ke saath bohot bohot ehsaan karne waale aur badi se badi neymato’n ko bakhshne waale aur thodi si bhi taarif ko qabool kar lene waale, zarra bara-bar shukriya ka bhi ewaz (badla) dene waale, Tu hi ehsaan farmane waala, neki karne waala, bakhshne waala hai, Tere siwa koi ma’bood nahin hai, aakhir mein Teri hi bargah mein sab ko haazir hona hai.", "Urdu": "اس لئے کہ تو بڑی سے بڑی نعمتوں کا عطا کرنے والا اور بڑے سے بڑے انعامات کا بخشنے والا ہے۔ مختصر سی حمد کو بھی قبول کرنے والا اور تھوڑے سے شکرئیے کی بھی قدر کرنے والا ہے اوراحسان کرنے والا اوربہت نیکی کرنے والا اورصاحب کرم وبخشش ہے۔ تیرے علاوہ کوئی معبود نہیں ہے اور تیری ہی طرف (ہماری) باز گشت ہے۔", "RArabic": null, "ArabicText1": "اِنَّكَ الْمَنَّانُ بِجَسِيْمِ الْمِنَنِ الْوَهَّابُ لِعَظِيْمِ النِّعَمِ الْقَابِلُ يَسِيْرَ الْحَمْدِ الشَّاكِرُ قَلِيْلَ الشُّكْرِ الْمُحْسِنُ الْمُجْمِلُ ذُو الطَّوْلِ لَا اِلٰهَ اِلَّا اَنْتَ اِلَيْكَ الْمَصِيْرُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicG