[{"Id": 1015154, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Sheikh Kafa’ami said: reporting from the Ahlulbayt (a): repeat the following supplication on the 23rd night of the holy month of Ramazan, either in prostration, or standing or sitting position or in any other condition, even at any time of the month or any time of the year, you recite this supplication after praising Allah the Most High and sending blessing to His Prophet (s)…", "GujaratiDescription": null, "RUrduDescription": "Muhammad ibne Eesa ne apni sanad ke saath Saleheen se riwaayat ki hai keh; 23rd Shab-e-Qadr mein is dua ko qayaam o qunoot aur ruku o sujood mein, neez har haal mein baar-baar padhe aur apni zindagi mein jab bhi yeh dua yaad aaye to padhta rahe, ab Haq-taala ki buzurgi bayaan karne aur Hazrat Nabi-e-Akram (s) par duruood o salaam bhejne ke baad kahe…", "UrduDescription": "محمد ابن عیسیٰ نے اپنی سند کے ساتھ صالحین سے روایت کی ہے کہ انہوں نے فرمایا: تیئیسویں رمضان کی رات اس دعا کو قیام و قعود اور رکوع وسجود میں نیز ہر حال میں بار بارپڑھے اور پھر اپنی زندگی میں جب بھی یہ دعا یادآئے تو پڑھتا رہے اب حق تعالیٰ کی بزرگی بیان کرنے اور حضرت نبی اکرم  ؐ پردرود وسلام بھیجنے کے بعد کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000238, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Be for Your servant, Hujjat bin al-Hasan, Your blessings be upon him and upon his forefathers, in this time and all times, a Master, a Protector, a Leader, a Helper, a Guide and a Guardian, till You make him dwell in Your earth and provide him with a long life in it.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Tu muhaafiz (protector) ban ja, apne Wali Hazrat Hujjat ibnil Hasan Al-Askari (a.t.f.s) ka. Teri rehmat naazil ho un par aur unke Aaba o Ajdaad par, is waqt aur har aane waale waqt mein unka sarprast (guardian), nigheh-baan (care-taker), peshwa (leader), madad-gaar (helper), rehnuma (guide) aur nigheh-daar (dekh-bhaal karne waala) ban ja. Yahan tak keh Tu logo’n ki chaahat se unhe zameen ki hukumat de aur muddato’n us par bar-qaraar rakkhe.", "Urdu": "اے معبود! محافظ بن جا اپنے ولی حجت القائم ؑ ابن حسنؑ کاتیری رحمت نازل ہو ان پر اور ان کے آباؤ اجداد پر اس لمحہ میں اور ہر آنے والے لمحہ میں، ان کا مددگاربن جا نگہبان پیشوا، حامی، راہنما اور نگہدار بن جا یہاں تک کہ تو لوگوں کی چاہت سے انہیں زمین کی حکومت دے اور مدتوں اس پر برقرار رکھے۔", "RArabic": "ALLAAHUMMA KUN LE-WALIYYEKAL HUJJATIBNIL HASANE SALAWAATOKA A’LAYHE WA A’LAA AAABAA-EHI FEE HAAZEHIS SAA-A’TE WA FEE KULLE SAA-A’TIN WALIYYAWN WA HAAFEZAWN WA QAA-EDAWN WA NAASERAWN WA DALEELAWN WA A’YNAN HATTAA TUSKENAHU ARZAKA TAW-A’N WA TOMATTE-A’HU FEEHAA TAWEELAA.", "ArabicText1": "اَللّٰھُمَّ كُنْ لِّوَلِیِّكَ الْحُجَّۃِ بْنِ الْحَسَنِ صَلَوَاتُكَ عَلَیْہِ وَعَلٰی آبَآئِہٖ فِیْ ھٰذِہِ السَّاعَۃِ وَفِیْ كُلِّ سَاعَۃٍ وَّلِیًّا وَّحَافِظًا وَّقَآئِدًا وَّنَاصِرًا وَّدَلِیْلًا وَّعَیْنًا حَتّٰی تُسْكِنَہٗ اَرْضَكَ طَوْعًا وَّتُمَتِّعَہٗ فِیْھَا طَوِیْلًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSig