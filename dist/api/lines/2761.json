[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011637, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, You are the High and the Great. Praise is only for You; such a praise which will never be destroyed. And You are the living, the forbearing. I beg You for the sake of the effulgence of Your noble face and for the sake of the majesty of Your face which is unreachable and Your power which cannot be suppressed that You bless Muhammad and Aale Muhammad (a.s) and that You forgive me and have mercy on me and overlook my mistakes. Indeed You are the forgiving and merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya Tu hi buland o bartar hai, Tere hi liye aisi hamd o sataaish saza-waar hai jo kabhi bhi fanah nahi hogi, bal-keh hamesha baaqi rehne waali hai aur Tu hi zindah aur burdbaar hai. Mai Tujh se Teri buzurg martaba zaat ki nooraaniyat o jalaalat ke sahaare se woh jalaalat jis ka qasd (iraada) nahi kiya ja sakta aur Tere us ghalba o iqtedaar ke zariye se keh jo maghloob nahi ho (haar nahi) sakta. Sawaal karta hu keh Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur mere gunah bakhsh de aur mujh par rahem farma, yaqeenan Tu tamaam rahem karne waalo’n mein sab se ziyadah raheem hai.", "Urdu": "خدایا! تو ہی بلند و برتر ہے، تیرے ہی لئے ایسی حمد و ستائش سزا وار ہے جو کبھی بھی فنا نہیں ہو گی، بل کہ ہمیشہ باقی رہنے والی ہے اور تو ہی زندہ اور بردبار ہے۔ میں تجھ سے تیری بزرگ مرتبہ ذات کی نورانیت و جلالت کے سہارے سے وہ جلالت جس کا قصد نہیں کیا جا سکتا اور تیرے اس غلبہ و اقتدار کے ذریعہ سے کہ جو مغلوب نہیں ہو سکتا۔ سوال کرتا ہو کہ حضرت محمدؐ اور انکی آلؑ پر رحمت نازل فرما اور میرے گناہ بخش دے اور مجھ پر رحم فرما، یقینًا تو تمام رحم کرنے والوں میں سب سے زیادہ رحیم ہے۔", "RArabic": "ALLAAHUMMA ANTAL A’LIYYUL A’ZEEMO LA-KAL HAMDO HAMDAN YABQAA WA LAA YAFNAA WA ANTAL HAIYYUL HALEEMO AS-ALOKA BE-NOORE WAJHE-KAL KAREEME WA BE-JALAALE WAJHE-KAL LAZEE LAA YORAA-MO WA BE-I’ZZATE-KAL LATEE LAA TUQ-HARO AN TO-SAL-LEYYA A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA AN TAGH-FERA-LEE WA TAR-HAMA-NEE INNA-KA ANTA AR-HAMUR RAAHE-MEEN.", "ArabicText1": "اَللّٰھُمَّ اَنْتَ الْعَلِیُّ الْعَظِیْمُ لَکَ الْحَمْدُ حَمْدًا یَبْقٰی وَلَایَفْنٰی وَاَنْتَ الْحَیُّ الْحَلِیْمُ اَسْئَلُکَ بِنُوْرِ وَجْھِکَ الْکَرِیْمِ وَبِجَلَالِ وَجْھِکَ الَّذِیْ لَایُرَامُ وَبِعِزَّتِکَ الَّتِیْ لَا تُقْھَرُ اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاَنْ تَغْفِرَلِیْ وَتَرْحَمَنِیْ اِنَّکَ اَنْتَ اَرْحَمُ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRe