[{"Id": 1013632, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "In some books of ziyarat it is mentioned that if you intend to enter the mosque, stand at the gate of the mosque and recite the following…", "GujaratiDescription": null, "RUrduDescription": "Kuch ziyarat ki kitaab mein hai keh, jab tum Masjide Sahla mein daakhil hona chaho to masjid ke darwaaze par khade ho kar is tarah se padho…", "UrduDescription": "بعض کتبِ زیارت سے معلوم ہوتا ہے کہ جب مسجدِ سہلہ میں داخل ہونے لگے تو دروازے پر کھڑے ہوکر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1013633, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah (I begin), in Allah (I trust), from Allah (I derive power), to Allah (I refer all my affairs), only that which Allah wills shall come to pass, and the most excellent Names are Allah’s. I rely upon Allah. There is neither might nor power except with Allah the All-high and All-great. O Allah, (please) make me of those who construct Your mosques and houses. O Allah, I turn my face toward You, asking You in the name of Muhammad and the Household of Muhammad and I present them before my requests; so, O Allah, (please) make me worthy of Your regard in their names, in this world and the Hereafter and make me of those who are made near to You.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke naam se, Khuda ki zaat se aur Khuda ki taraf aur jo kuchh Khuda chahe aur Khuda ke behtareen naam se bharosa karta hu Khuda par. Us Ali o Azeem ke siwa koi harkat o quwwat waala nahi hai. Ay Ma’bood! Mujhe un mein se qaraar de jo Teri masjido’n aur Tere gharo’n ko aabaad karte hai. Ay Ma’bood! Mai aaya hu Teri taraf Muhammad (s.a.w.a) wa Aale Muhammad (a.s) ke waaste se aur unhe wasila banaata hu apni haajaat mein. Pas ay Ma’bood! Mujhe apne nazdik duniya o aakherat mein ba-izzat qaraar de aur apne nazdiko’n mein rakh.", "Urdu": "خدا کے نام سے خدا کی ذات سے خدا کی طرف اور جو کچھ خدا چاہے اور خدا کے بہترین نام سے بھروسہ کرتا ہوں خدا پراس علی وعظیم کے سوا کوئی طاقت و قوت نہیں ہے اے معبود!مجھے ان میں سے قرار دے جو تیری مسجدوں اور تیرے گھروں کو آباد کرتے ہیں اے معبود! میں آیا ہوں تیری طرف محمدؐ وآل محمدؑ کے واسطے سے اور انہیں وسیلہ بناتاہوں اپنی حاجات میں پس اے معبود! مجھے اپنے نزدیک دنیا اور آخرت میں با عزّت قراردے اور اپنے نزدیکوں میں رکھ۔", "RArabic": "BISMIL LAAHE WA BILLAAHE WA MENAL LAAHE WA ELAL LAAHE WA MAA SHAAA-AL LAAHE WA KHAYRUL AS-MAAA-E LILLAAHE TAWAKKALTO A’LAL LAAHE WA LAA HAWLA WA LAA QUWWATA ILLAA BILLAAHIL A’LIYYIL A’ZEEME ALLAAHUMMAJ A’LNEE MEN U’MMAARE MASAAJEDEKA WA BOYOOTEKA ALLAAHUMMA INNEE ATAWAJJAHO ILAIKA BE-MOHAMMADIWN WA AALE MOHAMMADIWN WA O-QADDEMOHUM BAYNA YADAY HAWAAA-EJEE FAJ-A’LNEE ALLAAHUMMA BEHIM I’NDAKA WAJEEHAN FID-DUNYAA WAL AAKHERATE WA MENAL MOQARRABEENA.", "ArabicText1": "بِسْمِ اللہِ وَ بِاللہِ وَمِنَ اللہِ وَاِلَی اللہِ وَمَا شَآءَ اللہُ وَخَیْرُ الْاَسْمَآءِ لِلهِ تَوَكَّلْتُ عَلَی اللہِ وَلَا حَوْلَ وَلَا قُوَّۃَ اِلَّا بِاللہِ الْعَلِیِّ الْعَظِیْمِ۔ اَللّٰهُمَّ اجْعَلْنِیْ مِنْ عُمَّارِ مَسَاجِدِكَ وَبُیُوْتِكَ۔ اَللّٰهُمَّ اِنِّیْٓ اَتَوَجَّهُ اِلَیْكَ بِمُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَّاُقَدِّمُهُمْ بَیْنَ یَدَیْ حَوَآئِجِیْ فَاجْعَلْنِیْ۔ اَللّٰهُمَّ بِهِمْ عِنْدَكَ وَجِیْهًا فِیْ الدُّنْیَا وَالْاٰخِرَۃِ وَمِنَ الْمُقَرَّبِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign