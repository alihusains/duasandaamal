[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011770, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I seek from You guidance and taqwa, chastity and sufficiency (free of need of others) and deeds according to what You love and are pleased with. O Allah compensate our weakness with Your Might our poverty and need with Your sufficiency and our ignorance with Your forbearance and knowledge. O Allah bless Muhammad and his family and help us in thanking and remembering You in obeying and worshipping You by Your mercy, O the most merciful of those who display mercy.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Mai hidaayat aur taqwa, iffat (paakeezgi) o be-neyaazi, aur Tere pasandida amal ke baja laane ki talab-gaar hu. Ay Parwardigaar! Apni kamzori ke muqaable mein quwwat aur apni mohtaaji ke muqaable mein be-neyaazi aur apni jehaalat ke muqaable mein Tere hilm ka sawaal karta hu. Ay Parwardigaar! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par durood bhej aur apna shukr, zikr, ita’at aur ibaadat baja laane mein hamari madad farma, Tujhe apni rehmato’n ka waasta, ay beh-tareen rahem karne waale.", "Urdu": "اے پروردگار! میں ہدایت اور تقویٰ، عفت و بے نیازی، اور آپ کے پسندیدہ اعمال کے بجا لانے کی طلب گار ہوں۔ اے پروردگار! اپنی کوتاہ ہمتوں کے مقابل میں قوت اور اپنی محتاجی کے مقابل میں بے نیازی اور اپنی جہالت کے مقابل میں تیرے حلم کا سوال کرتی ہوں۔ اے پروردگار! محمد و آل محمد پر درود بھیج اور اپنا شکر، ذکر، اطاعت اور عبادت بجا لانے میں ہماری مدد فرما، تجھے اپنی رحمتوں کا واسطہ، اے بہترین رحم کرنے والے۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKAL HODAA WAT TOQAA, WAL A’FAAFE WAL GHENAA, WAL A’MALA BEMAA TOHIBBO WA TARZAA, ALLAAHUMMA INNEE AS-ALOKA MIN QUWWATEKA LE-ZA’FENAA, WA MIN GHENAAKA LE-FAQRENAA WA FAAQATENAA, WA MIN HILMEKA WA I’LMEKA LE-JAHLENAA. ALLAAHUMMA SALLE A’LAA MOHAMMADIN WA AALE MOHAMMADIN, WA A-I’NNAA A’LAA SHUKREKA WA ZIKREKA WA TAA-A’TEKA WA E’BAADATEKA, BE-RAHMATEKA YAA ARHAMAR RAAHEMEEN.", "ArabicText1": "اَللّٰہُمَّ اِنِّیْ اَسْئَلُکَ الْہُدٰی وَالتُّقٰی، وَالْعِفَافَ وَالْغِنٰی، وَالْعَمَلَ بِمَا تُحِبُّ وَتَرْضٰی۔ اَللّٰہُمَّ اِنِّیْ اَسْئَلُکَ مِنْ قُوَّتِکَ لِضَعْفِنَا، وَمِنْ غِنَاکَ لِفَقْرِنَا وَفَاقَتِنَا، وَمِنْ حِلْمِکَ وَعِلْمِکَ لِجَہْلِنَا۔ اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَآلِ مُحَمَّدٍ، وَاَعِنَّا عَلٰی شُکْرِکَ وَذِکْرِکَ، وَطَاعَتِکَ وَعِبَادَتِکَ، بِرَحْمَتِکَ یَا اَرْحَمَ الرَّاحِمیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGr