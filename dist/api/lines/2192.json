[{"Id": 1012003, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is narrated from Imam Sadiq (a) that he said: Fatima (s) complained to Messenger of Allah (s) about worrisome dreams. He said: When you see such kinds of dreams, recite as follows…", "GujaratiDescription": null, "RUrduDescription": "Imam Jafar Sadiq (a) se riwaayat hai keh Hazrat Fatema (s) ne burey aur pareshaan karne waale khwaab ke mutaaliq Paighambar-e-Islaam (s) se shikaayat ki to Aap (s) ne framaya; Jab bhi aise khwaab dekhe’n to kaho…", "UrduDescription": "امام جعفرصادق سے روایت ہے کہ حضرت فاطمہ نے برے اور پریشان کرنے والے خوابوں کے متعلق پیغمبر اسلامؐ سے شکایت کی تو پیغمبر اسلامؐ نے فرمایا، جب بھی ایسے خواب دیکھیں تو کہیں۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null,