[{"Id": 1013129, "EnglishTitle": "Uncle of Holy Prophet (s)", "GujaratiTitle": null, "RUrduTitle": "Rasool-e-Khuda (s) ke chacha", "UrduTitle": "رسول خدا (ص) کے چچا", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013130, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Fakhrul Mohaqqeqeen has written in ’Fakhriyah’: The Ziyarat of Hazrat Hamza (r) and other Martyrs of Ohod is recommended in Ohod. It is narrated from the Holy Prophet (s) that he (s) said, One who does my Ziyarat but does not do the Ziyarat of my uncle, angers me.”", "GujaratiDescription": null, "RUrduDescription": "Fakhrul Mohaqqeqeen apni kitaab Fakhriyah mein farmaya, Hazrat Hamza (a) aur Ohad ke digar shohoda ki ziyarat karna mustahab hai, kyu’n keh Rasool-e-Khuda (s) se riwaayat huwi keh farmaaya, “Jo shakhs meri ziyarat kare aur mere chacha Hamza (a) ki ziyarat ko na jaaye to goya us ne mujh par zulm kiya .”", "UrduDescription": "مؤلف کہتے ہیں : جناب حمزہ ؑکے اوصاف اور ان کی زیارت کی فضیلت بہت زیادہ ہے جو بیان نہیں کی جاسکتی۔فخر المحققینؒ نے رسالۂ فخریہ میں فرمایا :حضرت حمزہؑ اور أحد کے دیگر شہداء کی زیارت کرنا مستحب ہے کیوں کہ حضرت رسول ؐسے روایت ہوئی ہے کہ فرمایا : جو شخص میری زیارت کرے اور میرے چچا حمزہ ؑکی زیارت کو نہ جائے تو گویا اس نے مجھ پر ظلم کیا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1013131, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "Shaykh Mufeed writes that the Prophet (s) has ordered us to perform the Ziyarat of the grave of Hazrat Hamza (a). The Prophet (s) himself used to accord importance to the Ziyarat of Hazrat Hamza (a) and other martyrs. After the passing away of the Messenger of Allah (s), Hazrat Fatema Zahra (s) used to regularly perform the Ziyarat of their graves. In the lifetime of the Holy Prophet (s) it had become a practice (Sunnat) for the Muslims to go for the Ziyarat of the Prophet’s uncle.", "GujaratiDescription": null, "RUrduDescription": "Shaikh Mufeed ne farmaya: Hazrat Rasool (s) ne apni hayaat mein Hazrat Hamza (a) ki qabr ki ziyarat ka hukm diya aur khud bhi aap ki aur digar shohoda ki ziyarat karte rahe. Aan Hazrat (s) ki wafat ke baad Sayyada Fatema (s), Hazrat Hamza (a) ki qabr par jaati thi aur dusre musalmaan bhi aap ki ziyarat karte aur qabr par haazir hote thay.", "UrduDescription": "شیخ مفید ؒنے فرمایا: حضرت رسول ؐ نے اپنی حیات میں حضرت حمزہؑ کی قبر کی زیارت کا حکم دیااور خود بھی آپ کی اور دیگر شہداء أحد کی زیارت کرتے رہے،آنحضرت ؐکی وفات کے بعد سیدہ فاطمہ ؑ حضرت حمزہ ؑکی قبر پر جاتی تھیں اور دوسرے مسلمان بھی آپ کی زیارت کرتے اور قبر پر حاضر ہوتے تھے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1013132, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 3, "EnglishDescription": "In other tradition, it is mentioned that she (s) used to perform namaz there. The number of martyrs of Ohod is approximately 70. Amongst them are Hazrat Hamza, Abdullah bin Jahash, Musa’b bin Omair, Ammaar bin Ziyad and Shammaas bin Usmaan. When you go for the Ziyarat of Hazrat Hamza (r), recite it as follows…", "GujaratiDescription": null, "RUrduDescription": "Dusri riwaayat ke mutaabiq, Bibi Zahra (s), Hazrat Hamza (a) ki qabr par namaz adaa karti thi. Ohad ke shohoda ki taadad taqriban 70 hai. Un mein Hazrat Hamza (a), Abdullah bin Jahash, Musa’b bin Omair, Ammaar bin Ziyad aur Shammaas bin Usmaan. Jab tum Hazrat Hamza (a) ki ziyarat par jaawo, to is tarah se kaho…", "UrduDescription": "نیز اس حقیر نے’’ بیت الاحزان فی مصائب سیدۃ النسوان ‘‘میں نقل کیا ہے کہ حضرت رسول ؐ کے انتقال کے بعد حضرت فاطمہ ؑہر ہفتے میں دوشنبہ اور جمعرات کو حضرت حمزہ ؑاور دیگر شہداء احد کی زیارت کو جاتیں وہاں نماز پڑھتیں اور دعا مانگتیں حتیٰ کہ اپنی شہادت تک ایسا ہی کرتی رہیں۔ محمود ابن لبید نے بیان کیا : سیدہ جلیلہ حضرت حمزہ ؑکی قبر کے سرہانے کھڑے ہو کر گریہ فرمایا کرتی تھیں ایک روز جو میں حضرت حمزہ ؑکی زیارت کو گیا تو میں نے دیکھا کہ وہ معظمہ حضرت حمزہؑ کی قبر پر گریہ کر رہی ہیں۔ اس کے بعد قبلہ رُخ ہو کر دو رکعت نماز ِزیارت پڑھے۔پھر رسول ؐکے چچا حضرت حمزہؑ کی قبرِ مبارک سے لپٹ کر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013133, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you O uncle of the Prophet of Allah peace be upon him and his family; Peace be upon you O best of the martyrs; Peace be upon you O lion of Allah and the lion of His Prophet. I bear witness that you fought for Allah, the Most Mighty and Glorious and you exerted yourself and advised the Prophet of Allah and desired (the rewards) available through Allah the Most Glorious. May my father and mother be sacrificed for you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay Hazrat Rasool (s.a.w.a) ke chacha. Salaam ho aap par ay shohada mein behtareen. Salaam ho aap par ay Allah ke sher aur uske Rasool ke sher. Mai gawahi deta hu keh aap ne raahe Khuda mein jehaad kiya apni jaan ki qurbaani pesh ki Khuda ke Rasool ke khair-khwaai farmaayi aur aap ka Khuda ke yahan jo ajr tha uski taraf raaghib huwe. Mere maa baap aap par qurbaan.", "Urdu": "سلام ہو آپ پر اے حضرت رسولؐ کے چچا سلام ہو آپ پر اے شہداءمیں بہترین، سلام ہوآپ پر اے اللہ کے شیر اور اس کے رسولؐ کے شیر میں گواہی دیتا ہوں کہ آپ نے راہِ خدا میں جہاد کیا اپنی جان کی قربانی پیش کی خدا کے رسولؐ کی خیر خواہی فرمائی اور آپ خدا کے ہاں جو اجر تھا اس کی طرف راغب ہوئے میرے ماں باپ آپ پر قربان۔", "RArabic": "ASSALAAMO A’LAYKA YAA A’MMA RASOOLIL LAAHE SALLAL LAAHO A’LAYHE WA AALEHI ASSALAAMO A’LAYKA YAA KHAYRASH SHO-HADAAA-E ASSALAAMO A’LAYKA YAA ASADAL LAAHE WA ASADA RASOOLEHI ASH-HADO ANNAKA QAD JAA-HAD-TA FIL LAAHE A’ZZA WA JALLA WA JUD-TA BE-NAFSEKA WA NA-SAHTA RASOOLAL LAAHE WA KUNTA FEEMAA I’NDAL LAAHE SUBHAANAHU RAAGHEBAN BE ABEE ANTA WA UMMEE.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا عَمَّ رَسُوْلِ اللہِ صَلَّی اللہُ عَلَیْہِ وَاٰلِہٖ۔ اَلسَّلَامُ عَلَیْكَ یَا خَیْرَ الشُّھْدَآئِ۔ اَلسَّلَامُ عَلَیْكَ یَا اَسَدَ اللہِ وَاَسَدَ رَسُوْلِہٖ۔ اَشْھَدُ اَنَّكَ قَدْ جَاھَدْتَ فِیْ اللہِ عَزَّ وَجَلَّ وَجُدْتَ بِنَفْسِكَ وَنَصَحْتَ رَسُوْلَ اللہِ وَكُنْتَ فِیْمَا عِنْدَ اللہِ سُبْحَانَہٗ رَاغِبًا بِاَبِیْ اَنْتَ وَاُمِّیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013134, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I have come to you seeking closeness to Allah the Most Mighty and Glorious by visiting you, and seeking nearness to the Prophet of Allah peace be upon him and his family; through that desiring from (your) intercession; seeking from my visiting you freedom of myself and seeking refuge, through you, from the fire; those like me deserve it for the wrong I have done to myself.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai aap ki baargah mein Hazrat Rasool (s.a.w.a) ki qurbat ke liye aaya hu, is tarah mai mutawajjeh huwa hu aap ke taraf shafa’at ke liye keh aap ki ziyarat ke zariye apne bachaaw ke waaste aap ki panah haasil karu us aag se jo mere liye yaqeeni ho chuki hai is sitam ke badle jo mai ne khud par kiya.", "Urdu": "میں آپ کی بارگاہ میں حضرت رسولؐ کی قربت کے لئے آیا ہوں اس طر ح میں متوجہ ہوا ہوں آپ کی طرف شفاعت کے لئے کہ آپ کی زیارت کے ذریعے اپنی حفاظت کے واسطے آپ کی پناہ حاصل کروں اس آگ سے جو میرے لئے یقینی ہو چکی ہے اس ستم کے بدلے جو میں نے خود پر کیا۔", "RArabic": "A’TAIYTOKA MOTAQAREBAN ILAA RASOOLILLAAHE SALLALLAAHO ALAIHE WA AALEHI BE ZAALEKA RAAGHEBAN ELAIKA FISH-SHAFAA-A’TE AB-TAGHEE BE-ZEYAARATEKA KHALAASA NAFSEE MO-TA-A’WWEZAN BEKA MIN NAARENIS TAHAQQAHAA MISLEE BEMAA JANAYTO A’LAA NAFSEE.", "ArabicText1": "اَتَیْتُكَ مُتَقَرِبًا اِلٰی رَسُوْلِ اللہِ صَلَّی اللہُ عَلَیْہِ وَاٰلِہٖ بِذٰلِكَ رَاغِبًا اِلَیْكَ فِی الشَّفَاعَۃِ اَبْتَغِیْ بِزِیَارَتِكَ خَلَاصَ نَفْسِیْ مُتَعَوِّذًا بِكَ مِنْ نَارٍ اسْتَحَقَّھَا مِثْلِیْ بِمَا جَنَیْتُ عَلٰی نَفْسِیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013135, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "(I come) fleeing from my sins which I have committed; fleeing to you hoping g for the mercy of My Lord; I have come to you from a distant land seeking freedom from the fire, my back is loaded with my sins. I have committed what angers my Lord. I did not find anyone more worthy to flee to than you, the Ahlul-Bayt of mercy, so be my intercessors on the day of my poverty and need. I have traveled to you in a sad state and in distress.", "Gujarati": null, "RGujarati": null, "RUrdu": "Apne un gunaho’n se bhaaga hu jo mai ne apni pusht par utha rakkha hai apne Rab ki rehmat ki ummeed mein. Aap ke paas ghabraaya huwa aaya hu apni gardan aag se chhuda ne ke liye dur daraaz ka safar kar ke aap ke paas aa khada hu jab keh apne gunaho’n ka baar meri pusht par hai aur mai woh laaya hu jis se mera Rab naraaz hai mai kisi ko nahi paata keh us se faryaad karu jo mere liye aap Ahlebait (a.s) ki rehmat se behtar ho. Pas aap faqr o haajat ke din meri shafa’at karne waale ban jaaye keh mai mahezoon (gham-zadah) ho kar aap ke paas aaya aur karb wa gham ke aalam mein aap ke huzoor aaya.", "Urdu": "اپنے ان گناہوں سے بھاگا ہوں جو میں نے اپنی پشت پر اٹھا رکھے ہیں اپنے رب کی رحمت کی امید میں آپ کے پاس گھبرایا ہوا آیا ہوں اپنی گردن آگ سے چھڑانے کے لئے دور دراز کا سفر کرکے آپ کے پاس آکرکھڑا ہوں جب کہ اپنے گناہوں کا بار میری پشت پر ہے اور میں وہ لایا ہوں جس سے میرا رب ناراض ہے میں کسی کو نہیں پاتا کہ اس سے فریاد کروں جو میرے لئے آپ اہل بیت ِؑرحمت سے بہتر ہو پس آپ فقر و حاجت کے دن میری شفاعت کرنے والے بن جائیں کہ میں محزون ورنجیدہ ہو کرآپ کے پاس آیا اور کرب و غم کے عالم میں آپ کے حضور آیا۔", "RArabic": "HAAREBAN MIN ZONOOBEYAL LATEE AH-TA-TABTOHAA A’LAA ZAHREE FA-ZE-A’N ELAYKA RAJAAA-A RAHMATE RABBEE ATAYTOKA MIN SHUQQATIN BA-E’EDATIN TAA-LEBAN FA-KAAKA RAQABATEE MENAN NAARE WA QAD AW-QARAT ZAHREE ZONOOBEE WA ATAYTO MAA AS-KHATA RABBEE WA LAM AJID AHADAN AFZA-O’ ELAYHE KHAYRAN LEE MINKUM AHLA BAYTIR RAHMATE FA-KUN LEE SHA-FEE-A’N YAWMA FAQREE HAAJATEE FAQAD SIRTO ELAYKA MAHZOONAN WA ATAYTOKA MAKROOBAN.", "ArabicText1": "ھَارِبًا مِّنْ ذُنُوْبِیَ الَّتِیْ احْتَطَبْتُھَا عَلٰی ظَھْرِیْ فَزِعًا اِلَیْكَ رَجَآئَ رَحْمَۃِ رَبِّیْ اَتَیْتُكَ مِنْ شُقَّۃٍ بَعِیْدَۃٍ طَالِبًا فَكَاكَ رَقَبَتِیْ مِنَ النَّارِ وَقَدْ اَوْقَرَتْ ظَھْرِیْ ذُنُوْبِیْ وَاَتَیْتُ مَا اَسْخَطَ رَبِّیْ وَلَمْ اَجِدْ اَحَدًا اَفْزَعُ اِلَیْہِ خَیْرًا لِیْ مِنْكُمْ اَھْلَ بَیْتِ الرَّحْمَۃِ فَكُنْ لِیْ شَفِیْعًا یَوْمَ فَقْرِیْ وَحَاجَتِیْ فَقَدْ سِرْتُ اِلَیْكَ مَحْزُوْنًا وَاَتَیْتُكَ مَكْرُوْبًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013136, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I shed tears in front of you, crying I have come to you lonely; you are amongst those whom Allah has commanded to join with and has urged me towards piety and guided me to His grace and love; He urged me to come to you and inspired me to ask my needs to Him; You are the Ahlul-Bayt, no one who befriends you is miserable; one who comes to you is not disappointed and one who is inclined towards You does not lose nor does one who shows enmity towards you become happy.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur aap ki khidmat mein aa kar mai ne be-basi mein aansoo bahaaye hai. Mai sab ko chhod kar aap ki taraf chala aaya hu aur aap woh hai jin se wa-basta hone ka Khuda ne mujhe hukm diya jin se achchhaayi ki targheeb di jin ki fazilat se mujhe aagah kiya jin se mohabbat rakhne ki hidaayat ki, jin ki taraf aane ka shauq dilaaya, jin ki qurbat mein haajaat talab karne ki taaleem di. Ay Nabi ke Ahle khaandaan aap logo’n ka chahne waala bad-bakht nahi hai, jo aap ke paas aaye woh na-kaam nahi hai, jo aap se mohabbat rakkhe usey nuqsaan nahi hai, jo aap ka dushman ho usey kaamyaabi nahi milti.", "Urdu": "اور آپ کی خدمت میں آکر میں نے بے بسی میں آنسو بہائے ہیں میں سب کو چھوڑ کر آپ کی طرف چلا آیا ہوں اور آپ وہ ہیں جن سے وابستہ ہونے کا خدا نے مجھے حکم دیا جن سے اچھائی کی ترغیب دی جن کی فضیلت سے مجھے آگاہ کیا جن سے محبت رکھنے کی ہدایت کی جن کی طرف آنے کا شوق دلایا جن کی قربت میں طلب ِحاجات کرنے کی تعلیم دی اے نبیؐ کے اہلِ خاندان آپ لوگوں کا چاہنے والا بد بخت نہیں ہے جو آپ کے پاس آئے وہ ناکام نہیں ہے جوآپ سے محبت رکھے اسے نقصان نہیں ہے جو آپ کا دشمن ہو اسے کامیابی نہیں ملتی۔", "RArabic": "WA SA-KABTO A’BRATEE I’NDAKA BAAKEYAN WA SIRTO ELAYKA MUFRADAN WA ANTA MIMMAN AMARANEYAL LAAHO BE-SELATEHI WA HASSENEE A’LAA BIRREHI WA DALLANEE A’LAA FAZLEHI WA HADAANEE LE-HUBBEHI WA RAGH-GHA-BANEE FIL WEFAADATE ELAYHE WA ALHAMANEE TALABAL HAWAAA-EJE I’NDAHU ANTUM AHLO BAYTIN LAA YASHQAA MAN TAWALLAAKUM WA LAA YAKHEEBO MAN ATAAKUM WA LAA YAKHSARO MAN YAHWAAKUM WA LAA YAS-A’DO MAN A’ADAAKUM.", "ArabicText1": "وَسَكَبْتُ عَبْرَتِیْ عِنْدَكَ بَاكِیًا وَصِرْتُ اِلَیْكَ مُفْرَدًا وَاَنْتَ مِمَّنْ اَمَرَنِیَ اللہُ بِصِلَتِہٖ وَحَثَّنِیْ عَلٰی بِرِّہٖ وَدَلَّنِیْ عَلٰی فَضْلِہٖ وَھَدَانِیْ لِحُبِّہٖ وَرَغَّبَنِیْ فِیْ الْوِفَادَۃِ اِلَیْہِ وَاَلْھَمَنِیْ طَلَبَ الْحَوَآئِجِ عِنْدَہٗ اَنْتُمْ اَھْلُ بَیْتٍ لَا یَشْقٰی مَنْ تَوَلَّاكُمْ وَلَا یَخِیْبُ مَنْ اَتَاكُمْ وَلَا یَخْسَرُ مَنْ یَھْوٰیكُمْ وَلَا یَسْعَدُ مَنْ عَادَاكُمْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, 