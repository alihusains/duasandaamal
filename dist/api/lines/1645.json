[{"Id": 1011814, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "It is recommended to observe fasting on this day. Rayyan ibn Shabib has reported that Imam Reza (a) said, “Just as Allah (swt) responded to the prayer of Prophet Zakariya, He shall respond the prayer of one who observes fasting on this day and prays to Him.”", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh is din Roza rakkhe. Rayyan ibne Shabib likhte hai keh Imam Reza (a) farmaate hai, Jis tarah Allah (swt) ne Paighamber Zakariya ki dua ko mustajaab farmaya, isi tarah jo is din Roza rakh kar dua maange to uski dua bhi qabool hogi.", "UrduDescription": "روزہ رکھے،اس ضمن میں ریان ابن شبیب نے امام علی رضا ؑسے روایت کی ہے : جو شخص پہلی محرم کاروزہ رکھے اور خدا سے کچھ طلب کرے تو وہ اس کی دعا قبول فرمائے گا،جیسے حضرت زکریا ؑکی دعا قبول فر مائی تھی۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null,