l, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, the Lord of the gods, O the One, O the Alone, O the last of the last, O the victor of the victorious, O the Exalted, O the Mighty, You are the Most Highest of the High, You are Higher than everything High, O my master this is my covenant and You are the executor of my promise, O my master join my covenant and execute my promise, I believe in You.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ يَا اِلٰهَ الْاٰلِهَةِ، يَا وَاحِدُ، يَا اَحَدُ، يَا اٰخِرَ الْاٰخِرِيْنَ، يَا قَاهِرَ الْقَاهِرِيْنَ، يَا عَلِيُّ يَا عَظِيْمُ، اَنْتَ الْعَلِيُّ الْاَعْلٰى، عَلَوْتَ فَوْقَ كُلِّ عُلُوٍّ، هٰذَا يَا سَيِّدِيْ عَهْدِيْ وَاَنْتَ مُنْجِزُ وَعْدِيْ، فَصِلْ يَا مَوْلَايَ عَهْدِيْ، وَاَنْجِزْ وَعْدِيْ، اٰمَنْتُ بِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "Arabic