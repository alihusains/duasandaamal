ull, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016591, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Lord, You are Allah, You do what You will for among the issues, thus send mercy upon Mohammad (s.a.w.a) and his holy Progeny (a.s), and regard for me the hastening of the relief of Mohammad’s Progeny (a.s) among the issues You will, and accompany our relief and the relief of my brothers along with the relief of Mohammad’s Progeny (a.s), and do so and so for me.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Paalne waale! Tu hi Ma’bood hai, jis cheez ka mai Tujh se taqaaza karta hu Tu usey poora kar deta hai, Bas Tu durood bhej Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par aur moayyan farma mere liye jo Tu chahta hai, jaldi farma Qaaem’e Aale Muhammad (a.t.f.s) ke zahoor mein, un par Allah ka durood o salaam ho aur unke Aaba o Ajdaad par bhi, aur mere liye kushaadgi qaraar de aur mere bhai ke liye, aur zamaane mein kushaadgi qaraar de unke liye aur mere liye (yahan par apni haajate’n talab kare).", "Urdu": "اے پالنے والے توہی معبود ہے، جس چیز کا میں تجھ سے تقاضہ کرتا ہوں تو اسے پورا کر دیتا ہے، بس تو درود بھیج محمدؐ و آل محمدؑ پر اور معین فرما میرے لئے جو تو چاہتا ہے، جلدی فرما قائم آلِ محمدؑ کے ظہور میں، ان پر اللہ کا درود و سلام ہو اور ان کے آبا و اجداد پر، اور میرے لئے کشادگی قرار دے اور میرے بھائی کے لئے، اور ہر زمانِ میں کشادگی قرار دے ان کے لئے، اور میرے لئے ( یہاں اپنی حاجتیں طلب کریں)۔", "RArabic": "YAA RABBE, ANTAL-LAAHO, MAA SHE-TO MIN AMRIN YAKOO-NA, FA-SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WAJ-A’L LEE FEE-MAA TASHAAA-O AN TO-A’JJIL FARAJA AALE MOHAMMADIN, SALLAL-LAAHO A’LAIY-HE WA A’LAIY-HIM, WA TAJ-A’LA FARA-JEE WA FARAJA IKH-WANEE WAQ-ROO-NAN BE-FARAJE-HIM, WA TAF-A’LA BEE KAZA WA KAZA.", "ArabicText1": "یَا رَبِّ اَنْتَ اللهُ، مَا شِئْتُ مِنْ اَمْرٍ یَكُوْنَ، فَصَلِّ عَلٰی مُحَمِّدٍ وَّآلِ مُحَمَّدٍ وَاجْعَلْ لِیْ فِیْمَا تَشَاۗئُ اَنْ تُعَجِّلْ فَرَجَ آلِ مُحَمَّدٍ، صَلَّی اللهُ عَلَیْهِ وَعَلَیْهِمْ، وَتَجْعَلَ فَرَجِیْ وَفَرَجَ اِخْوَنِیْ وَقْرُوْنًا بِفَرَجِهِمْ، وَتَفْعَلَ بِیْ كَذَا وَكَذَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicT