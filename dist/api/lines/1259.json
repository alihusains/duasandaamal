[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000253, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O you Allah! I come near to Thee, towards Thy liberal beneficence and generous kindness. I come near to Thee, in the name of Muhammad, Thy servant, Thy Messenger. I come near to Thee, in the name of Thy close Angels, And Prophets, And Messengers, That blessings are sent on Muhammad, Thy servant and Thy Messenger, and on the children of Muhammad, and that comfort and happiness are made available for me, My sins are kept hidden, And forgiven; My wants and needs favourably taken care of, And I am not punished for shortcomings. Do what is good for me for surely Thou very kindly and lovingly takes care of me. Certainly Thou art able to do all things.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Be-shak mai Tere jud o karam ke zariye Tera taqarrub chahta hu aur mai Tere bande aur Rasool'e Muhammad (s.a.w.a) ke zariye Tujh se taqarrub chahta hu aur mai Tere malaayeka'e moqarrabin aur Tere nabiyo’n aur rasoolo’n ke zariye Tera taqarrub chahta hu. Ay Allah! Tu apne bande aur Rasool Hazrat Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur meri khata maaf kar de, mere gunaho’n ki parda-poshi aur un se maafi de-de, meri haajaat puri farma aur jo buri harkat mujh se huwi hai us par mujhe azaab na kar, be-shak Tera afvo, Tera karam mere shaamil'e haal hai, yaqeenan Tu har cheez par qaadir hai.", "Urdu": "اے معبود! بے شک میں تیرے جود وکرم کے ذریعے تیری قربت چاہتا ہوں اور میں تیرے بندے اور رسول محمدؐ کے ذریعے تجھ سے قربت چاہتا ہوں اور میں تیرے ملائکہ مقربین اور تیرے نبیوں اور رسولوں کے ذریعے تیری قربت چاہتا ہوں۔اے اللہ! تو اپنے بندے اور رسول حضرت محمدؐ اور آلِ محمد ؐپر رحمت نازل فرما۔اور میری خطا معاف فرما دے۔میرے گناہوں کی پردہ پوشی کر اور انہیں معاف کر دے۔ میری حا جات پوری فرما اور جو بری حرکت مجھ سے ہوئی ہے اس پر مجھے عذاب نہ کر۔بے شک تیرا عفوودرگزر اور تیرا جود و کرم میرے شامل ِحال ہے۔ یقینًا توہر چیز پر قادر ہے۔", "RArabic": "ALLAAHUMMA INNEE ATAQARRABO ELAYKA BEJOODEKA WA KARAMEKA WA ATAQARRABO ELAYKA BE MOHAMMADIN A’BDEKA WA RASOOLEKA WA ATAQARRABO ELAYKA BE MA-LAAA-EKATEKAL MOQARRABEENA WA ANBEYAAA-EKA WA ROSOLEKA AN TOSALLEYA A’LAA MOHAMMADIN A’BDEKA WA RASOOLEKA WA A’LAA AALE MOHAMMADIN WA AN TOQEELANEE A’SRATEE TASTORA A’LAYYA ZONOOBEE WA WA TAGHFERA HAALEE WA TAQZEYA LEE HAWAAA-EJEE WA LAA TO-A’ZZIBNEE BE QABEEHE KAANA MINNEE FAINNA A’FWAKA WA JOODAKA YASA-O’NEE INNAKA A’LAA KULLE SHAY-IN QADEER.", "ArabicText1": "اَللّٰهُمَّ اِنِّي اَتَقَرَّبُ اِلَيْكَ بِجُوْدِكَ وَكَرَمِكَ وَاَتَقَرَّبُ اِلَيْكَ بِمُحَمَّدٍ عَبْدِكَ وَرَسُوْلِكَ وَاَتَقَرَّبُ اِلَيْكَ بِمَلَآئِكَتِكَ الْمُقَرَّبِيْنَ وَاَنْبِيَآئِكَ وَرُسُلِكَ اَنْ تُصَلِّيَ عَلٰى مُحَمَّدٍ عَبْدِكَ وَرَسُوْلِكَ وَعَلٰى آلِ مُحَمَّدٍ وَّاَنْ تُقِيْلَنِيْ عَثْرَتِيْ وَتَسْتُرَ عَلَيَّ ذُنُوْبِيْ وَتَغْفِرَهَا لِيْ وَتَقْضِيَ لِيْ حَوَآئِجِيْ وَلَا تُعَذِّبَنِيْ بِقَبِيْحٍ كَانَ مِنِّيْ فَاِنَّ عَفْوَكَ وَجُوْدَكَ يَسَعُنِيْ اِنَّكَ عَلٰى كُلِّ شَيْٓءٍ قَدِيْرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2"