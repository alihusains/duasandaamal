[{"Id": 1013157, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Shaykh Mufid, Shahid, Sayyid Ibn Tawus, and others have mentioned the following form of Ziyarah: As you are determined to visit the tomb of Imam Ali (a), you should perform ghusl, put on two clean pieces of dress, and use a perfume, even though it is acceptable without it. While you are about to leave your residing place, you may say the following…", "GujaratiDescription": null, "RUrduDescription": "Shaikh Mufid, Shaheed, Sayyed Ibne Tawus aur digar ne is tarah ki ziyarat ka zikr kiya hai. Jab tum Imam Ali (a) ki ziyarat ka iraada karo to pehle Ghusl karo, paak o saaf libaas pehno aur khushboo lagaawo (khusboo na lagaaye to koi harz nahi). Jab apne rehne ke maqaam se haram ki taraf rawaana ho to pehle is tarah se kaho…", "UrduDescription": "یہ زیاراتِ مطلقہ کے بارے میں ہے، جس کا ذکر شیخ مفیدؒ،شہیدؒ،سید ابن طاؤسؒ وغیرہ نے کیا ہے۔ اس کی کیفیت یہ ہے کہ جب زیارت کا ارادہ ہو تو غسل کرے، دو پاک کپڑے پہنے اگر ہوسکے تو خوشبو بھی لگائے۔جب گھر سے روانہ ہو تو کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, 