[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013766, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O son of the Messenger of Allah. Peace be upon you, O son of the Prophet of Allah. Peace be upon you, O son of the commander of the faithful. Peace be upon you, O son of al Husain the martyr. Peace be upon you, O martyr. Peace be upon you, O wronged and harassed and the son of the wrong and harassed. Curse of Allah be on those who killed you. Curse of Allah be on those who persecuted you. Curse of Allah be on those who heard this even but rested satisfied.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay Rasool'e Khuda (s.a.w.a) ke farzand. Salaam ho aap par ay Nabiullah (s.a.w.a) ke farzand. Salaam ho aap par ay Ameerul Momeneen (a.s) ke farzand. Salaam ho aap par ay Husain’e Shaheed (a.s) ke farzand. Salaam ho aap par keh aap shaheed aur shaheed ke farzand hai. Salaam ho aap par keh aap mazloom aur mazloom ke farzand hai. Khuda ki laanat ho un par jinho’n ne aap ko qatl kiya. Khuda ki laanat ho un par jinho’n ne aap par zulm kiya. Khuda ki laanat ho un par jinho’n ne yeh waaqeya soona to us par raazi o khush huwe.", "Urdu": "آپ پر سلام ہو اے رسولؐ خدا کے فرزند! آپ پر سلام ہو اے نبی ؐخدا کے فرزند! سلام ہو آپ پر اے امیر المومنین ؑکے فرزند! آپ پر سلام ہو اے حسینؑ شہید کے فرزند سلام ہو آپ پر کہ آپ شہید ہیں شہید کے فرزند ہیں آپ پر سلام ہو کہ آپ مظلوم اور مظلوم کے فرزند ہیں خدا کی لعنت ہو ان پر جنہوں نے آپ کو قتل کیا خدا کی لعنت ہو ان پر جنہوں نے آپ پر ظلم کیا خدا کی لعنت ہو ان پر جنہوں نے یہ واقعہ سنا تو اس پر خوش ہوئے۔", "RArabic": "AS-SALAAMO A’LAIKA YABNA RASOOLIL LAAHE AS-SALAAMO A’LAIKA YABNA NABIYYIL LAAHE AS-SALAAMO A’LAIKA YABNA AMEERIL MOMENEENA AS-SALAAMO A’LAIKA YABNAL HUSAYNISH SHAHEEDE AS-SALAAMO A’LAIKA AYYOHASH SHAHEEDO AS-SALAAMO A’LAIKA AYYOHAL MAZLOOMO WABNUL MAZLOOME LA-A’NAL LAAHO UMMATAN QATALATKA WA LA-A’NAL LAAHO UMMATAN ZALAMATKA WA LA-A’NAL LAAHO UMMATAN SAME-A’T BE-ZAALEKA FARAZEYAT BEHI.", "ArabicText1": "اَلسَّلَامُ عَلَيْكَ يَا ابْنَ رَسُولِ اللهِ۔ اَلسَّلَامُ عَلَيْكَ يَا ابْنَ نَبِيِّ اللهِ۔ اَلسَّلَامُ عَلَيْكَ يَا ابْنَ اَمِيْرِ الْمُؤْمِنِيْنَ۔ اَلسَّلَامُ عَلَيْكَ يَا ابْنَ الْحُسَيْنِ الشَّهِيْدِ۔ اَلسَّلَامُ عَلَيْكَ اَيُّهَا الشَّهِيْدُ۔ اَلسَّلَامُ عَلَيْكَ اَيُّهَا الْمَظْلُوْمُ وَابْنُ الْمَظْلُوْمِ لَعَنَ اللهُ اُمَّةً قَتَلَتْكَ وَلَعَنَ اللهُ اُمَّةً ظَلَمَتْكَ وَلَعَنَ اللهُ اُمَّةً سَمِعَتْ بِذٰلِكَ فَرَضِيَتْ بِهِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "A