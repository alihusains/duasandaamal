[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018647, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! My heart is present in Your domain and the head is lowed down and eyes are fixed at You, feet are trembling and the body has become weak, old enmities are manifested; pots of malice are boiling out. O Allah! I complain to You of the departure of our Prophet and the abundance of the enemies, and the colourful desires. O Allah! Grant truth a victory between me and my enemies, as You are the best of those who bestow victory.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda wanda! Teri baargah mein dil haazir aur gardan kham (jhuki huwi), aankhe’n lagi huwi aur qadam badhe aur badan laaghar (kamzor) ho rahe hai, puraani dushmaniya’n khul rahi hai, keeno’n ki dege’n ubal rahi hai. Khuda wanda! Ham Tujh se faryaad karte hai keh hamare Nabi (s.a.w.a) (is dunya se) uth chuke, dushman ziyadah, khwaahe-shaat ranga rang (tarah tarah ke) hai. Parwardigaar! Hamaare aur dushmano ke darmiyaan haq ko fatah’e rehmat farma, keh Tu behtar fatah dene waala hai.", "Urdu": "خدا وندا! تیری بارگاہ میں دل حاضر اور گردن خم، آنکھیں لگی ہوئی اور قدم بڑھے اور بدن لاغر ہو رہے ہیں، پرانی دشمنیوں کھل رہی ہیں کینوں کی دیگیں ابل رہی ہیں۔ خدا وندا! ہم تجھ سے فریاد کرتے ہیں کہ ہمارے نبی اٹھ چکے، دشمن زیادہ، خواہشات رنگا رنگ ہیں۔ پروردگار! ہمارے اور دشمنوں کے درمیان حق کو فتح رحمت فرما، کہ تو بہتر فتح دینے والا ہے۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ اِلَیْكَ اَفَضَتِ الْقُلُوْبُ وَمُدَّتِ الْاَعْنَاقُ وَشَخَصَتِ الْاَبْصَارُ وَنُقِلَتِ الْاَقْدَامُ وَاُنْضِیَتِ الْاَبَدَانُ۔ اَللّٰهُمَّ قَدْ صَرَّحَ مَكْنُوْنُ الشَّنَاۗنِ وَجَاشَتْ مَرَاجِلُ الْاَضْعَانِ۔ اَللّٰهُمَّ اِنَّا نَشْكُوْ اِلَیْكَ غَیْبَۃَ نَبِیِّنَا وَكَثْرَۃَ عَدُوِّنَا وَتَشَتُّتِ اَهْوَاۗئِنَا رَبَّنَا افْتَحْ بَیْنَنَا وَبَیْنَ قَوْمِنَا بِالْحَقِّ وَاَنْتَ خَیْرُ الْفَاتِحِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSig