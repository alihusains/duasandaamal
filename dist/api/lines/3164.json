[{"Id": 1013913, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Shaikh Ja’far ibn Qawlawayh Qummi has reported through a considerable chain of authority that Abu Hamzah Thumali reported Imam Sadiq (a) as saying: When you intend to perform the ziyarat of the grave of Hazrat Abbas (a), stand at the gate of the shrine and recite…", "GujaratiDescription": null, "RUrduDescription": "Shaikh Ja’far ibn Qawlawayh Qummi ne motabar sanad ke saath Abu Hamza Somali se riwaayat ki hai keh Imam Jafar Sadiq (a) ne farmaaya: Hazrat Abbas (a) ki qabre mubarak ki ziyarat ka iraada karo to haram mubarak ke darwaaze par khade ho kar yu kaho…", "UrduDescription": "شیخ اجلّ جعفر ابن قولویہ قمیؒ نے معتبر سند کے ساتھ ابو حمزہ ثمالی سے روایت کی ہے کہ امام جعفر صادق ؑ نے فرمایا:جب تم عباس ابن امیر المومنین ؑ کی قبر مبارک کی زیارت کا ارادہ کرو جو دریائے فرات کے کنارے حائر حسینی کے مقابل واقع ہے تو آپ کے روضۂ پاک کے دروازے پر کھڑے ہو کر یوں کہو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013914, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace of Allah and Peace of His favorite angels, His commissioned prophets, His righteous servants, all the martyrs, and all the veracious (ones), and also pure, true blessings that come and go, be upon you; son of Amiral Momeneen (chief of the faithful ones).", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho Khuda ka aur salaam ho uske muqarrab farishto’n ka, uske bheje huwe nabiyyo’n ka, uske nek bando’n ka aur tamaam shaheedo’n aur siddiqo’n ka. Salaam ho aur behtareen rehmate’n ho har subh o shaam aap par ay Ameerul Momeneen (a.s) ke noor’e chashm.", "Urdu": "سلام ہو خدا کا اور سلام ہو اس کے مقرب فرشتوں کا اس کے بھیجے ہوئے نبیوں کااس کے نیک بندوں کا اور تمام شہیدوں اور صدیقوں کا سلام ہو اور بہترین رحمتیں ہوں ہر صبح اور ہرشام آپ پر اے امیرالمومنینؑ کے فرزند۔", "RArabic": "SALAAMUL LAAHE WA SALAAMO MALAAA-EKATEHIL MOQARRABEENA WA AMBEYAAA-EHIL MURSALEENA WA E’BAADEHIS SAALEHEENA WA JAMEE-I’SH SHOHADAAA-E WAS-SIDDEEQEENA WAZ-ZAAKEYAATUT TAYYEBAATO FEEMAA TAGHTADEE WA TAROOHO A’LAIKA YABNA AMEERIL MOMENEENA.", "ArabicText1": "سَلَامُ اللہِ وَسَلَامُ مَلٓاَئِكَتِهِ الْمُقَرَّبِیْنَ وَاَنْبِیَآئِهِ الْمُرْسَلِیْنَ وَعِبَادِهِ الصَّالِحِیْنَ وَجَمِیْعِ الشُّهَدَاْءِ وَالصِّدِّیْقِیْنَ وَالزَّاكِیَاتُ الطَّیِّبَاتُ فِیْمَا تَغْتَدِیْ وَتَرُوْحُ عَلَیْكَ یَابْنَ اَمِیْرِ الْمُؤْمِنِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013915, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I testify to you of submission (to the will of Allah), honest acceptance as true, loyalty, and sincerity with regard to the descendant of the commissioned Prophet, peace of Allah be upon him and his Household the chosen grandson (of the Prophet), the well knowledgeable guide (to the true religion), the conveying successor, and the wrongfully oppressed one. (Namely, Imam Husain ibn Ali). So, Allah may reward you on behalf of His Messenger, Amiral Momeneen, Hasan and Husain peace of Allah be upon them, With the best reward for your steadfastness, dedication (to the sake of Allah), and support (for the right party). Very excellent be the reward of the eternal life.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawahi deta hu aap ki us ita’at, taaeed, wafadaari aur khair-khwaai par jo aap ne Nabi’e Akram ke ja-nasheen se ki hai keh jo nek nasl, nawaase, saahebe ilm, rehbar, tableegh karne waale, qaaem maqaam aur woh sitam deedeh hai jin ko tang kiya gaya. Pas Khuda jaza de aap ko apne Rasool (s.a.w.a) ki taraf se, Ameerul Momeneen (a.s) ki taraf se aur Hasan (a.s) wa Husain (a.s) ki taraf se un sab par Khuda ki rehmate’n ho aap ko behtareen jaza de, keh aap ne sabr kiya, khair-khwaai ki aur madad o nusrat ki, kya hi achchha hai aap ka anjaam.", "Urdu": "میں گواہی دیتا ہوں آپ کی اس اطاعت،تائید، وفاداری اور خیر خواہی پر جو آپ نے نبی اکرم ؐ کے جانشین سے کی ہے کہ جو منتخب نواسے، صاحب ِدلیل وعلم رہبر، تبلیغ کرنے ولے قائم مقام اور وہ مظلوم ہیں جن کو تنگ کیاگیا پس خدا جزادے آپ کو اپنے رسولؐ کی طرف سے امیر المؤمنینؑ کی طرف سے اور حسن ؑو حسینؑ کی طرف سے ان سب پر خدا کی رحمتیں ہوں آپ کو بہترین جزا دے کہ آپ نے صبر کیا خیر خواہی کی اور مدد و نصرت کی کیا ہی اچھا ہے آپ کا انجام۔", "RArabic": "ASH-HADO LAKA BIT-TASLEEME WAT-TASDEEQE WAL WAFAAA-E WAN-NASEEHATE LE KHALAFIN NABIYYE SALLAL LAAHO A’LAIHE WA AALEHIL MURSALE WAS-SIBTIL MUNTAJABE WAD-DALEELIL A’ALEME WAL WASIYYIL MOBALLEGHE WAL MAZLOOMIL MOHTAZAME FAJAZAAKAL LAAHO A’N RASOOLEHI WA A’N AMEERIL MOMENEENA WA A’NIL HASANE WAL HUSAYNE SALAWAATUL LAAHE A’LAYHIM AFZALAL JAZAAA-E BEMAA SABARTA WAH-TASABTA WA A-A’NTA FANEA’-MA U’QBAD DAARE.", "ArabicText1": "اَشْهَدُ لَكَ بِالتَّسْلِیْمِ وَالتَّصْدِیْقِ وَالْوَفَآءِ وَالنَّصِیْحَۃِ لِخَلَفِ النَّبِیِّ الْمُرْسَلِ وَالسِّبْطِ الْمُنْتَجَبِ وَالدَّلِیْلِ الْعَالِمِ وَالْوَصِیِّ الْمُبَلِّغِ وَالْمَظْلُوْمِ الْمُهْتَضَمِ فَجَزَاكَ اللہُ عَنْ رَسُوْلِهٖ وَعَنْ اَمِیْرِ الْمُؤْمِنِیْنَ وَعَنِ الْحَسَنِ وَالْحُسَیْنِ صَلَوَاتُ اللہِ عَلَیْهِمْ اَفْضَلَ الْجَزَآءِ بِمَا صَبَرْتَ وَاحْتَسَبْتَ وَاَعَنْتَ فَنِعْمَ عُقْبَی الدَّارِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013916, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s curse be on him who killed you. And Allah’s curse be on him who omitted your right, And belittled your sanctity. And Allah’s curse be on him who precluded you from having from the water of the River Euphrates. I testify that you were killed wrongfully, and that Allah will verily fulfill His promise that He made with you. Son of Amiral Momeneen: I have come to you to present myself before you. My heart is submissive to you and is following you. And I am your follower.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda laanat kare aap ke qaatil par. Khuda laanat kare us par jis ne aap ka haq na pehchaana aur aap ki be-ehteraami ki. Khuda laanat kare us par jo aap ke aur Furaat ke paani ke darmiyaan rukaawat bana. Mai gawahi deta hu keh aap mazloomi mein qatl huwe aur Khuda aap ko woh jaza dega jis ka aap logo’n se waada kiya hai. Aap ke yahan aaya hu ay Ameerul Momeneen (a.s) ke farzand, aap ka mehmaan hu, mera dil aap ke hawaale aur taabe hai aur mai aap ka pairo-kaar hu.", "Urdu": "خدا لعنت کرے آپ کے قاتل پر خدا لعنت کرے اس پر جس نے آپ کا حق نہ پہچانااور آپ کی بے احترامی کی خدا لعنت کرے اس پر جو آپ کے اور فرات کے پانی کے درمیان رکاوٹ بنامیں گواہی دیتا ہوں کہ آپ مظلومی میں قتل ہوئے اور خدا آپ کو وہ جزا دے گا جس کا آپ لوگوں سے وعدہ کیا ہے آپ کے ہاں آیا ہوں اے امیرالمومنینؑ کے فرزند آپ کا مہمان ہوں میرادل آپ کے حوالے اور تابع ہے اور میں آپ کا پیروکارہوں میں۔", "RArabic": "LA-A’NAL LAAHO MAN QATALAKA WA LA-A’NAL LAAHO MAN JAHELA HAQQAKA WAS-TAKHAFFA BE HURMATEKA WA LA-A’NAL LAAHO MAN HAALA BAYNAKA WA BAYNA MAAA-IL FORAATE ASH-HADO ANNAKA QOTILTA MAZLOOMAN WA ANNAL LAAHA MUNJEZUN LAKUM MAA WA-A’DAKUM JEA-TOKA YABNA AMEERIL MOMENEENA WAAFEDAN ELAYKUM WA QALBEE MOSALLEMUN LAKUM WA TAABE-U’N WA ANAA LAKUM TAABE-U’N.", "ArabicText1": "لَعَنَ اللہُ مَنْ قَتَلَكَ وَلَعَنَ اللہُ مَنْ جَهِلَ حَقَّكَ وَاسْتَخَفَّ بِحُرْمَتِكَ وَلَعَنَ اللہُ مَنْ حَالَ بَیْنَكَ وَبَیْنَ مَآءِ الْفُرَاتِ۔ اَشْهَدُ اَنَّكَ قُتِلْتَ مَظْلُوْمًا وَاَنَّ اللہَ مُنْجِزٌ لَّكُمْ مَا وَعَدَكُمْ جِئْتُكَ یَابْنَ اَمِیْرِ الْمُؤْمِنِیْنَ وَافِدًا اِلَیْكُمْ وَقَلْبِیْ مُسَلِّمٌ لَّكُمْ وَتَابِعٌ وَاَنَا لَكُمْ تَابِعٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013917, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I am ready to support you until Allah decides for me. He is surely the Best of all who decide. I am verily with you, not with your enemy. I am one of those who believe in you and believe in your Return. I also one of those who deny your opposites and killers. Allah may kill the group who killed you with hands and tongues (by giving orders of killing you).", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap ki nusrat par aamaadah hu yahan tak keh Khuda faisle kare aur woh behtareen faisla karne waala hai. Aap ke saath hu, aap ke saath na keh aap ke dushman ke saath. Be-shak mai aap par aur aap ke waapas aane par imaan rakhta hu aur aap ke mukhaalif aur aap ke qaatil se mera koi taalooq nahi. Khuda qatl kare us giroh ko jis ne haath aur zabaan se aap ke saath jang ki.", "Urdu": "آپ کی نصرت پر آمادہ ہوں یہاں تک کہ خدا فیصلہ کرے اور وہ بہترین فیصلہ کرنے والا ہے آپ کے ساتھ ہوں آپ کے ساتھ نہ کہ آپ کے دشمن کے ساتھ بے شک میں آپ پر اور آپ کے واپس آنے پر ایمان رکھتا ہوں اور آپ کے مخالف اور آپ کے قاتل سے میرا کوئی تعلق نہیں خدا قتل کرے اس گروہ کو جس نے ہاتھ اور زبان سے آپ کے ساتھ جنگ کی۔", "RArabic": "WA NUSRATEE LAKUM MO-A’DDATUN HATTAA YAHKOMAL LAAHO WA HOWA KHAYRUL HAAKEMEENA FA-MA-A’KUM MA-A’KUM LAA MA-A’ A’DUWWEKUM INNEE BEKUM WA BE-EYAABEKUM MENAL MOMENEENA WA BEMAN KHAALAFAKUM WA QATALAKUM MENAL KAAFEREENA QATALAL LAAHO UMMATAN QATALATKUM BIL-AYDEE WAL-ALSONE.", "ArabicText1": "وَنُصْرَتِیْ لَكُمْ مُعَدَّۃٌ حَتّٰی یَحْكُمَ اللہُ وَهُوَ خَیْرُ الْحَاكِمِیْنَ فَمَعَكُمْ مَعَكُمْ لَا مَعَ عَدُوِّكُمْ اِنِّیْ بِكُمْ وَبِاِیَابِكُمْ مِنَ الْمُؤْمِنِیْنَ وَبِمَنْ خَالَفَكُمْ وَقَتَلَكُمْ مِنَ الْكَافِرِیْنَ قَتَلَ اللہُ اُمَّۃً قَتَلَتْكُمْ بِالْاَیْدِیْ وَالْاَلْسُنِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "Ara