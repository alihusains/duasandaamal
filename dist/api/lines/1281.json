ًا وَّاَشْھَدُ اَنَّ مُحَمَّدًاعَبْدُہٗ وَرَسُوْلُہُ الْمُجْتَبٰی وَاَنَّ عَلِیًّا اَمِیْرُ الْمُوْمِنِیْنَ وَسَیِّدُ الْوَصِیِّیْنَ وَاَنَّ ذُرِّیَّتَہُ الْمَعْصُوْمِیْنَ اَئِمَّتُنَا اُوْصِیْکُمْ عِبَادَاللہِ بِتَقْوٰی اللہِ وَاِغْتِنَامِ طَاعَتِہٖ وَاِعْدَادِ الْعَمَلِ الصَّالِحِ فِیْ ھٰذِہِ الْاَیَّامِ الْفَانِیَۃِ الْخَالِیَۃِ قَبْلَ اَنْ یَّھْجُمَ عَلَیْکُمُ الْمَوْتُ الَّذِیْ لَا مَھْرَبَ مِنْہُ وَلَا مَفَرَّ۔ اَللّٰھُمَّ صَلِّ عَلٰی مُحَمَّدٍ سَیِّدِ الْمُرْسَلِیْنَ وَعَلِیٍّ اَمِیْرِ الْمُؤمِنِیْنَ وَفَاطِمَۃَبِنْتِ مُحَمَّدٍوَّالْحَسَنِ وَالْحُسَیْنِ وَ عَلِیِّ بْنِ الْحُسَیْنِ وَمُحَمَّدٍبْنِ عَلِیٍّ وَّجَعْفَرِبْنِ مُحَمَّدٍ وَّمُوْسَی بْنِ جَعْفَرٍ وَّعَلِیِّ بْنِ مُوْسٰی وَمُحَمَّدِ بْنِ عَلِیٍّ وَّعَلِیِّ بْنِ مُحَمَّدٍ وَالْحَسَنِ بْنِ عَلِیٍّ وَّالْحُجَّۃِ الْقَائِمِ بِالْحَقِّ الْمَھْدِیِّ الَّذِیْ بِبَقَائِہٖ بَقِیَتِ الدُّنْیَا وَبِیُمْنِہٖ رُزِقَ الْوَرٰی وَبِوُجُوْدِہٖ ثَبَتَتِ الْاَرْضُ وَالسَّمَائُ وَبِہٖ یَمْلَأُاللہُ الْاَرْضَ قِسْطَاً وَّعَدْلًا کَمَا مُلِئَتْ ظُلْمًا وَّجَوْرًا وَعَجِّلْ لَنَا۔ اَللّٰھُمَّ ظُھُوْرَہٗ اِنَّھُمْ یَرَوْنَہٗ بَعِیْدًا وَّنَرٰاہُ قَرِیْبًا بِرَحْمَتِکَ یَااَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null,