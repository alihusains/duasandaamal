محروم نہ رکھ ان پر اور ان کی آل پر تیری رحمت ہو اور دنیا و آخرت سے متعلق میری تمام حاجات پوری فرما دے۔", "RArabic": "ALLAAHUM-MAR ZUQNEE HAJJA BAIYTE-KAL HARAAME FEE A’A-MEE HAAZAA WA FEE KULLE A’A-MIN MAA AB-QAIY-TANEE FEE YUS-RIN MINKA WA A’A-FE-YATIN WA SA’TE RIZQIN WA LAA TUKH-LE-NEE MIN TIL-KAL MAWAA-QE-FIL KAREE-MATE WAL MASHAA-HE-DISH SHAREE-FATE WA ZIYAA-RATE QABRE NABIYYE-KA SALWAA-TOKA A’LAIY-HE WA AALE-HI WA FEE JAMEE-E’ HAWAAA-E-JID DUNYAA WAL AAKHE-RATE FA-KULLEE.", "ArabicText1": "اَللّٰھُمَّ ارْزُقْنِیْ حَجَّ بَیْتِکَ الْحَرَامِ فِیْ عَامِیْ ھٰذٰا وَفِیْ کُلِّ عَامٍ مَآ اَبْقَیْتَنِیْ فِیْ یُسْرٍ مِّنْکَ وَعَافِیَۃٍ وَّسَعَۃِ رِزْقٍ وَلَا تُخْلِنِیْ مِنْ تِلْکَ الْمَوَاقِفِ الْکَرِیْمَۃِ وَالْمَشَاھِدِ الشَّرِیْفَۃِ وَزِیَارَۃِ قَبْرِ نَبِیِّکَ صَلَوَاتُکَ عَلَیْہِ وَاٰلِہٖ وَفِیْ جَمِیْعِ حَوَآئِجِ الدُّنْیَا وَالْاٰخِرَۃِ فَکُن لِّیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011420, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah I request you to take a decisive decision regarding my affairs in the night of Qadr, a decision that cannot be reserved, nor can be changed, which includes me among the pilgrims of the Sacred House their dutiful pilgrimage receiving Thy approval, their efforts acknowledge, their mistake forgiven, their sins atoned for; and in the course of it makes it possible that I live long in ease and comfort, pay back my debts and settle the money obligations. So be it, O the Lord of the worlds.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwadigaar mera sawaal yeh hai keh Shabe Qadr mein jo Tu insaano ke muqqaddar ka faisla karta hai, jis faisle ko koi badal nahi sakta, us mein mere baare mein likh de keh mera shumaar un hujjaaje Baitullah mein ho jin ka hajj behtareen aur jin ki saee (koshish) mashkur ho, jinke gunah bakhshe huwe ho aur jin ki khataawo’n ki parda poshi ki gayi ho aur apne qaza wa qadr mein yeh bhi qaraar de de keh meri umr tulaani ho, mere rizq mein wus’at ho aur meri amaanat aur mere qarz ko Tu hi adaa kar de, aameen ya rabbal aalameen.", "Urdu": "اے معبود! میں تجھ سے سوال کرتا ہوں کہ شب ِقدر میں تو جو یقینی امور طے فرماتا ہے اور جو محکم فیصلے کرتا ہے کہ جن میں کسی قسم کی رد ّو بدل نہیں ہوتی ان میں میرا نام اپنے بیت اﷲ (کعبہ) کا حج کرنے والوں میں لکھ دے کہ جن کا حج تمہیں منظور ہے اور ان کی سعی مقبول ہے ان کے گناہ بخشے گئے اور ان کی خطائیں مٹا دی گئیں ہیں اور اپنی قضا و قدر میں میری عمر طولانی میری روزی و رزق کشادہ فرما اور مجھے ہر امانت اور ہر قرض ادا کرنے کی توفیق دے ایسا ہی ہو اے جہانوں کے پالنے والے۔   ", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA FEE-MAA TAQZEE WA TO-QAD-DERO MINAL AMRIL MAHTOO-ME FEE LAIY-LATIL QADRE MINAL QAZAAA-IL LAZEE LAA YO-RADDO WA LAA YO-BADDA-LO AN TAKTO-BANEE MIN HUJJAA-JE BAIY-TE-KAL HARAA-MIL MAB-ROORE HAJJO-HOMUL MASH-KOORE SA’YO-HOMUL MAGH-FOORE ZONOO-BO-HOMUL MO-KAFFA-RE A’N-HUM SAIYYE-AATO-HUM WAJ-A’L FEE-MAA TO-QADDE-RO AN TOTEE-LA U’M-REE FEE TAA-A’TE-KA TO-WASSE-A’ A’LAIY-YA RIZQEE WA TO-ADDE-YA A’NNEE AMAA-NATEE WA DAIY-NEE AAMEE-NA RABBAL A’A-LAMEE-NA.", "ArabicText1": "اَللّٰھُمَّ اِنِّیْ اَسْئَلُکَ فِیْمَا تَقْضِیْ وَتُقَدِّرُ مِنَ الْاَمْرِ الْمَحْتُوْمِ فِیْ لَیْلَۃِ الْقَدْرِ مِنَ الْقَضَآئِ الَّذِیْ لَا یُرَدُّ وَلَا یُبَدَّلُ اَنْ تَکْتُبَنِیْ مِنْ حُجَّاجِ بَیْتِکَ الْحَرَامِ الْمَبْرُوْرِ حَجُّہُمُ الْمَشْکُوْرِ سَعْیُہُمُ الْمَغْفُوْرِ ذُنُوْبُھُمُ الْمُکَفَّرِ عَنْہُمْ سَیِّئَاتُہُمْ وَاجْعَلْ فِیْمَا تُقَدِّرُ اَنْ تُطِیْلَ عُمْرِیْ فِیْ طَاعَتِکَ تُوَسِّعَ عَلَیَّ رِزْقِیْ وَتُؤَدِّیَ عَنِّیْ اَمَانَتِیْ وَدَیْنِیْ اٰمِیْنَ رَبَّ الْعَالَمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "A