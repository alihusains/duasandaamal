َلَا تَحُوْلُ وَاِنْ حَالَ الزَّمَنُ وَالْعَصْرُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1017303, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, before I put forward my demand, I declare Your Oneness, and the Prophet-hood of Mohammad, and the Imamate of Ali, and the Infallibility of their Progeny and the obligation of their obedience. Similarly, through this guided Guardian, steadfast Master, Abi Mohammad Othman bin Saeed, I seek means towards You through his intercession, so that he intercedes for me near the intercessors, and those who possess his love, and have purified themselves for them, to protect me from the mishaps of this world and the hereafter.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": "اَللّٰھُمَّ اِنِّیْ اُقَدِّمُ بَیْنَ یَدَیْ سُؤَالِیْ، اَلْاِعْتِرَافِ لَكَ بِالْوَحْدَانِیَّۃِ، وَالْمُحَمَّدٍ بِالنُّبُوَّۃِ، وَلِعَلِیٍّ بِالْاِمَامَۃِ، وَلِذُرِّیَّتِهِمَا بِالْعِصْمَۃِ وَفَرْضِ الطَّاعَۃِ، وَبِهٰذَا الْوَلِیَّ الرَّشِیْدِ، وَالْمَوْلَی السَّدِیْدِ، اَبِیْ مُحَمَّدٍ عُثُمَانَ بْنِ سَعِیْدِ، اَتَوَسَّلَ اِلَی اللهِ بِالشَّفَاعَۃِ اِلَیْهِ، لِیَشْفَعَ اِلٰی شُفَعَائِهٖ، وَاَهْلِ مَوَدَّتِهٖ وَخُلَصَائِهٖ، اَنْ یَسْتَنْقِدُوْنِیْ مِنْ مَكِارِهِ الدُّنْیَا وَالْآخِرَۃِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign