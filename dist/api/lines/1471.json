[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010107, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O Aba Abdillah! Peace be upon you, O son of Rasoolullah! Peace be upon you, O son of Amirul Momeneen, O son of the leader of all Wasis! Peace be upon you, O son of Fatemah Zahra, leader of all the women of all the worlds! Peace be upon you, on your ancestor (Prophet), on your father! Peace be upon your mother and on your brother! Peace be upon you and on the nine Masooms who are from your race and who are your children. Peace be upon you, O leader of all the people! Blessings and bounties of Allah on you!", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Aba Abdillah (a.s). Aap par salaam ho ay Rasoole Khuda (s.a.w.a) ke farzand. Salaam ho aap par ay ausiya ke sardaar Ameeral Momeneen (a.s) ke farzand. Salaam ho aap par ay Fatema Zahra (s.a) ke farzand jo jahano ke aurto’n ki sardaar hai. Aap par salaam, aap ke jadd (Rasool), aap ke baaba par. Salaam aap ki waaleda aur aap ke bhai par. Salaam ho aap par aur un nau (9) Masoom (a.s) par jo aap ki zurriyat aur aulaad mein se hai. Salaam ho aap par ay tamaam logo’n ke sardaar, Allah ki rehmat aur Uski barkaat ho.", "Urdu": "آپ پر سلام ہو اے ابا عبد اللہؑ، آپ پر سلام ہو اے رسولِ خداؐ کے فرزند، سلام ہو آپ پر اے اوسیء کے سردار امیر المومینینؑ کے فرزند، سلام ہو آپ پر اے فاطمہ زہراؑ کے فرزند جو جہانوں کی عورتوں کی سردار ہے، آپ پر سلام، آپ کے جد (رسولؐ) پر، آپ کے بابا پر، سلام آپ کی والدا اور آپ کے بھئی پر، سلام ہو آپ پر اور اُن ۹ معصوموں پر جو آپ کی ذریت اور اولاد میں سے ہے، سلام ہو آپ پر اے تمام لوگوں کے سردار، اللہ کی رحمت اور اُس کی برکات ہو۔", "RArabic": "AS-SALAAMO A’LAIKA YAA ABAA A’BDIL LAAHE. AS-SALAAMO A’LAIKA YABNA RASOOLIL LAAHE. AS-SALAAMO A’LAIKA YABNA AMEERIL MO-MENEENA WABNA SAYYADIL WASIY-YEENA. AS-SALAAMO A’LAIKA YABNA FAATEMA-TAZ ZAHRA-AA-E SAYYADA-TE NESA-AA-IL AA’LAMEENA. AS-SALAAMO A’LAIKA WA A’LAA JADDE-KA WA ABEE-KA. AS-SALAAMO A’LAIKA WA A’LAA UMME-KA WA AKHEE-KA. AS-SALAAMO A’LAIKA WA A’LAA TIS-A’TIL MA’SOOMEENA MIN ZURRIY-YATE-KA WA BANEE-KA. AS-SALAAMO A’LAIKUM YAA SAADAA-TEE JAMEE-A’N WA RAHMA-TUL LAAHE WA BARA-KAATO-HU.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ یَااَبَا عَبْدِ اللہِ۔ اَلسَّلَامُ عَلَیْکَ یَابْنَ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْکَ یَابْنَ اَمِیْرِ الْمُؤْمِنِیْنَ وَابْنَ سَیِّدِ الْوَصِیِّیْنَ۔ اَلسَّلَامُ عَلَیْکَ یَابْنَ فَاطِمَۃَ الزَّھْرَآئِ سَیِّدَۃِ نِسَآئِ الْعٰلَمِیْنَ۔ اَلسَّلَامُ عَلَیْکَ وَعَلٰی جَدِّکَ وَاَبِیْکَ۔ اَلسَّلَامُ عَلَیْکَ وَعَلٰی اُمِّکَ وَاَخِیْکَ۔ اَلسَّلَامُ عَلَیْکَ وَعَلٰی تِسْعَۃِ الْمَعْصُوْمِیْنَ مِنْ ذُرِّیَّتِکَ وَبَنِیْکَ۔ اَلسَّلَامُ عَلَیْکُمْ یَاسَادَاتِیْ جَمِیْعًا وَرَحْمَۃُ اللہِ وَ بَرَکَاتُہٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null