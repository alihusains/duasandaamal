[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015601, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Him who knows what every female bears and what the wombs push off and what they grow. Everything with Him is measured. He is the Knower of all that is hidden and open – the Great, the Exalted. Those who hide the words and those who make it known, those who lurk in the night and those who go freely in the daytime are equal to Him. Glory be to God who causes to die what is living, and gives life to what is dead. He knows that which the earth consumes of them, and causes what He Wills, to remain in the wombs for an appointed time.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "SUBHAA-NAL LAZEE YA’LAMO MAA TAH-MELO KULLO UNSAA WA MAA TAGHEE-ZUL AR-HAAMO WA MAA TAZ-DAADO WA KULLO SHAIY-IN I’N-DAHU BE-MIQDAA-RIN A’ALE-MUL GHAIY-BE WASH-SHAHAA-DATIL KABEE-RUL MOTA-A’ALE SAWAA-OON MINKUM MAN ASAR-RAL QAWLA WA MAN JAHARA BEHI WA MAN HOWA MUS-TAKH-FIN BIL-LAIY-LE WA SAARE-BOON BIN-NAHAARE YOMEE-TUL AH-YAA-A WA YOHYIL MAWTIL (AM-WAATA) WA YA’LAMO MAA TANQO-SUL ARZO MIN-HUM WA YO-QIRRO FIL-AR-HAAME MAA YA-SHAA-O ILAA AJA-LIM MOSAM-MAN.", "ArabicText1": "سُبْحَانَ الَّذِيْ‌ يَعْلَمُ مَا تَحْمِلُ كُلُّ اُنْثٰى‌ وَمَا تَغِيْضُ الْاَرْحَامُ وَمَا تَزْدَادُ وَكُلُّ شَيْ‌ءٍ عِنْدَهٗ بِمِقْدَارٍ عَالِمُ الْغَيْبِ وَالشَّهَادَةِ الْكَبِيْرُ الْمُتَعَالِ سَوَاۗءٌ مِنْكُمْ مَنْ اَسَرَّ الْقَوْلَ وَمَنْ جَهَرَ بِهٖ وَمَنْ هُوَ مُسْتَخْفٍ بِاللَّيْلِ وَسَارِبٌ بِالنَّهَارِ يُمِيْتُ الْاَحْيَاۗءَ وَيُحْيِ الْمَوْتِىْ‌ (الْاَمْوَاتَ) وَيَعْلَمُ‌ مَا تَنْقُصُ الْاَرْضُ مِنْهُمْ‌ وَيُقِرُّ فِي الْاَرْحَامِ مَا يَشَاۗءُ اِلٰى‌ اَجَلٍ مُّسَمًّى‌۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011469, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Allah; the Shaper of breathes. Glory be to Allah, the Fashioner. Glory be to Allah, the Creator of all pairs. Glory be to Allah, the Maker of darkness and light. Glory be to Allah the Causer the grain and the stone to germinate. Glory be to Allah, the Creator of all things. Glory be to Allah, the Creator of the seen and the unseen. Glory be to Allah as much as the ink of His Words. Glory be to Allah, the Lord of the worlds.", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai Allah, jaan-daaro’n ka paiyda karne waala. Paak hai Allah, surat-gari karne (surat bana ne) waala. Paak hai Allah, tamaam maujoodaat mein jode (pair) bana ne waala. Paak hai Allah, roshni wa taariki ka paiyda karne waala. Paak hai Allah, daane aur beej ko cheerne waala. Paak hai Allah, sab cheezo’n ka paiyda karne waala. Paak hai Allah, dekhi an-dekhi cheezo’n ka paiyda karne waala. Paak hai Allah, apne kalemaat ko badha ne waala. Paak hai Allah, jahano ka Paalne waala.", "Urdu": "پاک ہے اللہ جان داروں کا پیدا کرنے والاپاک ہے اللہ صورت گری کرنے والا پاک ہے اللہ تمام موجودات میں جوڑے بنانے والا پاک ہے اللہ روشنی و تاریکی کا پیدا کرنے والا پاک ہے اللہ دانے اور بیج کو چیرنے والا پاک ہے اللہ سب چیزوں کا پیدا کرنے والا پاک ہے اللہ دیکھی اَن دیکھی چیزوں کا پیدا کرنے والا پاک ہے اللہ اپنے کلمات کو بڑھانے والا پاک ہے اللہ جہانوں کاپالنے والا۔", "RArabic": "SUBHAA-NAL LAAHE BAARE-IN NASAME, SUBHAA-NAL LAAHIL MO-SAWWE-RE, SUBHAA-NAL LAAHE KHAALE-QIL AZ-WAAJE KULLE-HAA, SUBHAA-NAL LAAHE JAA-E’LIZ ZOLO-MAATE WAN-NOORE, SUBHAA-NAL LAAHE FAALE-QIL HABBE WAN-NAWAA, SUBHAA-NAL LAAHE KHAALE-QE KULLE SHAIY-IN, SUBHAA-NAL LAAHE KHAALE-QE MAA YORAA WA MAA LAA YORAA, SUBHAA-NAL LAAHE ME-DAADA KALE-MAATE-HI, SUBHAA-NAL LAAHE RABBIL A’A-LAMEENA.", "ArabicText1": "سُبْحَانَ اللهِ بَارِئِ النَّسَمِ، سُبْحَانَ اللهِ الْمُصَوِّرِ، سُبْحَانَ اللهِ خَالِقِ الْاَزْوَاجِ كُلِّهَا، سُبْحَانَ اللهِ جَاعِلِ الظُّلُمَاتِ وَالنُّوْرِ، سُبْحَانَ اللهِ فَالِقِ الْحَبِّ وَالنَّوٰى، سُبْحَانَ اللهِ خَالِقِ كُلِّ شَيْ‏ءٍ، سُبْحَانَ اللهِ خَالِقِ مَا يُرٰى وَمَا لَا يُرٰى، سُبْحَانَ اللهِ مِدَادَ كَلِمَاتِهٖ۔ سُبْحَانَ اللهِ رَبِّ الْعَالَمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "Ara