[{"Id": 1015941, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "When a pilgrim comes out of Mecca wearing Ehraam, he should at once say ’Labbaik’ on seeing ’Abtah’ in a loud voice and on seeing Mina he should say…", "GujaratiDescription": null, "RUrduDescription": "Ehraam ke baad jab shaher-e-Makkah se baaher aa jaaye aur “Abtah” ke nazdik pohonche to buland awaaz mein Talbeeyah (Labbaik) kehna chahiye, jab Mina ke nazdik pohoncho to kahe…", "UrduDescription": "احرام کے بعد جب شہر مکّہ سے باہر آجائے اور ابطح کے نزدیک پہونچے تو بلند آواز میں تلبیہ (لبّیک) کہنا چاہیئے جب منٰی کے نزدیک پہونچے تو کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015942, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I place all my hopes in You and supplicate to You. Fulfill my hopes and put my actions in order.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Mai Tujh hi se ummeede’n baandhe hu aur Tujh hi ko pukaar raha hu, mujhe meri aarzoowo’n tak pohoncha de aur mere amaal ki islaah farma.", "Urdu": "خدایا! میں تجھ ہی سے امیدیں باندھے ہوں اور تجھ ہی کو پکار رہا ہوں، مجھے میری آرزوؤں تک پہنچا دے اور میرے عمل کی اصلاح فرما۔", "RArabic": "ALLAAHUMMA IYYAAKA ARJOO WA IYYAAKA AD-O’O FA-BALLIGHNEE AMALEE WA ASLEH LEE A’MALEE.", "ArabicText1": "اَللّٰہُمَّ اِیَّاكَ اَرْجُوْ وَاِیَّاكَ اَدْعُوْ فَبَلِّغْنِیْ اَمَلِیْ وَاَصْلِحْ لِیْ عَمَلِیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": 