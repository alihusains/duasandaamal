eSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010873, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "Imam Zainul Aabedin (a) is reported to have said: When I say the following words, I do not care even if both men and jinn help each other against me…", "GujaratiDescription": null, "RUrduDescription": "Imam Zainul Aabdin (a) se manqool hai keh who kehte hai: Jab mai neeche diye huwe kalemaat padh leta hu, to phir mai kuchh parwah nahi karta khwah mujhe zarar (nuksaan) pohonchane ke liye tamaam Jinn o Ins bhi jama ho jaaye…", "UrduDescription": "امام زین العابدینؑ سے منقول ہے : جب میں درج ذیل دعائیہ کلمات پڑھ لیتا ہوں تو پھر میں کوئی پروا نہیں کرتا خواہ مجھے ضرر پہنچانے کے لئے تمام جن و انس بھی جمع ہو جائیں۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1010874, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah (I begin), in Allah (I trust), from Allah (I derive power), to Allah (I refer all my affairs), and on the way of Allah (I proceed). O Allah, to You have I submitted myself, towards You have I turned to face, and to You do I refer all my affairs; so, (please do) safeguard me with the guard of faith from my front, from my back, from my right side, from my left side, from above, and from beneath me; and (please do) defend me with Your Might and Power, for there is no might and no power save with Allah the All-high and All-great.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke naam se, Khuda ki zaat se, Khuda ke isn (ijaazat) se, Khuda ki taraf aur Khuda ki raah mein. Ay Ma’bood! Mai ne apni jaan Tujhe soonp di (supurd ki), apna rukh Teri jaanib kar liya aur apna maamla Tere supurd kar diya hai. Pas meri nigheh daari kar imaan ki hifaazat kar ke mere aage (front) se, mere peechhe (back) se, mere daaye (right) se, mere baaye (left) se, mere upar (top) se aur mere neeche (bottom) se aur apni bakhshish o quwwat se mera difa karta rahe kyu’n keh nahi koi harkat o quwwat magar woh jo buland-tar buzurg-tar Khuda se hai.", "Urdu": "خدا کے نام سے خدا کی ذات سے خدا کے اذن سے اور خدا کی راہ میں اے معبود! میں نے اپنی جان تجھے سونپ دی اپنا رخ تیری جانب کرلیا اور اپنا معاملہ تیرے سپرد کر دیا تو مجھے ایمان کی حفاظت کے ساتھ محفوظ کرمیرے آگے سے میرے پیچھے سے میرے دائیں سے میرے بائیں سے میرے اوپر سے میرے نیچے سے اور اپنی بخشش و قوت سے میرا دفاع کرتا رہ کیوں کہ نہیں کوئی طاقت و قوت مگر وہ جو بلند تر بزرگ تر خدا سے ہے۔", "RArabic": "BISMILAA-HE WA BILAA-HE WA MINALAA-HE WA ILALLAA-HE WA FEE SABEE-LILAA-HE. ALLAAHUMMA ILAIKA AS-LAM-TO NAFSEE WA ILAIKA WAJJAH-TO WAJ-HEE WA ILAIKA FAWWAZ-TO AMREE FAH-FAZ-NEE BE-HIF-ZIL IMAANE MIM BAIYNE YA-DAIY WA MIN KHALFEE WA AN SHEMAA-LEE WA MIN FAU-QEE WA MIN TAHTEE WADFA’ ANNEE BE-HAWLE-KA WA QUWWATE-KA FA-INNA-HU LAA HAWLA WA LAA QUWWATA ILLAA BILLAA-HIL A’LIYYIL A’ZEEME.", "ArabicText1": "بِسْمِ اللهِ وَبِاللهِ وَمِنَ اللهِ وَاِلَی للهِ وَفِیْ سَبِیْلِ اللهِ۔ اَللّٰهُمَّ اِلَیْكَ اَسْلَمْتُ نَفْسِیْ وَاِلَیْكَ وَجَّهْتُ وَجْهِیْ وَاِلَیْكَ فَوَّضْتُ اَمْرِیْ فَاحْفَظْنِیْ بِحِفْظِ الْاِیْمَانِ مِنْۢ بَیْنِ یَدَیْ وَمِنْ خَلْفِیْ وَعَنْ شِمَالِیْ وَمِنْ فَوْقِیْ وَمِنْ تَحْتِیْ وَادْ فَعْ عَنِّیْ بِحَوْلِكَ وَقُوَّتِكَ فَاِنَّهٗ لَا حَوْلَ وَلَا قُوَّۃَ اِلَّا بِاللهِ الْعَلِیِّ الْعَظِیْمِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012159, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 3, "EnglishDescription": "Imam Jafar Sadiq (a) says that obligatory namaz is better than Hajj and Hajj is better than giving the house full of gold in sadaqa. During journey obligatory namaz should be offered and it is highly recommended not to neglect repeating the following zikr 30 times after each short-form (qasr) namaz…", "GujaratiDescription": null, "RUrduDescription": "Imam Jafar Sadiq (a) ka irshaad hai keh waajib namaz Hajj se behtar hai aur ek Hajj sone se bhare makaan ko sadqe mein dene se behtar hai. Safar mein namaz padhna chahiye aur namaz-e-qasr ke baad Tasbeehaat-e-Arba 30 martaba padhna tark na kare, kyu’n keh iske padhne ki bohot ziyadah taakeed bayaan huwi hai…", "UrduDescription": "امام جعفر صادق ؑ کا ارشاد ہے : فریضہ نماز بیس حج سے بہتر ہے اور ایک حج سونے سے بھرے ہوئے مکان کو صدقہ دے دینے سے بہتر ہے۔ سفر میں نماز پڑھنا چاہیے اور نماز قصر کے بعد درج ذیل تسبیح کو ۳۰ مرتبہ پڑھنا ترک نہ کریں، کیوں کہ اس کے پڑھنے کی بہت زیادہ تاکید بیان ہوئی ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenS