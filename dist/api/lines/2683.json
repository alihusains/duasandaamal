[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002198, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Run to a dead end the hoodwinked passengers who looked for the “Ghayrallah” (other than Thee), Lost their way, lured and swindled, those who hanged onto and held fast anything that offers itself, not linked with Thee, Cried in anguish, frightened and agitated, were those who stayed and took shelter anywhere other than with Thee, Went to waste the efforts of those who tried to profit from that which they came across instead of having the wholesome benefits from Thee. Thy door is wide open for those who call humbly and fervently on Thee, Success, high mindedness, and piety are freely available to those who pray and request Thee, Thy favours are common and open to all when besought submissively, They gifts come in long strides when asked for by the hopeful supplicants, tears in their eyes, the daily bread (from Thee) is openly spread out for one and all, even the transgressors, Thy indulgence reach out (even) to those who keep themselves far from Thee, Thy usual disposition is to do favour (even) to those who stir up mischief, Thy system looks after and keeps alive (even) those who are hostile to Thee. O my Allah, therefore, keep me on the path of those who are rightly guided, give me courage to strive like those who exert themselves fully in Thy way, and do not let me be among the negligent who have gone far in their forgetfulness, forgive me on the Day of Judgment.", "Gujarati": null, "RGujarati": null, "RUrdu": "Na-ummeed huwe Tere gair ki taraf jaane waale, ghaate mein rahe Tere gair se sawaal karne waale, tabaah huwe Tere gair ke yahan jaane waale, qahet ka shikaar huwe Tere fazl ke gair se rozi talab karne waale, Tera dar ahle raghbat ke liye khula hai Teri bhalaayi talab-gaaro’n ko bohot milti hai Tera fazl saaelo’n ke liye aam hai aur Teri ataa ummeed-waaro’n ke liye amaada hai Tera rizq na-farmaano ke liye bhi faraawa’n hai Teri burdbaari dushman ke liye zaahir wa ayaan hai, gunah-gaaro’n par ehsaan karna Teri aadat hai aur zaalimo’n ko baaqi rehne dena Tera shewah hai. Ay Ma’bood! Mujhe hidaayat yaafta logo’n ki raah par laga aur mujhe koshish karne waalo’n ki si koshish naseeb farma. Mujhe ghaafil aur dur kiye huwe logo’n mein se qaraar na de aur yaume jaza mein mujhe bakhsh de.", "Urdu": "نا امید ہوئے تیرے غیرکی طرف جانے والے گھاٹے میں رہے تیرے غیر سے سوال کرنے والے تباہ ہوئے تیرے غیر کے ہاں جانے والے، قحط کاشکار ہوئے تیرے فضل کے غیر سے روزی طلب کرنے والے تیرا در اہل ِرغبت کے لئے کھلا ہے تیری بھلائی طلب گاروں کو بہت ملتی ہے تیرا فضل سائلوں کے لئے عام ہے اور تیری عطا امید واروں کے لئے آمادہ ہے تیرا رزق نافرمانوں کے لئے بھی فراواں ہے تیری بردباری دشمن کے لئے ظاہر و عیاں ہے گناہگاروں پر احسان کرنا تیری عادت ہے اور ظالموں کو باقی رہنے دینا تیرا شیوہ ہے اے معبود! مجھے ہدایت یافتہ لوگوں کی راہ پر لگا اور مجھے کوشش کرنے والوں کی سی کوشش نصیب فرما مجھے غافل اور دورکیے ہوئے لوگوں میں سے قرار نہ دے اور یوم ِجزا میں مجھے بخش دے۔", "RArabic": null, "ArabicText1": "خَابَ الْوَافِدُوْنَ عَلٰى غَيْرِكَ وَخَسِرَ الْمُتَعَرِّضُوْنَ اِلَا لَكَ وَضَاعَ الْمُلِمُّوْنَ اِلَا بِكَ وَاَجْدَبَ الْمُنْتَجِعُوْنَ اِلَا مَنِ انْتَجَعَ فَضْلَكَ بَابُكَ مَفْتُوْحٌ لِلرَّاغِبِيْنَ وَخَيْرُكَ مَبْذُوْلٌ لِلطَّالِبِيْنَ وَفَضْلُكَ مُبَاحٌ لِلسَّائِلِيْنَ وَنَيْلُكَ مُتَاحٌ لِلْآمِلِيْنَ وَرِزْقُكَ مَبْسُوْطٌ لِمَنْ عَصَاكَ وَحِلْمُكَ مُعْتَرِضٌ لِمَنْ نَاوَاكَ عَادَتُكَ الْاِحْسَانُ اِلَى الْمُسِيْئِيْنَ وَسَبِيْلُكَ الْاِبْقَاءُ عَلَى الْمُعْتَدِيْنَ۔ اَللّٰهُمَّ فَاهْدِنِيْ هُدَى الْمُهْتَدِيْنَ وَارْزُقْنِي اجْتِهَادَ الْمُجْتَهِدِيْنَ وَلَا تَجْعَلْنِيْ مِنَ الْغَافِلِيْنَ الْمُبْعَدِيْنَ وَاغْفِرْ لِيْ يَوْمَ الدِّيْنِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "Ar