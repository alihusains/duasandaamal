[{"Id": 1000141, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "In Misbah and in Balad al-Amin, Shaikh Kafami, as well as Shaikh Shaheed in his Majmuah, have narrated that the Holy Prophet (s) said that one who says the following dua after each obligatory prayer in Ramadan will have all his sins forgiven up to the Resurrection Day…", "GujaratiDescription": null, "RUrduDescription": "Shaikh Kafami ne Misbah wa Balad al-Amin aur Shaikh Shaheed apne Majmuah mein Rasoole Khuda (s) se naql kiya hai keh Aap (s) ne farmaya: Jo shakhs Ramazanul Mubarak mein har waajib namaz ke baad yeh dua padhe to Khuda wanda uske qayaamat tak ke gunah maaf kar dega aur woh dua yeh hai…", "UrduDescription": "شیخ کفعمی ؒنے مصباح و بلد الامین اور شیخ شہید ؒنے اپنے مجموعہ میں رسول اﷲؐ سے نقل کیا ہے کہ آپ نے فرمایا: جو شخص رمضان المبارک میں ہر واجب نماز کے بعد یہ دعا پڑھے تو خداوند اس کے قیامت تک کے گناہ معاف کر دے گا اور وہ دعا یہ ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011417, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Let peace and tranquility prevail over the people buried in the graves. O Allah! Let the have-nots get rid of their scarcity. O Allah! Let the hungry be able to eat their fill. O Allah! Provide clothes to the mortals in tatters. O Allah! Enable all debtors pay back their debts. O Allah! Cheer up every heart-broken. O Allah! Let every wayfarer return to his home. O Allah! Set free every detained captive.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Qabro’n mein dafn shuda logo’n ko shaad-maani (khushi) ataa farma. Ay Ma’bood! Har mohtaaj ko gani bana de. Ay Ma’bood! Har bhuke ko shikam-ser kar de. Ay Ma’bood! Har uryaa’n (bin-libaas) ko libaas pehna de. Ay Ma’bood! Har maqrooz ka qarz adaa kar de. Ay Ma’bood! Har museebat zadah ko khush-haali ataa kar. Ay Ma’bood! Har musaafir ko watan waapas la. Ay Ma’bood! Har qaidi ko rehaayi bakhsh de.", "Urdu": "اے معبود! قبروں میں دفن شدہ لوگوں کو شادمانی عطا فرما اے معبود! ہر محتاج کو غنی بنا دے اے معبود! ہر بھوکے کو شکم سیر کر دے اے معبود! ہر عریان کو لباس پہنا دے اے معبود! ہر مقروض کا قرض ادا کر اے معبود! ہر مصیبت زدہ کو آسودگی عطا کر اے معبود! ہر مسافر کو وطن واپس لا اے معبود! ہر قیدی کو رہائی بخش دے۔", "RArabic": "ALLAAHUMMA ADKHIL A’LAA AHLIL QOBOO-RIS SOROO-RA. ALLAAHUMMA AGHNE KULLA FAQEE-RIN. ALLAAHUM-MASH BE’ KULLA JAAA-E-I’N. ALLAAHUM-MAK SO KULLA OO’R-YAA-NIN. ALLAAHUM-MAQ ZE DAIY-NA KULLE MADEE-NIN. ALLAAHUMMA FARRIJ A’N KULLE MAKROO-BIN. ALLAAHUMMA RUDDA KULLA GHAREE-BIN. ALLAAHUMMA FUKKA KULLA ASEE-RIN.", "ArabicText1": "اَللّٰہُمَّ اَدْخِلْ عَلٰی اَھْلِ الْقُبُوْرِ السُّرُوْرَ۔ اَللّٰہُمَّ اَغْنِ کُلَّ فَقِیْرٍ۔ اَللّٰھُمَّ اشْبِعْ کُلَّ جَآئِعٍ۔ اَللّٰہُمَّ اکْسُ کُلَّ عُرْیَانٍ۔ اَللّٰہُمَّ اقْضِ دَیْنَ کُلِّ مَدِیْنٍ۔ اَللّٰہُمَّ فَرِّجْ عَنْ کُلِّ مَکْرُوْبٍ۔ اَللّٰہُمَّ رُدَّ کُلَّ غَرِیْبٍ۔ اَللّٰہُمَّ فُکَ کُلَّ اَسِیْرٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011418, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Let every trouble-maker see the right path in the common interest of the Muslims. O Allah! Make the sick get well. O Allah! Fill the yawning gaps of the destitution through Thy unlimited resources. O Allah! Make better our deteriorating condition with the help of Thy free bounties and benefits. O Allah! Free us from the burden of debts and poverty. Verily Thou art able to do all things.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Musalmaano ke umoor (affairs) mein se har bigaad ki islaah farma. Ay Ma’bood! Har mareez (bimaar) ko shifa ataa farma. Ay Ma’bood! Apni daulat o sarwat se hamari mohtaji khatm kar de. Ay Ma’bood! hamari bad-haali ko khush-haali se badal de. Ay Ma’bood! hamein apne qarz adaa karne ki taufiq de aur mohtaji se bacha le, be-shak Tu har cheez par qudrat rakhta hai.", "Urdu": "اے معبود! مسلمانوں کے امور میں سے ہر بگاڑ کی اصلاح فرما دے اے معبود! ہر مریض کو شفا عطا فرما اے معبود! اپنی ثروت ودولت سے ہماری محتاجی ختم کر دے اے معبود! ہماری بد حالی کو خوش حالی سے بدل دے اے معبود! ہمیں اپنے قرض ادا کرنے کی توفیق دے اور محتاجی سے بچا لے بے شک تو ہر چیز پر قدرت رکھتا ہے۔", "RArabic": "ALLAAHUMMA ASLEH KULLA FAASE-DIN MIN OMOO-RIL MUSLE-MEENA. ALLAAHUM-MASH FE KULLA MAREE-ZIN. ALLAAHUMMA SUDDA FAQRA-NAA BE-GHE-NAAKA. ALLAAHUMMA GHAIYYIR SOO-A HAALE-NAA BE-HUSNE HAALE-KA. ALLAAHUM-MAQ ZE A’NNAD DAIY-NE WA AGH-NENAA MENAL FAQRE INNA-KA A’LAA SHAI-IN QADEE-RIN.", "ArabicText1": "اَللّٰہُمَّ اَصْلِحْ کُلَّ فَاسِدٍ مِّنْ اُمُوْرِ الْمُسْلِمَیْنَ۔ اَللّٰہُمَّ اشْفِ کُلَّ مَرِیْضٍ۔ اَللّٰہُمَّ سُدَّ فَقْرَنَا بِغِنَاکَ۔ اَللّٰہُمَّ غَیِّرْسُوْئَ حَالِنَا بِحُسْنِ حَالِکَ۔ اَللّٰہُمَّ اقْضِ عَنَّا الدَّیْنَ وَاَغْنِنَا مِنَ الْفَقْرِ اِنَّکَ عَلٰی کُلِّ شَیْٓءٍ قَدِیْرٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImag