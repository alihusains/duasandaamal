[{"Id": 1016781, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "This great supplication was mentioned in \"Al-Kalam Tayyib\" from the leader of the time (peace be on him) those that lost anything or those that has a demand should always read the following…", "GujaratiDescription": null, "RUrduDescription": "Al Kalam Al Tayyib mein farmate hai; dua azeem-ush-shaan jo keh Imam-e-Zamana (a) se marwi hai aur uske liye hai jiski koi cheez goom huwi ho ya uski koi ahem haajat ho, chunaan-che usey chahiye keh is dua ko ziyadah se ziyadah padhe…", "UrduDescription": "الکلم الطیب میں لکھتے ہیں یہ عظیم الشان دعا ہے کہ حضرت صاحب الزمان سے اس شخص کے لئے کہ جس کو کوئی چیز گم ہوئی ہے یا کوئی مہم حاجت رکھتا ہو روایت ہوئی ہے کہ جو بھی مہم حاجت رکھتا ہو اس دعا کو زیادہ پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlue