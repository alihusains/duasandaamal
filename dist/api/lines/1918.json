[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002417, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please do) send blessings upon the Commander of the Faithful Ali the son of Abu Talib, the brother, ally, choice, and patron of Your Prophet, the store of his knowledge, the depot of his secrets, the door to his wisdom, the spokesman with his arguments, the caller to his code of law, his viceroy in his community, the reliever of agonies from his face, the terminator of the infidels, and the conqueror on the wicked ones; You have made him, with regard to his position to Your Prophet, occupy the same position that (Prophet) Aaron enjoyed with (Prophet) Moses.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Momino ke Ameer Ali ibne Abi Taalib (a.s) par durood bhej keh jo Tere Nabi ke beraadar (bhai), unke waaris, unke pasandida, unke madad-gaar, unke ilm ke amaanat-daar, unke raaz ke ameen, unke hikmat ke mazhar, unki hujjat, bayaan karne waale, unki shariyyat ki taraf daawat dene waale, unki ummat mein unke khalifa, unki zaat se mushkilo’n ko dur karne waale, kaafiro’n ki quwwat tod ne waale aur fasaadiyo’n ko zer karne waale keh jin ko Tu ne apne Nabi ke saath woh maqaam diya jo Haaroon (a.s) ka Moosa (a.s) ke saath tha.", "Urdu": "اے معبود! رحمت فرما مومنوں کے سردار علی ؑابن ابی طالبؑ پر جو تیرے نبی ؐکے بھائی ان کے ولی ان کے مددگار ان کے وصی ان کے وزیر وں کے علم کے خزانہ دار وں کے راز داں ان کی حکمت کے دروازہ ان کی حجت بیان کرنے والے ان کی شریعت کی طرف بلانے والے امت میں ان کے قائم مقام اور خلیفہ ان سے سختی دورہٹانے والے کافروں کی کمر توڑنے والے اور فاجروں کو پست کرنے والے کہ جن کو تو نے اپنے نبی ؐکے ساتھ وہ مرتبہ دیا جو موسیٰؑ کے ساتھ ہارون کا تھا۔", "RArabic": "ALLAAHUMMA SALLE A’LAA AMEERIL MOMENEENA A’LIYYIBNE ABEE TAALE-BIN AKHEE NABIYYE-KA WA WALIYYE-HI WA NAASERE-HI WA WASIYYE-HI WA WAZEERE-HI WA MUSTAWDA-E’ IL’ME-HI WA MAWZE-E’ SIRRE-HI WA BAABE HIKMATE-HI WAN NAATE-QE BE-HUJJATE-HI WAD DAA-E’E ILAA SHAREE-A’TE-HI WA KHALEE-FATE-HI FEE UMMATE-HI WA MO-FARRE-JIL KARBE ’AN WAJHE-HI QAASE-MIL KAFARA-TE WA MURGHE-MIL FAJA-RATIL LAZEE JA-AL’TA-HU MIN NABIYYE-KA BE MANZE-LATE HAAROONA MIN MOOSAA.", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى اَمِيْرِ الْمُؤْمِنِيْنَ عَلِيِّ بْنِ اَبِيْ طَالِبٍ اَخِيْ نَبِيِّكَ وَوَلِيِّهٖ وَصَفِيِّهٖ وَوَزِيْرِهٖ وَمُسْتَوْدَعِ عِلْمِهٖ وَمَوْضِعِ سِرِّهٖ وَبَابِ حِكْمَتِهٖ وَالنَّاطِقِ بِحُجَّتِهٖ وَالدَّاعِيْ اِلٰى شَرِيْعَتِهٖ وَخَلِيْفَتِهٖ فِيْ اُمَّتِهٖ وَمُفَرِّجِ الْكُرَبِ عَنْ وَجْهِهٖ قَاصِمِ الْكَفَرَةِ وَمُرْغِمِ الْفَجَرَةِ الَّذِيْ جَعَلْتَهٗ مِنْ نَبِيِّكَ بِمَنْزِلَةِ هَارُوْنَ مِنْ مُوْسٰى۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002418, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please do) give support to anyone who supports him, be the enemy of everyone who antagonizes him, give victory to anyone who gives him his victory, disappoint everyone who disappoints him, and lay curse on anyone who incurs the hostility of him from the past and the coming generations. And (please do) bless him with the best blessings that You have ever poured on any of Your Prophet’s successors. O Lord of the worlds!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Usey dost rakh jo unko dost rakkhe, dushman rakkhe usko jo unka dushman ho, madad de usko jo unki madad kare aur usko ruswa kar jo unko chhod jaaye aur us par laanat bhej jis ne unki mukhaalefat ki awwaleen o aakhereen mein se aur un par rehmat farma woh behtareen rehmat jo Tu ne apne nabiyyo’n ke ja-nasheeno mein se kisi par farmaayi ho, ay jahano ke Parwardigaar.", "Urdu": "اے اللہ!اس کے دوست سے دوستی اور اس کے دشمن سے دشمنی رکھ جو ان کی مددکرے اس کی مدد کر اور چھوڑ دے اس کوجو اس کو چھوڑ دے اور لعنت کر اس پر اولین و آخرین میں سے جو ان کے مقابل آیا اور رحمت فرما حضرت امیرؑ پر وہ بہترین رحمت جو تو نے اپنے نبیوں کے اوصیاء میں سے کسی پر کی ہو اے جہانوں کے پالنے والے۔", "RArabic": "ALLAAHUMMA WAALE MAN WAALAA-HU MA AA’DE MAN AA’DAA-HU WAN SUR MAN NASARA-HU WAKH-ZUL MAN KHA-ZALA-HU WAL-A’N MAN NASABA LAHU MINAL AW-WALEE-NA WAL AAKHE-REENA WA SALLE A’LAIHE AF-ZALA MAA SALLAI-TA A’LAA AH-DIN MIN AWSE-YAA-E AMBIYAA-E-KA YAA RABBAL AA’LAMEE-NA.", "ArabicText1": "اَللّٰهُمَّ وَالِ مَنْ وَالَاهٗ وَعَادِ مَنْ عَادَاهٗ وَانْصُرْ مَنْ نَصَرَهٗ وَاخْذُلْ مَنْ خَذَلَهٗ وَالْعَنْ مَنْ نَصَبَ لَهٗ مِنَ الْاَوَّلِيْنَ وَالْآخِرِيْنَ وَصَلِّ عَلَيْهِ اَفْضَلَ مَا صَلَّيْتَ عَلٰى اَحَدٍ مِّنْ اَوْصِيَاءِ اَنْۢبِيَائِكَ يَا رَبَّ الْعَالَمِيْنَ ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGre