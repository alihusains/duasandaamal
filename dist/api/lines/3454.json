abicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014948, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please) help me pay back to all of Your creatures their dues for which I am liable, both the insignificant and the large, with easiness and wellbeing from Your Presence. As for the dues that I am too weak to settle, I am too poor to make up, and my physique, certitude, and self are too short to satisfy, (please) settle them on behalf of me out of the abundant favor You own. Then, (please) do not cut off any amount of it from my good deeds. O most merciful of all those who show mercy!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Lauta de saari makhlooq ko unke doobe huwe qarze jo mujh par hai, chhote hai ya bade apni taraf se aasaani wa sahoolat ke saath keh jin ki adaayegi meri taaqat o wus’at se baahar hai, jin ko adaa karna mere badan, meri jaan ke liye dushwaar hai, pas woh meri taraf se adaa kar de aur apne fazl se itna ziyadah de keh phir mujh par kisi ka kuchh bhi baaqi na rahe keh jise Tu meri nekiyo’n se adaa kare, ay sab se ziyadah rahem karne waale.", "Urdu": "اے معبود!ساری مخلوق کو ان کے ڈوبے ہوئے قرضے جو مجھ پر ہیں لوٹادے چھوٹے ہیں یا بڑے اپنی طرف سے آسانی و سہولت کے ساتھ کہ جن کی ادائیگی میری طاقت و وسعت سے باہر ہے جن کو ادا کرنا میرے بدن میری جان کے لئے دشوار ہے پس وہ میری طرف سے ادا کر دے اور اپنے فضل سے اتنا زیادہ دے کہ پھر مجھ پر کسی کا کچھ بھی باقی نہ رہے کہ جسے تو میری نیکیوں سے ادا کرے اے سب سے زیادہ رحم کرنے والے۔", "RArabic": "ALLAAHUM-MAR DUD ILAA JAMEE-E’ KHALQE-KA MAZAA-LEMA-HOMUL LATEE QEBA-LEE SAGHEE-RAHAA WA KABEE-RAHAA FEE YUSRIM MINKA WA A’AFE YATIN WA MAALAM TAB-LUGH-HO QUWWA-TEE WA LAM TASA’HO ZAATO YADEE WA LAM YAQWA A’LAIY-HE BADA-NEE WA YAQEE-NEE WA NAFSEE FA-ADDE-HI A’NNEE MIN JAZEE-LE MAA I’NDA-KA MIN FAZLE-KA SUMMA LAA TO-KHALLIF A’LAIYYA MINHO SHAIY-AN TAQZEE-HE MIN HASA-NAATEE YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "اَللّٰهُمَّ ارْدُدْ اِلٰى جَمِيْعِ خَلْقِكَ مَظَالِمَهُمُ الَّتِىْ قِبَلِىْ صَغِيْرَهَا وَكَبِيْرَهَا فِىْ يُسْرٍ مِّنْكَ وَعَافِيَةٍ وَمَالَمْ تَبْلُغْهُ قُوَّتِىْ وَلَمْ تَسَعْهُ ذَاتُ يَدِىْ وَلَمْ يَقْوَ عَلَيْهِ بَدَنِىْ وَيَقِيْنِىْ وَنَفْسِىْ فَاَدِّهٖ عَنِّىْ مِنْ جَزِيْلِ مَا عِنْدَكَ مِنْ فَضْلِكَ ثُمَّ لَا تُخَلِّفْ عَلَىَّ مِنْهُ شَيْئًا تَقْضِيْهِ مِنْ حَسَنَاتِىْ يَا اَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014949, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I bear witness that there is no god but Allah, One and Only and having no associate with Him. I bear witness that Muhammad is His servant and messenger, the religion is as exactly as He has legislated, Islam is as exactly as He has described, the Book is as exactly as He has revealed, the truth is as exactly as He has said, and Allah is the manifest truth. May Allah make good mention of Muhammad and his Household and may He greet Muhammad and his Household with peace.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawah hu keh nahi koi ma’bood magar Allah hai, Woh yakta hai koi Us ka shareek nahi aur mai gawah hu keh Muhammad (s.a.w.a) Us ke bande aur rasool hai, yeh keh deen woh hai jo Us ne muqarrar kiya, Islaam wohi hai jaise Us ne bataaya, kitaab wohi hai jaise Us ne naazil kiya, aur qoul wohi hai jo Us ne farmaaya, aur yeh keh Khuda wohi aashkaar'e haq hai jis ne Muhammad (s.a.w.a) aur unke Ahle-baiyt (a.s) ko khoobi se yaad kiya aur durood bhejta hai Hazrat Muhammad (s.a.w.a) aur unke Ahle-baiyt (a.s) par salaam ke saath.", "Urdu": "میں گواہ ہوں کہ نہیں کوئی معبود مگر اللہ ہے وہ یکتا ہے کوئی اس کا شریک نہیں اور میں گواہ ہوں محمدؐ اس کے بندے اور رسولؐ ہیں یہ کہ دین وہ ہے جو اس نے مقرر کیا اسلام وہی ہے جیسے اس نے بتا یا کتاب وہی ہے جیسے اس نے نازل کی اور قول وہی ہے جو اس نے فرمایا اور یہ کہ خدا وہی آشکار حق ہے جس نے محمدؐ اور ان کے اہل بیتؑ کو خوبی سے یاد کیا اور درود بھیجتا ہے حضرت محمدؐ اور ان کے اہل بیؑت پر سلام کے ساتھ۔", "RArabic": "ASH-HADO AN LAA ILAAHA ILLAL LAAHO WAHDA-HU LAA SHAREEKA LAHU, WA ASH-HADO ANNA MOHAMMADAN A’BDA-HU WA RASOOLO-HU WA A’NNAD DEENA KAMAA SHARA-A’ WA ANNAL ISLAAMA KAMAA WA-SAFA WA ANNAL KETAABA KAMAA ANZAL WA ANNAL QAWLA KAMAA HADDASA WA ANNAL LAAHA HOWAL HAQQUL MOBEENO ZAKA-RAL LAAHO MOHAMMADAW WA AHLE-BAIYTE-HI BE-KHAI-RIN WA HAYYAA MOHAMMADAW WA AHLE-BAIYTE-HI BIS SALAAME.", "ArabicText1": "اَشْهَدُ اَنْ لَا اِلٰهَ اِلَّا اللهُ وَحْدَهٗ لَا شَرِيْكَ لَهٗ وَاَشْهَدُ اَنَّ مُحَمَّدًا عَبْدُهٗ وَرَسُوْلُهٗ وَاَنَّ الدِّيْنَ كَمَا شَرَعَ وَاَنَّ الْاِ سْلَامَ كَمَا وَصَفَ وَاَنَّ الْكِتَابَ كَمَا اَنْزَلَ وَاَنَّ الْقَوْلَ كَمَا حَدَّثَ وَاَنَّ اللهَ هُوَ الْحَقُّ الْمُبِيْنُ ذَكَرَ اللهُ مُحَمَّدًا وَّاَهْلَ بَيْتِهٖ بِخَيْرٍ وَحَيَّا مُحَمَّدًا وَّاَهْلَ بَيْتِهٖ بِالسَّلَامِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18