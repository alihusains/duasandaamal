ll, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016817, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I truly accept that there is no God but Allah, I have faith and I certify that there is no God but Allah, I declare out of servitude and serfdom that there is no God but Allah. O Allah! O He who honours every lonely believer, and humiliates every adamant titan, You are my Protector while different paths trouble me, and while the Earth tightens for me with all its extensiveness.", "Gujarati": null, "RGujarati": null, "RUrdu": "Bar-haq aur saabit Khuda ke alaawa koi ma’bood nahi hai aur imaan o sachchaai ke saath Allah ke alaawa koi ma’bood nahi hai aur bandagi o ghulaami ke saath kehta hu keh Allah ke alaawa koi ma’bood nahi hai. Ay Allah! Tu har tanha momin ka madad-gaar hai aur zaalim o sarkash ko zaleel karne waala hai aur jab mujhe mukhtalif mazaahib o raaste fikr-mand karte hai, to Tu hi meri panah-gah hai aur zameen mujh par apni wus’at ke ba-wajood tang ho jaati hai.", "Urdu": "برحق اور ثابت خدا کے علاوہ کوئی معبود نہیں ہے اور ایمان و سچائی کے ساتھ اللہ کے علاوہ کوئی معبود نہیں ہے اور بندگی و غلامی کے ساتھ کہتا ہوں کہ اللہ کے علاوہ کوئی معبود نہیں ہے۔ اے اللہ! تو ہر تنہا مومن کا مددگار ہے اور ظالم و سرکش کو ذلیل کرنے والا ہے اور جب مجھے مختلف مذاہب و راستے فکر مند کرتے ہیں تو، توہی میری پناہ گاہ ہے اور زمین مجھ پر اپنی وسعت کے باوجود تنگ ہو جاتی ہے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "لَا اِلٰهَ اِلَّا اللهُ حَقًّا حَقًّا، لَا اِلٰهَ اِلَّا اللهُ اِيْمَانًا وَ صِدْقًا، لَا اِلٰهَ اِلَّا تَعَبُّدًا وَرِقًّا۔ اَللّٰھُمَّ مُعِزَّ كُلِّ مُؤْمِنٍ وَحِیْدٍ، وَمُذِلَّ كُلِّ جَبَّارٍ عَنِیْدٍ، اَنْتَ كَنَفِیْ حِیْنَ تُعْیِیْنِی الْمَذَاهِبُ، وَتَضِیْقُ عَلَیَّ الْاَرْضُ بِمَا رَحُبَتْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRed