gn4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013855, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Abu Abdillah (a.s). Aap par salaam ho ay Rasool'e Khuda (s.a.w.a) ke farzand. Mai gawahi deta hu keh aap ne namaz qaaem ki, zakaat adaa ki hai, aap ne nek kaamo ka hukm diya aur buraaiyo’n se mana farmaaya, aap ne logo’n ko apne Rab ke raaste ki taraf bulaaya, daanish mandi aur behtareen naseehat ke saath. Mai gawahi deta hu keh yaqeenan jin logo’n ne aap ka khoon bahaaya aur aap ki be-ehteraami ki woh laanati azaab waale hai. Dawood (a.s) aur Isa bin Mariyam (a.s) ki zabaane mubarak par na-farmaani aur zulm ki wajah se.", "Urdu": "آپ پر سلام ہو اے ابو عبداؑ للہ! آپ پر سلام ہو اے رسول خداؐ کے فرزند میں گواہی دیتا ہوں کہ آپ نے نماز قائم کی زکوٰۃ ادا کی آپ نے نیک کاموں کا حکم دیا اور برائیوں سے منع فرمایا آپ نے لوگوں کو اپنے رب کے راستے کی طرف بلایا دانش مندی اور بہترین نصیحت کے ساتھ، میں گواہی دیتا ہوں یقینًا ان لوگوں نے آپ کا خون بہایا اور آپ کی بے احترامی کی وہ لعنتی اورعذاب والے ہیں داؤدؑ اورعیسیٰ ؑابن مریم(س) کی زبان مبارک پر نافرمانی اور ظلم کی وجہ سے۔", "RArabic": "AS-SALAAMO A’LAIKA YAA ABAA A’BDIL LAAHE. AS-SALAAMO A’LAIKA YABNA RASOOLIL LAAHE. ASH-HADO ANNA-KA QAD AQAM-TAS SALAATA WA AA-TAIY-TAZ ZAKAATA WA AMARTA BIL MA’ROO-FE WA NAHAY-TA A’NIL MUNKARE WA DA-A’WTA ILAA SABEELE RABBE-KA BIL HIKMATE WAL MAW-E’ZATIL HASANA-TE WA ASH-HADO ANNAL LAZEE-NA SAFA-KOO DAMAKA WAS TAHAL-LOO HURMATA-KA MAL-OO’NOONA MO-A’ZZA-BOONA A’LAA LE-SAANE DAAWOODA WA EE’SAB-NE MARYAMA ZAALEKA BE-MAA A’SAW WA KAANOO YA’TA-DOONA.", "ArabicText1": "اَلسَّلَامُ عَلَيْكَ يَا اَبَا عَبْدِ اللهِ۔ اَلسَّلَامُ عَلَيْكَ يَا ابْنَ رَسُوْلِ اللهِ۔ اَشْهَدُ اَنَّكَ قَدْ اَقَمْتَ الصَّلَاةَ وَآتَيْتَ الزَّكَاةَ وَاَمَرْتَ بِالْمَعْرُوْفِ وَنَهَيْتَ عَنِ الْمُنْكَرِ وَدَعَوْتَ اِلٰى سَبِيْلِ رَبِّكَ بِالْحِكْمَةِ وَالْمَوْعِظَةِ الْحَسَنَةِ وَاَشْهَدُ اَنَّ الَّذِيْنَ سَفَكُوْا دَمَكَ وَاسْتَحَلُّوْا حُرْمَتَكَ مَلْعُوْنُوْنَ مُعَذَّبُوْنَ عَلٰى لِسَانِ دَاوُدَ وَعِيْسَى ابْنِ مَرْيَمَ ذٰلِكَ بِمَا عَصَوْا وَكَانُوْا يَعْتَدُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) choicest blessings be upon Mohammed and his holy progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar Tu rehmat naazil farma Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par.", "Urdu": "اے معبود! رحمت نازل فرما حضرت محمدؐ اور انکی آل ؑپر۔", "RArabic": "ALLAHUMMA SWALLE ALAA MUHAMMADIW WA AALE MUHAMMADIN", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14":