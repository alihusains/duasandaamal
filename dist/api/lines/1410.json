ll, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000136, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I am satisfied and happy that Allah is my Lord, Muhammad (blessings of Allah be on him and on his children) is my prophet; Islam is my religion, Quran is the book (I follow), Kabah is the direction (towards which I turn), Ali is my wali (vicegerent) and Imam (guide), Hasan, Husayn, Ali son of Husayn, Muhammad son of Ali, Jafar son of Muhammad, Musa son of Jafar.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai raazi hu is par keh Allah mera Rab aur Hazrat Muhammad (s.a.w.a) mere Nabi hai. Islam mera deen hai. Qur’an meri kitaab hai. Kaaba mera qibla hai. Aur raazi hu keh Ali (a.s) mere Maula aur Imam hai. Neez (aur) Hasan o Husain (a.s), Ali ibne Husain (a.s), Muhammad ibne Ali (a.s), Ja’far ibne Muhammad (a.s), Moosa ibne Ja’far (a.s).", "Urdu": "میں راضی ہوں اس پر کہ اﷲمیرا رب اور حضرت محمدؐ میرے نبی ہیں اسلام میرادین ہے قرآن میری کتاب ہےکعبہ میرا قبلہ ہے اورر اضی ہوں اس پر کہ علی ؑ میرے مولا اور امام ہیں نیز حسن ؑ و حسین ؑ، علی ؑ ابن حسین ؑ، محمدؑ ابن علی ؑ، جعفر ؑ ابن محمدؑ، موسیٰٰ ؑ ابن جعفرؑ۔", "RArabic": "RAZEETO BILLAAHE RABBAN WA BE MOHAMMADIN SALLALLAAHO A’LAYHE WA AALEHI NABIYYAN WA BIL ISLAAME DEENAN WA BIL QUR-AANE KETAABAN WA BIL KA’BATE QIBLATAN WA BE A’LIYYIN WALIYYAWN WA EMAAMAN WA BIL HASANE WAL HUSAYNE WA A’LIYYIBNIL HUSAYNE WA MOHAMMADIBNE A’LIYYIN WA JA’FARIBNE MOHAMMADIN WA MOOSABNE JA’FARIN.", "ArabicText1": "رَضِیْتُ بِاللہِ رَبًّا وَّبِمُحَمَّدٍ صَلَّی اللہُ عَلَیْہِ وَآلِہٖ نَبِیًّا وَّبِالْاِسْلَامِ دِیْنًا وَّبِالْقُرْآنِ کِتَاْبًا وَّبِالْکَعْبَۃِ قِبْلَۃً وَّبِعَلِیٍّ وَّلِیًّا وَّاِمَامًا وَّبِالْحَسَنِ وَالْحُسَیْنِ وَعَلِیِّ ابْنِ الْحُسَیْنِ وَمُحَمَّدِابْنِ عَلِیٍّ وَّجَعْفَرِابْنِ مُحَمَّدٍ وَّمُوْسَی بْنِ جَعْفَرٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010194, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Ali son of Musa, Muhammad son of Ali, Ali son of Muhammad, Hasan son Ali, Hujjat (living argument) son of Hasan, (blessings of Allah be on them all) are my Imams (guides). O Allah, I am satisfied and happy that all of them are my Imams, so let me be a source of happiness to them. Verily You are able to do all things.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ali ibne Moosa (a.s), Muhammad ibne Ali (a.s), Ali ibne Muhammad (a.s), Hasan ibne Ali (a.s) aur Hujjat ibnil Hasan (a.t.f.s) keh un par Allah ki rehmate’n ho woh aimma hai. Ay Mabood mai raazi hu keh woh mere Imam (a.s) hai, pas unhe mujh se raazi farma de, be-shak Tu har cheez par qaadir hai.", "Urdu": "علی ؑ ابن موسیٰٰ ؑ، محمد ؑ ابن علیؑ، علی ؑ ابن محمدؑ، حسن ؑ ابن علی ؑ،اور حجتؑ ابن حسنؑ کہ ان پر اللہ کی رحمتیں ہوں میرے امام ہیں اے معبود! میں راضی ہوں کہ وہ میرے امام ؑ ہیں اب انہیں مجھ سے راضی فرمادے بے شک توہر چیز پرقادر ہے۔", "RArabic": "WA A’LIYYIBNE MOOSAA WA MOHAMMADIBNE A’LIYYIN WA A’LIYYIBNE MOHAMMADIN WAL HASANIBNE A’LIYYIN WAL HUJJATIBNIL HASANE SALAWAATULLAAHE A’LAYHIM A-IMMATAN ALLAAHUMMA INNEE RAZEETO BEHIM A-IMMATAN FARZENEE LAHUM INNAKA A’LAA KULLE SHAY-IN QADEERUN.", "ArabicText1": "وَعَلِیِّ بْنِ مُوْسٰی وَمُحَمَّدِبْنِ عَلِیٍّ وَّعَلِیِّ بْنِ مُحَمَّدٍ وَّالْحَسَنِ بْنِ عَلِیٍّ وَّالْحُجَّۃِ بْنِ الْحَسَنِ الْعَسْکَرِیِّ صَلَوَاتُ اللہِ عَلَیْھِمْ اَئِمَّۃً۔ اَللّٰھُمَّ اِنِّیْ رَضِیْتُ بِھِمْ اَئِمَّۃً فَارْضَنِیْ لَھُمْ اِنَّکَ عَلٰی کُلِّ شَىْٓءٍ قَدِیْرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": nul