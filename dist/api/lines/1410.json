[{"Id": 1000135, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Recite this dua daily because it is a declaration of our faith, what we believe and whom we follow. It brings countless blessings for us in this world; and on the day of judgement will serve us as Visa for Jannat.", "GujaratiDescription": null, "RUrduDescription": "Is dua ko rozana padhe kyun keh yeh imaan ki qawahi hai, keh kya ham maante aur kiski ham pehrawi karte hai. Yeh dua is duniya mein be-panah neymate’n laati hai, aur Roz-e-Qayaamat yeh Jannat ke parwaane ke taur par kaam aayegi.", "UrduDescription": "شیخ طوسیؒ نے محمد ابن سلیمان دیلمی سے روایت کی ہے کہ میں نے امام جعفر صادق ؑکی خدمت میں عرض کیا: بعض شیعہ بھائیوں کا کہنا ہے کہ ایمان کی دو قسمیں ہیں:یعنی ایک محکم و ثابت اور دوسرا عارضی و امانتی جو زائل ہوسکتا ہے۔ اب آپ مجھے کوئی ایسی دعا تعلیم فرمائیں کہ جس کے پڑھنے سے میرا ایمان قائم و ثابت رہے اور زائل نہ ہونے پائے۔ تو آپ ؑنے فرمایا : ہر واجب نماز کے بعد یہ دعا پڑھا کرو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": n