[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012634, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mujh par apne rizq ki lagaataar baarish barsa, mujh par apne fazl o karam ka baarish barsa, mujh par apni ataa ki pe-dar-pe baarish barsa, meri zaroorato’n ke alaawa izaafi ne’mato’n ka saaya kar de, apni sakhaawat se mujhe apna hi mohtaaj rakh, mujhe us shakhs se be-neyaaz rakh jo Tujh se maangta hai, apne fazl ko meri naadaari (ghurbat) ki dawa bana, apni ataa se meri haajat ko be-daar farma, meri tang-dasti ko apni bohot ataawo’n ka aur meri be-nawaai o faqeeri ko apni bakhshish ka sadaqa de.", "Urdu": "اے معبود! مجھ پر اپنے رزق کی لگاتار بارش برسا مجھ پر اپنے فضل و کرم کامینہ برسا مجھ پر اپنی عطا کی پے در پے بارش برسا میری ضرورتوں کے علاوہ اضافی نعمتوں کا سایہ کردے اپنی سخاوت سے مجھے اپنا ہی محتاج رکھ مجھے اس شخص سے بے نیاز رکھ جو تجھ سے مانگتا ہے اپنے فضل کو میری ناداری کی دوا بنا اپنی عطا سے میری حاجت کو بیدار فرما میری تنگ دستی کو اپنی بہت عطاؤں کا اور میری بے نوائی وفقیری کو اپنی بخشش کا صدقہ دے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اَرْسِلْ عَلَىَّ سِجَالَ رِزْقِكَ مِدْرَارًا وَّاَمْطِرْ عَلَىَّ سَحَاۗئِبَ اِفْضَالِكَ غِزَارًا وَّاَدِمْ غَيْثَ نَيْلِكَ اِلَىَّ سِجَالًا وَاَسْبِلْ مَزِيْدَ نِعَمِكَ عَلٰى خُلَّتِىْ اِسْبَالًا وَاَفْقِرْنِىْ بِجُوْدِكَ اِلَيْكَ وَاَغْنِنِىْ عَمَّن يَّطْلُبُ مَالَدَيْكَ وَدَاوِدَاۗءَ فَقْرِىْ بِدَوَاۗءِ فَضْلِكَ وَانْعَشْ صَرْعَةَ عَيْلَتِىْ بِطَوْلِكَ وَتَصَدَّقَ عَلٰى اِقْلَالِىْ بِكَثْرَةِ عَطَاۗئِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012635, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Mere liye rizq ki raah aasaan kar de, mere liye uski bunyaade’n mazboot bana de, apni rehmat se mere liye faraawaani ke chashme jaari kar de, apni maher-baani se meri zindagi mein khooshiyo’n ki nehre’n rawa’n kar de, mere faqr ki zameen ko banjar kar de, meri bad-haali ke qahet ko faraawaani mein badal de meri rozi mein jo rukaawat hai woh dur kar de, mujh se tangi ke nishaan alag kar de aur mujhe wus’at'e rizq ka hadaf bana.", "Urdu": "اور میری بے نوائی وفقیری کو اپنی بخشش کا صدقہ دے اے پروردگار! میرے لئے رزق کی راہ آسان کر دے میرے لئے اس کی بنیادیں مضبوط بنا دے اپنی زحمت سے میرے لئےفراوانی کے چشمے جاری کردے اپنی مہربانی سے میری زندگی میں خوشیوں کی نہریں رواں کردے میرے فقر کی زمین کو بنجرکردے میری بدحالی کے قحط کو فراوانی میں بدل دے میری روزی میں جو رکاوٹیں ہیں وہ دور کردے مجھ سے تنگی کے نشان الگ کر دے اور مجھے وسعت ِرزق کا ہدف بنا۔", "RArabic": null, "ArabicText1": "وَعَلَى اخْتِلَالِىْ بِكَرِيْمِ حِبَاۗئِكَ وَسَهِّلْ رَبِّ سَبِيْلَ الرِّزْقِ اِلَىَّ وَ ثَبِّتْ قَوَاعِدَهٗ لَدَىَّ وَبَجِّسْ لِىْ عُيُوْنَ سَعَتِهٖ بِرَحْمَتِكَ وَفَجِّرْ اَنْهَارَ رَغَدِ الْعَيْشِ قِبَلِىْ بِرَاْفَتِكَ وَاَجْدِبْ اَرْضَ فَقْرِىْ وَاَخْصِبْ جَدْبَ ضُرِّىْ وَاصْرِفْ عَنِّىْ فِى الرِّزْقَ الْعَوَاۗئِقَ وَاقْطَعْ عَنِّىْ مِنَ الضَّيْقِ الْعَلَائِقَ وَارْمِنِىْ مِنْ سَعَةِ الرِّزْقِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012636, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Rozi ki bochhaar kar de, meri zindagi ko ziyadah se ziyadah pur musarrat (khush-haal) bana aur ay Ma’bood! mujh ko aasaaish ka jaama pehna aur khooshi ki chaadar udha de, pas ay Parwardigaar! Mai muntazir hu keh tangi dur ho aur mujhe Teri ne’mate’n naseeb ho, taakhir (intezaar) khatm ho aur Teri ataa mil jaaye, rozi ki tangi dur ho aur Tu fazl se nawaaz de, mera rishta Tere karam se judey aur aasaani naseeb ho.", "Urdu": "اے معبود! روزی کی بوچھار کردے میری زندگی کو زیادہ سے زیادہ پُر مسرت بنا اور اے معبود! مجھ کو آسائش کا جامہ پہنا اور خوشی کی چادر اوڑھا دے پس اے پروردگار! میں منتظر ہوں کہ تنگی دور ہو اور مجھے تیری نعمتیں نصیب ہوں تاخیر ختم ہو اور تیری عطا مل جائے روزی کی تنگی دور ہو اور تو فضل سے نواز دے میرا رشتہ تیرے کرم سے جڑے اور آسانی نصیب ہو اور برسا دے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ بِاَخْصَبِ سِهَامِهٖ وَاحْبُنِىْ مِن رَّغَدِ الْعَيْشِ بِاَكْثَرِ دَوَامِهٖ وَاكْسُنِى۔ اَللّٰهُمَّ سَرَابِيْلَ السَّعَةِ وَجَلَابِيْبَ الدَّعَةِ فَاِنِّىْ يَا رَبِّ مُنْتَظِرٌ لْاِِنْعَامِكَ بِحَذْفِ الْضَيْقِ وَلِتَطَوُّلِكَ بِقَطْعِ التَّعْوِيْقِ، وَلِتَفَضُّلِكَ بِاِزَالَةِ التَّقْتِيْرِ وَلِوُصُوْلِ حَبْلِىْ بِكَرَمِكَ بِالتَّيْسِيْرِ وَاَمْطِرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012637, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Aur barsa de ay Ma’bood! rozi ko aasmaan se lagaataar baarish, mujhe ne’mato’n se ziyadah hissa de, makhlooq se be-neyaaz kar de, meri naadaari (ghurbat) ke galey par teer maar de aur meri tangi dur kar ke uska bojh tez-tar baar-kasho’n (bojh uthaane waalo’n) par daal de, meri usrat o tangi ki gardan par naaboodi ki talwaar chala de, ay Parwardigaar! Mujhe apni wasee ne’mato’n ka tohfa ataa kar aur maal mein izaafe se meri madad kar mujhe tang-dasti ki aziyyat se mehfooz farma aur qahet ki takleef mujh se dur rakh.", "Urdu": "اور برسا دے اے معبود! روزی کے آسمان سے لگاتار بارش مجھے نعمتوں سے زیادہ حصہ دے مخلوق سے بے نیاز کردے میری ناداری کے گلے پر تیر مار دے اور میری تنگی دور کرکے اس کا بوجھ تیز تر بار کشوں پر لاد دے میری عسر ت و تنگی کی گردن پر نابودی کی تلوار چلا دے اے پروردگار! مجھے اپنی وسیع نعمتوں کا تحفہ عطا کر اور مال میں اضافے سے میری مدد کرمجھے تنگ دستی کی اذیت سے محفوظ فرما اور قحط کی تکلیف مجھ سے دور رکھ۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ عَلَىَّ سَمَاۗءَ رِزْقِكَ بِسِجَالِ الدِّيَمِ وَاَغْنِنِىْ عَنْ خَلْقِكَ بِعَوَاۗئِدِ النِّعَمِ وَارْمِ مَقَاتِلَ الْاِقْتَارِ مِنِّىْ وَاحْمِلْ كَشْفَ الضُّرِّ عَنِّىْ عَلٰى مَطَايَا الْاِعْجَالِ وَاضْرِبْ عَنِّى الضِّيْقَ بِسَيْفِ الْاِسْتِيْصَالِ وَاَتْحِفْنِىْ رَبِّ مِنْكَ بِسَعَةِ الْاِفْضَالِ وَامْدُدْنِىْ بِنُمُوِّ الْاَمْوَالِ وَاحْرُسْنِىْ مِنْ ضِيْقِ الْاِقْلَالِ وَاقْبِضْ عَنِّىْ سُوْۗءَ الْجَدْبِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012638, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Mere liye ne’mato’n ki bisaat (mat) bichha de aur mujhe apni rozi ke khush-gawaar paani se seraab kar, mere liye apni umoomi ataa ke darwaaze khol de, mujhe jahan se daulat milne ki ummeed na ho wahan se inaayat farma aur uske zariye mujhe tangi se nikaal, subh ke waqt meri madad farma aur khush-haali ka maalik bana de, be-shak Tu bohot badi bakhshish'e aam, fazl o karam, gira’n qadr ehsaan ka maalik aur bohot dene waala sakhi hai.", "Urdu": "میرے لئے نعمتوں کی بساط بچھا دے اور مجھے اپنی روزی کے خوش گوار پانی سے سیراب کر میرے لئے اپنی عمومی عطا کے دروازے کھول دے مجھے غیر متوقع دولت عنایت فرما اور اس کے ذریعے مجھے تنگی سے نکال صبح کے وقت میری مدد فرما اور خوش حالی کا مالک بناد ےبے شک تو بہت بڑی بخشش عام فضل وکرم، گراں قدر احسان کا مالک اور بہت دینے والا سخی ہے۔", "RArabic": null, "ArabicText1": "وَابْسُطْ لِىْ بِسَاطَ الْخِصْبِ وَاسْقِنِىْ مِن مَّاۗءِ رِزْقِكَ غَدَقًا وَانْهَجْ لِىْ مِنْ عَمِيْمِ بَذْلِكَ طُرُقًا وَفَاجِئْنِىْ بِالثَّرْوَةِ وَالْمَالِ وَانْعَشْنِىْ بِهٖ مِنْ الْاِقْلَالِ وَصَبِّحْنِىْ بِالْاِسْتِظْهَارِ وَمَسِّنِىْ بِالتَّمَكُّنِ مِنَ الْيَسَارِ اِنَّكَ ذُو الطَّوْلِ الْعَظِيْمِ وَالْفَضْلِ الْعَمِيْمِ وَالْمَنِّ الْجَسِيْمِ وَاَنْتَ الْجَوَادُ الْكَرِيْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "A