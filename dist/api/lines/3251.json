[{"Id": 1014302, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Sayed Ibne Tawoos has recorded this ziyarat in this way…", "GujaratiDescription": null, "RUrduDescription": "Yeh ziyarat Sayed Ibne Tawoos ne yu’n naql ki hai…", "UrduDescription": "یہ زیارت سید ابن طاؤس ؒنےیوں نقل کی ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014303, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon the fresh truth and the knowledgeable whose knowledge never expires. Peace be upon the reviver of the believers and the terminator of the unbelievers. Peace be upon the restorer of all nations and the combiner of all creeds. Peace be upon the successor of the ancestors and the owner of honor.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho us par jo Imam bar-haq aur mujaddid (sahih deen pesh karne waale)) hai, zindah aur aisa aalim hai jis ka ilm khatm nahi hota. Salaam ho momino ko zindah karne waale aur kaafiro’n ko na’bood karne waale par. Salaam ho qaumo ke rehbar aur tamaam kalemaate ilaahi ke aalim par. Salaam ho tamaam guzre huwe par keh jo ja-nasheen aur buzurgiyo’n ke maalik par.", "Urdu": "سلام ہو اس پر جو امام بر حق اور مجددہے زندہ اورایسا عالم ہے جس کا علم ختم نہیں ہوتا سلام ہو مؤمنوں کو زندہ کرنے والے اور کافروں کو نابود کرنے والے پر سلام ہو قوموں کے رہبر اور تمام کلمات الہٰی کے عالم پر سلام ہو تمام گذشتگان کے جانشین اور بزرگیوں کے مالک پر۔", "RArabic": "AS-SALAAMO A’LAL HAQQIL JADEEDE WAL-A’ALEMIL LAZEE I’LMOHU LAA YABEEDO AS-SALAAMO A’LAA MOHYIL MOMENEENA WA MOBERIL KAAFEREENA AS-SALAAMO A’LAL MAHDIYYIL OMAME WA JAAME-I’L KALEME AS-SALAAMO A’LAA KHA-LAFIS SALAFE WA SAAHEBISH SHA-RAFE.", "ArabicText1": "اَلسَّلَامُ عَلَی الْحَقِّ الْجَدِیْدِ وَالْعَالِمِ الَّذِیْ عِلْمُهٗ لَا یَبِیْدُ۔ اَلسَّلَامُ عَلٰی مُحْیِی الْمُؤْمِنِیْنَ وَمُبِیْرِ الْكَافِرِیْنَ۔ اَلسَّلَامُ عَلٰی مَهْدِیِّ الْاُمَمِ وَجَامِعِ الْكَلِمِ۔ اَلسَّلَامُ عَلٰی خَلَفِ السَّلَفِ وَصَاحِبِ الشَّرَفِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014304, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon the argument of the Worshipped (Lord) and the Word of the Praised (Lord). Peace be upon the consolidator of the intimate servants (of God) and the humiliator of the enemies. Peace be upon the inheritor of the Prophets and the seal of the (Prophets’) successors. Peace be upon the Rising (Imam), the awaited, and the famed establisher of justice.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho Khuda ki hujjat aur taarif kiye huwe kalme par. Salaam ho dosto’n ki izzat badha ne waale aur dushmano ko pastt karne waale par. Salaam ho us par jo nabiyyo’n ka waaris aur ausiya mein aakhri hai. Salaam ho us Qaaem (a.t.f.s) par jis ka intezaar hai aur jo adl mein mashhoor hai.", "Urdu": "سلام ہو خدا کی حجت اور تعریف کیے ہوئے کلمے پر سلام ہو دوستوں کی عزّت بڑھانے والےاور دشمنوں کو پست کرنے والے پر سلام ہو اس پر جو نبیوں کا وارث اور او صیاء میں آخر ہے سلام ہو اس قائمؑ پرجس کا انتظار (ہورہا)ہے اور جو عدل میں مشہور ہے۔", "RArabic": "AS-SALAAMO A’LAA HUJJATIL MA’BOODE WA KALEMATIL MAHMOODE AS-SALAAMO A’LAA MO-I’ZZIL AWLEYAAA-E WA MOZILLIL A-A’DAAA-E AS-SALAAMO A’LAA WAARESIL AMBEYAAA-E WA KHAATEMIL AWSEYAAA-E AS-SALAAMO A’LAL QAAA-EMIL MUNTAZARE WAL-A’DLIL MUSH-TAHARE.", "ArabicText1": "اَلسَّلَامُ عَلٰی حُجَّۃِ الْمَعْبُوْدِ وَكَلِمَۃِ الْمَحْمُوْدِ۔ اَلسَّلَامُ عَلٰی مُعِزِّ الْاَوْلِیَآءِ وَمُذِلِّ الْاَعْدَآءِ۔ اَلسَّلَامُ عَلٰی وَارِثِ الْاَنْبِیَآءِ وَخَاتِمِ الْاَوْصِیَآءِ۔ اَلسَّلَامُ عَلَی الْقَآئِمِ الْمُنْتَظَرِ وَالْعَدْلِ الْمُشْتَهَرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014305, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon the unsheathed sword, the brilliant moon, and the dazzling light. Peace be upon the sun of darkness and the absolutely full moon. Peace be upon the springtime of humanity and the bloom of days. Peace be upon the holder of sharp sword and the splitter of heads. Peace be upon the long-established faith and the scripture inscribed.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho us par jo talwaar kheche huwe hai, chamakta huwa chaand aur roshan-tar noor hai. Salaam ho us par jo taarikiyo’n mein suraj aur chaudhwi ka chaand hai. Salaam ho us par jo logo’n mein nishaane bahaar aur zamaane ki taazgi hai. Salaam ho us par jo haatho’n mein shamsheer liye huwe aur mutakabbiro’n ki khopdiya’n tod ne waala hai.", "Urdu": "سلام ہو اس پر جو تلوار سونتے ہوئے ہے چمکتا ہوا چاند اور روشن تر نور ہے سلام ہو اس پر جو تاریکیوں میں سورج اور چودھویں کا چاند ہے سلام ہو اس پر جو لوگوں میں نشان ِبہار اور زمانے کی تازگی ہے سلام ہو اس پر جو شمشیر ہاتھ لئے ہوئے ہے اور متکبروں کی کھوپڑیاں توڑنے والا ہے۔", "RArabic": "AS-SALAAMO A’LAS SAYFISH SHAA-HERE WAL-QAMARIZ ZAAHERE WA NOORIL BAAHERE AS-SALAAMO A’LAA SHAMSIZ ZALAAME WA BAD-RIT TAMAAME AS-SALAAMO A’LAA RABEE-I’L ANAAME WA NAZRATIL AYYAAME AS-SALAAMO A’LAA SAAHEBIS SAMSAAME WA FALLAAQIL HAA-ME.", "ArabicText1": "اَلسَّلَامُ عَلَی السَّیْفِ الشَّاهِرِ وَالْقَمَرِ الزَّاهِرِ وَالنُّوْرِ الْبَاهِرِ۔ اَلسَّلَامُ عَلٰی شَمْسِ الظَّلَامِ وَبَدْرِ التَّمَامِ۔ اَلسَّلَامُ عَلٰی رَبِیْعِ الْاَنَامِ وَنَضْرَۃِ الْاَیَّامِ۔ اَلسَّلَامُ عَلٰی صَاحِبِ الصَّمْصَامِ وَفَلَّاقِ الْهَامِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014306, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon the left by Allah in His lands and the argument of Him against His servants to whom the inheritances of the Prophets end and with whom the traditions of the elite ones are kept. Peace be upon the one entrusted with the secret and the one who shall undertake the mission.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho us par jo muqarrar shudah deen aur qalam’e qudrat ki likkhi huwi kitaab hai. Salaam ho jo Khuda ke shahero’n mein uska aakhri numaainda aur kogo’n par uski hujjat hai, nabiyyo’n ki wiraasate’n us tak pohonchi aur woh bar-guzido’n ke aasaar o naqoosh ka haamil hai woh raaze ilaahi ka amaanat-daar aur saahebe hukumat hai.", "Urdu": "سلام ہو اس پر جو مقرر شدہ دین اور قلم ِقدرت کی لکھی ہوئی کتاب ہے سلام ہو جو خدا کے شہروں میں اس کا آخری نمائندہ اور لوگوں پر اس کی حجت ہے نبیوں کی وراثتیں اس تک پہنچیں اور وہ برگزیدوں کے آثار و نقوش کا حامل ہے وہ رازِ الہٰی کا امانت دار اور صاحب ِ حکومت ہے۔", "RArabic": "AS-SALAAMO A’LAD DEENIL MAASOORE WAL-KETAABIL MASTOORE AS-SALAAMO A’LAA BAQIYYATIL LAAHE FEE BELAADEHI WA HUJJATEHI A’LAA E’BAADEHIL MUNTAHAA ELAYHE MAWAAREESUL AMBEYAAA-E WA LADAYHE MAWJOODUN AASAARUL ASFEYAAA-IL MOTAMANE A’LAS SIRRE WAL-WALIYYE LIL-AMRE.", "ArabicText1": "اَلسَّلَامُ عَلَی الدِّیْنِ الْمَاْثُوْرِ وَالْكِتَابِ الْمَسْطُوْرِ۔ اَلسَّلَامُ عَلٰی بَقِیَّۃِ اللہِ فِیْ بِلَادِهٖ وَحُجَّتِهٖ عَلٰی عِبَادِهِ الْمُنْتَهٰی اِلَیْهِ مَوَارِیْثُ الْاَنْبِیَآءِ وَلَدَیْهِ مَوْجُوْدٌ اٰثَارُ الْاَصْفِیَآءِ الْمُؤْتَمَنِ عَلَی السِّرِّ وَالْوَلِیِّ لِلْاَمْرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014307, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon al-Mahdi (the rightly guided) through whom Allah the Almighty and All-majestic promised the nations to combine all decrees, to bring together all scattered matters, to fill the earth with fairness and justice, to make possible for him (to win over the all), and to fulfill His promise to the believers.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho us Imam Mahdi (a.t.f.s) par jin ka waada Khuda ne qaumo se kiya keh woh unke darmiyaan wahedat’e kalma paiyda (ek kalme par jama) karenge, be-ittefaaqi ko dur karenge aur zameen ko adl o insaaf se pur kar denge woh unhe muqtadar banayega aur momino se kiya huwa waada pura karega.", "Urdu": "سلام ہو اس امام مہدیؑ پر جن کا وعدہ خدا نے قوموں سے کیا کہ وہ ان کے درمیان وحدت کلمہ (اتحاد) پیدا کریں گے بے اتفاقی کو دور کریں گے اور زمین کو عدل و انصاف سے پُر کر دیں گے وہ انہیں بااقتدار بنائے گا اور مومنوں سے کیا ہوا وعدہ پورا کرے گا۔", "RArabic": "AS-SALAAMO A’LAL MAHDIYYIL LAZEE WA-A’DAL LAAHO A’ZZA WA JALLA BEHIL OMAMA AYN YAJ-MA-A’ BIL KALEMA WA YALUMMA BEHISH SHA’-SA WA YAM-LA-O BEHIL ARZA QISTAWN WA A’DLAWN WA YOMAKKENA LAHU WA YUNJEZA BEHI WA’DAL MOMENEENA.", "ArabicText1": "اَلسَّلَامُ عَلَی الْمَهْدِیِّ الَّذِیْ وَعَدَ اللہُ عَزَّ وَجَلَّ بِهِ الْاُمَمَ اَنْ یَّجْمَعَ بِهِ الْكَلِمَ وَیَلُمَّ بِهِ الشَّعْثَ وَیَمْلَاَ بِهِ الْاَرْضَ قِسْطًا وَّعَدْلًا وَّیُمَكِّنَ لَهٗ وَیُنْجِزَ بِهٖ وَعْدَ الْمُؤْمِنِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014308, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I bear witness, O my master, that you and the Imams, your fathers, are my leaders and masters in this worldly life and on the day when the Witnesses will rise (to witness). I thus ask you, O my master, to ask Allah the All-blessed and All-exalted to set aright all my affairs, to grant me all my needs, to forgive my sins, and to lead me rightly in the affairs of my faith, worldly life, and the Next Life, as well as the affairs of my all believing brothers and sisters. Verily, He is All-forgiving, All-merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawahi deta hu ay mere Aaqa, keh be-shak aap aur woh Aimma (a.s) jo aap ke buzurgo’n mein se hai mere Imam aur haakim hai duniyaawi zindagi mein aur qayaamat ke din bhi. Sawaal karta hu aap se ay mere Aaqa yeh keh aap Khudaaye buzurg o bartar ke huzoor dua farmaaye keh meri haalat sudhar jaaye, meri haajat puri ho, mere gunah bakhsh diye jaaye, meri dastgiri ki jaaye deen mein, duniya mein aur aakherat mein, neez mere sabhi momin bahiyyo’n aur meri momina behno ki dastgiri (madad) bhi ho, be-shak woh bakhsh ne waala maher-baan hai.", "Urdu": "میں گواہی دیتا ہوں اے میرے آقا کہ بے شک آپ اور وہ ائمہؑ جو آپؑ کے بزرگوں میں سے ہیں میرے امام اور حاکم ہیں دنیاوی زندگی میں اور قیامت کے دن بھی سوال کرتا ہوں آپؑ سے اے میرے آقا یہ کہ آپ خدائے بزرگ و برترکے حضور دعا فرمائیں کہ میری حالت سدھر جائے میری حاجات پوری ہوں میرے گناہ بخش دیے جائیں میری مدد کی جائے دین میں، دنیا میں اور آخرت میں مزید میرے سبھی مومن بھائیوں اور میری مومنہ بہنوں کی مدد بھی ہو بے شک وہ بخشنے والا مہربان ہے۔", "RArabic": "ASH-HADO YAA MAWLAAYA ANNAKA WAL-A-IMMATA MIN AABAAA-EKA A-IMMATEE WA MAWAALIYYA FIL HAYAATID DUNYAA WA YAWMA YAQOOMUL ASH-HAADO AS-ALOKA YAA MAWLAAYA AN TAS-A-LAL LAAHA TABAARAKA WA TA-A’ALAA FEE SALAAHE SHAANEE WA QAZAAA-E HAWAAA-JEE WA GHUFRAANE ZONOOBEE WAL-AKHZE BE-YADEE FEE DEENEE WA DUNYAAYA WA AAKHERATEE LEE WA LE-IKHWAANEE WA AKHAWAATIL MOMENEENA WAL-MOMENAATE KAAFFATAN INNAHU GHAFOORUR RAAHEEM.", "ArabicText1": "اَشْهَدُ یَا مَوْلَایَ اَنَّكَ وَالْاَئِمَّۃَ مِنْ اٰبَآئِكَ اَئِمَّتِیْ وَمَوَالِيَّ فِی الْحَیٰوۃِ الدُّنْیَا وَیَوْمَ یَقُوْمُ الْاَشْهَادُ اَسْئَلُكَ یَا مَوْلَایَ اَنْ تَسْئَلَ اللہَ تَبَارَكَ وَتَعَالٰی فِیْ صَلَاحِ شَاْنِیْ وَقَضَآءِ حَوَآئِجِیْ وَغُفْرَانِ ذُنُوْبِیْ وَالْاَخْذِ بِیَدِیْ فِیْ دِیْنِیْ وَدُنْیَایَ وَاٰخِرَتِیْ لِیْ وَلِاِخْوَانِیْ وَاَخَوَاتِیَ الْمُؤْمِنِیْنَ وَالْمُؤْمِنَاتِ كَآفَّۃً اِنَّهٗ غَفُوْرٌ رَّحِیْمٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": nu