[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000249, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to the Lord of Honour, and Sublime Authority; Glory be to the Lord of Majesty and Exalted Greatness; Glory be to the Lord of eternal Pride. Glory be to He Who is Splendour and Beauty; Glory be to He Who is Light and Dignity; Glory be to He Who makes out the footprints of the ant on the stone; Glory be to He Who knows (the exact time and place) the bird dips down through the air; Glory be to He Who is like this and no one (other than Him) is like this. O Allah, send blessings on Muhammad and on the progeny of Muhammad.", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai woh zaat jo aala wa buland izzat ka Maalik hai, paak hai woh zaat jo aala wa buland jalaalat ka maalik hai, paak hai woh zaat jo qadeem o azeem saltanat ka maalik hai, paak hai woh zaat jisne husn o jamaal ka libaas pehna hai, paak hai woh zaat jisne noor aur waqaar ki chaadar odhi hai, paak hai woh jo chatiyal patthar par chuti (ant) ka naqsh'e pa (pair ke nishaan) dekh leta hai, paak hai woh jo hawa mein parinde ke nishan dekh leta hai, paak hai woh jo aisa hai aur koi dusra aisa nahi hai.", "Urdu": "پاک ہے وہ ذات جو اعلیٰ و بلند عزّت کی مالک ہے پاک ہے وہ ذات جو اعلیٰ و ارفع جلالت کی مالک ہے پاک ہے وہ ذات جو قدیم و عظیم سلطنت کی مالک ہے پاک ہے وہ جس نے حُسن و جمال کا لباس پہنا پاک ہے وہ ذات جس نے نور اور وقار کی چادر اوڑھی ہوئی ہے پاک ہے وہ جو چٹیل پتھر پر چیونٹی کا نقش پا دیکھ لیتی ہے پاک ہے وہ جو ہوا میں پرندوں کے نشان دیکھ لیتاہے پاک ہے وہ جو ایسا ہے اور کوئی دوسرا ایسا نہیں ہے۔", "RArabic": "SUBHAANA ZIL I’ZZISH SHAAMEKHIL MONEEFE SUBHAANA ZIL JALAALIL BAA-ZEKHIL A’ZEEME SUBHAANA ZIL MULKIL FAAKHERIL QADEEME SUBHAANA MAN LABESAL BAHJATE WAL JAMAALE SUBHAANA MAN TARADDAA BIN-NOORE WAL WAQAARE SUBHAANA MAN YARAA ASARAN NAMLE FIS SAFAA SUBHAANA MAN YARAA WAQA-A’T TAYRE FIL HAWAAA-E SUBHAANA MAN HOWA HAAKAZAA LAA HAAKAZAA GHAYROHU.", "ArabicText1": "سُبْحَانَ ذِي الْعِزِّ الشَّامِخِ الْمُنِيْفِ۔ سُبْحَانَ ذِي الْجَلَالِ الْبَاذِخِ الْعَظِيْمِ۔ سُبْحَانَ ذِي الْمُلْكِ الْفَاخِرِ الْقَدِيْمِ۔ سُبْحَانَ مَنْ لَّبِسَ الْبَهْجَةَ وَالْجَمَالَ۔ سُبْحَانَ مَنْ تَرَدّٰى بِالنُّوْرِ وَالْوَقَارِ۔ سُبْحَانَ مَنْ يَّرٰى اَثَرَ النَّمْلِ فِي الصَّفَا۔ سُبْحَانَ مَنْ يَّرٰى وَقْعَ الطَّيْرِ فِي الْهَوَآءِ۔ سُبْحَانَ مَنْ هُوَ هٰكَذَا لَا هٰكَذَا غَيْرُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "Ara