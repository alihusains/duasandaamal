[{"Id": 1014808, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "For those who suffer from nyctalopia (i.e reduction or loss of vision in dim light), they are recommended to write down the Aayat of <Noor (24:35)> several times (on a sheet of paper) in a cup, wash it, put it in a flask, and use it as eye ointment.", "GujaratiDescription": null, "RUrduDescription": "Aur yeh nazr ki kamzori ke liye bhi faiyde-mand hai neez nazr ki kamzori aur tondhi ko dur karne ke liye <Noor (24:35)> aayat mutarad baar (several times) kisi bartan par likh kar dho’e aur us paani ko kisi sheeshi mein daal kar phir usko salaaee (stick) se aankho’n mein lagaata rahe.", "UrduDescription": "یہ نظر کی کمزوری کے لئے بھی فائدہ مند ہے نیز نظر کی کمزوری اور رتوندھی کو دور کرنے کے لئے <نور: ۳۵> آیت متعدد بار کسی برتن پر لکھ کر دھوئے اور اس پانی کو کسی شیشی میں ڈال کر پھر اس کو سلائی سے آنکھوں میں لگاتا رہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": nu