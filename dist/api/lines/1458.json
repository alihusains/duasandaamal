SH-SHAHAADATE MIN ZEE RAHME RASOOLIL LAAHE AS-SALAAMO A'LAYKOMA AYYOHASH SHAHEEDANE FEE NUSRATE DEENIL LAAHE. AS-SALAAMO A'LAYKOMA AYYOHAL MAZLOOMANIL QATEELAANE BE ARZE KARBALAA AS-SALAAMO A'LAYKOMA AYYOHAL MAZLOOMAANE BE AYDIL ASHKEYAAE AS-SALAAMO A'LAYKOMA AYYOHAL MOKHALLAFAANE MIN MUSLIM IBNE AQEELIN ALQATEEL ASSALAMO A'LAYKOMA AYYOHAZ ZABEEHAANE MIN NASLE ISMAAE'ELA AS-SALAAMO A'LAYKOMA AYYOHAL HAYYAANIL MARZOOQAANE I'NDA RABBEKOMAL JALEELE.", "ArabicText1": "اَلسَّلَامُ عَلَیْكُمَا یَا قُرَّتَیْ عَیْنِ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكُمَا یَا فَلْذَتَیْ كَبِدِ ابْنِ عَمِّ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكُمَا یَا نَاصِرَیْ سِبْطِ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكُمَا اَیُّهَا السَّابِقَانِ فِی الشَّهَادَۃِ مِنْ ذِیْ رَحْمِ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكُمَا اَیُّهَا الشَّهِیْدَانِ فِیْ نُصْرَۃِ دِیْنِ اللہِ۔ اَلسَّلَامُ عَلَیْكُمَا اَیُّهَا الْمَظْلُوْمَانِ الْقَتِیْلَانِ بِاَرْضِ كَرْبَلَاءِ۔ اَلسَّلَامُ عَلَیْكُمَا اَیُّهَا الْمَظْلُوْمَانِ بِاَیْدِی الْاَشْقِیَآءِ۔ اَلسَّلَامُ عَلَیْكُمَا اَیُّهَا الْمُخَلَّفَانِ مِنْ مُسْلِمِ ابْنِ عَقِیْلٍ اَلْقَتِیْلِ۔ اَلسَّلَامُ عَلَیْكُمَا اَیُّهَا الذَّبِیْحَانِ مِنْ نَسْلِ اِسْمٰعِیْلَ۔ اَلسَّلَامُ عَلَیْكُمَا اَیُّهَا الْحَیَّانِ الْمَرْزُوْقَانِ عِنْدَ رَبِّكُمَا الْجَلِیْلِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign