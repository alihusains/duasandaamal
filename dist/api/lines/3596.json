[{"Id": 1015967, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "It is recommended to go to Masha’rul Haraam from Arafaat with a serene body and heart and seek repentance on the way. Upon reaching the red mound from the right one should say…", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh itminaan o sukoon ke saath Arafaat se Masharul Haraam ki jaanib rawaana ho. Isteghfaar karte rahe aur jaise hi daayi (left) jaanib se surkh tiley ke paas pohonche to is tarah se kahe…", "UrduDescription": "مستحب ہے کہ اطمینان و سکون کے ساتھ عرفات سے مشعر الحرام کی جانب روانہ ہو۔ استغفار کرتا رہے اور جیسے ہی دائیں جانب سے سُرخ ٹیلے کے پاس پہنچے تو کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015968, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! have mercy on me as I stand in Your audience in worship, enrich my devotions, maintain my firmness in faith, and accept my performance of the rituals.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Mere yahan wuqoof par rahem farma aur ise mere amal mein ziyaadati qaraar de, mere deen ko qabool kar aur meri ibaadato’n ko qabool kar le.", "Urdu": "خدایا! میرے یہاں وقوف پر رحم فرما اور اسے میرے عمل میں زیادتی قرار دے، میرے دین کو قبول کر اور میری عبادتوں کو قبول کرلے۔", "RArabic": "ALLAAHUMMAR HAM TAWAQQOFEE WA ZIDHO FEE A’MALEE WA SALLIM DEENEE WA TAQABBAL MANAASEKEE.", "ArabicText1": "اَللّٰہُمَّ ارْحَمْ تَوَقُّفِیْ وَزِدْہُ فِیْ عَمَلِیْ وَسَلِّمْ دِیْنِیْ وَتَقَبَّلْ مَنَاسِكِیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015969, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "Imam Sadiq (a) says: “Walk with moderation and do not hurt anyone. It is recommended to delay Maghrib and Isha prayers till one reaches Muzdalifah and one third night passes away. Perform both the prayers with single Azaan and Eqaamat and perform the Nawafils of Maghrib after Isha prayers. If there is some obstacle on the way before half night then he should not delay prayers and perform them on the way itself.”", "GujaratiDescription": null, "RUrduDescription": "Imam sadiq (a) ne farmaya keh “motawassit (darmiyaani) raftaar se chale aur chalne mein kisi ko aziyyat o takleef na pohonchaye. Mustahab hai keh Muszdalifah pohonchne tak Namaz-e-Maghrebain aur soone mein taakhir kare, chahe ek tihaayi (1/3) raat hi kyu’n na guzar jaaye aur dono namaze’n (Maghrib o Isha) ek (1) azaan aur do (2) eqaamat ke saath baja laaye aur Maghrib ke nawaafil ko Isha ke baad padhe aur agar aadi raat se pehle Muzdalifah pohonchne mein koi maane (rukaawat) ho to Namaz-e-Maghrebain mein itni taakhir na kare aur raaste mein (nisf shab se qabl (aadi raat se pehle)) hi padh le.", "UrduDescription": "امام جعفر صادقؑ نے فرمایا کہ متوسط رفتار سے چلے اور چلنے میں کسی کو اذیت و تکلیف نہ پہنچائے، مستحب ہے کہ مزدلفہ پہونچنے تک نماز معنہ بین اور سونے میں تاخیر کرے، چاہے ایک تہائی رات ہی کیوں نہ گزر جائے اور دونوں نمازیں (مغرب و عشاء) ایک ذان اور دو اقامت کے ساتھ بکا لائے اور مغرب کے نوافل کو عشاء کے بعد پڑھے اور اگر آدھی رات سے پہلے مزدلفہ پہنچنے میں کوئی مانع ہو تو نماز مغربین اتنی تاخیر نہ کرے اور استتہ میں (مصف شب سے قبل) ہی پڑھ لے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015970, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 3, "EnglishDescription": "It is recommended to enter in the middle of valley from the right. If a pilgrim is performing Hajj for a first time then it is recommended to get down at Masha’rul Haraama and spent the night in Allah’s worship as much as possible and recite this supplication…", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh daayi taraf se waadi (valley) ke darmiyaan tak pohonche aur agar pehli martaba Hajj kar rahe hai to masharul Haraam ki zameen par qadam rakhna bhi mustahab hai (yaani gaadi hi mein na baiytha rahe) jis qadr mumkin ho, raat ibaadat o ita’at-e-Ilaahi mein basar kare aur yeh dua padhe…", "UrduDescription": "مستحب ہے کہ دائیں طرف سے واری کے وسط تک پہونچے اور اگر پہلی مرتبہ حج کر رہا ہے تو مشعر الحرام کی زمین پر قدم رکھنا بھی مستحب ہے (یعنی گاڑی ہی میں نہ بیٹھا رہے) جس قدر ممکن ہو، رات عبادت و اطاعت الٰہی میں بسر کرے اور یہ دُعا پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015971, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Yeh meri tamaam ibaadate’n hai. Khudaaya! Mai Tujh se sawaal karta hu keh Tu un tamaam maqamaat mein mere liye khair ko jama kar de. Khudaaya! Mujhe us khair se maayoos na karna jis ke liye mai ne Tujh se sawaal kiya hai Tu usko mere dil mein jama kar de aur mujhe us manzil mein un tamaam cheezo’n ki maarefat kara de jin ki Tu ne apne auliya ko maarefat karaayi hai aur Tu mujhe tamaam buraaiyo’n se bacha le.", "Urdu": "خدایا! یہ میری تمام عبادتیں ہیں، خدایا! میں تجھ سے سوال کرتا ہوں کہ تو ان تمام مقامات میں میرے لئے خیر کو جمع کر دے، خدایا! مجھے اس خیر سے مایوس نہ کرنا جس کے لئے میں نے تجھ سے سوال کیا ہے، تو اس کو میرے دل میں جمع کر دے اور مجھے اس منزل میں ان تمام چیزوں کی معرفت کرا دے جن کی تونے اپنے اولیاء کو معرفت کرائی ہے اور تو مجھے تمام برائیوں سے بچا لے۔", "RArabic": "ALLAAHUMMA HAAZEHI JOMA-O’ ALLAAHUMMA INNEE ASALOKA AN TAJ-MA-A’ LEE FEEHAA JAWAAME-A’L KHAYRE ALLAAHUMMA LAA TOAYISNEE MENAL KHAYRIL LAZEE SA-ALTOKA AN TAJ-MA-A’HU LEE FEE QALBEE WA ATLOBO ELAYKA AN TO-A’RREFANEE MAA A’RRAFTA AWLEYAAA-AKA FEE MANZELEE HAAZAA AN TAQEYANEE JAWAAME-A’SH SHARRE.", "ArabicText1": "اَللّٰہُمَّ ہٰذِہٖ جُمَعُ۔ اَللّٰہُمَّ اِنِّیْ اَسْئَلُكَ اَنْ تَجْمَعَ لِیْ فِیْہَا جَوَامِعَ الْخَیْرِ۔ اَللّٰہُمَّ لَا تُؤْیِسْنِیْ مِنَ الْخَیْرِ الَّذِیْ سَاَلْتُكَ اَنْ تَجْمَعَہٗ لِیْ فِیْ قَلْبِیْ وَاَطْلُبُ اِلَیْكَ اَنْ تُعَرِّفَنِیْ مَا عَرَّفْتَ اَوْلِیَآئَكَ فِیْ مَنْزِلِیْ ہٰذَا اَنْ تَقِیَنِیْ جَوَامِعَ الشَّرِّ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015972, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 4, "EnglishDescription": "Imam Sadiq (a) says: It is recommended to praise and glorify Allah after Morning prayers in a clean condition. One should invoke about the bounties and excellence of Allah as much as possible. He should pray to Allah and recite this supplication…", "GujaratiDescription": null, "RUrduDescription": "Imam Jafar Sadiq (a) ne farmaya: “Mustahab hai keh Namaz-e-Subh ke baa dba-tahaarat hamd o sana-e-Ilaahi baja laaye aur jis qadar mumkin ho neymaat o inaayaat-e-Parwardigar ko yaad kare, Muhammad (s) wa Aale Muhammad (a) par salawaat bheje aur dua kare ya is tarah se padhe…", "UrduDescription": "امام جعفر صادقؑ نے فرمایا: مستحب ہے کہ نماز صبح کے بعد با طہارت حمد و ثنائے الٰہی بجا لائے اور جس قدر ممکن ہو نعمات و عنایات پروردگار کو یاد کرے، محمدؐ و آلِ محمدؑ پر صلوات بھیجے اور دُعائیں کرے اور یہ دُعا بھی پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015973, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Lord of the Holy Mash’ar, spare me the fire of Hell, increase my lawful sustenance and keep me away from the harm of the evil ones among the jinn and mankind. O Allah! You are the best to turn to, the best to beseech, and the best to be supplicated to. There is a reward for every visitor, and in this place, I aspire that my reward be that You forgive my slips, accept my plea, forgive my sins, and make piety my provision from this world.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Ay Masharul Haraam ke Parwardigaar! Meri gardan ko Jahannam se azaad kar de aur apne rizq'e halaal ko mere upar kushaadah kar de aur Jinn o Ins ke faasiqo’n ke sharr o fasaad ko mujh se dur kar de. Khudaaya! Tu behtar hai un cheezo’n se jin ko talab kiya jaaye aur maanga (talab) aur poonchhe jaane waali cheezo’n se behtar hai. Aur har aane waale ke liye ek atiya aur inaam hota hai lehaaza Tu mere yahan aane aur rehne ka inaam yeh qaraar de keh meri laghzisho’n ko maaf kar aur mere uzr ko qabool kar le aur meri khataawo’n se dar-guzar farma, gunaho’n ko bakhsh de aur duniya se taqwa mera tosha (saamaan) qaraar de.", "Urdu": "خدایا! اے مشعر الحرام کے پروردگار! میری گردن کو جہنم سے آزاد کر دے اور اپنے رزق حلال کو میرے اوپر کشادہ کر دے، اور جن و انس کے فاسقوں کے شر و فساد کو مجھ سے دور کر دے۔ خدایا! تو بہتر ہے ان چیزوں سے جن کو طلب کیا جائے اور مانگی اور پوچھے جانے والی چیزوں سے بہتر ہے، اور ہر آنے والے کے لئے ایک عطیہ اور انعام ہوتا ہے، لہٰذا تو میرے یہاں آنے اور رہنے کا انعام یہ قرار دے کہ میری لغزشوں کو معاف کر اور میرے عزر کو قبول کر لے اور میری خطاؤں سے درگزر فرما، گناہوں کو بخش دے اور دنیا سے تقویٰ میرا توشہ قرار دے۔", "RArabic": "ALLAAHUMMA RABBAL MASH-A’RIL HARAAME FUKKA RAQABATEE MENAN NAARE WA AW-SE’ A’LAYYA MIN RIZQEKAL HALAALE WAD-RAA A’NNEE SHARRA FASAQATIL JINNE WAL INSE ALLAAHUMMA ANTA KHAYRO MATLOOBIN ELAYHE WA KHAYRO MAD-O’WWIN WA KHAYRO MAS-OOLIN WA LEKULLE WAAFEDIN JAA-EZATAN FAJ-A’L JAA-EZATEE FEE MAWTENEE HAAZAA AN TOQEELANEE A’SRATEE WA TAQBALA MA’ZERATEE WA AN TOJAAWEZO A’N KHATEEE-ATEE SUMMAJ A’LIT TAQWAA MENAD DUNYAA ZAADEE.", "ArabicText1": "اَللّٰہُمَّ رَبَّ الْمَشْعَرِ الْحَرَامِ فُكَّ رَقَبَتِیْ مِنَ النَّارِ وَاَوْسِعْ عَلَیَّ مِنْ رِزْقِكَ الْحَلَالِ وَادْرَا عَنِّیْ شَرَّ فَسَقَۃِ الْجِنِّ وَالْاِنْسِ۔ اَللّٰہُمَّ اَنْتَ خَیْرُ مَطْلُوْبٍ اِلَیْہِ وَخَیْرُ مَدْعُوٍّ وَخَیْرُ مَسْؤُوْلٍ وَلِكُلِّ وَافِدٍ جَائِزَۃً فَاجْعَلْ جَائِزَتِیْ فِیْ مَوْطِنِیْ ہٰذَا اَنْ تُقِیْلَنِیْ عَثْرَتِیْ وَتَقْبَلَ مَعْذِرَتِیْ وَاَنْ تُجَاوِزَ عَنْ خَطِیْٓئَتِیْ ثُمَّ اجْعَلِ التَّقْوٰی مِنَ الدُّنْیَا زَادِیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015974, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 5, "EnglishDescription": "On should bring 70 pebbles to be thrown in Mina from Muzdalifah itself. It is recommended while coming towards Mina from Muzdalifah one should walk a distance of about hundred steps fast like a camel upon reaching the valley of Muhassar. Recitation of this supplication is recommended…", "GujaratiDescription": null, "RUrduDescription": "Rami Jamrah ke liye Muzdalifah se kankariya (chhote patthar) choonna mustahab hai jin ki tadaad sattar (70) hona chahiye. Jab Muzdalifah se Mina ki jaanib rawaana ho aur waadiye Mohassar pohonche to 100 qadam oont (camel) ki maanind tez-tez chale, aur agar sawaar hai to sawaari ko kuchh tez kar de aur kahe…", "UrduDescription": "رمی جمرہ کے لئے مزدلفہ سے کنکریاں چننا مستحب ہے، جن کی تعداد ۷۰ ہونا چاہیئے۔ جب مزدلفہ سے منٰی کی جانب روانہ ہو اور وادی محسّر پہونچے تو ۱۰۰ قدم اونٹ کی مانند تیز تیز چلئے اور اگر سوار ہے تو سواری کو کچھ تیز کر دے اور کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": nul