bicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000581, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, water us with rain, unfold upon us Thy mercy through Thy copious rain from the driven clouds, so that Thy goodly earth may grow on all horizons!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Ham ko apni baaraan'e rehmat (baarish) se seraab farma, aur apni rehmat ham par phaila de, apni aisi baarish ke zariye jo us baadalo’n ke zariye se ham par naazil ho.", "Urdu": "بارالہا! ابر باراں سے ہمیں سیراب فرما اور ان ابروں کے ذریعہ ہم پر دامن رحمت پھیلا جو مو سلادھار بارشوں کے ساتھ زمین کے سبزہ خوش رنگ کی روئیدگی کا سروسامان لئے ہوئے اطراف عالم میں روانہ کئے جاتے ہیں اور پھلوں کے پختہ ہونے سے اپنے بندوں پر احسان فرما اورشگوفوں کے کھلنے سے اپنے شہروں کو زندگی نو بخش۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اسْقِنَا الْغَيْثَ وَانْشُرْ عَلَيْنَا رَحْمَتَكَ بِغَيْثِكَ الْمُغْدِقِ مِنَ السَّحَابِ الْمُنْسَاقِ لِنَبَاتِ اَرْضِكَ الْمُوْنِقِ فِيْ جَمِيْعِ الْاٰفَاقِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001711, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Show kindness to Thy servants through the ripening of the fruit, revive Thy land through the blossoming of the flowers, and let Thy angels, the noble scribes, be witness to a beneficial watering from Thee, lasting in its abundance, plenty in its flow, heavy, quick, soon, through which Thou revivest what has vanished, ringest forth what is coming, and providest plentiful foods, through heaped up, wholesome, productive clouds, in reverberating layers, the rain’s downpour not without cease, the lightning’s flashes not without fruit!", "Gujarati": null, "RGujarati": null, "RUrdu": "Aisi rehmat naazil farma jo musalsal ho aur zameen se achche achche sabz (vegetation) ugaaye aur phalo’n ko paka ne se bando’n par ehsaan farma. Kaliyo’n ko khilaane se sahero’n ko nayi zindagi ataa kar. Apni izzat waale ba-khabar farishto’n ko aisi nafa phonchaane waali baarish par aamaada kar jiski kasrat hamesha ho aur rawaani sab taraf ho. Badi bundo’n (drops) waali tezi se aane waali aur jald barasne waali ho jisse Tu murda cheezo’n mein zindagi paiyda kar, guzri huwi bahaare waapas farma aur jo cheeze’n aane waali hai unhe zaahir kar de, zindagi guzaarne waali cheezo’n mein izaafa kar de, aisa abr o baadal chhaaye jo tahe ba teh (ek ke upar ek) ho, khush-khabari dene waala ghan-garaj (kadakte huwe) barasne waala uski baarish us tarah lagaataar na barse aur na uski bijlee dhoka dene waali hoke chamke, garazti rahe aur barse nahi.", "Urdu": "اوراپنے معزز وباوقار فرشتوں اورسفیروں کو ایسی نفع رساں بارش پر آمادہ کر جس کی فروانی دائم اورروانی ہمہ گیر ہو۔ اوربڑی بوندوں والی تیزی سے آنے والی اورجلد برسنے والی ہو۔ جس سے تو مردہ چیزوں میں زندگی دوڑا دے۔ گزری ہوئی بہاریں پلٹا دے اور جو چیزیں آنے والی ہیں انہیں نمودار کر دے اورسامان معیشت میں وسعت پید ا کر دے۔ ایسا ابر چھائے جو تہہ بہ تہہ، خوش آئند وخوش گوار زمین پر محیط اورگھن گرج والا ہو اوراس کی بارش لگاتار نہ برسے ( کہ کھیتوں اورمکانوں کو نقصان پہنچے ) اورنہ اس کی بجلی دھوکا دینے والی ہو ( کہ چمکے گرجے اوربرسے نہیں )۔", "RArabic": null, "ArabicText1": "وَامْنُنْ عَلٰى عِبَادِكَ بِايْنَاعِ الثَّمَرَةِ وَاَحْيِ بِلَادَكَ بِبُلُوْغِ الزَّهَرَةِ وَاَشْهِدْ مَلَاۗئِكَتَكَ الْكِرَامَ السَّفَرَةَ بِسَقْيٍ مِنْكَ نَافِعٍ دَاۗئِمٍ غُزْرُهُ، وَاسِعٍ دِرَرُهٗ وَابِلٍ سَرِيْعٍ عَاجِلٍ تُحْيِيْ بِهٖ مَا قَدْ مَاتَ وَتَرُدُّ بِهٖ مَا قَدْ فَاتَ وَتُخْرِجُ بِهٖ مَا هُوَاتٍ وَتُوَسِّعُ بِهٖ فِي الْاقْوَاتِ سَحَابًا مُتَرَاكِمًا هَنِيْئًا مَرِيْئًا طَبَقًا مُجَلْجَلًا غَيْرَ مُلِثٍّ وَدْقُهٗ وَلَا خُلَّبٍ بَرْقُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001712, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, give us water through rain, helping, productive, fertilizing, widespread, plentiful, abundant, bringing back the risen, restoring the broken! O God, give us water with a watering through which Thou wilt make the stone hills pour, fill the cisterns, flood the rivers, make the trees grow, bring down prices in all the lands, invigorate the beasts and the creatures, perfect for us the agreeable things of provision, make grow for us the fields, let flow for us the teats, and add for us strength to our strength!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Hame us baarish se seraab kar jo qahet (famine) ko dur karne waali yaani sukhi zameeno se sabze ugaane waali (dasht o saheraawo’n ko) jangal o baya-baano, shahero’n ko hara-bhara karne waali, badi phailaaw waali, la-mahedood gaheraaw waali jisse Tu murjaayi huwi ghaas ki rounak lauta de aur sukhe murjaaye huwe sabzo’n mein jaan paiyda kar de. Khudaaya! Hamein aisi baarish se seraab kar jisse Tu tilo’n aur pahadiyo’n par se paani ki dhaare’n baha de, kuwe’n chhalka de, nahere jaari kar de, darakhto’n ko sabz o shaadaab hara-bhara kar de, shahero’n mein cheezo’n ki qimato’n ko sasti kar de, chopaayo’n aur insaano mein nayi rooh phoonk de, paakeeza roozi ka sar o saamaan hamare liye mohayya kar de, kheto’n ko hara-bhara kar de, chopaayo’n ke thano ko dudh se bhar de, aur uske zariye se hamari quwwat o taaqat mein mazeed taaqat ka izaafa kar de.", "Urdu": "بارالہا! ہمیں اس بارش سے سیراب کر جو خشک سالی کو دور کرنے والی( زمین سے ) سبزہ اگانے والی دشت وصحرا کو سر سبز کرنے والی بڑے پھیلاو اوربڑھاؤ اوران تھاہ گہراؤ والی ہو جس سے تو مرجھائی ہوئی گھاس کی رونق پلٹا دے اورسوکھے سڑے سبزے میں جان پیدا کر دے۔ خدایا!ہمیں ایسی بارش سے سیراب کر جس سے ٹیلوں پر سے پانی کے دھارے بہا دے، کنویں چھلکا دے، نہریں جاری کر دے، درختوں کو ترو تازہ و شاداب کر دے، جو پاؤں اورانسانوں میں نئی روح پھونک دے، پاکیزہ روزی کا سروسامان ہمارے لئے مکمل کر دے، کھیتوں کو سر سبز وشاداب کر دے اورچوپایوں کے تھنوں کو دودھ سے بھر دے اور اس کے ذریعہ ہماری قوت وطاقت میں مزید قوت کا اضافہ کر دے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ اسْقِنَا غَيْثًا مُغِيْثًا مَرِيْعًا مُمْرِعًا عَرِيْضًا وَاسِعًا غَزِيْرًا تَرُدُّ بِهِ النَّهِيْض، وَتَجْبُرُ بِهِ الْمَهِيْضَ۔ اَللّٰهُمَّ اسْقِنَا سَقْيًا تُسِيْلُ مِنْهُ الظِّرَابَ وَتَمْلَاُ مِنْهُ الْجِبَابَ، وَتُفَجِّرُ بِهِ الْاَنْهَارَ وَتُنْبِتُ بِهِ الْاَشْجَارَ وَتُرْخِصُ بِهِ الْاسْعَارَ فِيْ جَمِيْعِ الْامْصَارِ وَتَنْعَشُ بِهِ الْبَهَاۗئِمَ وَالْخَلْقَ وَتُكْمِلُ لَنَا بِهٖ طَيِّبَاتِ الرِّزْقِ وَ تُنْبِتُ لَنَا بِهِ الزَّرْعَ وَتُدِرُّ بِهِ الضَّرْعَ وَتَزِيْدُنَا بِهٖ قُوَّةً اِلٰى قُوَّتِنَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001713, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, make not the cloud’s shadow over us a burning wind, allow not its coldness to be cutting, let not its pouring down upon us be a stoning, and make not its waters for us bitter! O God, bless Muhammad and his Household and provide us with the blessings of the heavens and the earth! Thou art powerful over everything!", "Gujarati": null, "RGujarati": null, "RUrdu": "Baare Ilaaha! Us abr (baadal) ke chhaah ne ko hamare liye julsa dene waala luka joka (taklif-deh) aur uski thandak ko nuqsaan phonchaane waali aur uske barasne ko azaab ka zariya aur uske paani ko hamare kaam-kaaj ke liye mushkil na bana. Baare Ilaaha! Rehmat naazil farma Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par aur hamein aasmaan aur zameen ki barkat o faaida pohoncha is liye keh Tu har cheez par qudrat rakhta hai.", "Urdu": "بارالہا!اس ابر کی سایہ افگنی کو ہمارے لئے جھلسا دینے والا لو کا جھونکا اس کی خنکی کو نحوست کا سرچشمہ اوراس کے برسنے کو عذاب کا پیش خیمہ اوراس کے پانی کو (ہمارے کام ودہن کے لئے )شور نہ قرار دینا۔بارالہا! رحمت نازل فرما محمد اوران کی آل پر اور ہمیں آسمان وزمین کی برکتوں سے بہرہ مند کر اس لئے کہ تو ہر چیز پر قدرت رکھتا ہے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ لَا تَجْعَلْ ظِلَّهٗ عَلَيْنَا سَمُوْمًا وَلَا تَجْعَلْ بَرْدَهٗ عَلَيْنَا حُسُوْمًا وَلَا تَجْعَلْ صَوْبَهٗ عَلَيْنَا رُجُوْمًا وَلَا تَجْعَلْ مَاۗءَهُ عَلَيْنَا اُجَاجًا۔ اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَارْزُقْنَا مِنْ بَرَكَاتِ السَّمَاوَاتِ وَالْاَرْضِ اِنَّكَ عَلٰى كُلِّ شَيْ‏ءٍ قَدِيْرٌ ۔", "ArabicGreenSign1": null, "ArabicRedSign1": 