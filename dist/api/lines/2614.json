[{"Id": 1016807, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Shaikh Nomaani narrates this supplication in his book Al Ghaybah from Yunus bin Zibyaan that Imam Sadiq (a) said: When the eve of Friday arrives, Allah sends an angel towards the Heaven of this world. That blowing the dawn, that angel sits on the Throne situating himself above the Bait ul Ma moor. Then he arranges pulpits of light for Prophet Mohammad (s), Ali (a), Imam Hasan (a) and Imam Husain (a), they ascend the pulpit, then the angles and the prophets and the believers gather around them and the doors of the Heaven opens wide. When the time of Zuhr arrives, Allah’s Messenger (s) says: O Lord, when will the time of the fulfillment of promises made by You in Quran come? And that promise is the following verse (24:55)…", "GujaratiDescription": null, "RUrduDescription": "Marhoom Shaikh Nomaani kitaab Al-Ghaibah mein Yoonus bin Zibyaan se aur unho ne Imam Sadiq (a) se naql kiya hai keh Hazrat ne farmaya; Jab bhi Shab-e-Juma aati hai Parwardigaar-e-Aalam ek farishte ko dunya ke aasmaan ki taraf bhejta jai aur tuloo-e-fajr hone ke baad woh farishta arsh par Baitul Maamoor ke upar baiyth-ta hai aur Hazrat Muhammad (s), Ali (a), Hasan (a) aur Husain (a) ke liye mimber nasb hota hai woh mimbar ke upar jaate hai aur momeneen, awliya, ambiya aur malaaeka unke gird jama hote hai, aasmaan ka darwaaza khul jaata hai aur zawwaal-e-aaftaab ke waqt Rasool-e-Khuda (s) Parwardigaar-e-Aalam se arz karte hai; Parwardigaar! Jiska Tu ne kitaab mein waada kiya hai uska waqt aa gaya hai?Aur woh waada aayat (24:55) hai…", "UrduDescription": "مرحوم شیخ نعمانی کتاب الغیبہ میں یونس بن ظبیان سے اس نے امام صادق سے نقل کیا ہے کہ آنحضرت نے فرمایا جب بھی شب جمعہ آجائے تو خداوند تعالیٰ ایک ملک کو دنیا کے آسمان کی طرف بھیجتاہے جس وقت طلوع فجر ہوجائے تو یہ ملک عرش پر بیت لمعمور کے اوپر بیٹھتاہے اور محمد علی(علیہ السلام ) حسن(علیہ السلام ) حسین(علیہ السلام ) کے لئے نور کے منبر نصب کرتاہے یہ منبر پر چلے جاتے ہیں ملائکہ انبیاء مومنین ان کے اردگرد جمع ہوجاتے ہیں آسمان کے دروازے کھولے جاتے ہیں اور سورج زوال ہوتے وقت رسول اللہ خدا سے کہتے ہیں اے پروردگار جو وعدہ آپ نے کتاب میں کیا تھا اس کا وقت پہنچاہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1005920, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 55, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah has promised to those of you who believe and do good that He will most certainly make them rulers in the earth as He made rulers those before them, and that He will most certainly establish for them their religion which He has chosen for them, and that He will most certainly, after their fear, give them security in exchange; they shall serve Me, not associating aught with Me; and whoever is ungrateful after this, these it is who are the transgressors.", "Gujarati": null, "RGujarati": null, "RUrdu": "Allah ne tum mein se sahebaan'e imaan o amal'e saaleh se waada kiya hai keh unhe ruye-zameen mein isi tarah apna khalifa banaayega jis tarah pehle waalo’n ko banaya hai aur unke liye is deen ko ghaalib banaayega jise unke liye pasandeedah qaraar diya hai aur unke khouf ko amn se tabdeel kar dega. Keh woh sab sirf Meri ibaadat karenge aur kisi tarah ka shirk na karenge aur uske baad bhi koi kaafir ho jaaye to dar-haqeeqat wohi log faasiq aur bad-kirdaar hai.", "Urdu": "اللہ نے تم میں سے صاحبانِ ایمان و عمل صالح سے وعدہ کیا ہے کہ انہیں روئے زمین میں اسی طرح اپنا خلیفہ بنائے گا جس طرح پہلے والوں کو بنایا ہے اور ان کے لئے اس دین کو غالب بنائے گا جسے ان کے لئے پسندیدہ قرار دیا ہے اور ان کے خوف کو امن سے تبدیل کر دے گا کہ وہ سب صرف میری عبادت کریں گے اور کسی طرح کا شرک نہ کریں گے اور اس کے بعد بھی کوئی کافر ہو جائے تو در حقیقت وہی لوگ فاسق اور بدکردار ہیں۔", "RArabic": "WA’ADAL LAAHUL LAZEENA AAMANOO MINKUM WA ’AMILUS SAALIHAATI LA YASTAKHLIFAN NAHUM FIL ARDI KAMASTAKH LAFAL LAZEENA MIN QABLIHIM WA LA YUMAKKINANNA LAHUM DEENAHUMUL LAZIR TADAA LAHUM WA LA YUBADDILANNAHUM MIM BA’DI KHAWFIHIM AMNAA; YA’BUDOONANEE LAAYUSHRIKOONA BEE SHAI’AA; WA MAN KAFARA BA’DA ZAALIKA FA ULAAA’IKA HUMUL FAASIQOON.", "ArabicText1": "وَعَدَ اللهُ الَّذِيْنَ اٰمَنُوْا مِنْكُمْ وَعَمِلُوا الصّٰلِحٰتِ لَيَسْتَخْلِفَنَّهُمْ فِي الْاَرْضِ كَمَا اسْتَخْلَفَ الَّذِيْنَ مِنْ قَبْلِهِمْ", "ArabicGreenSign1": "ص  ", "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": "وَلَيُمَكِّنَنَّ لَهُمْ دِيْنَهُمُ الَّذِي ارْتَضٰى لَهُمْ وَلَيُبَدِّ لَنَّهُمْ مِّنْۢ بَعْدِ خَوْفِهِمْ اَمْنًا", "ArabicGreenSign2": null, "ArabicRedSign2": "ط ", "ArabicBlueSign2": null, "ArabicText3": "يَّعْبُدُوْنَنِيْ لَا يُشْرِكُوْنَ بِيْ شَيْئًا", "ArabicGreenSign3": null, "ArabicRedSign3": "ط ", "ArabicBlueSign3": null, "ArabicText4": "وَّمَنْ كَفَرَ بَعْدَ ذٰلِكَ فَاُولٰۗئِكَ هُمُ الْفٰسِقُوْنَ", "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016808, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Thereafter, the angels and prophets recite the same supplication; then Mohammad, Ali, Hasan and Husain (peace be upon them) go in the state of prostration, and say…", "GujaratiDescription": null, "RUrduDescription": "Phir ambiya o malaaeka bhi isi tarah kehte hai us waqt Muhammad (s), Ali (a), Hasan (a) aur Husain (a) sajdeh mein jaate hai aur kehte hai…", "UrduDescription": "اس کے بعد ملائکہ اور انبیاء ان کی طرح کہیں گے اس وقت محمد علی حسن اور حسین سجدہ میں پڑجائیں گے اس کے بعد کہیں گے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016809, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": "پس خداوند جو چاہے گا انجام دے گا اور وہ روز معلوم ظہور کا دن ہے۔", "English": "O Lord, be angry, as Your sanctity has been violated, Your chosen ones have been killed, Your nobles servants have been humiliated.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaara! Ghazab-naak ho us par jo Teri mohtaram cheezo’n ki tauhin kare aur jisne Tere muntakhab bando’n ko qatl kiya aur Tere saaleh bando’n ko zaleel kiya.", "Urdu": "اے پروردگارا! غضبناک ہو اس پر جو تیری محترم چیزوں کی توہن کرے اور جس نے تیرے منتخب بندوں کو قتل کیا اور تیرے صالح بندوں کو ذلیل کیا۔", "RArabic": "YAA RABBE IGH-ZIB, FA-INNA-HU QAD HO-TEKA HAREE-MOKA, WA QOTE-LA AS-FEYAA-OKA, WA OZILLA E’BAA-DOKAS SAALE-HOONA.", "ArabicText1": "یَا رَبِّ اِغْضَبْ، فَاِنَّهٗ قَدْ هُتِكَ حَرِیْمُكَ، وَقُتِلَ اَصْفِیَاؤُكَ، وَاُذِلَّ عِبَادُكَ الصَّالِحُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign