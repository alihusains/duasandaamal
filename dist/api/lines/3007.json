[{"Id": 1013066, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Ismail, was the elder son of Imam Jafar Sadiq (a). Some Shias considered him as the 7th Imam. This sect is known as Ismailis, although the deceased himself had belief in the Imamate of his brother, Imam Musa Kazim (a). Imam Kazim (a) also respected him. The Ziyarat of Ismail is as follows…", "GujaratiDescription": null, "RUrduDescription": "Ismail, Imam Jafar Sadiq (a) ke bade farzand thay. Kuchh Shia unhe 7th Imam samjhte hai aur yeh firka Ismaili khelaata hai, jab keh sadiyo’n logo’n ne unke bhai, Imam Musa Kazim (a) ki imaamat ke kaayel thay. Imam Kazim apne bhai ka bada ehteraam karte thay. Ziyarate Ismail ko is tarah se anjaam de…", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "Ara