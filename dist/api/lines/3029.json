[{"Id": 1013162, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "When your reach the trench of Kufa recite as follows…", "GujaratiDescription": null, "RUrduDescription": "Jab Kufa ke khandaq par pohonche to khade ho kar kahe…", "UrduDescription": "جب خندقِ کوفہ پر پہنچے تو کھڑے ہوکر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013163, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah is the Most Great. Allah is the Most Great. O worthiest of exaltation, glorification, and grandeur. Allah is the Most Great. O worthiest of being deemed Great, of sanctification, of glorification, and of granting bounties. Allah is Greater than what I fear and what I worry about. Allah is the Most Great; He is my support and on Him do I rely. Allah is the Most Great; He is my hope and to Him do I turn.", "Gujarati": null, "RGujarati": null, "RUrdu": "Allah buzurg-tar hai, Allah buzurg-tar hai, keh woh bohot badi badaayi ka Maalik hai, badi shaan aur buzurgi waala hai. Allah buzurg-tar hai woh badaayi kiye jaane, paakeezgi bayaan kiye jaane aur yaad kiye jaane ke laaeq aur neymat waala hai. Allah buzurg-tar hai har us cheez se jis se mein khaaef wa tarsa’n huwa hu. Allah buzurg-tar hai jo mera sahara hai aur us par bharosa karta hu. Allah buzurg-tar hai aur meri ummeed hai usi ki taraf palat-ta hu.", "Urdu": "اللہ بزر گ تر ہے اللہ بزرگ تر ہے کہ وہ بہت بڑی بڑائی کا مالک ہے بڑی شان اور بزرگی والا ہے اللہ بزرگ تر ہے وہ بڑائی کیے جانے پاکیزگی بیان کیے جانے اور یاد کیے جانے کے لائق اور نعمت والا ہے اللہ بزرگ تر ہے ہر اس چیز سے جس سے میں خوف زدہ و ہراساں ہوں اللہ بزرگ تر ہے جو میرا سہارا ہے اور اس پر بھروسہ کرتا ہوں اللہ بزرگ تر ہے اور میری امید ہے اسی کی طرف پلٹتا ہوں۔", "RArabic": "ALLAAHO AKBARO ALLAAHO AKBARO AHLAL KIBREYAAA-E WAL MAJDE WAL A’ZAMATE. ALLAAHO AKBARO AHLUT TAKBEE-RE WAT TAQDEE-SE WAT TASBEE-HE WAL AALAAA-E. ALLAAHO AKBARO MIMMAA AKHAA-FO WA AHZARO. ALLAAHO AKBARO E’MAADEE WA A’LAIY-HE ATA-WAKKALO. ALLAAHO AKBARO RAJAAA-EE WA ILAYHE ONEE-BO.", "ArabicText1": "اَللہُ اَكْبَرُ اَللہُ اَكْبَرُ اَهْلَ الْكِبْرِیَآءِ وَالْمَجْدِ وَالْعَظَمَۃِ۔ اَللہُ اَكْبَرُ اَهْلُ التَّكْبِیْرِ وَالتَّقْدِیْسِ وَالتَّسْبِیْحِ وَالْاٰلَآءِ۔ اَللہُ اَكْبَرُ مِمَّا اَخَافُ وَاَحْذَرُ۔ اَللہُ اَكْبَرُ عِمَادِیْ وَعَلَیْہِ اَتَوَكَّلُ اللہُ اَكْبَرُ رَجَآئِیْ وَاِلَیْہِ اُنِیْبُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013164, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, You are indeed the source of my blessings and You alone can respond to my request. You know my neediness and whatever is concealed by the premonitions of hearts and the thoughts of inner selves. I therefore beseech You in the name of Muhammad, the Chosen Prophet, through whom You have stopped all the claims of those who may excuse and the pretexts of those who may make apologies and whom You have decided to be mercy to the peoples.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Tu hi mujhe neymat dene waala aur meri haajat bar laane (puri karne) par qaadir hai, Tu meri haajat ko jaanta aur seeno mein chhupi tamanaawo’n aur dilo’n mein guzar ne waale khayaalo’n se waaqif hai, pas mai sawaal karta hu Tujh se Muhammad'e Mustafa (s.a.w.a) ke waaste se jin ke zariye Tu hujjat laane waalo’n ki daleel aur uzr karne waalo’n ke uzr qata (kaat) kar de aur Aan Hazrat (s.a.w.a) ko jahaano ke liye rehmat qaraar diya.", "Urdu": "اے اللہ تو ہی مجھے نعمت دینے والا اور میری حاجت پوری کرنے پر قادر ہے تو میری حاجت کو جانتا اور سینوں میں چھپی تمناؤں اور دلوں میں گزرنے والے خیالوں سے واقف ہے پس میں سوال کرتا ہوں تجھ سے محمد مصطفیٰؐ کے واسطے سے جن کے ذریعے تو حجت لانے والوں کی دلیل اور عذر کرنے والوں کے عذر قطع کر دیے اور آنحضرتؐ کو جہانوں کے لئے رحمت قرار دیا۔", "RArabic": "ALLAAHUMMA ANTA WALIYYO NE’MATEE WAL QAADERO A’LAA TALE-BATEE TA’LAMO HAA-JATEE WA-MAA TUZME-ROHU HAWAAJE-SUS SODOO-RE WA KHAWAATE-RUN NOFOO-SE FA-AS-ALOKA BE-MOHAMMADE-NIL MUSTA-FAL LAZEE QATA’TA BEHI HOJA-JAL MOHTAJ-JEENA WA UZ’RAL MOA’TAZE-REENA WA JA-AL’TA-HU RAHMA-TAL LIL AA’LAMEENA.", "ArabicText1": "اَللّٰهُمَّ اَنْتَ وَلِیُّ نِعْمَتِیْ وَالْقَادِرُ عَلٰی طَلِبَتِیْ تَعْلَمُ حَاجَتِیْ وَمَا تُضْمِرُہٗ هَوَاجِسُ الصُّدُوْرِ وَخَوَاطِرُ النُّفُوْسِ فَاَسْئَلُكَ بِمُحَمَّدِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": " نِ", "ArabicText2": "الْمُصْطَفٰی الَّذِیْ قَطَعْتَ بِہٖ حُجَجَ الْمُحْتَجِّیْنَ وَعُذْرَ الْمُعْتَذِرِیْنَ وَجَعَلْتَهٗ رَحْمَۃً لِّلْعَالَمِیْنَ۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013165, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "(I beseech You) not to deprive me of the rewards of my visiting Your intimate servant, the brother of Your Prophet, and the Commander of the Believers and my directing to him, and to include me with the virtuous delegation to him and with his pious adherents; (I beseech for that) in the name of Your mercy, O most Merciful of all those who show mercy.", "Gujarati": null, "RGujarati": null, "RUrdu": "Yeh keh mujhe apne Wali (a.s) aur apne Nabi (s.a.w.a) ke bhai Ameerul Momeneen (a.s) ki ziyarat aur qasd'e ziyarat (ziyarat ke iraade) ke sawaab se mehroom na farma mujhe unki baargah mein aane waale neku-kaaro’n aur parhez-gaaro’n mein qaraar de apni rehmat se, ay sab se ziyadah rahem karne waale.", "Urdu": "یہ کہ مجھے اپنے ولی ؑاور اپنے نبیؐ کے بھائی امیرالمومنین ؑ کی زیارت اور قصدِ زیارت کے ثواب سے محروم نہ فرمامجھے ان کی بارگاہ میں آنے والے نیکو کاروں اور پرہیز گار پیروکاروں میں قرار دے اپنی رحمت سے اے سب سے زیادہ رحم کرنے والے۔", "RArabic": "AN LAA TAHRIM-NEE SAWAABA ZIYAA-RATE WALIYYE-KA WA AKHEE NABIYYE-KA AMEERIL MOMENEENA WA QAS-DAHU WA TAJ-A’LANEE MIN WAFDE-HIS SAALE-HEENA WA SHEE-A’TE-HIL MUTTA-QEENA BE RAHMATE-KA YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "اَنْ لَا تَحْرِمْنِیْ ثَوَابَ زِیَارَۃِ وَلِیِّكَ وَاَخِیْ نَبِیِّكَ اَمِیْرِ الْمُؤْمِنِیْنَ وَقَصْدَهٗ وَتَجْعَلَنِیْ مِنْ وَفْدِهِ الصَّالِحِیْنَ وَشِیْعَتِهِ الْمُتَّقِیْنَ بِرَحْمَتِكَ یَا اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": nu