[{"Id": 1020382, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my Allah! It is sufficient for my honour that I am your servant and I am proud of the fact that you are my Lord. You are just as I want so make me as you like me to be.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Meri izzat ke liye yahi kaafi hai keh mai Tera banda hu aur mere fakhr ke liye yahi kaafi hai keh Tu mera Rab hai. Tu aisa hai jaisa keh mai chahta hu, pas mujhe waisa bana de jaisa keh Tu chahta hai.", "Urdu": "میرے معبود !میری عزت کے لیے یہی کافی ہے کہ میں تیرا بندہ ہوں اور میرے فخر کے لئے یہی کافی ہے کہ تو میرا پروردگار ہے۔تو ویسا ہے جیسا  میں چاہتا ہوں اب مجھے ویسا بنادے جیسا  تو چاہتاہے۔", "RArabic": "ILAAHEE KAFAA BEE ‘IZZAN AN AKOO-NA LAKA A’BDAN, WA KAFAA BEE FAKH-RAN AN TAKOO-NA LEE RABBAN ANTA KAMAA O-HIBBO FAJ’ALNEE KAMAA TO-HIBBO.", "ArabicText1": "اِلٰهِيْ كَفٰى بِيْ عِزًّا اَنْ اَكُوْنَ لَكَ عَبْدًا وَكَفٰى بِيْ فَخْرًا اَنْ تَكُوْنَ لِيْ رَبًّا اَنْتَ كَمَا اُحِبُّ فَاجْعَلْنِيْ كَمَا تُحِبُّ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9":