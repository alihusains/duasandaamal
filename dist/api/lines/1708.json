[{"Id": 1010981, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is highly advisably not to neglect having the early dawn meal (Saher) even if a single date or a drink of water are had. The best food in the early dawn meal is fine flour and dates. A Hadith reads that Almighty Allah and His angels bless those who implore for His forgiveness at the last hours of night and have the early dawn meal.", "GujaratiDescription": null, "RUrduDescription": "Saheri khaana (karna) tark na kare, agar-che is mein ek khajur aur ek ghoont paani hi kyu’n na ho aur saheri ke waqt ki behtareen khowraak sattu hai jis mein khajur mila ho aur riwaayat mein hai ke Khuda wande aalam aur malaayeka durood bhejte hai un par jo isteghfaar karte hai saheri ke waqt aur saheri karte hai.", "UrduDescription": "سحری کھانا، سحری کھانا ترک نہ کرے اگرچہ اس میں ایک کھجور اور ایک گھونٹ پانی ہی کیوں نہ ہو۔ اور سحری کے وقت کی بہترین خوراک ستو ہے، جس میں کھجور کا پوڈر ملا ہو (اور روایت نقل ہوئی ہے : خدا وند عالم اور ملائکہ ان پر درود بھیجتے ہیں جو سحری کے وقت استغفار کرتے ہیں اور سحری کھاتے ہیں)۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010982, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is recommended to recite <Surah Qadr> at early dawn (Saher), for a Hadith reads that any believer who recites this surah at the early dawn meal (Saher) and the breaking the fast meal (Iftar) will be decided as sacrificing his blood for the sake of Almighty Allah between these two times.", "GujaratiDescription": null, "RUrduDescription": "Saheri ke waqt <Surah Qadr> padhe. Riwaayat mein hai keh jo shakhs saheri aur iftaari aur un waqto’n ke darmiyaan is surah ki tilaawat kare to uske liye us shakhs jitna sawaab hai jo raahe Khuda mein zakhm khaaye aur jaan qurbaan kar de.", "UrduDescription": "سحری کے وقت <سورۂ قدر> پڑھے روایت میں آیا ہے: جو شخص سحری وافطاری اوران اوقات میں اس سورے کی تلاوت کرے تو اس کے لئے اس شخص جتنا ثواب ہے جو راہِ خدا میں زخم کھاکر جان قربان کر دے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010983, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": "Maaloom hona chahiye keh ulma farmate hai keh roze ki niyyat sehri ke baad kare to behtar hai warna awwal-e-shab se aakhri shab tak jis waqt chahe roze ki niyyat kar le. Niyyat ke silsile mein itna hi kaafi hai keh usko ilm ho aur uska iraadah ho keh kal Khuda ki ita’at mein roza rakhega, phir woh cheez se parhez kare jo roze ko baatil karti hai. Neez bohot behtar hai keh sehri ke waqt namaz-e-shab ka baja laana tark na kare.", "UrduDescription": "معلوم ہونا چاہیے کہ علماء فرماتے ہیں : روزے کی نیت سحری کے بعد کرے تو بہتر ہے ورنہ اولِ رات سے آخر ِرات تک جس وقت چاہے روزے کی نیت کرلے۔ نیت کے سلسلے میں اتنا ہی کافی ہے کہ اس کو علم ہو اور اس کا ارادہ ہو کہ کل خدا کی اطاعت میں روزہ رکھے گا پھر ہر وہ چیز سے پرہیز کرے جو روزے کو باطل کرتی ہے۔ نیزبہت بہتر ہے کہ سحری کے وقت نماز تہجد کا بجا لانا ترک نہ کرے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText