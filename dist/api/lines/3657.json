[{"Id": 1016311, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "INSHA-ALLAH COMING SOON", "GujaratiDescription": null, "RUrduDescription": "Imam Jafar Sadiq (a.s) se riwaayat hai keh Hazrat Fatema (s.a) ke das (10) naam hai, Fatema, Siddiqa, Mubarakah, Tahera, Zakiya, Raaziya, Marziya, Mohaddisah, Zahra, Haaniyah. Aap ke naam mukhtalif munaasibato’n se rakhe gaye hai, ism (naam) aur musamma (jo naam rakha gaya) ke darmiyaan mutaabeqat (taalluq) tawajjoh talab hai aur yahan par faqat do maano (Fatema, Mohaddisah) ke mutaaliq arz karna hai.", "UrduDescription": "امام جعفرصادق سے روایت ہے کہ حضرت فاطمہ کے نو نام ہیں، فاطمہ، صدیقہ، مبارکہ، طاہرہ، ذکیہ، راضیہ، مرضیہ، محدثہ، زہرا۔ آپ کے نام مختلف مناسبتوں سے رکھے گئے ہیں، اسم اور مسمی کے درمیان مطابقت توجہ طلب ہے اور یہاں پر فقط دو ناموں (فاطمہ، محدثہ) کے متعلق عرض کرنا ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "Ara