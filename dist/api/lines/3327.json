, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014583, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O son of Allah’s Messenger. Peace be upon you, O son of the Commander of the Faithful. Peace be upon you, O son of the veracious, immaculate lady Fatimah the Doyenne of the women of the world. Peace be upon you, O my master Abu Abdullah. So be upon you Allah’s mercy and blessings.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "ASSALAAMO A’LAYKA YABNA RASOOLILLAAH ASSALAAMO A’LAYKA YABNA AMEERIL MO’MENEENA ASSALAAMO A’LAYKA YABNAS SIDDEEQATIT TAAHERATE SAYYEDATE NESAAA-IL A’ALAMEENA ASSALAAMO A’LAYKA YAA MAWLAAYA YAA ABA A’BDILLAAHE WA RAHMATULLAAHE WA BARAKAATOHU.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ یَابْنَ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْکَ یَابْنَ اَمِیْرِ الْمُؤْمِنِیْنَ۔ اَلسَّلَامُ عَلَیْکَ یَابْنَ الصِّدِّیْقَۃِ الطَّاہِرَۃِ سَیِّدَۃِ نِسَآئِ الْعَالَمِیْنَ۔ اَلسَّلَامُ عَلَیْکَ یَا مَوْلَایَ یَا اَبَا عَبْدِ اللہِ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlu