[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002432, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please) send blessings upon Ja`far the son of Muhammad the veracious, the hoarder of knowledge, the caller to You with the truth, and the manifest light. O Allah, as You have made him the core of Your words and revelations, the hoarder of Your knowledge, the spokesman of the profession of Your Oneness, the authorized to undertake Your mission, and the keeper of Your religion, so also (please) send blessings upon him with the most excellent blessings that You have ever sent upon any of Your elite people and arguments. Verily, You are full of praise, full or glory.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Jafar bin Muhammad (a.s) par durood bhej jo saadiq hai woh ilm ke khazeene-daar haq ke saath Teri taraf bula ne waale aur roshan noor hai. Ay Ma’bood! Jaise Tu ne apne kalaam aur wahi ka sambhaal ne waala qaraar diya apne ilm ka khazeene-daar apni tawheed ka tarjumaan, apne hukm ka nigheh-daar aur apne deen ka rakhwaala banaya hai, usi tarah un par rehmat farma woh behtareen rehmat jo Tu ne apne bar-guzido’n aur apni hujjato’n mein se kisi par ki hai. Be-shak Tu taarif waala hai buzurg-waar.", "Urdu": "اے معبود! جعفرؑ ابن محمدؑ پر درود بھیج جو صادقؑ ہیں وہ علم کے خزانہ دار حق کے ساتھ تیری طرف بلانے والے اور آشکارا نورہیں اے معبود! جیسے تو نے اپنے کلام اور وحی کا سنبھالنے والا قرار دیا اپنے علم کا خزانہ دار اپنی توحید کا ترجمان اپنے حکم کا نگہدار اور اپنے دین کا رکھوالا بنایا ہے اسی طرح ان پر رحمت فرما وہ بہترین رحمت جو تو نے اپنے برگزیدوں اور اپنی حجتوں میں سے کسی پر کی ہے بے شک تو تعریف والا بزرگوارہے۔", "RArabic": "ALLAAHUMMA SALLE A’LAA JAA’-FARIBNE MOHAMMADENIS SAADEQE KHAAZENIL I’LMID DAA-E’E ELAYKA BIL HAQQIN NOORIL MOBEENE ALLAAHUMMA WA KAMAA JA-A’LTAHU MAA’-DENA KALAAMEKA WA WAHYEKA WA KHAAZENA I’LMEKA WA LESAANA TAWHEEDEKA WA WALIYYA AMREKA WA MUSTAHFEZA DEENEKA FASALLE A’LAYHE AFZALA MAA SALLAYTA A’LAA AHADIN MIN ASFEYAAA-EKA WA HOJAJEKA INNAKA HAMDEEDUN MAJEEDUN.", "ArabicText1": "اَللّٰہُمَّ صَلِّ عَلٰی جَعْفَرِ بْنِ مُحَمَّدِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": " نِ", "ArabicText2": "الْصَّادِقِ خَازِنِ الْعِلْمِ الدَّاعِیْ اِلَیْكَ بِالْحَقِّ النُّوْرِ الْمُبِیْنِ۔ اَللّٰہُمَّ وَكَمَا جَعَلْتَہٗ مَعْدِنَ كَلَامِكَ وَ وَحْیِكَ وَخَازِنَ عِلْمِكَ وَلِسَانَ تَوْحِیْدِكَ وَ وَلِیَّ اَمْرِكَ وَمُسْتَحْفِظَ دِیْنِكَ فَصَلِّ عَلَیْہِ اَفْضَلَ مَا صَلَّیْتَ عَلٰی اَحَدٍ مِّنْ اَصْفِیَآئِك وَحُجَّتِكَ اِنَّكَ حَمِیْدٌ مَّجِیْدٌ۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": nul