[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018655, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! This sky is Your sky, and this earth is Your earth. In the heavens and the skies whatever is there from the beginning to the end belongs to You. O Allah make this earth narrow for so and so, son of so and so (here mention the name) put Your hold on his eyes, ears and tongue and darken his ways of exit like stormy waters in which waves after waves starts gushing in and the clouds covers it, one darkness covers the other darkness. So that when he brings out his hand it is not visible, and he whom Allah does not give light, from where can he get light.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda wanda! Yeh aasmaan Tera aur yeh zameen Teri, yeh khushki Teri hi milkiyat hai, aur yeh samandar Tere samandar hai. Zameen o aasmaan ke darmiyaan dunya se aakherat tak jo kuchh hai woh Tera hi hai. Khuda wanda! Yeh zameen fula’n farzande fula’n ke oont ki khaal se ziyadah tang kar de. Uski samaat o basaarat o dil par qabza farma le. Ya bhaagne ki raahe’n toofaani samandar ki taareekiyo’n ke maanind siyaah (kaala) kar de, keh jin mein maujo’n par mauje’n uth rahi ho, aur un par baadal chhaaye ho. Ek andhere se badh-chadh kar dusra andhera ho, keh jab woh haath nikaale to kuchh nazar na aaye, aur jise Khuda roshni na de usey noor kaha’n se naseeb ho sakta hai.", "Urdu": "اس دعا کے گرد آیتہ الکرسی لکھ کر کاغذ کو ۳ دن تک لٹکا رہنے دیا جائے پھر وہاں رکھیں جہاں وہ شخص رہتا سہتا ہو، انشاء اللہ تعالٰی واپس آجائے گا۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ اِنَّ السَّمَاۗئَ سَمَاۗئُكَ وَالْاَرْضُ اَرْضُكَ وَالْبَرُّ بَرُّكَ وَالْبَحْرُ بَحْرُكَ وَمَا بَیْنَهُمَا فِی الدُّنْیَا وَالْاٰخِرَۃِ لَكَ۔ اَللّٰهُمَّ فَاجْعَلِ الْاَرْضَ بِمَا رَحُبَتْ عَلٰی فُلَانِ ابْنِ فُلَانٍ اَضْیَقَ مِنْ مَسْكِ جَمْلٍ وَخُذْ بِسَمْعِهٖ وَبَصَرِهٖ وَقَلْبِهٖ اَوْ كَظُلُمَاتٍ فِیْ بَحْرٍ لُجِّیٍّ یَّغْشٰهُ مَوْجٌ فَوْقِهٖ سَحَابٌ ظُلُمَاتٌ بَعْضُهَا فَوْقَ بَغْضٍ اِذَا اَخْرَجَ یَدَهٗ لَمْ یَكَدْ یَرٰهَا وَمَنْ لَمْ یَجْعَلِ اللهُ نُوْرًا فَمَالَهٗ مِنْ نُوْرٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "Ar