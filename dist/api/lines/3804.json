[{"Id": 1016640, "EnglishTitle": "PLEASE NOTE: Be it clear that the reason for presenting Translation is to understand Salaat and to recite in Arabic with concentration because reciting Salaat other than Arabic language (or Transliteration) is not correct.", "GujaratiTitle": null, "RUrduTitle": "Waazeh rahe keh tarjuma-e-namaz pesh karne ki asal wajah namaz samajh ke Arabi mein khuzoo aur tawajjoh ke saath namaz padhna hai. Kyu’n keh Arabi ya Roman-Arabi (Transliteration) ke siwa kisi aur zabaan mein namaz padhna sahih nahin hai.", "UrduTitle": "واضح رہے کہ ترجمۂ نماز پیش کرنے کی اصل غرض نماز سمجھ کے عربی میں خضوع اور توجہ کے ساتھ نماز پڑھنا ہے۔ کیوں کہ عربی کے سوا کسی اور زبان میں نماز پڑھنا صحیح نہیں ہے۔ اس لئے ہر ایک کے لئے نماز کی حد تک قرآن و عربی سیکھنا واجب ہے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1017699, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It has been reported from the Holy Prophet (s): Whoever recites 100 rakat namaz in the form of 2x2 rakat, in first rakat after <Surah Fateha> reciting <Surah Falaq>; in each second rakat after <Surah Fateha> reciting <Surah Naas>, an angel would descend from each heaven to record the reward for him up until the Resurrection Day when his face shall be as bright as the moon, and he would be given his Record of Deeds to the right hand and he would benefit from an easy reckoning.", "GujaratiDescription": null, "RUrduDescription": "Hazrat Rasool-e-Khuda (s) se riwaayat hai keh jo koi 100 rakat namaz 2x2 kar ke anjaam de keh jis ki 1st rakat mein <Surah Fateha> ke baad ek martaba <Surah Falaq> aur 2nd rakat mein <Surah Fateha> ke baad ek martaba <Surah Naas> padhe to har aasmaan ke farishte’n uske ajr ko likhenge ta Qayaamat keh jab uska chehra chaand  jaisa noorani hoga aur usey uska amaal naama seedhe haath mein diya jaayega aur hisaab o kitaab mein aasaani hogi.", "UrduDescription": "حضرت رسول خداؐ سے روایت ہے کہ جو کوئی ۱۰۰ رکعت نماز دو دو کر کے انجام دے کہ جس کی پہلی رکعت میں <سورۂ فاتحہ> کے بعد ایک مرتبہ <سورۂ فلق> اور دوسری رکعت میں <سورۂ فاتحہ> کے بعد ایک مرتبہ <سورۂ ناس> پڑھے تو ہر آسمان کے فرشتے اس کے اجر کو لکھیں گے تا قیامت کہ جب اس کا چہرہ چاند جیسا نورانی ہو گا  اور اسے اس کا عمال نامہ سیدھے ہاتھ میں دیا جائیں گا اور حساب و کتاب میں آسانی ہو گی۔ ", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": nu