[{"Id": 1000612, "EnglishTitle": "His Supplication in Satisfaction with the Decree", "GujaratiTitle": null, "RUrduTitle": "Jab ahle duniya ko dekhte to raazi ba riza rehne ke liye yeh dua padhte…", "UrduTitle": "رضائے الہی پر خوش رہنے کی دعاء۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000613, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Praise belongs to God in satisfaction with God’s decision! I bear witness that God has apportioned the livelihoods of His servants with justice and undertaken bounty for all His creatures. O God, bless Muhammad and his Household, tempt me not with what Thou hast given to Thy creatures and tempt them not with what Thou hast withheld from me. Lest I envy Thy creatures and despise Thy decision!", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai Khuda ke hukm par raazi rahe kar uski hamd o sana karta hu aur gawahi deta hu keh Khuda wande aalam ne apne bando’n ke asbaab'e zindagi (rozi wagairah) insaaf ke saath baat-ta hai, aur apni tamaam makhluq se fazl o ehsaan ka rawaiyya ikhteyaar kiya hai. Ay Ma’bood! Hazrat Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur mujhe un cheezo’n se jo Tu ne dusro’n ko di hai hairaan o pareshaan na hone de keh mai Teri makhluq par hasad karu aur Tere faislo’n ko haqeer samajhu aur jin cheezo’n se mujhe mehroom rakkha hai unhe dusro’n ke liye imtehaan ka zariya na bana de keh woh guroor ki nazr se mujhe haqeer samajh kar dekhe.", "Urdu": "اللہ تعالی کے حکم پر رضا وخوشنودی کی بنا پر اللہ کے لئے حمد وستائش ہے۔ میں گواہی دیتا ہوں کہ اس نے اپنے بندوں کی روزیاں آئین عدل کے مطابق تقسیم کی ہیں۔اور تمام مخلوقات سے فضل واحسان کا رویہ اختیار کیا ہے۔ اے اللہ! محمد اور ان کی آل پر رحمت نازل فرما اورمجھے ان چیزوں سے جو دوسروں کو دی ہیں آشفتہ وپریشان نہ ہونے دے کہ میں تیری مخلوق پر حسد کروں اورتیرے فیصلہ کو حقیر سمجھوں۔ اور جن چیزوں سے مجھے محروم رکھا ہے انہیں دوسروں کے لئے فتنہ وآزمائش نہ بنا دے (کہ وہ ازروئے غرورمجھے بہ نظر حقارت دیکھیں)۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَلْحَمْدُ لِلهِ رِضًى بِحُكْمِ اللهِ شَهِدْتُ اَنَّ اللهَ قَسَمَ مَعَايِشَ عِبَادِهٖ بِالْعَدْلِ وَاَخَذَ عَلٰى جَمِيْعِ خَلْقِهٖ بِالْفَضْلِ۔ اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِهٖ وَلَا تَفْتِنِّيْ بِمَا اَعْطَيْتَهُمْ وَلَا تَفْتِنْهُمْ بِمَا مَنَعْتَنِيْ فَاَحْسُدَ خَلْقَكَ وَاَغْمَطَ حُكْمَكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001846, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, bless Muhammad and his Household, delight my soul through Thy decree, expand my breast through the instances of Thy decision, give to me a trust through which I may admit that Thy decree runs only to the best, and let my gratitude to Thee for what Thou hast taken away from me be more abundant than my gratitude to Thee for what Thou hast conferred upon me!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur mujhe apne faisle qaza o qadr par khush-haal rakh, aur apne faislo’n ki qabooliyat ke liye mere seene ko kushaada kar de, aur mere andar bharose ki rooh phoonk de keh mai iqraar karu keh Tera qaza o qadr ka faisla khair o neki ke saath laagu huwa, aur un neymato’n par adaa’e shukr ke muqaable mein jo mujhe ataa kiya hai un cheezo’n par bhi shukriya adaa karne ki kaamil taaqat o quwwat ataa kar jo mujh se rok li hai yaani mujhe nahi ataa ki hai.", "Urdu": "اے اللہ! محمد اور ان کی آل پر رحمت نازل فرما اور مجھے اپنے فیصلہ قضاء وقدر پر شادماں رکھ اور اپنے مقدرات کی پذیرائی کے لئے میرے سینہ میں وسعت پیدا کر دے اور میرے اندر وہ روح اعتماد پھونک دے کہ میں یہ اقرار کروں کہ تیرا فیصلہ قضا و قدر خیر وبہبودی کے ساتھ نافذ ہوا ہے اور ان نعمتوں پر ادائے شکر کی بہ نسبت جو مجھے عطا کی ہیں ان چیزوں پر میرے شکریہ کا کامل وفزوں تر قرار دے جو مجھ سے روک لی ہیں۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِهٖ وَطَيِّبْ بِقَضَاۗئِكَ نَفْسِيْ وَوَسِّعْ بِمَوَاقِعِ حُكْمِكَ صَدْرِيْ وَهَبْ لِيَ الثِّقَةَ لِاُقِرَّ مَعَهَا بِاَنَّ قَضَاۗءَكَ لَمْ يَجْرِ اِلَّا بِالْخِيَرَةِ وَاجْعَلْ شُكْرِيْ لَكَ عَلٰى مَا زَوَيْتَ عَنِّيْ اَوْفَرَ مِنْ شُكْرِيْ اِيَّاكَ عَلٰى مَا خَوَّلْتَنِيْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001847, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Preserve me from imagining any meanness in someone who is destitute or imagining any superiority in someone who possesses wealth, for the noble is he whom obedience to Thee has ennobled and the exalted is he whom worship of Thee has exalted! So bless Muhammad and his Household, give us to enjoy a wealth which does not run out, confirm us with an exaltation which will never be lost, and let us roam freely in the kingdom of everlastingness! Surely Thou art the One, the Unique, the Eternal Refuge; Thou hast not begotten, nor hast Thou been begotten, and equal to Thee is not any one!", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur mujhe is baat se mehfooz rakh keh mai kisi kamzor, naadaar, gareeb ko zillat wa hikaarat ki nazr se dekhu, ya kisi saahebe daulat o sarwat ke baare mein mai (uski daulat ki bina par) fazilat o bartari ka ghumaan karu, is liye keh haqeeqat mein saaheb’e sharf o fazilat woh hai jise Teri ita’at ne sharaf bakhsha, aur saaheb’e izzat woh hai jise Teri ibaadat ne izzat o bulandi di hai. Ay Allah! Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur hamein aisi sarwat o daulat se maala-maal kar jo khatm hone waali na ho, aur aisi izzat o buzurgi se hamari ta’eed farma jo zaayel hone waali na ho, aur mulk’e jaaweda (hamaesha rehne waale thikane) ki taraf rawa-dawa’n kar, be-shak Tu (woh) waahdahu la-sharik aur be-neyaaz hai keh Tu na kisi se paiyda huwa hai, na Tujh se koi paiyda huwa, aur Tera koi misl nahin.", "Urdu": "اور مجھے اس سے محفوظ رکھ کہ میں کسی نادار کو ذلت وحقارت کی نظر سے دیکھوں یا کسی صاحب ثروت کے بارے میں میں (اس ثروت کی بنا پر) فضلیت وبرتری کا گمان کروں۔ اس لۓ کہ صاحب شرف وہ ہے جسے تیری اطاعت نے شرف بخشا ہو اور صاحب عزّت وہ ہے جسے تیری عبادت نے عزّت وسربلندی دی ہو۔ اے اللہ محمد اور ان کی آل پر رحمت نازل فرما اور ہمیں ایسی ثروت ودولت سے بہرہ اندوز کرجو ختم ہونے والی نہیں اور ایسی عزّت وبزرگی سے ہماری تائید فرما جو زائل ہونے والی نہیں۔ اور ہمیں ملک جاوداں کی طرف رواں دواں کر۔ بیشک تو یکتا ویگانہ اور ایسا بے نیاز ہے کہ نہ تیری کوئی اولاد ہے اور نہ تو کسی کی اولاد ہے اور نہ تیرا کوئی مثل وہمسر ہے۔", "RArabic": null, "ArabicText1": "وَاعْصِمْنِيْ مِنْ اَنْ اَظُنَّ بِذِيْ عَدَمٍ خَسَاسَةً اَوْ اَظُنَّ بِصَاحِبِ ثَرْوَةٍ فَضْلًا فَاِنَّ الشَّرِيْفَ مَنْ شَرَّفَتْهُ طَاعَتُكَ وَالْعَزِيْزَ مَنْ اَعَزَّتْهُ عِبَادَتُكَ فَصَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِهٖ وَمَتِّعْنَا بِثَرْوَةٍ لَا تَنْفَدُ وَاَيِّدْنَا بِعِزٍّ لَا يُفْقَدُ وَاسْرَحْنَا فِيْ مُلْكِ الْاَبَدِ انَّكَ الْوَاحِدُ الْاَحَدُ الصَّمَدُ الَّذِيْ لَمْ تَلِدْ وَلَمْ تُولَدُ وَلَمْ يَكُنْ لَكَ كُفُوًا اَحَدٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRe