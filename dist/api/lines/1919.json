[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002419, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, send salutations on the truthful (siddiqah), Fatimah and Purified (zakiyah) beloved of Your beloved and Your messenger and the mother of Your beloved and the chosen. Whom You chose & favoured and You selected her over the worlds women. O Allah! Behold him who oppressed her and belittled her right. O Allah! And avenge the blood of her children.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Durood bhej Siddiqa’e kaayenaat Sayyada Fatema (.s.a) par jo paakeeza hai Tere Paighambar (s.a.w.a) aur Tere mehboob ki pyaari beti hai aur Tere mehboob aur bar-guzido’n ki waaleda hai, wohi Bibi jahano ki aurto’n mein se jin ko Tu ne chun liya, azmat di aur pasandida banaya. Ay Ma’bood! Jinho ne un par zulm dhaaya un se badla le aur jo unke haq ki parwah na ki un se badla le aur ay Ma’bood! Unki aulaad ke khoon ka inteqaam le.", "Urdu": "اے معبود! درود بھیج صدیقۂ کائنات سیدہ فاطمہ(س) پر جو پاکیزہ ہیں تیرے پیغمبرؐ اور تیرے محبوب کی پیاری بیٹی ہیں اور تیرے محبوب اوربرگزیدوں کی والدہ ہیں وہی بی بی(س) جہانوں کی عورتوں میں سے جن کو تو نے چن لیا عظمت دی اور پسندیدہ بنایا اے معبود! جنہوں نے ان پر ظلم ڈھایا ان سے بدلہ لے اور ان کے حق کی پرواہ نہ کی ان سے بدلہ لے اور اے معبود! ان کی اولاد کے خون کا انتقام لے۔", "RArabic": "ALLAAHUMMA SALLE A’LAS SIDDEEQATE FAATEMATAZ ZAKIYYATE HABEEBATE HABEEBEKA WA NABIYYEKA WA UMME AHIBBAAA-EKA WA ASFEYAAA-EKAL LATIN TAJABTAHAA WA FAZZALTAHAA WAKH-TARTAHAA A’LAA NESAAA-IL A’ALAMEENA ALLAAHUMMA KONIT TAALEBA LAHAA MIMMAN ZALAMAHAA WAS-TAKHAFFA BE-HAQQEHAA WA KONIS SAAA-ERA ALLAAHUMMA BE-DAME AWLAADEHAA.", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلَى الصِّدِّيْقَةِ فَاطِمَةَ الزَّكِيَّةِ حَبِيْبَةِ حَبِيْبِكَ وَنَبِيِّكَ وَاُمِّ اَحِبَّائِكَ وَاَصْفِيَائِكَ الَّتِي انْتَجَبْتَهَا وَفَضَّلْتَهَا وَاخْتَرْتَهَا عَلٰى نِسَاءِ الْعَالَمِيْنَ۔ اَللّٰهُمَّ كُنِ الطَّالِبَ لَهَا مِمَّنْ ظَلَمَهَا وَاسْتَخَفَّ بِحَقِّهَا وَكُنِ الثَّائِرَ اللّٰهُمَّ بِدَمِ اَوْلَادِهَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002420, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, And as You have chosen her to be the mother of the Leaders(Imams) of Guidance, the associate of the Flag Bearer the most honored lady in the exalted assembly, so send salutations on her and on her mother A salutation by which her father, Muhammad is honored Salutations of Allah be on him & his progeny And by which the eyes of her progeny are comforted And on my behalf convey to them, now the best of the greetings and salam.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Jaisa keh Tu ne unko banaya hidaayat waale Imaamo’n ki maa, Paighambar ke alam-bardaar (flag bearer) ki zauja mohtarma aur aalam baala arsh o kursi ke maqaam mein izzat waali qaraar diya. Pas un par aur unki aulaad par rehmat farma jis se Tere nabi Muhammad (s.a.w.a) ka chehra mubarak chamak uthay aur un Bibi ki aulaad ki aankhe’n thandi ho aur pohoncha un sab ko us waqt mera behtareen durood aur adaab o salaam.", "Urdu": "اور اے معبود!جیسا کہ تو نے ان کوبنایا ہدایت والے اماموں کی ماں پیغمبرؐ کے علم بردار کی زوجۂ محترمہ اور عالَمِ بالاعرش و کرسی کے مقام میں عزّت والی قرار دیا پس ان پر اور ان کی والدہ(س) پر رحمت فرما جس سے تیرے نبی محمدؐکا چہرۂ مبارک چمک اٹھے اور ان بی بی(س) کی اولاد کی آنکھیں ٹھنڈی ہوں اوران سب کو اس وقت میرا بہترین درود اور آداب و سلام پہنچا۔", "RArabic": "ALLAAHUMMA WA KAMAA JA-A’LTAHAA UMMA A-IMMATIL HODAA WA HALEELATA SAAHEBIL LEWAAA-E WAL-KAREEMATA I’NDAL MA-LAA-IL A-A’LAA FA-SALLE A’LAYHAA WA A’LAA UMMEHAA SALAATAN TUKREMO BEHAA WAJHA ABEEHAA MOHAMMADIN SALLAL LAAHO A’LAYHE WA AALEHI WA TOQIRRO BEHAA A-A’YONA ZURRIYYATEHAA WA ABLIGH-HUM A’NNEE FEE HAAZEHIS SAA-A’TE AFZALAT TAHIYYATE WAS-SALAAME.", "ArabicText1": "اَللّٰهُمَّ وَكَمَا جَعَلْتَهَا اُمَّ اَئِمَّةِ الْهُدٰى وَحَلِيْلَةَ صَاحِبِ اللِّوَاءِ وَالْكَرِيْمَةَ عِنْدَ الْمَلَاِ الْاَعْلٰى فَصَلِّ عَلَيْهَا وَعَلٰى اُمِّهَا صَلَاةً تُكَرِّمُ بِهَا وَجْهَ اَبِيْهَامُحَمَّدٍ صَلَّى اللهُ عَلَيْهِ وَآلِهٖ وَتُقِرُّ بِهَا اَعْيُنَ ذُرِّيَّتِهَا وَاَبْلِغْهُمْ عَنِّيْ فِيْ هٰذِهِ السَّاعَةِ اَفْضَلَ التَّحِيَّةِ وَالسَّلَامِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9":