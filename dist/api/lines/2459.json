[{"Id": 1019974, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It has been narrated by Imam Reza (a) that he (a) said: Whoever will recite this name of Almighty Allah 100 times in forenoon having sincere intention paying full attention towards Allah - the High, and its meaning, his heart will be illuminated and he will remain safe from the goading of Satan…", "GujaratiDescription": null, "RUrduDescription": "Imam Reza (a) se riwaayat hai ke unho’n ne farmaya: Jo koi dopaher se pehle (forenoon) khuloos’e dil se, iske maaine (meaning) aur Allah (swt) ki taraf tawajjoh karte huwe 100 martaba is zikr ko padhe, to uska dil munawwar hoga aur woh shaitaan ke hamlo’n se mehfooz rahega…", "UrduDescription": "امام رضاؑ سے روایت ہے کہ انہوں نے فرمایا: جو کوئی دوپہر سے پہلے، خلوصِ دل سے، اس کے معنی اور اللہ تعالی کی طرف توجہ کرتے ہوئے ۱۰۰ مرتبہ اس ذکر کو پڑھے، تو اُس کا دل منور ہو گا اور وہ شیطان کے حملوں سے محفوظ رہے گا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "Arabic