[{"Id": 1016640, "EnglishTitle": "PLEASE NOTE: Be it clear that the reason for presenting Translation is to understand Salaat and to recite in Arabic with concentration because reciting Salaat other than Arabic language (or Transliteration) is not correct.", "GujaratiTitle": null, "RUrduTitle": "Waazeh rahe keh tarjuma-e-namaz pesh karne ki asal wajah namaz samajh ke Arabi mein khuzoo aur tawajjoh ke saath namaz padhna hai. Kyu’n keh Arabi ya Roman-Arabi (Transliteration) ke siwa kisi aur zabaan mein namaz padhna sahih nahin hai.", "UrduTitle": "واضح رہے کہ ترجمۂ نماز پیش کرنے کی اصل غرض نماز سمجھ کے عربی میں خضوع اور توجہ کے ساتھ نماز پڑھنا ہے۔ کیوں کہ عربی کے سوا کسی اور زبان میں نماز پڑھنا صحیح نہیں ہے۔ اس لئے ہر ایک کے لئے نماز کی حد تک قرآن و عربی سیکھنا واجب ہے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1017596, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Shaikh in Misbah from Dawood ibne Sarhaan and he from Imam Jafar Sadiq (a) that this 12 rakat namaz has to be recited on the Eve of 15th Rajab in the form of (2x2) rakats, in each rakat after <Surah Fateha>, recite any Surah. After namaz recite <Surah Fateha>, <Surah Falaq>, <Surah Naas>, <Surah Ikhlaas>, and <Aayatul Kursi> 4 times each and after12 rakat namaz recite 4 times each…", "GujaratiDescription": null, "RUrduDescription": "Shaikh ne Misbah mein Dawood ibne Sarhaan ke zariye Imam Jafar Sadiq (a) se is namaz ka ek aur tariqa bayaan kiya hai: 15th Rajab ki shab mein mustahab hai keh 12 rakat namaz, 2x2 karke padhe. Har rakat mein <Surah Fateha> ke baad koi bhi Surah padhe aur namaz ke baad <Surah Fateha>, <Surah Falaq>, <Surah Naas>, <Surah Ikhlaas> aur <Aayatul Kursi> har ek 4 martaba padhe aur phir har ek zikr ko 4 martaba padhe…", "UrduDescription": "لیکن شیخؒ نے مصباح میں داؤد ابن سرحان کے ذریعے امام جعفر صادق ؑسے اس نماز کا ایک اور طریقہ بیان کیا ہے : ۱۵ رجب کی شب میں ۱۲ رکعت نماز ادا کرے جس کی ہر رکعت میں <سورۂ فاتحہ> کے بعد کوئی ایک سورۂ پڑھے اور نماز کے بعد <سورۂ فاتحہ>، <سورۂ فلق>، <سورۂ ناس>، <سورۂ اخلاص> اور <آیت الکرسی> میں سے ہر ایک ۴ مرتبہ پڑھے اور پھر ہر ایک ذکر۴ مرتبہ پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "Arabic