[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002288, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "All praise belongs to Allah, Who has not taken a son and does not have a partner in the Dominion, nor does He have a helper out of weakness; and magnify Him with a worthy magnification. O Allah, I ask You by the juncture of Your might over the pillars of Your Throne, and the ultimate Mercy from Your book. And (I ask You) by Your name the great, the majestic, the splendid. And (I ask You) by Your remembrance the elevated, the sublime, the exalted; and by Your complete and perfect words, that You bless Muhammad and his family and do for me, what You are worthy of.", "Gujarati": null, "RGujarati": null, "RUrdu": "Hamd hai us Khuda ke liye jisne kisi ko apna beta nahi banaya aur na koi uski hukumat mein uska saathi hai, na woh kamzor hai keh koi uska haami (madad-gaar) ho aur tum uski badaayi khoob bayaan karo. Ay Ma’bood! Mai sawaal karta hu Tujh se arsh par Tere maqaamate izzat ke waaste se aur us intehaayi rehmat ke waaste se jo Tere Qur’an mein hai aur ba-waasta Tere naam ke jo bohot bada, bohot bada, bohot hi bada hai. Ba-waasta Tere zikr keh jo buland-tar, buland-tar, bohot hi buland-tar hai aur ba-waasta Tere kaamil kalemaat ka, sawaali hu keh Tu rehmat farma Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par aur mujh se woh sulook farma jo Tere shaaya-ne shaan hai.", "Urdu": "حمد ہے اس خداکے لئے جس نے کسی کو اپنا بیٹا نہیں بنایا اور نہ کوئی اس کی حکومت میں اس کا شریک ہے نہ وہ کمزور ہے کہ کوئی اس کا حامی ہو اور تم اس کی بڑائی خوب بیان کرو اے معبود! میں سوال کرتا ہوں تجھ سے عرش پر تیرے مقامات ِعزت کے واسطے سے اور اس انتہائی رحمت کے واسطے سے جو تیرے قرآن میں ہے اور تیرے نام کے واسطے سےجو بہت بڑا، بہت بڑا، بہت ہی بڑا ہے تیرے ذکر کےواسطے سے جو بلند تر، بلندتر اور بہت بلندتر ہے اور تیرے کامل کلمات کے واسطے سے سوالی ہوں کہ تو حضرت محمدؐ اور ان کی آل ؑپر رحمت فرما اور مجھ سے وہ سلوک فرما جو تیرے شایان ِشان ہے۔", "RArabic": "AL-HAMDO LIL-LAAHIL LAZEE LAM YATTA-KHIZ WALA-DAN WA LAM YAKUN LAHU SHAREE-KOON FIL MULKE WA LAM YAKUN LAHU WALIYYUN MENAZ ZULLE WA KABBIR-HO TAK-BEERAN. ALLAAHUMMA INNEE AS-ALOKA BE-MAA’QEDE I’ZZE-KA A’LAA AR-KAANE A’R-SHEKA WA MUNTA-HAR RAHMATE MIN KETAABE-KA WA BISME-KAL A’ZA-MIL A’ZA-ME WA ZIKRE-KAL A’LAL A’LAL A’LAA WA BE-KALE-MAATE-KAT TA-AMMAA-TEKA AN TO-SALLE-YA A’LAA MOHAMMADIW WA AALE-HI WA AN TAF-Q’LA BEE MAA ANTA AHLO-HU.", "ArabicText1": "اَلْحَمْدُ لِلهِ الَّذِیْ لَمْ یَتَّخِذْ وَلَدًا وَّلَمْ یَكُنْ لَّهٗ شَرِیْكٌ فِی الْمُلْكِ وَلَمْ یَكُنْ لَّهٗ وَلِیٌّ مِنَ الذُّلِّ وَكَبِّرْهُ تَكْبِیْرًا۔ اَللّٰهُمَّ اِنِّیْ اَسْاَلُكَ بِمَعَاقِدِ عِزِّكَ عَلٰی اَرْكَانِ عَرْشِكَ وَمُنْتَهَی الرَّحْمَۃِ مِنْ كِتَابِكَ وَبِاسْمِكَ الْاَعْظَمِ الْاَعْظَمِ الْاَعْظَمِ وَذِكْرِكَ الْاَعْلَی الْاَعْلَی الْاَعْلٰی وَبِكَلِمَاتِكَ التَّآمَّاتِكَ اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّاٰلِهٖ وَاَنْ تَفْعَلَ بِیْ مَا اَنْتَ اَهْلُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicT