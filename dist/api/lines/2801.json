[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011697, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, You gave such a discourse to Your Prophet, may Allah bless him and his progeny, that it rendered the other disbeliever nations dumb. Thus You have said Say: Call on those whom you assert besides Him, so they shall not control the removal of distress from you nor change the condition. So O One, except whom no one can remove our distress and change our condition. Bless Muhammad and Aale Muhammad (a.s). And remove my distress and change my bad condition and transfer me in this great month from the degradation of sins to the honor of obedience, O the most merciful of the merciful ones.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baare Ilaaha! Tu ne apne Nabi (s.a.w.a) ki zabaane mubarak par (dandaane shikan) kalam ko jaari farma ke tamaam aqwaam (baatil parast qaumo’n) ki zabaano ko goong-gah kar diya, chunaan-che Tu ne irshaad farmaya hai keh Ay Nabi, aap kahe dijiye, keh pukaare woh unko, keh jinke baare mein ghumaan karte hai keh yeh bhi Allah ke alaawa kuchh hai. Yaqeenan woh log tum se museebato’n ke dafa karne ki aur tumhaari haalat ko badal-ne ki, siwaaye Allah ke zara bhi qudrat nahin rakhte. Ay woh keh jiske alaawa koi bhi hamari museebato’n ko dur nahin kar sakta aur na hamari haalat badal sakta hai. Rehmat naazil farma Hazrat Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par aur meri museebat ko dur kar aur meri is bad-haali ko badal de aur mujh ko is buzurg mahine mein gunaho’n ki zillat o ruswaayi se nikaal kar ita’at o farmaan bardaari ki izzat tak pohoncha de. Ay rahem karne waalo’n mein sab se ziyadah raheem.", "Urdu": "بار الہ! تو نے اپنے نبیؐ کی زبان مبارک پر کلام کو جاری فرما کے تمام اقوام (باطل پرست) کی زبانوں کو گنگا کر دیا، چنانچہ تو نے ارشاد فرمایا ہے کہ، اے نبی، آپ کہے دیجیے کہ پکارے وہ ان کو، کے جن کے بارے میں گمان کرتے ہے کہ یہ بھی اللہ کے علاوہ کچھ ہے۔ یقینًا وہ لوگ تم سے مصیبتوں کے دفع کرنے کی اور تمہاری حالت کو بدل نے کی سوائے اللہ کے ذرا بھی قدرت نہیں رکھتے۔ اے وہ کہ جس کے علاوہ کوئی بھی ہماری مصیبتوں کو دور نہیں کر سکتا اور نہ ہماری حالت بدل سکتا ہے۔ رحمت نازل فرما محمدؐ اور آل محمدؑ پر اور میری مصیبت کو دور کر اور میری اس بدحالی کو بدل دے اور مجھ کو اس بزرگ مہینے میں گناہوں کی زلت و رسوائی سے نکال کر اطاعت و فرمان برداری کی عزّت تک پہنچا دے۔ ات رحم کرنے والوں میں سب سے زیادہ رحیم۔", "RArabic": "ALLAAHUMMA INNA-KA A’IY-YAIY-TA AQWAA-MAN A’LAA LE-SAANE NABIYYE-KA SALLAL LAAHO A’LAIY-HE WA AALE-HI FA-QULTA QO-LID-U’L LAZEE-NA ZA-A’M-TUM MIN DOONE-HI FA-LAA YAMLE-KOONA KASH-FAZ ZURRE A’N-KOOM WA LAA TAHWEE-LAN FA-YAA MAN LAA YAMLE-KO KA-SHA-FAZ ZURRE A’NNAA WA LAA TAHWEE-LAN GHAIRA-HU SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WAK-SHIF MAA-BEE MIN ZURRIN WA HAWWIL-HO A’NNEE WAN-QULNEE FEE HAA-ZASH SHAHRIL A’ZEEME MIN ZULLIL MA-A’A-SEE ILAA I’ZZIT-TAA-A’TE YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "اَللّٰھُمَّ اِنَّکَ عَیَّیْتَ اَقْوَامًا عَلٰی لِسَانِ نَبِیِّکَ صَلَّی اللہُ عَلَیْہِ وَاٰلِہٖ فَقُلْتَ قُلِ ادْعُو الَّذِیْنَ زَعَمْتُمْ مِنْ دُوْنِہٖ فَلَا یَمْلِکُوْنَ کَشْفَ الضُّرِّ عَنْکُمْ وَلَا تَحْوِیْلًا فَیَا مَنْ لَّا یَمْلِکُ کَشَفَ الضُّرِّ عَنَّا وَلَا تَحْوِیْلًاغَیْرَہٗ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاکْشِفْ مَابِیْ مِنْ ضُرٍّ وَّحَوِّلْہُ عَنِّیْ وَانْقُلْنِیْ فِیْ ھٰذَ الشَّھْرِ الْعَظِیْمِ مِنْ ذُلِّ الْمَعَاصِیْ اِلٰی عِزِّالطَّاعَۃِ یَااَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign1