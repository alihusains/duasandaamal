duImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012777, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Abawa is a name of a village 13 miles from Juhfah. Lady Aamena (s) binte Wahab, the mother of Holy Prophet (s) was returning from Medina to Mecca after visiting the grave of her husband Abdullah (a) when she fell ill and passed away here. Her grave is famous in Abawa. It is recommended to recite the Ziyarat of <Lady Aamena (s)> at this place.", "GujaratiDescription": null, "RUrduDescription": "Abawa, Juhfah se 13 mile ki duri par hai. Bibi Aamena (s) binte Wahab, jo Rasool-e-Khuda (s) ki maadar-e-giraami hai, woh apne shauhar Abdullah (a) ki ziyarat karke Madine se Makkeh ki taraf laut rahi thi, raaste mein woh bimaari huwi aur unki wafaat ho gayi. Unki qabr mubarak Abawa mein mashhoor hai, Mustahab hai keh is jagah par ziyarat <Bibi Aamena (s)> zaroor padhe.", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "A