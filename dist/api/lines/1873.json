le": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Here you take the name of the buried one.", "GujaratiDescription": null, "RUrduDescription": "Yahan par dafn hone waale ka naam le.", "UrduDescription": "فلاں کے بجائے میت کا نام لے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1002916, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "If you do so, Almighty Allah will immediately send 1000 angels to the grave of that individual; each angel carrying a dress and a garment. Moreover, Almighty Allah will expand his grave, saving him from tightness up to the day when the Trumpet will be blown. As for the one who has offered this namaz, he will be given rewards as many as everything touched by the sunlight and he will be raised 40 ranks.", "GujaratiDescription": null, "RUrduDescription": "Agar kisi ne is amal ko anjaam diya to Allah (swt) 1000 farishto’n ko uski qabr par bhej deta hai keh un mein se har ek ke paas ek libaas hota hai aur woh us mayyit ki qabr ko soor phoonke jaane tak kushaada karte rahenge. Neez is namaz padhne waale ko un tamaam cheezo’n ki taadaad ke bara-bar ajr milta hai jin par suraj tuloo karta (chamakta) hai aur uske liye 40 darjeh buland kiye jaate hai.", "UrduDescription": "اگر کسی نے اس عمل کو انجام دیا تو اسی وقت حق تعالی ٰ۱۰۰۰ فرشتہ اس قبر پر بھیج دیتا ہے کہ ان میں سے ہرایک کے پاس ایک لباس ہوتا ہے اوروہ اس میت کی قبر کو صور پھونکے جانے تک کشادہ کرتے رہیں گے نیز اس نماز پڑھنے والے کو ان تمام چیزوں کی تعداد کے برابر اجر ملتا ہے جن پر سورج طلوع کرتا ہے اور اس کے لئے چالیس درجے بلند کیے جاتے ہیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1"