[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002431, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please) send blessings upon Muhammad the son of Ali the splitter of knowledge, the leader to true guidance, the chief of the people of piety, and the superbly selected from among Your servants. O Allah, as You have made him sign for Your servants, lantern in Your lands, depot of Your wisdom, and interpreter of Your revelations, and You ordered (us) to obey him, warned (us) against disobeying him; so also (please), O Lord, send blessings upon him with the most excellent blessings that You have ever sent upon any of the offspring of Your Prophets, Elite Ones, Messengers, and trustees. O Lord of the worlds!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Muhammad bin Ali (a.s) par durood bhej jo ilm phaila ne waale Imam’e hidaayat, parhez-gaaro’n ke peshwa aur Tere bando’n mein se bar-guzidah hai. Ay Ma’bood! Jaise Tu ne qaraar diya unko bando’n ke liye nishaane hidaayat apne shahero’n ke liye roshni apni hikmat ka ameen aur apni wahi ka tarjumaan banaya, neez unki ita’at ka hukm diya aur unki na-framaani se mana kiya hai. Pas un par rehmat farma ay Parwardigaar woh behtareen rehmat jo Tu ne apne nabiyyo’n, apne bar-guzido’n, apne rasoolo’n aur apne amaanat-daaro’n mein se kisi ki aulaad par ki hai, ay jahano ke Parwardigaar.", "Urdu": "اے معبود! محمدؑ ابن علیؑ پر درود بھیج جو علم پھیلانے والے امامؑ ِہدایت پرہیز گاروں کے پیشوا اور تیرے بندوں میں سے برگزیدہ ہیں اے معبود! جیسے تو نے قرار دیا ان کو اپنے بندوں کے لئے نشانِ ہدایت اپنے شہروں کے لئے روشنی اپنی حکمت کا امین اور اپنی وحی کا ترجمان بنایانیز ان کی اطاعت کا حکم دیا اور ان کی نافرمانی سے منع کیا ہے پس ان پر رحمت فرما اے پروردگار وہ بہترین رحمت جو تونے اپنے نبیوں اپنے برگزیدوں اپنے رسولوں اور اپنے امانت داروں میں سے کسی کی اولادپر کی ہے اے جہانوں کے پروردگار۔", "RArabic": "ALLAAHUMMA SALLE A’LAA MOHAMMADIBNI A’LIYYIN BAAQIRIL I’LME WA EMAAMIL HODAA WA QAAA-EDE AHLIT TAQWAA WAL MUNTAJABE MIN E’BAADEKA ALLAAHUMMA WA KAMAA JA-A’LTAHU A’LAMAN LE-E’BAADEKA WA MANAARAN LE BELAADEKA WA MUSTAWDA-A’N LE HIKMATEKA WA MOTARJEMAN LE WAHYEKA WA AMARTA BETAA-A’TEHI WA HAZZARTA MIN MA’-SEYATEHI FA SALLE A’LAYHE YAA RABBE AFZALA MAA SALLAYTA A’LAA AHADIN MIN ZURRIYYATE AMBEYAAA-EKA WA ASFEYAAA-EKA WA ROSOLEKA WA OMANAAA-EKA YAA RABBAL A’ALAMEENA.", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدِ بْنِ عَلِيٍّ بَاقِرِ الْعِلْمِ وَاِمَامِ الْهُدٰى وَقَائِدِ اَهْلِ التَّقْوٰى وَالْمُنْتَجَبِ مِنْ عِبَادِكَ۔ اَللّٰهُمَّ وَكَمَا جَعَلْتَهٗ عَلَمًا لِعِبَادِكَ وَمَنَارًا لِبِلَادِكَ وَمُسْتَوْدَعًا لِحِكْمَتِكَ وَمُتَرْجِمًا لِوَحْيِكَ وَاَمَرْتَ بِطَاعَتِهٖ حَذَّرْتَ عَنْ مَعْصِيَتِهٖ فَصَلِّ عَلَيْهِ يَا رَبِّ اَفْضَلَ مَا صَلَّيْتَ عَلٰى اَحَدٍ مِّنْ ذُرِّيَّةِ اَنْبِيَاءِكَ وَاَصْفِيَاءِكَ وَرُسُلِكَ وَاُمَنَائِكَ يَا رَبَّ الْعَالَمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "Ara