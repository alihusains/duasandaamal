[{"Id": 1013103, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "There are many small mosques on the edge of Sala'kahar which indicate the map of the Battle of Khandaq. The army of Islam had camped here. Later a mosque was built here and it became famous with the name of Masjid-e-Fath. It is said that the Holy Prophet (s) prayed for the victory of Muslims here and it was here that the Holy Prophet (s) got the news of victory of Muslims. Hence it is named so.", "GujaratiDescription": null, "RUrduDescription": "Jang-e-Khandaq ke maidaan mein kaafi chhoti chhoti masjid hai. Islam ki fauj yahan par muqaam karti thi. Baad mein yahan par ek masjid baandhi gayi thi aur woh Masjid Fath ke naam se mashhoor huwi. Kaha jaata hai keh Rasool-e-Khuda (s) musalmaano ki fateh ke liye is masjid mein dua karte thay aur unko is masjid mein fateh ki khabar mili, is liye iska naam Masjid Fath hai.", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10":