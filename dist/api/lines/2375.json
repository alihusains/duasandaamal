[{"Id": 1019656, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Washsha reports that when a person came to Imam Reza (a) he (a) asked: What happened? I see the color of your face pale. He said: Once in every four days I get fever which made me unable to move. Imam Reza (a) asked for his pen and paper and wrote…", "GujaratiDescription": null, "RUrduDescription": "Washsha riwaayat karte hai keh jab ek shakhs Imam Reza (a) ki khidmat mein aaya to Imam (a) ne us se poochha: Kya baat hai keh mai tumhaare chehre ka rang fikha (pale) dekh raha hu? Us ne farmaya: Har 4 dino mein mujhe bukhaar aata hai jis ki wajah se mai harkat nahin kar paata. Imam Reza (a) ne us se kaaghaz o kalam talab kiya aur us par likkha…", "UrduDescription": "وشاء روایت کرتے ہیں کہ جب ایک شخص امام رضاؑ کی خدمت میں آیا تو امامؑ نے اُس سے پوچھا: کیا بات ہے کہ میں تمہارے چہرے کا رنگ فکا دیکھ رہا ہو؟ اُس نے فرمایا: ہر چار دنوں میں مجھے بخار آتا ہے جس کی وجہ سے میں حرکت نہیں کر پاتا۔ امام رضاؑ نے اُس سے کاغذ و قلم طلب کیا اور اُس پر لکھا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019657, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the name of Allah, the Beneficent, the Merciful. In the name of Allah and by Allah Abjad, Hawwaz, Hutti from so-and-so son of so-and-so with the permission of Allah, the High.", "Gujarati": null, "RGujarati": null, "RUrdu": "Allah ke naam se jo bada maher-baan nehaayat rahem karne waala hai. Allah ke naam se aur Allah ki zaat se Abjad, Hawwaz, Hutti fulaan bin fulaan ki taraf se Allah buzurg o bartar ke izn (permission) se.", "Urdu": "اللہ کے نام سے جو بڑا مہربان نہایت رحم کرنے والا ہے، اللہ کے نام سے اور اللہ کی ذات سے ابجد، ہوز، حُطی فلاں بن فلان کی طرف سے اللہ بزرگ و برتر کے حکم سے۔", "RArabic": "BISMILLAA-HIR RAHMAA-NIR RAHEEM. BISMILLAAHE WA BILLAAHE ABJAD HAWWAZ HUTTEE A’N FOLAA-NIB-NE FOLAANA-TEEN BE-IZNIL LAAHE TA-A’ALAA.", "ArabicText1": "بِسْمِ اللهِ الرَّحْمٰنِ الرَّحِيْمِ۔ بِسْمِ اللهِ وَبِاللهِ اَبْـجَدْ هَوَّزْ حُطِّيْ عَنْ فُلَانِ بْنِ فُلَانَةٍ بِاِذْنِ اللهِ تَعَالٰى۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019658, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Then he (a) put the ‘Seal of Sulaiman’ 7 times below it. Then after rolling it said: O Moa’ttab! Give me thread on which neither water nor saliva is touched. When he presented a thread to Imam Reza (a) he put a knot on it. Then he (a) brought it near his face and put four knots on one side and on every knot he (a) recited, <Surah Fateha>, <Surah Naas>, <Surah Falaq>, <Surah Ikhlaas> and <Aayatul Kursi>, on the other side of the thread he (a) put three knots and again recited the same surahs and handed it over to the patient and said: Tie it on your right shoulder and recite Aayatul Kursi till the end and do not copulate till it is on your shoulder.", "GujaratiDescription": null, "RUrduDescription": "Phir Imam (a) ne us kaaghaz par 7 martaba Suleman ki Mohr (seal) laga di. Phir us kaaghaz ko lapet-ne ke baad farmaya: Ay Moattab! Mujhe woh dhaaga do jis ko na paani aur na hi loaab’e dahan (saliva) laga ho. Jab us ne woh dhaaga Imam Reza (a) ko pesh kiya to Imam (a) ne us par ek ghaant (knot) lagaayi. Phir Imam (a) ne Us ke chehre ke qareeb le gaye aur ek taraf 4 ghaante’n (knots) lagaayi aur har ghaant par Imam (a) ne <Surah Fateha>, <Surah Naas>, <Surah Falaq>, <Surah Ikhlaas> aur <Aayatul Kursi> ki tilaawat ki, dhaage ki dusri taraf Imam (a) ne 3 ghaante’n lagaayi aur phir se har ek ghaant par yehi Suroh ki tilaawat ki aur mareez ke hawaale karte huwe farmaya: Isey apne daaye’n baazu (right shoulder) par baandh do aur mukammal Aayatul Kursi ko padho’n aur jab tak yeh taaweez tumhaare baazu par bandha huwa ho tab tak ham-bistri (sex) se parhez karo.", "UrduDescription": "پھر امامؑ نے اُس کاغذ پر ۷ مرتبہ مہرِ سلیمان لگا دی، پھر اُس کاغذ کو لپٹ نے کے بعد فرمایا: اے معتب! مجھے وہ دھاگہ دو جس کو نہ پانی اور نہ ہی لعابِ دہن لگا ہو۔ جب اُس نے وہ دھاگہ امام رضاؑ کو پیش کیا تو امامؑ نے اُس پر ایک گانٹھ لگائی۔ پھر امامؑ نے اُس کے چہرے کے قریب لے گئے اور ایک طرف ۴ گانٹھ لگائی اور ہر گانٹھ پر امامؑ نے <سورۂ فاتحہ>، <سورۂ ناس>، <سورۂ فلق>، <سورۂ اخلاص> اور <آیت الکرسی> کی تلاوت کی، دھاگہ کی دوسری طرف امامؑ نے ۳ گانٹھ لگائی اور پھر سے ہر ایک گانٹھ پر یہی سوروں کی تلاوت کی اور مریض کے سپرد کرتے ہوئے فرمایا: اسے اپنے دائیں بازو پر باندھ دو اور مکمل آیت الکرسی کو پڑھوں اور جب تک یہ تعویز تمہارے بازو پر بندھا ہوا ہو تب تک ہمبستری سے پرہیز کرو۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSi