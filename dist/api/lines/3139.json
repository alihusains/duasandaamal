[{"Id": 1013843, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Imam Sadiq (a) says, when one of you prepares for the Ziyarat the dwellers of the heavens give good news to each other and when he leaves the house and goes by a vehicle or on foot, Allah appoints 1000 Angels that they continue to send salawat (blessings) on him till he reaches the grave of Imam Husain (a). After this Imam Sadiq (a) said: When you go near the grave of Imam Husain (a) stand at the door of the tomb and recite these words as in exchange of each word you will receive the benefit of Allah’s mercy…", "GujaratiDescription": null, "RUrduDescription": "Imam Sadiq (a) ne farmaya, Jab koi Ziyarat ke liye jaaye to ek dusro ko khush khabri do. Aur jab tum ghar se rawaana ho sawaari ya paiydal to Allah (swt) 1000 farishte muqarar karta hai jo uske liye salwaat padhte hai jab tak woh Imam Husain (a) ke rauze par na pohonche. Iske baad Imam Sadiq (a) farmate hai, Jab tum qabr par pohoncho’n to sar (head) ki jaanib khade ho kar is tarah se padho ke Allah (swt) ki rehmat haasil ho…", "UrduDescription": "یہ ایک مختصر زیارت ہے جسے سید ابن طاؤسؒ نے مزار میں نقل کیا اور فرمایا ہے : اس زیارت کی فضلیت بہت زیادہ ہے، جابر جعفیؒ نے امام جعفر صادق ؑ سے روایت کی ہے کہ آپ نے فرمایا:تمہارے اور امام حسینؑ کی قبر مبارک کے درمیان کس قدر فاصلہ ہے؟ میں نے عرض کی: ایک دن کی مسافت سے کچھ زیادہ ہے! آپ نے فرمایا :کیا تم حضرتؑ کی زیارت کرنے جایا کرتے ہو؟ میں نے عرض کی : ہاں جاتا ہوں۔ آپ نے فرمایا: کیا میں تجھے اس کے ثواب کی خوش خبری نہ دوں؟ میں نے عرض کی: ہاں میں آپ پر فدا ہو جاؤں بشارت دیجئے! آپ نے فرمایا کہ بے شک جب تم میں سے کوئی شخص امام حسینؑ کی زیارت کے لئے تیار ہوتا ہے تو آسمان میں فرشتے ایک دوسرے کو خوش خبری دیتے ہیں جب وہ سوار یا پیادہ اپنے گھر سے روانہ ہوتا ہے تو حق تعالیٰ ۱۰۰۰ فرشتے اس پر مقرر کرتا ہے جو روضۂ امام حسینؑ پر پہنچنے تک اس کے لئے طلبِ رحمت کرتے رہتے ہیں۔ پھر فرمایا : جب وہ شخص روضۂ امام حسینؑ کے دروازے پر پہنچتا ہے تو وہاں کھڑے ہو کر یہ کلمات زبان سے ادا کرتاہے تو خدائے تعالیٰ ہر کلمے کے بدلے میں اس پر رحمت بھیجتا ہے، میں نے عرض کی : وہ کلمات کون سے ہیں؟ تو آپ نے فرمایا : وہ کلمات یہ ہیں۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013844, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O inheritor of Adam the choice of Allah. Peace be upon you, O inheritor of Noah the prophet of Allah. Peace be upon you, O inheritor of Abraham the friend of Allah. Peace be upon you, O inheritor of Moses the spoken by Allah. Peace be upon you, O inheritor of Jesus the spirit of Allah. Peace be upon you, O inheritor of Muhammad the most-beloved of Allah.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Aadam (a.s) ke waaris jo Khuda ke bar-guzidah hai. Aap par salaam ho ay Nooh (a.s) ke waaris jo Khuda ke nabi hai. Aap par salaam ho ay Ibrahim (a.s) ke waaris jo Khuda ke khaleel hai. Aap par salaam ho ay Moosa (a.s) ke waaris jo Khuda ke kaleem. Aap par salaam ho ay Isa (a.s) ke waaris jo Khuda ki rooh hai. Aap par salaam ho ay Muhammad (s.a.w.a) ke waaris jo Khuda ke habib hai.", "Urdu": "آپ پر سلام ہو اے آدمؑ کے وارث جو خدا کے چنے ہوئے ہیں!آپ پر سلام ہو اے نوحؑ کے وارث جو خدا کے نبی ہیں! آپ پر سلام ہو اے ابراہیمؑ کے وارث جو خدا کے خلیل ہیں! سلام ہو آپ پراے موسیٰ ؑکے وارث جو خدا کے کلیم ہیں!آپ پر سلام ہو اے عیسیٰؑ کے وارث جو خدا کی روح ہیں! سلام ہوآپ پر اے محمدؐ کے وارث جو خدا کے رسولوں کے سردار ہیں۔", "RArabic": "AS-SALAAMO A’LAIKA YAA WAARESA AADAMA SIFWATIL LAAHE AS-SALAAMO A’LAIKA YAA WAARESA NOOHIN NABIYYIL LAAHE AS-SALAAMO A’LAIKA YAA WAARESA IBRAAHEEMA KHALEELIL LAAHE AS-SALAAMO A’LAIKA YAA WAARESA MOOSAA KALEEMIL LAAHE AS-SALAAMO A’LAIKA YAA WAARESA E’ESAA ROOHIL LAAHE AS-SALAAMO A’LAIKA YAA WAARESA MOHAMMADIN SAYYEDE ROSOLIL LAAHE.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا وَارِثَ اٰدَمَ صَفْوَۃِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا وَارِثَ نُوْحٍ نَبِیِّ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا وَارِثَ اِبْرَاهِیْمَ خَلِیْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا وَارِثَ مُوْسٰی كَلِیْمِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا وَارِثَ عِیْسٰی رُوْحِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا وَارِثَ مُحَمَّدٍ سَیِّدِ رُسُلِ اللہِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013845, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O inheritor of Ali the successor of Allah’s Messenger. Peace be upon you, O inheritor of Hasan the Well-pleased. Peace be upon you, O inheritor of Fatima the daughter of Allah’s Messenger. Peace be upon you, O martyr and veracious. Peace be upon you, O obedient and pious successor. Peace be upon the souls that resided in your yard and settled next to your place.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Ali (a.s) ke waaris jo Rasool ke Wasi hai. Aap par salaam ho ay Hasan (a.s) ke waaris jo Khuda ke pasandida hai. Aap par salaam ho ay Fatema (s.a) ke waaris jo Rasool'e Khuda (s.a.w.a) ki dukhtar hai. Aap par salaam ho ay woh shaheed jo siddiq hai. Aap par salaam ho ay woh Wasi jo nek o parhez-gaar hai. Salaam ho un rooho’n par jo aap ke aastaane par utre’n aur apni sawaariya’n yahan baandhe’n.", "Urdu": "سلام ہو آپ پر اے علیؑ کے وارث جو مومنوں کے امیر اور اوصیاء میں سب سے بہتر ہیں آپ پر سلام ہو اے حسنؑ کے وارث جو پسندیدہ پاک راضی شدہ پسندیدہ ہیں آپ پر سلام ہوکہ آپ ہی صدیق اکبر ہیں آپ پر سلام ہو اے وصی جو نیک کردارپرہیز گار ہیں سلام ہو آپ پر اور ان روحوں پر جو آپ کے آستانے پر حاضر ہوتی ہیں اور یہاں اپنی سواریاں کھڑی کرتی ہیں۔", "RArabic": "AS-SALAAMO YAA WAARESA A’LIYYIN AMEERIL MOMINEENA WA KHAYRIL WASIYYEENA AS-SALAAMO A’LAIKA YAA WAARESAL HASANIR RAZI’YIT TAAHERIR RAAZIL MARZIYYE AS-SALAAMO A’LAIKA AYYOHAS SIDDEEQUL AKBARO AS-SALAAMO A’LAIKA AYYOHAL WASIYYUL BARRUT TAQIYYO AS-SALAAMO A’LAIKA WA A’LAL ARWAAHIL LATEE HALLAT BE FENAAA-EKA WA ANAAKHAT BE RAHLEK.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا وَارِثَ عَلِیٍّ اَمِیْرِ الْمُؤْمِنِیْنَ وَخَیْرِ الْوَصِیِّیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَا وَارِثَ الْحَسَنِ الرَّضِیِّ الطَّاهِرِ الرَّاضِی الْمَرْضِیِّ۔ اَلسَّلَامُ عَلَیْكَ اَیُّهَا الصِّدِّیْقُ الْاَكْبَرُ۔ اَلسَّلَامُ عَلَیْكَ اَیُّهَا الْوَصِیُّ الْبَرُّ التَّقِیُّ۔ اَلسَّلَامُ عَلَیْكَ وَعَلَی الْاَرْوَاحِ الَّتِیْ حَلَّتْ بِفِنَآئِكَ وَاَنَاخَتْ بِرَحْلِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013846, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon the angels of Allah who keep eyes on you. I bear witness that you performed the prayers, defrayed the poor-rate, enjoined the right, forbade the evil, and served Allah sincerely until death came upon you. Peace and Allah’s mercy and blessings be upon you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho Khuda ke farishto’n par jo aap ke gird rehte hai. Mai gawahi deta hu keh aap ne namaz qaaem ki aur zakaat di, aap ne nek kaamo ka hukm diya aur burey kaamo se roka, Khuda ki bandagi ki, hatta keh aap shaheed ho gaye. Aap par salaam ho aur Khuda ki rehmat ho aur Uski barkaat ho.", "Urdu": "سلام ہو آپ پر اور ان فرشتوں پر جو آپ کے گرد رہتے ہیں میں گواہی دیتا ہوں کہ آپ نے نماز قائم کی زکوٰۃ ادا کی، نیک کاموں کا حکم فرمایا اور برے کاموں سے منع کیا آپ نے بے دینوں سے جہاد کیا اور خدا کی بندگی میں رہے یہاں تک کہ شہید ہو گئے آپ پر سلام ہو اور خدا کی رحمت ہو اور اس کی برکات ہوں۔", "RArabic": "AS-SALAAMO A’LAIKA WA A’LAL MALAAA-EKATIL HAAF-FEENA BEKA ASH-HADO ANNAKA QAD AQAMTAS SALAATA WA AATAYTAZ ZAKAATA WA AMARTA BIL MA’ROOFE WA NAHAYTA A’NIL MUNKARE WA JAAHADTAL MULHEDEENA WA A’BADTAL LAAHA HATTAA ATAAKAL YAQEENO AS-SALAAMO A’LAIKA WA RAHMATUL LAAHE WA BARAKAATOHU.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ وَعَلَی الْمَلَآئِكَۃِ الْحَآفِّیْنَ بِكَ اَشْهَدُ اَنَّكَ قَدْ اَقَمْتَ الصَّلٰوۃَ وَاٰتَیْتَ الزَّكٰوۃَ وَاَمَرْتَ بِالْمَعْرُوْفِ وَنَهَیْتَ عَنِ الْمُنْكَرِ وَجَاهَدْتَ الْمُلْحِدِیْنَ وَعَبَدْتَ اللہَ حَتّٰی اَتٰیكَ الْیَقِیْنُ۔ اَلسَّلَامُ عَلَیْكَ وَرَحْمَۃُ اللہِ وَبَرَكَاتُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013847, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "After this go to the blessed grave. For each step you take you would be rewarded equal to that martyr who bathes in his blood in the path of Allah. When you reach near the grave, you stand up and put your hand on the grave and say…", "GujaratiDescription": null, "RUrduDescription": "Phir qabr ke paas jaawo. Har qadam ke badle mein tum ko woh sawaab milega jo Allah ki raha mein ek shahid ko milta hai. Jab qabr ke qareeb pohoncho, to apne haath ko qabr par daal kar is tarah kaho…", "UrduDescription": "پھر ضریح مبارک کی طرف چلے کہ اس کے اٹھائے جانے اور رکھے جانے والے ہر قدم کے بدلے میں اس کو ایسے شہیدِ راہ خدا کا ثواب ملے گا جو اپنے خون میں ڈوبا ہو جب ضریح پاک کے قریب پہنچے تو رک جائے اور اپنا ہاتھ قبرِ مبارک سے مس کرتے ہوئے یہ کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "