[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011687, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah: (please), among the matters that You decide and make, From among the inevitable affairs, and from among the wise matters that You make distinct, At the Grand Night From among the act that is neither rejected nor altered, That You decide me to be with the pilgrims to Your Holy House, At this year, Those whose pilgrimage is admitted, Whose efforts are praised, Whose sins are forgiven, and whose offenses and pardoned. and (please), among the matters that You decide and make, Decide to prolong my lifetime, and to expand my sustenance.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Jin umoor ka Tu Lailatul Qadr mein faisla karta hai, hatmi faislo’n mein se aur un ko muqarrar farmaata hai aur jin par hikmat umoor mein imteya-zaat deta hai aur aisi qaza o qadr mo’ayyan karta hai jis ko radd ya tabdil nahi kiya ja sakta us mein Tu mujhe is saal ke Hujjaaj mein qaraar de keh jin ka Hajj maqbool, jin ki saee (koshish) pasandida, jin ke gunah maaf, jin ki buraayi mita di gayi hai aur jin ka Tu ne faisla kiya us mein meri umr ko daraaz aur mere rizq ko wasee qaraar de.", "Urdu": "اے معبود! جن امور کا تو لیلۃ القدر میں فیصلہ کرتا ہے حتمی فیصلوں میں سے اور ان کو مقرر فرماتا ہے اور جن پُر حکمت کاموں میں امتیازات دیتا ہے اور ایسی قضا وقدر معین کرتا ہے جس کو ردّوبدل نہیں کیا جا سکتا اس میں تو مجھے اس سال کے حجاج میں قرار دے کہ جن کا حج مقبول، جن کی سعی پسندیدہ، جن کے گناہ معاف، جن کی برائیاں مٹا دی گئی ہیں اور جن کا تو نے فیصلہ کیا اس میں میری عمر کو دراز اور میرے رزق کو وسیع قرار دے اور میرے ساتھ یہ برتاؤکر۔", "RArabic": "ALLAAHUM-MAJ A’L FEE-MAA TAQZEE WA FEE-MAA TO-QADDE-RO MINAL AMRIL MAHTOO-ME WA FEE-MAA TAF-ROQO MINAL AMRIL HAKEEME FEE LAIY-LATIL QADRE MINAL QAZAA-IL LAZEE LAA YO-RADDO WA LAA YO-DADDA-LO AN TAKTO-BANEE MIN HUJJAAJE BAIY-TE-KAL HARAAME FEE HAAZAL MAB-ROORE HAJJO-HOMUL MASH-KOORE SA’YO-HOMUL MAGH-FOORE ZO-NOOBO-HOMUL MO-KAFFA-RE A’N-HUM SAIYYE-AATO-HUM WAJ-A’L FEE-MAA TAQZEE WA TO-QADDE-RO AN TOTEE-LA U’MREE WA TO-WASSE-A’ LEE FEE RIZQEE.", "ArabicText1": "اَللّٰهُمَّ اجْعَلْ فِيْمَا تَقْضِيْ وَفِيْمَا تُقَدِّرُ مِنَ الْاَمْرِ الْمَحْتُوْمِ وَفِيْمَا تَفْرُقُ مِنَ الْاَمْرِ الْحَكِيْمِ فِيْ لَيْلَةِ الْقَدْرِ مِنَ الْقَضَاءِ الَّذِيْ لَا يُرَدُّ وَلَا يُبَدَّلُ اَنْ تَكْتُبَنِيْ مِنْ حُجَّاجِ بَيْتِكَ الْحَرَامِ فِيْ عَامِيْ هٰذَا الْمَبْرُوْرِ حَجُّهُمُ الْمَشْكُوْرِ سَعْيُهُمُ الْمَغْفُوْرِ ذُنُوْبُهُمُ الْمُكَفَّرِ عَنْهُمْ سَيِّئَاتُهُمْ وَاجْعَلْ فِيْمَا تَقْضِيْ وَتُقَدِّرُ اَنْ تُطِيْلَ عُمْرِيْ وَتُوَسِّعَ لِيْ فِيْ رِزْقِيْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "Ar