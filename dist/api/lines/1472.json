[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010108, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O leader of those who do Sajdah! Peace be upon you, O prestige of pious ones! Peace be upon you, O participant of unhappiness and sadness! Peace be upon you, O that Imam, who got sores on spots which touched during sajdah! Peace be upon you, O one who wept and mourned! Peace be upon you, one who was captive of hardships! Peace be upon you, O one from the great worshippers! Peace be upon you, O son of Sayyadush Shohada (Husain)! Peace be upon you, O hope of pious ones! Peace be upon you, and Allah’s blessings and bounties on you!", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay sajdah karne waalo’n ke sardaar. Salaam ho aap par ay ibaadat karne waalo’n ke sardaar. Salaam ho aap par ay gham-zadah ke shareek. Salaam ho aap par ay woh zaat jis ke aaza’e sajdah (peshaani) par kasrat’e sajdeh se gatthe (nishaan) pad jaate hai. Salaam ho aap par ay girya karne waale. Salaam ho aap par ay aseer’e ranj o mahan (gham zadah). Salaam ho aap par ay Aale Aaba (Laqab’e Rasool’e Khuda) ki azmat ke haamil. Salaam ho aap par ay ahle kisa ki paanchwi fard (5th member) ke farzand. Salaam ho aap par ay sayadush shohadah ke farzand. Salaam ho aap par ay saahebaan’e taqwa ke pusht panah. Aap par salaam ho aur Khuda ki rehmat o barkat’e naazil ho.", "Urdu": "سلام ہو آپ پر اے سجدہ کرنے والوں کے سردار، سلام ہو آپ پر اے عبادت کرنے والوں کے سردار، سلام ہو آپ پر اے غمزدہ کے شریک، سلام ہو آپ پر اے وہ ذات جس کے اعضاء سجدہ پر کثرت سجدہ سے گٹھے پڑ جاتے ہیں، سلام ہو آپ پر اے گریہ کرنے والے، سلام ہو آپ پر اے اسیر رنج و  محن، سلام ہو آپ پر اے آل عبا کی عظمت کے حامل، سلام ہو آپ پر اے اہل کساء کی پانچوی فرد کے فرزند، سلام ہو آپ پر اے سید الشہداء کے  فرزند، سلام ہو آپ پر اے صاحبان تقویٰ کے پشت پناہ، آپ پر سلام ہو  اور رحمت و برکت خدا نازل ہو۔", "RArabic": "AS-SALAAMO A’LAIKA YAA SAYYA-DAS SAAJE-DEENA. AS-SALAAMO A’LAIKA YAA ZAI-NAL AA’BE-DEENA. AS-SALAAMO A’LAIKA YAA HANEE-FAL HASA-RAATE. AS-SALAAMO A’LAIKA YAA ZAS-SAFA-NAATE. AS-SALAAMO A’LAIKA YAA SAAHE-BAL A’BA-RAATE. AS-SALAAMO A’LAIKA YAA ASEE-RAL KORO-BAATE. AS-SALAAMO A’LAIKA YAA AADAMA AALIL E’BAAA-E. AS-SALAAMO A’LAIKA YABNA KHAAME-SE AH-LIL KESAAA-E. AS-SALAAMO A’LAIKA YABNA SAYYA-DISH SHOHA-DAAA-E. AS-SALAAMO A’LAIKA YAA E’MAA-DAL ATQE-YAAA-E. AS-SALAAMO A’LAIKA WA RAHMA-TUL LAAHE WA BARA-KAATO-HU.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ یَاسَیِّدَالسَّاجِدِیْنَ۔ اَلسَّلَامُ عَلَیْکَ یَازَیْنَ الْعَابِدِیْنَ۔ اَلسَّلَامُ عَلَیْکَ یَاحَنِیْفَ الْحَسَرَاتِ۔ اَلسَّلَامُ عَلَیْکَ یَاذَالثَّفَنَاتِ۔ اَلسَّلَامُ عَلَیْکَ یَاصَاحِبَ الْعَبَرَاتِ۔ اَلسَّلَامُ عَلَیْکَ یَااَسِیْرَالْکُرُبَاتِ۔ اَلسَّلَامُ عَلَیْکَ یَااٰدَمَ اٰلِ الْعِبَآئِ۔ اَلسَّلَامُ عَلَیْکَ یَابْنَ خَامِسِ اَھْلِ الْکِسَآئِ۔ اَلسَّلَامُ عَلَیْکَ یَابْنَ سَیِّدِالشُّہَدَآئِ۔ اَلسَّلَامُ عَلَیْکَ یَا عِمَادَالْاَتْقِیَآئِ۔ اَلسَّلَامُ عَلَیْکَ وَرَحْمَۃُاللہِ وَبَرَکَاتُہٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": n