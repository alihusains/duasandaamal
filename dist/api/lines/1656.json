[{"Id": 1011958, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Prophet Migrated from Makkah to Madina (1H)", "GujaratiDescription": null, "RUrduDescription": "Rasoole Khuda (s) ne Makkeh se Madine ki taraf hijrat ki (1H).", "UrduDescription": "بعثت کے تیرھویں سال اسی رات حضرت رسولؐ کی مکۂ معظمہ سے مدینۂ منورہ کو ہجرت کا آغاز ہوا۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1011959, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "At this night, prophet hid in Cave Thawr. Imam Ali (a) sacrificed himself, when he spent the night in the place of the Holy Prophet so as to give the latter enough time to leave Makkah safely and to arrive at his destination. Imam Ali (a) challenged the polytheists who had plotted to assassinate the Holy Prophet (s) by attacking him in his bed collectively. Thus, everybody confessed of Imam Ali’s bravery and courage, as well as his love for and fraternity with the Holy Prophet (s). Immortalizing this event, Almighty Allah revealed the following holy verse (2:207)…", "GujaratiDescription": null, "RUrduDescription": "Be’sat ke 13th saal is shab mein Rasoole Khuda (s) ne Makkah Mo’zama se Madina Munawwar ki taraf hijrat ka aaghaaz kiya, is raat Aaap (s) Ghaar-e-Saur mein poshida rahe aur Hazrat Ali (a) apni jaan aap par fida karne ke liye mushrik kabaael (kabilo’n) ki talwaaro’n se be-parwa ho kar Hazrat (s) ke bistar par sow rahe thay. Is tarah aap ne apni fazilat aur Hazrat ke saath apni ukhwat aur hamdardi ki azmat ko saare aalam par aash-kaar kar diya. Pas isi raat Amirul Momeneen (a) ki shaan mein yeh aayat naazil huwi (2:207)…", "UrduDescription": "حضرت امیرؑاپنی جان آپ پر فدا کرنے کے لئے مشرک قبائل کی تلواروں سے بے پرواہ ہو کر حضورؐ کے بستر پر سو رہے تھے۔ اس طرح آپ نے اپنی فضیلت اور حضورؐکے ساتھ اپنی اخوت و برادری اور ہمدردی کی عظمت کو سارے عالَم پر آشکار کردیا۔تو اسی رات امیرالمؤمنین ؑ کی شان میں یہ آیت(بقرہ،۲۰۷) نازل ہوئی۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1011960, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And among men is he who sells himself to seek the pleasure of Allah; and Allah is affectionate to the servants.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur logo’n mein woh bhi hai jo apne nafs ko marzi’e Parwardigaar ke liye bechh daalte hai aur Allah apne bando’n par bada maher-baan hai.", "Urdu": "اور لوگوں میں وہ بھی ہیں جو اپنے نفس کو مرضی پروردگار کے لئے بیچ ڈالتے ہیں۔", "RArabic": "WA MENAN NAASE MAIY-YASHREE NAFSA-HUB TEGHAA-A MARZAA-TIL LAAHE WAL-LAAHO RA-OO-FUM BIL E’BAADE.", "ArabicText1": "وَمِنَ النَّاسِ مَنْ يَّشْرِيْ نَفْسَهُ ابْتِغَاۗءَ مَرْضَاتِ اللهِ", "ArabicGreenSign1": null, "ArabicRedSign1": "ط ", "ArabicBlueSign1": null, "ArabicText2": "وَاللهُ رَءُوْفٌۢ بِالْعِبَادِ۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": n