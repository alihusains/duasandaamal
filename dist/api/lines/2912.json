bicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010086, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And there is no animal in the earth but on Allah is the sustenance of it, and He knows its resting place and its depository all (things) are in a manifest book.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur zameen par chalne waali koi makhlooq aisi nahi hai jiska rizq Khuda ke zimme na ho. Woh har ek ke sope jaane (thair ne) ki jagah aur uske qaraar ki manzil ko jaanta hai aur sab-kuchh kitaab'e mubin mein mehfooz hai.", "Urdu": "اور زمین پر چلنے والی کوئی مخلوق ایسی نہیں ہے جس کا رزق خدا کے ذمہ نہ ہو، وہ ہر ایک کے سونپے جانے کی جگہ اور اس کے قرار کی منزل کو جانتا ہے اور سب کچھ کتابِ مبین میں محفوظ ہے۔", "RArabic": "WA MAA MIN DAAABBATIN FIL ARZE ILLA ’ALAL LAAHE RIZQOHA WA YA’LAMO MUSTAQARRAHA WA MUSTAWDA’AHA; KULLUN FEE KITAABIM MUBEEN.", "ArabicText1": "وَمَا مِنْ دَاۗبَّةٍ فِي الْاَرْضِ اِلَّا عَلَى اللهِ رِزْقُهَا وَيَعْلَمُ مُسْتَقَرَّهَا وَمُسْتَوْدَعَهَا", "ArabicGreenSign1": null, "ArabicRedSign1": "ط ", "ArabicBlueSign1": null, "ArabicText2": "كُلٌّ فِيْ كِتٰبٍ مُّبِيْنٍ۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010087, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And if Allah should afflict you with harm, then there is none to remove it but He; and if He intends good to you there is none to repel His grace; He brings it to whom He pleases of His servants; and He is the Forgiving, the Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur agar Khuda nuqsaan pohonchana chahe to Uske alaawa koi bachaane waala nahi hai aur agar woh bhalaayi ka iraada kar le to Uske fazl ka koi rokne waala nahi hai woh jis ko chahta hai apne bando’n mein bhalaayi ataa karta hai Woh bada bakhsh ne waala aur maher-baan hai.", "Urdu": "اور اگر خدا نقصان پہنچانا چاہے تو اس کے علاوہ کوئی بچانے والا نہیں ہے اور اگر وہ بھلائی کا ارادہ کرلے تو اس کے فضل کا کوئی روکنے والا نہیں ہے وہ جس کو چاہتا ہے اپنے بندوں میں بھلائی عطا کرتا ہے وہ بڑا بخشنے والا اور مہربان ہے۔", "RArabic": "WA INY YAM SASKAL LAAHO BE-ZURRIN FALA KAASHEFA LAHU ILLA HOWA, WA INY YORIDKA BE-KHAIRIN FALA RA-AADDA LEFAZLEHI; YUSEEBO BEHI MAIY YASHAAA’O MIN ’EBAADEHI; WA HOWAL GHAFOORUR RAHEEM.", "ArabicText1": "وَاِنْ يَّمْسَسْكَ اللهُ بِضُرٍّ فَلَا كَاشِفَ لَهٗٓ اِلَّا هُوَ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": "ج ", "ArabicText2": "وَاِنْ يُّرِدْكَ بِخَيْرٍ فَلَا رَاۗدَّ لِفَضْلِهٖ", "ArabicGreenSign2": null, "ArabicRedSign2": "ط ", "ArabicBlueSign2": null, "ArabicText3": "يُصِيْبُ بِهٖ مَنْ يَّشَاۗءُ مِنْ عِبَادِهٖ", "ArabicGreenSign3": null, "ArabicRedSign3": "ط ", "ArabicBlueSign3": null, "ArabicText4": "وَهُوَ الْغَفُوْرُ الرَّحِيْمُ۔", "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010088, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah brings about ease after difficulty. Only that which Allah will shall come to pass. There is no power save in Allah. Allah is sufficient for us and most excellent is the Protector. And I entrust my affair to Allah. Surely, Allah sees the servants . There is no god but You. All glory be to You. Verily, I have been a wrongdoer. O Lord, surely I stand in need of whatever good You may send down to me. O my Lord, leave me not alone; and You are the best of inheritors.", "Gujarati": null, "RGujarati": null, "RUrdu": "An-qareeb Khuda tanghi ke baad wus’at ataa karega. Masha-Allah uske alaawa kisi ke paas koi quwwat nahi hai. Khuda kaafi hai aur wohi hamara zimme-daar hai. Aur mai to apne mamlaat ko Parwardigaar ke hawaale kar raha hu keh be-shak Woh tamaam bando’n ke haalaat ka khoob dekhne waala hai. Tere alaawa koi Khuda nahi hai Tu paak o be-neyaaz hai aur mai apne nafs par zulm karne waalo’n mein se tha. Parwardigaar yaqeenan mai us khair ka mohtaaj hu jo Tu meri taraf bhej de. Parwardigaar mujhe akela na chhod dena keh Tu tamaam waariso’n se behtar waaris hai.", "Urdu": "بہت جلد خدا سختی کے بعد آسانی عطا کرے گا جو اللہ چاہے وہ ہوگا نہیں کوئی قوت سوائے اللہ کے، اللہ ہمارے لئے کافی ہے وہ بہترین کارساز ہے اور میں اپنا ہر کام اللہ کے سپرد کرتا ہوں بے شک خدا اپنے بندوں کو خوب جانتا ہے تیرے سوا کوئی معبود نہیں تو پاک تر ہے بے شک میں ہی قصور وار تھا اے پروردگارتو مجھ کو جو بھی نعمت عطا کرے گا میں اس کی حاجت رکھتا ہوں میرے رب مجھ کو اکیلا نہ چھوڑ جب کہ بہترین وارث تو ہی ہے۔", "RArabic": "SA YAJ’ALUL LAAHO BA’DA USRINY YUSRA. MAASHA ALLAAHO LA QUWWATA ILLA BILLAAH. HASBO NALLAAHO WA NE’MAL VAKIL. WA OFAWWEZO AMREE ILALLAAH; INNALLAAHA BASEERUM BIL’EBAAD. LA ILAAHA ILLA ANTA SUBHAANAKA INNI KUNTO MENAZ ZAALIMEEN. RABBI INNI LEMAA ANZALTA ELAIYYA MIN KHAIREEN FAQEER. RABBI LA TAZARNI FARDAN WA ANTA KHAIRUL WAARESEEN.", "ArabicText1": "سَيَجْعَلُ اللهُ بَعْدَ عُسْرٍ يُّسْرًا۔ مَا شَاۗءَ اللهُ لَا قُوَّةَ اِلَّا بِاللهِ۔ حَسْبُنَا اللهُ وَنِعْمَ الْوَكِيْلُ۔ وَاُفَوِّضُ اَمْرِيْٓ اِلَى اللهِ", "ArabicGreenSign1": null, "ArabicRedSign1": "ط ", "ArabicBlueSign1": null, "ArabicText2": "اِنَّ اللهَ بَصِيْرٌۢ بِالْعِبَادِ۔ لَآ اِلٰهَ اِلَّآ اَنْتَ سُبْحٰنَكَ اِنِّيْ كُنْتُ مِنَ الظّٰلِمِيْنَ۔ رَبِّ اِنِّيْ لِمَآ اَنْزَلْتَ اِلَيَّ مِنْ خَيْرٍ فَقِيْرٌ۔ رَبِّ لَا تَذَرْنِيْ فَرْدًا وَّاَنْتَ خَيْرُ الْوٰرِثِيْنَ۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "Ar