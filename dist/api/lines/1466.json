[{"Id": 1010432, "EnglishTitle": "Friday has been assigned to Imam Mahdi (a)", "GujaratiTitle": null, "RUrduTitle": "Friday Imam Mahdi (a) se mansoob hai", "UrduTitle": "جمعہ حضرت صا حب الزمان (عج) کا دن ہے اور یہ وہی دن ہے جس دن آپ ظہور فرمائیں گے لہازا ان کی یہ زیارت پڑھیں۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010153, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O argument of Allah in His lands! Peace be upon you, O sight of Allah on His creatures! Peace be upon you, O light of Allah by which those who have been guided [to the true guidance] are guided and by which the believers are relieved! Peace be upon you, O polite and fearful!", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay zameen par hujjat’e Khuda. Salaam ho aap par ay Allah ki makhluq par Khuda ki jaanib se nighrah . Salaam ho aap par noor'e Khuda jis se hidaayat haasil karne waale hidaayat paate hai aur jiske zariye momeneen masaayeb se chutkaara paate hai. Salaam ho aap par ay saahebe tehzib aur Khuda se khouf zadah rehne waale.", "Urdu": "آپ پر سلام ہو جو خدا کی زمین میں اس کی حجت ہیں آپ پر سلام ہو جو خدا کی مخلوق میں اس کی آنکھ ہیں آپ پر سلام ہو جو خدا کے وہ نور ہیں جس سے ہدایت چاہنے والے ہدایت پاتے ہیں اور جس سے مومنوں کو کشادگی وآسودگی ملتی ہے آپ پر سلام ہو جو نیک طینت ڈرنے والے ہیں!", "RArabic": "ASSALAAMO A’LAYKA YAA HUJJATAL LAAHE FEE ARZEHI ASSALAAMO A’LAYKA YAA AYNAL LAAHE FEE KHALQEHI ASSALAAMO A’LAYKA YAA NOORAL LAAHIL LAZEE YAHTADEE BEHIL MOHTADOONA WA YOFARRAJO BEHEE A’NIL MOMINEENA ASSALAAMO A’LAYKA AYYOHAL MOHAZZABUL KHAAA-EFO.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ یَاحُجَّۃَ اللہِ فِیْ اَرْضِہٖ۔ اَلسَّلَامُ عَلَیْکَ یَاعَیْنَ اللہِ فِیْ خَلْقِہٖ۔ اَلسَّلَامُ عَلَیْکَ یَانُوْرَاللہِ الَّذِیْ یَھْتَدِیْ بِہِ الْمُھْتَدُوْنَ وَیُفَرَّجُ بِہٖ عَنِ الْمُؤْمِنِیْنَ۔ اَلسَّلَامُ عَلَیْکَ اَیُّھَاالْمُھَذَّبُ الْخَآئِفُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010431, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O sincere patron! Peace be upon you, O ark of salvation! Peace be upon you, O essence of life! Peace be upon you. May Allah send blessings to you and upon your Household, the pure and immaculate. Peace be upon you. May Allah hasten that which He has promised you; namely, victory and prevalence of your authority.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay khair khwa sar-parast. Salaam ho aap par ay khasti’e najaat. Salaam ho aap par ay chashme hayaat. Salaam ho aap par aur Allah ka durood ho aap par aur aap ke tayyab o taahir ahle khaana par. Salaam ho aap par, Allah ne aap se jis nusrat aur amr ke zuhoor ka waada kiya hai uski takmil me jaldi kare.", "Urdu": "آپ پر سلام ہو اے خیر خواہ و سرپرست! آپ پر سلام ہو اے کشتیِ نجات! آپ پر سلام ہو اے چشمۂ حیات! آپ پر سلام ہو خدا کی رحمت ہو آپؑ پر اورآپ کے پاک و پاکیزہ خاندانؑ پر آپ پر سلام ہو خدا اس امر کے ظہور اور نصرت میں جس کا وعدہ اس نے آپ سے کیا ہے۔", "RArabic": "ASSALAAMO A’LAYKA AYYOHAL WALIYYUN NAASEHO ASSALAAMO A’LAYKA YAA SAFEENATAN NAJAATE ASSALAAMO A’LAYKA YAA A’YNAL HAYAATE ASSALAAMO A’LAYKA SALLAL LAAHO A’LAYKA WA A’LAA AALE BAYTEKAT TAYYABEENAT TAAHEREENA ASSALAAMO A’LAYKA A’JJALAL LAAHO LAKA MAA WA A’DAKA MENAN NASRE WA ZOHOORIL AMRE.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ اَیُّھَاالْوَلِیُّ النَّاصِحُ۔ اَلسَّلَامُ عَلَیْکَ یَاسَفِیْنَۃَ النَّجَاۃِ۔ اَلسَّلَامُ عَلَیْکَ یَاعَیْنَ الْحَیَاۃِ۔ اَلسَّلَامُ عَلَیْکَ صَلَّی اللہُ عَلَیْکَ وَعَلٰی اٰلِ بَیْتِکَ الطَّیِّبِیْنَ الطَّاھِرِیْنَ۔ اَلسَّلَامُ عَلَیْکَ عَجَّلَ اللہُ لَکَ مَا وَعَدَکَ مِنَ النَّصْرِوَ ظُھُوْرِالْاَمْرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010154, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O my master. I am a servant of you and I recognize the first and the last of your affair. I seek nearness to Allah, the Exalted, through your Household and you and I am expecting your advent and the prevalence of the truth at your hands. And I beseech Allah to send blessings to Muhammad and the Household of Muhammad. And to include me with those who are expecting you, those who follow you and support you against your enemies, and those who will be martyred in front of you in the group of your loyalists.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay mere maula o aaqa mai aap ka ghulam hu aur aap ke aaghaz o anjaam ki maarefat rakhta hu. Mai aap ke zariye aur aap ke ghar waalo’n ke zariye Allah ka taqarrub (nazdiki) chahta hu aur aap ke zuhoor ka muntazir hu keh aap ke haatho’n par haq'e zuhoor pazir ho. Aur mai Khuda se sawaali hu keh woh Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil kare. Aur mujh ko aap ke intezaar karne waalo’n, aap ke pairo-kaaro’n aur aap ke dushmano ke muqaabil mein aap ki madad karne waalo’n aur aap ke ru-baru (saath) jam'e shahadat nosh karne waalo’n aur aap ke dosto’n mein qaraar de.", "Urdu": "آپؑ پر سلام ہو اے میرے سردار میں آپ کا غلام ہوں آپ کے آغاز و انجام سے واقف ہوں میں خدا کی قربت چاہتا ہوں آپ کا اور آپ کے خاندان کے و سیلے کا انتظار کرتا ہوں آپ کے ظہوراورآپ کے ہا تھو ں حق کے ظہو ر کا اور خد ا سے سو ال کرتا ہوں کہ وہ محمدؐ و آلؑ محمدؐ پر رحمت فرمائے اور مجھے آپ کے انتظار کرنے والوں اور پیروی کرنے والوں اور آپ کے دشمنوں کے مقابل آپ کے مددگاروں اور آپ کے سامنے شہید ہونے والے آپ کے دوستوں میں سے قرار دے!", "RArabic": "ASSALAAMO A’LAYKA YAA MAWLAAYA ANAA MAWLAAKA A’AREFUN BE OOLAAKA WA UKHRAAKA ATAQARRABO ELAL LAAHE TA-A’ALAA BEKA WA BE AALE BAYTEKA WA ANTAZERO ZOHOORAKA WA ZOHOORAL HAQQE A’LAA YADAYKA WA AS-ALUL LAAHA AYN YOSALLEYA A’LAA MOHAMMADIN WA AALE MOHAMMADIN WA AN YAJA’LANI MENAL MUNTAZEREENA LAKA WAT TAABE-E’ENA WAN NAASEREENA LAKA A’LAA AA’-DAAAEKA WAL MUSTASH-HADEENA BAYNA YADAYKA FEE JUMLATE AWLEYAAA-EKA.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ یَامَوْلَایَ اَنَا مَوْلَاکَ عَارِفٌۢ بِاُوْلَاکَ وَاُخْرَاکَ اَتَقَرَّبُ اِلَی اللہِ تَعٰالٰی بِکَ وَبِآلِ بَیْتِکَ وَاَنْتَظِرُ ظُھُوْرَکَ وَ ظُھُوْرَ الْحَقِّ عَلٰی یَدَیْکَ وَاَسْئَلُ اللہَ اَنْ یُصَلِّیَ عَلٰی مُحَمَّدٍوَّآلِ مُحَمَّدٍ وَاَنْ یَّجْعَلَنِیْ مِنَ الْمُنْتَظِرِیْنَ لَکَ وَالتَّابِعِیْنَ وَالنَّاصِرِیْنَ لَکَ عَلٰی اَعْدَآئِکَ وَالْمُسْتَشْھَدِیْنَ بَیْنَ یَدَیْکَ فِیْ جُمْلَۃِ اَوْلَیَآئِکَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "Arabi