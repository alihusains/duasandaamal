[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009902, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to He whose Arsh is in the heavens! Glory be to He whose Will operates in the earth! Glory be to He who examines (the dead) in the graves! Glory be to He who surfaced a path over the ocean! Glory be to He who has the total control over the Fire! Glory be to He who surrounds the Paradise with (His) mercy! Glory be to He who will do justice on the Day of Judgment! Glory be to He who raised the sky! Glory be to He who spread the earth! Glory be to He from whom there is no running away unless (one takes refuge) with Him!", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai woh zaat jiska arsh aasmaan mein hai. Paak hai woh zaat jiska hukm zameen mein naafiz hai. Paak hai woh zaat jiska faisla qabro’n mein naafiz hai. Paak hai woh zaat jiska dariya (river) mein raasta hai. Paak hai woh zaat jo Jahannam par ikhteyaar rakhta hai. Paak hai woh zaat Jannat mein jiski rehmat hai. Paak hai woh zaat qayamat mein jiska adl hai. Paak hai woh zaat jisne aasmaan ko buland kiya. Paak hai woh zaat jisne zameen beechhaayi. Paak hai woh zaat jis se panah o najaat nahi magar usi ke yahan se.", "Urdu": "پاک ہے وہ خدا جس کا عرش آسمان میں ہے پاک ہے وہ خدا جس کا حکم زمین میں نافذ ہے پاک ہے وہ خد اجس کا فیصلہ قبروں میں نافذ ہے پاک ہے وہ خدا جس کا دریا میں راستہ ہے پاک ہے وہ خدا جو جہنم پر اختیار رکھتا ہے پاک ہے وہ خدا جنت میں جس کی رحمت ہے پاک ہے وہ خداقیامت میں جس کا عدل ہے پاک ہے وہ خدا جس نے آسمان بلند کیا پاک ہے وہ خدا جس نے زمین بچھائی پاک ہے وہ خدا جس سے پناہ و نجات نہیں مگر اسی کے ہاں سے۔", "RArabic": "SUBHAA-NAL LAZEE FIS SAMAA-E A’R-SHO-HU. SUBHAA-NAL LAZEE FIL ARZE HUKMO-HU. SUBHAA-NAL LAZEE FIL QOBOO-RE QAZAAA-O-HU. SUBHAA-NAL LAZEE FIL BAHRE SABEELO-HU. SUBHAA-NAL LAZEE FIN NAARE SULTAANO-HU. SUBHAA-NAL LAZEE FIL JANNATE RAHMATO-HU. SUBHAA-NAL LAZEE FIL QEYAA-MATE A’D-LOHU. SUBHAA-NAL LAZEE RAFA-A’S SAMAAA-A. SUBHAA-NAL LAZEE BASA-TAL ARZA. SUBHAA-NAL LAZEE LAA MALJA-A WA LAA MANJAA MINHO ILLAA ILAIHE.", "ArabicText1": "سُبْحَانَ الَّذِیْ فِی السَّمَآئِ عَرْشُہٗ۔ سُبْحَانَ الَّذِیْ فِی الْاَرْضِ حُکْمُہٗ۔ سُبْحَانَ الَّذِیْ فِی الْقُبُوْرِ قَضَآؤُہٗ۔ سُبْحَانَ الَّذِیْ فِی الْبَحْرِ سَبِیْلُہٗ۔ سُبْحَانَ الَّذِیْ فِی النَّارِ سُلْطَانُہٗ۔ سُبْحَانَ الَّذِیْ فِی الْجَنَّۃِ رَحْمَتُہٗ۔ سُبْحَانَ الَّذِیْ فِی الْقِیٰمَۃِ عَدْلُہٗ۔ سُبْحَانَ الَّذِیْ رَفَعَ السَّمَآئَ۔ سُبْحَانَ الَّذِیْ بَسَطَ الْاَرْضَ۔ سُبْحَانَ الَّذِیْ لَا مَلْجَاَ وَلَا مَنْجَا مِنْہُ اِلَّا اِلَیْہِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null