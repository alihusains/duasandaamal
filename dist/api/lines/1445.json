AL HARAME WA MALEKA-TAL BAT-HAAA-E. AS-SALAAMO A’LAIKE YAA AWWALA MAN SADDA-QAT RASOOLIL LAAHE MINAN NESAAA-E. AS-SALAAMO A’LAIKE YAA MAN WA FAT BIL O’BOO-DIYYA-TE HAQQAL WAFAAA-E WA ASLA-MAT NAFSA-HAA WA AN-FAQAT MAA-LAHAA LE-SAYYEDIL AMBIYAA-E. AS-SALAAMO A’LAIKE YAA QAREENA-TA HABEE-BE ILAA-HIS SAMAA-IL MUZZAW-WAJA-TE BE-KHOLAA-SATIL ASFE-YAAA-E YABNA-TA IBRAAHEE-MAL KHALEE-LE.", "ArabicText1": "اَلسَّلَامُ عَلَيْكِ يَااُمَّ الْاَئِمَّةِ الطَّاهِرِيْنَ۔ اَلسَّلَامُ عَلَيْكِ يَااُمَّ الْمُؤْمِنِيْنَ۔ اَلسَّلَامُ عَلَيْكِ يَااُمَّ الْمُؤْمِنَاتِ۔ اَلسَّلَامُ عَلَيْكِ يَاخَالِصَةَ الْمُخْلِصَاتِ۔ اَلسَّلَامُ عَلَيْكِ يَاسَيِّدَةَ الْحَرَمِ وَمَلِكَةَ الْبَطْحَآءِ۔ اَلسَّلَامُ عَلَيْكِ يَااَوَّلَ مَنْ صَدَّقَتْ رَسُوْلِ اللهِ مِنَ النِّسَآءِ۔ اَلسَّلَامُ عَلَيْكِ يَامَنْ وَفَتْ بِالْعُبُوْدِيَّةِ حَقَّ الْوَفَآءِ وَاَسْلَمَتْ نَفْسَهَا وَاَنْفَقَتْ مَالَهَا لِسَيِّدِ الْاَنْبِيَآءِ۔ اَلسَّلَامُ عَلَيْكِ يَاقَرِيْنَةَ حَبِيْبِ اِلٰهِ السَّمَآءِ الْمُزَّوَّجَةِ بِخُلَاصَةِ الْاَصْفِيَآءِ يَابْنَةَ اِبْرَاهِيْمَ الْخَلِيْلِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": 