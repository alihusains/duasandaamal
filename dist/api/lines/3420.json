[{"Id": 1014814, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Imam Ali (a) is reported to have advised those who intend to neutralize the spell that is cast upon them to write down the following statements on a parchment made of an antelope’s skin and then hang it on the body…", "GujaratiDescription": null, "RUrduDescription": "Hazrat Ameerul Momeneen Ali ibne Abi Talib (a) se riwaayat hai keh jadoo ka tod karne ke liye yeh taweez hiran ki khaal (deer skin) par likh kar apne paas rakhe…", "UrduDescription": "حضرت امیر المومنین علی ؑابن ابی طالب ؑ سے مروی ہے : جادو کا توڑ کرنے کے لئے یہ تعویذ ہرن کی کھال پر لکھ کر اپنے پاس رکھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014815, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke naam se aur Khuda ki zaat se, Khuda ke naam se aur jo Khuda chahe aur Khuda ke naam se aur nahi koi taaqat o quwwat magar jo Khuda se hai. Moosa (a.s) ne kaha: Tum jo jadoo le kar aaye ho Khuda usko baatil kar dega, be-shak Khuda fasaad karne waalo’n ka bhala nahi karta. Pas haq ghaalib aaya aur jo kuchh unho ne kiya barbaad ho gaya to wohi shikast kha gaye aur zaleel ho kar waapas chale gaye.", "Urdu": "خدا کے نام سے اور خدا کی ذات سے خدا کے نام سے اور جو خدا چاہے اور خدا کے نام سے اور نہیں طاقت وقوت مگر جو خدا سے ہے موسیٰؑ نے کہا: تم جو جادو لے کر آئے ہو یقینًا ًخدا اس کو باطل کر دے گا بے شک خدا فساد کرنے والوں کا بھلا نہیں کرتا پس حق غالب آیا اور جو کچھ انہوں نے کیا برباد ہوگیا تو وہیں شکست کھا گئے اور ذلیل ہو کر واپس چلے گئے۔", "RArabic": "BISMILLAAHE WA BILLAAHE, BISMILLAAHE WA MAASHAA-ALLAAHO, BISMILLAAHE WA LAA HAWLA WA LAA QUWWATA ILLAA BILLAAHE QAALA MOOSAA MAA JE-TUM BEHIS SEHRO INNAL LAAHA SA-YUBTE-LOHU INNAL LAAHA LAA YUS-LEHO A’MA-LAL MUFSE-DEENA FAWQA-A’L HAQQO WA BATA-LA MAA KAANOO YA’MALOO-NA FA-GHOLE-BOO HONAA-LEKA WAN-QALA-BOO SAA-GHE-REENA.", "ArabicText1": "بِسْمِ اللهِ وَبِاللهِ بِسْمِ اللهِ وَمَاشَاۗءَ اللهُ بِسْمِ اللهِ وَلَاحَوْلَ وَلَا قُوَّةَ اِلَّا بِاللهِ قَالَ مُوْسٰى مَا جِئْتُمْ بِهِ السِّحْرُ اِنَّ اللهَ سَيُبْطِلُهٗ اِنَّ اللهَ لَايُصْلِحُ عَمَلَ الْمُفْسِدِيْنَ فَوَقَعَ الْحَقُّ وَبَطَلَ مَا كَانُوْا يَعْمَلُوْنَ فَغُلِبُوْا هُنَالِكَ وَانْقَلَبُوْا صَاغِرِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText