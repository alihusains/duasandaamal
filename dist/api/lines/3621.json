[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016088, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah is great in His greatness, and abundant praise belongs to Allah; Glory be to Exalted Allah, and praise is due to His Honour both morning and night. And bow down to Him for a part of the night, and glorify Him for a long time at night. There is no god save Allah, the One; He has fulfilled His word, granted victory to [helped] His servant, and alone defeated the parties.", "Gujarati": null, "RGujarati": null, "RUrdu": "Allah ki kibriyaa’ee buland-tar hai. Allah ki hamd be-paaya’n hai, aur paak hai Parwardigaar'e Azeem, aur hamd hai Khuda'e maher-baan ke liye subh o shaam. Raat ke kuchh hisse mein Uske liye sajdah karo aur raat ke waqt Uski tasbeeh karo taweel mudad tak, aur nahi hai koi ma’bood siwaaye us Khuda'e waahid ke jis ne apne waade ko pura kiya aur apne bande ki madad ki aur tanha kufr o nifaaq ke giroh ko naabood kiya.", "Urdu": "اللہ کی کبریائی بلند تر ہے، اللہ کی حمد بےپایاں ہے اور پاک ہے، پروردگار عظیم اور حمد ہے خدا ئے مہربان کے لئے صبح و شام۔ رات کے کچھ حصے میں اس کے لئے سجدہ کرو اور رات کے وقت اسکی تسبیح کرو طویل مدت تک اور نہیں ہے کوئی معبود سوائے اس خدائے واحد کے جس نے اپنے وعدے کو پورا کیا اور اپنے بندے کی مدد کی اور تنہا کفر و نفاق کے گروہوں کو نابود کیا۔", "RArabic": "ALLAAHO AKBARO KABEE-RAN, WAL HAMDO LIL-LAAHE KASEE-RAN. WA SUBHAA-NAL LAAHIL A’ZEEME WA BE-HAMDE-HIL KAREEME BUKRA-TAN WA ASEE-LAN, WA MENAL LAIYLE FAS-JUD LAHU WA SABBEH-HO LAIY-LAN TAWEE-LAN, LAA ILAAHA ILLAL-LAAHO WAHDA-HU, AN-JAZA WA’DA-HU, WA NASARA A’BDA-HU, WA HAZA-MAL AH-ZAABA WAHDA-HU.", "ArabicText1": "اَللہُ اَكْبَرُ كَبِیْرًا، وَالْحَمْدُ لِلهِ كَثِیْرًا، وَسُبْحَانَ اللهِ الْعَظِیْمِ وَبِحَمْدِهِ الْكَرِیْمِ بُكْرَۃً وَاَصِیْلًا، وَمِنَ الَّیْلِ فَاسْجُدْ لَهٗ وَسَبِّحْهُ لَیْلًا طَوِیْلًا، لَآ اِلٰهَ اِلَّا اللهُ وَحْدَهٗ، اَنْجَزَ وَعْدَهٗ، وَنَصَرَ عَبْدَهٗ، وَهَزَمَ الْاَحْزَابَ وَحْدَهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016089, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Nothing is there before or after Him; He is the One Who gives life or causes death, and He is the living Who never dies or passes away. All good is in His hand; the return of all is to Him, and He has power over all things. O Lord! Forgive and have mercy and pardon and be gracious and excuse what Thou knowest, surely Thou knowest what we do not know, verily Thou art Allah, the All-mighty, the most Generous.", "Gujarati": null, "RGujarati": null, "RUrdu": "Nahi hai koi shai Us se pehle aur na Uske baad. Woh zindah karta hai aur maut deta hai aur Woh aisa zindah rehne waala hai jiske liye maut nahi aur jo hargiz khatm nahi hoga. Khair Uske haath mein hai aur sab ko Uski taraf palat kar jaana hai aur Woh har baat ki qudrat rakhta hai. Parwardigaar! Mujhe maaf kar de, rahem farma aur bakhsh de aur lutf kar aur dar-guzar farma hamare un amaal se jis ko Tu jaanta hai. Be-shak Tu jaanta hai har woh cheez jo ham nahi jaante. Be-shak Tu hi Khuda'e azeez wa buzurg-waar hai.", "Urdu": "نہیں ہے کوئی شئے اس سے پہلے اور نہ اسکے بعد، وہ زندہ کرتا ہے اور مار ڈالتا ہے اور وہ ایسا زندہ رہنے والا ہے جس کے لئے کوئی موت نہیں اور جو ہرگز ختم نہیں ہوگا، خیر اس کے ہاتھ میں ہے اور سب کو اسکی طرف پلٹ کر جانا ہے اور وہ ہر بات کی قدرت رکھتا ہے۔ پروردگار! مجھے معاف کردے، رحم فرما اور بخش دے اور لطف کر اور درگزر فرما ہمارے ان اعمال سے جنہیں تو جانتا ہے، بے شک تو جانتا ہے ہر سہ چیز جو ہم نہیں جانتے بیشک توہی خدائے عزیز و بزورگوار ہے۔", "RArabic": "LAA SHAI-A QABLA-HU WA LAA BA’DA-HU, YOHYE WA YOMEE-TO, WA HOWA HAIYYUL LAA YAMOO-TO WA LAA YAFOO-TO ABA-DAN, BE-YADE-HIL KHAIRO WA ILAI-HIL MASEE-RO, WA HOWA A’LAA KULLE SHAI-IN QADEE-ROON, RABBIGH-FIR WAR-HAM WA’FO WA TAKAR-RAM WA TAJAA-WAZ A’MMAA TA’LAM INNA-KA TA’LAMO MAA LAA NA’LAM.", "ArabicText1": "لَا شَیْءَ قَبْلَهٗ وَلَا بَعْدَهٗ، یُحْیِ وَیُمِیْتُ، وَهُوَ حَیُّ لَّا یَمُوْتُ وَلَا یَفُوْتُ اَبَدًا، بِیَدِهِ الْخَیْرُ وَاِلَیْهِ الْمَصِیْرُ، وَهُوَ عَلٰی كُلِّ شَیْئٍ قَدِیْرٌ، رَبِّ اغْفِرْ وَارْحَمْ وَاعْفُ وَتَكَرَّمْ وَتَجَاوَزْ عَمَّا تَعْلَمْ اِنَّكَ تَعْلَمُ مَالَا نَعْلَمْ، اِنَّكَ اَنْتَ اللهُ الْاَعَزُّ الْاَكْرَمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016090, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Lord! Save us from Fire, and make us safe, successful, happy, rejoicing with Thy righteous servants, with those who are blessed by Thee – the Prophets, the truthful, the martyrs, and the righteous-and what good companions are those. That is the bounty of Allah, and it is enough that Allah is All-knowing. There is no god save Allah, truly right. There is no god save Allah and only Him we do worship; we make our religion sincerely His, though the unbelievers may be averse.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar! Hamein najaat de Jahannam se dar-haali keh ham saalim hai, behrah-mand hai aur khush hai aur hamein Jannat ki khush-khabari de apne saaleh bando’n ke saath jinhe Tu ne apne inaam se nawaaza hai aur jo anbiya, siddiqain, shaheed aur saaleheen hai aur yeh log kya khub rafiq (dost) hai. Yeh Allah ki taraf se fazl hai aur Allah hi kaafi hai jo aaleem o daana hai. Nahi koi ma’bood siwaaye Us Khuda'e waahid ke jo bar-haq hai, bar-haq hai. Nahi koi ma’bood siwaaye Allah ke aur ham ibaadat nahi karte siwaaye Uske kisi aur ki aur mukhlisaana taur par Uske deen ki pairawi karte hai, agar-che kaafiro’n ko yeh pasand na ho.", "Urdu": "پروردگار! ہمیں نجات دے جہنم سے درحاکہ کہ ہم سالم ہیں، بہرہ مند ہیں اور خوش ہیں اور ہمیں جنت کی خوشخبری دے اپنے صالح بندوں کے ساتھ جنہیں تو نے اپنے انعام سے نوازا ہے اور جو انبیاء، صدیقین، شہدا اور صالحین ہیں اور یہ لوگ کیا خوب رفیق ہیں، یہ اللہ کی طرف سے فضل ہے اور اللہ ہی کافی ہے جو عالم و دانا ہے، نہیں معبود سوائے اس خدائے واحد کے جو برحق ہے، برحق ہے۔ نہیں معبود سوائے اللہ کے اور ہم عبادت نہیں کرتے سوائے اسکے کسی اور کی اور مخلصانہ طور پر اسکے دین کی پیروی کرتے ہیں اگر چہ کافروں کو یہ پسند نہ ہو۔", "RArabic": "RABBE NAJJE-NA MENAN NAARE SAALE-MEENA GHAANE-MEENA, FARE-HEENA MUSTAB-SHE-REENA MA-A’ E’BAADE-KAS SAALE-HEENA, MA-A’L LAZEENA AN-A’MAL LAAHO A’LAI-HIM MENAN NABIY-YEENA WAS SIDDEE-QEENA WASH-SHOHADAA-E WAS-SAALE-HEENA WA HASANO OO-LAAA'e KA RAFEE-QAN, ZAALE-KAL FAZLO MINAL LAAHE WA KAFAA BIL-LAAHE A’LEE-MAN, LAA ILAAHA ILLAL LAAHO HAQQAN HAQQAN, LAA ILAAHA ILLAL LAAHO.", "ArabicText1": "رَبِّ نَجِّنَا مِنَ النَّارِ سَالِمِیْنَ غَانِمِیْنَ، فَرِحِیْنَ مُسْتَبْشِرِیْنَ مَعَ عِبَادِكَ الصَّالِحِیْنَ، مَعَ الَّذِیْنَ اَنْعَمَ اللهُ عَلَیْهِمْ مِنَ النَّبِیِّیْنَ وَالصِّدِّیْقِیْنَ وَالشُّهَدَائِ وَالصَّالِحِیْنَ وَحَسَنُ اُوْلٰۗئِكَ رَفِیْقًا، ذٰلِكَ الْفَضْلُ مِنَ اللهِ وَكَفٰی بِاللهِ عَلِیْمًا، لَآ اِلٰهَ اِلَّا اللهُ حَقًّاحَقًّا، لَآ اِلٰهَ اِلَّا اللهُ وَلَا نَعْبُدُ اِلَّا اِیَّاهُ، مُخْلِصِیْنَ لَهۃ الدِّیْنُ وَلَوْكَرِهَ الْكَافِرُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1003199, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 158, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Surely the Safa and the Marwa are among the signs appointed by Allah; so whoever makes a pilgrEnglishImage to the House or pays a visit (to it), there is no blame on him if he goes round them both; and whoever does good spontaneously, then surely Allah is Grateful, Knowing.", "Gujarati": null, "RGujarati": null, "RUrdu": "Be-shak Safa aur Marwa dono pahaadiya Allah ki nishaniyo’n mein se hai lehaaza jo shakhs bhi hajj ya umrah kare uske liye koi harj nahi hai keh un dono pahaadiyo’n ka chakkar lagaaye aur jo mazeed khair karega to Khuda uske amal ka qadr-daan aur us se khoob waaqif hai.", "Urdu": "بے شک صفا اور مروہ دونوں پہاڑیاں اللہ کی نشانیوں میں ہیں لہٰذاجو شخص بھی حج یا عمرہ کرے اس کے لئے کوئی حرج نہیں ہے کہ ان دونوں پہاڑیوں کا چکر لگائے اور جو مزید خیر کرے گا تو خدا اس کے عمل کا قدر دان اوراس سے خوب واقف ہے۔", "RArabic": "INNAS SAFAA WAL-MARWATA MIN SHA’AAA’IRIL LAAHI FAMAN HAJJAL BAITA AWI’TAMARA FALAA JUNAAHA ’ALAIHI AI YATTAWWAFA BIHIMAA; WA MAN TATAWWA’A KHAIRAN FA INNAL LAAHA SHAAKIRUN’ALEEM.", "ArabicText1": "اِنَّ الصَّفَا وَالْمَرْوَةَ مِنْ شَعَآئِرِ اللهِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": "ج ", "ArabicText2": "فَمَنْ حَجَّ الْبَيْتَ اَوِ اعْتَمَرَ فَلَا جُنَاحَ عَلَيْهِ اَنْ يَّطَّوَّفَ بِهِمَا", "ArabicGreenSign2": null, "ArabicRedSign2": "ط ", "ArabicBlueSign2": null, "ArabicText3": "وَمَنْ تَطَوَّعَ خَيْرًا فَاِنَّ اللهَ شَاكِرٌ عَلِيْمٌ", "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSi