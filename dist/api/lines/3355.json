[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012377, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O son of Allah’s Messenger. Peace be upon you, O son of the Commander of the Faithful. Peace be upon you, O son of the veracious, immaculate lady Fatimah the Doyenne of the women of the world. Peace be upon you, O my master Abu Abdullah. So be upon you Allah’s mercy and blessings.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay Rasoole Khuda (s.a.w.a) ke farzand. Salaam ho aap par ay Ameerul Momineen (a.s) ke farzand. Salaam ho aap par ay Fatema-tuz-Zahra (s.a) ke farzand jo bohot hi sachchi, paakeeza aur tamaam jahano ki aurto’n ki sardaar hai. Aap par salaam ho ay mere maula ay Aba Abdillah. Khuda ki rehmat ho aap par aur uski barkate’n naazil ho aap par.", "Urdu": "آپ پر سلام ہو اے رسولؐ خداکے فرزند! آپ پر سلام ہو اے امیرالمومنینؑ کے فرزند! آپ پر سلام ہو اے فاطمہؑ کے فرزند جو بہت سچی پاکیزہ اور تمام جہانوں کی عورتوں کی سردار ہیں آپ پر سلام ہو اے میرے مولا اے ابا عبداللہؑ خدا کی رحمت ہو اور اس کی برکات ہوں۔", "RArabic": "AS-SALAAMO A’LAIKA YABNA RASOOLIL LAAHE AS-SALAAMO A’LAIKA YABNA AMEERIL MOMENEENA AS-SALAAMO A’LAIKA YABNAS SIDDEEQATIT TAAHERATE FAATEMATA SAYYEDATE NASAAA-IL A’ALAMEENA AS-SALAAMO A’LAIKA YAA MAWLAAYA YAA ABAA A’BDIL LAAHE WA RAHMATUL LAAHE WA BARAKAATOHU.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَابْنَ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ اَمِیْرِ الْمُؤْمِنِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ الصِّدِّیْقَۃِ الطَّاھِرَۃِ فَاطِمَۃَ سَیِّدَۃِ نِسَآءِ الْعَالَمِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَامَوْلَایَ یَااَبَا عَبْدِ اللہِ وَرَحْمَۃُ اللہِ وَبَرَكَاتُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010196, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I bear witness that you performed the prayers, defrayed the poor-rate, enjoined the right, forbade the wrong, recited the Book (i.e. the Holy Qur’an) as exactly as it should be recited, strove for the sake of Allah as exactly as striving must be, and faced all troubles steadfastly for His sake, seeking his reward, until death came upon you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawahi deta hu keh aap ne namaz qaayem ki aur zakat di. Aap ne logo’n ko nek kaamo ka hukm diya aur burey kaamo se mana kiya (roka). Aur aap ne Kitaab’e Khuda (Qur’an) ki is tarah tilaawat ki jo tilaawat ka haq hai. Aur raahe Khuda mein woh jehaad kiya jo jehaad ka haq hai. Aur aap ne Khuda ke liye (Khuda ki khushnoodi ke khaatir) dukho’n (museebato’n) par sabr kiya ummeed’e ajr mein, yahan tak keh aap darja’e shahadat par faayez huwe.", "Urdu": "میں گواہی دیتا ہوں کہ آپ نے نماز قائم کی اور زکوٰۃ دی آپ نے نیک کاموں کا حکم دیا اور برے کاموں سے منع کیا آپ نے تلاوت ِقران کی جو تلاوت کا حق ہے آپ نے خدا کی راہ میں جہاد کیا جو جہاد کا حق ہے اور آپ نے خدا کی خاطر دکھوں پر صبر کیا اجر کی امیدمیں حتی کہ آپ نے شہادت پائی۔", "RArabic": "ASH-HADO ANNAKA QAD AQAMTAS SALAATA WA AATAYTAZ ZAKAATA WA AMARTA BIL-MA’ROOFE WA NAHAYTA A’NIL MUNKARE WA TALAWTAL KETAABA HAQQA TELAAWATEHI WA JAAHADTA FIL LAAHE HAQQA JEHAADEHI WA SABARTA A’LAL AZAA FEE JAMBEHI MOHTASEBAN HATTAA ATAAKAL YAQEENO.", "ArabicText1": "اَشْھَدُ اَنَّكَ قَدْ اَقَمْتَ الصَّلٰوۃَ وَاٰتَیْتَ الزَّكٰوۃَ وَاَمَرْتَ بِالْمَعْرِوْفِ وَنَھَیْتَ عَنِ الْمُنْكَرِ وَتَلَوْتَ الْكِتَّابَ حَقَّ تِلَاوَتِهٖ وَجَاھَدْتَ فِی اللہِ حَقَّ جِھَادِهٖ وَصَبَرْتَ عَلَی الْاَذٰی فِیْ جَنْبِهٖ مُحْتَسِبًا حَتّٰی اَتٰیكَ الْیَقِیْنُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010315, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I also bear witness that those who dissented you, those who fought against you, those who let you down, and those who slew you (all those) were accursed directly by the Meccan Prophet. And he who forges lies indeed fails to attain his desire. May Allah curse those who wronged you from amongst the past and the present generations. May Allah also double for them the painful torment.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawahi deta hu keh jinho’n ne aap ki mukhaalefat ki aur aap se jang ki aur aap ka saath nahi diya aur jinho’n ne aap ko qatl kiya woh sab maloon qaraar diye gaye Nabiye Ummi ki zabaan se, yaqeenan woh na-kaam raha jisne jootha daawa kiya. Khuda ki laanat ho un par jinho’n ne aap par zulm kiya hai (chahe woh) awwaleen mein se ho ya aakhereen mein se, aur dugna (double) ho un par darad-naak azaab.", "Urdu": "میں گواہی دیتا ہوں کہ جنہوں نے آپ کی مخالفت کی اور آپ سے لڑے نیز جنہوں نے آپ کا ساتھ نہ دیا اور جنہوں نے آپ کو قتل کیاوہ سب ملعون قراردیئے گئے نبی امی کی زبان سے یقینًا وہ ناکام رہا جس نے جھوٹا دعویٰ کیا خدا کی لعنت ہو ان پر جنہوں نے آپ پر ظلم کیا ہے اولین وآخرین میں سے اور دگنا ہو ان پر درد ناک عذاب۔", "RArabic": "ASH-HADO ANNAL LAZEENA KHAALAFOOKA WA HAARABOOKA WAL-LAZEENA KHAZALOOKA WAL-LAZEENA QATALOOKA MAL-O’ONOONA A’LAA LESAANIN NABIYYIL UMMIYYE WA QAD KHAABA MANIF TARAA LA-A’NAL LAAHUZ ZAALEMEENA LAKUM MENAL AWWALEENA WAL-AAKHEREENA WA ZAA-A’FA A’LAIHEMUL A’ZAABAL ALEEMA.", "ArabicText1": "اَشْھَدُ اَنَّ الَّذِیْنَ خَالَفُوْكَ وَحَارَبُوْكَ وَالَّذِیْنَ خَذَلُوْكَ وَالَّذِیْنَ قَتَلُوْكَ مَلْعُوْنُوْنَ عَلٰی لِسَانِ النَّبِیِّ الْاُمِّیِّ وَقَدْ خَابَ مَنِ افْتَرٰی لَعَنَ اللہُ الظَّالِمِیْنَ لَكُمْ مِنَ الْاَوَّلِیْنَ وَالْاٰخِرِیْنَ وَضَاعَفَ عَلَیْھِمُ الْعَذَابَ الْاَلِیْمَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010316, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my master and son of Allah’s Messenger, I have come to you visiting you, acknowledging the standing that you enjoy, declaring my loyalty to those who are loyal to you, renouncing your enemies, seeking to follow the true guidance that you are following, and recognizing the deviation of those who oppose you; so, (please) intercede for me before your Lord.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai aaya (haazir huwa) aap ke yahan ay mere aaqa o maula ay farzande Rasoole Khuda (s.a.w.a) aap ki ziyarat karne aap ke haq ko pehchaante huwe. Aap ke dosto’n se dosti aur aap ke dushmano se dushmani rakhte huwe. Us raaste ko duroost aur sahih hidaayat ka raasta jaante huwe jis par aap chale, aur usey gumrah samajhte huwe jisne aap se mukhaalefat ki. Pas apne Parwardigaar ke yahan hamare liye sifaarish farma de.", "Urdu": "میں آپ کے ہاں آیا اے میرے مولا اے رسول ِخداؐ کے فرزند زیارت کرنے آیاآپ کاحق پہنچاتے ہوئے آپ کے دوستوں سے دوستی آپ کے دشمن سے دشمنی رکھتے ہوئے اس راستے کو درست جانتے ہوئے جس پر آپ چلے اور اسے گمراہ سمجھتے ہوئے جس نے آپ سے مخالفت کی پس اپنے رب کے ہاں میری سفارش کریں۔", "RArabic": "ATAYTOKA YAA MAWLAAYA YABNA RASOOLIL LAAHE ZAA-ERAN A’AREFAN BE-HAQQEKA MOWAALEYAN LE-AWLEYAAA-EKA MO-A’ADEYAN LE-A-A’DAAA-EKA MUSTABSERAN BIL-HODAL LAZEE ANTA A’LAIHE A’AREFAN BE-ZALAALATE MAN KHAALAFAKA FASH-FA’ LEE I’NDA RABBEKA.", "ArabicText1": "اَتَیْتُكَ یَامَوْلَایَ یَابْنَ رَسُوْلِ اللہِ زَآئِرًا عَارِفًا بِحَقِّكَ مُوَالِیًا لِاَوْلِیَآئِكَ مُعَادِیًا لِاَعْدَآئِكَ مُسْتَبْصِرًا بِالْھُدَی الَّذِیْ اَنْتَ عَلَیْهِ عَارِفًا بِضَلَالَۃِ مَنْ خَالَفَكَ فَاشْفَعْ لِیْ عِنْدَ رَبِّكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "Arabic