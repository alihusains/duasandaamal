[{"Id": 1019682, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Muhammad Ibn Muslim narrates on the authority of Imam Reza (a) that he (a) said: “Write this invocation on a paper or parchment for pregnant humans and animals…", "GujaratiDescription": null, "RUrduDescription": "Muhammad Ibne Muslim riwaayat karte hai Imam Reza (a) se keh Imam (a) ne farmaya: Is dua ko ek kaaghaz par likh lo haamela (pregnant) insaan aur jaanwar ke liye…", "UrduDescription": "محمد ابن مسلم روایت کرتے ہیں امام رضاؑ سے کہ امامؑ نے فرمایا: اس دعا کو ایک کاغذ پر لکھ لو حاملہ انسان اور حیوان کے لئے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019683, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, in the Name of Allah, in the Name of Allah, Surely with difficulty is ease. With difficulty is surely ease Allah desires ease for you, and He does not desire for you difficulty, and (He desires) that you should complete the number and that you should exalt the greatness of Allah for His having guided you and that you may give thanks. And when My servants ask you concerning Me, then surely I am very near; I answer the prayer of the suppliant when he calls on Me, so they should answer My call and believe in Me that they may walk in the right way And provide for you a profitable course in your affair And provide for you a profitable course in your reasoning. And upon Allah it rests to show the right way, and there are some deviating (ways); and if He please He would certainly guide you all aright Then (as for) the way, He has made it easy (for him) Do not those who disbelieve see that the heavens and the earth were closed up, but We have opened them; and We have made of water everything living, will they not then believe?", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "BISMIL LAAHE BISMIL LAAHE BISMIL LAAHE INNA MA-A’L U’SRE YUSRAN. INNA MA-A’L U’SRE YUSRAA. YOREEDUL LAAHO BEKOMUL YUSRA WA LAA YOREEDO BEKOMUL U’SR, WA LETUKMELUL I’DDATA WA LETOKABBERUL LAAHA A’LAA MAA HADAAKUM WA LAA’LLAKUM TASHKOROON. WA EZAA SA-ALAKA E’BAADEE A’NNEE FA-INNEE QAREEB, OJEEBO DA’WATAD DAA-E’ EZAA DAA’ANE, FALYASTAJEEBOO LEE WAL-YOAMENOO BEE LA-A’LLAHUM YARSHODOON. WA YOHAYYE LAKUM MIN AMREKUM MIRFAQAA. WA YOHAYYE LAKUM MIN AMREKUM RASHADAA. WA A’LAL LAAHE QASDUS SABEELE WA MINHAA JAAA-ER, WA LAW SHAAA-A LA-HADAAKUM AJMA-E’EN. SUMMAS SABEELA YASSARAHU. AWA LAM YARAL LAZEENA KAFAROO ANNAS SAMAAWAATE WAL ARZA KAANATAA RATQAN FA-FATAQNAA-HOMAA, WA JA-A’LNAA MENAL MAAA-E KULLA SHAY-IN HAYY, AFALAA YOAMENOON.", "ArabicText1": "بِسْمِ اللهِ بِسْمِ اللهِ بِسْمِ اللهِ اِنَّ مَعَ الْعُسْرِ يُسْرًا۔ اِنَّ مَعَ الْعُسْرِ يُسْرًا۔ يُرِيْدُ اللہُ بِكُمُ الْيُسْرَ وَلَا يُرِيْدُ بِكُمُ الْعُسْرَ۔ وَلِتُكْمِلُوْا الْعِدَّۃَ وَلِتُكَبِّرُوْا اللہَ عَلٰي مَا ھَدٰىكُمْ وَلَعَلَّكُمْ تَشْكُرُوْنَ۔ وَاِذَا سَاَلَكَ عِبَادِيْ عَـنِّىْ فَاِنِّىْ قَرِيْبٌ۔ اُجِيْبُ دَعْوَۃَ الدَّاعِ اِذَا دَعَانِ۔ فَلْيَسْتَجِيْبُوْا لِيْ وَلْيُؤْمِنُوْا بِيْ لَعَلَّہُمْ يَرْشُدُوْنَ۔ وَيُہَيِّئْ لَكُمْ مِّنْ اَمْرِكُمْ مِّرْفَقًا۔ وَيُهَيِّءْ لَكُمْ مِنْ اَمْرِكُمْ رَشَدًا وَعَلَي اللہِ قَصْدُ السَّبِيْلِ وَمِنْہَا جَاۗىِٕرٌ۔ وَلَوْ شَاۗءَ لَہَدٰىكُمْ اَجْمَعِيْنَ۔ ثُمَّ السَّبِيْلَ يَسَّرَہٗ۔ اَوَلَمْ يَرَ الَّذِيْنَ كَفَرُوْٓا اَنَّ السَّمٰوٰتِ وَالْاَرْضَ كَانَتَا رَتْقًا فَفَتَقْنٰہُمَا۔ وَجَعَلْنَا مِنَ الْمَاۗءِ كُلَّ شَيْءٍ حَيٍّ۔ اَفَلَا يُؤْمِنُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019684, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "So she conceived him; then withdrew herself with him to a remote place. And the throes (of childbirth) compelled her to betake herself to the trunk of a palm tree. She said: Oh, would that I had died before this, and had been a thing quite forgotten! Then (the child) called out to her from beneath her: Grieve not, surely your Lord has made a stream to flow beneath you; And shake towards you the trunk of the palm tree, it will drop on you fresh ripe dates: So eat and drink and refresh the eye. Then if you see any mortal, say: Surely I have vowed a fast to the Beneficent Allah, so I shall not speak to any man today. And she came to her people with him, carrying him (with her). They said: O Maryam! surely you have done a strange thing. O sister of Haroun! your father was not a bad man, nor, was your mother an unchaste woman. But she pointed to him. They said: How should we speak to one who was a child in the cradle?", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": "FA-HAMALAT-HO FANTABAZAT BEHI MAKAANAN QASIYYAA. FA-AJAAA-AHAL MAKHAAZO ELAA JIZ-I’N NAKHLAH, QAALAT YAA LAYTANEE MITTO QABLA HAAZAA WA KUNTO NASYAM MANSIYYAA. FA-NAADAAHAA MIN TAHTEHAA ALLAA TAHZANEE QAD JA-A’LA RABBOKE TAHTAKE SARIYYAA. WA HUZZEE ELAYKE BE-JIZ-I’N NAKHLATE TOSAAQIT A’LAYKE ROTABAN JANIYYAA. FA-KOLEE WASHRABEE WA QARREE A’YNAA, FA-IMMAA TARAYINNA MENAL BASHARE AHADAN, FA-QOOLEE INNEE NAZARTO LIRRAHMAANE SAWMAA FA-LAN OKALLEMAL YAWMA INSIYYAA. FA-ATAT BEHI QAWMAHAA TAHMELOH, QAALOO YAA MARYAMO LAQAD JEATE SHAY-AN FARIYYAA. YAA UKHTA HAAROONA MAA KAANA ABOOKIM RA-A SAWINW WA MAA KAANAT UMMOKE BAGHIYYAA. FA-ASHAARAT ELAYH, QAALOO KAYFA NOKALLEMO MAN KAANA FIL MAHDE SABIYYAA.", "ArabicText1": "فَـحَمَلَتْہُ فَانْتَبَذَتْ بِہٖ مَكَانًا قَصِيًّا۔ فَاَجَاۗءَہَا الْمَخَاضُ اِلٰى جِذْعِ النَّخْلَۃِ۔ قَالَتْ يٰلَيْتَنِيْ مِتُّ قَبْلَ ھٰذَا وَكُنْتُ نَسْـيًا مَّنْسِـيًّا۔ فَنَادٰىہَا مِنْ تَحْتِہَآ اَلَّا تَحْزَنِيْ قَدْ جَعَلَ رَبُّكِ تَحْتَكِ سَرِيًّا۔ وَہُزِّيْٓ اِلَيْكِ بِجِذْعِ النَّخْلَۃِ تُسٰقِطْ عَلَيْكِ رُطَبًا جَنِيًّا۔ فَكُلِيْ وَاشْرَبِيْ وَقَرِّيْ عَيْنًا۔ فَاِمَّا تَرَيِنَّ مِنَ الْبَشَرِ اَحَدًا۔ فَقُوْلِيْٓ اِنِّىْ نَذَرْتُ لِلرَّحْمٰنِ صَوْمًا فَلَنْ اُكَلِّمَ الْيَوْمَ اِنْسِـيًّا۔ فَاَتَتْ بِہٖ قَوْمَہَا تَحْمِلُہٗ۔ قَالُوْا يٰمَرْيَمُ لَقَدْ جِئْتِ شَـيْـــــًٔـا فَرِيًّا۔ يٰٓاُخْتَ ہٰرُوْنَ مَا كَانَ اَبُوْكِ امْرَاَ سَوْءٍ وَّمَا كَانَتْ اُمُّكِ بَغِيًّا۔ فَاَشَارَتْ اِلَيْہِ۔ قَالُوْا كَيْفَ نُكَلِّمُ مَنْ كَانَ فِيْ الْمَہْدِ صَبِيًّا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019685, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "He said: Surely I am a servant of Allah; He has given me the Book and made me a prophet; And He has made me blessed wherever I may be, and He has enjoined on me prayer and poor-rate so long as I live; And dutiful to my mother, and He has not made me insolent, unblessed; And peace on me on the day I was born, and on the day I die, and on the day I am raised to life. Such is Isa, son of Maryam; And Allah has brought you forth from the wombs of your mothers, you did not know anything, and He gave you hearing and sight and hearts that you may give thanks. Do they not see the birds, constrained in the middle of the sky? None withholds them but Allah; most surely there are signs in this for a people who believe. Thus, O newborn child, come forth healthy, by the will of Allah, the Mighty and Sublime.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": "QAALA INNEE A’BDUL LAAH, AATAANEYAL KETAABA WA JAA’LANEE NABIYYANW. WA JA-A’LANEE MOBAARAKAN AYNA MAA KUNT, WA AWSAANEE BISSALAATE WAZ ZAKAATE MAA DUMTO HAYYANW. WA BARRAM BEWAALEDATEE, WA LAM YAJ-A’LNEE JABBAARAN SHAQIYYAA. WAS SALAAMO A’LAYYA YAWMA WOLIDTO WA YAWMA AMOOTO WA YAWMA UB-A’SO HAYYAA. ZAALEKA E’ESAB NO MARYAM.1WAL LAAHO AKHRAJAKUM MIM BOTOONE UMMAHAATEKUM LA TA’LAMOONA SHAY-ANW, WA JAA’LA LAKOMUS SAM-A’ WAL ABSAARA WAL AFEDATA, LAA’LLAKUM TASHKOROON. ALAM YARAW ELAT TAYRE MOSAKH-KHARAA-TIN FEE JAWWIS SAMAAA, MAA YUMSEKOHUNNA ILLAL LAAH, INNA FEE ZAALEKA LAAAYAATIL LEQAWMINY YOAMENOON. KAZAALEKA AYYOHAL MAWLOODUKH RUJ SAWIYYAN BE-IZNIL LAAHE A’ZZA WA JALLA.", "ArabicText1": "قَالَ اِنِّىْ عَبْدُ اللہِ۔ اٰتٰىنِيَ الْكِتٰبَ وَجَعَلَنِيْ نَبِيًّا وَّجَعَلَنِيْ مُبٰرَكًا اَيْنَ مَا كُنْتُ۔ ‎وَاَوْصٰىنِيْ بِالصَّلٰوۃِ وَالزَّكٰوۃِ مَا دُمْتُ حَيًّا وَّبَرًّۢا بِوَالِدَتِيْ۔ وَلَمْ يَجْعَلْنِيْ جَبَّارًا شَقِيًّا۔ وَالسَّلٰمُ عَلَيَّ يَوْمَ وُلِدْتُّ وَيَوْمَ اَمُوْتُ وَيَوْمَ اُبْعَثُ حَيًّا۔ ذٰلِكَ عِيْسَى ابْنُ مَرْيَمَ وَاللہُ اَخْرَجَكُمْ مِّنْۢ بُطُوْنِ اُمَّہٰتِكُمْ لَا تَعْلَمُوْنَ شَـيْـــًٔـا وَّجَعَلَ لَكُمُ السَّمْعَ وَالْاَبْصَارَ وَالْاَفْــِٕدَۃَ لَعَلَّكُمْ تَشْكُرُوْنَ اَلَمْ يَرَوْا اِلَى الطَّيْرِ مُسَخَّرٰتٍ فِيْ جَوِّ السَّمَاۗءِ۔ مَا يُمْسِكُہُنَّ اِلَّا اللہُ۔ اِنَّ فِيْ ذٰلِكَ لَاٰيٰتٍ لِّقَوْمٍ يُّؤْمِنُوْنَ كَذٰلِكَ اَيُّهَا الْمَوْلُودُ اخْرُجْ سَوِيًّا بِاِذْنِ اللهِ عَزَّ وَجَلَّ‏۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "Ara