cText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002181, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He from whom I can hope for all goodness And I am safe from His anger at every evil. O He who gives a lot in exchange of a little. O He who gives to one who asks Him. O He who gives to one who does not ask Him and does not know Him, Out of His affection and mercy. Give me, for my request is only to You alone, All the good of this world and all the good of the Hereafter. Keep away from me, for my request is only to You alone, All the evil of this world and the evil of the Hereafter. For indeed it is not diminishing what is given by You. Increase (for) me from Your bounty, O The Generous.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay woh jis se har bhalaayi ki ummeed rakhta hu aur har buraayi ke waqt uske ghazab se amaan chahta hu. Ay woh jo thode amal par ziyadah ajr deta hai. Ay woh jo har sawaal karne waale ko deta hai. Ay woh jo usey bhi deta hai jo sawaal nahi karta aur usey bhi deta hai jo usey nahi pehchanta. Ehsaan o rehmat ke taur par Tu mujhe bhi mere sawaal par duniya o aakherat ki tamaam bhalaaiya aur nekiya’n ataa farma de aur meri talab-gaari par duniya o aakherat ki tamaam takleefe aur mushkile dur kar ke mujhe mehfooz kar de kyu’n keh Tu jitna ataa kare Tere yahan kami nahi padti, to ay kareem Tu mujh par apne fazl mein izaafa farma.", "Urdu": "اے وہ جس سے ہر بھلائی کی امید رکھتا ہوں اور ہر برائی کے وقت اس کے غضب سے امان چاہتا ہوں اے وہ جو تھوڑے عمل پر زیادہ اجر دیتا ہے اے وہ جو ہر سوال کرنے والے کو دیتا ہے اے وہ جو اسے بھی دیتا ہے جو سوال نہیں کرتا اور اسے بھی دیتا ہے جو اسے نہیں پہچانتا احسان و رحمت کے طور پر تو مجھے بھی میرے سوال پر دنیا و آخرت کی تمام بھلائیاں اور نیکیاں عطا فرما دے اور میری طلب گاری پر دنیا و آخرت کی تمام تکلیفیں اور مشکلیں دور کر کے مجھے محفوظ فرما دے کیوں کہ تو جتنا عطا کرے تیرے ہاں کمی نہیں ہوتی اے کریم تو مجھ پر اپنے فضل میں اضافہ فرما۔", "RArabic": "YAA MAN ARJOO-HO LE-KULLE KHAIRIN WA AA-MANO SAKHTA-HU I’NDA KULLE SHARRIN, YAA MAIY-YO’TIL KASEERA BIL QALEELE, YAA MAIY-YA’TEE MAN SA-A-LAHU, YAA MAIY-YO’TEE MAL-LAM YAS-A-LOHU WA MAL-LAM YA’RIFHO TAHAN-NONAN MINHO WA RAHMA-TAN, A’TE-NEE BE-MAS-A-LATEE IYYAAKA JAMEE-A’ KHAIRID DUNYAA WA JAMEE-A’ KHAIRIL AAKHERA-TE, WASRIF A’NNEE BE-MAS-ALA-TEE IYYAAKA JAMEE-A’ SHARRID DUNYAA WA SHARRIL AAKHERA-TE, FA INNAHU GHAIRO MANQOO-SIN MAA A’TAIYTA WA ZIDNEE MIN FAZLE-KA YAA KAREEME.", "ArabicText1": "یَامَنْ اَرْجُوْهُ لِكُلِّ خَیْرٍ وَّاٰمَنُ سَخْطَهٗ عِنْدَ كُلِّ شَرٍّ، یَامَنْ یُّعْطِی الْكَثِیْرَ بِالْقَلِیْلِ، یَامَنْ یُّعْطِیْ مَنْ سَئَلَهٗ، یَامَنْ یُّعْطِیْ مَنْ لَّمْ یَسْئَلُهٗ وَمَنْ لَّمْ یَعْرِفْهُ تَحَنُّنًا مِنْهُ وَرَحْمَۃً، اَعْطِنِیْ بِمَسْئَلَتِیْ اِیَّاكَ جَمِیْعَ خَیْرِ الدُّنْیَا وَجَمِیْعَ خَیْرِ الْاٰخِرَۃِ، وَاصْرِفْ عَنِّیْ بِمَسْئَلَتِیْ اِیَّاكَ جَمِیْعَ شَرِّالدُّنْیَا وَشَرِّ الْاٰخِرَۃِ، فَاِنَّهٗ غَیْرُ مَنْقُوْصٍ مَآ اَعْطَیْتَ وَزِدْنِیْ مِنْ فَضْلِكَ یَاكَرِیْمِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002182, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Then the 6th Imam held his beard in his left hand and gave a movement to the index finger in his right hand saying…", "GujaratiDescription": null, "RUrduDescription": "Phir 6th Imam ne apne rish’e mubarak ko baaye haath se pakda aur apne daaye haath ki shaadat waali ungli ko daaye baaye phiraate huwe is tarah kaha…", "UrduDescription": "راوی کہتا ہے : اس کے بعد امام ؑنے اپنی ریشِ مبارک کو بائیں مٹھی میں لیا اور داہنے ہاتھ کی انگشتِ شہادت کو ہلاتے ہوئے نہایت گریہ و زاری کی حالت میں یہ دعا پڑھی۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1002183, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O The Sublime and The Distin