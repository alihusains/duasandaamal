[{"Id": 1002180, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Recite this dua after every obligatory namaz in the month of Rajab…", "GujaratiDescription": null, "RUrduDescription": "Is dua ko mahe Rajab mein har waajib namaz ke baad zaroor padhe…", "UrduDescription": "محمد ابن ذکو ان،جو اس لئے سجاد کے نام سے معروف ہیں کہ انہوں نے اتنے سجدے کیے اور خوف ِخدا میں اس قدر روئے کہ نابینا ہوگئے تھے، سید ابن طاؤس ؒنے محمد ابن ذکوان سے روایت کی ہے کہ انہوں نے کہا: میں نے امام جعفر صادقؑ کی خدمت میں عرض کیا: میں آپ پر قربان ہو جاؤں! یہ ماہِ رجب ہے، مجھے کوئی دعا تعلیم کیجئے کہ حق تعالیٰ اس کے ذریعے مجھے فائدہ عطا فرمائے۔ آپ نے فرمایا : لکھوبسم اللہ الرحمٰن الرحیم اور رجب کے مہینے میں ہر روزصبح وشام کی نماز کے بعد یہ دعا پڑھا کرو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, 