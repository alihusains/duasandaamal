[{"Id": 1014016, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Imam Muhammad Taqi (a)’s tomb is in the back of the tomb of his grandfather (ie. Imam Kazim (a)). Standing at the blessed grave recite the following…", "GujaratiDescription": null, "RUrduDescription": "Imam Muhammad Taqi (a) ki qabr mubarak unke jad’e buzurg-waar Imam Moosa Kazim (a) ki qabr mubarak ki pusht ki jaabin hai. Qabre mubarak ke saamne khade ho kar is tarah se padhe…", "UrduDescription": "شیخ مفیدؒ شیخ شہیدؒ اور محمد ابن المشہدی ؒنے فرمایا ہے : زائر جب امام موسیٰ کاظم ؑ کی زیارت سے فارغ ہوتو پھر امام محمد تقی ؑ کی طرف متوجہ ہو کہ جو اپنے جد بزرگوار امام موسیٰ کاظم ؑ کی پشت کی جانب مدفون ہیں۔ اب ان کی قبرِ مبارک کے سامنے کھڑے ہو کر یہ زیارت پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014017, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O intimate servant of Allah. Peace be upon you, O Allah’s argument. Peace be upon you, O Allah’s light in the darkness of the earth. Peace be upon you, O son of Allah’s Messenger. Peace be upon you and upon your fathers. Peace be upon you and upon your descendants. Peace be upon you and upon your loyalists.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Waliye Khuda. Aap par salaam ho ay Hujjat’e Khuda. Aap par salaam ho keh aap zameen ki taarikiyo’n mein Khuda ka noor hai. Aap par salaam ho ay Rasoole Khuda (s.a.w.a) ke farzand. Aap par salaam ho aur aap ke paakeeza Aaba’o par. Aap par salaam ho aur aap ke farzando’n par. Aap par aur aap ke auliya par.", "Urdu": "آپ پر سلام ہو اے ولی خدا! آپ پر سلام ہو اے حجت ِخدا! آپ پر سلام ہو کہ آپ زمین کی تاریکیوں میں خدا کا نور ہیں آپ پر سلام ہو اے رسولِ خداؐ کے فرزند آپ پر سلام ہو اور آپ کے پاکیزہ آباء پر آپ پر سلام ہواور آپ کے فرزندوں پر آپ پر اور آپ کے اولیاء پر۔", "RArabic": "AS-SALAAMO A’LAIKA YAA WALIYYAL LAAHE AS-SALAAMO A’LAIKA YAA HUJJATAL LAAHE AS-SALAAMO A’LAIKA YAA NOORAL LAAHE FEE ZOLOMAATIL ARZE AS-SALAAMO A’LAIKA YABNA RASOOLIL LAAHE AS-SALAAMO A’LAIKA WA A’LAA AABAAA-EKA AS-SALAAMO A’LAIKA WA A’LAA ABNAAA-EKA AS-SALAAMO A’LAIKA WA A’LAA AWLEYAAA-EKA.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا وَلِیَّ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا حُجَّۃَ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا نُوْرَ اللہِ فِیْ ظُلُمَاتِ الْاَرْضِ۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ وَعَلٰی اٰبَآئِكَ۔ اَلسَّلَامُ عَلَیْكَ وَعَلٰی اَبْنَآئِكَ۔ اَلسَّلَامُ عَلَیْكَ وَعَلٰی اَوْلِیَآئِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014018, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I bear witness that you performed the prayers, defrayed the poor-rate, enjoined the right, forbade the wrong, recited the Book as it should be recited, strove for Allah as exactly as striving should be, and endured harm for His sake until death came upon you. I have come to you, visiting you, recognizing your right, declaring loyalty to your loyalists, and incurring the animosity of your enemies; so, (please) intercede for me with Your Lord.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawahi deta hu keh yaqeenan aap ne namaz qaaem ki aur zakaat di, aap ne nek kaamo ka hukm diya aur burey kaamo se roka, aap ne tilaawate Qur’an ka haq adaa kar diya, aap ne Khuda ke liye jehaad kiya jo haqqe jehaad hai aur Khuda ke khaatir taklifo’n par sabr karte rahe yahan tak-keh shaheed ho gaye. Mai aap ki ziyarat ko aaya hu, aap ka haq pehchaante hu, aap ke dosto’n se dosti, aap ke dushmano se dushmani rakhta hu, pas apne Rab ke yahan meri shafa’at kare.", "Urdu": "میں گواہی دیتا ہوں کہ یقینًا آپ نے نماز قائم کی اور زکوٰۃ دی آپ نے نیک کاموں کا حکم دیا اوربرے کاموں سے روکا آپ نے تلاوت ِقرآن کا حق ادا کردیا آپ نے خدا کے لئے جہاد کیا جو حق ِجہاد ہے اور خدا کی خاطر تکلیفوں پر صبر کرتے رہے یہاں تک کہ شہید ہوگئے میں آپ کی زیارت کو آیا ہوں آپ کا حق پہچانتا ہوں آپ کے دوستوں سے دوستی آپ کے دشمن سے دشمنی رکھتا ہوں پس اپنے رب کے ہاں میری شفاعت کریں۔", "RArabic": "ASH-HADO ANNAKA QAD AQAMTAS SALAATA WA AATAYTAZ ZAKAATA WA AMARTA BIL MA’ROOFE WA NAHAYTA A’NIL MUNKARE WA TALAWTAL KETAABA HAQQA TELAAWATEHI WA JAAHADTA FILLAAHE HAQQA JEHAADEHI WA SABARTA A’LAL AZAA FEE JAMBEHI HATTAA ATAAKAL YAQEENO ATAYTOKA ZAAA-ERAN A’AREFAN BE HAQQEKA MOWAALEYAN LE AWLEYAAA-EKA MO-A’ADEYAN LE-A’ADAAA-EKA FASH-FA’ LEE I’NDA RABBEKA.", "ArabicText1": "اَشْھَدُ اَنَّكَ قَدْ اَقَمْتَ الصَّلٰوۃَ وَاٰتَیْتَ الزَّكٰوۃَ وَاَمَرْتَ بِالْمَعْرُوْفِ وَنَھَیْتَ عَنِ الْمُنْكَرِ وَتَلَوْتَ الْكِتَابَ حَقَّ تِلَاوَتِهٖ وَجَاھَدْتَ فِی اللہِ حَقَّ جِھَادِهٖ وَصَبَرْتَ عَلَی الْاَذٰی فِیْ جَنْبِهٖ حَتّٰی اَتٰیكَ الْیَقِیْنُ اَتَیْتُكَ زَآئِرًا عَارِفًۢا بِحَقِّكَ مُوَالِیًا لِاَوْلِیَآئِكَ مُعَادِیًا لِاَعْدَآئِكَ فَاشْفَعْ لِیْ عِنْدَ رَبِّكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null,