[{"Id": 1015677, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Hajj literally means ’Aim’ and ’Ziyarat of the House of Allah’ and special deeds there according to Islamic law (Shariah).", "GujaratiDescription": null, "RUrduDescription": "Lagwi (dictionary ke) etebaar se Hajj ke maani “Qasad” ke hai aur shari’at ki rooh se Hajj Khaana-e-Khuda ki ziyarat aur makhsoos amaal o manaasik anjaam dene ka naam hai.", "UrduDescription": "لغوی اعتبار سے حج کے معنی قصد کے ہیں اور شریعت کی رو سے حج خانۂ خدا کی زیارت اور مخصوص اعمال و مناسک انجام دینے کا نام ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015678, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "Hajj which means ’Ziyarat of the House of Allah’ and performing certain rituals is one of the five pillars of Islam. Scholars of both sects believe that Hajj is a necessity of religion and its denier is a disbeliever. Hence one who refrains from Hajj has made Allah angry. It is said (3:96-97)…", "GujaratiDescription": null, "RUrduDescription": "Hajj Islaam ke paanch (5) bunyaadi arkaan aur tamaam ulma’e Imamiya wa Ahle Sunnat ke nazdik zarooriyaat’e deen mein shumaar hota hai aur Hajj ka munkir kaafir hai. Khuda wande aalam ki jaanib se Hajj na karne waalo’n ki shadeed alfaaz mein tambeeh aur mazammat ki gayi hai. Irshaad hota hai (3:96-97)…", "UrduDescription": "حج اسلام کے ۵ بنیادی ارکان اور تمام علماء امامیہ و اہل سنت کے نزدیک ضروریات دین میں شمار ہوتا ہے اور حج کا منکر کافر ہے۔ خداوند عالم کی جانب سے حج نہ کرنے والوں کی شدید الفاظ میں تنبیہ اور مزمّت کی گئی ہے۔ ارشاد ہوتا ہے(آلِ عمران: ۹۶۔۹۷)۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "Ara