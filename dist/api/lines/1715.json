[{"Id": 1011427, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "In his book of Al-Muqniah, Shaikh Mufid has narrated on the authority of Ali ibn Mahziyar, that Imam Muhammad Taqi (a) has recommended to say this dua as many times as possible during the month of Ramazan and specially on the eve of 19th Mahe Ramazan…", "GujaratiDescription": null, "RUrduDescription": "Shaikh Mufid apni kitaab Al-Muqniah mein, Ali ibne Mahziyar ki jaanib se, keh Imam Taqi (a) ne is dua ko Mahe Ramazan mein rozana padhne ki taaqid ki hai aur khaas kar keh 19th Mahe Ramazan ki shab mein…", "UrduDescription": "کتاب مقنعہ میں شیخ مفید ؒ نے ثقہ جلیل علی ابن مہزیار سے روایت کی ہے کہ امام محمد تقی ؑنے فرمایا:ماہِ رمضان کے دنوں اور راتوں میں اس دعا کو زیادہ سے زیادہ پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, 