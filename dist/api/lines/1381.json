[{"Id": 1000655, "EnglishTitle": "One of his Glorifications of Allah…", "GujaratiTitle": null, "RUrduTitle": "Tasbeeh wa taqdees ke silsile mein yeh dua padhte…", "UrduTitle": "تسبیح و تقدیس کے سلسلہ میں", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000656, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Thee, O God, and I beg Thy loving care! Glory be to Thee, O God, and high art Thou exalted! Glory be to Thee, O God, and might is Thy loincloth! Glory be to Thee, O God, and mightiness is Thy cloak! Glory be to Thee, O God, and magnificence is Thy authority! Glory be to Thee, All-Mighty! How mighty Thou art!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay mere Ma’bood! Mai Teri tasbeeh karta hu Tu mujh par karam par karam farma. Baare Ilaaha! Mai Teri tasbeeh karta hu Tu buland o bartar hai. Khudaaya mai Teri tasbeeh karta hu izzat Teri hi zaat se makhsoos hai. Khudaaya mai Teri tasbeeh karta hu azmat Tere hi liye khaas hai. Ay Parwardigaar! Mai Teri tasbeeh karta hu aur kibriyaayi Teri hi hujjat hai.", "Urdu": "اے میرے معبود! میں تیری تسبیح کرتا ہوں تو مجھ پر کرم توبالائے کرم فرما، بارِ الہٰا! میں تیری تسبیح کرتا ہوں اور تو بلند و برتر ہے، خدایا! میں تیری تسبیح کرتا ہوں اور عزّت تیرا ہی جامہ ہے، بارِ الہٰا! میں تیری تسبیح کرتا ہوں اور عظمت تیری ہی ردا ہے، اے پروردگار! میں تیری تسبیح کرتا ہوں اور کبریائی تیری دلیل و حجت ہے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "سُبْحَانَكَ اللّٰهُمَّ وَحَنَانَيْكَ۔ سُبْحَانَكَ اللّٰهُمَّ وَتَعَالَيْتَ۔ سُبْحَانَكَ اللّٰهُمَّ وَالْعِزُّ اِزَارُكَ۔ سُبْحَانَكَ اللّٰهُمَّ وَالْعَظَمَةُ رِدَاۗؤُكَ۔ سُبْحَانَكَ اللّٰهُمَّ وَالْكِبْرِيَاۗءُ سُلْطَانُكَ۔ سُبْحَانَكَ مِنْ عَظِيْمِ مَا اَعْظَمَكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002060, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Thee! Thou art glorified in the highest! Thou hearest and seest what is under the soil! Glory be to Thee! hou art witness over every whispered conversation! Glory be to Thee, the place where every complaint is put down! Glory be to Thee, present in every assembly! Glory be to Thee, object of great hopes! Glory be to Thee! Thou seest what is at the lowest depth of the water!", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai Tu ay azeem o bartar Tu kitna azmat waala hai, paak hai Tu ay woh keh mala'e aala (khaas jagah) ke rehne waalo’n mein Teri tasbeeh ki gayi hai, jo kuchh zameen ke neeche hai Tu usey soonta hai aur dekhta hai, paak hai Teri zaat Tu har chhupi wa dhaki baato’n ko bhi jaanta hai, paak hai Tu ay woh jo har ranj, dukh, shikwa-shikaayat ke pesh karne ki jagah hai, paak hai Tu ay woh jo har ijtema (har majme) mein maujood hai. Paak hai Tu ay woh jisse badi badi ummeede’n joodi hai.", "Urdu": "پاک ہے تو اے عظیم و برتر تو کتناعظمت والا ہے، پاک ہے تو! اے وہ کہ ملا ءِاعلیٰ کے رہنے والوں میں تیری تسبیح کی گئی ہے، جو کچھ تہِ خاک ہے تو اُسے سنتا اور دیکھتا ہے۔ پاک ہے تیری ذات! تو ہر راز دارانہ گفتگو پر مطلع ہے، پاک ہے تو! اے وہ جو ہر رنج و شکوہ کے پیش کرنے کی جگہ ہے، پاک ہے تو! اے وہ جو ہر اجتماع میں موجود ہے، پاک ہے تو اے وہ جس سے بڑی سے بڑی امید میں باندھی جاتی ہیں۔", "RArabic": null, "ArabicText1": "سُبْحَانَكَ سُبِّحْتَ فِي الْمَلَا اَلْاَعْلٰى تَسْمَعُ وَتَرٰى مَا تَحْتَ الثَّرٰى۔ سُبْحَانَكَ اَنْتَ شَاهِدُ كُلِّ نَجْوٰى۔ سُبْحَانَكَ مَوْضِعُ كُلِّ شَكْوٰى۔ سُبْحَانَكَ حَاضِرُ كُلِّ مَلَا۔ سُبْحَانَكَ عَظِيْمُ الرَّجَاۗءِ۔ سُبْحَانَكَ تَرٰى مَا فِيْ قَعْرِ الْمَاۗءِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002061, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Thee! Thou hearest the breaths of the fish in the lowest depths of the oceans! Glory be to Thee! Thou knowest the weight of the heavens! Glory be to Thee! Thou knowest the weight of the earths! Glory be to Thee! Thou knowest the weight of the sun and the moon! Glory be to Thee! Thou knowest the weight of the darkness and the light!", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai Tu jo kuchh paani ki gehraaiyo’n mein hai usey Tu dekhta hai, paak hai Teri zaat Tu samandaro’n ki gehraaiyo’n mein machhliyo’n ki saas (breathing) lene ki awaaz soonta hai, paak hai Teri zaat Tu suraj aur chaand ke wazn se waaqif hai.", "Urdu": "پاک ہے تو! جو کچھ پانی کی گہرائی میں ہے اسے تو دیکھتا ہے، پاک ہے تیری ذات! تو سمندروں کی گہرائیوں میں مچھلیوں کے سانس لینے کی آواز سنتا ہے، پاک ہے تیری ذات! تو آسمانوں کا وزن جانتا ہے۔", "RArabic": null, "ArabicText1": "سُبْحَانَكَ تَسْمَعُ اَنْفَاسَ الْحِيْتَانِ فِيْ قُعُوْرِ الْبِحَارِ۔ سُبْحَانَكَ تَعْلَمُ وَزْنَ السَّمَوَاتِ۔ سُبْحَانَكَ تَعْلَمُ وَزْنَ الْاَرَضِيْنَ۔ سُبْحَانَكَ تَعْلَمُ وَزْنَ الشَّمْسِ وَالْقَمَرِ۔ سُبْحَانَكَ تَعْلَمُ وَزْنَ الظُّلْمَةِ وَالنُّوْرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002062, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to Thee! Thou knowest the weight of the shadow and the air! Glory be to Thee! Thou knowest the weight of the wind, how many times it is greater than the weight of a dust mote! Glory be to Thee, All-holy, All-holy, All-holy! Glory be to Thee! I wonder how any who knows Thee could fear Thee not! Glory be to Thee, O God, and Thine is the praise! Glory be to God, the All-high, the All-Mighty!", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai Teri zaat Tu saaye aur hawa ke wazn ko jaanta hai, paak hai Teri zaat Tu hawa ke har jokey se aagah hai keh woh wazn mein kitne zarro’n ke bara-bar hai, paak hai Teri zaat Tu (tasawwur o khayaal, wahem o ghumaan mein aane se) paak o munazza wa bari hai, mai Teri tasbeeh karta hu taajjub hai keh jisne Tujhe pehchaana woh kyu’n kar Tujh se nahi darta, ay Allah! Mai hamd o sana ke saath Teri paakeezgi bayaan karta hu, paak hai woh Parwardigaar jo bohot badi azmato’n waala hai.", "Urdu": "پاک ہے تیری ذات! تو زمینوں کے وزن سے باخبر ہے،پاک ہے تیری ذات! تو سورج اور چاند کے وزن سے واقف ہے، پاک ہے تیری ذات! تو تاریکی اور روشنی کے وزن سے آگاہ ہے،پاک ہے تیری ذات تو سایہ اور ہوا کا وزن جانتا ہے،پاک ہے تیری ذات! تو ہوا کے ( ہر جھونکے کے) وزن سے آگاہ ہے کہ وہ وزن میں کتنے ذرّوں کے برابر ہے۔", "RArabic": null, "ArabicText1": "سُبْحَانَكَ تَعْلَمُ وَزْنَ الْفَيْءِ وَالْهَوَاۗءِ۔ سُبْحَانَكَ تَعْلَمُ وَزْنَ الرِّيْحِ كَمْ هِيَ مِنْ مِثْقَالِ ذَرَّةٍ۔ سُبْحَانَكَ قُدُّوْسٌ قُدُّوْسٌ قُدُّوْسٌ۔ سُبْحَانَكَ عَجَبَا مَنْ عَرَفَكَ كَيْفَ لَا يَخَافُكَ۔ سُبْحَانَكَ اللّٰهُمَّ وَبِحَمْدِكَ سُبْحَانَكَ اللهُ الْعَلِيُّ الْعَظِيْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "Arabi