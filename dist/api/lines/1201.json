scription": null, "RUrduDescription": "2 Rakat namaz, har rakat mein <Surah Fateha> ke baad 1 martaba <Surah An’aam> padhe. Namaz ke baad Allah (swt) se dua kare keh woh usey har dard o khouf se bachaaye rakkhe aur is mahine mein usko aisa maamla dar-pesh na ho jisko woh pasand na karta ho.", "UrduDescription": "چاند رات میں ۲ رکعت نماز پڑھے جس کی ہر رکعت میں <سورۂ فاتحہ> کے بعد <سورۂ انعام> کی قرائت کرے،نماز کے بعد حق تعالیٰ سے دعا کرے کہ وہ اسے ہر درد وخوف سے بچائے رکھے اوراس مہینے میں اسے کوئی ایسا معاملہ درپیش نہ ہو جس کو وہ پسند نہ کرتا ہو۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "Arabi