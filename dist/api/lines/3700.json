[{"Id": 1016647, "EnglishTitle": "Ethics of Shias towards Imam Mahdi (a) on the day of Eid-ul-Fitr.", "GujaratiTitle": null, "RUrduTitle": "Roz-e-Eid-ul-Fitr, Imam Mahdi (a) ki Shiyo’n se nisbat.", "UrduTitle": "روز عید فطر امام عصر (عج) اور احنافداہ کی نسبت شیعوں کا ادب و احترام۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016648, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "The honourable Sayyid Razi ud Deen Ali bin Taoos writes in a section of his book under the heading ethics of Shias on the day of Eid towards someone who considers that he is the Imam and holds a mighty position that…", "GujaratiDescription": null, "RUrduDescription": "Syed bin Tawoos is jagah par Aan Hazrat (a) ki Imamat aur unke buland martaba ke motaqeed afraad ke Aan Hazrat (a) ki nisbat adab o ehteraam ka tazkira karte huwe farmate hai…", "UrduDescription": "انشاء اللہ ترجمہ جلد آرہا ہے", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016649, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Hence I say: when the day of Eid ul Fitr arrives, and if the Master of the government and its issues is Imam Mahdi (a) himself, who administers the nation and the kingdom, and his people hold the character he desires, thus congratulate his holiness for Allah (swt) has turned towards him and has granted him the power and kingdom. Then congratulate yourself, and all your near and dear one, and all the people living on earth having faith in the Imamate of his holiness, and all those who have benefitted from his presence, his imamate, his grace and guidance, and has gained the benefits of his noble kingdom.", "GujaratiDescription": null, "RUrduDescription": "Roz-e-Eid-ul-Fitr woh Saaheb-e-Amr (a) hote aur masnad-e-hukumat par baiytha hote to sabhee log Aan Hazrat (a) ke zer farmaan hote lehaaza Aan Hazrat (a) ke upar Parwardigaar-e-Aalam ki is tawajjoh wa ehsaan unko mubarak-baad deni chahiye. Iske baad khud ko, apne azeezo’n ko, tamaam duniya ke logo’n ko aur har us fard ko jis ne unki imamat aur unke wujood ki barkat se hidaayat paayi hai aur unki hukumat ki barkato’n se khush-bakht huwa hai mubarak-baad pesh kare.", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016650, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "And if the person whose obedience is considered obligatory by You but he is prevented from ruling the kingdom, then the impact of Allah’s wrath and anger should be evident on your faces, and you should be sorrowful and upset about all the divine grace and favour from which you are deprived.", "GujaratiDescription": null, "RUrduDescription": "Aur agar aqeeda yeh hai keh Aan Hazrat (a) ki ita’at waajib hai lekin woh reyaasat ke umoor mein tasrruf (change) nahi kar sakte to aise surat mein huqooq ki bara-bari, madad aur ghaiz o ghazab mein Khuda pesh-e-nazar rahe is liye keh woh tumhara aur unka Mawla hai aur woh fazl jo haatho’n se chala gaya us par ghussa aur afsos hona chahiye.", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016651, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Thus, indeed we have narrated from the book Man-la Yahzarhul Faqeeh through our own chain of authority which ends on Sheikh Sadooq, and from other books with his authority, from Hannan bin Sadeer, who narrated from Abdullah bin Dinar, who narrated from Imam Baqir (a) that his holiness said: O Abdullah, there is no Eid ul Qurbaan or Fitr that arrives for the Muslims in which the sorrow and grief of the household of Mohammad (a) does not increase.", "GujaratiDescription": null, "RUrduDescription": "Is liye ke Shaikh Sadooq ne apni sanad ke mutaabiq Man-la Yahzarhul Faqeeh mein aur dusro’n ne apni sanad ke mutaabiq riwaayat ki hai keh Hanaan bin Sadeer ne Abdullah bin Dinar se aur unho ne Imam Muhammad Baqir (a) se naql kiya hai. Hazrat farmate hai; Ay Abdullah koi bhi Eid-ul-Fitr aur Eid-ul-Qurbaan musalmaano ke liye nahi hai keh jis mein Aale Muhammad (a) ka gham yaad na aata ho. ", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016652, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Abdullah asked: What for? His holiness replied: Because they (peace be upon them) consider their right to be usurped by others. I say: If you knew the conditions of the time of his reappearance, and would be aware of how the flags of Islam will be wide open for justice, and the rulings of people will be evident by grace and knowledge, and the riches will be distributed with generosity between the slaves of Allah in His path, and the desires will be fulfilled, safety and peace will overcome all the near and distanced points of earth, and victory will be in the hands of the weak and humiliated men, and the sun of good-fortune will shine upon the world making it bright, good fortune will spread widely in all the high and low lying lands, and the illuminating order of Allah along with His powerful empire will prevail in such a way that all minds will be delighted, all hearts will be rejoiced, and all place will be dominated by light. Indeed, this Eid, upon whose arrival you are delighted, would seem offensive to you and you would realize how much of Allah’s grace and bounties you have lost, and your heart would be occupied with mourning and grief, and it is appropriate and loyal for someone who is dignified and respectable near You.", "GujaratiDescription": null, "RUrduDescription": "Ham ne arz kiya kyu’n? Hazrat (a) ne farmaya; Chun-keh woh apna haq dusro’n ke paas dekhte hai. Syed bin Tawoos aage farmate hai; haa’n agar Hazrat ke huzoor ko apni nighaho’n ke saamne mujassam karte to dekhte kis tarah parcham-e-Islaam adl o insaaf ke saath lehra raha hai, logo’n ke ehkaam apni bartaree ke saath raaej hai, saara maal Khuda ki eaah mein bando’n ke darmiyaan taqseem ho raha hai, logo’n ko neyk umeedo’n ki bashaarat di ja rahi hai aur woh unhe qabool kar rahe hai amn o amaan qareeb wa baeed sabhi jagah qaaem hai kis tarah har kamzor o naadaar aur tanha ki madad kare hai? Kis tarah duniya-khursheed-e-saadat (kaamyaabi ka suraj) se roshan ho gayi hai aur apni pur faiz kirno se zameen ki pasti o bulandi ko ba-taure masaawi munawwar aur darkhshaa’n (roshan) kar raha hai, aur kis tarah sab par ghaalib aane waale Khuda ka hukm aur kaamyaab hukumat har jagah nazr aa rahi hai is tarah qalb wa dil masroor (khush) hai aur tamaam aafaaq (kaaenaat) par noor hi noor phaila huwa hai. Mere azeez bhai! Khuda ki qasam agar is tarah ki mamlekat (hukumat) tumhari nazro’n ke saamne mujassam ho aur aisi Eid jis par aap khush-haal o masroor thay to phir aap ka yeh aish o aaraam khatm ho jaayega, aur aap ko mehsoos hoga keh kis darje karaamat o fazl Parwardigaar se ham maala-maal hai, gham o andoh aur afsos aap par ghalba karega aur aap ke poore wujood ko sakhti mein daal dega ajab nahi keh aankhe’n aansoowo’n se bhar jaaye is liye keh shaaishta (behtar) hai keh aap apne mehboob se wafa kare.", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016653, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "By mentioning these brief points, we have unveiled the reality for you up to some extent but haven’t illustrated and explained it like it should have been done; and that which we mentioned is merely for providing awareness and to indicate towards it. This is because the aforementioned text falls short of explaining that which we intend to explain. And you should know that friendship and loyalty for the righteous people while living away from them is more appropriate than the friendship and loyalty expressed in their presence. Thus, this friendship and devotion should seep in the bottom of ones heart for his master; and your Lord is able to solve and remove all your grief, sorrows and difficulties.", "GujaratiDescription": null, "RUrduDescription": "Guftagoo ko bas isi par khatm karte hai agar-che is baab mein is mauzoo par likhne ke liye bohot kuchh hai lekin jin cheezo’n ki taraf ishaara kiya woh taakeed aur yaad-dahaani thi, warna jis cheez ki ham sharah (tafseer) karna chahte hai un ko alfaaz mein bayaan nahi kar sakte. Maaloom hona chahiye keh haq shanaas dosto’n ki firaaq wa judaai ke waqt wafa o mohabbat qareeb aur paas rehne ki wafa o mohabbat se kahin ziyadah hai, lehaaza ham ko chahiye keh dil mein apne Mawla ki mohabbat aur wafa rakhe’n aap ka Parwardigaar aap ke huzn o andoh ko dur karne par qaadir hai.", "UrduDescription": null