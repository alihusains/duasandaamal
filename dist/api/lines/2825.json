[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011742, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah: I do beseech You for the humbleness of those who humble themselves before You; and for the sincerity of those possessing certainty; and for the companionship of the pious ones; and for the worthiness of the truths of faith; and for gaining a share of all pious deeds; and for safety from all sins; and for the merit of Your mercy; and for the qualifications of winning Your forgiveness; and for winning Paradise; and for salvation from Hellfire.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai maangta hu Tujh se dil laga ne waalo’n ki tawajjoh, yaqeen rakhne waalo’n ka khuloos, neku-kaaro ki hamraahi (saath), imaan ki haqeeqato’n tak rasaayi (pohonch), har neki mein apni hisse-daari aur har gunah se bache rehne ki salaahiyat, neez apne liye Teri rehmat ke laazmi hone, Teri taraf se apni bakhshish ke yaqeeni hone, Jannat mein daakhil hone aur Jahannam se rehaayi ka sawaali hu.", "Urdu": "اے معبود! میں تجھ سے دل لگانے والوں کی توجہ مانگتا ہوں اور یقین رکھنے والوں کا خلوص، نیکوکاروں کی ہمراہی کا سوال کرتا ہوں اور ایمان کی حقیقتوں تک رسائی، ہر نیکی میں اپنی حصے داری اور ہر گناہ سے بچے رہنے کی صلاحیت کا خواہاں ہوں نیز اپنے لئے تیری رحمت کے لازمی ہونے، تیری طرف سے اپنی بخشش کے یقینی ہونے، جنت میں داخل ہونے اور جہنم سے رہائی کا سوال کرتا ہوں۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA IKHBAA-TAL MUKHBE-TEENA WA IKHLAA-SAL MOOQE-NEENA WA MORAA-FAQA-TAL AB-RAARE WAS-THE-QAAQA HAQAA-E-QAL IMAANE WAL GHANEE-MATA MIN KULLE BIRRIN WAS-SALAA-MATA MIN KULLE ISMIN WA WOJOO-BA RAH-MATEKA WA A’ZAA-E-MA MAGH-FERATE-KA WAL FAWZA BIL JANNATA MINAN NAARE.", "ArabicText1": "اَللّٰهُمَّ اِنِّيْ اَسْاَلُكَ اِخْبَاتَ الْمُخْبِتِيْنَ وَاِخْلَاصَ الْمُوْقِنِيْنَ وَمُرَافَقَةَ الْاَبْرَارِ وَاسْتِحْقَاقَ حَقَائِقِ الْاِيْمَانِ وَالْغَنِيْمَةَ مِنْ كُلِّ بِرٍّ وَالسَّلَامَةَ مِنْ كُلِّ اِثْمٍ وَ وُجُوْبَ رَحْمَتِكَ وَعَزَائِمَ مَغْفِرَتِكَ وَالْفَوْزَ بِالْجَنَّةِ وَالنَّجَاةَ مِنَ النَّارِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "Arabic