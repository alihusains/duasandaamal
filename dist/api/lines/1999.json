[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018456, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah I seek forgiveness from those things which I have repeated after repenting for it and I repent to You for those things which was intended for You but while doing it the intention was changed which was not for You. And I seek Your forgiveness from those bounties which was bestowed for Your obedience but I used for Your disobedience and I repent for it that there is no one other than Allah, He is the living, the self existing, knower of the unseen and present everywhere, the beneficent the merciful. I seek forgiveness for all those sins which I have committed and for all those sins which I have initiated. O Allah give me perfect intelligence and enlighten my wishes and intellect, clean heart, abundance knowledge, clear ethics, all these things which are beneficial to me and not harmful to me, O the one who is most beneficial by Your mercy.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ya Allah! Un baato’n ki taubah jin se ek martaba taubah kar ke phir wohi kiya ho, aur mai Tujh se un cheezo’n ke liye taubah karta hu jo mai ne ki thi faqat Tere liye magar phir us mein woh niyyate’n shareek ho gayi jo Tere liye na thi, aur mai taubah karta hu un ne’mato’n ke liye jo Tu ne mujhe ataa farmaayi, aur mai ne un se Teri na-farmaaniyo’n ke liye quwwat haasil ki. Mai us Allah se taubah karta hu jiske alaawah koi ma’bood nahin, Woh hayyo wa qayyum, aalam’e ghaib o huzoor (haazir) hai, rehmaan o raheem hai, har us gunah se taubah jo baja laaya hu, aur har us maasiyat se taubah jiska irtekaab kiya (anjaam diya) ho. Khudaaya! Mujhe aql’e kaamil aur iraadah’e roshan-gar, wazni o daanish-wari, paakeezah dil, bohot ziyadah ilm, numaaya’n akhlaaq ataa farma, aur yeh sab baate’n mere liye mufeed ho, muzir (nuqsaan dene waali) na ho. Ay sab se bade rahem karne waale Tujhe apni rehmat ka sadqa.", "Urdu": "یا اللہ! ان باتوں کی توبہ جن سے  ایک مرتبہ توبہ کر کے بھر وہی کیا ہو، اور میں تجھ سے ان چیزوں کے لئے توبہ کرتا ہوں جو میں نے کی تھیں فقط تیرے لئے مگر پھر اس میں وہ نیّتیں شریک ہو گئیں جو تیرے لئے نہ تھیں، اور میں توبہ کرتا ہوں ان نعمتوں کے لئے جو تونے مجھے عطا فرمائیں، اور میں نے ان سے تیری نفرمانیوں کے لئے قوت حاصل کی۔ میں اس اللہ سے توبہ کرتا ہوں، جس کے علاوہ کوئی للہ نہیں، وہ حیّ و قیّوم، عالم غیب و حضور ہے، رحمٰن و رحیم ہے، ہر اس گناہ سے توبہ جو بجا لایا ہوں، اور ہر اس معصیت سے توبہ جس کا ارتکاب کیا ہو۔ خدایا! مجھے عقل کامل اور ارادۂ روشن گر، وزنی و دانشوری، پاکیزہ دل، ہت زیادہ علم، نمایاں اخلاق، عطا فرما، اور یہ سب باتیں میرے لئے مفید ہوں، مضر نہ ہوں، اے سب سے بڑے رحم کرنے والے تجھے اپنی رحمت کا صدقہ۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَسْتَغْفِرُكَ مِمَّا تُبْتُ اِلَیْكَ مِنْهُ ثُمَّ عُدْتُ فِیْهِ وَاَسْتَغْفِرُكَ لِمَا اَرَدْتُ بِهٖ وَجْهَكَ فَخَالَطَنِیْ فِیْهِ مَا لَیْسَ لَكَ وَاَسْتَغْفِرُكَ لِلنِّعَمِ الَّتِیْ مَنَنْتَ بِهَا عَلَیَّ فَتَقَوَّیْتُ بِهَا عَلٰی مَعَاصِیْكَ اَسْتَغْفِرُ اللهَ الَّذِیْ لَا اِلٰهَ اِلَّا هُوَ الْحَیُّ الْقَیُّوْمُ عَالِمُ الْغَیْبِ وَالشَّهَادَۃِ الرَّحْمٰنُ الرَّحِیْمُ لِكُلِّ ذَنْۢبٍ اَذْنَبْتُهٗ وَلِكُلِّ مَعْصِیَۃٍ اِرْتَكَبْتُهَا۔ اَللّٰهُ