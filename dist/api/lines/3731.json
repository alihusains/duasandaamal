[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016020, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, to You have I turned my face, Your pleasure have I sought, for Your reward have I desired, in You do I believe, and on You do I rely. O Allah, (please) send blessings upon Muhammad and the Household of Muhammad, open the ears of my hearts to remembering You, make me stand firmly on the religion of You and Your Prophet, make not my hearts to deviate after You have guided me a right, and grant me from You mercy. Surely, You are the most liberal Giver.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai Teri taraf mutawajjeh hu, Teri khushnoodi ka taalib, Tere sawaab ka khwaahish-mand, Tujh par imaan rakhta hu aur Tujh par bharosa karta hu. Ay Ma’bood! Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat farma aur apne zikr ke liye mere dil ke kaan khol de aur mujhe apne aur apne Nabi (s.a.w.a) ke deen par qaaem rakh, hidaayat ke baad mere dil mein kaji (teda-pan) na aane de aur mujh par apni khaas rehmat farma, keh be-shak Tu bohot ataa karne waala hai.", "Urdu": "اے معبود! میں تیری طرف متوجہ ہو، تیری خشنودی کا طالب، تیرے ثواب کا خواہش مند، تجھ پر ایمان رکھتا ہو اور توجہ پو بھروسہ  کرتا ہو۔ اے معبود! محمدؐ و آلے محمدؑ پر رحمت فرما اور اپنے ذکر کے لئے میرے دل کے کان کھل دے اور مجھے اپنے اور اپنے نبیؐ کے دین پر قائم رکھ، ہدایت کے بعد میرے دل میں کجی نہ آنے دے اور مجھ پر اپنی خاص رحمت فرما، کہ بےشک تو بہت عطا کرنے والا ہے۔", "RArabic": "ALLAAHUMMA ILAIY-KA TAWAJJAH-TO WA MARZAA-TA-KA TALAB-TO WA SAWAABA-KAB TA-GHAIY-TO, WA BEKA AAMAN-TO WA A’LAIY-KA TAWAKKAL-TO. ALLAAHUMMA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WAF-TAH MASAAME-A’ QALBEE LE ZIKRE-KA WA SABBIT-NEE A’LAA DEENE-KA WA DEENE NABIYYE-KA WALAA TO-ZIGH QALBEE BA’DA IZ HADAIY-TANEE WA HABLEE MIN LA-DUNKA RAHMA-TAN INNA-KA ANTAL WAHHAAB.", "ArabicText1": "اَللّٰھُمَّ اِلَيْکَ تَوَجَّھْتُ وَمَرْضَاتَکَ طَلَبْتُ وَثَوَابَکَ ابْتَغَيْتُ، وَبِکَ آمَنْتُ وَعَلَيْکَ تَوَکَّلْتُ۔ اَللّٰھُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَافْتَحْ مَسَامِعَ قَلْبِیْ لِذِکْرِکَ وَثَبِّتْنِیْ عَلٰی دِيْنِکَ وَدِيْنِ نَبِيِّکَ وَلَا تُزِغْ قَلْبِیْ بَعْدَ اِذْ ھَدَيْتَنِیْ وَھَبْ لِیْ مِنْ لَدُنْکَ رَحْمَۃً اِنَّکَ اَنْتَ الْوَہَّابُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign1