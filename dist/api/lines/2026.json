[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018538, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Have mercy on my delicate skin and weak bones, save me from the burning things. If you believe in Allah then do not eat the flesh, do not drink the blood and do not show your strength on the mouth and go to the one who ascribes a partner to Allah. I believe that there is no lord except Allah and He is one without any partner and Mohammad (peace be upon him and his progeny) is His servant and His Prophet.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Meri naazuk khaal (skin) aur kamzor haddiyo’n par rahem farma, aur mujhe jalaane waale ki sozish (garmi) se panah de. Agar tu Allah par imaan rakhti hai, to gosht na kha, khoon na pee, moo’n mein zor na dikha, aur us ke paas ja jis ke khayaal mein Khuda ka koi shareek ho. Mai to yaqeenan (imaan) rakhta hu keh ek Allah ke siwa koi Allah nahin, Woh ek hai Uska koi shareek nahin, aur Hazrat Muhammad’e Mustafa (Habeeb’e Kibriya, Sayedul Mursaleen, Rehmatul Aalameen) (s.a.w.a) Usi ke bande aur rasool hai.", "Urdu": "خدایا! میری نازک کھال اور کمزور ہڈیوں پر رحم فرما، اور مجھے جلانے والے کی سوزش سے پناہ دے، اے مادر ملدم اگر تو اللہ پر ایمان رکھتی ہے، تو گوشت نہ کھا، خون نہ پی، منہ میں زور نہ دکھا، اور اس کے پاس جا جس کے خیال میں خدا کا کوئی شریک ہو، میں تو یقین رکھتا ہوں کہ ایک اللہ کے سوا کوئی اللہ نہیں، وہ ایک ہے اس کا کوئی شریک نہیں، اور حضرت محمد مصطفٰیؐ (حبیب کبریا، سید المرسلین، رحمتہ العٰلمین اس کے بندے اور رسول ہیں۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ ارْحَمْ جِلْدِیَ الرَّقِیْقِ وَعَظْمِیَ الدَّقِیْقِ وَاَعُوْذُ بِكَ مِنْ فَوْرَةِ الْحَرِیْقِ یَا اُمَّ مِلْدَمٍ اِنْ كُنْتِ اٰمَنْتِ بِاللهِ فَلَا تَاكُلِی اللَّحْمَ وَلَا تَشْرَبِیْ الدَّمَ وَلَا تُفُوْرِیْ مِنَ الْفَمِ وَانْتَقِلِیْ اِلٰی مَنْ یَزْعُمُ اَنَّ مَعَ اللهِ اِلٰهًا اٰخَرَ فَاِنِّیْ اَشْهَدُ اَنْ لَٓا اِلٰهَ اِلَّا اللهُ وَحْدَهُ لَا شَرِیْكَ لَهٗ وَاَنَّ مُحَمَّدًا عَبْدُهٗ وَرَسُوْلُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": 