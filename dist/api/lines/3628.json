[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016110, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai Allah se sawaal karta hu keh yaqeenan wohi Allah hai jiske alaawa koi aur Khuda nahi hai. Woh baadshah hai, quddus hai, salaam hai, momin hai, nigra’n aur muhaafiz hai, azeez o ghaalib hai, jaabir hai, bada hai, Allah paak o paakeeza un cheezo’n se jin ko mushrekeen Uska shareek qaraar dete hai, Woh Khuda khaaliq hai, paiyda karne waala hai, tasveer kashi karne (surat banaane) waala hai, Uske liye achchhe naam hai, jo cheez bhi aasmaano aur zameen mein hai sab Usi ki tasbeeh karti hai. Woh ghaalib aur hikmat waala hai.", "Urdu": "میں اللہ سے سوال کرتا ہوں کہ یقینًا وہی اللہ ہے جس کے علاوہ کوئی اور خدا نہیں ہے، وہ بادشاہ ہے، قدوس ہے، سلام ہے، مومن ہے، نگراں اور محافظ ہے، عزیز و غالب ہے، جابر ہے، بڑا ہے، اللہ پاک و پاکیزہ ان چیزوں سے جن کو مشرکین اس کا شریک بتاتے ہیں، وہ خدا خالق ہے، پیدا کرنے والا ہے، تصور کشی کرنے والا ہے، اس کے لئے اچھے نام ہیں، جو چیز بھی آسمانوں اور زمینوں میں ہے سب اس کی تسبیح کرتی ہے، وہ غالب اور حکمت والا ہے۔", "RArabic": "AS-ALUL LAAHA BE-ANNAHU HOWAL LAAHUL LAZEE LAA ELAAHA ILLAA HOWAL MALEKUL QUDDOOSUS SALAAMUL MOA-MENUL MOHAYMENUL A’ZEEZUL JABBAARUL MOTAKABBERUL SUBAHAANAL LAAHE A’MMAA YUSHREKOONA HOWAL LAAHUL KHAALEQUL BAAREUL MOSAWWERO LAHUL ASMAAA-UL HUSNAA YOSABBEHO LAHU MAA FIS SAMAAWAATE WAL ARZE WA HOWAL A’ZEEZUL HAKEEMO.", "ArabicText1": "اَسْئَلُ اللهَ بِاَنَّہٗ ہُوَ اللهُ الَّذِیْ لَا اِلٰہَ اِلَّا ہُوَ الْمَلِكُ الْقُدُّوْسُ السَّلَامُ الْمُؤْمِنُ الْمُہَیْمِنُ الْعَزِیْزُ الْجَبَّارُ الْمُتَكَبِّرُ۔ سُبْحَانَ اللهِ عَمَّا یُشْرِكُوْنَ ہُوَ اللهُ الْخَالِقُ الْبَارِئُ الْمُصَوِّرُ لَہُ الْاَسْمَآئُ الْحُسْنٰی یُسَبِّحُ لَہٗ مَا فِی السَّمٰوَاتِ وَالْاَرْضِ وَہُوَ الْعَزِیْزُ الْحَكِیْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign