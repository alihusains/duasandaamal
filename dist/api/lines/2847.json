[{"Id": 1009870, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is Mustahab to mention the name of Allah while leaving for Eid Namaz and Juma Namaz and to recite this dua…", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh Allah ka naam le jab Eid Namaz ya Juma Namaz ke liye ghar se niklo, aur yeh dua padhe…", "UrduDescription": "ابو حمزہ ثمالی نے امام محمد باقر ؑسے روایت کی ہے کہ عید فطر،عید قربان اور جمعہ کے روز جب نماز کے لئے نکلے تو یہ کہو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009871, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, if one, on this day, prepares oneself, takes pains, gets ready, or prepares oneself to visit another one, hoping for his aid, gifts, benefits, and grants; for You alone, my Lord, is my readiness, preparations, taking pains, training, and inclination in the hope of gaining Your aid, gifts, grants, benefits, bounties, and donations. I find myself celebrating one of the feasts commemorated by the nation of Your Prophet, Muhammad, blessings of Allah be upon him and his Household.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Mabood! Jo shakhs aamaada hai aaj ke din, ya qamar basta hai, ya taiyyari karta aur taiyyar hota hai logo’n ki taraf jaane ko us ummeed se keh un se naqdi cheeze’n, bakhshishe aur ataae’n haasil kare. Lekin ay mere Aaqa! Meri taiyyari, meri amaadghi aur meri saari koshish Teri taraf aane mein hai keh mai ummeed-waar hu Teri ataa, Tere inaam, Teri inaayato’n, Tere ehsaano, Teri maher-baaniyo’n aur bakhshisho’n ka. Aur aaj subh ki hai mai ne ek Eid ke din jo un Eido’n mein se hai jo muqarrar ki Tere Nabi Muhammad (s.a.w.a) ne keh Khuda ki rehmate’n ho un par aur unki Aal (a.s) par.", "Urdu": "اے معبود! جو شخص آمادہ ہے آج کے دن یا کمر بستہ ہے یا تیاری کرتا اور تیار ہوتا ہے لوگوں کی طرف جانےکے لئے اس امید سے کہ ان سے نقدی چیزیں بخششیں اور عطائیں لے لیکن اے میرے آقا میری تیاری میری آمادگی اور میری ساری کوشش تیری طرف آنے میں ہے کہ میں امیدوارہوں تیری عطاتیرے انعام تیری عنایتوں تیرے احسانوں تیری مہربانیوں اور بخششوں کا اور آج صبح کی ہے میں نے ایک عید کے دن جوان عیدوں سے ہے جو مقرر کیں تیرے نبی محمدؐ نے کہ خدا کی رحمتیں ہوں ان پر اور ان کی آلؑ پر اور۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ مَنْ تَهَيَّا فِي هٰذَا الْيَوْمِ اَوْ تَعَبَّا اَوْ اَعَدَّ وَاسْتَعَدَّ لِوِفَادَةٍ اِلٰى مَخْلُوْقٍ رَجَآءَ رِفْدِهٖ وَنَوَافِلِهٖ وَفَوَاضِلِهٖ وَعَطَايَاهُ فَاِنَّ اِلَيْكَ يَاسَيِّدِيْ تَهْيِئَتِيْ وَتَعْبِئَتِي وَاِعْدَادِيْ وَاسْتِعْدَادِيْ رَجَآءَ رِفْدِكَ وَجَوَآئِزِكَ وَنَوَافِلِكَ وَفَوَاضِلِكَ وَفَضَآئِلِكَ وَعَطَايَاكَ وَقَدْ غَدَوْتُ اِلٰى عِيْدٍ مِّنْ اَعْيَادِ اَمَّةِ نَبِيِّكَ مُحَمَّدٍ صَلَوَاتُ اللهِ عَلَيْهِ وَعَلٰى آلِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGre