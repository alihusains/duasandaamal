[{"Id": 1000104, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Recite the following dua after Namaz-e-Zohr as is quoted from Misbah al-Mutahajjid…", "GujaratiDescription": null, "RUrduDescription": "Namaz-e-Zohr ke baad is dua ko padhe jo Misbah al-Mutahajjid se naql ki gayi hai…", "UrduDescription": "کتاب مصباح المتھجد میں ہے کہ نماز ظہر کی تعقیبات کے بعد یہ دعا پڑھیں۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000105, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "There is no god But Allah, the Great, the Clement: there is no god but Allah, the Lord of ‘Arsh (the throne) of Grace; and all praise is for Allah, the Lord of the worlds: O Allah I beseech Thee for all that time which is the cause of Thy Mercy, and that which ascertain Thy Forgiveness: and the benefit of every virtue, and safety from every sin.", "Gujarati": null, "RGujarati": null, "RUrdu": "Azeem aur burdbaar Allah ke siwa koi Khuda nahi hai aur arsh ke maalik wa karim Allah ke alaawa koi Mabood nahi hai. Tamaam hamd us Khuda ke liye hai jo aalameen ka Rab hai. Khudaaya! Mai Tujh se us cheez ka sawaal karta hu jo Teri rehmat wa maghferat ka sabab hai. (Aur sawaal karta hu) keh har neki se faaida uthaawo’n aur har gunah se mehfooz wa bachne ki taufiq ataa ho jaaye.", "Urdu": "خدائے عظیم و حلیم کے سوا کوئی معبود نہیں، رب ِعرشِ بریں کے سوا کوئی سزاوارِخدا نہیں۔تمام حمد عالمین کے پالنے والے خدا ہی کے لئے ہے، اے خدا!میں تجھ سے تیری رحمت اور یقینی مغفرت کے اسباب کا سوال کرتا ہوں،ہر نیکی سے حصہ پانے اور ہر گناہ سے بچاؤ کا طلب گار ہوں۔", "RArabic": "LAA ELAAHA ILLALLAAHUL A’ZEEMUL HALEEMO, LAA ELAAHA ILLALLAAHO RABBUL A’RSHIL KAREEME, AL-HAMDOLILLAAHE RABBIL A’ALAMEENA, ALLAAHUMMA INNEE AS-ALOKA MOOJEBAATE RAHMATEKA, WA A’ZAA-EME MAGHFERATEKA WAL GHANEEMATA MIN KULLE BIRRIN, WAS-SALAAMATA MIN KULLE ISMIN.", "ArabicText1": "لَا اِلٰہَ اِلَّااللہُ الْعَظِیْمُ الْحَلِیْمُ لَآ اِلٰہَ اِلَّااللہُ رَبُّ الْعَرْشِ الْکَرِیْمِ اَلْحَمْدُ لِلہِ رَبِّ الْعَالَمِیْنَ۔ اَللّٰھُمَّ اِنِّیْ اَسْئَلُکَ مُوْجِبَاتِ رَحْمَتِکَ وَعَزَآئِمَ مَغْفِرَتِکَ وَالْغَنِیْمَۃَ مِنْ کُلِّ بِرٍّ وَّالسَّلَامَۃَ مِنْ کُلِّ اِثْمٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010125, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah leave not any sin on me but that You forgive it, and any affliction but that You remove it, and any illness but that You heal it, and any defect but that You conceal it, and any subsistence but that You increase it, and any fear but that You protect (me) from it; and any evil but that You repel it, an any of my need in which is Thy pleasure and which is beneficial for me, but that You grant it; O that Most Merciful, grant me my supplication, O’ the Lord of the Worlds.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Tu mere kisi gunah ko gunah na rehne de bal-keh usey bakhsh de aur kisi gham ko gham na rehne de bal-keh usey Khushi mein badal de aur mere kisi maraz ko bhi baaqi na rakh bal-keh usey shafa ataa kar de. (Mabood!) Mere tamaam oyub ko chhupa de aur mere tamaam rizq ko wasee’a farma de aur mere tamaam khouf ko amn (peace) o amaan se tabdeel kar de aur meri kisi buraayi ko mujh mein baaqi na rehne de bal-keh usey mujh se dur farma de aur meri tamaam aisi haajate’n’n jis mein Teri razaa ho aur us mein meri bhalaayi bhi ho, Tu usey pura kar de. Ay sabse badey rahem karne waale! Meri un duaao’n ko qabool farma. Ay aalameen ke paalne waale.", "Urdu": "اے معبود! میرے ذمہ کوئی ایسا گناہ نہ چھوڑ جسے تو معاف نہ کرے۔ کوئی غم نہ دے جسے تو دور نہ کر دے، بیماری نہ دے مگر وہ جس سے شفا عطا کردے، عیب نہ لگا مگر وہ جسے تو پوشیدہ رکھے،رزق نہ دے مگر وہ جس میں فراخی عطا کرے، خوف نہ ہومگر جس سے تو امن عطا کرے، برائی نہ آئے مگر وہ جسے تو ہٹا دے، کوئی حاجت نہ ہو مگر جسے تو پورا فرمائے اور اس میں تیری رضا اور میری بہتری ہو۔ اے سب سے زیادہ رحم کرنے والے! آمین اے عالمین کے پالنے والے۔", "RArabic": "ALLAAHUMMA LAA TADA’ LEE ZANBAN ILLAA GHAFARTAHU, WA LAA HAMMAN ILLAA FARRAJTAHU, WA SUQMAN ILLAA SHAFAYTAHU, WA LAA A’YBAN ILLAA SATARTAHU, WA LAA RIZQAN ILLAA BASAT-TAHU WA LAA KHAWFAN ILLAA AAMANTAHU, WA LAA SOOO-AN ILLAA SARAFTAHU, WA LAA HAAJATAN HEYA LAKA REZAN WA LEYA FEEHAA SALAAHAN, ILLAA QAZAYTAHAA, YAA ARHAMAR RAAHEMEENA AAMEENA RABBAL A’ALAMEENA.", "ArabicText1": "اَللّٰھُمَّ لَا تَدَعْ لِیْ ذَنْبًا اِلَّا غَفَرْتَہٗ وَلَاھَمًّااِلَّا فَرَّجْتَہٗ وَلَا سُقْمًا اِلَّا شَفَیْتَہٗ وَلَا عَیْبًا اِلَّا سَتَرْتَہٗ وَلَا رِزْقًا اِلَّا بَسَطْتَّہٗ وَلَا خَوْفًا اِلَّااٰمَنْتَہٗ وَلَا سُوٓئً اِلَّا صَرَفْتَہٗ وَلَاحَاجَۃً ھِیَ لَکَ رِضًا وَلِیَ فِیْھَا صَلَاحٌ اِلَّا قَضَیْتَھَا یَااَرْحَمَ الرَّاحِمِیْنَ اٰمِیْنَ رَبَّ الْعَالَمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": 