[{"Id": 1016640, "EnglishTitle": "PLEASE NOTE: Be it clear that the reason for presenting Translation is to understand Salaat and to recite in Arabic with concentration because reciting Salaat other than Arabic language (or Transliteration) is not correct.", "GujaratiTitle": null, "RUrduTitle": "Waazeh rahe keh tarjuma-e-namaz pesh karne ki asal wajah namaz samajh ke Arabi mein khuzoo aur tawajjoh ke saath namaz padhna hai. Kyu’n keh Arabi ya Roman-Arabi (Transliteration) ke siwa kisi aur zabaan mein namaz padhna sahih nahin hai.", "UrduTitle": "واضح رہے کہ ترجمۂ نماز پیش کرنے کی اصل غرض نماز سمجھ کے عربی میں خضوع اور توجہ کے ساتھ نماز پڑھنا ہے۔ کیوں کہ عربی کے سوا کسی اور زبان میں نماز پڑھنا صحیح نہیں ہے۔ اس لئے ہر ایک کے لئے نماز کی حد تک قرآن و عربی سیکھنا واجب ہے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002805, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "The Holy Prophet (s) is reported as having mentioned a great reward for those who offer a special prayer on Sundays in Zilqad, adding that their repentance would be accepted, their sins forgiven, their rivals made pleased with them on the Resurrection Day, caused to die on true faith, given the true religion, granted expansion and light in the grave, the parents made pleased with them, their parents and offspring had their sins forgiven, provided with expansive sustenance, and granted lenience of the Angel of Death and easiness of their souls leaving their bodies.", "GujaratiDescription": null, "RUrduDescription": "Rasoole Khuda (s) ka farmaan hai keh jo shakhs is namaz ko baja laaye uski taubah qabool hoti hai, gunah bakhsh diye jaate hai, qayaamat mein dushman us se raazi ho jaayenge, uski maut imaan par hogi aur uska deen salaamat rahega. Uski qabr wasee o roshan hogi, uske waaledain us se raazi honge, uske waaledain aur aulaad ko maghferat haasil hogi, uske rizq mein wus’at hogi, Malakul Maut uski rooh narmi se qabz karega aur uski maut aasaan hogi.", "UrduDescription": "اس ماہ میں اتوار کے دن کی ایک نماز ہے جو بڑی فضیلت رکھتی ہے، حضرت رسول اﷲؐکا فرمان ہے : جو شخص اس نماز کو بجا لائے اس کی توبہ قبول ہوتی ہے، گناہ بخشے جاتے ہیں، قیامت میں دشمن اس سے راضی ہوجائیں گے، اس کی موت ایمان پر ہوگی اور اس کا دین سلامت رہےگا۔ اس کی قبر وسیع و روشن ہوگی اس کے والدین اس سے راضی ہوں گے، اس کے والدین اور اولاد کو مغفرت حاصل ہوگی، اس کے رزق میں وسعت ہوگی، ملک الموت اس کی روح نرمی سے قبض کرے گا اور اس کی موت آسان ہوگی۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1002806, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "This namaz to be recited on any or all Sunday of Zilqad. The method of this prayer is that one should perform Ghusl (spiritual bath) on Sunday, followed by Wuzu, and offer 4 rakat namaz, in the form of (2x2). In each rakat after <Surah Fateha> recite <Surah Ikhlaas> 3 times, <Surah Falaq> and <Surah Naas> once each. After completing 4 rakat namaz say 70/100 times…", "GujaratiDescription": null, "RUrduDescription": "Yeh namaz ko Ziqadah ke kisi bhi ek ya sabhi Sunday ko anjaam de. Namaz se pehle Ghusl aur Wuzu kare. 4 rakat namaz, 2x2 kar ke padhe. Har rakat mein <Surah Fateha> ke baad 3 martaba <Surah Ikhlaas> aur 1 martaba <Surah Falaq> aur <Surah Naas> padhe. 4 Rakat namaz tamaam kar ke 70/100 martaba kahe…", "UrduDescription": "اس نماز کا طریقہ یہ ہے:اتوار کے دن غسل اور وضو کرکے ۴ رکعت نماز دو دو کر کے پڑھے جس کی ہر رکعت میں <سورۂ فاتحہ> کے بعد ۳ مرتبہ <سورۂ اخلاص> اور ایک ایک مرتبہ <سورۂ فلق> و <سورۂ ناس> کی قرائت کرے، نماز کے بعد ۷۰/۱۰۰ مرتبہ استغفار کرے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText1