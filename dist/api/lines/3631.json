 پناہ چاہتا ہے، اے سب سے بہتر مسئول، اے سب سے پہتر عطا کرنے والے، اے طالب رحم پر سب سے بہتر رحم کرنے والے! میرے کئے اپنی رحمت کو جلیل کردے اور اپنی عافیت کا لباس پہنا دے، اور اپنی تمام مخلوقات کے شر کو مجھ سے دور کردے اور مجھے دنیا و آخرت کی بھلائی عطا فرما۔", "RArabic": "ALLAAHUMMA INNEE A-O’OZO BEKA MENAL FAQRE WA MIN TASHATTOTIL OMOORE WA MIN SHARRE MAA YAHDOSO LEE BIL LAYLE WAN NAHAARE AMSAA ZULMEE MUSTAJEERAN BE-A’FWEKA WA AMSAA KHAWFEE MUSTAJEERAN BE-AMAANEKA WA AMSAA ZONOOBEE MUSTAJEERAN BE-I’ZZEKA WA AMSAA WAJHEYAL FAANEE MUSTAJEERAN BEWAJHEKAL BAAQEE YAA KHAYRA MAN SO-ELA WA YAA AJWADA MAN A-A’TAA YAA ARHAMA MANIS TURHEMA JALLILNEE BE-RAHMATEKA WA ALBISNEE A’AFEYATEKA WAS-RIF A’NNEE SHARRA JAMEE-E’ KHALQEKA WAR-ZUQNEE KHAYRAD DUNYAA WAL-AAKHERATE.", "ArabicText1": "اَللّٰہُمَّ اِنِّیْ اَعُوْذُ بِكَ مِنَ الْفَقْرِ وَمِنْ تَشَتُّتِ الْاُمُوْرِ وَمِنْ شَرِّ مَا یَحْدُثُ لِیْ بِاللَّیْلِ وَالنَّہَارِ اَمْسٰی ظُلْمِیْ مُسْتَجِیْرًا بِعَفْوِكَ وَاَمْسٰی خَوْفِیْ مُسْتَجِیْرًا بِاَمَانِكَ وَاَمْسٰی ذُنُوْبِیْ مُسْتَجِیْرًا بِعِزِّكَ وَاَمْسٰی وَجْہِیَ الْفَانِیْ مُسْتَجِیْرًا بِوَجْہِكَ الْبَاقِیْ یَا خَیْرَ مَنْ سُئِلَ وَیَا اَجْوَدَ مَنْ اَعْطٰی یَا اَرْحَمَ مَنِ اسْتُرْحِمَ جَلِّلْنِیْ بِرَحْمَتِكَ وَاَلْبِسْنِیْ عَافِیَتَكَ وَاصْرِفْ عَنِّیْ شَرَّ جَمِیْعِ خَلْقِكَ وَارْزُقْنِیْ خَیْرَ الدُّنْیَا وَالْآخِرَۃِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicTe