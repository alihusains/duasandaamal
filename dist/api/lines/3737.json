[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1003204, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 163, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And your God is one God! there is no god but He; He is the Beneficent, the Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur tumhaara Khuda bas ek hai. Uske alaawa koi Khuda nahi hai wohi Rehman bhi hai aur wohi Raheem bhi hai.", "Urdu": "اور تمہارا خدا بس ایک ہے، اس کے علاوہ کوئی خدا نہیں ہے وہی رحمان بھی ہے اور وہی رحیم بھی ہے۔", "RArabic": "WA ILAAHUKUM ILLAAHUNW WAAHID, LAAA ILAAHA ILLAA HUWAR RAHMAANUR RAHEEM.", "ArabicText1": "وَاِلٰهُكُمْ اِلٰهٌ وَّاحِدٌ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": "ج ", "ArabicText2": "لَآ اِلٰهَ اِلَّا هُوَ الرَّحْمٰنُ الرَّحِيْمُ", "ArabicGreenSign2": null, "ArabicRedSign2": "ع19", "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1003205, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 164, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Most surely in the creation of the heavens and the earth and the alternation of the night and the day, and the ships that run in the sea with that which profits men, and the water that Allah sends down from the cloud, then gives life with it to the earth after its death and spreads in it all (kinds of) animals, and the changing of the winds and the clouds made subservient between the heaven and the earth, there are signs for a people who understand.", "Gujarati": null, "RGujarati": null, "RUrdu": "Be-shak zameen o aasmaan ki khilqat roz o shab ki raft o aamad (aana-jaana). Un kashtiyo’n mein jo dariyaao mein logo’n ke faaide ke liye chalti hai aur us paani mein jise Khuda ne aasmaan se naazil kar ke uske zariye murda zameeno ko zinda kar diya hai aur us mein tarah-tarah ke chopaaye (animals having 4 leg) phaila diye hai aur hawaao’n ke chalne mein aur aasmaan o zameen ke darmiyaan musakkhar (paiyda) kiye jaane waale baadal mein sahebaan'e aql ke liye Allah ki nishaaniya paayi jaati hai.", "Urdu": "بےشک زمین و آسمان کی خلقت روز و شب کی رفت وآمد، ان کشتیوں میں جو دریاؤں میں لوگوں کے فائدہ کے لئے چلتی ہیں اور اس پانی میں جسے خدا نے آسمان سے نازل کرکے اس کے ذریعہ مردہ زمینوں کو زندہ کردیا ہے اور اس میں طرح طرح کے چوپائے پھیلا دیئے ہیں اور ہواؤں کے چلانے میں اور آسمان و زمین کے درمیان مسخر کئے جانے والے بادل میں صاحبانِ عقل کے لئے اللہ کی نشانیاں پائی جاتی ہیں۔", "RArabic": "INNA FEE KHALQIS SAMAAWAATI WAL ARDI WAKHTILAAFIL LAILI WANNAHAARI WALFULKIL LATEE TAJREE FIL BAHRI BIMAA YANFA’UNNAASA WA MAAA ANZALAL LAAHU MINAS SAMAAA’I MIM MAAA’IN FA AHYAA BIHIL ARDA BA’DA MAWTIHAA WA BAS SA FEEHAA MIN KULLI DAAABBATINW WA TASREEFIR RIYAAHI WASSAHAABIL MUSAKHKHARI BAINAS SAMAAA’I WAL ARDI LA AAYAATIL LIQAWMINY YA’QILOON.", "ArabicText1": "اِنَّ فِيْ خَلْقِ السَّمٰوٰتِ وَالْاَرْضِ وَاخْتِلَافِ الَّيْلِ وَالنَّهَارِ وَالْفُلْكِ الَّتِيْ تَجْرِيْ فِي الْبَحْرِ بِمَا يَنْفَعُ النَّاسَ وَمَآ اَنْزَلَ اللهُ مِنَ السَّمَاۗءِ مِن مَّاۗءٍ فَاَحْيَا بِهِ الْاَرْضَ بَعْدَ مَوْتِهَا وَبَثَّ فِيْهَا مِنْ كُلِّ دَاۗبَّةٍ", "ArabicGreenSign1": "ص  ", "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": "وَّتَصْرِيْفِ الرِّيٰحِ وَالسَّحَابِ الْمُسَخَّرِ بَيْنَ السَّمَاۗءِ وَالْاَرْضِ لَاٰيٰتٍ لِّقَوْمٍ يَّعْقِلُوْنَ", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1003206, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 165, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And there are some among men who take for themselves objects of worship besides Allah, whom they love as they love Allah, and those who believe are stronger in love for Allah and O, that those who are unjust had seen, when they see the chastisement, that the power is wholly Allah’s and that Allah is severe in requiting (evil).", "Gujarati": null, "RGujarati": null, "RUrdu": "Logo’n mein kuchh aise log bhi hai jo Allah ke alaawa dusro’n ko Uska misl (jaisa) qaraar dete hai aur un se Allah jaisi mohabbat bhi karte hai jab-keh imaan waalo’n ki tamaam-tar mohabbat Khuda se hoti hai aur ay kaash zaalemeen is baat ko us waqt dekh lete jo azaab ko dekhne ke baad samjhe-ge ke saari quwwat sirf Allah ke liye hai aur Allah sakht-tareen azaab karne waala hai.", "Urdu": "لوگوں میں کچھ ا یسے لوگ بھی ہیں جو اللہ کے علاوہ دوسروں کو اس کا مثل قرار دیتے ہیں اور ان سے اللہ جیسی محبت بھی کرتے ہیں جب کہ ایمان والوں کی تمام تر محبّت خدا سے ہوتی ہے اور اے کاش ظالمین اس بات کو اس وقت دیکھ لیتے جو عذاب کو دیکھنے کے بعد سمجھیں گے کہ ساری قوت صرف اللہ کے لئے ہے اور اللہ سخت ترین عذاب کرنے والا ہے۔", "RArabic": "WA MINAN NAASI MAI YATTAKHIZU MIN DOONIL LAAHI ANDAADAI YUHIBBOONAHUM KAHUBBIL LAAHI WALLAZEENA AAMANOOO ASHADDU HUBBAL LILLAH; WA LAW YARAL LAZEENA ZALAMOO IZ YARAWNAL ’AZAABA ANNAL QUWWATA LILLAAHI JAMEE’ANW WA ANNALLAAHA SHADEEDUL ’AZAAB.", "ArabicText1": "وَمِنَ النَّاسِ مَن يَّتَّخِذُ مِنْ دُوْنِ اللهِ اَنْدَادًا يُّحِبُّوْنَهُمْ كَحُبِّ اللهِ", "ArabicGreenSign1": null, "ArabicRedSign1": "ط ", "ArabicBlueSign1": null, "ArabicText2": "وَالَّذِيْنَ اٰمَنُوْٓا اَشَدُّ حُبًّا لِّلهِ", "ArabicGreenSign2": null, "ArabicRedSign2": "ط ", "ArabicBlueSign2": null, "ArabicText3": "وَلَوْ يَرَى الَّذِيْنَ ظَلَمُوْٓا اِذْ يَرَوْنَ الْعَذَابَ اَنَّ الْقُوَّةَ لِلهِ جَمِيْعًا وَّاَنَّ اللهَ شَدِيْدُ الْعَذَابِ", "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 4, "EnglishTitle": null,