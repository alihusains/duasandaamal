[{"Id": 1000710, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Holy Prophet (s.a.w.a) asked to Gabriel: What is the virtue of these words? Gabriel said: Far away! Far away! It is something impossible, for if the angels of seven heavens and seven earths gather to describe its virtues till the Day of Judgment, they are not able to describe a single part of it.", "GujaratiDescription": null, "RUrduDescription": "Rasoole Khuda (s) ne Jibraeel (a) se pooncha: Is dua ka ajr kiya hai? Jibareel (a) ne kaha: bohot bohot! Na mumkin hai. Agar 7 aasmaano aur zameeno ke farishte jama ho kar Qayaamat ke din tak iska ajr likhna chahe to bhi woh bayaan nahi kar sakte hai…", "UrduDescription": "یہ وہ دعا ہے جوانسانوں کو گناہوں سے بچاتی ہے اور دنیا وآخرت دونوں کے لئے مفید ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlu