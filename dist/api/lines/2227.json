[{"Id": 1016203, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is narrated from Imam Jafar Sadiq (a) say, that anyone from you who need the help from God, then he should offer a 2 rakat namaz. Upon accomplishment, go into sajdah and say…", "GujaratiDescription": null, "RUrduDescription": "Imam Jafar Sadiq (a) se riwaayat hai keh aap mein se koi agar baargah-e-Khuda mein isteghasa karna chahta ho, to usey chahiye keh 2 rakat namaz adaa kare aur namaz ke baad sajdeh mein ja kar kahe…", "UrduDescription": "امام جعفرصادق علیہ السلام سے روایت ہے کہ آپ میں سے کوئی اگر بارگاہ ایزدی میں استغاثہ کرنا چاہتا ہو، تو اسے چاہیے کہ ۲ رکعت نماز پڑھے، پھر سجدہ میں جا کر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBl