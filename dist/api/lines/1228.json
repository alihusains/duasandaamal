[{"Id": 1018194, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Ayatollah Mohammed Baqir Fishraki in his booklet for the Amaal’s of Rajab, Shaban and Ramazan writes that a person life increases by 11 years if this dua is recited on the last Friday of the month of Rajab…", "GujaratiDescription": null, "RUrduDescription": "Ayatullah Muhammad Baqir Fishraki ne apni kitaab Amaal’e Mahe Rajab, Shaban aur Ramazan mein tehreer farmaayi hai, keh us shakhs ki zindagi mein 11 saal ka izaafa hoga jo is dua ko Mahe Rajab ke aakhri Juma mein padhega…", "UrduDescription": "آیت اللہ محمد باقر فشراکی نے اپنی کتاب عمالِ ماہِ رجب، شعبان اور رمضان میں تحریر فرمائی ہے، کہ اس شخص کی زندگی میں ۱۱؍ سال کا اضافہ ہو گا جو اس دعا کو ماہِ رجب کے آخری جمعہ میں پڑھے گا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "A