[{"Id": 1010751, "EnglishTitle": "Eve of 10th Muharram", "GujaratiTitle": null, "RUrduTitle": "10th Muharram ki shab", "UrduTitle": "دسویں محرم کی رات", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011929, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "As regarding the reward of spending this whole night with acts of worship, is considered having worshipped Almighty Allah with the worship of all the angels. Furthermore, to practice acts of worship at this night is equal to 70 years worship.", "GujaratiDescription": null, "RUrduDescription": "Is raat mein jaag ne (be-daar rahne) waala us ke misl hai jis ne tamaam malaayeka jitni ibaadat ki ho, us raat mein ki gayi ibaadat ka sawaab 70 saal ki ibaadat ke bara-bar hai.", "UrduDescription": "یہ شب ِعاشور ہے،سید ؒنے اس رات کی بہت سی بافضیلت نمازیں اور دعائیں نقل فرمائی ہیں۔ اس رات بیداری کی فضیلت میں روایت وارد ہوئی ہے کہ اس رات کو جاگنے والا اس کے مثل ہے جس نے تمام ملائکہ جتنی عبادت کی ہو، اس رات میں کی گئی عبادت ۷۰ سال کی عبادت کے برابر ہے۔ اگر کسی شخص کے لئے یہ ممکن ہو تو آج رات کو اسے سر زمین کربلا میں رہنا چاہیے، جہاں وہ حضرت امام حسین ؑکے روضۂ اقدس کی زیارت کرے اور حضرت امام حسین ؑ کے قرب میں شب بیداری کرے تاکہ خدا اس کو امام حسین ؑکے ساتھیوں میں شمار کرے جو اپنے خون میں لتھڑے ہوئے تھے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, 