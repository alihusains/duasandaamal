[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018455, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I seek forgiveness of all those sins of which You have knowledge of either it is of my good deeds or evil deeds, knowledge of my whole life, or from first to last, knowingly or unknowingly or the knowledge of my sins which I have erred erroneously whether little or great, big or small, old and new, secret or open and those sins of which I am guilty of. And I ask forgiveness of You and request You to send blessings on Mohammad (s.a.w.a) and the progeny of Mohammed (a.s) and forgive all my excuses which I have done on Your creation and is in Your knowledge because their rights are incumbent on me and I am responsible of it. But You can forgive them as You desire O the most merciful of all the mercifuls.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ya Allah! Mai Tujh se har us gunah ke liye bakhshish maangta hu jo mere mutaalliq Tere ilm mein aaya ho, khwah (chahe) woh meri khubiyo’n (achchhaayi) ka ilm ho ya badee (buraayi) ka, meri zindagi bhar ka ilm, meri zindagi ke awwal se aakhir tak ka ilm, jaan bujh kar ya galti se ya bhool chuk se hone waale gunaho’n ka ilm, kam aur ziyadah, chhote aur bade, naye aur puraane, khufiya aur elaaniya (zaahir) khataawo’n ka ilm, aur un tamaam cheezo’n ka ilm jin ka mai gunah-gaar hu, aur mai Tujh se taubah karta hu, aur dar-khwaast karta hu keh Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma, aur meri un tamaam ziyaadatiyo’n ko maaf kar de jo mai ne Tere bando’n par ki ho, aur Tere ilm mein ho, kyu’n keh Tere bando’n ke mujh par kuchh haq hai aur mai unka zimmedaar hu, magar Tu unhe’n maaf kar sakta hai, jis tarah chahe aur jab chahe, ay maher-baano mein sab se bade maher-baan.", "Urdu": "یا اللہ! میں تجھ سے ہر اس گناہ کے لئے بخشش مانگتا ہوں جو میرے متعلق تیرے علم میں آیا ہو، خواہ وہ میری کوبیوں کا علم ہو یا بدی کا، مری زندگی بھر کا علم، میری زندگی کے اول سے آخر تک کا علم، جان بوجھ کر، یا غلطی سے یا بُھول جوک سے ہونے والے گناہوں کا علم، کم اور زیادہ، چھوٹے اور بڑے، نئے اور پُرانے، خفیہ اور علانیہ خطاؤں کا علم، اور ان تمام چیزوں کا علم جن کا میں گنہگار ہوں، اور میں تجھ سے توبہ کرتا ہوں، اور درخواست کرتا ہوں کہ محمدؐ و آل محمدؑ پر رحمت نزل فرم، اور میری ان تمام زیادتیوں کو معاف کر دے جو میں ے تیرے بندوں پر کی ہوں، اور تیرے علم میں ہوں، کیونکہ تیرے بندوں کے مجھ پر کچھ حق ہیں اور میں ان کا ذمّے دار ہوں، مگر تو انہیں معاف کر سکتا ہے، جس طرح چاہے اور جب چاہے، اے  مہربانوں میں سب سے بڑے مہربان۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَسْتَغْفِرُكَ لِكُلِّ ذَنْۢبٍ جَرٰی بِهٖ عِلْمُكَ فِیَّ وَعَلَیَّ اٰخِرِ عُمْرِیْ بِجَمِیْعِ ذُنُوْبِیْ لِاَوَّلِهَا وَاٰخِرِهَا وَعَمَدِهَا وَخَطَائِهَا وَقَلِیْلِهَا وَكَثِیْرِهَا وَدَقِیْقِهَا وَجَلِیْلِهَا وَقَدِیْمِهَا وَحَدِیْثِهَا وَسِرِّهَا وَعَلَانِیَتِهَا وَجَمِیْعِ مَا اَنَا مُذْنِبُهٗ وَاَتُوْبُ اِلَیْكَ وَاَسْئَلُكَ اَنْ تُصَلِّیَ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَاَنْ تَغْفِرْلِیْ جَمِیْعَ مَا اَحْصَیْتَ مِنْ مَظَالِمِ الْعِبَادِ قِبَلِیْ فَاِنَّ لِعِبَادِكَ عَلَیَّ حُقُوْقًا وَاَنَا مُرْتَهَنٌ بِهَا تَغْفِرُهَا فِیْ كَیْفَ شِئْتَ وَاَنّٰی شِئْتَ یَا اَرْحَمَ الرَّحِمِیْنَ۔"