l, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1013978, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah (I begin), in Allah (I trust), and on the way of Allah and on the norm of the Messenger of Allah (I proceed), may Allah bless him and his Household. O Allah, (please do) forgive me, my parents, and all the believing men and women.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke naam se, Khuda ki zaat ke waaste se, Khuda ki raah mein aur Rasool'e Khuda (s.a.w.a) ke deen par Khuda rehmat kare un par aur unki Aal (a.s) par. Ay Ma’bood! Bakhsh de mujhe aur mere waaledain ko aur tamaam momeneen o momenaat ko.", "Urdu": "خدا کے نام سے خدا کی ذات کے واسطے سے خدا کی راہ میں اور رسول ؐ خدا کے دین پر خدا رحمت کرے ان پر اور ان کی آل ؑ پراے معبود!بخش دے مجھے اور میرے والدین کو اور تمام مومنین و مومنات کو۔", "RArabic": "BISMIL LAAHE WA BILLAAHE WA FEE SABEELIL LAAHE WA A’LAA MILLATE RASOOLIL LAAHE SALLAL LAAHO A’LAIHE WA AALEHI ALLAAHUMMAGH FIRLEE WA LE WAALEDAYYA WA LE JAMEE-I’L MOMENEENA WAL MOMENAATE.", "ArabicText1": "بِسْمِ اللہِ وَبِاللہِ وَفِیْ سَبِیْلِ اللہِ وَعَلٰی مِلَّۃِ رَسُوْلِ اللہِ صَلَّی اللہُ عَلَیْهِ وَاٰلِهٖ۔ اَللّٰهُمَّ اغْفِرْ لِیْ وَلِوَالِدَیَّ وَلِجَمِیْعِ الْمُؤْمِنِیْنَ وَالْمُؤْمِنَاتِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19