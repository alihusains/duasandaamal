[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018619, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Through You I am attacking and through You I am going forward and by Your help I am hiding and by Your support I am achieving success. I am dieing and living for You. I have pledged my soul and my transactions to You and there is no power or strength except Allah the great. O Allah You have created me, sustained me, You have concealed me and have bestowed honour upon me among Your creatures whenever I felt weak You bestowed strength on me, whenever I stumbled You held me, whenever I was sick You cured me, whenever I called You, You answered me. Be happy with me as You have made me happy. And blessing of Allah be on Prophet Mohammad (s.a.w.a) and his Progeny (a.s) the pure ones.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda wanda! Tere zariye hamla aawar, aur Tere zariye iqdaam (koshish) karta hu, Tere sahaare japat-ta (hu), aur Tere sahaare kaamyaab hota hu, Tere liye marta hu, Tere liye zindagi basar karta hu. Mai ne apna nafs aur maamelaat Tere supurd (hawaale) kar diye hai aur koi taaqat o quwwat nahin hai magar Khuda’e buzurg o bartar ke zariye. Khuda wanda! Tu ne mujhe paiyda kiya, Tu ne mujhe rozi di, Tu ne meri pardah poshi ki, aur apne bando’n mein apne ehsaan se sar-faraaz kiya, jab bhi kamzori mehsoos ki to Tu ne ustawaari (bara-bari) ataa ki, jab bhi thokar lagi to Tu ne roka, bimaar huwa to shafa marhamat farmaayi, jab bhi Tujhe pukaara to Tu ne jawaab diya. Mere Mawla mujh se khush ho ja keh Tu ne mujhe khush rakkha. Aur Allah ki rehmat naazil ho Muhammad (s.a.w.a) aur unki awlaad’e taahereen (a.s) par.", "Urdu": "خدا وندا! تیرے ذریعے حملہ آور اور تیرے ذریعے اقدام کرتا ہوں، تیرے سہارے جھپٹتا ہوں اور تیرے سہارے کامیاب ہوتا ہوں۔ تیرے لئے مرتا ہوں، تیرے لئے زندگی بسر کر رہا ہوں۔ میں نے اپنا نفص اور معاملات تیرے سپرد کر دیئے ہیں اور کوئی طاقت و قوت نہیں ہے مگر خدائے بزرگ و برتر کے ذریعے۔ خدا وندا! تو نے مجھے پیدا کیا، تو نے مجھے روزی دی، تونے میری پردہ پوشی کی اور اپنے بندوں میں اپنے احسان سے سرفراز کیا، جب بھی کمزوری محسوس کی تو تونے استواری عطا کی، جب بھی ٹھوکر لگی تو تونے روکا، بیمار ہوا تو شفاء مرحمت فرمائی، جب بھی تجھے پکارا تو تونے جواب دیا۔ میرے مولا! مجھ سے خوس ہو جا کہ تونے مجھے خوش رکھا، اور اللہ کی رحمت ہو محمدؐ اور ان کی اولادِ طاہرینؑ پر۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ بِكَ اُسَاوِرُ وَبِكَ اُحَاوِلُ وَبِكَ اَصُوْلُ وَبِكَ اَنْتَصِرُ وَبِكَ اَمُوْتُ وَبِكَ اَحْیَا اَسْلَمْتُ نَفْسِیْ اِلَیْكَ وَفَوَّضْتُ اَمْرِیْ اِلَیْكَ وَلَا حَوْلَ وَلَا قُوَّۃَ اِلَّا بِاللهِ الْعَلِیِّ الْعَظِیْمِ۔ اَللّٰهُمَّ اِنَّكَ خَلَقْتَنِیْ وَرَزَقْتَنِیْ وَسَرَرْتَنِیْ وَسَتَرْتَنِیْ وَبَیْنَ الْعِبَادِ بِلُطْفِكَ خَوَّلْتَنِیْ اِذَا وَهَیْتُ رَدَدْتَنِیْ وَاِذَا عَسَرْتُ اَقَلْتَنِیْ وَاِذَا مَرِضْتُ شَفَیْتَنِیْ وَاِذَا دَعَوْتُكَ اَجَبْتَنِیْ سَیِّدِیْ اِرْضَ عَنِّیْ فَقَدْ اَرْضَیْتَنِیْ وَصَلَّی اللهُ عَلٰی مُحَمَّدٍ وَّاٰلِهِ الطَّاهِرِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": n