[{"Id": 1013463, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Imam Ali (a), is reported to have said that whoever enters a graveyard and says the following words, Almighty Allah will grant him the reward of 50 year worship and erases from him and his parents the punishment of 50 year wrongdoings…", "GujaratiDescription": null, "RUrduDescription": "Imam Ali (a) se manqool hai keh jo koi Qabrastan mein jaaye aur is tarah kahe to Allah (swt) us shakhs ke liye 50 saal ki ibaadat ka sawaab likkhega, neez uske aur uske maa baap ke 50 saal ke gunah maaf kar dega…", "UrduDescription": "خدااس شخص کے آدمؑ سے قیامت تک کے انسانوں کی تعداد کے برابر نیکیاں لکھے گا۔ امیر المومنینؑ سے منقول ہے کہ جب کوئی شخص قبر ستان میں جائے تو یہ کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null,