[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002430, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please) send blessings upon Ali the son of al-Hussain the chief of worshippers whom You have purely dedicated to Yourself and brought forth from him the Leaders of True Guidance who guide to the truth and judge with it. You have chosen him for Yourself, purified him against filth, selected him, and made him guide and well-guided. O Allah, send blessings upon him with the most excellent blessings that You have ever sent upon any of Your Prophets’ offspring so that these blessings raise him to what delights his eye in this world and the Hereafter. You are verily Almighty and Wise.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Imam Ali bin Husain (a.s) par durood bhej jo ibaadat guzaaro’n ke sardaar hai jin ko Tu ne apne liye makhsoos kiya aur unki aulaad mein Tu ne Aimma’e hidaayat qaraar diye jo haq ke saath hidaayat karte aur adl se faisle karte hai, Tu ne unko apne liye chuna, unko aaloodgi se paak rakkha, unko pasand kiya aur unko hidaayat yaafta rehbar banaya. Pas ay Ma’bood! Imam chharum (4th Imam) par rehmat farma woh behtareen rehmat jo Tu ne apne nabiyyo’n ki aulaad mein se kisi par ki ho, hatta keh unko us maqaam par pohoncha jis se unki aankhe’n thandi ho duniya o aakherat mein, be-shak to zabardast hikmat waala hai.", "Urdu": "اے معبود! امام علیؑ ابن الحسینؑ پر درود بھیج جو عبادت گزاروں کے سردار ہیں جن کو تو نے اپنے لئے مخصوص کیا اور ان کی اولاد میں تو نے ائمۂ ہدایت قرار دئیے جو حق کے ساتھ ہدایت کرتے اور عدل سے فیصلے کرتے ہیں تو نے ان کو اپنے لئے چنا ان کو آلودگی سے پاک رکھا ان کو پسند کیا اور ان کو ہدایت یافتہ رہبر بنایا پس اے معبود! امامؑ چہارم پر رحمت فرما وہ بہترین رحمت جو تو نے اپنے نبیوں کی اولادمیں سے کسی پر کی ہو حتی کہ ان کو اس مقام پر پہنچا جس سے ان کی آنکھیں ٹھنڈی ہوں دنیا اور آخرت میں بے شک تو زبردست حکمت والاہے۔", "RArabic": "ALLAAHUMMA SALLE A’LAA A’LIYYIBNIL HUSAYNE SAYYEDIL A’ABIDEENAL LAZIS-TAKHLASTAHU LE NAFSEKA WA JA-A’LTA MINHO A-IMMATAL HODAL LAZEENA YAHDOONA BIL HAQQE WA BEHI YAA’-DELOONAKH TARTAHU LE NAFSEKA WA TAHHARTAHU MENAR RIJSE WASTAFAYTAHU WA JA-A’LTAHU HAADEYAN MAHDIYYAN ALLAAHUMMA FA SALLE A’LAYHE AFZALA MAA SALLAYTA A’LAA AHADIN MIN ZURRIYYATE AMBEYAAA-EKA HATTAA TABLOGHA BEHI MAA TAQARRO BEHI A’YNOHU FID DUNYAA WAL AAKHIRATE INNAKA A’ZEEZUN HAKEEMUN.", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى عَلِيِّ بْنِ الْحُسَيْنِ سَيِّدِ الْعَابِدِيْنَ الَّذِي اسْتَخْلَصْتَهٗ لِنَفْسِكَ وَجَعَلْتَ مِنْهُ اَئِمَّةَ الْهُدَى الَّذِيْنَ يَهْدُوْنَ بِالْحَقِّ وَبِهِ يَعْدِلُوْنَ اخْتَرْتَهٗ لِنَفْسِكَ وَطَهَّرْتَهٗ مِنَ الرِّجْسِ وَاصْطَفَيْتَهٗ وَجَعَلْتَهٗ هَادِيًا مَهْدِيًّا۔ اَللّٰهُمَّ صَلِّ عَلَيْهِ اَفْضَلَ مَا صَلَّيْتَ عَلٰى اَحَدٍ مِّنْ ذُرِّيَّةٖ اَنْبِيَاءِكَ حَتّٰى تَبْلُغَ بِهٖ مَا تَقَرُّ بِهٖ عَيْنُهٗ فِي الدُّنْيَا وَالْآخِرَةِ اِنَّكَ عَزِيْزٌ حَكِيْمٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "Ar