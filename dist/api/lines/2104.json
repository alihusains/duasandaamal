[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018718, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my hoared treasure during my troubles, O my listener in my trails, O my leader in my bounties, O the One to make me successful at the time of my need, O the one to give me salvation at the time of my destruction, O the one to keep a watch over me in solitude, forgive my sins, and ease for me, my transactions, grant me peace at the time of troubles, grant me success in supplications, reformation in my condition and protection in all the things which worry me, make correction and rectification in my affairs never distance protection from me, whether I am alive or dead and also in the hereafter. By Your mercy O most merciful of all the mercifuls.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay meri takleefo’n mein mere zakheere, ay meri sakhtiyo’n mein mere faryaad-ras, ay meri ne’mato’n mein mere Mawla, ay meri zarurato’n mein mujhe kaamyaab karne waale, ay meri tabah haali (barbaadi) mein meri panah, ay meri halaakato’n mein mujhe najaat dilaane waale, ay meri tanhaayi mein meri nigeh-baani karne waale, meri khataaye’n bakhsh de aur mere maamelaat aasaan kar de, mujhe pareshaani mein jamee’at (ziyadah ne’mat) ataa farma, mujhe dua mein kaamyaabi, meri haalat mein islaah aur jin cheezo’n ka gham hai un mein meri kifaayat farma, mere maamelaat mein dursusti aur tadbeer paiyda kar, mere aur aafiyat ke darmiyaan kabhi bhi judaayi na daalna, mai zindah hu ya jab maut aaye aur aakherat mein hu, Tujhe apni rehmat ka sadqa, ay maher-baano mein sab se bade maher-baan.", "Urdu": "اے میری تکلیفوں میں میرے ذخیرے، اے میری شختیوں میں میرے فریاد رس، اے میری نعمتوں میں میرے مولا، اے میری ضرورتوں میں مجھے کامیاب کرنے والے، اے میری تباہ حالی میں میری پناہ، اے میری ہلاکتوں میں مجھے نجات دلانے والے، اے میری تنہائی میں میری نگہبانی کرنے والے، میری خطائیں بخش دے اور میرے معاملات آسان کردے، مجھے پرشانی میں جمیعت عطا فرما، مجھے دعا میں کامیابی، میری حالت میں اصلاح اور رجن چیزوں کا غم ہے ان میں میری کفایت فرما، میرے معاملات میں درستی اور تدبیر پیدا کر، میرے اور عافیت کے درمیان کبھی بھی جدائی نہ ڈالنا، میں زندہ ہوں یا جب موت آئے اور آخرت میں ہوں، تجھے اپنی رحمت کا صدقہ اے مہربانوں میں سب سے بڑے مہربان۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "یَا عُدَّتِیْ عِنْدَ كُرْبَتِیْ یَا غِیَاثِیْ عِنْدَ شِدَّتِیْ یَا وَلِّیِ فِیْ نِعْمَتِیْ یَا مُنْجِحِیْ فِیْ حَاجَتِیْ یَا مَفْزَعِیْ فِیْ وَرْطَتِیْ یَا مُنْقِذِیْ مِنْ هَلَكَتِیْ یَا كَالِئِیْ فِیْ وَحْدَتِیْ اِغْفِرْلِیْ خَطِیْئَتِیْ وَیَسِّرْ لِیْ اَمْرِیْ وَاجْمَعْ لِیْ شَمْلِیْ وَانْحِجْ لِیْ طَلِبَتِیْ وَاَصْلِحْ لِیْ شَانِیْ وَاكْفِنِیْ مَا اَهَمَّنِیْ وَاجْعَلْ لِیْ مِنْ اَمْرِیْ فَرَجًا وَمَخْرَجًا وَّلَا تُفَرِّقْ بَیْنِیْ وَبَیْنَ الْعَافِیَۃِ اَبَدًا مَّا اَبْقَیْتَنِیْ وَفِیْ الْاٰخِرَۃَ اِذَا تَوَفَّیْتَنِیْ بِرَحْمَتِكَ یَا اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "Arab