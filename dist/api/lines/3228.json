"ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014177, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Enter the shrine and recite the famous ziyarat of the two Imams (a) in the following word…", "GujaratiDescription": null, "RUrduDescription": "Haram mein daakhil ho kar un dono Imamo’n ki yeh mashhoor ziyarat ko padhe…", "UrduDescription": "اس کے بعد حرم مبارک میں داخل ہو کر ان دونوں اماموں کی یہ مشترکہ زیارت پڑھے جو سب زیارتوں میں سے صحیح تر ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014178, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on both of you, O the representatives of Allah. Peace be on both of you, O the decisive arguments of Allah. Peace be on both of you, O the lights of Allah in the darkness of the (ignorant) world. Peace be on both of you, Allah was the first to lay down your privileges. I have come to visit you, aware of your rights, averse to your enemies, attached to your friends; I believe in that which you accepted as true.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap dono par ay Khuda ke auliya. Salaam ho aap dono par ay Khuda ki hujjat. Salaam ho aap dono par jo zameen ki taarikiyo’n mein Khuda ke do (2) noor hai. Salaam ho aap dono par Khuda ne jin ki shaan zaahir farmaayi, aaya hu aap ki ziyarat karne, aap ke haq ko pehchaante huwe, aap dono ke dushmano ka dushman, aap ke dosto’n ka dost hu, imaan rakhta hu jis par aap ka imaan hai.", "Urdu": "سلام ہو آپ دونوں پر اے اولیاء خدا!سلام ہو آپ دونوں پر اے حجت ِخدا، سلام ہو آپ دونوں پر جو زمین کی تاریکیوں میں خدا کے دو نور ہیں سلام آپ دونوں پر خدا نے جن کی شان ظاہر فرمائی آپ کی زیارت کرنے آیا ہوں، آپ کا حق پہچانتا ہوں آپ دونوں کے دشمنوں کا دشمن، آپ کے دوستوں کا دوست ہوں ایمان رکھتا ہوں جس پر آپ کا ایمان ہے۔", "RArabic": "AS-SALAAMO A’LAYKOMAA YAA WALIYYAYIL LAAHE AS-SALAAMO A’LAYKOMAA YAA HUJJATAYIL LAAHE AS-SALAAMO A’LAYKOMAA YAA NOORAYIL LAAHE FEE ZOLOMAATIL ARZE AS-SALAAMO A’LAYKOMAA YAA MAN BADAA LILLAAHE ATAYTOKOMAA ZAA-ERAN A’AREFAN BEHAQQEKOMAA MO-A’ADEYAN LE-AA’-DAAA- EKOMAA MOWAALEYAN LE-AWLEYAAA-EKOMAA MOOMENAN.", "ArabicText1": "اَلسَّلَامُ عَلَیْكُمَا یَا وَلِیَّیِ اللہِ۔ اَلسَّلَامُ عَلَیْكُمَا یَا حُجَّتَیِ اللہِ۔ اَلسَّلَامُ عَلَیْكُمَا یَا نُوْرَیِ اللہِ فِیْ ظُلُمَاتِ الْاَرْضِ۔ اَلسَّلَامُ عَلَیْكُمَا یَا مَنْ مبَدَا لِلهِ فِیْ شَاْنِكُمَا اَتَیْتُكُمَا زَآئِرًا عَارِفًا بِحَقِّكُمَا مُعَادِیًا لِاَعْدَآئِكُمَا مُوَالِیًا لِاَوْلِیَآئِكُمَا مُؤْمِنًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014179, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I say “no” to that which you rejected as false. I take as true that which you determined as genuine. I refute that which you proved false. I had besought Allah, my Lord and your Lord, to make me happy by making my visit to you possible, to send blessings on Muhammad and on his children, and to let your company in the Paradise be my sustenance, along with your pious forefathers.", "Gujarati": null, "RGujarati": null, "RUrdu": "Uska inkaar karta hu jis ka aap inkaar karte hai, usko haq samajhta hu jise aap ne haq samjha, usko jhootlaata hu jise aap ne jhootlaaya, sawaal karta hu Allah se jo mera aur aap ka Parwardigaar hai, yeh keh woh qaraar de aap ki ziyarat mein mera hissa Muhammad (s.a.w.a) aur unki Aal (a.s) par durood aur yeh keh mujhe naseeb kare aap dono ki Jannat mein, keh aap ke swaaleh Aaba (baap dada) ke saath.", "Urdu": "اس کا انکار کرتا ہوں جس کا آپ انکار کرتے ہیں اس کو حق سمجھتا ہوں جسے آپ نے حق سمجھا اس کو جھٹلاتا ہوں جسے آپ نے جھٹلایا سوال کرتا ہوں اللہ سے جو میرا اور آپ کا پروردگار ہے یہ کہ وہ قرار دے آپ کی زیارت میں میرا حصہ محمدؐ اور ان کی آلؑ پر درود اور یہ کہ مجھے نصیب کرے آپ دونوں کی جنت میں کہ آپ کے صالح آباء کے ساتھ۔", "RArabic": "BE MAA AAMANTOMAA BEHI KAAFERAN BEMAA KAFARTOMAA BEHI MOHAQQEQAN LEMAA HAQQAQTOMAA MUBTELAN LEMAA ABTALTOMAA AS-ALULLAAHA RABBEE WA RABBAKOMAA AYN YAJ-A’LA HAZZEE MIN ZEYAARATEKOMAS SALAATA A’LAA MOHAMMADIN WA AALEHI WA AYN YARZOQANEE MORAAFAQATAKOMAA FIL JENAANE MA-A’ AABAAA-EKOMAS SAALEHEENA.", "ArabicText1": "بِمَا اٰمَنْتُمَا بِهٖ كَافِرًۢا بِمَا كَفَرْتُمَا بِهٖ مُحَقِّقًا لِّمَا حَقَّقْتُمَا مُبْطِلًا لِّمَا اَبْطَلْتُمَا اَسْئَلُ اللہَ رَبِّیْ وَرَبِّكُمَا اَنْ یَّجْعَلَ حَظِّیْ مِنْ زِیَارَتِكُمَا الصَّلٰوۃَ عَلٰی مُحَمَّدٍ وَّاٰلِهٖ وَاَنْ یَّرْزُقَنِیْ مُرَافَقَتَكُمَا فِی الْجِنَانِ مَعْ اٰبَآئِكُمَا الصَّالِحِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014180, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I also asked him to save my neck from the fire of hell, to preserve me under your patronage, in your group, to maintain friendship between me and you, and not to let my love for you and your forefathers dissipate, not to let my this visit to you be my last ziyarat, and to raise me on the Day of Judgement to be with you in the Paradise, through His mercy.", "Gujarati": null, "RGujarati": null, "RUrdu": "Neez us se sawaal karta hu keh woh meri gardan aag se azaad kar de mujhe aap dono ki shafa’at aur ham nasheeni ataa farmaaye aur mere aur aap ke darmiyaan aashnaayi paiyda kare, neez mujh se aap dono ki aur aap ke swaaleh Aaba ki mohabbat waapis na le. Is ziyarat ko mere liye aap dono ki aakhri ziyarat na banaaye, mujh ko Jannat mein aap dono ke saath thaiyraaye apni rehmat se.", "Urdu": "نیز اس سے سوال کرتا ہوں کہ وہ میری گردن آگ سے آزاد کردے مجھے آپ دونوں کی شفاعت اور ہم نشینی عطا فرمائے اور میرے اور آپ کے درمیان آشنائی پیدا کرے نیز مجھ سے آپ دونوں کی اور آپ کے صالح آباء کی محبت واپس نہ لے اس زیارت کو میرے لئے آپ دونوں کی آخری زیارت قرارنہ دےمجھ کو جنت میں آپ دونوں کے ساتھ ٹھہرائے اپنی رحمت سے۔", "RArabic": "WA AS-A-LOHU AYN YOA’-TEQA RAQABATEE MENAN NAARE WA YARZOQANEE SHAFAA-A’TAKOMAA WA MOSAAHABATAKOMAA WA YO-A’RREFA BAYNEE WA BAYNAKOMAA WA LAA YASLOBANEE HUBBAKOMAA WA HUBBA AABAAA-EKOMAS SAALEHEENA WA AN LAA YAJ-A’LAHU AAKHERAL A’HDE MIN ZEYAARATEKOMAA WA YAHSHORANEE MA-A’KOMAA FIL JANNATE BERAHMATEHI.", "ArabicText1": "وَاَسْئَلُهٗ اَنْ یُّعْتِقَ رَقَبَتِیْ مِنَ النَّارِ وَیَرْزُقَنِیْ شَفَاعَتَكُمَا وَمُصَاحَبَتَكُمَا وَیُعَرِّفَ بَیْنِیْ وَبَیْنَكُمَا وَلَا یَسْلُبَنِیْ حُبَّكُمَا وَحُبَّ اٰبَآئِكُمَا الصَّالِحِیْنَ وَاَنْ لَّا یَجْعَلَهٗ اٰخِرَ الْعَھْدِ مِنْ زِیَارَتِكُمَا وَیَحْشُرَنِیْ مَعَكُمَا فِیْ الْجَنَّۃِ بِرَحْمَتِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014181, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Shaykh Mohammad bin Mashhadi, Shaykh Mufeed and the Shaheed have also narrated it with some differences said that you must throw yourself on both the graves, kiss them and put your right cheek on them, then your left cheek and then raise up your head and say…", "GujaratiDescription": null, "RUrduDescription": "Shaikh Muhammad bin Mashhadi, Shaikh Mufeed aur Shaheed ne bhi naql karte huwe bayaan farmaaya hai, keh apne ko zareeh se mas kare, bosa de, apne daaye aur baaye rukhsaar (right and left cheeks) zareeh se lagaye aur phir apne chehre ko baland karte huwe is tarah se kahe…", "UrduDescription": "شیخ محمد ابن المشہدیؒ، شیخ مفیدؒ اور شہیدؒ نے بھی معمولی اختلاف کے ساتھ اپنی کتب مزار میں درج کیا ہے انہوں نے یہ بھی فرمایا کہ خود کو ان دونوں قبروں کے ساتھ لپٹائے ان پر بوسہ دے اور اپنے دونوں رخسار باری باری ان قبروں پر رکھے پھر سر اوپر اٹھاکر یہ پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1014182, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "May Allah let me live in your love and die as your follower. O Allah send to hell those who usurped the rights of the progeny of Muhammad, take revenge from them; O Allah curse the instigators as well as the followers, increase their punishment, throw them, their friends, their sympathisers, and their followers, into the lowest tiers of the burning fire. Verily, You are able to do all things. O Allah send back Your representative, the son of your representative, at once, and let us be with him. O the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mujhe un dono ki mohabbat ataa kar aur unke deen par wafaat (maut) de. Ay Ma’bood! Aale Muhammad (a.s) ka haq chheen ne waale par laanat kar aur un se us zaalim ka badla le. Ay Ma’bood! Un mein se pehle aur aakhri zaalim par laanat kar aur dugna kar de un par apna azaab aur unko aur unke saathiyo’n ko unke dosto’n ko aur unke pairo-kaaro’n ko dozakh ke sab se gehre khadde (deep hole) mein pohoncha, keh yaqeenan Tu har cheez par qudrat rakhta hai. Ay Ma’bood! Tera Wali jo Tere Wali ka farzand hai uske zahoor mein jaldi kar, uski kashaaish mein hamari bhi kashaaish farma ay sab se ziyadah rahem waale.", "Urdu": "اے معبود!مجھے ان دونوں کی محبت عطا کر اور ان کے دین پر وفات دے اے معبود! آل محمدؑ کا حق چھیننے والوں پر لعنت کر اور ان سے اس ظلم کا بدلہ لے اے معبود!ان میں سے پہلے اور آخری ظالم پر لعنت کر اور ان پر اپنا عذاب دگنا کر دے اور ان کو اور ان کے ساتھیوں کوان کے دوستوں کو اور ان کے پیروکاروں کو دوزخ کے سب سے گہرے گڑھے میں پہنچا کہ یقینًا تو ہر چیز پر قدرت رکھتا ہے اے معبود! تیرا ولی جو تیرے ولی کا فرزند ہے اس کے ظہور میں جلدی کر اس کی کشائش وآسائش میں ہماری بھی کشائش وآسائش فرما اے سب سے زیادہ رحم کرنے والے۔", "RArabic": "ALLAAHUMMAR-ZUQNEE HUBBAHOMAA WA TAWAFFANEE A’LAA MILLATEHEMAA ALLAAHUMMAL-A’N ZAALEMEE AALE MOHAMMADIN HAQQAHUM WANTAQIM MINHUM ALLAAHUMMAL-A’NIL AWWALEENA MINHUM WAL AAKHEREEN WA ZAA-I’F A’LAIHEMUL A’ZAABA WAB-LUGH BEHIM WA BE-ASHYAA-E’HIM WA MOHIBBEEHIM WA MUTTABE-E’EHIM ASFALA DARAKIM MENAL JAHEEME INNAKA A’LAA KULLE SHAY-IN QADEERUN ALLAAHUMMA A’JJIL FARAJA WALIYYEKA WABNE WALIYYEKA WAJ-A’L FARAJANAA MA-A’ FARAJEHIM YAA ARHAMAR RAAHEMEENA.", "ArabicText1": "اَللّٰھُمَّ ارْزُقْنِیْ حُبَّهُمَا وَتَوَفَّنِیْ عَلٰی مِلَّتِهِمَا۔ اَللّٰھُمَّ الْعَنْ ظَالِمِیْٓ اٰلِ مُحَمَّدٍ حَقَّهُمْ وَانْتَقِمْ مِنْهُمْ۔ اَللّٰھُمَّ الْعَنِ الْاَوَّلِیْنَ مِنْهُمْ وَالْاٰخِرِیْنَ وَضَاعِفْ عَلَیْهِمُ الْعَذَابَ وَابْلُغْ بِهِمْ وَبِاَشْیَاعِهِمْ وَمُحَبِّیْهِمْ وَمُتَّبِعِیْهِمْ اَسْفَلَ دَرَكٍ مِّنَ الْجَحِیْمِ اِنَّكَ عَلٰی كُلِّ شَیْءٍ قَدِیْرٌ۔ اَللّٰھُمَّ عَجِّلْ فَرَجَ وَلِیِّكَ وَابْنِ وَلِیِّكَ وَاجْعَلْ فَرَجَنَا مَعَ فَرَجِهِمْ یَآ اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) choicest blessings be upon Mohammed and his holy progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar Tu rehmat naazil farma Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par.", "Urdu": "اے معبود! رحمت نازل فرما حضرت محمدؐ اور انکی آل ؑپر۔", "RArabic": "ALLAHUMMA SWALLE ALAA MUHAMMADIW WA AALE MUHAMMADIN", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014183, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "You may then move to the head side of the tomb and offer 4 rakat namaz (2 rakat for each Imam) and then pray for yourself, your parents and other momeneen.", "GujaratiDescription": null, "RUrduDescription": "Ab sar ki jaanib jaaye aur wahan par 4 rakat namaz (2 rakat har ek Imam ke liye) adaa kare aur phir haajat talab kare apne liye, apne waaledain aur digar momeneen ke liya.", "UrduDescription": "زیارت کے بعد سرہانے کی طرف کھڑے ہو کر دو دو کر کے ۴ رکعت نمازِ زیارت پڑھے پھرچاہے تو وہاں اور بھی نمازیں پڑھے۔ اس کے بعد اپنے، اپنے والدین، اپنے بھائی بہن