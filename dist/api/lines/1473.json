[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010109, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O Imam of sound advice! Peace be upon you, O moon in darkness! Peace be upon you, O shelter of piety! Peace be upon you, O leader of pious ones! Peace be upon you, O revealer of the knowledge of Prophets! Peace be upon you, O prestige of the skies and the earths! O Allah! In the same way as Thou make him as the protector of Thy beings and the trustee of Thy tolerance and the translator of Thy messages, send the choicest blessings on him blessings sent by Thee on the descendants of Thy Prophets & on Thy select beings and on Thy messengers and on Thy trustees, O Owner of the two worlds!", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay hidaayat ke rehbar. Salaam ho aap par ay shab ke andhero’n ke maah kaamil (chaand). Salaam ho aap par ay mazboot panah-gah. Salaam ho aap par ay saahebaan’e taqwa ke rehnuma. Salaam ho aap par ay ambiya ke ilm ko shigaaf (zaahir) karne waale. Salaam ho aap par ay aasmaano aur zameeno ki zeenat. Khudaaya! Tu ne unko apne bando’n ke liye nishaani aur apne hilm ka ameen aur apne wahi ka tarjumaan qaraar diya hai, lehaaza un par rehmat naazil farma, aisi hi beh-tareen aur afzal rehmat jaisi Tu ne apne ambiya o awsiya aur rasoolo’n aur amaanat daaro’n ki Aal ki har fard par naazil farmaayi hai, ay aalameen ke paalne waale.", "Urdu": " سلام ہو آپ پر اے ہدایت کے رہبر، سلام ہو آپ پر اے شب تاریک کے ماہ کامل، سلام ہو آپ پر اے مضبوط پناہ گاہ، سلام ہو آپ پر اے صاحبان تقویٰ کے رہنما، سلام ہو آپ پر اے انبیاء کے علم کو شگاف کرنے والے، سلام ہو آپ پر اے آسمانوں اور زمینوں کی زینت، خدا یا! تو نے ان کو اپنے بندوں کے لیے نشانی  اور اپنے حلم کا امین اور اپنے وحی کا ترجمان قرار دیا ہے لہذا ان پر رحمت نازل فرما ایسی ہی بہترین اور افضل رحمت جیسی تو نے اپنے انبیاء و اوصیاء اور رسولوں اور امانت داروں کی آل کی ہر فرد پر نازل فرمائی ہے، اے عالمین کے پالنے والے۔", "RArabic": "AS-SALAAMO A’LAIKA YAA IMAAMAL HODAA. AS-SALAAMO A’LAIKA YAA BADRAD-DOJAA. AS-SALAAMO A’LAIKA YAA KAH-FAT TOQAA. AS-SALAAMO A’LAIKA YAA QAAA-E-DA AHLIT TAQWAA. AS-SALAAMO A’LAIKA YAA BAAQERA I’L-MIN NABIY-YEENA. AS-SALAAMO A’LAIKA YAA ZEENAS SAMAA-WAATE WAL AR-ZEENA. ALLAAHUMMA KAMAA JA-A’L-TAHU A’LA-MAN LE-E’BAADE-KA WA MUS-TAWDE-AN LE-HILME-KA WA MO-TARJE-MAN LE-WAH-YEKA FA-SALLE A’LAI-HE AF-ZALA MAA SAL-LAIY-TA A’LAA AHA-DIN MIN ZUR-RIYYA-TE AMBIYAA-E-KA WA AS-FEYAA-E-KA WA RASOOLE-KA WA OMA-NAA-E-KA, YAA RABBAL AA’LAMEENA.", "ArabicText1": "اَلسَّلَامُ عَلَیْکَ یَااِمَامَ الْھُدٰی۔ اَلسَّلَامُ عَلَیْکَ یَابَدْرَالدُّجٰی۔ اَلسَّلَامُ عَلَیْکَ یَاکَھْفَ التُّقٰی۔ اَلسَّلَامُ عَلَیْکَ یَاقَآئِدَ اَھْلِ التَّقْوٰی۔ اَلسَّلَامُ عَلَیْکَ یَابَاقِرَ عِلْمِ النَّبِیِّیْنَ۔ اَلسَّلَامُ عَلَیْکَ یَازَیْنَ السَّمٰوٰتِ وَالْاَرْضِیْنَ۔ اَللّٰہُمَّ کَمَا جَعَلْتَہٗ عَلَمًا لِعِبَادِکَ وَمُسْتَوْدِعًا لِحِلْمِکَ وَمُتَرْجِمًا لِوَحْیِکَ فَصَلِّ عَلَیْہِ اَفْضَلَ مَا صَلَّیْتَ عَلٰی اَحَدٍ مِّنْ ذُرِّیَّۃِ اَنْۢبِیَآئِکَ وَاَصْفِیَآئِکَ وَرُسُلِکَ وَاُمَنَآئِکَ یَارَبَّ الْعَالَمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null