[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016064, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I am present, O High, I am present. I am present, O one who calls towards Heaven. I am present, I am present O Forgiver of sins. I am present, I am present O One who owns my presence. I am present, I am present O Mighty and Generous. I am present, I am present O You who first created and to whom all will return. I am present, I am present O One who is free from want and to whom all turn for their needs. I am present, I am present O who is feared and to whom there is inclination. I am present I am present, O true God. I am present O the One with Grace, Excellence, Goodness and Beauty. I am present O one who averts major calamities. I am present, I am present Your servant and the son of Your servant. I am present I am present O Generous, I am present.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay sidhiyo’n aur zameeno waale aasmaan ke maalik! Mai haazir hu, ay salaamati ki taraf bulaane waale mai jawaab deta hu haazir hu, ay gunaho’n ke ziyadah bakhshne waale! Mai haazir hu. Ay jawaab diye jaane ke laayaq! Mai haazir hu labbaik kehta hu, ay jalaal o ikraam ke maalik mai haazir hu. Ay ibteda karne waale! Mai haazir hu, ay woh Khuda jiski taraf sab ko laut kar jaana hai mai haazir hu, ay woh Khuda! Jo be-neyaaz hai aur sab ko Teri ehtiyaaj (haajat) hai mai haazir hu, ay woh hasti jis se dara jaaye aur jiski taraf raghbat ki jaaye mai haazir hu, ay haqeeqi Khuda! Mai haazir hu. Ay neymato’n aur behtareen fazl o karam waale! Mai haazir hu.Haazir hu ay bade bade ranj o gham ko dur karne waale Khuda! Mai haazir hu. Ay Khuda! Tera banda aur Tere do (2) bando’n (maa baap) ka beta haazir hai. Ay Kareem Khuda! Mai haazir hu, mai jawaab deta hu.", "Urdu": "اے سیڑھیوں اور زمینوں والے آسمان کے مالک! میں حاضر ہوں، اے سلامتی کی طرف بلانے والے میں جواب دیتا ہوں حاضر ہوں، اے گناہوں کے زیادہ بخشنے والے! میں حاضر ہوں، اے جواب دیئے جانے کے لائق! میں حاضر ہوں لبیک کہتا ہوں، اے جلال و اکرام کے مالک میں حاضر ہوں، اے ابتدا کرنے والے! میں حاضر ہوں، اے وہ خدا جسکی طرف سب کو لوٹ کر جانا ہے میں حاضر ہوں، اے وہ خدا جو بےنیاز اور سب کو تیری احتیاج ہے میں حاضر ہوں، اے وہ ہستی جس سے ڈرا جائے اور جس کی طرف رغبت کی جائے میں حاضر ہوں، اے حقیقی خدا! میں حاضر ہوں، اے نعمتوں اور بہترین فضل و کرم والے! میں حاضر ہوں، اے بڑے بڑے رنج و غم کو دور کرنے والے خدا! میں حاضر ہوں، اے خدا! تیرا بندہ اور تیرے دو بندوں (ماں باپ) کا بیٹا حاضر ہے، اے کریم خدا! میں حاضر ہوں میں جواب دیتا ہوں۔", "RArabic": "LABBAYKA ZAL-MA-A’AREJE LABBAYKA LABBAYKA DAA-E’YAN ELAA DAARIS SALAAME LABBAYKA LABBAYKA GHAFFAARAZ ZONOOBE LABBAYKA LABBAYKA AHLAT TALBEYATE LABBAYKA LABBAYKA ZAL JALAALE WAL IKRAAME LABBAYKA LABBAYKA TUBDE-O WAL MO-A’ADO ELAYKA LABBAYKA LABBAYKA TASTAGHNEE WA YUFTAQARO ELAYKA LABBAYKA LABBAYKA MARHOOBAN WA MARGHOOBAN ELAYKA LABBAYKA LABBAYKA ELAAHAL HAQQE LABBAYKA LABBAYKA ZAN-NA’MAAA-E WAL-FAZLIL HASANIL JAMEELE LABBAYKA LABBAYKA KASH-SHAAFAL KORABIL E’ZAAME LABBAYKA LABBAYKA A’BDOKA WABNO A’BDAYKA LABBAYKA LABBAYKA YAA KAREEMO LABBAYKA.", "ArabicText1": "لَبَّیْكَ ذَالْمَعَارِجِ لَبَّیْكَ لَبَّیْكَ دَاعِیًا اِلٰی دَارِ السَّلَامِ۔ لَبَّیْكَ لَبَّیْكَ غَ