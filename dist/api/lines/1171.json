ull, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009345, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 7, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "(As for) those who believe and do good, surely they are the best of men.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur be-shak jo log imaan laaye hai aur unho ne nek aamaal kiye hai woh behtareen khalaaeq hai.", "Urdu": "اور بے شک جو لوگ ایمان لائے ہیں اور انہوں نے نیک اعمال کئے ہیں وہ بہترین خلائق ہیں۔", "RArabic": "INNAL LAZEENA AAMANU WA ’AMILUS SAALIHAATI ULA-IKA HUM KHAIRUL BAREEY YAH.", "ArabicText1": "اِنَّ الَّذِيْنَ اٰمَنُوْا وَعَمِلُوا الصّٰلِحٰتِ اُولٰۗئِكَ هُمْ خَيْرُ الْبَرِيَّةِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009346, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 8, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Their reward with their Lord is gardens of perpetuity beneath which rivers flow, abiding therein forever; Allah is well pleased with them and they are well pleased with Him; that is for him who fears his Lord.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar ke yahan unki jaza woh baaghaat hai jinke neeche nehre jaari hongi woh unhi mein hamesha rehne waale hai Khuda un se raazi hai aur woh Us se raazi hai aur yeh sab uske liye hai jiske dil mein khouf'e Khuda hai.", "Urdu": "پروردگار کے یہاں ان کی جزا وہ باغات ہیں جن کے نیچے نہریں جاری ہوں گی وہ انہی میں ہمیشہ رہنے والے ہیں خدا ان سے راضی ہے اور وہ اس سے راضی ہیں اور یہ سب اس کے لئے ہے جس کے دل میں خوفِ خدا ہے۔", "RArabic": "JAZAA-UHUM INDA RABBIHIM JAN NAATU ’ADNIN TAJREE MIN TAHTIHAL AN HAARU KHALIDEENA FEEHA ABADA; RADIY-YALLAAHU ’ANHUM WA RA DU ’AN ZAALIKA LIMAN KHASHIYA RABBAH.", "ArabicText1": "جَزَاۗؤُهُمْ عِنْدَ رَبِّهِمْ جَنّٰتُ عَدْنٍ تَجْرِيْ مِنْ تَحْتِهَا الْاَنْهٰرُ خٰلِدِيْنَ فِيْهَآ اَبَدًا", "ArabicGreenSign1": "صلے ", "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": "رَّضِيَ اللهُ عَنْهُمْ وَرَضُوْا عَنْهُ", "ArabicGreenSign2": null, "ArabicRedSign2": "ط ", "ArabicBlueSign2": null, "ArabicText3": "ذٰلِكَ لِمَنْ خَشِيَ رَبَّهٗ", "ArabicGreenSign3": null, "ArabicRedSign3": "ع1", "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign