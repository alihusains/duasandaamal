ull, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012734, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay batha (Makkeh) ke sardaar. Aap par salaam ho ay woh hasti jise haatif’e ghaib ne buzurg neda ke saath pukaara. Aap par salaam ho ay Ibrahim’e Khaleel (a.s) ke farzand. Aap par salaam ho ay Ismaeel’e Zabeeh (a.s) ke waaris.", "Urdu": "آپ پر سلام ہو اے بطحا (مکہ) کے سردار، آپ پر سلام ہو اے وہ ہستی جسے ہاتف غیب نے بزرگ ندا کے ساتھ پکارا، آپ پر سلام ہو اے ابراہیم خلیلؑ کے فرزند، آپ پر سلام ہو اے اسماعیل ذبیحؑ کے وارث۔", "RArabic": "ASSALAAMO A’LAYKA YAA SAYYEDAL BAT-HAAA-E ASSALAAMO A’LAYKA YAA MAN NAADAAHO HAATEFUL GHAYBE BE AKRAME NEDAAA-IN ASSALAAMO A’LAYKA YABNA IBRAAHEEMAL KHALEELE ASSALAAMO A’LAYKA YAA WAARESAZ ZABEEHE ISMAA-E’ELA.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا سَیِّدَ الْبَطْحَآئِ۔ اَلسَّلَامُ عَلَیْكَ یَا مَنْ نَادَاہُ ہَاتِفُ الْغَیْبِ بِاَكْرَمِ نِدَآئٍ۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ اِبْرَاہِیْمَ الْخَلِیْلِ۔ اَلسَّلَامُ عَلَیْكَ یَا وَارِثَ الذَّبِیْحِ اِسْمٰعِیْلَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012735, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay ay woh hasti jis ki dua se Allah ne as’haabe feel ko halaak kiya aur unke makr (planing) ko barbaad kar diya aur un par Abaabeel parindo’n ka azaab bhej diya jinho ne un par khadonche ke (nokdaar) patthar barsaaye aur unhe’n chabaaye huwe bhoose ki tarah kar diya.", "Urdu": "آپ پر سلام ہو اے وہ ہستی جس کی دُعا سے اللہ نے اصحاب فیل کو ہلاک کیا اور ان کے مکم کو برباد کر دیا، اور ان پر أبا بیل پرندہ کا عذاب بھج دیا، جنہوں نے ان پر کھڑبخےکے پتھر برسائے اور انہیں چبائے ہوئے بھوسہ کی طرح کر دیا۔", "RArabic": "ASSALAAMO A’LAYKA YAA MAN AHLAKAL LAAHO BE-DO-A’AA-EHI ASHAABAL FEELA WA JA-A’LA KAYDAHUM FEE TAZLEELIN WA ARSALA A’LAYHIM TAYRAN ABAABEELA TARMEEHIM BEHEJAARATIN MIN SIJJEELIN FA-JA-A’LAHUM KA-A’SFIN MAAKOOLIN.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا مَنْ اَھْلَكَ اللهُ بِدُعَآئِہٖ اَصْحَابَ الْفِیْلَ وَجَعَلَ كَیْدَہُمْ فِیْ تَضْلِیْلٍ وَاَرْسَلَ عَلَیْہِمْ طَیْرًا اَبَابِیْلَ تَرْمِیْہِمْ بِحِجَارَۃٍ مِنْ سِجِّیْلٍ فَجَعَلَہُمْ كَعَصْفٍ مَاْكُوْلٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "