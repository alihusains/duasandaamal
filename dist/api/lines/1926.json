[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002433, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please) send blessings upon the honest and trusted Mus? the son of Ja`far, the dutiful, the faithful, the pure, the bright, the clear light, the striver, the seeker of Your rewards, and the bearer of harm for Your sake. O Allah, as he conveyed on the authority of his fathers all Your orders and prohibitions that were deposited with him, directed (people) to the clear course, and had to encounter the people of authority and persecution while he was facing troubles from the ignorant people, so, O Lord, bless him with the most favorite and most perfect blessings that You have ever conferred upon anyone who obeyed You and wished well for Your servants. You are verily All-forgiving, All-merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Amaanat-daar aur amaanat-daar banaaye gaye Moosa bin Jafar (a.s) par durood bhej jo nek o wafa-daar, paak shudah, paak-baaz, noore darakhsha’n, saae o khosha’n, khair chahne waale, Tere liye takleef par sabr karne waale hai. Ay Ma’bood! Jaise unho ne apne buzurgaan ki taraf se supurd shudah Tere Amr o Nahi ko bayaan kiya, logo’n ko seedhi raah par daala aur saamna kiya kibr o ghuroor ke sakht bartaaw ka un baato’n mein jo aap ki qaum ke jaahilo’n ne phailaaye’n. Pas ay Parwardigaar Hazrat par rehmat kar behtareen o kaamil-tareen rehmat jo Tu ne kisi aise shakhs par ki jis ne Teri ita’at aur Tere bando’n ki khair khwaahi ki, be-shak Tu pardah posh aur maher-baan hai.", "Urdu": "اے معبود! امانت دار اور امانت دار بنائے گئے موسیٰؑ ابن جعفرؑ پر درود بھیج جو نیک وفا دار پاک شدہ پاک باز نورِ درخشاں ساعی و کوشاں خیر چاہنے والے تیرے لئے تکلیف پر صبر کرنے والے ہیں اے معبود! جیسے انہوں نے اپنے بزرگوں کی طرف سے سپرد شدہ تیرے امر و نہی کو بیان کیالوگوں کو سیدھی راہ پر ڈالا اور سامنا کیا اہلِ کبر و غرور کے سخت برتاؤ کا ان باتوں میں جو آپ کی قوم کے جاہلوں نے پھیلائیں پس اے پروردگار حضرتؑ پر رحمت کر بہترین و کامل ترین رحمت جو تو نے کسی ایسے شخص پر کی جس نے تیری اطاعت اور تیرے بندوں کی خیر خواہی کی بے شک تو پردہ پوش مہربان ہے۔", "RArabic": "ALLAAHUMMA SALLE A’LAL AMEENIL MO-TAMA-NE MOOSAB-NE JA’FARE-NIL BARRIL WA FIYYIT TAAHE-RIZ ZAKIYYIN NOORIL MOBEE-NIL MUJTA-HE-DIL MOHTA-SE-BIS SAABE-RE A’LAL AZAA FEEKA. ALLAAHUMMA WA KAMAA BALLA-GHA A’N AABAA-E-HI MAS TOODE-A’ MIN AMRE-KA WA NAH-YEKA WA HAMALA A’LAL MA-HAJJA-TA WA KAA-BADA AH-LAL I’ZZATE WA SHIDDA-TE FEE MAA KAANA YALQAA MIN JOH-HAALE QAWME-HI RABBE FA-SALLE A’LAIHE AF-ZALA WA AK-MALA MAA SALLAIY-TA A’LAA AHA-DIM MIMMAN ATAA-A’KA WA NASA-HA LE-E’BAADE-KA INNA-KA GHAFOO-RUR RAHEE-MOON.", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلَى الْاَمِيْنِ الْمُؤْتَمَنِ مُوْسَى بْنِ جَعْفَرِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": " نِ", "ArabicText2": "الْبَرِّ الْوَفِيِّ الطَّاهِرِ الزَّكِيِّ النُّوْرِ الْمُبِيْنِ الْمُجْتَهِدِ الْمُحْتَسِبِ الصَّابِرِ عَلَى الْاَذٰى فِيْكَ۔ اَللّٰهُمَّ وَكَمَا بَلَّغَ عَنْ آبَائِهٖ مَا اسْتُوْدِعَ مِنْ اَمْرِكَ وَنَهْيِكَ وَحَمَلَ عَلَى الْمَحَجَّةَ وَكَابَدَ اَهْلَ الْعِزَّةِ وَالشِّدَّةِ فِيْمَا كَانَ يَلْقٰى مِنْ جُهَّالِ قَوْمِهٖ رَبِّ فَصَلِّ عَلَيْهِ اَفْضَلَ وَاَكْمَلَ مَا صَلَّيْتَ عَلٰى اَحَدٍ مِّمَّنْ اَطَاعَكَ وَنَصَحَ لِعِبَادِكَ اِنَّكَ غَفُوْرٌ رَّحِيْمٌ۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "R