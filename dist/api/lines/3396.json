[{"Id": 1012684, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is reported that when a child is ailed, the mother may ascend to a roof, throw the head cover away, expose the hair of her head under the sky, prostrate herself, and say the following supplication. The mother will not raise her head from the prostration but that her child is restored to health…", "GujaratiDescription": null, "RUrduDescription": "Ek riwaayat mein hai keh jab koi bachcha bimaar ho, to uski maa ghar ki chhat (roof) par ja kar (jahan koi na-maheram dekhta na ho) sar se chaadar utaar de aur zer-e-aasmaan baal bikhra kar sar sajdeh mein rakh kar yeh dua padhe. Aur phir us waqt tak sar sajdeh se na uthaaye jab tak bachche ko aaraam na ho jaaye…", "UrduDescription": "ایک روایت ہے : جب کوئی بچہ بیمار ہو تو اس کی ماں گھر کی چھت پر جاکر سر سے چادراتار دے اور زیرِ آسمان بال بکھرا کر سر سجدے میں رکھ کر یہ دعا پڑھے۔ پھر اس وقت تک سر سجدے سے نہ اٹھائے جب تک بچے کو آرام نہ ہو جائے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013910, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, O my Lord! It is You Who have given him to me and it is You Who have endued me with Him. O Allah, so (please) renew Your donation to me on this day. You are verily all-powerful and omnipotent.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood, ay Paalne waale Tu ne hi mujhe ataa kiya aur Tu ne hi mujhe yeh diya tha, pas ay Ma’bood apni is bakhshish ko aaj phir taaza kar de, keh Tu hi qudrat o ikhteyaar waala hai.", "Urdu": "اے معبود! اے پالنے والے تونے ہی مجھے عطا کیا اور تو نے ہی مجھے یہ دیا تھا پس اے معبود! اپنی اس بخشش کو آج پھر تازہ کردے کہ تو ہی قدرت و اختیار والا ہے۔", "RArabic": "ALLAAHUMMA RABBE ANTA A’TAIYTA-NAIHE WA ANTA WA HABTA-HU LEE. ALLAAHUMMA FAJ-A’L HEBATA-KAL YAUMA JADEE-DATAN INNAKA QAADE-RUM MUQTADE-RUN.", "ArabicText1": "اَللّٰهُمَّ رَبِّ اَنْتَ اَعْطَيْتَنَيْهِ وَاَنْتَ وَهَبْتَهُ لِىْ اَللّٰهُمَّ فَاجْعَلْ هِبَتَكَ الْيَوْمَ جَدِيْدَةً اِنَّكَ قَادِرٌ مُّقْتَدِرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": n