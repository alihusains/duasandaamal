[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011749, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He who melted the iron for Dawood, peace be on him! O He who relieved Ayyub, peace be on him, from affliction and pain! O He who dispelled the sorrows of Yaqoob, peace be on him! O He who put the sad Yusuf, peace be on him, at ease! Send blessings on Muhammad and on the children of Muhammad; and in a manner befitting Thee, bless all of them; and so also likewise settle my affairs, and do not do that which I deserve.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Hazrat Dawood (a.s) ke liye lohe (Iron) ko narm karne waale. Ay Hazrat Ayub (a.s) ke dukh aur takleef ko hata dene waale. Ay Hazrat Yaqoob (a.s) ki be-taabi (be-chaini) dur karne waale. Ay Hazrat Yusuf (a.s) ka ranj mita dene waale. Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma, jaisa keh Tu uska ahel hai keh un sab par apni taraf se rehmat naazil farma aur mere saath woh sulook kar jo Tere shaayaane shaan hai aur woh sulook na kar jiska mai sazaawaar hu.", "Urdu": "اے حضرت داؤد ؑ کے لئے لوہے کو نرم کرنے والے اے حضرت ایوبؑ کے دکھ اور تکلیفیں ہٹا دینے والے اے یعقوب ؑ کی بے تابی دور کرنے والے اے یوسف ؑ کا رنج مٹا دینے والےمحمدؐ اور آل محمدؐ پر رحمت نازل فرما جیسا کہ تو اس کا اہل ہے کہ ان سب پر اپنی طرف سے رحمت نازل فرما اور میرے ساتھ وہ سلوک کر جو تیرے شایانِ شان ہے اور وہ سلوک نہ کر جو میرے لائق ہے۔", "RArabic": "YAA MOLIYYE-NAL HADEE-DE LE-DAAWOO-DA, YAA KAASHE-FAZ ZURRE WAL KORA-BIL E’ZAA-ME A’N AIYYOO-BA, AY MO-FARRE-JA HAMME YA’QOO-BA, AY MO-NAFFE-SA GHAMME YOOSOFA, SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN KAMAA ANTA AHLO-HU AN TO-SALLE-YA A’LAIY-HIM AJMA-E’ENA WAF-A’L BEE MAA ANTA AHLO-HU WA LAA TAF-A’L BEE MAA ANAA AHLO-HU.", "ArabicText1": "يَامُلَيِّنَ الْحَدِيْدِ لِدَاوُدَ، يَاكَاشِفَ الضُّرِّ وَالْكُرَبِ الْعِظَامِ عَنْ اَيُّوْبَ، اَيْ مُفَرِّجَ هَمِّ يَعْقُوْبَ، اَيْ مُنَفِّسَ غَمِّ يُوْسُفَ، صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ كَمَا اَنْتَ اَهْلُهٗ اَنْ تُصَلِّيَ عَلَيْهِمْ اَجْمَعِيْنَ وَافْعَلْ بِيْ مَا اَنْتَ اَهْلُهٗ وَلَا تَفْعَلْ بِيْ مَا اَنَا اَهْلُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "Ara