[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011795, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah prolong my life span, increase my means of livelihood, keep my body in sound condition, fulfill my desires. If I am to be thrown into calamities, cancel my entanglement with such misfortunes, and write my name in the list of those who have been blessed to be fortunate, because Thou has said in Thy Book, revealed to Thy commissioned Prophet (Thy blessings be on him and on his children), “Allah cancels what He wills, and confirms (what He wills); and with Him is source of the Book (ordinance).”", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Meri umr mein izaafa kar de, mere rizq mein wus’at de, mere badan ko tandurast rakh aur meri aarzoo puri farma aur agar mai bad-bakhto’n mein se hu to mera naam bad-bakhto’n mein se kaat (delete kar) de aur mera naam khush bakhto’n mein likh de kyu’n keh Tu ne apni is kitaab mein farmaaya hai jo Tu ne apne Nabiye Mursal (s.a.w.a) par naazil ki keh Teri rehmat ho un par aur unki Aal (a.s) par yaani Khuda jo chaahe mita deta hai aur jo chaahe likh deta hai aur usi ke paas hai ummul kitaab.", "Urdu": "اے اﷲ! میری عمر دراز فرما، میرے رزق میں وسعت دے، میرے بدن کو تندرست رکھ اور میری آرزو پوری فرما اور اگر میں بدبختوں میں سے ہوں تو میرا نام بدبختوں سے کاٹ دے اور میرا نام خوش بختوں میں لکھ دے کیوں کہ تو نے اپنی اس کتاب میں فرمایا ہے جو تونے اپنے نبی مرسلؐ پر نازل کی کہ تیری رحمت ہو ان پر اور ان کی آل ؑپر یعنی خدا جو چاہے مٹا دیتا ہے اور جو چاہے لکھ دیتا ہے اور اسی کے پاس ام الکتاب ہے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰہُمَّ امْدُدْلِیْ فِیْ عُمْرِیْ وَاَوْسِعْ لِیْ فِیْ رِزْقِیْ وَاَصِحَّ لِیْ جِسْمِیْ وَبَلِّغْنِیْ اَمَلِیْ وَاِنْ کُنْتَ مِنَ الْاَشْقِیَآئِ فَامْحُنِیْ مِنَ الْاَشْقِیَآئِ وَاکْتُبْنِیْ مِنَ السُّعَدَآئِ فَاِنَّکِ قُلْتُ فِیْ کِتَابِکَ الْمُنْزَلِ عَلٰی نَبِیِّکَ الْمُرْسَلِ صَلَوٰتُکَ عَلَیْہِ وَاٰلِہٖ یَمْحُواللہُ مَا یَاشَآئُ وَیُثْبِتُ وَعِنْدَہٗ اُمُّ الْکِتَابِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "A