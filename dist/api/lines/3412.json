[{"Id": 1014778, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "It is reported that a man complained to Imam Musa Kazim (a) about suffering from continuous tenesmus (i.e a frequent, excessive, and painful desire to defecate). As treatment, the Imam (a) taught the man to say the following supplicatory prayer after the Night Prayer…", "GujaratiDescription": null, "RUrduDescription": "Riwaayat hai keh ek shakhs ne Hazrat Imam Moosa Kazim (a) ki khidmat mein paiychish ki shikaayat ki aur kaha keh yeh rukne nahi paati, Aap (a) ne farmaaya jab namaz-e-shab se faarigh ho jaawo to yeh dua padho…", "UrduDescription": "مروی ہے : ایک شخص نے حضرت امام موسیٰ کاظم ؑ کی خدمت میں پیچش کی شکایت کی اور کہا: یہ نہیں رکتی؟! آپؑ نے فرمایا: جب نماز تہجد سے فارغ ہو جاؤ تو یہ دعا پڑھو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014779, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, whatsoever good thing I have ever experienced has been from You and I have no praiseworthy thing about it. As for whatsoever evil I have done, You have already warned me against it; therefore, I am not excused in doing it at all. O Allah, I thus pray Your protection against that I rely upon things that I have no praiseworthy interference it them or that I feel secure against things that I am unexcused in committing them.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Jo achchhayi hai Teri taraf se hai us mein meri koi khoobi nahi aur jo buraayi mujh se sarzad hoti hai Tu ne pehle mujhe us se daraaya hai uske liye mai koi izzat nahi rakhta. Ay Ma’bood! Mai be-shak Teri panah leta hu keh is baat par bharosa karu jo mere liye wajah'e taareef nahi hai ya us par mutmaeen rahu jis ke liye mai koi uzr nahi rakhta.", "Urdu": "اے معبود! جو اچھائی ہے تیری طرف سے ہے اس میں میری کوئی خوبی نہیں اور جو برائی مجھ سے سر زد ہوتی ہے تو نے پہلے مجھے اس سے ڈرایا ہےاس کے لئے میں کوئی عذ ر نہیں رکھتا اے معبود! میں بے شک تیری پناہ لیتا ہوں کہ اس بات پر بھروسہ کروں جو میرے لئے تعریف کا سبب نہیں ہے یا اس پر مطمئن رہوں جس کے لئے میں کوئی عذر نہیں رکھتا۔", "RArabic": "ALLAAHUMMA MAA KAANA MIN KHAIRIN FA-MINKA LAA HAMDA-LEE FEEHE WA MAA A’MAL-TO MIN SOO-IN FA-QAD HAZZAR-TANEE-HE LAA U’ZRA LEE FEEHE. ALLAAHUMMA INNEE AOO’ZO BEKA AN ATTA-KELA A’LAA MAALAA HAMDA-LEE FEEHE AW AA-MANA MIMMAA LAA U’DRA LEE FEEHE.", "ArabicText1": "اَللّٰهُمَّ مَا كَانَ مِنْ خَيْرٍ فَمِنْكَ لَاحَمْدَلِىْ فِيْهِ وَمَا عَمِلْتُ مِنْ سُوْءٍ فَقَدْ حَذَّرْتَنِيْهِ لَاعُذْرَ لِىْ فِيْهِ اَللّٰهُمَّ اِنِّىْ اَعُوْذُبِكَ اَنْ اَتَّكِلَ عَلٰى مَالَا حَمْدَلِىْ فِيْهِ اَوْ آمَنَ مِمَّا لَا عُذْرَ لِىْ فِيْهِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014780, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "Imam Musa Kazim (a) is also reported to have advised the same previous supplicatory prayer to be said after the Night Prayer by those who suffer from stomach gurgling. (A man said to him, “I suffer from stomach gurgling that never stops. Therefore, I feel embarrassed when people to whom I speak hear the sounds of such gurgling. So, please pray Allah to cure me of it.)", "GujaratiDescription": null, "RUrduDescription": "Riwaayat mein hai keh ek shakhs ne Imam Moosa Kazim (a) ke huzoor shikaayat ki keh uske peyt mein se hawa ke harkat karne ki aawaaz rehti hai, mujhe logo’n ke saath baat karte waqt sharam aati hai kyu-keh hawa mere peyt se khaarij hoti hai aur log usey soonte hai. Aap (a) mere liye hawa ki is takleef ke dur karne ki dua taleem farmaaye, Imam Moosa Kazim (a) ne isi dua ko Namaz-e-Shab se faarigh hone ke baad padhne ko kaha hai.", "UrduDescription": "روایت نقل ہوئی ہے : ایک شخص نے امام موسیٰ کاظم ؑ کے حضور شکایت کی کہ اس کے پیٹ میں سے ہوا کی حرکت کرنے کی آواز رہتی ہے مجھے لوگوں کے ساتھ بات کرتے وقت شرم آتی ہے کیوں کہ ہوا میرے پیٹ سے خارج ہوتی ہے اور لوگ اسے سنتے ہیں آپؑ میرے لئے ہوا کی اس تکلیف کے دور کرنے کی دعا تعلیم فرمائیں امام موسیٰ کاظم ؑ نے فرمایا: جب نماز تہجد پڑھ چکو تو اپر دی ہوی دُعا پڑھے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014781, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 3, "EnglishDescription": "Imam Sadiq (a), advising those who suffer from stomach gurgling, said, “Black cumin may be mixed with honey and then eaten.”", "GujaratiDescription": null, "RUrduDescription": "Imam Jafar Sadiq (a) se bhi is baare mein manqool hai keh harmal ko shahed (honey) mein mila kar khaaye.", "UrduDescription": "مزید امام جعفر صادق ؑ سے بھی اس بارے میں منقول ہے : ہر مل کو شہد میں ملا کر کھائے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicG