[{"Id": 1013030, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Fatema binte Asad (s) is one of the most honorable ladies. The Holy Prophet (s) used to respect her a great deal. Hazrat Ali bin Abi Talib (a) is her son. Her grave is near the graves of the Imams of Baqi. According to some people her grave is near the grave of Haleemah Sa’diyyah. Stand near the grave of this respected lady and recite her Ziyarat as follows…", "GujaratiDescription": null, "RUrduDescription": "Fatema binte Asad (s) jo ek azeem khatoon hai. Rasool-e-Khuda (s) unka bohot ehteraam karte thay. Hazrat Ali (a) unke farzand thay. Unki qabr Aimma al-Baqi (a) ke qareeb hai. KuchH logo’n ka kehna hai keh unki qabr Haleemah Sadiyyah ki qabr ke qareeb hai. Yeh azeem khatoon ki qabr ke paas khade ho kar unki ziyarat is tarah se padhe…", "UrduDescription": "آپ امیرالمومنینؑ کی والدۂ ماجدہ ہیں،ان بی بی کی قبر کے نزدیک کھڑے ہو کر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": nu