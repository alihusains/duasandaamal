ull, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010141, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O examined lady. He Who created you has examined you and found that you have passed the examination patiently. I am a believer of you and I am carrying out that with which your father and his successor has come patiently; peace be upon both of them. I now beseech you by my belief in you to add me up with my belief in both of them so that I will be delighted. So, testify to me that I am totally loyal to you and to your Household; peace of Allah be upon them all.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay imtehaan dene waali Bibi, keh aap ka imtehaan aap ke Khaaliq ne liya aur aap ko manzil'e imtehaan mein sabr karne waali paaya. Ay Bibi mai aap ki tasdeeq karta hu aur aap ke pidar'e buzurg-waar aur unke Wasi (in dono par Allah ki rehmat naazil ho) ke laaye huwe ahkaam par sabr o shukr karne waala hu. Ay Bibi mai aap se sawaali hu keh agar meri tasdeeq haqeeqi hai to mujhe in dono (Rasoole Khuda (s.a.w.a) aur Hazrat Ali (a.s)) se mulhaq kar dijiye ta-keh mera dil khush ho jaaye. Aap gawah rahe keh mai aap aur aap ke ghar waalo’n ki wilaayat ke sabab taahir hu un sab par Allah ki rehmate’n naazil ho.", "Urdu": "آپ پر سلام ہو اے آزمائی ہوئی ذات! آپ کے خالق نے آپ کا امتحان لیا تو اس نے آپ کو امتحان میں صبر کرنے والی پایا،میں آپ پر ایمان رکھتا ہوں جو کچھ آپ کے والد گرامی اور ان کے وصی کو دیا گیا اس پر ثا بت قدم ہوں، ان دونوں پر خدا کی رحمت ہومیں آپ سے سوال کرتا ہوں کہ اگر میں نے آپ کی تصدیق کی ہے تو صرف اس لئے کہ آپ اس تصدیق کے ذریعے مجھے اپنے بابا اور ان کے وصی سے ملحق کر دیجیے تاکہ مجھے خو شی ملے۔ اے بی بی ؑگواہ رہنا کہ میں آپ کی اور آپ کے خاندان کی ولایت کی تائید کرتا ہوں ان سب پر خدا کی رحمتیں ہوں۔", "RArabic": "ASSALLAMO A’LAYKE YAA MUMTAHANATUM TAHANAKIL LAZEE KALAQAKE FAWAJADAKE LEMAM TAHANAKE SAABERATAN ANAA LAKE MOSADDEQUN SAABERUN A’LAA MAA ATAA BEHI ABOOKE WA WASIYYOHU SALAWAATUL LAAHE A’LAYHEMAA WA ANAA ASALOKE IN KUNTO SADDAQTOKE ILLAA AL HAQTENEE BE TASDEEQEE LAHOMAA LE-TOSARRA NAFSEE FASH-HADEE ANNEE ZAAHERUN BE- WELAAYATEKE WA WELAAYATE AALE BAYTEKE SALAWAATUL LAAHE A’LAYHIM AJMAE’EN.", "ArabicText1": "اَلسَّلَامُ عَلَیْکِ یَامُمْتَحَنَۃُ امْتَحَنَکِ الَّذِیْ خَلَقَکِ فَوَجَدَکِ لِمَا امْتَحَنَکِ صَابِرَۃً اَنَا لَکِ مُصَدِّقٌّ صَابِرٌ عَلٰی مَا اَتٰی بِہٖ اَبُوْکِ وَ وَصِیُّہٗ صَلَوَاتُ اللہِ عَلَیْھِمَا وَاَنَا اَسْئَلُکِ اِنْ کُنْتُ صَدَّقْتُکِ اِلَّا اَلْحَقْتِنِیْ بِتَصْدِیْقِیْ لَھُمَا لِتُسَرَّ نَفْسِیْ فَاشْھَدِیْ اَنِّیْ ظَاھِرٌۢ بِوِلَایَتِکِ وَ وِلَایَۃِ آلِ بَیْتِکِ صَلَوَاتُ اللہِ عَلَیْھِمْ اَجْمَعِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": 