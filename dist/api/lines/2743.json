[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011621, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God of Ibrahim and O God of Ishaq. And O God of Yaqub and the tribes. Lord of the angels and the Holy spirit. The Hearer, the All-knowing, the Wise, the Noble, the High and the Great. I kept fast for You and with Your sustenance I end my fast and I seek refuge with You and I entered Your court and You are the Kind and Merciful. Make me strong enough to fast and pray and do not expose me on Judgment Day. Indeed you do not break Your promise.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ibrahim (a.s) ke Khuda, ay Is’haaq (a.s) ke Khuda, ay Yaqoob (a.s) ke Khuda aur unke asbaat (nawaaso’n) ke Khuda, ay Malaayeka aur Roohul Quds ke Parwardigaar. Ay soonne waale, ay jaanne waale, ay hikmat waale, ay karam karne waale, ay buzurg o bartar, mai ne Tere hi liye roza rakkha aur Teri hi di huwi rozi se iftaar kiya aur Tere hifz o amaan mein panah-guzi ho gaya (panah le liye) hu aur Teri baargah mein mai ne rujoo kiya aur Teri hi taraf baaz-gasht (palatna) hai. Tu hi maher-baan aur raheem hai mujh ko namaz aur roze ki taaqat de aur ba-roze Qayamat mujhe ruswa na karna be-shak Tu waada khilaafi nahi karta.", "Urdu": "اے ابراہیمؑ کے خدا، اے اسحاقؑ کے خدا، اے یعقوبؑ کے خدا اور ان کے اثبات کے خدا، اے ملائکہ اور روح القدس کے   پروردگار۔ اے سننے والے، اے جاننے والے، اے حکمت والے، اے کرم والے، اے بزرگی و برتر، میں نے تیرے ہی لئے روضہ رکھا ہے، تیری ہی دی ہوئی رضی سے افطار کیا اور تیرے حفظ و امان میں پناہ گزی ہو گیا ہو اور تیری بارگاہ میں مئی نے رجو کیا اور تیری ہی طرف باز گشت ہے۔ تو ہی مہر بان اور رحیم ہے مجھ کو نماز اور روضہ کی طاقت دے اور بروز قیامت مجھے رسوا نہ کرنا بےشک تو وعدہ خلافی نہیں کرتا۔", "RArabic": "YAA ILAAHA IBRAA-HEEMA WA ILAAHA IS-HAAQA WA ILAAHA YA’QOOBA WAL IS-BAATE RABBAL MALAA-E-KATE WARROO-HIS SAMEE-U’L A’LEE-MUL HAKEE-MUL KAREE-MUL A’LIYYUL A’ZEEMO LAKA SUMTO WA A’LAA RIZQE-KA AFTAR-TO WA ILAA KANA-FEKA AA-WAIY-TA WA ILAIY-KA A-NABTO WA ILAI-KAL MASEE-RO WA ANTAR RA-OO-FUR RAHEEMO QAWWE-NEE A’LAS SALAATE WAS SEYAA-ME WA LAA TUKH-ZE-NEE YAWMAL QEYAAMA-TE INNA-KA LAA TUKHLE-FUL MEE-AA’D.", "ArabicText1": "یَااِلٰہَ اِبْرٰھِیْمَ وَاِلٰہَ اِسْحٰقَ وَاِلٰہَ یَعْقُوْبَ وَالْاَسْبَاطِ رَبَّ الْمَلَآئِکَۃِ وَالرُّوْحِ السَّمِیْعُ الْعَلِیْمُ الْحَکِیْمُ الْکَرِیْمُ الْعَلِیُّ الْعَظِیْمُ لَکَ صُمْتُ وَعَلٰی رِزْقِکَ اَفْطَرْتُ وَاِلٰی کَنَفِکَ اٰوَیْتَ وَاِلَیْکَ اَنَبْتُ وَاِلَیْکَ الْمَصِیْرُ وَاَنْتَ الرَّئُوْفُ الرَّحِیْمُ قَوِّنِیْ عَلَی الصَّلٰوۃِ وَالصِّیَامِ وَلَاتُخْزِنِیْ یَوْمَ الْقِیٰمَۃِ اِنَّکَ لَاتُخْلِفُ الْمِیْعَادَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "Ara