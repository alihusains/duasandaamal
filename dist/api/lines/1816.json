[{"Id": 1012151, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Sayyid Ibn Tawus and Shaikh al-Saduq have both narrated the following on the authority of Jabir ibn Abdullah al-Ansari: I visited the Messenger of Allah (s) on the last Friday of Ramazan. As he saw me, he said, “Jabir: This is the last Friday of Ramazan. You should thus bid it farewell by saying this dua. Verily, anyone who says this dua will win one of the two good things; either attaining the next Ramazan or having the forgiveness and mercy of Almighty Allah.”…", "GujaratiDescription": null, "RUrduDescription": "Sayyid ibne Tawus aur shaikh Saduq ne Jabir ibne Abdullah Ansari se riwaayat ki hai keh mai Rasoole Khuda (s) ki khidmat mein haazir huwa aur woh din Mahe Ramazan ka aakhri Juma tha. Jab Aan Hazrat (s) ki nazar mujh par padi to farmaya keh “Ay Jabir! Yeh Mahe Ramazan ka aakhri Juma hai, pas Mahe Ramazan ko is dua se al-wida karo. Jo shakhs is dua ko padhe to yaqeenan woh do (2) saadato’n mein se ek zaroor haasil karta hai, yaani woh aainda Ramazan ko paayega ya Khuda ki intehaayi rehmat o bakhshish se maala-mal ho kar aalame baqa mein raahate haasil karega”…", "UrduDescription": "سیدؒ و شیخ صدوق ؒنے جابر ابن عبداللہ انصاری سے روایت کی ہے : میں رسول اﷲؐکی خدمت میں حاضر ہوا اور وہ دن رمضان مبارک کا آخری جمعہ تھا۔ جب آنحضرت ؐ کی نظر مجھ پر پڑی تو فرمایا : اے جابر! یہ ماہِ رمضان کا آخری جمعہ ہے پس ماہِ رمضان کو الوداع کرتے ہوئے کہو۔ جوشخص اس دعا کو پڑھے تو یقینًا وہ دوسعادتوں میں سے ایک ضرور حاصل کرتا ہے۔ یعنی وہ آئندہ رمضان کو پائے گا یا خدا کی انتہائی رحمت و بخشش سے ہم کنار ہو کر عالم بقا میں راحت وسکون حاصل کرے گا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012152, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah: (please) do not make it the last of our fasting in this month; but if You decide so, then (please) make me enjoy (Your) mercy and do not make me deprived (of it).", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Is Mahe Ramazan ke rozo’n ko meri zindagi ke aakhri roze qaraar na dena aur agar Teri marzi yahi hai to apni rehmat se mujhe marhoom (rahem kiya huwa) qaraar dena aur mehroom qaraar na dena.", "Urdu": "اے اﷲ! رمضان کے اس مہینے کے روزے میرے لئے آخری روزے قرار نہ دے پس اگر تو ایسا کرے تو مجھے رحم کیا ہواقرار دے اور رحمت سے محروم کیا ہوا نہ بنا۔", "RArabic": "ALLAAHUMMA LAA TAJ-A’L-HU AA-KHE-RAL A’HDE MIN SEYAA-MENAA IYYAA-HO FA-IN JA-A’L-TAHU FAJ-A’L-NEE MARHU-MAN WA LAA TAJ-A’L-NEE MAHROO-MAN.", "ArabicText1": "اَللّٰهُمَّ لَا تَجْعَلْهٗ آخِرَ الْعَهْدِ مِنْ صِيَامِنَا اِيَّاهُ فَاِنْ جَعَلْتَهٗ فَاجْعَلْنِيْ مَرْحُوْمًا وَلَا تَجْعَلْنِيْ مَحْرُوْمًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null,