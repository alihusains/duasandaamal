[{"Id": 1013493, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "When you reach the gate of Baab al-Feel, stop there and recite…", "GujaratiDescription": null, "RUrduDescription": "Jab Baab al-Feel par pohonche to wahan khade ho kar yeh padhe…", "UrduDescription": "جب مسجد کے دروازے (باب الفیل) پر آئے تو اس کے نزدیک کھڑے ہوکر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013494, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon our master the Messenger of Allah, Muhammad son of Abdullah, and upon his immaculate progeny. Peace be upon the Commander of the Faithful, Ali the son of Abu-Talib. Allah’s mercy and blessings be upon him, upon his sessions, upon his meeting places, upon the places that witnessed his wisdom, upon the traces of his forefathers: Adam, Noah, Abraham, and Ishmael, and upon the places that witnessed the presentations of his evidences.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho hamare sardaar Khuda ke Rasool Hazrat Muhammad bin Abdullah (s.a.w.a) par aur unki Aal (a.s) par. Salaam ho momino ke Ameer Hazrat Imam Ali ibne Abdu Talib (a.s) par, Khuda ki rehmat ho aur Uski barkaat ho. Salaam unki majaalis, unke mazaahar aur unki hukumat ke maqaam par. Salaam ho unke buzurgo’n Aadam (a.s) wa Nooh (a.s) aur Ibrahim (a.s) wa Ismaail (a.s) par aur Salaam unke waazeh dalaael par.", "Urdu": "سلام ہو ہمارے سردار خدا کے رسولؐ حضرت محمدؐ ابن عبداﷲؑ پر اور ان کی آلؑ پرسلام ہو مومنوں کے امیر حضرت امام علیؑ ابن ابی طالب پر خدا کی رحمت ہو اور اس کی برکات ہوں سلام ان کی مجالس ان کے مظاہر اوران کی حکمت کے مقام پر سلام ہو ان کے بزرگوں آدمؑ و نوحؑ اور ابراہیمؑ و اسماعیلؑ پر اور سلام ہوان کے واضح دلائل پر۔", "RArabic": "AS-SALAAMO A’LAA SAYYEDENAA RASOOLIL LAAHE MOHAMMADIBNE A’BDIL LAAHE WA AALEHIT TAAHEREENA ASSALAAAMO A’LAA AMEERIL MOMENEENA A’LIYYIBNE ABEE TAALEBIWN WA RAHMATUL LAAHE WA BARAKAATOHU WA A’LAA MAJAALESEHI WA MASHA-HEDEHI WA MAQAAME HIKMATEHI WA AASAARE AABAA-EHI AADAMA WA NOOHIN WA IBRAAHEEMA WA ISMAA-E’ELA WA TIBYAANE BAYYENAATEHI.", "ArabicText1": "اَلسَّلَامُ عَلٰی سَیِّدِنَا رَسُوْلِ اللہِ مُحَمَّدِ بْنِ عَبْدِ اللہِ وَآلِهِ الطَّاهِرِیْنَ۔ اَلسَّلَامُ عَلٰی اَمِیْرِ الْمُؤْمِنِیْنَ عَلِیِّ بْنِ اَبِیْ طَالِبٍ وَّرَحْمَۃُ اللہِ وَبَرَكَاتُهٗ وَعَلٰی مَجَالِسِهٖ وَمَشَاهِدِهٖ وَمَقَامِ حِكْمَتِهٖ وَاٰثَارِ اٰبَائِهٖٓ اٰدَمَ وَنُوْحٍ وَاِبْرَاهِیْمَ وَاِسْمٰعِیْلَ وَتِبْیَانِ بَیِّنَاتِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013495, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon the Imam: the wise, the just, the grandest veracious, and the fair distinguisher by whom Allah distinguished the right from the wrong, atheism from (true) belief, and polytheism from monotheism, so that he who would perish might perish by clear proof and he who would live might live by clear proof.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho un Aimma (a.s) par jo hakeem, aadil, siddiqe Akbar aur ba-insaaf faarooq hai keh jin ke zariye Khuda taala ne haq o baatil, kufr o imaan aur shirk o tawheed ka farq waazeh kiya, ta keh jo halaak ho uski halaakat par hujjat qaaem ho aur jo zindah rahe woh hujjat par zindah rahe.", "Urdu": "سلام ہو ان ائمہؑ پر جو حکیم عادل صدیق اکبر اور باانصاف فاروق ہیں کہ جن کے ذریعے خدائے تعالیٰ نے حق و باطل کفر و ایمان اور شرک و توحید کا فرق واضح کیا تاکہ جو ہلاک ہواس کی ہلاکت پر حجت قائم ہو اور جو زندہ رہے وہ حجت پرزندہ رہے۔", "RArabic": "AS-SALAAMO A’LAL EMAAMIL HAKEEMIL A’DLIS SIDDEEQIL AKBARIL FAAROOQE BIL-QISTIL LAZEE FARRAQAL LAAHO BEHI BAYNAL HAQQE WAL BAATELE WAL KUFRE WAL EEMAANE WASH-SHIRKE WAT-TAWHEEDE LE-YAHLEKA MAN HALAKA A’M BAYYENATIWN WA YAHYAA MAN HAYYA A’M BAYYENATIN.", "ArabicText1": "اَلسَّلَامُ عَلَی الْاِمَامِ الْحَكِیْمِ الْعَدْلِ الصِّدِّیْقِ الْاَكْبَرِ الْفَارُوْقِ بِالْقِسْطِ الَّذِیْ فَرَّقَ اللہُ بِهٖ بَیْنَ الْحَقِّ وَالْبَاطِلِ وَالْكُفْرِ وَالْاِیْمَانِ وَالشِّرْكِ وَالتَّوْحِیْدِ لِیَهْلِكَ مَنْ هَلَكَ عَنْۢ بَیِّنَۃٍ وَّیَحْیٰ مَنْ حَیَّ عَنْۢ بَیِّنَۃٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013496, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I bear witness that you are verily the commander of the faithful, the elite of the selves of the select ones, the elite of the selves of the select ones, the elite of the selves of the select ones, and that you are verily the judge of Allah on His lands, and that you are verily the judge of Allah on His lands, and that you are verily the judge of Allah on His lands, the maker of His pledge, the maker of His pledge, the maker of His pledge, the haven of redemption, the course of piety, the most elevated rank, and the executor of the laws of the Most Exalted Judge. O Commander of the Faithful, through you do I seek close nearness to Allah for you are my chief, master, and means (to Allah) in this world as well as the Hereafter.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawahi deta hu keh aap momino ke Ameer, paak asl, logo’n ki roohaani khaasiyat, saahebaane sidq ki zeenat aur aazmoodah logo’n (azmaaye huwo) mein ziyadah saabir hai. Neez aap Khuda ki zameen mein uske munsif (insaaf karne waale), Uske hukm ko jaari karne waale, Uski hukumat ka darwaaza, Uska paimaan baandh ne waale, uska waada bata ne waale, usko aur Uske bando’n ko ba-ham mila ne waali rassi, najaat ka markaz, taqwa ka raasta, buland darja aur tasallut rakhne waale munsif hai. Ay momino ke Ameer, mai aap ke zariye buland-tar Khuda ka qurb chahta hu keh aap mere wali, mere sardaar aur mera wasila hai duniya o aakherat mein.", "Urdu": "میں گواہی دیتا ہوں کہ آپ مومنوں کے امیر پاک اصل لوگوں کی روحانی خاصیت صاحبان ِصدق کی زینت اورآزمودہ لوگوں میں زیادہ صابر ہیں نیز آپ خدا کی زمین میں اس کے منصف اس کے حکم کو جاری کرنے والے اس کی حکمت کا دروازہ اس کا عہد وپیمان باندھنے والے اس کا وعدہ بتانے والے اس کو اور اس کے بندوں کو باہم ملانے والی رسّی نجات کا مرکز تقویٰ کا راستہ بلند درجہ اور تسلط رکھنے والے منصف ہیں اے مومنوں کے امیر میں آپ کے ذریعے بلند ترخدا کی قربت چاہتا ہوں کہ آپ میرے ولی میرے سردار اور میرا وسیلہ ہیں دنیا و آخرت میں۔", "RArabic": "ASH-HADO ANNAKA AMEERUL MOMENEENA WA KHAAAS-SATO NAFSIL MUNTAJABEENA WA ZAYNUS-SIDDEEQEENA WA SAABERUL MUMTAHANEENA WA ANNAKA HAKAMUL LAAHE FEE ARZEHI WA QAAZEE AMREHI WA BAABO HIKMATEHI WA A’AQEDO A’HDEHI WAN-NAATEQO BE-WA’DEHI WAL HABLUL MAWSOOLO BAYNAHU WA BAYNA E’BAADEHI WA KAHFUN NAJAATE WA MINHAAJUT TOQAA WAD-DARAJATUL U’LYAA WA MOHAYMENUL QAAZIL A-A’LAA YAA AMEERAL MOMENEENA BEKA ATAQARRABO ELAL LAAHE ZULFAA ANTA WALIYYEE WA SAYYEDEE WA WASEELATEE FID DUNYAA WAL-AAKHERATE.", "ArabicText1": "اَشْهَدُ اَنَّكَ اَمِیْرُ الْمُؤْمِنِیْنَ وَخَآصَّۃُ نَفْسِ الْمُنْتَجَبِیْنَ وَزَیْنُ الصِّدِّیْقِیْنَ وَصَابِرُ الْمُمْتَحَنِیْنَ وَاَنَّكَ حَكَمُ اللہِ فِیْ اَرْضِهٖ وَقَاضِیْ اَمْرِهٖ وَبَابُ حِكْمَتِهٖ وَعَاقِدُ عَهْدِهٖ وَالنَّاطِقُ بِوَعْدِهٖ وَالْحَبْلُ الْمَوْصُوْلُ بَیْنَهٗ وَبَیْنَ عِبَادِهٖ وَكَهْفُ النَّجَاۃِ وَمِنْهَاجُ التُّقٰی وَالْدَّرَجَۃُ الْعُلْیَا وَمُهَیْمِنُ الْقَاضِیْ الْاَعْلٰی یَا اَمِیْرَ الْمُؤْمِنِیْنَ بِكَ اَتَقَرَّبُ اِلَی اللہِ زُلْفٰی اَنْتَ وَلِیِّیْ وَسَیِّدِیْ وَ وَسِیْلَتِیْ فِی الدُّنْیَا وَالْاٰخِرَۃِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign