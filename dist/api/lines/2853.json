[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009901, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to the Lord of Honor and Sublime Authority. Glory be to the Lord of Majesty and Exalted Greatness. Glory be to the Lord of eternal, splendid sovereignty. Glory be to Him Who makes out the footprints of the ant on the stone. Glory be to Him Who knows the exact time and place of the bird dipping down through the air. Glory be to Him Who is like this and no one other than Him is like this.", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai Woh jo buland o baala izzat ka maalik hai, paak hai Woh saahebe jalaalat shaan o azmat waala, paak hai Woh qadeemi qaabile fakhr hukumat ka Maalik, paak hai Woh jo chatil patthar par chiyoonti ke paau ka nishaan dekhta hai, paak hai Woh jo fiza mein parinde ke udne ke khat dekhta hai, paak hai Woh jo aisa hai aur Uske siwa koi aisa nahi.", "Urdu": "پاک ہے وہ جو بلند و بالا عزّت کا مالک ہے پاک ہے وہ صاحب ِجلالت شان و عظمت والاپاک ہے وہ قدیمی قابلِ فخر حکومت کا مالک پاک ہے وہ جو چٹیل پتھر پر چیونٹی کے پاؤں کا نشان دیکھتا ہے پاک ہے وہ جو فضا میں پرندے کے اڑنے کے خط دیکھتا ہے پاک ہے وہ جو ایسا ہے اور اس کے سوا کوئی ایسا نہیں۔", "RArabic": "SUBHAANA ZIL I’ZZIL SHAAMEKHIL MONEEFE SUBHAANA ZIL JALAALIL BAAZEKHIL A’ZEEME SUBHAANA ZIL MULKIL FAAKHERIL QADEEME SUBHAANA MAN YARAA ASARAN NAMLATE FIS SAFAA SUBHAANA MAN YARAA WAQ-A’T TAYRE FIL HAWAAA-E SUBHAANA MAN HOWA HAAKAZAA WA LAA HAAKAZAA GHAYROHU.", "ArabicText1": "سُبْحَانَ ذِي الْعِزِّ الشَّامِخِ الْمُنِيْفِ، سُبْحَانَ ذِي الْجَلَالِ الْبَاذِخِ الْعَظِيْمِ، سُبْحَانَ ذِي الْمُلْكِ الْفَاخِرِ الْقَدِيْمِ، سُبْحَانَ مَنْ يَرٰى اَثَرَ النَّمْلَةِ فِي الصَّفَا۔ سُبْحَانَ مَنْ يَرٰى وَقْعَ الطَّيْرِ فِي الْهَوَاءِ، سُبْحَانَ مَنْ هُوَ هَكَذَا وَلَا هَكَذَا غَيْرُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSig