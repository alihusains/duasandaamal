[{"Id": 1012487, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Whenever you recite or hear the verse of Obligatory Sajdah in Arabic or R-Arabic (transliteration) it is obligatory to perform Sajdah and recommended to recite this zikr. This zikr can also be recited in the verses of Mustahab Sajdah…", "GujaratiDescription": null, "RUrduDescription": "Jab bhi aap Waajib Sajdeh ki aayat Arabic ya R-Arabic (transliteration) mein padhe ya soone to laazim hai keh fauran Sajdah kare aur sajdeh mein is zikr ko padhe jo mustahab hai. Is zikr ko Mustahab Sajdeh ki aayato’n mein bhi padha ja sakta hai…", "UrduDescription": "جب بھی آپ واجب سجدہ کی آیت عربی یا رومن عربی میں پڑھیں یا سنے تو فورن سجدہ کرے اور مستحب ہے کہ سجدہ میں اس زکر کو پڑھیں، اس زیکر کو مستحب سجدہ میں بھی پڑھا جا سکتا ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11"