, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014473, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah with Whose Name no malady will harm. I pray for the protection of Allah’s Words with which nothing will harm. All-holy. All-holy. All-holy. I beseech You, O my Lord, in Your Name, the all-pure, the sacred, the all-blessed; whoever beseeches You in Your Name, You will give him and whoever implores You in Your Name, You will respond to him.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke naam se jis ke naam ke hote huwe bimaari takleef nahi de sakti, panah leta hu Khuda ke kalemaat ke saath jis ke hote huwe koi cheez nuqsaan nahi de sakti, Woh paak hai, paak hai, paak hai sawaal karta hu ay Parwardigaar Tere naam par jo paak se paakeeza aur barkat waala hai keh jo uske zariye Tujh se maange Tu ataa karta hai jo Tujhe uske zariye pukaare Tu uski soonta hai.", "Urdu": "خدا کے نام سے جو بڑارحم والا مہربان ہے خدا کے نام سے جس کے نام کے ہوتے ہوئے بیماری تکلیف نہیں دے سکتی پناہ لیتا ہوں خدا کے کلمات کے ساتھ جس کے ہوتے ہوئے کوئی چیز نقصان نہیں دے سکتی وہ پاک ہے پاک ہے پاک ہے سوال کرتا ہوں اے پروردگار تیرے نام پر جو پاک سے پاکیزہ اور برکت والا ہے کہ جو اس کے ذریعے تجھ سے مانگے تو عطا کرتا ہے جو تجھے اس کے ذریعے پکارے تو اس کی سنتا ہے۔", "RArabic": "BISMILLA-HIL LAZEE LAA YA-ZURRO MA-A’S MEHI DAAA-UN A-OO’ZO BE-KALEMAA-TIL LAAHIL LATEE LAA YAZURRO MA-A’HAN SHAIY-UN QUDDOOSUN, QUDDOOSUN, QUDDOOSUN AS-ALOKA YAA RABBE BISME-KAT TAAHE-RIL MOQADDA-SIL MOBAARA-KIL LAZEE MAN SA-A-LAKA BEHE A’TAIY-TAHU WA MAN DA-AA’KA BEHI AJAB-TAHU.", "ArabicText1": "بِسْمِ اللهِ الَّذِىْ لَايَضُرُّ مَعَ اسْمِهٖ دَاۗءٌ اَعُوْذُ بِكَلِمَاتِ اللهِ الَّتِىْ لَايَضُرُّ مَعَهًا شَيْءٌ قُدُّوْسٌ قُدُّوْسٌ قُدُّوْسٌ اَسْئَلُكَ يا رَبِّ بِاسْمِكَ الطَّاهِرِ الْمُقَدَّسِ الْمُبَارَكِ الَّذِىْ مَنْ سَئَلَكَ بِهِ اَعْطَيْتَهٗ وَ مَنْ دَعَاكَ بِهٖ اَجَبْتَهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014474, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I beseech you, O Allah, O Allah, O Allah, to bless Muhammad, the Prophet, and his Household and to cure me of the ache from which I am suffering in my mouth, my head, my hearing, my sight, my stomach, my back, my hand, my leg, and all of my organs.", "Gujarati": null, "RGujarati": null, "RUrdu": "Tujh se ya Allah, ya Allah, ya Allah yeh sawaal karta hu ya keh Tu rehmat naazil farma apne Nabi Muhammad (s.a.w.a) aur unke Ahle-bait (a.s) par aur aur yeh keh Tu mujhe bacha le un bimaariyo’n se jo mere mooh mein hai mere sar mein hai, kaan, Aankho’n aur peyt mein aur mere haatho’n, paiyro’n aur mere tamaam aaza (organs) mein hai.", "Urdu": "تجھ سے سوال کرتا ہوں یا للہ یا اللہ یا اللہ یہ کہ تو رحمت نازل فرما اپنے نبی محمد ؐاور ان کے اہل بیت ؑپر اور یہ کہ تو مجھے بچا لے ان بیماریوں سے جو میرے منہ میں ہیں میرے سر میں ہیں کان آنکھوں اور پیٹ میں اور کمر میں ہیں اور میرے ہاتھوں پیروں اور میرے تمام اعضا میں ہیں۔", "RArabic": "AS-ALOKA YAA ALLAAHO, YAA ALLAAHO, YAA ALLAAHO AN TO-SALLEYA A’LAA MOHAMMADIN NABIYYE WA AHLE-BAITE-HI WA AN TO-A’AFEYA-NEE MIMMAN AJEDO FEE FAMAA WA FEE RAASAA WA FEE SAM-A’A WA FEE BASARAA WA FEE BATNAA WA FEE ZAHRAA WA FEE YADAA WA FEE RIJLAA WA FEE JAWAARE-HEE KULLE-HAA.", "ArabicText1": "اَسْئَلُكَ يَا اللهُ يَا اللهُ يَا اللهُ اَنْ تُصَلِّىَ عَلٰى مُحَمَّدٍ النَّبِىِ وَاَهْلِ بَيْتِهٖ وَاَنْ تُعَافِيَنِىْ مِمًّا اَجِدُ فِىْ فَمٰى وَفِىْ رَاْسٰى وَفِىْ سَمْعٰى وَفِىْ بَصَرٰى وَفِىْ بَطْنٰى وَفِىْ ظَهْرٰى وَفِىْ يَدٰى وَفِىْ رِجْلٰى وَفِىْ جَوَارِحِىْ كُلِّهَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7":