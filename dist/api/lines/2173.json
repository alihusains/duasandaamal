[{"Id": 1011488, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is narrated that a person remained under hardships of imprisonment in Shaam for a period of time till he had a dream that Lady Fatema Zahra (s) was saying: Recite this supplication, which when he recited after learning, he was freed from the prison…", "GujaratiDescription": null, "RUrduDescription": "Riwaayat hai keh Shaam mein ek qaidi arse se qaid mein tha. Ek raat khwaab mein Hazrat Zahra (s) ko dekhta hai jo uske paas aa kar farmati hai keh is dua ko padho, us mard ne woh dua ko Janabe Sayyada (s) se seekha aur dua maangi to phir woh azaad ho kar ghar laut aaya…", "UrduDescription": "روایت ہے کہ شام میں ایک قیدی عرصہ سے قیدس تھا۔ ایک رات خواب میں حضرت زہرا کو دیکھتا ہے جو اس کے پاس آکر فرماتی ہیں کہ اس دعا کو پڑھو، اس مرد نے وہ دعا جناب سیدہ سے سیکھی اور دعا مانگی اور پھر وہ آزاد ہو کر گھر لوٹ آیا، اور وہ دعا یہ ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "Arabi