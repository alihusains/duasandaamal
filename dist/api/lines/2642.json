LAAMO A’LAA JA’FARIB-NE MOHAMMADIN. AS-SALAAMO A’LAA MOOSAB-NA JA’FARIN. AS-SALAAMO A’LAA A’LIYYIB NA MOOSAR REZAA. AS-SALAAMO A’LAA MOHAMMADIB-NE A’LIYYIN. AS-SALAAMO A’LAA A’LIYYIB-NE MOHAMMADIN. AS-SALAAMO A’LAA HASANIB-NE A’LIYYIN.", "ArabicText1": "اَلسَّلَامُ عَلٰی جَدِّکَ الْمُصْطَفٰی۔ اَلسَّلَامُ عَلٰی اَبِیْکَ الْمُرْتَضٰی ۔ اَلسَّلَامُ عَلٰی خَدِیْجَۃَ اُمِّ سَیِّدَۃِ نِسَآئِ الْعَالَمِیْنَ۔ اَلسَّلَامُ عَلٰی فَاطِمَۃَ اُمِّ الْاَئِمَّۃِ الطَّاہِرِیْنَ۔ اَلسَّلَامُ عَلَی السَّیِّدَیْنِ الْحَسَنِ وَالْحُسَیْنِ سَیَّدَیْ شَبَابِ اَہْلِ الْجَنَّۃِ اَجْمَعِیْنَ۔ اَلسَّلَامُ عَلَی عَلِیِّ بْنِ الْحُسَیْنِ۔ اَلسَّلَامُ عَلَی مُحَمَّدِ بْنِ عَلِیٍّ، اَلسَّلَامُ عَلَی جَعْفَرِ بْنِ مُحَمَّدٍ۔ اَلسَّلَامُ عَلَی مُوْسَی بْنَ جَعْفَرٍ۔ اَلسَّلَامُ عَلَی عَلِیِّ بْنَ مُوْسَی الرِّضَا۔ اَلسَّلَامُ عَلَی مُحَمَّدِ بْنِ عَلِیٍّ۔ اَلسَّلَامُ عَلَی عَلِیِّ بْنِ مُحَمَّدٍ۔ اَلسَّلَامُ عَلَی حَسَنِ بْنِ عَلِیٍّ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign