[{"Id": 1016377, "EnglishTitle": "Namaz & Concentration towards Imam-e-Zamana (a).", "GujaratiTitle": null, "RUrduTitle": "Namaz aur Imam-e-Zamana (a) ki taraf Tawajjoh.", "UrduTitle": "امام عصر (عج) کے لئے نماز اور دُعاء توجہ۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016378, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Ahmad bin Ibrahim said: I complain to Abu Ja'far, Muhammad bin Uthman that I am interested to see our Master (a) he said to me: with interest you desire to see him? Yes I replied. Be grateful to God for your interest, he said to me, and I would show you his direction in good health and at ease, O Abu Abdullah don't solicit to see him because the days of occultation are yearning to see him and don't request to convene with him because it is a firm resolution of God and it is better you submitted to it but you concentrate to him through Ziyarat. Regards what shall be his duty is what Muhammad bin Ali dictated to him as follows: Give concentration to Imam with Ziyarat after you have offered 12 Rak'at of prayer, in every rakat after <Surah Fateha> recite <Surah Ikhlaas> and after every 2 rakats you terminate your prayer, you send salutation to Muhammad (s) and his progeny (a) after that recite the following words of God…", "GujaratiDescription": null, "RUrduDescription": "Ahmed bin Ibrahim kehte hai keh Imam-e-Zamana (a) ki ziyarat ka shouq mere dil mein paiyda huwa is liye Janabe Abu Jafar Muhammad bin Usmaan se shikaayat ki jo Nawab-e-Arba mein se ek thay. Janabe Muhammad bin Usmaan ne farmaaya keh kya dil se aarzoo rakhte ho ke Imam-e-Zamana (a) ki mulaqaat ho jaaye? Mai ne kaha haa’n Khuda wande taala tumhaari aarzoo ko pura kare, mai tumhara maamla aasaan dekhta hu, ay Aba Abdillah unki ziyarat ka iltemaas na karo chun-keh ghaibat-e-kubra ke dauraan unki ziyarat ka ishteyaaq rehta hai lekin us ijetma se un se sawaal nahi kiya ja sakta hai yeh aayaat Ilaahi mein se hai lekin isko tasleem karna zaroori hai lekin jab aap uski taraf tawajjoh karna chahe to is ziyarat ke saath Hazrat ki taraf mutawajjeh ho jaaye. Ziyarat is tarah kare keh 12 rakat namaz (2x2) rakat kar ke anjaam de aur har rakat mein <Surah Fateha> ke baad <Surah Ikhlaas> padhe. Har 2 rakat ke baad Muhammad (s) aur Aale Muhammad (a) par durood bheje aur phir Parwardigaar ke is qoul ko is tarah se padhe…", "UrduDescription": "احمد بن ابراھیم کہتاہے امام زمانہ کی زیارت کا شوق میرے دل میں پیدا ہوا اس لئے جناب ابوجعفر محمد بن عثمان سے شکایت کی جو نواب اربعہ میں سے ایک تھا جناب محمد بن عثمان نے فرمایا کہ کیا دل سے آرزو رکھتے ہو کہ امام زمانہ کی ملاقات ہوجائے میں نے کہا ہاں فرمایا خداوند تعالیٰ کے تمہاری آرزو کو پورا کرے میں تمہارا معاملہ آسان دیکھتاہوں ای ابا عبداللہ ان کی زیارت کا التماس نہ کرو چونکہ غیبت کبریٰ کے دوران ان کی زیارت کا اشتیاق رہتاہے لیکن اس اجتماع سے ان سے سوال نہیں کیا جاسکتاہے یہ آیات الٰہی میں سے ہے لیکن اس کو تسلیم کرنا ضروری ہے لیکن جب آپ اس کی طرف توجہ کرنا چاہیں تو اس زیارت کے ساتھ حضرت کی طرف متوجہ ہوجائیں زیارت اس طرح کریں ۱۲ رکعت نماز دو دو رکعت کرکے پڑھے اور تمام رکعتوں میں <سورۂ اخلاص> پڑھے جب محمد و آل محمد پر درود بھیجے تو اس طرح سے خدا سے کلام کرے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": nu