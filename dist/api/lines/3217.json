[{"Id": 1014143, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "It is said that when you reach Samarrah you must perform the ghusl of Ziyarat and wear your most ritually purified dress and start with patience and respectful demenour till you reach the gate of the shrine and then seek permission…", "GujaratiDescription": null, "RUrduDescription": "Samarrah pohonchne par ziyarat ke iraade se ghusl kare, paak o saaf libaas pehne aur waqaar ke saath ziyarat ke liye rawaana ho. Jab haram sharif ke darwaaze par pohonche to wahan khade ho kar andar daakhil hone ki ijaazat talab karte huwe is tarah se kahe…", "UrduDescription": "سید ابن طاؤسؒ نے فرمایا: زائرین جب سرمن رَاَیٰ (سامرہ)پہنچیں تو سب سے پہلے غسل کریں پاکیزہ لباس پہنیں اور پھر وقار کے ساتھ زیارت کے لئے روانہ ہوں جب حرم مبارک کے دروازے پر پہنچیں تو وہاں کھڑے ہو کر اندر داخل ہونے کی اجازت طلب کرتے ہو ئے یہ پڑھیں۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014144, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "May I enter, O Prophet of Allah? May I enter, O Commander of the Faithful? May I enter, O Fatima the luminous and the leader of the women of the world? May I enter, O my master Hasan the son of Ali? May I enter, O my master Husain the son of Ali? May I enter, O my master Ali the son of Husain? May I enter, O my master Muhammad the son of Ali? May I enter.", "Gujarati": null, "RGujarati": null, "RUrdu": "Kya mai andar aa jaawu ay Khuda ke Nabi (s.a.w.a)? Kya mai andar aa jaawu ay Ameerul Momeneen (a.s)? Kya mai andar aa jaawu ay Sayyada Fatema Zahra (s.a) ay tamaam jahano ki aurto’n ki sardaar? Kya mai andar aa jaawu ay mere aaqa Hasan ibne Ali (a.s)? Kya mai andar aa jaawu ay mere aaqa Husain ibne Ali (a.s)? Kya mai andar aa jaawu ay mere aaqa Ali bin Husain (a.s)? Kya mai andar aa jaawu ay mere aaqa Muhammad ibne Ali (a.s)?", "Urdu": "کیا میں اندر آجاؤں اے خدا کے نبیؐ؟ کیا میں اندر آجاؤں اے مومنوں کے امیرؑ ؟کیا میں اندر آجاؤں اے سیدہ فاطمہ زہرا ؑاے تمام جہانوں کی عورتوں کی سردار؟ کیا میں اندر آجاؤں اے میرے آقا حسنؑ ابن علی ؑ؟کیا میں اندر آجاؤں اے میرے آقا حسینؑ ابن علیؑ ؟کیا میں اندر آجاؤں اے میرے آقا علیؑ ابن الحسینؑ ؟کیا میں اندر آجاؤں اے میرے آقا محمدؑ ابن علیؑ ؟", "RArabic": "A-ADKHOLO YAA NABIYYAL LAAHE? A-ADKHOLO YAA AMEERAL MOMENEENA? A-ADKHOLO YAA FAATEMATAZ ZAHRAAA-O SAYYEDATE NESAAA-IL A’ALAMEENA? A-ADKHOLO YAA MAWLAAYAL HASANABNA A’LIYYIN? A-ADKHOLO YAA MAWLAAYAL HUSAYNABNA A’LIYYIN? A-ADKHOLO YAA MAWLAAYA A’LIYYABNAL HUSAYNE? A-ADKHOLO YAA MAWLAAYA MOHAMMADABNA A’LIYYIN? A-ADKHOLO YAA MAWLAAYA JA’FARABNA MOHAMMADIN?", "ArabicText1": "ءَاَدْخُلُ یَا نَبِیَّ اللہِ؟ ءَاَدْخُلُ یَا اَمِیْرَ الْمُؤْمِنِیْنَ؟ ءَاَدْخُلُ یَا فَاطِمَۃَ الزَّهرَآءِ سَیِّدَۃَ نِسَآءِ الْعَالَمِیْنَ؟ ءَاَدْخُلُ یَا مَوْلَایَ الْحَسَنَ بْنَ عَلِیٍّ؟ ءَاَدْخُلُ یَا مَوْلَايَ الْحُسَیْنَ بْنَ عَلِیٍّ؟ ءَاَدْخُلُ یَا مَوْلَايَ عَلِیَّ بْنَ الْحُسَیْنِ؟ ءَاَدْخُلُ یَا مَوْلَايَ مُحَمَّدَ بْنَ عَلِیٍّ؟ ءَاَدْخُلُ یَآ مَوْلَايَ جَعْفَرَ بْنَ مُحَمَّدٍ؟", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014145, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my master Ja`far the son of Muhammad? May I enter, O my master Musa the son of Ja`far? May I enter, O my master Ali the son of Musa? May I enter, O my master Muhammad the son of Ali? May I enter, O my master Abul Hasan Ali the son of Muhammad? May I enter, O my master Aba Muhammad Hasan the son of Ali? May I enter, O angels of Allah whom are assigned to manage this holy sanctuary?", "Gujarati": null, "RGujarati": null, "RUrdu": "Kya mai andar aa jaawu ay mere aaqa Jafar ibne Muhammad (a.s)? Kya mai andar aa jaawu ay mere aaqa Moosa ibne Jafar (a.s)? Kya mai andar aa jaawu ay mere aaqa Ali ibne Moosa (a.s)? Kya mai andar aa jaawu ay mere aaqa Muhammad ibne Ali (a.s)? Kya mai andar aa jaawu ay mere aaqa ay Abul Hasan, Ali ibne Muhammad (a.s)? Kya mai andar aa jaawu ay mere aaqa Abu Muhammad, Hasan ibne Ali (a.s)? Kya mai andar aa jaawu ay Khuda ke farishto keh jo us harame sharif par muqarrar kiye gaye hai.", "Urdu": "کیا میں اندر آجاؤں اے میرے آقا جعفرؑ ابن محمدؑ ؟کیا میں اندر آجاؤں اے میرے آقاموسٰیؑ ابن جعفرؑ؟ کیا میں اندر آجاؤں اے میرے آقاعلیؑ ابن موسٰیؑ ؟کیا میں اندر آجاؤں اے میرے آقامحمدؑ ابن علیؑ ؟کیا میں اندر آجاؤں اے میرے آقااے ابولحسن علیؑ ابن محمد ؟کیا میں اندر آجاؤں اے میرے آقا ابو محمد حسنؑ ابن علیؑ ؟کیا میں اندر آجاؤں اے خدا کے فرشتو کہ جو اس حرم مبارک پر مقرر کیے گئے ہو ؟", "RArabic": "A-ADKHOLO YAA MAWLAAYA MOOSABNA JA’FARIN? A-ADKHOLO YAA MAWLAAYA A’LIYYABNA MOOSAA? A-ADKHOLO YAA MAWLAAYA MOHAMMADABNA A’LIYYIN? A-ADKHOLO YAA MAWLAAYA YAA ABAL HASANE A’LIYYINABNA MOHAMMADIN? A-ADKHOLO YAA MAWLAAYA ABAA MOHAMMADENIL HASANABNA A’LIYYIN? A-ADKHOLO YAA MALAAA-EKATAL LAAHIL MOWAKKALEENA BE-HAAZAL HARAMISH SHAREEFE.", "ArabicText1": "ءَاَدْخُلُ یَا مَوْلَایَ مُوْسَی بْنَ جَعْفَرٍ؟ ءَاَدْخُلُ یَا مَوْلَایَ عَلِیَّ بْنَ مُوْسٰی؟ ءَاَدْخُلُ یَا مَوْلَایَ مُحَمَّدَ بْنَ عَلِیٍّ؟ ءَاَدْخُلُ یَا مَوْلَایَ یَا اَبَا الْحَسَنِ عَلِیَّ بْنَ مُحَمَّدٍ؟ ءَاَدْخُلُ یَا مَوْلَایَ اَبَا مُحْمَّدِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": " نِ", "ArabicText2": "الْحَسَنَ بْنَ عَلِیٍّ؟ ءَاَدْخُلُ یَا مَلَآئِكَۃَ اللہِ الْمُوَكَّلِیْنَ بِهٰذَا الْحَرَمِ الشَّرِیْفِ۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "Arabic