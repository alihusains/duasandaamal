": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014285, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I, Your visiting servant am in the yard of Your visited vicegerent the obedience to whom has been made obligatory by You on the slaves and the free and through whom You shall save Your intimate servants from the chastisement of Hellfire. O Allah, (please) decide it to be an admitted visitation of a granted prayer from one who gives full credence to Your vicegerent and who never suspects him.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Tera yeh bandah Tere Wali (a.t.f.s) ke aastaan ki ziyarat kar raha hai us Imam ki ziyarat jis ki ita’at Tu ne har ghulaam o azaad par farz ki aur jin ke zariye Tere dost Jahannam ke azaab se chhotenge Ay Ma’bood! Isey meri maqbool ziyarat qaraar de jis mein dua qabool ho jaaye jo Tere Wali ki tasdeeq karne waale ne ki hai jis mein koi shak nahi.", "Urdu": "اے معبود!تیرا یہ بندہ تیرے ولیؑ کے آستانے کی زیارت کر رہا ہے اس امامؑ کی زیارت جس کی اطاعت تو نے ہر غلام و آزاد پرفرض کی اور جن کے ذریعے تیرے دوست عذاب ِجہنم سے چھوٹیں گے اے معبود!اسے میری مقبول زیارت قرار دے جس میں دعا قبول ہو جائے جو تیرے ولی کی تصدیق کرنے والے نے کی ہےجس میں کوئی شک نہیں۔", "RArabic": "ALLAAHUMMA A’BDOKAZ ZAA-ERO FEE FE-NAAA-E WALIYYEKAL MAZOORIL LAZEE FA-RAZTA TAA-A’TAHU A’LAL A’BEEDAL AHRAARE WA ANQAZTA BEHI AWLEYAAA-EKA MIN A’ZAABIN NAARE ALLAAHUMMAJ-A’LHAA ZEYAARATAN MAQBOOLATAN ZAATA DO-A’AA-IN MUSTAJAABIN MIN MOSADDEQIN BE-WALIYYEKA GHAYRE MURTAABIN.", "ArabicText1": "اَللّٰھُمَّ عَبْدُكَ الزَّائِرُ فِیْ فِنَآءِ وَلِیِّكَ الْمَزُوْرِ الَّذِیْ فَرَضْتَ طَاعَتَهٗ عَلَی الْعَبِیْدِ وَالْاَحْرَارِ وَاَنْقَذْتَ بِهٖ اَوْلِیَآئَكَ مِنْ عَذَابِ النَّارِ۔ اَللّٰھُمَّ اجْعَلْھَا زِیَارَۃً مَقْبُوْلَۃً ذَاتَ دُعَآءٍ مُسْتَجَابٍ مِّنْ مُّصَدِّقٍ بِوَلِیِّكَ غَیْرِ مُرْتَابٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014286, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please) do not decide this to be the last of my presence and visitation to him and do not cut off my traces in his shrine and in visitation to his father and grandfather. O Allah, (please) compensate for me my expenditure, make me benefit from the sustenance that You have provided me in my worldly life and in my Next Life, and do the same to my brothers, parents, and all of my offspring. I entrust you with Allah, O Leader through whom the believers will win and at whose hands the belying unbelievers will perish.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Isey meri aakhri haazri o ziyarat qaraar na de aur iski ziyarat-gah se mere qadam ke nishaan qata na kar keh mai ne unke baap daada ki ziyarat bhi ki hai, mai ne jo kharch kiya hai uska badla de duniya o aakherat mein, jo rozi di hai usey mufeed bana, mere liye mere bhaiyyo’n aur waaledain ke liye aur mere saare khaandaan ke liye. Mai ne aap ko Khuda ke supurd kiya ay woh Imam jis ke zariye momeneen kaamyaab honge aur jis ke haatho’n kaafir aur jhootla ne waale log halaak honge.", "Urdu": "اے معبود! اسے میری آخری حاضری و زیارت قرار نہ دے اور اس کی زیارت گاہ سے میرا نشانِ قدم قطع نہ کر کہ میں نے ان کے باپ دادا کی زیارت بھی کی ہے میں نے جو خرچ کیا ہے اس کا بدلہ دے دنیا وآخرت میں جو روزی دی ہے اسے مفید بنا میرے لئے میرے بھائیوں اور والدین کے لئے اور میرے سارے خاندان کے لئے میں نے آپ کو سپردِ خدا کیا اے وہ امامؑ جس کے ذریعے مومنین کامیاب ہوں گے اور جس کے ہاتھوں کافر اور جھٹلانے والے لوگ ہلاک ہوں گے۔", "RArabic": "ALLAAHUMMA LAA TAJ-A’LHO AAKHERAL A’HDE BEHI WA LAA BE-ZEYAARATEHI WA LAA TAQ-TA’ A-SAREE MIM-MASH-HADEHI WA ZEYAARATE ABEEHE WA JADDEHI ALLAAHUMMA AKH-LIF A’LAYYA NA-FA-QATEE WAN-FA-A’NEE BEMAA RA-ZAQANEE FEE DUNYAAYA WA AAKHERATEE LEE WA LE-AKH-WAANEE WA ABAWAYYA WA JA-MEE-E’ I’TRATEE AS-TAW-DE-O’KAL LAAHA AYYOHAL EMAAMUL LAZEE YAFOOZO BEHIL MO-MENOONA WA YAH-LEKO A’LAA YADAYHIL KAAFEROONAL MOKAZZEBOONA.", "ArabicText1": "اَللّٰهُمَّ لَا تَجْعَلْهُ اٰخِرَ الْعَهْدِ بِهٖ وَلَا بِزِیَارَتِهٖ وَلَا تَقْطَعْ اَثَرِیْ مِنْ مَّشْهَدِهٖ وَزِیَارَۃِ اَبِیْهِ وَجَدِّهٖ۔ اَللّٰهُمَّ اَخْلِفْ عَلَیَّ نَفَقَتِیْ وَانْفَعْنِیْ بِمَا رَزَقْتَنِیْ فِیْ دُیْنَایَ وَاٰخِرَتِیْ لِیْ وَلِاِخْوَانِیْ وَاَبَوَیَّ وَجَمِیْعِ عِتْرَتِیْ اَسْتَوْدِعُكَ اللہُ اَیُّھَا الْاِمَامُ الَّذِیْ یَفُوْزُ بِهِ الْمُؤْمِنُوْنَ وَیَهْلِكُ عَلٰی یَدَیْهِ الْكَافِرُوْنَ الْمُكَذِّبُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014287, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my Master! O son of Hasan the son of Ali, I have come to you visiting you, your father, and your grandfather, being certain of winning through you, and having full faith in your Imamate. O Allah, (please) write down this testimony and visitation to me with You in the Most Elevated Place, make me attain that which is attained by the righteous ones, and make me benefit by my love for them, O Lord of the Worlds.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay mere Maula! Ay Hasan Askari bin Ali Naqi (a.s) ke farzand haazir huwa hu aap ki ziyarat karne aur aap ke baap daada ki ziyarat karne, mujhe yaqeen hai keh aap ke zariye kaamyaab ho jaawunga, mera imaan hai keh aap Imam hai. Ay Ma’bood! Mere naam par yeh gawahi likh le aur yeh ziyarat apne yahan illiyyin mein mujhe saalehin ke maqaam o manzil par pohoncha aur un se mohabbat ka ajr de ay jahano ke Parwardigaar.", "Urdu": "اے میرے مولا اے حسن عسکریؑ ابن علی نقیؑ کے فرزند حاضر ہوا ہوں آپ کی زیارت کرنے اورآپ کے باپ دادا کی زیارت کرنے مجھے یقین ہے کہ آپ کے ذریعے کامیاب ہو جاؤں گا میرا ایمان ہے کہ آپ امام ہیں اے معبود! میرے نام پر یہ گواہی لکھ لے اور یہ زیارت (بھی)اپنے ہاں علیین میں، مجھے صالحین کے مقام و منزل پر پہنچا اور ان سے محبت کا اجر دے اے جہانوں کے پروردگار۔", "RArabic": "YAA MAWLAAYA YABNAL HASAN IBNE A’LIYYIN JEA-TOKA ZAAA-ERAL LAKA WA-LE-ABEEKA WA JADDEKA MOTAYAQQENA NIL-FAWZA BEKUM MO’TAQEDAN EMAAMATAKUM ALLAAHUMMAK- TUB HAA-ZEHISH SHA-HAADATE WAZ-ZEYAARATA LEE I’NDAKA FEE I’LLIYYEENA WA BALLIGH-NEE BALAAGHAS SAALEHEENA WAN FA-A’NEE BE-HUBBEHIM YAA RABBAL A’ALAMEENA.", "ArabicText1": "یَا مَوْلَایَ یَابْنَ الْحَسَنِ بْنِ عَلِیٍّ جِئْتُكَ زَآئِرًا لَّكَ وَلِاَبِیْكَ وَجَدِّكَ مُتَیَقِّنًا", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": " نِ", "ArabicText2": "الْفَوْزَ بِكُمْ مُعْتَقِدًا اِمَامَتَكُمْ۔ اَللّٰھُمَّ اكْتُبْ هٰذِهِ الشَّھَادَۃَ وَالزِّیَارَۃَ لِیْ عِنْدَكَ فِیْ عِلِیِّیْنَ وَبَلِّغْنِیْ بَلَاغَ الصَّالِحِیْنَ وَانْفَعْنِیْ بِحُبِّهِمْ یَا رَبَّ الْعَالَمِیْنَ۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "Ara