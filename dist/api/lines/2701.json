[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002478, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! For the sake of this holy night and he that was born it, You proof that and the appointed one, that You unite its virtue and perfected Your that is truth and Just, there is no change in Your words and there is no reviewer of Your signs, Your light is shining and Your brightness that is luminous and the banner of light in the cloud of gloominess, the concealed one that is absent.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Mabood! Tujhe waasta hai hamari is raat ka aur is raat ke maulood (birth of Imam'e Zamaana a.t.f.s) ka aur Teri hujjat aur uske mauwood ka (jiska Tu ne waada kiya hai) jisko Tu ne fazilat par fazilat ataa ki aur (jiske zariye) Tera kalema (kalaam) sidq o adl (sachchaayi aur insaaf) ke lehaaz se pura ho gaya. Tere kalemaat ko badal ne waala koi nahi aur na koi Teri aayato’n (nishaaniyo’n) ka muqaabela karne waala hai.", "Urdu": "اے معبود! واسطہ ہماری اس رات کا اور اس کے مولود کا اور تیری حجت ؑاور اس کے موعود ؑکا جس کو تو نے فضیلت پر فضیلت عطا کی اور تیرا کلمۂ صدق و عدل کے لحاظ سے پورا ہوگیا تیرے کلموں کو بدلنے والا کوئی نہیں اورنہ کوئی تیری آیتوں کا مقابلہ کرنے والا ہے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ بِحَقِّ لَيْلَتِنَا هٰذِهٖ وَمَوْلُوْدِهَا وَحُجَّتِكَ وَمَوْعُوْدِهَا، اَلَّتِيْ قَرَنْتَ اِلٰى فَضْلِهَا فَضْلًا، فَتَمَّتْ كَلِمَتُكَ صِدْقًا وَعَدْلًا، لَا مُبَدِّلَ لِكَلِمَاتِكَ، وَلَا مُعَقِّبَ لَآيَاتِكَ، نُوْرُكَ الْمُتَاَلِّقُ، وَضِيَاؤُكَ الْمُشْرِقُ، وَالْعَلَمُ النُّوْرُ فِيْ طَخْيَآءِ الدَّيْجُوْرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002479, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "His birth is majesty, his lineage is precious and the Angels are his witness, and Allah is his helper and supporter when the promised time comes, the Angels are his supporter, Allah’s sword that doesn’t turn away, His light that doesn’t hide, who possess forbearance that doesn’t come to an end.", "Gujarati": null, "RGujarati": null, "RUrdu": "Woh Mahdiye Mauwood (a.t.f.s) Tera noore taaba (chamakta huwa noor) aur jhilmilati (twinkling) roshni hai, woh noor ka sutoon, shaan waali siyaah (kaali) raat ki taariki (andhero’n) mein pinha wa poshida hai. Uski wilaadat buland martaba rakhti hai, uski asl wa haqeeqat par farishte’n uske gawah hai aur Allah uska madad-gaar wa haami hai, Jab uske waade ka waqt aayega aur farishte’n uske moaawin (madad-gaar) hai. Woh Khuda ki talwaar hai jo kabhi kund (sharpless) nahi hoti, aur uska aisa noor hai jo dheema nahi padta. Woh aisa burdbaar hai jo hadde tajaawuz (limit cross) nahi karta. Woh har zamaane ka sahara hai.", "Urdu": "وہ (مہدی موعودؑ) تیرا نورِ تاباں اور جھلملاتی روشنی ہے وہ نور کا ستون، شان والی سیاہ رات کی تاریکی میں مخفی و پوشیدہ ہے اس کی ولادت بلند مرتبہ ہے اس کی اصل، فرشتے ا س کے گواہ ہیں اور اللہ ا س کا مددگار و حامی ہے جب اس کے وعدے کا وقت آئے گااور فرشتے اس کے معاون ومددگار ہیں وہ خدا کی تلوار ہے جو کند نہیں ہوتی اور اس کا ایسا نور ہے جو ماند نہیں پڑتا وہ ایسا بردبار ہے جو حد سے نہیں نکلتا وہ ہر زمانے کا سہارا ہے۔", "RArabic": null, "ArabicText1": "اَلْغَائِبُ الْمَسْتُوْرُ جَلَّ مَوْلِدُهٗ، وَكَرُمَ مَحْتِدُهٗ، وَالْمَلَائِكَةُ شُهَّدُهٗ، وَاللّهُ نَاصِرُهٗ وَمُؤَيِّدُهٗ، اِذَا آنَ مِيْعَادُهٗ وَالْمَلَائِكَةُ اَمْدَادُهٗ، سَيْفُ اللّهِ الَّذِيْ لَا يَنْبُوْ، وَنُوْرُهُ الَّذِيْ لَا يَخْبُوْ، وَذُو الْحِلْمِ الَّذِيْ لَا يَصْبُوْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002480, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "The pivot of the time and the secrets of the time, the leader of the affair, whom the Qur’an has been revealed to, and what have been revealed in the Night of Power, the companion of resurrection, the translator of His revelation and the leader of His command and His prohibition.", "Gujarati": null, "RGujarati": null, "RUrdu": "Yeh Masoomeen (a.s) har ahed (daur) ki izzat aur waaliyaane Amr (saahebaane Amr) hai. Jo kuchh shabe qadr mein naazil kiya jaata hai pehle unhi par naazil hota hai. Wahi hashr o nashar mein saath dene waale hai. Uski wahi (revelation) ke tarjumaan aur Uske amr o nehi ke nighraan hai. Ay Ma’bood! Pas unke Khaatim aur unke Qaaem (a.t.f.s) par rehmat naazil farma jo is qayenaat se poshida hai.", "Urdu": "یہ معصومینؑ ہر عہد کی عزّت اور والیانِ امر ہیں جو کچھ شبِ قدر میں نازل کیا جاتا ہے انہی پر نازل ہوتا ہے وہی حشر و نشر میں ساتھ دینے والے اس کی وحی کے ترجمان اور اس کے امر و نہی کے نگران ہیں اے معبود! پس ان کے خاتم اور ان کے قائم پر رحمت فرما جو اس کائنات سے پوشیدہ ہیں۔", "RArabic": null, "ArabicText1": "مَدَارُ الدَّهْرِ، وَنَوَامِيْسُ الْعَصْرِ، وَوُلَاةُ الْاَمْرِ، وَالْمُنَزَّلُ عَلَيْهِمْ مَا يَتَنَزَّلُ فِيْ لَيْلَةِ الْقَدْرِ، وَاَصْحَابُ الْحَشْرِ وَالنَّشْرِ، تَرَاجِمَةُ وَحْيِهٖ، وَوُلَاةُ اَمْرِهٖ وَنَهْيِهٖ۔ اَللّٰهُمَّ فَصَلِّ عَلٰى خَاتِمِهِمْ وَقَائِمِهِمُ الْمَسْتُوْرِ عَنْ عَوَالِمِهِمْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002481, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Bless their seal and he who stand among them who was hidden from their world, let us witness his days, his reappearance and his risen, and make us among his helper and let our revolution near his own, write our status among his helper and trustee, and grant us life in his smooth government, and let us achieve his companionship and steadfast in his right, and should be rescued from the entire evils. O the Most Merciful of the merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Hamein uska zamaana, uska zahoor aur qeyaam dekhna naseeb farma aur hamein uske madad-gaaro’n mein qaraar de, hamara aur uska inteqaam ek kar de aur hamein uske madad-gaaro’n aur mukhliso’n mein likh de, hamein uski hukumat mein zindagi ki neymat ataa kar, aur uski sohbat (accompany) se behr-yaab (sharaf ataa) farma. Uske haq (favour) mein qayaam karne waale, aur buraayi se mehfooz rehne ki taufiq de, ay sab se ziyadah rahem karne waale.", "Urdu": "اے معبود! ہمیں اس کا زمانہ اس کا ظہور اور قیام دیکھنا نصیب فرما اور ہمیں اس کے مددگاروں میں قرار دے ہمارا اور اس کا انتقام ایک کردے اور ہمیں اس کے مددگاروں اور مخلصوں میں لکھ دے ہمیں اس کی حکومت میں زندگی کی نعمت عطا کر اور اس کی ہم نشینی سے فیض یاب فرما اس کے حق میں قیام کرنےوالے اور برائی سے محفوظ رہنے کی توفیق دے اے سب سے زیادہ رحم کرنے والے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ وَاَدْرِكْ بِنَا اَيَّامَهٗ وَظُهُوْرَهٗ وَقِيَامَهٗ، وَاجْعَلْنَا مِنْ اَنْصَارِهٖ، وَاقْرِنْ ثاْرَنَا بِثَاْرِهٖ، وَاكْتُبْنَا فِيْ اَعْوَانِهٖ وَخُلَصَائِهٖ، وَاَحْيِنَا فِيْ دَوْلَتِهٖ نَاعِمِيْنَ، وَبِصُحْبَتِهٖ غَانِمِيْنَ، وَبِحَقِّهٖ قَائِمِيْنَ، وَمِنَ السُّوْٓءِ سَالِمِيْنَ، يَااَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002482, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And praise be to God, the Lord of the worlds, blessing be on the seal of the Prophets and the Messengers and his royal household and his articulated progeny. Curse be on the whole oppressors and judge between us and them, O the best of the Judges.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur hamd o sana Allah hi ke liye hai jo saare jahano ka Parwardigaar hai aur uski rehmate’n ho hamare sardaar Muhammad (s.a.w.a) par jo nabiyyo’n aur rasoolo’n ke khaatam hai aur unke Ahlebait (a.s) par jo har haal mein sachh bolne waale hai aur unke Ahle khandaan par jo haq ke tarjumaan hai, aur laanat kar tamaam zulm karne waalo’n par, aur faisla kar hamare aur unke darmiyaan ay sabse badh kar behtareen faisla karne waale.", "Urdu": "اور حمد اللہ ہی کے لئے ہے جو جہانوں کا پروردگار ہے اور اس کی رحمتیں ہوں ہمارے سردار محمدؐ پر جو نبیوں اور رسولوں کے خاتم ہیں اور ان کے اہل پر جو ہر حال میں سچ بولنے والے ہیں اور ان کے اہل ِ خاندان پر جو حق کے ترجمان ہیں اور لعنت کرتمام ظلم کرنے والوں پر اور فیصلہ کر ہمارے اور ان کے درمیان اے سب سے بڑھ کر فیصلہ کرنے والے۔", "RArabic": null, "ArabicText1": "وَالْحَمْدُ لِلهِ رَبِّ الْعَالَمِينَ، وَصَلَوَاتُهٗ عَلٰى سَيِّدِنَا مُحَمَّدٍ خَاتَمِ النَّبِيِّيْنَ وَالْمُرْسَلِيْنَ وَعَلٰى اَهْلِ بَيْتِهِ الصَّادِقِيْنَ وَعِتْرَتِهِ النَّاطِقِيْنَ، وَالْعَنْ جَمِيْعَ الظَّالِمِيْنَ، وَاحْكُمْ بَيْنَنَا وَبَيْنَهُمْ يَااَحْكَمَ الْحَاكِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSig