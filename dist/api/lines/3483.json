[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015313, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah: This month of Ramadhan, in which You revealed the Qur’an, As guidance for people and clear proofs of true guidance and distinction (between the right and the wrong), Has commenced. O Allah: in this month, I seek Your protection against Satan, the accursed, And against his tricks and his ruses, And his deception and his trickeries, And his parties and his riding forces, And his on foot forces and his evil inspirations, And against straying off after being guided, And against atheism after belief, And against hypocrisy and showing off and felonies, And against the evil of the whisperings of the slinking Devil, Who whispers into the hearts of men; From among the jinn and the men.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "ALLAAHUMMA INNA HAAZAA SHARO RAMAZAANA AL-LAZEE AN-ZALTA FEEHIL QURAANA, HODAN LIN-NAASE WA BAIYYE-NAATIN MENAL HODAA WAL FUR-QAANE QAD HAZARA YAA RABBE A-O’OZO BEKA FEEHE ME-NASH SHAIY-TAANIR RAJEE-ME, WA MIN MAKRE-HI WA HE-YALE-HI, WA KHEDAA-E’HI WA JABAAA-E-LEHI, WA JONOO-DEHI WA KHAILE-HI, WA RIJLE-HI WA WASE-WESE-HI, WA MINAZ ZALAALE BA’DAL HODAA, WA MINAL KUFRE BA’DAL IMAANE, WA MINAN NEFAA-QE WAR REYAAA-E WAL JENAA-YAATE, WA MIN SHARRIL WASWAA-SIL KHANNAA-SIL LAZEE YO-WAS-WESO FEE SODOO-RIN NAASE, MINAL JINNATE WAN-NAASE.", "ArabicText1": "اَللّٰهُمَّ اِنَّ هٰذَا شَهْرُ رَمَضَانَ اَلَّذِيْ اَنْزَلْتَ فِيْهِ الْقُرْآنَ، هُدًى لِلنَّاسِ وَبَيِّنَاتٍ مِّنَ الْهُدٰى وَالْفُرْقَانِ قَدْ حَضَرَ يَا رَبِّ اَعُوْذُ بِكَ فِيْهِ مِنَ الشَّيْطَانِ الرَّجِيْمِ، وَمِنْ مَكْرِهٖ وَحِيَلِهٖ، وَخِدَاعِهٖ وَحَبَاۗئِلِهٖ، وَجُنُوْدِهٖ وَخَيْلِهٖ، وَرِجْلِهٖ وَوَسِاوِسِهٖ، وَمِنَ الضَّلَالِ بَعْدَ الْهُدٰى، وَمِنَ الْكُفْرِ بَعْدَ الْاِيْمَانِ، وَمِنَ النِّفَاقِ وَالرِّيَاۗءِ وَالْجِنَايَاتِ، وَمِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ، الَّذِيْ يُوَسْوِسُ فِيْ صُدُوْرِ النَّاسِ، مِنَ الْجِنَّةِ وَالنَّاسِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015314, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah: and confer upon me with the fasting and the doing of acts of worship during this month, And with the doing of acts of obedience to You, And to Your Messenger and the Men in authority, may peace be upon him and them, And the doing of whatever act that takes me near You, And (please) take me away from acts of disobedience to You. And confer upon me in this month with repentance, turning to You, and responding to Your instructions. And protect me in it against backbiting and lethargy and failure. And respond my prayers in it. And grant me well-being for my body and my intellect. And grant me time to do acts of obedience to You as well as acts that take me near You. O the All-generous; O the All-magnanimous. O the All-generous: (please) send blessings upon Muhammad (s.a.w.a) and the Household of Muhammad (a.s), And do all that to us, O the most Merciful of all those who show mercy.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": "ALLAAHUMMA WAR ZUQNEE SEYAAMA-HU, WA QEYAAMA-HU, WAL A’MALA FEEHE BE-TAA-A’TE-KA, WA TAA-A’TE RASOOLE-KA WA OOLAA AL-AMRE, A’LAIY-HE WA A’LAIY-HEMUS SALAAMO, WA MAA QARRABA MINKA, WA JANNIB-NEE MA-A’A-SEEKA, WAR ZUQNEE FEE-HIT TAWBATA WAL INAA-BATA WAL IJAA-BATA WA A-I’Z-NEE FEEHE MINAL GHAIY-BATE WAL KASALE WAL FA-SHALE, WAS-TAJIB LEE FEE-HID DO-A’AA-A, WA ASEH-HA LEE FEEHE JISMEE WA A’Q-LEE WA FARRIGH-NEE FEEHE LE-TAA-A’TEKA WA MAA QARRABA MINKA, YAA KAREEMO YAA JAWAADO, YAA KAREEMO, SALLE A’LAA MOHAMMADIW WA A’LAA AHLE-BAIYTE MOHAMMDIN A’LAIY-HE WA A’LAIY-HEMUS SALAAMO, WA KAZAALE-KA FAF-A’L BENAA YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "اَللّٰهُمَّ وَارْزُقْنِيْ صِيَامَهٗ وَقِيَامَهٗ، وَالْعَمَلَ فِيْهِ بِطَاعَتِكَ، وَطَاعَةِ رَسُوْلِكَ وَاُوْلٰي اَلْاَمْرِ، عَلَيْهِ وَعَلَيْهِمُ السَّلَامُ، وَمَا قَرَّبَ مِنْكَ، وَجَنِّبْنِيْ مَعَاصِيْكَ، وَارْزُقْنِيْ فِيْهِ التَّوْبَةَ وَالْاِنَابَةَ وَالْاِجَابَةَ وَاَعِذْنِيْ فِيْهِ مِنَ الْغَيْبَةِ وَالْكَسَلِ وَالْفَشَلِ، وَاسْتَجِبْ لِيْ فِيْهِ الدُّعَاۗءَ، وَاَصِحَّ لِيْ فِيْهِ جِسْمِيْ وَعَقْلِيْ وَفَرِّغْنِيْ فِيْهِ لِطَاعَتِكَ وَمَا قَرَّبَ مِنْكَ، يَا كَرِيْمُ يَا جَوَادُ، يَا كَرِيْمُ، صَلِّ عَلٰى مُحَمَّدٍ وَّعَلٰى اَهْلِ بَيْتِ مُحَمَّدٍ عَلَيْهِ وَعَلَيْهِمُ السَّلَامُ، وَكَذَالِكَ فَافْعَلْ بِنَا يَا اَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6"