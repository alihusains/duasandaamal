[{"Id": 1013833, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Shaykh Kulaini has narrated from Imam Ali Naqi (a) that he (a) said: Recite the following at the grave of Imam Husain (a). Come near the door of the dome from the side of the Imam (a)’s head and stand before the Imam while your back is towards Qibla and recite…", "GujaratiDescription": null, "RUrduDescription": "Shaikh Kulaini, Imam Ali Naqi (a) se riwaayat karte hai keh, Qabr Imam Husain (a) ke sar (head) ki jaanib se daakhil ho aur is tarah khade ho keh tumhara pusht qible ki jaanib ho aur phir kahe…", "UrduDescription": "شیخ کلینیؒ نے امام علی نقی ؑ سے روایت کی ہے کہ آپ نے فرمایا: امام حسینؑ کی قبرِ مبارک کے پاس یہ زیارت پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013834, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be on you, O Abu Abdullah. Peace be on you, O the proof of Allah in his earth and His witness upon His creation. Peace be on you, O the son of the Apostle of Allah. Peace be on you, O the son of Ali Al-Murtaza. Peace be on you, O the son of Fatema Zahra. I bear witness that you established the prayer and gave the poor-due and enjoined the good and forbade the evil and strove in the way of Allah till death overtook you. Then may Allah bless you in life and in death.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Abu Abdillah. Aap par salaam ho ay Khuda ki zameen par Uski hujjat aur Uski makhlooq par uske gawah. Aap par salaam ho ay Rasool'e Khuda (s.a.w.a) ke farzand. Aap par salaam ho ay Ali'e Murtaza (a.s) ke farzand. Aap par salaam ho ay Fatema Zahra (s.a) ke farzand. Mai gawahi deta hu keh aap ne namaz qaaem ki, zakaat di, nek kaamo ka hukm diya aur burey kaamo se roka aur aap Khuda ki raah mein masroofe jehaad rahe yahan tak keh aap shaheed ho gaye. Pas aap par Khuda rehmat kare dauraane zindagi aur maut ke baad.", "Urdu": "آپ پر سلام ہو اے ابو عبد اللہؑ! آپ پر سلام ہو اے خدا کی زمین پر اس کی حجت اور اس کی مخلوق پراس کے گواہ، آپ پر سلام ہو اے رسولؐ خدا کے فرزند، آپ پر سلام ہواے علی مرتضیٰؑ کے فرزند آپ پرسلام ہو اے فاطمہؑ زہرا کے فرزند میں گواہی دیتا ہوں کہ آپ نے نماز قائم کی زکوٰۃ دی نیک کاموں کاحکم دیا اور برے کاموں سے روکا اور آپ خدا کی راہ میں مصروف ِجہادرہے یہاں تک کہ آپ شہید ہو گئے پس آپ پر خدارحمت کرے دورانِ زندگی اور بعدِ موت بھی۔", "RArabic": "AS-SALAAMO A’LAIKA YAA ABA A’BDIL LAAHE AS-SALAAMO A’LAIKA YAA HUJJATAL LAAHE FEE ARZEHI WA SHAA-HEDAHU A’LAA KHALQEHI AS-SALAAMO A’LAIKA YABNA RASOOLIL LAAHE AS-SALAAMO A’LAIKA YABNA A’LIYYENIL MURTAZAA AS-SALAAMO A’LAIKA YABNA FAATEMATAZ ZAHRAAA-E ASH-HADO ANNAKA QAD AQAMTAS SALAATA WA AATAYTAZ ZAKAATA WA AMARTA BIL MA’ROOFE WA NAHAYTA A’NIL MUNKARE WA JAAHADTA FEE SABEELIL LAAHE HATTAA ATAAKAL YAQEENO FA-SALLAL LAAHO A’LAIKA HAYYAN WA MAYYETAN.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَآ اَبَا عَبْدِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَا حُجَّۃَ اللہِ فِیْٓ اَرْضِهٖ وَشَاهِدَهٗ عَلٰی خَلْقِهٖ۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ عَلِیٍّ الْمُرْتَضٰی۔ اَلسَّلَامُ عَلَیْكَ یَابْنَ فَاطِمَۃَ الزَّهْرَآءِ۔ اَشْهَدُ اَنَّكَ قَدْ اَقَمْتَ الصَّلٰوۃَ وَاٰتَیْتَ الزَّكٰوۃَ وَاَمَرْتَ بِالْمَعْرُوْفِ وَنَهَیْتَ عَنِ الْمُنْكَرِ وَجَاهَدْتَ فِیْ سَبِیْلِ اللہِ حَتّٰی اَتٰیكَ الْیَقِیْنُ فَصَلَّی اللہُ عَلَیْكَ حَیًّا وَمَیِّتًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "Arabi