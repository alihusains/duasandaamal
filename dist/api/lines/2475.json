[{"Id": 1020080, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Late Kafami (r), Allamah Majlisi (r) and others have recommended the following salawat and said: It has been narrated by infallible Imams (a) that when you enter into the holy shrine of Imam Reza (a) say…", "GujaratiDescription": null, "RUrduDescription": "Marhoom Kafami, Allamah Majlisi aur digar ulema ne is salawaat ki taakeed karte huwe farmaya: Yeh Aimma’e Masoomeen (a) se riwaayat hai keh jab tum Imam Reza (a) ke haram mein daakhil ho to is tarah se kaho…", "UrduDescription": "مرحوم کفعمی، علامہ مجلسی اور دگر علما نے اس صلوات کی تاکید کرتے ہوئے فرمایا: یہ ائمہ معصومینؑ سے روایت ہے کہ جب تم امام رضاؑ کے حرم میں داخل ہو تو اس طرح سے کہو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12"