[{"Id": 1013263, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "In Mustadrak al-Wasa’il, the following narration has been quoted from the book of al-Mazar al-Qadim on the authority of our master, Imam Muhammad Baqir (a): Accompanying my father, I went for visiting the tomb of my grandfather, Ali ibn Abi Talib (a), in Najaf. My father stopped at the holy tomb, wept, and said the following…", "GujaratiDescription": null, "RUrduDescription": "Mustadrak al-Wasa’il mein Mazar al-Qadim se naql kiya gaya hai ke hamare Maula Imam Muhammad Baqir (a) se marwi hai keh farmaaya: “Mai apne waalide buzurg-waar ke saath apne daada Ameerul Momeneen (a) ki ziyarat’e qabr ke liye Najaf Ashraf gaya, wahan mere waalid qabr ke nazdik khade ho kar roye aur yu kaha…", "UrduDescription": "مستدرک میں مزارِ قدیم سے نقل کیا گیا ہے کہ ہمارے مولا امام محمد باقر ؑ سے مروی ہے کہ فرمایا: میں اپنے والد بزرگوارکے ساتھ اپنے دادا امیرالمومنینؑ کی زیارتِ قبرمطہر کے لئے نجف اشرف گیا وہاں میرے والد قبر کے نزدیک کھڑے ہو کر روئے اور یوں گویا ہوئے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013264, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon the father of the Imams, the friend of the Prophethood, and the one exclusively granted the fraternity (of the Holy Prophet). Peace be upon the chief of true faith, the Scale of the deeds and the sword of the Lord of Majesty. Peace be upon the most righteous of the believers, the inheritor of the knowledge of the Prophets, and the judge on the Judgment Day.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho Aimma (a.s) ke pidare buzurg-waar par, nabuwwat ke khaleel aur Hazrat Rasool (s.a.w.a) ke khaas beraadar par. Salaam ho Islaam o imaan ke sardaar, amaal ke meyaar o mizaan aur saahebe jalaal Khuda ki talwaar par. Salaam ho sab se behtareen momin par jo nabiyyo’n ke uloom ke waaris aur roze jaza mein hukm karne waale hai.", "Urdu": "سلام ہو ائمہؑ کے پدر بزرگوار پر نبوت کے خلیل اور حضرت رسولؐ کے برادر خاص پر سلام ہو اسلام و ایمان کے سردار اعمال کے معیار و میزان اور صاحب ِجلال خدا کی تلوار پر سلام ہو سب سے بہترین مومن پر جو نبیوں کے علوم کے وارث اور روزِ جزا میں حکم کرنے والے ہیں۔", "RArabic": "AS-SALAAMO A’LAA ABIL AIMMA-TE WA KHALEE-LIN NABUWWATE WAL MAKH-SOOSE BIL-O-KHUW-WATE. AS-SALAAMO A’LAA YA’SOO-BIL IMAANE WA MEEZAA-NIL A’MAALE WA SAIFE ZIL-JALAA-LE. AS-SALAAMO A’LAA SAALE-HIL MO-MENEENA WA WAARE-SE IL’MIN NABIY-YIY-NAL HAAKEME FEE YAUW-MID-DEENE.", "ArabicText1": "اَلسَّلَامُ عَلٰى اَبِي الْاَئِمَّةِ وَخَلِيْلِ النُّبُوَّةِ وَالْمَخْصُوْصِ بِالْاُخُوَّةِ۔ اَلسَّلَامُ عَلٰى يَعْسُوْبِ الْاِيْمَانِ وَمِيْزَانِ الْاَعْمَالِ وَسَيْفِ ذِي الْجَلَالِ۔ اَلسَّلَامُ عَلٰى صَالِحِ الْمُؤْمِنِيْنَ وَ وَارِثِ عِلْمِ النَّبِيِّيْنَ الْحَاكِمِ فِيْ يَوْمِ الدِّيْنِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013265, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon the Tree of Piety. Peace be upon Allah’s conclusive argument, His flowing boon, and His forceful punishment. Peace be upon the clear-cut path, the patent star, and the advising leader. May Allah’s mercy and blessings be upon him.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho un par jo shajra’e taqwa hai. Salaam ho Khuda ki kaamil tareen hujjat par jo Uski neymat'e wasee aur Uski taraf se saza dene waale hai. Salaam ho un par jo Khuda ka waazeh raasta chamak-ta huwa sitaara aur naseehat karne waale Imam hai. Un par rehmat ho Khuda ki aur barkate’n ho.", "Urdu": "سلام ہو ان پر جو شجرِ تقویٰ ہیں سلام ہو خدا کی کامل ترین حجت پر جو اس کی نعمتِ وسیع اور اس کی طرف سے سزا دینے والے ہیں سلام ہو ان پر جو خدا کا واضح راستہ چمکتا ہوا ستارہ اور نصیحت کرنے والے امام ہیں ان پر رحمت ہو خدا کی اور برکتیں ہوں۔", "RArabic": "AS-SALAAMO A’LAA SHA-JARA-TIT TAQWAA. AS-SALAAMO A’LAA HUJJA-TILLAA-HIL BAALE-GHA-TE WA NE’MATE-HIS SAABE-GHA-TE WA NIQ-MATE-HID DAAME-GHA-TE. AS-SALAAMO A’LAS SERAA-TIL WAAZE-HE WAN-NAJMIL LAA'e HE WAL IMAAMIN NAASE-HE WA RAHMA-TUL-LAAHE WA BARA-KAATO-HU.", "ArabicText1": "اَلسَّلَامُ عَلٰى شَجَرَةِ التَّقْوٰى۔ اَلسَّلَامُ عَلٰى حُجَّةِ اللهِ الْبَالِغَةِ وَنِعْمَتِهِ السَّابِغَةِ وَنِقْمَتِهِ الدَّامِغَةِ۔ اَلسَّلَامُ عَلَى الصِّرَاطِ الْوَاضِحِ وَالنَّجْمِ اللَّائِحِ وَالْاِمَامِ النَّاصِحِ وَرَحْمَةُ اللهِ وَبَرَكَاتُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013266, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "My father (a) then added the following…", "GujaratiDescription": null, "RUrduDescription": "Phir mere waalid ne in jumlo’n ko bhi adaa kiya…", "UrduDescription": "اس کے بعد یہ فرمایا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1013267, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "You are verily my means and my course to Allah. And I enjoy the right of my loyalty to you and my hoping for you. So, (please) be my intercessor before Allah the Almighty and All-majestic as regards the settlement of my request, which is the release of my neck from Hellfire. And (please) seal my current situation with success and with response to all that which I have asked for, out of His mercy and power.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap Khuda ke huzoor mera wasila aur mera zariya hai aur mere liye dosti aur ummeed waari ka haq hai, pas Khuda az-wa-jal ke yahan mere sifaarish bane, meri haajat bar-aawri (puri karne) ke liye aur woh meri gardan ko aag se najaat dene ke liye hai, is jagah se mujhe kaamyaab kara ke lautaaye aur woh sab kuchh dilwaaye jo ba-waasta uski rehmat o qudrat ke maanga hai.", "Urdu": "آپ خدا کے حضور میرا وسیلہ اور میرا ذریعہ ہیں اور میرے لئے دوستی اور امید واری کا حق ہیں پس خداء عزوجل کے ہاں میرے سفارشی بنئے میری حاجت پوری کرنے کے لئے اور وہ میری گردن کی آگ سےنجات ہے اس جگہ سے مجھے کامیاب کرا کے لوٹائیے اور وہ سب کچھ دلوایئے جو اس کی رحمت و قدرت کے واسطے سےمانگا ہے۔", "RArabic": "AN-TAL WASEE-LATEE ILAL-LAAHE WA ZAREE-A’TEE WA LEE HAQQO MOWAA-LAATEE WA TAAMEE-LEE FA-QUN LEE SHAFEE-EE’ ILAL-LAAHE A’ZZA WA JALLA FIL WOQOO-FE A’LAA QAZAA-E HAAJA-TEE WA HEYA FA-KAAKO RAQABA-TEE MENAN-NAARE WASRIF-NEE FEE MAWQE-FEE HAAZAA BINNUJ-HE WA BE-MAA SA-ALTO-HU KULLA-HU (KULLE-HI) BE-RAHMATE-HI WA QUDRATE-HI.", "ArabicText1": "اَنْتَ وَسِيْلَتِيْ اِلَى اللهِ وَذَرِيْعَتِيْ وَلِيْ حَقُّ مُوَالَاتِيْ وَتَأْمِيْلِيْ فَكُنْ لِيْ شَفِيْعِيْ اِلَى اللهِ عَزَّ وَجَلَّ فِي الْوُقُوْفِ عَلٰى قَضَاءِ حَاجَتِيْ وَهِيَ فَكَاكُ رَقَبَتِيْ مِنَ النَّارِ وَاصْرِفْنِيْ فِيْ مَوْقِفِيْ هٰذَا بِالنُّجْحِ وَبِمَا سَاَلْتُهٗ كُلَّهٗ (كُلِّهٖ) بِرَحْمَتِهٖ وَقُدْرَتِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013268, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please do) grant me an utter intellect, sharp aptitude, pure heart, much deed, and fabulous courtesy, and make all that for my good and do not make it against me, (I beseech You) in the name of Your mercy, O most Merciful of all those who show mercy!", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mujhe ataa farma aql’e kaamil, behtareen dimaagh, paakeeza qalb, kasrat’e amal aur buland-tar akhlaaq aur yeh sab neymate’n mere liye mufeed qaraar de aur unko ba-waasta apni rehmat ke, ay sab se ziyadah rahem karne waale.", "Urdu": "اے معبود!مجھے عطا فرما عقلِ کامل بہترین دماغ پاکیزہ قلب کثرت ِعمل اور بلند تر اخلاق اور یہ سب نعمتیں میرے لئے مفید قرار دے اور ان کو اپنی رحمت کے واسطے سےاے سب سے زیادہ رحم کرنے والے۔", "RArabic": "ALLAAHUM-MAR ZUQNEE AQ’LAN KAAME-LAN WA LUBBAN RAAJE-HAN WA QALBAN ZAKIY-YAN WA A’MA-LAN KASEE-RAN WA ADA-BAN BAARE-AN WAJ-AL’ ZAALEKA KULLA-HU LEE WA LAA TAJ-A’L-HU A’LAIYYA BE-RAHMATE-KA YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "اَللّٰهُمَّ ارْزُقْنِيْ عَقْلًا كَامِلًا وَلُبًّا رَاجِحًا وَقَلْبًا زَكِيًّا وَعَمَلًا كَثِيْرًا وَاَدَبًا بَارِعًا وَاجْعَلْ ذٰلِكَ كُلَّهٗ لِيْ وَلَا تَجْعَلْهٗ عَلَيَّ بِرَحْمَتِكَ يَا اَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": nu