[{"Id": 1010974, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "On 13th and 14th Jamadi-ul-Awwal (11H), as per the narrations she lived 75 days after the death of her father and then got shahadat, so recite ziyarat of <Martyrdom J.Fatema (s)> and do maatam.", "GujaratiDescription": null, "RUrduDescription": "13th aur 14th Jamadi-ul-Awwal (11H) mein <Shahadat J.Fatema (s)> ki ziyarat padhe aur maatam kare, is liye keh riwaayato’n mein aaya hai keh aap apne waalid-e-giraami ke baad 75 din is dunya mein zindah rahi aur phir aap shahadat pa gayi.", "UrduDescription": "تیرھویں اور چودھویں جمادی الاول میں <زیارت فاطمہ زہراؑ> پڑھے اور مظلومہ بی بی کا ماتم کرے، اس لئے کہ روایتوں میں آیا ہے کہ آپ اپنے والد گرامی کے بعد پچھتر(۷۵) دن اس دنیا میں زندہ رہیں اور پھر آپ شہادت پا گئیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "