BINTE RASOO-LIL-LAAHIL AMEENE, AS-SALAAMO A’LAI-KE YAA BINTE SAYYADIL MUR-SA-LEENA, AS-SALAAMO A’LAI-KE YAA BINTAL AMEERIL MOMENEENA WA SAYYE-DIL WASEE-YIYEENA WA AMAA-MAL MUTTAQEENA WA YAA QAA-E-DAL GHURRIL MO-HAJJA-LEENA WAL-HAAKE-MA YAW-MADDEE-NE WAN NABAAA-IL A’ZEE-MIL LAZEE A’N-HO YUS-ALOO-NA WA A’LAIY-HE YOA’RA-ZOONA WA BE-SAKE-HI YAD KHOOLU-NA JANNAA-TIN NAEE’ME, AS-SALAAMO A’LAI-KE WA A’LAA UMMIL BANEE-NA SAAHE-BATE LAWAA-E KAR-BALAA-E, AS-SALAAMO A’LAI-KE AYYA-TOHAZ ZAKI-YA-TUT TAAHE-RATUR RAZI-YATUL TAQI-YATUN NAQI-YATUL WAFI-YATUL FAAZE-LATO WAR-ROKI-YATO.", "ArabicText1": "بِسْمِ اللهِ وَبِاللهِ وَعَلٰی مِلَّۃِ رَسُوْلِ اللهِ صَلَّی اللهُ عَلَیْهِ وَآلِهٖ، اَلسَّلَامُ عَلَیْكِ یَا بِنْتَ رَسُوْلِ اللهِ الْاَمِیْنِ، اَلسَّلَامُ عَلَیْكِ یَابِنْتَ سَیِّدَ الْمُرْسَلِیْنَ، اَلسَّلَامُ عَلَیْكِ یَابِنْتَ الْاَمِیْرِ الْمُؤْمِنِیْنَ وَسَیِّدِ الْوَصِیِّیْنَ وَاَمَامَ الْمُتَّقِیْنَ وَیَا قاۗئِدَ الْغُرِّ الْمُحَجَّلِیْنَ وَالْحَاکِمَ یَوْمَ الدِّیْنِ وَالنَّبَاۗئِ الْعَظِیْمِ الَّذِیْ عَنْہُ یُسْئَلُوْنَ وَعَلَیْہِ یُعْرَ ضُوْنَ وَبِصَکِہٖ یَدْ خُلُوْنَ جَنَّاتِ النَّعِیْمِ، اَلسَّلَامُ عَلَیْكِ وَعَلٰی اُمِّ الْبَنِیْنَ صَاحِبَۃِ لَوَآئِ كَرْبَلَائِ، اَلسَّلَامُ عَلَیْكِ اَیَّتُهَا الزَّكِیَّۃُ الطَّاهِرَۃُ الرَّضِیَّۃُ الْتَقِیَّۃُ النَّقِیَّۃُ الْوَفِیَّۃُ الْفَاضِلَۃُ وَالرُّقِیَّۃُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGre