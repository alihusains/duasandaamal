[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000151, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "(All) praise is for Allah (alone) who wrapped the night (with darkness), made sleep a medium of rest and repose, and the day a time to work and make efforts. (All) praise is for Thee (alone), [for Thou makes me come out of the deep sleep (motionless spell of inactivity) everyday, although if Thou wills it could be a rest for ever], everlasting praise, (that) never ever is cut off, nor anyone of the created beings can know, write or count up.", "Gujarati": null, "RGujarati": null, "RUrdu": "Tamaam taarife’n Allah ke liye hai jisne raat ko parda qaraar diya aur neend ko aaraam ka wasila, din ko chalne-phirne ka zariya qaraar diya. Khudaaya Tere liye hamd hai keh Tu ne mujhe meri khaab-gah (neend) se dobaara zinda uthaaya warna agar Tu chahta to is neend ko hamesha bar-qaraar rakhta (maut de-deta). (Khudaaya) Teri hamd o sana daayemi hai jo kabhi khatm nahi ho sakti aur Teri hamd o sana ko makhluq shumaar nahi kar sakti.", "Urdu": "خد اکے نا م سے شر وع کرتا ہوں جو بڑا مہربان اور نہا یت ہی رحم کر نے والا ہے حمد اس خد اکے لئے ہے جس نے رات کو پر دے اور نیند کو آرام کا ذریعہ بنا یا او ر دن کو کام کرنے کے لئے قرار دیا تیرے لئے حمد ہے کہ تو نے مجھے میری خواب گاہ سے زندہ اٹھایا اور اگر تو چاہتا تو اس نیند کو دائمی بنا دیتا۔ تیری ایسی حمد جو ہمیشہ رہے کبھی ختم نہ ہو کہ جس کی تعداد کو مخلوق شمار نہ کر سکے۔ ", "RArabic": "AL-HAMDO LILLAA-HIL LAZEE JA-A’LAL LAIYLA LEBAA-SAN WAN-NAWMA SOBAA-TAN WA JA-A’LAN NAHAARA NO-SHOO-RAN LAKAL HAMDO AN BA-A’S-TANEE MIN MAR-QADEE WA LAW-SHE-TA JA-A’L-TAHU SAR-MADAN HAMDAN DAA-E-MAN LAA YAN-QATE-O’ ABA-DAN WA LAA YOH-SEE LAHUL KHALAA-E-QO A’DA-DAN.", "ArabicText1": "اَلْحَمْدُ لِلہِ الَّذِیْ جَعَلَ اللَّیْلَ لِبَاسًا وَّالنَّوْمَ سُبَاتًا وَّجَعَلَ النَّھَارَ نُشُوْرًا لَّکَ الْحَمْدُ اَنْۢ بَعَثْتَنِیْ مِنْ مَرْقَدِیْ وَلَوْ شِئْتَ جَعَلْتَہٗ سَرْمَدًا حَمْدًا دَآئِمًا لَّا یَنْقَطِعُ اَبَدًا وَّلَا یُحْصِیْ لَہُ الْخَلَآئِقُ عَدَدًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001143, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my Allah, (All) praise is for Thee (alone) for Thou created, (everything) in order and equilibrium, well-measured, properly managed, effectively carried out, and determined the duration, gave life, cause (things) to decay, and recover, made available comforts, (mixed with) troubles and sorrows. Calm and unruffled Thou occupied the A’rsh (seat of Divine authority), the whole universe under Thy domain and jurisdiction.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya Teri hamd o sana is baat par hai keh Tu ne paiyda kiya, sahih o saalim banaya, qaza o qadr, maut o zindagi, bimaari aur shifa, aafiyat o bala sab Tere hi hukm ke maatahet (muti) hai aur Tu arsh par ghaalib huwa aur tamaam aalam ki baadshahat par haawi huwa, mai Tujh se dua karta hu us shakhs ke maanind jiska wasila kamzor hai jiski tatbeere munqata ho chuki hai aur uski muddat (maut) qareeb hai aur duniya mein uski aarzoo’e aahista-aahista kam ho gayi hai aur jisko Teri rehmat ki ehteyaaj (zarurat) ziyadah ho aur kotaahiyo’n ke sabab hasrate’n (khwaaish/desire) badhi huwi ho aur lagzisho’n aur qaul mein phislaawo’n (phisalna) ki ziyadati ho aur phir khuloos'e dil se Teri bargah mein tauba kare.", "Urdu": "اے معبود!تیرے ہی لئے حمد ہے کہ تو نے پیدا کیا تو درست پیدا کیا اور قضا و قدر بنائی تو موت دیتا اور زندگی بخشتا ہے بیمار کرتا ہے شفا دیتا ہے تو بچاتا ہے اور آزماتا ہے اور عرش پر تیری حکومت اور ملک تیرے قبضئہ قدرت میں ہے میں تجھے ایسے شخص کی طرح پکارتا ہوں جس کا وسیلہ کمزور ہو،چارۂ کار منقطع ہو گیا ہو، موت قریب آگئی ہو اور وہ دنیا کی آرزو میں گرفتار ہو اور تیری رحمت کا بہت زیادہ محتاج ہو،اس کی کوتاہیوں کے باعث اس کی حسرتیں بڑھ چکی ہوں اور اس کی لغزشیں اور ٹھوکریں بہت زیادہ ہوں اور تیرے حضور سچی توبہ کر رہا ہوں۔", "RArabic": "ALLAAHUMMA LAKAL HAMDO AN KHA-LAQTA FA-SAW-WAIY-TA WA QADDAR-TA WA QA-ZAIY-TA WA A-MATTA WA AH-YAIY-TA WA AM-RAZTA WA SHA-FAIY-TA WA AA’FEETA WA AB-LAIY-TA WA A’LAL A’R-SHIS TA-WAIY-TA WA A’LAL MUL-KIH TA-WAIY-TA.", "ArabicText1": "اَللّٰھُمَّ لَکَ الْحَمْدُ اَنْ خَلَقْتَ فَسَوَّیْتَ وَقَدَّرْتَ وَقَضَیْتَ وَاَمَتَّ وَاَحْیَیْتَ وَاَمْرَضْتَ وَشَفَیْتَ وَعَافَیْتَ وَاَبْلَیْتَ وَعَلَی الْعَرْشِ اسْتَوَیْتَ وَعَلَی الْمُلْکِ احْتَوَیْتَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001144, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I call Thee with a request like the one whose means and opportunities are frail and unsure, resources cut off, and the end in very near, expectations from the worldly life proved to be of little worth, (now) in need of Thy mercy cracks up, sigh of grief and regrets for immoderate conduct are heartbreaking, errors are very many, and also offences, but with sincerity has turned repentant to Thee. Therefore send blessing on Muhammad, the Last Prophet, on his pure and pious children, and make available for me recommendations of Muhammad, peace and blessings of Allah be on him and on his children, and do not deprive me of his company, verily Thou art the Most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Khudaaya) Hazrat Muhammad Mustafa (s.a.w.a) jo aakhri nabi hai aur unki tayyab o taahir Aal (a.s) par rehmat ka nuzool farma, aur mujhe Muhammad (s.a.w.a) aur unki Aal (a.s) ki shifa’at ataa farma, aur hamein unki ham-nasheeni se mehroom na kar be-shak Tuhi sabse ziyadah rahem karne waala hai.", "Urdu": " پس تو نبیوں کے خاتم محمدمصطفیٰؐ پر رحمت فرما اور ان کے پاک وپاکیزہ اہل بیتؑ پر بھی رحمت فرمااور مجھے محمدؐ وآل محمدؐ کی شفاعت وحمایت نصیب فرمااور مجھے ان کی قربت سے محروم نہ فرما۔ بے شک تو سب سے زیادہ رحم کرنے والا ہے۔", "RArabic": "AD-OO’KA DOAA’E MAN ZAO’FAT WASEE-LATO-HU WAN-QATA-A’T HEELA-TAHU WAQ-TARABA AJA-LOHU WA TADAA-NAA FID DUNYAA AMALA-HU WASH-TADDAT ILAA RAH-MATE-KA FAA-QATA-HU WA A’ZO-MAT LE-TAFREE-TEHI HAS-RATO-HU WA KASOO-RAT ZALLA-TOHU WA A’SRA-TAHU WA KHALO-SAT LE-WAJHE-KA TAWBA-TAHU FA-SALLE A’LAA MOHAMMADIN KHAA-TAMIN NABIY-YEENA WA A’LAA AHLE BAIYTE-HIT TAIYY-BEE-NAT TAAHE-REENA WAR-ZUQNEE SHAFAA-A’TA MOHAMMADIN SALLAL-LAAHO A’LAIY-HE WA AALE-HI WA LAA TAH-RIMNEE SOH-BATA-HU INNA-KA ANTA AR-HAMUR RAAHE-MEENA.", "ArabicText1": "اَدْعُوْکَ دُعَآئَ مَنْ ضَعُفَتْ وَسِیْلَتُہٗ وَانْقَطَعَتْ حِیْلَتُہٗ وَاقْتَرَبَ اَجَلُہٗ وَتَدَانٰی فِیْ الدُّنْیَا اَمَلُہٗ وَاشْتَدَّتْ اِلٰی رَحْمَتِکَ فَاقَتُہٗ وَعَظُمَتْ لِتَفْرِیْطِہٖ حَسْرَتُہٗ وَکَثُرَتْ زَلَّتُہٗ وَعَثْرَتُہٗ وَخَلُصَتْ لِوَجْھِکَ تَوْبَتُہٗ فَصَلِّ عَلٰی مُحَمَّدٍ خَاتَمِ النَّبِیِّیْنَ وَعَلٰی اَھْلِ بَیْتِہِ الطَّیِّبِیْنَ الطَّاھِرِیْنَ وَارْزُقْنِیْ شَفَاعَۃَ مُحَمَّدٍ صَلَّی اللہُ عَلَیْہِ وَآلِہٖ وَلَا تَحْرِمْنِیْ صُحْبَتَہٗ اِنَّکَ اَنْتَ اَرْحَمُ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "A