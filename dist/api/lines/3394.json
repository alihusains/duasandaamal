[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012911, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I turn my attention towards the One who has created the heavens and the earth as a true believer and a Muslim; and I am not among the polytheists, My prayer, hady, life and death are for Allah, the Sustainer of the worlds. He has no partner and so have I been ordered and I am of those who have submitted to You. O Allah all this is from and for You. I commence in the Name of Allah and Allah is great. O Allah! accept my devotions.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai ne apna rukh us Allah ki taraf kiya jis ne aasmaano aur zameen ko paiyda kiya, mai baatil se katraane waala musalmaan hu, mushrekeen mein se nahi hu. Yaqeenan meri namaz, meri ibaadat, meri zindagi aur meri maut sab kuchh Allah ke liye hai jo tamaam aalameen ka paalne waala hai, Uska koi shareek nahi hai, mujhe yahi hukm diya gaya hai aur mai musalmaano mein se hu. Khudaaya! Yeh hukm’e qurbaani aur yeh ita’at Tere liye hai. Bismillah wallaho Akbar, ay Allah Tu meri taraf se isey qabool kar.", "Urdu": null, "RArabic": "WAJ-JAHTO WAJHE-HI LIL-LAZEE FATA-RAS SAMAA-WAATE WAL ARZE HANEE-FAN MUSLE-MAN WA MAA ANAA MINAL MUSHRE-KEENA INNA SALAA-TEE WA NOSO-KEE WA MAH-YAAYA WA MAMAA-TEE LIL-LAAHE RABBIL AA’LAMEE-NA LAA SHAREE-KA LAHU WA BE-ZAALE-KA OMIR-TO WA ANAA MINAL MUSLEMEENA. ALLAAHUMMA MINKA WA LAKA BISMILLAA-HE WAL-LAAHO AKBARO ALLAAHUMMA TA-QABBAL MINNEE.", "ArabicText1": "وَجَّہْتُ وَجْہِیَ لِلَّذِیْ فَطَرَ السَّمٰوَاتِ وَالْاَرْضَ حَنِیْفًا مُسْلِمًا وَمَا اَنَا مِنَ الْمُشْرِكِیْنَ اِنَّ صَلَاتِیْ وَنُسُكِیْ وَمَحْیَایَ وَمَمَاتِیْ لِلہِ رَبِّ الْعَالَمِیْنَ لَا شَرِیْكَ لَہٗ وَبِذَالِكَ اُمِرْتُ وَاَنَا مِنَ الْمُسْلِمِیْنَ۔ اَللّٰہُمَّ مِنْكَ وَلَكَ بِسْمِ اللهِ وَاللهُ اَكْبَرُ اَللّٰہُمَّ تَقَبَّلْ مِنِّیْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, 