[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1001087, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah: (please do) include us with the righteous ones, out of Your mercy. And uplift us to the rank of illiyyin (most elevated rank). And serve us with water running out of spring of Salsabil. And, out of Your mercy, give us as wives the women of Paradise. And make the Paradisiacal youths who never alter in age and who are like hidden pearls serve us. And give us food from the fruits of Paradise and from the meat of birds there.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Apni rehmat se hamein nek logo’n mein daakhil farma, aur hamein buland maqaam waalo’n ke saath rakhna, salsabeel ke khush-gawaar jaam se seraab farma. Apni maher-baani se Huraane Jannat ko hamari biwiya’n (wives) bana, aur hamesha jawaan rehne waale ladke (Ghilmaan) jo goya chhupe moti ki tarah hai unhe hamari khidmat par laga. Jannat ke meweh (fruits) aur wahan ke parindo’n ka gosht hamein kheela.", "Urdu": "اے معبود! اپنی رحمت سے ہمیں نیکوکاروں میں داخل فرما جنت علیین میں ہمارے درجے بلند فرما ہمیں چشمۂ سلسبیل کے خوش گوار جام سے سیراب فرما اپنی مہربانی سے حوران ِجنت کو ہماری بیویاں بنا اور ہمیشہ جوان رہنے والےلڑکے جو گویا چھپے موتی ہیں انہیں ہماری خدمت پر لگا جنت کے میوے اور وہاں کے پرندوں کا گوشت ہمیں کھلا۔", "RArabic": "ALLAAHUMMA BE-RAHMATE-KA FIS SAALE-HEENA FA-AD-KHIL-NAA WA FEE ILLIYYIN FAR-FA’NAA WA BE-KA-ASIN MIM MA-E’E-NIN MIN A’IY-NIN SAL-SABEE-LIN FAS-QENAA WA MENAL HOORIL E’E-NE BE-RAHMATE-KA FA-ZAWWIJ-NAA WA MENAL WIL-DAANIL MO-KHALLA-DEENA KA-ANNA-HUM LOOLO-OON MAKNOO-NOON FA-AKH-DIM-NAA WA MIN SEMAA-RIL JANNA-TE WA LOHOO-MIT TAIY-RE FA-AT-I’M-NAA.", "ArabicText1": "اَللّٰہُمَّ بِرَحْمَتِکَ فِی الصَّالِحِیْنَ فَاَدْخِلْنَا وَفِیْ عِلِّیِّیْنَ فَارْفَعْنَا وَبِکَاَسٍ مِّنْ مَّعَیْنٍ مِّنْ عَیْنٍ سَلْسَبِیْلٍ فَاسْقِنَا وَمِنَ الْحُوْرِ الْعِیْنِ بِرَحْمَتِکَ فَزَوِّجْنَا وَمِنَ الْوِلْدَانِ الْمُخَلَّدِیْنَ کَاَنَّھُمْ لُؤْلُؤٌ مَّکْنُوْنٌ فَاَخْدِمْنَا وَمِنْ ثِمَارِالْجَنَّۃِ وَلُحُوْمِ الطَّیْرِ فَاَطْعِمْنَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011425, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And dress us from the clothes of fine and thick silk and rich brocade. And give us success to catch the Grand Night The pilgrimage to Your Holy House, And the martyrdom in Your way. And respond to our goodly prayer and invocation. And when You shall gather the past and the coming generations on the Resurrection Day, (please) have mercy upon us. And (please) release us from Hellfire. And do not fetter us in Hell.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur hamein reshmi aur chamkile kapdo’n ke bane huwe libaas pehna, hamein Shabe Qadr ataa kar, apne Baitullah (Kaabe) ke hajj ki taufiq de, aur apni raah mein shahadat naseeb farma, hamari nek dua’o aur achchi haajato’n ko pura farma aur jab Qayamat ke roz Tu aghle peechhlo’n ko ikhatta (gather) kare to ham par rahem farma. Hamare liye Jahannam se chhut kaara laazmi qaraar de, hamein us mein na daal.", "Urdu": "اور ہمیں سندس ریشم اور چمکیلے کپڑوں کے بنے ہوئے لباس پہنا ہمیں شب ِقدر عطا کر اپنے بیت اﷲ (کعبہ) کے حج کی توفیق دے اور اپنی راہ میں شہادت نصیب کر دے ہماری نیک دعاؤں اور اچھی حاجتوں کو پورا فرما دے اور جب قیامت کے روز تو اگلے پچھلوں کو اکٹھا کرے تو ہم پر رحم فرما ہمارے لئے جہنم سے خلاصی لاز می کردے ہمیں اس میں نہ ڈال۔", "RArabic": "WA MIN SEYAA-BIS SANDO-SE WAL HAREE-RE WAL ISTAB-RAQE FA-AL-BISNAA WA LAIY-LATAL QADRE WA HAJJA BAIY-TEKAL HARAA-ME WA QATA-LAN FEE SABEELE-KA FA-WAFFIQ LANAA WA SAALE-HAD DO-AA’E WAL MAS-ALA-TE FASTA-JIB LANAA WA IZAA-JAMA’TAL AWWA-LEENA WAL AAKHE-REENA YAW-MAL QIYAA-MATE FAR-HAMNAA WA BARAA-ATAN MENAN NAARE FAKTUB LANAA WA FEE JA-HANNA-MA.", "ArabicText1": "وَمِنْ ثِیَابِ السَّنْدُسِ وَالْحَرِیْرِ وَالْاِسْتَبْرَقِ فَاَلْبِسْنَا وَلَیْلَۃَ الْقَدْرِ وَحَجَّ بَیْتِکَ الْحَرَامِ وَقَتَلًا فِیْ سَبِیْلِکَ فَوَفِّقْ لَنَا وَصَالِحَ الدُّعَآئِ وَالْمَسْئَلَۃِ فَاسْتَجِبْ لَنَا وَاِذَاجَمَعْتَ الْاَوَّلِیْنَ وَالْاٰخِرِیْنَ یَوْمَ الْقِیَامَۃِ فَارْحَمْنَا وَبَرَآئَۃً مِّنَ النَّارِ فَاکْتُبْ لَنَا وَفِیْ جَھَنَّمَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011426, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "And do not try us through Your chastisement and humiliations. And do not feed us from zaqqum and thorns. And do not add us to the devils. And do not throw us down on our faces in Hellfire. And do not dress us from the clothes of fire and the shirts of pitch. And save us from all evils; O there is no god save You, I beseech You in the name of there is no god save You.", "Gujarati": null, "RGujarati": null, "RUrdu": "Hamein apne azaab aur zillat mein na fasa, aur hamein zaqqoom aur zehrili ghaas na kheela, aur hamein shaitaano ka ham-nasheen na bana. Aur Jahannam mein hamein chehro’n ke bal na latka, hamein aatishi (aag ke) kapde aur qatraan ke pairaahan na pehna. Aur ay woh keh nahi koi ma’bood magar Tu hi hai, Tere siwa koi ma’bood nahi, Khudaara hamein bacha le (aameen).", "Urdu": "ہمیں اپنے عذاب اور ذلت میں نہ پھنسا اور ہمیں تھوہر اور زہریلی گھاس نہ کھلا اور ہمیں شیطانوں کا ہم نشین نہ بنا اور جہنم میں ہمیں چہروں کے بل نہ لٹکا ہمیں آتشی کپڑےاور قطران کے پیراہن نہ پہنا اور اے وہ کہ نہیں کوئی معبود مگر تو ہی ہے نہیں کوئی معبود مگر تو ہے اس واسطے ہمیں برائیوں سے بچا۔", "RArabic": "FALAA TA-GHUL-LANAA WA FEE A’ZAA-BEKA WA HAWAA-E-KA FALAA TAB-TALENAA WA MENAZ ZAQOO-ME WAZ ZAREE-E FALAA TUT-I’M-NAA WA MA-A’SH SHAYAA-TEENE FALAA TAJ-A’L-NAA WA FIN NAARE A’LAA WAJOO-HENAA FALAA TAKBUB-NAA WA MIN SEYAA-BIN NAARE WA SARAA-BEE-LIL QATE-RAAANE FALAA TUL-BISNAA WA MIN KULLE SOO-IN YAA LAA ILAAHA ILLAA ANTA BE-HAQQE LAA ILAAHA ILLAA ANTA FA-NAJJE-NAA.", "ArabicText1": "فَلَاتَغُلَّنَا وَفِیْ عَذَابِکَ وَھَوَآئِکَ فَلَا تَبْتَلِنَا وَمِنَ الزَّقُوْمِ وَالضَّرِیْعِ فَلَا تُطْعِمْنَا وَمَعَ الشَّیَآطِیْنِ فَلَا تَجْعَلْنَا وَفِی النَّارِ عَلٰی وَجُوْھِنَا فَلَا تَکْبُبْنَا وَمِنْ ثِیَابِ النَّارِ وَسَرَابِیْلِ الْقَطِرَآنِ فَلَا تُلْبِسْنَا وَمِنْ کُلِّ سُوْٓئٍ یَالَا اِلٰہَ اِلَّا اَنْتَ بِحَقِّ لَا اِلٰہَ اِلَّا اَنْتَ فَنَجِّنَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null,