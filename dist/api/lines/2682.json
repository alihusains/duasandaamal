[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002197, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O One Who has command over the fulfillment of the desires of those who beg. He knows what is in the hearts of those who remain quiet. Every question is heard by You and for it answer is provided. O Allah Your promises are so true, Your blessings so abundant, and your Mercy so encompassing. So I beg You to send Your blessings on Mohammad and the Progeny of Mohammed and fulfill all my desires of this world and the world to come. Verily You have potency over all things O Allah! Send Your Blessing on Mohammad and his Progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay woh jo saaelin ki haajato’n ka Maalik hai aur khaamosh logo’n ke dilo’n ki baate’n jaanta hai, har woh sawaal jo Tujh se kiya jaaye Tera kaan usey soonta hai aur uska jawaab taiyyaar hai. Ay Ma’bood! Tere sab waade yaqeenan sachche hai, Teri neymate’n bohot umdah hai aur Teri rehmat badi wasee hai. Pas mai Tujh se sawaal karta hu keh, Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par rehmat naazil farma aur yeh keh meri duniya aur aakherat ki haajate’n puri farma. Be-shak Tu har cheez par qudrat rakhta hai.", "Urdu": "اے وہ جوسائلین کی حاجتوں کامالک ہے اور خاموش لوگوں کے دلوں کی باتیں جانتا ہے ہر وہ سوال جو تجھ سے کیا جائے تیرا کان اسے سنتا ہے اور اس کا جواب تیار ہے اے معبود! تیرے سب وعدے یقینًا سچے ہیں تیری نعمتیں بہت عمدہ ہیں اور تیری رحمت بڑی وسیع ہے پس میں تجھ سے سوال کرتا ہوں کہ محمدؐؐوآلؑ محمدؐؐ پر رحمت نازل فرما اور یہ کہ میری دنیا اور آخرت کی حاجتیں پوری فرما بے شک تو ہر چیز پر قدرت رکھتا ہے۔", "RArabic": null, "ArabicText1": "يَا مَنْ يَمْلِكُ حَوَائِجَ السَّائِلِيْنَ وَيَعْلَمُ ضَمِيْرَ الصَّامِتِيْنَ لِكُلِّ مَسْاَلَةٍ مِنْكَ سَمْعٌ حَاضِرٌ وَجَوَابٌ عَتِيْدٌ۔ اَللّٰهُمَّ وَمَوَاعِيْدُكَ الصَّادِقَةُ وَاَيَادِيْكَ الْفَاضِلَةُ وَرَحْمَتُكَ الْوَاسِعَةُ فَاَسْئَلُكَ اَنْ تُصَلِّيَ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَاَنْ تَقْضِيَ حَوَائِجِيْ لِلدُّنْيَا وَالْآخِرَةِ اِنَّكَ عَلٰى كُلِّ شَيْ‏ءٍ قَدِيْرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicTex