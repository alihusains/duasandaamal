[{"Id": 1016640, "EnglishTitle": "PLEASE NOTE: Be it clear that the reason for presenting Translation is to understand Salaat and to recite in Arabic with concentration because reciting Salaat other than Arabic language (or Transliteration) is not correct.", "GujaratiTitle": null, "RUrduTitle": "Waazeh rahe keh tarjuma-e-namaz pesh karne ki asal wajah namaz samajh ke Arabi mein khuzoo aur tawajjoh ke saath namaz padhna hai. Kyu’n keh Arabi ya Roman-Arabi (Transliteration) ke siwa kisi aur zabaan mein namaz padhna sahih nahin hai.", "UrduTitle": "واضح رہے کہ ترجمۂ نماز پیش کرنے کی اصل غرض نماز سمجھ کے عربی میں خضوع اور توجہ کے ساتھ نماز پڑھنا ہے۔ کیوں کہ عربی کے سوا کسی اور زبان میں نماز پڑھنا صحیح نہیں ہے۔ اس لئے ہر ایک کے لئے نماز کی حد تک قرآن و عربی سیکھنا واجب ہے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002941, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "This namaz has no such condition of purity (tahaarat) or wuzu. Anyone reciting this namaz with the Imam has to recite himself all the below zikr (listening the zikr is not sufficient). If the dead body is that of a male the prayer leader has to stand before its waist and if it is that of a female he should stand in front of the chest. This namaz consist of 5 Takbir (Allahu Akbar) and soon after making the intention (niyyat) one should say…", "GujaratiDescription": null, "RUrduDescription": "Waajib hai keh namaz padhne waala qibla rukh khada ho, mayyit ka sar uski daayni jaanib (right side) ho aur mayyit ko pusht ke bal letaaya jaaye. Is namaz mein paak hone ki shart nahi hai, chunaan-che mujnib mard, haiz waali aurat aur bagair wuzu shakhs bhi yeh namaz padh sakta hai, lekin sunnat hai keh ba-wuzu ho kar padhi jaaye, agar paani na mil sakey ya paani ke istemaal mein koi rukaawat aati ho, ya waqt ki kami ho to sunnat hai keh tayammum kiya jaaye aur ahadees ke mutabiq kisi uzr ke bagair bhi tayammum kiya ja sakta hai. Neez sunnat hai keh agar mayyat Mard ki ho to Pesh Namaz mayyit ke kamar ke saamne khada ho aur agar Aurat ki mayyit ho to uske seene ke saamne khade ho kar namaz padhe aur sunnat hai keh joote (shoes) utaar kar namaz padhe, aur waajib hai keh namaz ki niyyat karke 5 takbeer padhi jaaye. Sunnat hai keh har takbeer par haatho’n ko kaano ke bara-bar laaya jaaye aur mashhoor yehi hai keh…", "UrduDescription": "واجب ہے کہ نماز پڑھنے والا قبلہ رخ کھڑا ہو میت کا سراس کی داہنی جانب ہو اور میت کو پشت کے بل لٹا یاجائے اس نماز میں حدث سے پاک ہونے کی شرط نہیں ہے،چنانچہ مجنب مرد، حیض والی عورت اور بے وضو شخص بھی یہ نماز پڑھ سکتا ہے،لیکن سنّت ہے کہ با وضو ہوکر پڑھی جائے اگر پانی نہ مل سکے یا پانی کے استعمال میں کوئی امر مانع ہویا وقت تنگ ہوتو سنت ہے کہ تیمم کیا جائے اور احادیث کے مطابق کسی عذر کے بغیر بھی تیمم کیا جا سکتا ہے۔نیز سنت ہے کہ اگر میت مرد کی ہوتو پیش نماز اس کی کمر کے مقابل کھڑا ہو اور اگر عورت کی ہے تو اس کے سینے کے مقابل کھڑے ہوکر نماز پڑھے اور سنت ہے کہ جوتے اتار کر نماز پڑھے، اور واجب ہے کہ نماز کی نیت کر کے پانچ تکبیریں پڑھی جائیں۔ سنت ہے کہ ہر تکبیر پر ہاتھوں کو کانوں کے برابر لایا جائے اور مشہور یہی ہے کہ۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1002942, "EnglishTitle": "1st Takbeer ALLAAHO AKBAR then say…", "GujaratiTitle": null, "RUrduTitle": "1st Takbeer ALLAAHO AKBAR ke baad kahe…", "UrduTitle": "پہلی تکبیر اَللهُ اَکْبَـرُ کے بعد کہے۔۔۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002943, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I testify that there is no god except Allah. The One, there is no partner for him. I testify that Muhammad is His servant and Messenger, whom He sent with truth as a giver of glad tidings and a warner till the Judgment Day.", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai gawah hu keh nahin hai koi ma’bood magar Allah jo yakta hai, Uska koi shareek nahi aur mai gawah hu keh Muhammad (s.a.w.a) Uske bande aur rasool hai, Allah ne unhe haq ke saath bheja, woh ta-qayaamat khoosh khabri dene aur daraane waale hai.", "Urdu": "میں گواہ ہوں کہ نہیں ہے معبود مگر اﷲجو یکتا ہے کوئی اس کا شریک نہیں اور میں گواہ ہوں کہ محمدؐ اس کے بندے اور رسولؐ ہیں، اﷲنے انہیں حق کے ساتھ بھیجا، وہ تا قیامت خوش خبری دینے اور ڈرانے والے ہیں۔", "RArabic": "ASH-HADO AN LAA ILAAHA ILLAL-LAAHO WAH-DAHU LAA SHAREE-KA LAHU WA ASH-HADO ANNA MOHAMMADAN A’B-DAHU WA RASOO-LAHU, AR-SALA-HU BIL HAQQE BASHEE-RAWN, WA NAZEE-RAM BAIY-NA YADA-YIS SAA-A’H.", "ArabicText1": "اَشْھَدُ اَنْ لَّآ اِلٰہَ اِلَّا اللہُ وَحْدَہٗ لَاشَرِیْکَ لَہٗ وَاَشْھَدُ اَنَّ مُحَمَّدًا عَبْدُہٗ وَرَسُوْلُہٗ اَرْسَلَہٗ بِالْحَقِّ بَشِیْرًا وَّنَذِیْرًۢا بَیْنَ یَدَیِ السَّاعَۃِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5"