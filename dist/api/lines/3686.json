کو نیکیوں میں باہم ملادے، بے شک تو دعائیں قبول کرنے والا ہے یقیناً تو ہر چیز پر قدرت رکھتا ہے۔", "RArabic": "ALLAAHUM-MAGH FIR-LIL MOA-ME-NEENA WAL MOA-ME-NAATE, WAL MUSLE-MEENA WAL MUSLE-MAATE, AL-AH-YAA-E MIN-HUM WAL AM-WAATE, TAABE’ BAIY-NA-NAA WA BAIY-NA-HUM BIL-KHAI-RAATE INNAKA MOJEE-BUD DA-A’WAATE, INNA-KA A’LAA KULLE SHAIY-IN QADEER.", "ArabicText1": "اَللّٰھُمَّ اغْفِرْلِلْمُؤْمِنِیْنَ وَالْمُؤْمِنَاتِ وَالْمُسْلِمِیْنَ وَالْمُسْلِمَاتِ اَلْاَحْیَآئِ مِنْھُمْ وَالْاَمْوَاتِ تَابِعْ بَیْنَنَا وَبَیْنَھُمْ بِالْخَیْرَاتِ اِنَّکَ مُجِیْبُ الدَّعَوَاتِ اِنَّکَ عَلٰی کُلِّ شَیْ ئٍ قَدِیْرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "Ara