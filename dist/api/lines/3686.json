: null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002945, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, exalt Muhammad and the progeny of Muhammad and bless Muhammad and the progeny of Muhammad and have mercy on Muhammad and the progeny of Muhammad, like You exalted and blessed and had mercy on Ibrahim and the progeny of Ibrahim, indeed You are the praised and the majestic. And exalt all the prophets and messengers and martyrs and the truthful and all the righteous servants.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Rehmat naazil farma Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par, aur barkat naazil farma Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par, aur rahem farma Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par, us se behtar rehmat o barkat aur rahem farmaya Tu ne Ibrahim (a.s) aur Aale Ibrahim (a.s) par. Be-shak Tu khoobi waala, shaan waala hai, rehmat farma tamaam nabiyyo’n aur rasoolo’n par.", "Urdu": " اے معبود! رحمت نازل فرما محمدؐ و آل محمدؑ پر اور برکت نازل فرما محمدؐ و آل محمدؑ پر اور رحم فرما محمدؐ و آل محمدؑ پر اس سے بیشتر جو رحمت کی تو نے اور برکت نازل کی تو نے اور رحم فرمایا تو نے ابراہیمؑ اور آل ابراہیمؑ پر۔ بے شک تو خوبی والا، شان والا ہے اور رحمت فرما تمام نبیوں اور رسولوں پر۔", "RArabic": "ALLAAHUMMA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN, WA BAARIK A’LAA MOHAMMADIW WA AALE MOHAMMADIN, WAR-HAM MOHAMMADAW WA AALE MOHAMMADIN, KA-AFZA-LE MAA SAL-LAIY-TA WA BAARAK-TA WA TARAH-HAMTA A’LAA IBRAA-HEEMA WA AALE IBRAA-HEEMA WA INNA-KA HAMEE-DOOM MAJEE-DOON, WA SALLE A’LAA JAMEE-I’L AMBIYAA-E WAL MUR-SALEE-NA, WASH-SHOHDAA-E WAS-SIDDEE-QEENA, WA JAMEE-E’ E’BAA-DILLAA-HIS SAALE-HEEN.", "ArabicText1": "اَللّٰھُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَّبَارِکْ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَّارْحَمْ مُحَمَّدًا وَّاٰلَ مُحَمَّدٍ کَاَفْضَلِ مَاصَلَّیْتَ وَبَارَکْتَ وَتَرَحَّمْتَ عَلٰٓی اِبْرَاھِیْمَ وَاٰلِ اِبْرَاھِیْمَ وَاِنَّکَ حَمِیْدٌ مَّجِیْدٌ وَّصَلِّ عَلٰی جَمِیْعِ الْاَ نْۢبِیَآئِ وَالْمُرْسَلِیْنَ وَالشُّھَدَآئِ وَالصِّدِّیْقِیْنَ وَجَمِیْعِ عِبَادِاللہِ الصَّالِحِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "Arab