[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011347, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah: the month of Ramadan has commenced, and You have made obligatory upon us to observe fasting during it, and You revealed the Qur’an in it, As guidance for people and clear proofs of true guidance and distinction (between the right and the wrong). O Allah: (please) help us observe fasting in it, and accept it from us, and keep us safe during it, and help us observe it adequately, and keep it sound for us with easiness and good health from You. You verily have power over all things. O the All-beneficent, O the All-merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mahe Ramazan aa gaya aur Tu ne ham par iske roze farz kiya hai, Tu ne is mein Qur’an utaara keh jis mein logo’n ke liye hidaayat aur hidaayat ki daleele’n aur yeh haq o baatil ka farq hai. Ay Ma’bood! Roze rakhne mein hamari madad farma aur unhe qabool kar. Hamein is maah mein tandurast rakh, is se mustafid kar (faaiyda pohoncha), is purey mahine mein hamein aasaani naseeb farma aur aasaaish de, be-shak Tu har cheez par qudrat rakhta hai, ay bade rahem waale ay maher-baan.", "Urdu": "اے معبود! ماہِ رمضان آ گیا اور تو نے ہم پر اس کے روزے فرض کیے ہیں تو نے اس میں قرآن اتارا کہ جس میں لوگوں کے لئے ہدایت اور ہدایت کی دلیلیں اور یہ حق و باطل کا فرق ہے اے معبود! روزے رکھنے میں ہماری مدد فرما اور انہیں قبول کر ہمیں اس ماہ میں تندرست رکھ اس سے مستفید کر اس پورے مہینے میں ہمیں آسانی نصیب فرمااور آسائش دے بے شک تو ہر چیز پر قدرت رکھتا ہے اے بڑے رحم والے اے مہربان۔", "RArabic": "ALLAAHUMMA QAD HAZARA SHAHRO RAMAZAA-NA WA QADIF TA-RAZTA A’LAIY-NAA SE-YAAMA-HU WA ANZAL-TA FEE-HIL QUR-AANA HUDAL-LIN-NAASE WA BAIYYE-NAATIM MENAL HODAA WAL FUR-QAANE. ALLAAHUMMA A-I’NNAA A’LAA SEYAA-ME-HI WA TA-QABBAL-HO MINNAA WA SALLIM-NAA FEEHE WA SALLIM-NAA MINHO WA SALLIM-HO LA-NAA FEE YUSREEN MINKA WA AA’FE-YATIN INNA-KA A’LAA KULLE SHAI-IN QADEE-ROON YAA RAHMAA-NO YAA RAHEE-MO.", "ArabicText1": "اَللّٰهُمَّ قَدْ حَضَرَ شَهْرُ رَمَضَانَ وَ قَدِ افْتَرَضْتَ عَلَيْنَا صِيَامَهٗ وَاَنْزَلْتَ فِيْهِ الْقُرْآنَ هُدًى لِّلنَّاسِ وَبَيِّنَاتٍ مِّنَ الْهُدٰى وَالْفُرْقَانِ۔ اَللّٰهُمَّ اَعِنَّا عَلٰى صِيَامِهٖ وَتَقَبَّلْهُ مِنَّا وَسَلِّمْنَا فِيْهِ وَسَلِّمْنَا مِنْهُ وَسَلِّمْهُ لَنَا فِيْ يُسْرٍ مِنْكَ وَعَافِيَةٍ اِنَّكَ عَلٰى كُلِّ شَيْ‏ءٍ قَدِيْرٌ يَا رَحْمَانُ يَا رَحِيْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": nul