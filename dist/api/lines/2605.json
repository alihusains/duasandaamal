ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016777, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Light of the light, O the administrator of the affairs, O He who shall resurrect those in the grave, bless Muhammad and the family of Muhammad, grant me and my followers relief from adversity, way out from grieves, and widen our ways of sustenance, send to us from Yourself what shall delight us and grant us what You possess, O the Generous.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay noor ko faroogh dene (phaila ne) waale! Ay umoor ki tadbeer karne waale! Ay qabro’n se murdo’n ko utha-ne waale! Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par durood bhej, mujhe aur mere shiyo’n ko sakhti se najaat aur ghamo se rehaayi ataa farma, hamare liye raaste ko wasee kar de, hamein woh cheez inaayat farma jo hamare kaam mein aasaani paiyda kare aur hamare saath woh sulook kar jo Tere shaayaan'e shaan hai, ay Kareem!", "Urdu": "اے نور کو فروغ دینے والے! اے امور کی تدبیر کرنے والے! اے قبور سے مردوں کو اٹھانے والے! محمدؐ و آل محمدؑ پر درود بھیج، مجھے اور میرے شیعوں کو سختی سے نجات اور غموں سے رہائی عطا فرما، ہمارے لئے راستے کو وسیع کردے، ہمیں وہ چیز عنایت فرما جو ہمارے کام میں آسانی پیدا کرے اور ہمارے ساتھ وہ سلوک کر جو تیرے شایانِ شان ہے، اے کریم!", "RArabic": "YAA NOORAN NOORE, YAA MODAB-BERAL OMOO-RE, YAA BAA-E’SA MAN FIL QOBOORE, SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN, WAJ-A’L LEE WA LE-SHAIY-A’TEE MINAZ ZEEQE FARAJAN, WA MINAL HAMME MAKH-RAJAN, WA AWSE’ LA-NAL MAN-HAJA, WA ATLIQ LANAA MIN I’NDE-KA MAA YO-FARRE-JO, WAF-A’L MAA ANTA AH-LOHU YAA KAREEMO.", "ArabicText1": "يَا نُوْرَ النُّوْرِ، يَا مُدَبِّرَ الْاُمُوْرِ، يَا بَاعِثَ مَنْ فِي الْقُبُوْرِ، صَلِّ عَلٰى مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ، وَاجْعَلْ لِيْ وَلِشِيْعَتِيْ مِنَ الضِّيْقِ فَرَجًا، وَمِنَ الْهَمِّ مَخْرَجًا، وَاَوْسِعْ لَنَا الْمَنْهَجَ، وَاَطْلِقْ لَنَا مِنْ عِنْدِكَ مَا يُفَرِّجُ، وَافْعَلْ بِنَا مَا اَنْتَ اَهْلُهٗ يَاكَرِيْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSi