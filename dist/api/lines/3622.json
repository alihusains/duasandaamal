[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016091, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah is Great, Allah is Great, Allah is Great and praise belongs to Him, There is no god save Allah, the One, the Unique, the Everlasting, He Who has taken no consort, and has no Children, He Who has no partner in His kingdom, nor has He a master out of weakness, And we glorify Him greatly. O Allah! Thou hast said in Thy revealed Book “Call unto Me, and I will grant your request.”", "Gujarati": null, "RGujarati": null, "RUrdu": "Allaho Akbar, Allaho Akbar, Allaho Akbar, taarif Allah ke liye hai. Nahi koi ma’bood siwaaye Us Khuda'e waahid ke jo akela yekta hai, jo be-neyaaz hai, jiski na koi biwi hai aur na hi koi aulaad aur na Uski mamlekat mein Uska koi shareek hai. Aur na hi koi Uska madad-gaar hai. Takbeer kaho jis tarah takbeer kehne ka haq hai. Be-shak Tu ne apni naazil kardah kitaab mein kaha hai keh Mujh se dua maango, taa-keh Mai tumhaari dua qabool karu.", "Urdu": "اللہ اکبر، اللہ اکبر، اللہ اکبر، تعریف اللہ کے لئے ہے۔ نہیں معبود سوائے خدائے واحد کے جو اکیلا یکتا ہے، جو بے نیاز ہے جس کی نہ کوئی بیوی ہے اور نہ ہی کوئی أولاد اور نہ اسکی مملکت میں اسکا کوئی شریک ہے، اور نہ ہی کوئی اسکا مددگار ہے۔ تکبیر کہو جس طرح تکبیر کہنے کا حق ہے۔ بار الٰہا! بے شک تو نے اپنی نازل کردہ کتاب میں کہا ہے کہ مجھ سے دُعا مانگو، تا کہ میں تمہاری دُعا قبول کروں۔", "RArabic": "ALLAAHO AKBARO ALLAAHO AKBARO, ALLAAHO AKBARO WA LILLAA-HIL HAMDO, LAA ILAAHA ILLAL LAAHUL WAAHE-DUL FAR-DUS SAMA-DUL LAZEE LAM YATTA-KHIZ SAAHE-BA-TIN WA LAA WALA-DAN, WA LAM YA-KUL-LAHU SHAREE-KUN FIL MULKE WA LAM YA-KUL-LAHU WALIYYUN MENAZ ZULLE WA KABBIR-HO TAKBE-RAN.", "ArabicText1": "اَللہُ اَكْبَرُ اَللہُ اَكْبَرُ، اَللہُ اَكْبَرُ وَلِلهِ الْحَمْدُ، لَآ اِلٰهَ اِلَّا اللهُ الْوَاحِدُ الْاَحَدُ الْفَرْدُ الصَّمَدُ، الَّذِیْ لَمْ یَتَّخِذْ صَاحِبَۃً وَلَا وَلَدًا، وَلَمْ یَكُنْ لَّهٗ شَرِیْكٌ فِی الْمُلْكِ وَلَمْ یَكُنْ لَّهٗ وَلِیٌ مِّنَ الذُّلِّ وَكَبِّرْهُ تَكْبِرًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016092, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Lord! We have called unto Thee, as Thou hast ordered us; so forgive us, Truly Thou never doest change Thy word. O Lord! We have heard a caller calling to faith: “Have faith in your Lord.” We have faith; so Lord, forgive us our sins, and acquit us of our evil deeds, and take us to Thee with the righteous. O Lord! Give us what Thou promised us through Thy Prophets, Do not disgrace us on the Day of Judgment, Surely Thou never doest change Thy word.", "Gujarati": null, "RGujarati": null, "RUrdu": "Lehaaza ham dua karte hai, pas ay Paalne Waale! Hamein maaf kar de jis tarah hamein hukm diya hai. Be-shak Tu waada khilaafi nahi karta. Parwardigaar! Ham ne is munaadi kosha jo imaan ki awaaz laga raha tha keh apne Parwardigaar par imaan le aawo, to ham imaan le aaye. Parwardigaar! Ab hamaare gunaho’n ko maaf farma aur hamaari buraaiyyo’n ki pardah-poshi farma aur hamein neyk bando’n ke saath mehshoor farma. Parwardigaar! Jo Tu ne apne rasoolo’n se waada kiya hai usey ataa farma aur roz'e qayaamat hamein ruswa na karna, keh Tu waada khilaafi nahi karta.", "Urdu": "لہٰذا ہم دُعا کرتے ہیں، پس اے پالنے والے! ہمیں معاف کردے جس طرح ہمیں حکم دیا ہے، بےشک تو وعدہ خلافی نہیں کرتا۔ پروردگار! ہم نے اس منادی کو سنا جو ایمان کی آواز لگا رہا تھا کہ اپنے پروردگار پر ایمان لے آؤ، تو ہم ایمان لے آئے۔ پروردگار! آپ ہمارے گناہوں کو معاف فرما اور ہماری برائیوں کی پردہ پوشی فرما اور ہمیں نیک بندوں کے ساتھ محشور فرما۔ پروردگار! جو تو نے اپنے رسولوں سے وعدہ کیا ہے اسے عطا فرما اور روز قیامت ہمیں رسوا نہ کرنا، کہ تو وعدے کے خلافی نہیں کرتا۔", "RArabic": "ALLAAHUMMA INNAKA QULTA FEE KETAABE-KAL MUNZALE: UD-OO’NEE ASTA-JIB LAKUM DAWOO-NAAKA RABBA-NAG FIR LANAA KAMAA AMAR-TANAA INNAKA LAA TUKHLE-FUL MEE-AA’DA, RABBA-NAA SAME’NAA MO-NAADE-YAN YONAA-DEE LIL-EEMAA-NE AN AA-MENOO BE-RABBE-KUM FA-AAA-MANNA, RABBA-NAA FAGHFIR-LANAA ZONOO-BANAA WA KAFFIR A’NNAA SAYYE-AAATE-NAA WA TAWAF-FANAA MA-A’L AB-RAARE, RABBA-NAA WA AATE-NAA MAA WA A’DTA-NAA A’LAA RASOOLE-KA WA LAA TUKH-ZENAA YAWMAL QEYAAMATE INNA-KA LAA TUKHLE-FUL MEE-AA’DA.", "ArabicText1": "اَللّٰهُمَّ اِنَّكَ قُلْتَ فِیْ كِتَابِكَ الْمُنْزَلِ: اُدْعُوْنِیْ اَسْتَجِبْ لَكُمْ، دَعُوْنَاكَ رَبَّنَا غْفِرْ لَنَا كَمَا اَمَرْتَنَا اِنَّكَ لَا تُخْلِفُ الْمِیْعَادَ، رَبَّنَا سَمِعْنَا مُنَادِیًا یُنَادِیْ لِلْاِیْمَانِ اَنْ اٰمِنُوْا بِرَبِّكُمْ فَاۗمَنَّا، رَبَّنَا فَاغْفِرْلَنَا ذُنُوْبَنَا وَكَفِّرْ عَنَّا سَیِّئَاۗتِنَا وَتَوَفَّنَا مَعَ الْاَبْرَارِ، رَبَّنَا وَاٰتِنَا مَا وَعَدْتَنَا عَلٰی رُسُلِكَ وَلَا تُخْزِنَا یَوْمَ الْقِیَامَۃِ اِنَّكَ لَا تُخْلِفُ الْمِیْعَادَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016093, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Lord! We trust Thee, and we turn to Thee, and to Thee is the final return of all. O Lord! Forgive us and our brethren who preceded us in faith, and let our hearts hold no grudge against those who have belief, Surely, Thou art the Kind, the Compassionate. O Lord! Forgive and have mercy and pardon and be gracious and excuse what Thou knowest, surely Thou knowest what we do not know, verily Thou art Allah, the All-mighty, the most Generous.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar! Mai ne Tere upar bharosa kiya hai aur Teri hi taraf rujoo’a kiya hai aur Teri hi taraf palat-na bhi hai. Parwardigaar! Hamein maaf kar de aur hamaare un bhaaiyyo’n ko bhi jinho ne imaan mein ham par sabqat ki hai aur hamaare dilo’n mein saahebaan'e imaan ke liye kisi tarah ka keena (buri sochh) qaraar na dena keh Tu bada maher-baan aur rahem karne waala hai. Baar'e Ilaaha! Bakhsh de, rahem farma, maaf farma aur us se dar-guzar farma jo Tu mere mutaaliq jaanta hai, kyu’n keh Tu Woh jaanta hai jo mai nahi jaanta. Be-shak Tu intehaayi sar buland aur buzurg-waar Khuda hai.", "Urdu": "پروردگار! میں نے تیرے اوپر بھروسہ کیا ہے اور تیری ہی طرف رجوع کیا ہے اور تیری ہی طرف پلٹنا بھی ہے۔ پروردگار! ہمیں معاف کر دے اور ہمارے ان بھائیوں کو بھی جنہوں نے ایمان میں ہم پر سبقت کی ہے اور ہمارے دلوں میں صاحبان ایمال کے لئے کسی طرح کا کینہ قرار نہ دینا کہ تو پڑا مہربان اور رحم کرنے والا ہے۔ بار الٰہا! بخش دے، رحم فرما، معاف فرما، کرم فرما اور اس سے درگزر فرما جو تو میرے متعلق جانتا ہے، کیونکہ تو وہ جانتا ہے جو میں نہیں جانتا۔ بےشک تو انتہائی سر بلند اور بزرگوار خدا ہے۔ ", "RArabic": "RABBA-NAA A’LAIKA TAWAKKAL-NAA WA ILAIKA ANAB-NAA WA ILAI-KAL MASEERO, RABBA-NAGH-FIR-LANAA WA LE-IKHWAANE-NAL LAZEE-NA SABA-QOONAA BIL-EEMAA-NE, WA LAA TAJ-A’L FEE QOLOO-BENAA GHILLAN LIL-LAZEENA AA-MANOO, RABBA-NAA INNA-KA RAOO-FUR RAHEE-MOON RAB-BIGH-FIR WAR-HAM WA’FO WA TA-KARRAM WA TAJAA-WAZ A’MMAA TA’LAMO MAA LAA NA’LAMO, INNA-KA ANTAL LAAHUL A-A’ZZUL AKRAMO.", "ArabicText1": "رَبَّنَا عَلَیْكَ تَوَكَّلْنَا وَاِلَیْكَ اَنَبْنَا وَاِلَیْكَ الْمَصِیْرُ، رَبَّنَا اغْفِرْلَنَا وَلِاِخْوَانِنَا الَّذِیْنَ سَبْقُوْنَا بِلْاِیْمَانِ، وَلَا تَجْعَلْ فِیْ قُلُوْبِنَا غِلًّا لِلَّذِیْنَ اٰمَنُوْا، رَبَّنَا اِنَّكَ رَئُوْفٌ رَّحِیْمٌ رَبِّ اغْفِرْ وَارْحَمْ وَاعْفُ وَتَكَرَّمْ وَتَجَاوَزْ عَمَّا تَعْلَمُ، اِنَّكَ تَعْلَمُ مَا لَا نَعْلَمُ، اِنَّكَ اَنْتَ اللهُ الْاَعَزُّ الْاَكْرَمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1003199, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 158, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Surely the Safa and the Marwa are among the signs appointed by Allah; so whoever makes a pilgrEnglishImage to the House or pays a visit (to it), there is no blame on him if he goes round them both; and whoever does good spontaneously, then surely Allah is Grateful, Knowing.", "Gujarati": null, "RGujarati": null, "RUrdu": "Be-shak Safa aur Marwa dono pahaadiya Allah ki nishaniyo’n mein se hai lehaaza jo shakhs bhi hajj ya umrah kare uske liye koi harj nahi hai keh un dono pahaadiyo’n ka chakkar lagaaye aur jo mazeed khair karega to Khuda uske amal ka qadr-daan aur us se khoob waaqif hai.", "Urdu": "بے شک صفا اور مروہ دونوں پہاڑیاں اللہ کی نشانیوں میں ہیں لہٰذاجو شخص بھی حج یا عمرہ کرے اس کے لئے کوئی حرج نہیں ہے کہ ان دونوں پہاڑیوں کا چکر لگائے اور جو مزید خیر کرے گا تو خدا اس کے عمل کا قدر دان اوراس سے خوب واقف ہے۔", "RArabic": "INNAS SAFAA WAL-MARWATA MIN SHA’AAA’IRIL LAAHI FAMAN HAJJAL BAITA AWI’TAMARA FALAA JUNAAHA ’ALAIHI AI YATTAWWAFA BIHIMAA; WA MAN TATAWWA’A KHAIRAN FA INNAL LAAHA SHAAKIRUN’ALEEM.", "ArabicText1": "اِنَّ الصَّفَا وَالْمَرْوَةَ مِنْ شَعَآئِرِ اللهِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": "ج ", "ArabicText2": "فَمَنْ حَجَّ الْبَيْتَ اَوِ اعْتَمَرَ فَلَا جُنَاحَ عَلَيْهِ اَنْ يَّطَّوَّفَ بِهِمَا", "ArabicGreenSign2": null, "ArabicRedSign2": "ط ", "ArabicBlueSign2": null, "ArabicText3": "وَمَنْ تَطَوَّعَ خَيْرًا فَاِنَّ اللهَ شَاكِرٌ عَلِيْمٌ", "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable":