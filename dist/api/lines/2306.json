[{"Id": 1019286, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Supplication to be recited after Namaz of Ziyarat during a Journey on Deputation…", "GujaratiDescription": null, "RUrduDescription": "Kisi ki Niyaabat mein Namaz’e Ziyarat ke baad ki dua…", "UrduDescription": "كسی كی نیابت میں نماز زیارت کے بعد کی دعا ۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019287, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Whatever fatigue, or discomfort, or starvation, or exhaustion I have been afflicted (in this journey), then reward so-and-so son of so-and-so for it, and recompense me on his behalf. Peace be on you, O my master from so-and-so son of so-and-so I have come to you as a visitor on his behalf, intercede him and me near Your Lord.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Is safar mein jo takleef ya sakhti mujhe pohonchi, jo gard o ghobaar pada, ya thakan huwi is ka ajr fulaan bin fulaan ko de aur mujhe bhi uski taraf se yeh amal baja laane ka sawaab ataa farma. Aap par salaam ho ay mere Aaqa fulaan bin fulaan ki taraf se. Mai ne us ki taraf se aap ki ziyarat ki pas apne Rab ke yahan uski shafa’at kare.", "Urdu": "اے معبود! اس سفر میں جو تکلیف یا سختی مجھے پہنچی جو گرد و غبار پڑا یا تھکن ہوئی ہے اس کا اجر فلاں ابن فلاں کو دے اور مجھے بھی اس کی طرف سے یہ عمل بجالانے کا ثواب عطا فرما ۔ آپ پر سلام ہو اے میرے آقا فلاں ابن فلاں کی طرف سے میں نے اس کی  طرف سے آپ کی زیارت کی پس اپنے رب کے ہاں اس کی شفاعت کریں۔", "RArabic": "ALLAAHUMMA MAA ASAA-BANEE MIN TA-A’BIN AW NASA-BIN AW SHA-A’SIN AW FAAJUR FULAA-NAB-NA FULAANIN FEEHE WAAJUR-NEE FEE QAZAA-EE A’N-HO. AS-SALAAMO A’LAIKA YAA MAWLAAYA AN FULAA-NIBNE FULAA-NIN ATAIYTO-KA ZAA-E-RAN A’N-HO FASHFA-A’ LAHU I’N-DA RABBEKA.", "ArabicText1": "اَللّٰهُمَّ مَا اَصَابَنِيْ مِنْ تَعَبٍ اَوْ نَصَبٍ اَوْ شَعَثٍ اَوْ لُغُوْبٍ فَأْجُرْ فُلَانَ بْنَ فُلَانٍ فِيْهِ وَأْجُرْنِيْ فِيْ قَضَائِيْ عَنْهُ۔ اَلسَّلَامُ عَلَيْكَ يَا مَوْلَايَ عَنْ فُلَانِ بْنِ فُلَانٍ اَتَيْتُكَ زَائِرًا عَنْهُ فَاشْفَعْ لَهٗ عِنْدَ رَبِّكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17"