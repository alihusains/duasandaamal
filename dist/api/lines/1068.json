0": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009818, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Our Lord! And make them enter the gardens of perpetuity which Thou hast promised to them and those who do good of their fathers and their wives and their offspring, surely Thou are the Mighty, the Wise. And keep them from evil deeds, and whom Thou keepest from evil deeds this day, indeed Thou hast mercy on him, and that is the mighty achievement.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar unhe aur unke baap-dada, azwaaj aur aulaad mein se jo nek aur saaleh afraad hai unko hamesha rehne waale baaghaat mein daakhil farma jin ka Tu ne un se waada kiya hai keh be-shak Tu sab par ghaalib aur saheb'e hikmat hai. Aur unhe buraaiyo’n se mehfooz farma keh aaj jin logo’n ko Tu ne buraaiyo’n se bacha liya goya unhi par rahem kiya hai aur yeh bohot badi kaam-yaabi hai.", "Urdu": "پروردگار انہیں اور ان کے باپ دادا، ازواج اور اولاد میں سے جو نیک اور صالح افراد ہیں ان کو ہمیشہ رہنے والے باغات میں داخل فرما جن کا تو نے ان سے وعدہ کیا ہے کہ بےشک تو سب پر غالب اور صاحبِ حکمت ہے۔ اور انہیں برائیوں سے محفوظ فرما کہ آج جن لوگوں کو تو نے برائیوں سے بچا لیا گویا ان ہی پر رحم کیا ہے اور یہ بہت بڑی کامیابی ہے۔", "RArabic": "RABBANNAA WA ADKHILHUM JANNAATI ’ADNINIL LATEE WA’ATTAHUM WA MAN SALAHA MIN AABAAA’IHIM WA AZWAAJIHIM WA ZURRIYYAATIHIM; INNAKA ANTAL ’AZEEZUL HAKEEM. WA QIHIMUS SAIYI-AAT; WA MAN TAQIS SAIYI-AATI YAWMA’IZIN FAQAD RAHIMTAH; WA ZAALIKA HUWAL FAWZUL ’AZEEM.", "ArabicText1": "رَبَّنَا وَاَدْخِلْهُمْ جَنّٰتِ عَدْنٍ الَّتِيْ وَعَدْتَّهُمْ وَمَنْ صَلَحَ مِنْ اٰبَاۗئِهِمْ وَاَزْوَاجِهِمْ وَذُرِّيّٰتِهِمْ", "ArabicGreenSign1": null, "ArabicRedSign1": "ط ", "ArabicBlueSign1": null, "ArabicText2": "اِنَّكَ اَنْتَ الْعَزِيْزُ الْحَكِيْمُ۔ وَقِهِمُ السَّيِّاٰتِ", "ArabicGreenSign2": null, "ArabicRedSign2": "ط ", "ArabicBlueSign2": null, "ArabicText3": "وَمَنْ تَقِ السَّيِّاٰتِ يَوْمَئِذٍ فَقَدْ رَحِمْتَهٗ", "ArabicGreenSign3": null, "ArabicRedSign3": "ط ", "ArabicBlueSign3": null, "ArabicText4": "وَذٰلِكَ هُوَ الْفَوْزُ الْعَظِيْمُ۔", "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "Arabi