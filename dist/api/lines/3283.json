[{"Id": 1014408, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Shaikh Mufid in his book al-Muqni’ah, has reported this form of ziyarat. After performing the ritual bathing of ziyarat and putting on the purest of your clothes, you may stop at the tomb of Imam Reza (a) and recite…", "GujaratiDescription": null, "RUrduDescription": "Shaikh Mufid apni kitaab Muqniah mein naql farmaayi aur kaha hai keh ghusl karne aur paakeeza libaas pehen ne ke baad Imam Ali Reza (a) ki qabre athaar ke nazdik khade ho kar kahe…", "UrduDescription": "شیخ مفیدؒ نے مقنعہ میں نقل فرمایا ہے اور کہا : غسل زیارت کرنے اور پاکیزہ لباس پہننے کے بعد امام علی رضا   ؑ کی قبر اطہر کے نزدیک کھڑے ہو کر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014409, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O Allah’s authority and son of His authority. Peace be upon you, O Allah’s argument and son of His argument. Peace be upon you, O leader to true guidance and firmest handle (of Islam). Allah’s mercy and blessings be upon you. I bear witness that you passed away carrying the same principles on which your immaculate fathers had passed away. Allah’s blessings be upon them. You never preferred blindness to true guidance and never slanted from right to wrong. And you acted for the sake of Allah and His Messenger sincerely and fulfilled the trust. May Allah reward you on behalf of Islam and its embracers with the most favorable reward. I have come to you may my father and mother be accepted as ransoms for you visiting you, recognizing your right, declaring loyalty to your loyalists, and showing enmity towards your enemies. So, intercede for me with your Lord.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay Waliye Khuda aur Waliye Khuda ke farzand. Aap par salaam ho ay Hujjat-e-Khuda aur Hujjat-e-Khuda ke farzand. Aap par salaam ho ay hidaayat waale Imam aur mohkam silsila, Khuda ki rehmat ho aur uski barkaat ho. Mai gawahi deta hu keh aap usi aqeede par duniya se gaye jis par aap ke paak buzurg rukhsat huwe, Khuda ki rehmate’n ho un par. Aap ne gumraahi ko hidaayat ke noor par tarjeeh na di aur haq se baatil ki taraf na phere bal-keh Khuda aur uske Rasool (s.a.w.a) ki khair andesh rahe aur amaanat-daari ka haq adaa kiya, pas Khuda jaza de aap ko Islaam o Ahle Islaam ki taraf se behtareen jaza. Qurbaan mere maa baap, mai aaya hu aap ki ziyarat karne, aap ke haq se waaqif, aap ke dosto’n ka dost, aap ke dushmano ka dushman hu, pas apne Rab ke yahan meri sifaarish kare.", "Urdu": "آپ پر سلام ہو اے ولی خدا اور ولی خدا کے فرزند! آپ پر سلام ہو اے حجت ِخدا اور حجت ِخدا کے فرزند آپ پر سلام ہو اے ہدایت والے امام اور سلسلۂ محکم خدا کی رحمت ہو اور اس کی برکات ہوں گواہی دیتا ہوں کہ آپ اسی عقیدے پر دنیا سے گئے جس پر آپ کے پاک بزرگ رخصت ہوئے خدا کی رحمتیں ہوں ان پر۔ آپ نے گمراہی کو نورِ ہدایت پر ترجیح نہ دی اور حق سے باطل کی طرف نہ پھرے بلکہ آپ خدا اور اس کے رسولؐ کے خیر خواہ رہے اور امانت داری کا حق ادا کیا پس خدا جزا دے آپ کو اسلام و اہل ِ اسلام کی طرف سے بہترین جزا میں آیا ہوں قربان میرے ماں باپ آپ کی زیارت کرنے آپ کے حق سے واقف آپ کے دوستوں کا دوست آپ کے دشمنوں کا دشمن ہوں پس اپنے رب کے ہاں میری سفارش کریں۔", "RArabic": "AS-SALAAMO A’LAIKA YAA WALIYYAL-LAAHE WABNA WALIYYE-HI. AS-SALAAMO A’LAIKA YAA HUJJA-TAL-LAAHE WABNA HUJJATE-HI. AS-SALAAMO A’LAIKA YAA IMAA-MAL HODAA WAL O’RWA-TAL WUSQAA WA RAHMA-TUL LAAHE WA BARA-KAATO-HU. ASH-HADO ANNA-KA MAZEE-TA A’LAA MAZAA A’LAIHE AABAA-O-KAT TAAHE-ROONA SALWAA-TUL LAAHE A’LAI-HIM. LAM TO-SIR A’MAN A’LAA HO-DAN WA LAM TA-MIL MIN HAQQIN ILAA BAATE-LIN WA ANNA-KA NA-SAH-TA LILLAAHE WALE RASOOLE-HI WA A-DAIY-TAL AMAA-NATA FA-JAZAA-KAL-LAAHO A’NIL ISLAAME WA AHLE-HI KHAI-RAL JAZAA-E A-TAI-TOKA BE-ABEE WA UMMEE ZAA-E-RAN AA’RE-FAN BE-HAQQE-KA MOWAALE-YAN LE-AWLEYAA-E-KA MO-AA’DE-YAN LE-A’DAA-E-KA FASHFA’ LEE I’NDA RABBE-KA.", "ArabicText1": "اَلسَّلَامُ عَلَيْكَ يَا وَلِيَّ اللهِ وَابْنَ وَلِيِّهٖ۔ اَلسَّلَامُ عَلَيْكَ يَا حُجَّةَ اللهِ وَابْنَ حُجَّتِهٖ۔ اَلسَّلَامُ عَلَيْكَ يَا اِمَامَ الْهُدٰى وَالْعُرْوَةَ الْوُثْقٰى وَرَحْمَةُ اللهِ وَبَرَكَاتُهٗ۔ اَشْهَدُ اَنَّكَ مَضَيْتَ عَلٰى مَا مَضٰى عَلَيْهِ آبَاؤُكَ الطَّاهِرُوْنَ صَلَوَاتُ اللهِ عَلَيْهِمْ۔ لَمْ تُؤْثِرْ عَمًى عَلٰى هُدًى وَلَمْ تَمِلْ مِنْ حَقٍّ اِلٰى بَاطِلٍ وَاَنَّكَ نَصَحْتَ لِلهِ وَلِرَسُوْلِهٖ وَاَدَّيْتَ الْاَمَانَةَ فَجَزَاكَ اللهُ عَنِ الْاِسْلَامِ وَاَهْلِهٖ خَيْرَ الْجَزَاءِ اَتَيْتُكَ بِاَبِيْ وَاُمِّيْ زَائِرًا عَارِفًا بِحَقِّكَ مُوَالِيًا لِاَوْلِيَائِكَ مُعَادِيًا لِاَعْدَائِكَ فَاشْفَعْ لِيْ عِنْدَ رَبِّكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014411, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "You may then kiss the tomb, put your both cheeks on it, turn to the side of the Imam’s head, and recite…", "GujaratiDescription": null, "RUrduDescription": "Ab qabre mubarak ko bosa de, dono rukhsaar se mas kare aur phir sirhaane (head side) ja kar is tarah se kahe…", "UrduDescription": "پھر خود کو قبر ِمبارک سے لپٹائے اس پربوسہ دے اپنے دونوں رخسار باری باری اس پر رکھے اور پھر سرہانے کی طرف مڑکر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1014412, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O my master, O son of Allah’s Messenger. Allah’s mercy and blessings be upon you. I bear witness that you are verily the guiding leader and the directing saint. I repudiate your enemies in the presence of Allah and seek nearness to Allah through declaring loyalty to you. May Allah bless you. Allah’s mercy and blessings be upon you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay mere Aaqa ay Rasool'e Khuda (s.a.w.a) ke farzand, Khuda ki rehmat ho aur uski barkaat. Mai gawahi deta hu keh aap Imam, rehbar, sar-parast, rehnuma hai. Mai Khuda ke saamne aap ke dushmano se be-zaari karta hu aur aap ki wilaayat se uska qurb chahta hu. Khuda durood bheje aap par Khuda ki rehmat ho aur uski barkaat ho.", "Urdu": "آپ پر سلام ہو اے میرے آقا اے رسول ِخداؐ کے فرزند خدا کی رحمت ہو اور اس کی برکات میں گواہی دیتا ہوں کہ آپ امام رہبر سرپرست رہنما ہیں میں خدا کے سامنے آپ کے دشمنوں سے بیزاری کرتا ہوں اور آپ کی ولایت سے اس کی قربت چاہتا ہوں خدا درود بھیجےآپ پر خدا کی رحمت ہو اور اس کی برکات ہوں۔", "RArabic": "AS-SALAAMO A’LAIY-KA YAA MAWLAA-YA YABNA RASOO-LIL-LAAHE WA RAHMA-TUL-LAAHE WA BARA-KAATO-HU. ASH-HADO ANNA-KAL IMAA-MUL HAADEE WAL-WALIY-YUL MUR-SHEDO ABRA-O E-LAL-LAAHE MIN A’DAA'e KA WA ATA-QARRA-BO E-LAL-LAAHE BE-WELAA-YATE-KA SALLAL-LAAHO A'LAIY-KA WA RAHMA-TUL-LAAHE WA BARA-KAATO-HU.", "ArabicText1": "اَلسَّلَامُ عَلَيْكَ يَا مَوْلَايَ يَا ابْنَ رَسُوْلِ اللهِ وَرَحْمَةُ اللهِ وَبَرَكَاتُهٗ۔ اَشْهَدُ اَنَّكَ الْاِمَامُ الْهَادِيْ وَالْوَلِيُّ الْمُرْشِدُ اَبْرَاُ اِلَى اللهِ مِنْ اَعْدَائِكَ وَاَتَقَرَّبُ اِلَى اللهِ بِوِلَايَتِكَ صَلَّى اللهُ عَلَيْكَ وَرَحْمَةُ اللهِ وَبَرَكَاتُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicTex