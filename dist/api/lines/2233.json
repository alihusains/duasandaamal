ext13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016281, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Tumhari tarah ki millat mai ne nahi dekhi jo be-wafa aur maamlaat mein buri ho, Rasool'e Khuda (s.a.w.a) ka janaaza hamare haatho’n mein chhod kar apne qaul o qaraar aur waado’n ko phaad diya hai, aur bhul gaye ho hamein khilaafat se to mehroom kar hi diya gaya, hamare liye kisi qism ke haq ke bhi qaael nahi ho, goya Ghadeer'e khum waale waaqe se aagaahi nahi rakhte.", "Urdu": "تمہاری طرح کی ملت میں نے نہیں دیکھی جو بے وفا اور معاملات میں بری ہو، رسول خدا کا جنازہ ہمارے ہاتھوں میں چھوڑ کر اپنے قول و قرار اور وعدوں کو پھاڑ دیا ہے اور بھول گئے ہو ہمیں خلافت سے تو محروم کرہی دیا کیا ہمارے لئے کسی قسم کے حق کے بھی قائل نہیں ہو گویا غدیرخم والے واقعہ سے آگاہی نہیں رکھتے۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "لَا عَهْدَ لِیْ بِقَوْمٍ اَسْوَءَ مَحْضَرٍ مِّنْكُمْ، تَرَكْتُمْ رَسُوْلَ اللهِ جِنَازَۃً بَیْنَ اَیْدِیْنَا، وَقَطَعْتُمْ اَمْرَكُمْ فِیْمَا بَیْنَكُمْ، فَلَمْ تُؤَمَّرُوْنَا وَلَمْ تَرَوْا لَنَا حَقَّنَا، كَاَنَّكُمْ لَمْ تَعْلَمُوْا مَا قَالَ یَوْمَ غَدِیْرِ خُمٍّ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016282, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ki qasam, us din Paighambar'e Islaam (s.a.w.a) ne Ameerul Momeneen (a.s) ki wilaayat ko na faqat bataaya bal-keh logo’n se baiy’at bhi li ta-keh tum jaise mauqa-parast logo’n ki ummeedo’n ko khatm kare, lekin tum ne Paighambar'e Islaam (s.a.w.a) se taaluqaat ke rishto’n ko paara-paara kar diya, to jaan lo keh dunya o aakherat mein Allah (swt) hamare aur tumhare darmiyaan faisla kar dega.", "Urdu": "خدا کی قسم اس دن پیغمبر اسلامؐ نے امیر المومنین کی ولایت کو نہ فقط بتایا بلکہ لوگوں سے بیعت بھی لی تاکہ تم جیسے موقع پرست لوگوں کی امیدوں کو ختم کریں لیکن تم نے پیغمبر اسلامؐ سے تعلقات کے رشتوں کو پارہ پارہ کردیا، تو جان لو کہ دنیا و آخرت میں اللہ تعالیٰ ہمارے اور تمہارے درمیان فیصلہ کردے گا۔", "RArabic": null, "ArabicText1": "وَاللهِ لَقَدْ عَقَدَ لَهٗ یَوْمَئِذٍ الْوَلَاءَ، لِیَقْطَعَ مِنْكُمْ بِذٰلِكَ مِنْهَا الَّرِجَاۗئَ، وَلٰكِنَّكُمْ قَطَعْتُمُ الْاَسْبَابَ بَیْنَكُمْ وَبَیْنَ نَبِیِّكُمْ، وَاللهُ حَسِیْبٌ بَیْنَنَا وَبَیْنَكُمْ فِی الدُّنِیَا وَالْآخِرَۃِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "Arabic