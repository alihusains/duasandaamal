[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011599, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O ALLAH the month of Ramazan has set in. Thou has made “Fasting” obligatory on each day of this month, and in this month Thou sent down the Qur’an, a guidance to mankind. wherein are Signs to distinguish between good and evil. O ALLAH make us observe fast, respond to its calling, let it take care of our affairs, and keep us in good condition and look after our welfare and comfort through Thy consent. Verily Thou are able to do all things.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya Mahe Ramazan aa gaya aur Tu ne ham par iske roze waajib qaraar diya hai, aur Qur’an naazil kiya hai, jo logo’n ke liye hidaayat aur tameeze haq wa baatil ki nishani hai (jo haq o baatil ko waazeh karne waali kitaab hai). Khudaaya in rozo’n par hamari imdaad (madad) farma aur inhe qabool kar le, isey hamare liye salaamati qaraar de-de aur hamein sahuliyat wa aafiyat ke saath salaamat rakhna keh Tu har shai par qaadir hai.", "Urdu": "اے معبود! ماہِ رمضان آگیا ہے اور تونے اس کے روزے ہم پر فرض کیے ہیں اس میں تو نے قرآن اتارا ہے جو لوگوں کے لئے ہدایت اور ہدایت کی نشانیاں اور حق وباطل میں فرق کرتا ہے اے معبود! اس کے روزے رکھنے میں مدد کر اور اسے ہم سے قبول فرما اس کو ہم سے پورا لے اور ہمارے لئے پورا فرما اپنی طرف سے آسانی و سہولت کے ساتھ بے شک تو ہرچیز پر قدرت رکھتا ہے۔", "RArabic": "ALLAAHUMMA QAD HAZARA SHAHRO RAMAZAA-NA WA QAD AF-TARAZ-TA A’LAIY-NAA SE-YAAMA-HU WA ANZAL-TA FEE-HIL QURAANA HO-DAL LIN-NAASE WA BAIYYE-NAA-TIN MENAL HODAA WAL FURQAAN. ALLAAHUMMA A-I’NNAA A’LAA SE-YAAME-HI WA TA-QABBAL-HO MINNAA WA TASAL-LAM-HO LA-NAA FEE YUSRIM MINKA WA AA’FE-YATIN INNA-KA A’LAA KULLE SHAI-IN QADEER.", "ArabicText1": "اَللّٰہُمَّ قَدْ حَضَرَ شَھْرُ رَمَضَانَ وَقَدْ اَفْتَرَضْتَ عَلَیْنَا صِیَامَہٗ وَاَنْزَلْتَ فِیْہِ الْقُرْاٰنَ ھُدًی لِّلنَّاسِ وَبَیِّنَاتٍ مِّنَ الْھُدٰی وَالْفُرْقَانِ۔ اَللّٰہُمَّ اَعِنَّا عَلٰی صِیَامِہٖ وَتَقَبَّلْہُ مِنَّا وَتَسَلَّمْہُ لَنَا فِیْ یُسْرٍ مِّنْکَ وَعَافِیَۃٍ اِنَّاکَ عَلٰی کُلِّ شَیْٓءٍ قَدِیْرٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12":