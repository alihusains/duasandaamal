[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019031, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My Lord! As you are very attached with your beloved and you are always ready to fulfil their desires who have faith on you. You know their secrets and their conscience. You know their deep prudence. All their secrets and their hearts are plaintiff before you. Whenever loneliness frightens them, your invocation helps them and when they are overtaken by misery, seek protection from you. They know all affairs are in His control and its benefits are depend on His decision. O My Lord! If I would become helpless or perplexed of my desires, guide me as my advisor. Turn my mind towards the good. This is not against the correct guidance and not new for you to be managed. O Allah, make me suitable for your forgiveness and not for justice.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda wanda! Tu apne chahne waalo’n ke liye har maanoos (qareeb) hone waale se ziyadah maanoos hai, aur apne upar bharosa karne waalo’n ke liye sab se ziyadah haajat rawaayi (poori karne) ko tayyaar hai. Un ke raazo’n ka mushaaheda aur un ki zameero’n se ba-khabar, un ki baseerato’n ki gheraayi se waaqif hai, unke tamaam raaz Tere saamne waazeh aur unke dil Tere huzoor mein faryaadi hai. Jab bhi tanhaayi unhe’n ghabraati hai to Tera zikr unhe’n sahaara deta hai, aur agar masaaeb ka hujoom hota hai to woh Tujh hi se panah maangne par majboor hote hai. Unhe’n maaloom hai keh maamelaat ki baag-daud Tere qabza’e qudrat mein hai aur un ke mafaad (faaide) ki manzil Tere hi faisle hai. Ay mere Allah! Agar mai sawaal karne se aajeez ya apni khwaaisho’n se pareshaan ho jaawo’n to meri islaa’eh kaar (hidaayat) ke liye rehnumaayi farma, aur jis mein meri bhalaayi ho us ki taraf mera dil mod de. Keh yeh baat na Tere usool’e hidaayat numaayi ke khilaaf hai na Teri sar-baraahi ke liye navi hai. Khudaaya! Mujhe apni afwo wa bakhshish ka ahel qaraar de insaaf o adl ka nahin.", "Urdu": "خداوندا! تو اپنے چاہنے والوں کے لئے ہر مانوس ہونے والے سے زیادہ مانوس ہے، اور اپنے اُوپر بھروسہ کرنے والوں کے لئے سب سے زیادہ حاجت روائی کو تیار ہے، ان کے رازوں کا مشاہدہ اور ان کی ضمیروں سے با خبر، ان کی بصیرتوں کی گہرائی سے واقف ہے، ان کے تمام راز تیرے سامنے واضح اور ان کے دل تیرے حضور میں فریادی ہیں۔ جب بھی تنہائی انہیں گھبراتی ہے تو تیرا ذکر انہیں سہارا دیتا ہے، اور اگر مصائب کا ہجوم ہوتا ہے تو وہ تجھی سے پناہ مانگنے پر مجبور ہوتے ہیں، انہیں معلوم ہے کہ معاملات کی باگ ڈور تیرے قبضہٴ قدرت میں ہے اور ان کے مفاد کی منزل تیرے ہی فیصلے ہیں۔  اے میرے اللہ! اگر میں سوال کرنے سے عاجز یا اپنی خواہشوں سے پریشان ہو جاؤں تو میری اصلاح کار کے لئے راہنمائی فرما، اور جس میں میری بھلائی ہو اس کی طرف میرا دل موڑ دے، کہ یہ بات نہ تیرے اصولِ ہدایت نمائی کے خلاف ہے نہ تیری سربراہی کے لئے نئی ہے۔ بار خدایا! مجھے اپنی عفو و بخشش کا اہل قرار دے انصاف و عدل کا نہیں۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰـهُمَّ! اِنَّكَ آنَسُ الْآنِسِیْنِ لِاَوْلِیَاۗئِكَ وَاَحْضَرَهُمْ بِالْكَفَایَۃِ لِلْمُتَوَكِّلِیْنَ عَلَیْكَ تُشَاهِدُهُمْ فِیْ سَرَاۗئِرِهِمْ وَتَطَّلِعُ عَلَیْهِمْ فِیْ ضَمَاۗئِرِهِمْ وَتَعْلَمُ مَبْلَغَ بَصَاۗئِرِهِمْ فَاَسْرٰرُهُمْ لَكَ مَكْشُوْفَۃٌ وَقُلُوْبُهُمْ اِلَیْكَ مَلْهُوْفَۃٌ اِنْ اَوْ حَشَتْهُمُ الْغُرْفَۃُ آفَسَهُمْ ذِكْرُكَ وَاِنْ صُبَّتْ عَلَیْهِمُ الْمَصَاۗئِبُ لَجَاۗؤُا اِلَی الْاِسْتِجَارَۃِ بِكَ عِلْمًا بِاَنَّ اَزِمَّۃِ الْاَمُوْرِ بِیَدِكَ وَمَصَادِرَهَا عَنْ قَضَاۗئِكَ۔ اَللّٰهُمَّ! اِنْ فَهِهْتُ عَنْ مَسْئَلَتِیْ اَوْ عَمِهْتُ عَنْ طَلِّبَتِیْ فَدُلَّنِیْ عَلٰی مَصَالِحِیْ وَخُذْ بِقَلْنِیْ اِلٰی مَرَاشِدِیْ فَلَیْسَ ذٰلِكَ بِنُكْرٍ مِنْ هِدَایَاتِكَ وَلَا بِبَدَعٍ مِنْ كِفَایَاتِكَ۔ اَللّٰهُمَّ احْمِلْنِیْ عَلٰی عَفْوِكَ وَلَا تَحْمِلْنِیْ عَلٰی عَدْلِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGree