[{"Id": 1016640, "EnglishTitle": "PLEASE NOTE: Be it clear that the reason for presenting Translation is to understand Salaat and to recite in Arabic with concentration because reciting Salaat other than Arabic language (or Transliteration) is not correct.", "GujaratiTitle": null, "RUrduTitle": "Waazeh rahe keh tarjuma-e-namaz pesh karne ki asal wajah namaz samajh ke Arabi mein khuzoo aur tawajjoh ke saath namaz padhna hai. Kyu’n keh Arabi ya Roman-Arabi (Transliteration) ke siwa kisi aur zabaan mein namaz padhna sahih nahin hai.", "UrduTitle": "واضح رہے کہ ترجمۂ نماز پیش کرنے کی اصل غرض نماز سمجھ کے عربی میں خضوع اور توجہ کے ساتھ نماز پڑھنا ہے۔ کیوں کہ عربی کے سوا کسی اور زبان میں نماز پڑھنا صحیح نہیں ہے۔ اس لئے ہر ایک کے لئے نماز کی حد تک قرآن و عربی سیکھنا واجب ہے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019110, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Maqaatil Ibn Maqaatil says, ‘I requested Imam Reza (a): May I be sacrificed upon you please teach me any supplication to fulfil my desires.’ Imam Reza (a) said: Whenever you have any special invocation to ask the Almighty Allah, after taking bath put on clean and best dress, apply fragrance, go under open sky and offer 2 rakats namaz. In each rakat after <Surah Fateha> recite <Surah Ikhlaas> 15 times, then in ruku after zikr’e ruku, while standing from ruku, then in 2 sujood after zikr’e sajdah, between 2 sajdah and after 2nd sajdah recite <Surah Ikhlaas> 15-15 times. After finishing the prayer recite the following supplication in sajdah…", "GujaratiDescription": null, "RUrduDescription": "Maqaatil bin Maqaatil se riwaayat hai keh Us ne Imam Reza (a) se guzaarish ki keh aap par qurbaan jaawu, mujhe Qaza’e Hawaaej ke liye taalim farmaaye, aap ne farmaaya: Jab bhi koi ahem haajat pesh aaye to ghusl karo, beh-tareen libaas pehen kar khushboo lagaawo, aasmaan ke neeche ja kar 2 rakat namaz padho ke jis ki har rakat mein <Surah Fateha> ke baad 15 martaba <Surah Ikhlaas> padho aur phir ruku mein zikr’e ruku ke baad, ruku se khade ho kar, dono sajdoh mein zikr’e sajdeh ke baad, dono sajdoh ke darmiyaan mein aur 2nd sajdeh ke baad 15-15 martaba <Surah Ikhlaas> padho. Namaz ke baad sajdeh mein ja kar is tarah se kaho…", "UrduDescription": "مقاتل بن مقاتل سے روایت ہے کہ اس نے امام رضاؑ سے گزارش کی کہ آپ پر قربان جاؤں، مجھے قضاء حوائج کے لئے تعلیم فرمائیں، آپ نے فرمایا: جب بھی کوئی اہم حاجت درپیش ہو تو غسل کرو، بہترین لباس پہن کر کچھ خوشبو لگاؤ، آسمان کے نیچے جا کر ۲ رکعت نماز پڑھو کہ جس کی ہر رکعت <سورۂ فاتحہ> کے بعد ۱۵ مرتبہ <سورۂ اخلاص> پڑھو، پھر رکوع میں ذکر رکوع کے بعد، پھر رکوع سے کھڑے ہو کر، دونوں سجدوں کے ذکر سجدہ کے بعد اور دونوں سجدوں کے درمیان، دوسرے سجدہ کے بعد مے ۱۵۔ ۱۵ مرتبہ سورہٴ اخلاص پڑھو، نماز کے بعد سجدے میں جا کر کہو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019111, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Every god from Your Throne upto the depth of the Your earth is negated except You. Then surely You are the clear truth, fulfil my so and so need now, at this moment.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Paalne waale! Arsh se le kar Teri zameen tak Tere siwa har ma’bood baatil hai, be-shak Tu Ma’bood’e haq o roshan hai, meri is haajat ko poori farma, isi waqt, isi waqt (aur apne iraadeh par israar karo).", "Urdu": "اے پالنے والے! عرش سے لے کر تیری زمین تک تیرے سوا ہر معبود باطل ہے، بے شک تو معبودِ حق و روشن ہے، میری اس حاجت کو پورا فرما، اسی وقت، اسی وقت (اور اپنے ارادہ میں اصرار کرو)۔", "RArabic": "ALLAAHUMMA INNA KULLA MA’BOO-DIN MIN LA-DUN A’R-SHE-KA ILAA QARAARE ARZE-KA FA-HOWA BAATE-LOON SEWAA-KA FA-INNA-KA ANTAL LAAHUL HAQQUL MOBEENO IQZE LEE HAAJA-TAN KAZAA WA KAZAA AS-SAA-A’TAS SAA-A’TA.", "ArabicText1": "اَللّٰہُمَّ اِنَّ كُلَّ مَعْبُوْدٍ مِنْ لَدُنْ عَرْشِكَ اِلٰی قَرَارِ اَرْضِكَ فَہُوَ بَاطِلٌ سِوَاكَ فَاِنَّكَ اَنْتَ اللہُ الْحَقُّ الْمُبِیْنُ اِقْضِ لِیْ حَاجَۃً كَذَا وَكَذَا اَلسَّاعَۃَ السَّاعَۃَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreen