[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015605, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Our Lord! Make not our hearts to deviate after Thou hast guided us aright, and grant us from Thee mercy; surely Thou art the most liberal Giver. Our Lord! surely we have heard a preacher calling to the faith, saying: Believe in your Lord, so we did believe. Our Lord! forgive us therefore our faults, and cover our evil deeds and make us die with the righteous.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar! Jab Tu ne hamein hidaayat de di hai to ab hamare dilo’n mein kaji (bigaad) na paiyda hone paaye aur hamein apne paas se rehmat ataa farma keh Tu behtareen ataa karne waala hai. Parwardigaar ham ne us munaadi (awaaz dene waale) ko soona jo imaan ki aawaaz laga raha tha keh apne Parwardigaar par imaan le aawo to ham imaan le aaye. Parwardigaar ab hamare gunaho’n ko maaf farma aur hamari buraaiyo’n ki parda-poshi farma (chhupa de) aur hamein nek bando’n ke saath mehshoor farma.", "Urdu": "پروردگار جب تونے ہمیں ہدایت دے دی ہے تو اب ہمارے دلوں میں کجی نہ پیدا ہونے پائے اور ہمیں اپنے پاس سے رحمت عطا فرما کہ تو بہترین عطا کرنے والا ہے۔ پروردگار ہم نے اس منادی کو سُنا جو ایمان کی آواز لگا رہا تھا کہ اپنے پروردگار پر ایمان لے آؤ تو ہم ایمان لے آئے۔ پروردگار اب ہمارے گناہوں کو معاف فرما اور ہماری برائیوں کی پردہ پوشی فرما اور ہمیں نیک بندوں کے ساتھ محشور فرما۔", "RArabic": "RABBANAA LAA TO-ZIGH QOLOO-BANAA BA’DA IZ-HADAIY-NAA WA HAB-LANAA MIN LA-DUNKA RAH-MATAN INNA-KA ANTAL WAH-HAABO. RABBANAA INNA-NAA SAME’NAA MO-NAADE-YAN YONAA-DEE LIL-IMAANE AN AA-MENOO BE-RABBE-KUM FA-AA-MANNAA RABBANAA FAGH-FIR LANAA ZONOO-BANAA WA KAFFIR A’NNAA SAIYYE-AATE-NAA WA TAWAF-FANAA MA-A’L AB-RAARE.", "ArabicText1": "رَبَّنَا لَا تُزِغْ قُلُوْبَنَا بَعْدَ اِذْ هَدَيْتَنَا وَهَبْ لَنَا مِن لَّدُنْكَ رَحْمَةً اِنَّكَ اَنْتَ الْوَهَّابُ۔ رَبَّنَآ اِنَّنَا سَمِعْنَا مُنَادِيًا يُّنَادِيْ لِلْاِيْمَانِ اَنْ اٰمِنُوْا بِرَبِّكُمْ فَاٰمَنَّا۔ رَبَّنَا فَاغْفِرْ لَنَا ذُنُوْبَنَا وَكَفِّرْ عَنَّا سَيِّاٰتِنَا وَتَوَفَّنَا مَعَ الْاَبْرَارِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015606, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Our Lord! and grant us what Thou hast promised us by Thy apostles; and disgrace us not on the day of resurrection; surely Thou dost not fail to perform the promise. Our Lord! do not punish us if we forget or make a mistake. Our Lord! do not lay on us a burden as Thou didst lay on those before us.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar jo Tu ne apne Rasoolo’n se waada kiya hai usey ataa farma aur roz’e qayamat hamein ruswa na karna keh Tu waade ke khilaaf nahin karta. Parwardigaar! Ham jo kuchh bhul jaaye ya ham se galti ho jaaye uska ham se muakheza (puchh-taachh) na karna. Khudaaya! Ham par waisa bojh na daalna jaisa pehle waali ummato’n par dala gaya hai.", "Urdu": "پروردگار جو تو نے اپنے رسولوں سے وعدہ کیا ہے اسے عطا فرما اور روزِ قیامت ہمیں رسوا نہ کرنا کہ تو وعدہ کے خلاف نہیں کرتا۔ پروردگار! ہم جو کچھ بھول جائیں یا ہم سے غلطی ہو جائے اس کا ہم سے مواخذہ نہ کرنا۔ خدایا ہم پر ویسا بوجھ نہ ڈالنا جیسا پہلے والی امتوں پر ڈالا گیا ہے۔", "RArabic": "RABBANAA WA AATE-NAA MAA WA A’D-TANAA A’LAA ROSOLE-KA WA LAA TUKH-ZENAA YAUW-MAL QIYAAMATE INNA-KA LAA TUKH-LE-FUL MEE-A’ADA.RABBANAA LAA TO-AA-KHIZNAA IN NASEE-NAA AW AKH-TAANA. RABBANAA WA LAA TAHMIL A’LAIY-NA ISRAN KAMAA HAMAL-TAHU A’LAL LAZEENA MIN QABLE-NAA.", "ArabicText1": "رَبَّنَا وَاٰتِنَا مَا وَعَدتَّنَا عَلٰى رُسُلِكَ وَلَا تُخْزِنَا يَوْمَ الْقِيٰمَةِ اِنَّكَ لَا تُخْلِفُ الْمِيْعَادَ۔ رَبَّنَا لَا تُؤَاخِذْنَآ اِنْ نَّسِيْنَآ اَوْ اَخْطَاْنَا۔ رَبَّنَا وَلَا تَحْمِلْ عَلَيْنَآ اِصْرًا كَمَا حَمَلْتَهٗ عَلَى الَّذِيْنَ مِنْ قَبْلِنَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015607, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Our Lord do not impose upon us that which we have not the strength to bear; and pardon us and grant us protection and have mercy on us, Thou art our Patron, so help us against the unbelieving people. Bless Muhammad and His household accept our prayers forgive us and our parents and grandparents You are most merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar! Ham par woh baar na daalna jiski ham mein taaqat na ho. Hamein maaf kar dena hamein bakhsh dena ham par rahem karna Tu hamara maula aur maalik hai ab kaafiro’n ke muqaable mein hamari madad farma. Rehmat naazil farma Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par, hamari dua ko qabool farma, hamein aur hamare waaledain aur hamare buzurgo’n ko bakhsh de, be-shak Tu bada bakhshne waala hai.", "Urdu": "پروردگار ! ہم پر وہ بار نہ ڈالنا جس کی ہم میں طاقت نہ ہو ، ہمیں معاف کر دینا، ہمیں بخش دینا، ہم پر رحم کرنا تو ہمارا مولا اور مالک ہے اب کافروں کے مقابلہ میں ہماری مدد فرما۔ رحمت نازل فرما محمدؐ اور ان کی آلؑ پر اور یہ کہ ہماری دعا قبل فرما، ہمیں اور ہمارے والدین کو ہمارے بزرگوں کو بخش دے، بےشک تو بڑا بخشنے والا ہے۔", "RArabic": "RABBANAA WA LAA TO HAMMIL-NAA MAA LAA TAA-QATA LANAA BEHI WA’FO A’NNAA WAGH-FIR LANAA WAR-HAMNAA ANTA MAWLAA-NAA FANSOOR-NAA A’LAL QAUWMIL KAAFE-REENA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WAS-TAJIB DOAA’-ANAA WAGH-FIR LANAA WA LE-WAALE-DAIY-NAA (WA WAALE-DAYA) WA WAALEDE WAALE-DAIY-NAA WA MAA WALADA INNA-KA ANTAL GHAFOO-RUR RAHEEMO.", "ArabicText1": "رَبَّنَا وَلَا تُحَمِّلْنَا مَا لَا طَاقَةَ لَنَا بِهٖ وَاعْفُ عَنَّا، وَاغْفِرْ لَنَا، وَارْحَمْنَا، اَنْتَ مَوْلٰنَا فَانْصُرْنَا عَلَى الْقَوْمِ الْكٰفِرِيْنَ۔ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ وَاسْتَجِبْ دُعَاۗءَنَا وَاغْفِرْ لَنَا وَ لِوَالِدَيْنَا (وَ وَالِدَيَ) وَ وَالِدِ وَالِدَيْنَا وَمَا وَلَدَ اِنَّكَ اَنْتَ الْغَفُوْرُ الرَّحِيْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSig