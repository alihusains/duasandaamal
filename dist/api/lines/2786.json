[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011679, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O the Helper of those who seek refuge, bless Muhammad and Aale Muhammad (a.s). And be for me a fort of protection O the refuge of those who seek refuge, bless Muhammad and Aale Muhammad (a.s) and be for me a refuge, a support and help, O the one who listens to the entreaties of those who call, bless Muhammad and Aale Muhammad (a.s). And be for me a refuge and a protection.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay panah chahne waalo’n ke madad-gaar! Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur Tu mere liye qila (fort) aur hifaazat ban ja. Ay panah chahne waalo’n ki jaae panah. Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farma aur Tu mere liye jaae panah aur quwwate baazu aur mera moin o madad-gaar ho ja, ay fariyaad karne waalo’n ke fariyaad-ras Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma aur Tu mera fariyaad-ras aur panah dene waala ho ja.", "Urdu": "اے پناہ چاہنے والوں کے مدد گار! حضرت محمدؐ اور ان کی آلؑ پر رحمت نازل فرما اور تو میرے لئے قلع اور حفاظت بن جا۔ اے پناہ چاہنے والوں کی جائے پناہ۔ حضرت محمدؐ اور ان کی آلؑ پر رحمت نازل فرما اور تو میرے لئے جائے پناہ اور قوت بازوں اور میرا معین و مدد گار ہو جا، اے فریاد کرنے والوں کے فریاد رس، محمدؐ اور آل محمدؑ پر رحمت نازل فرما اور تو میرا فریاد رس اور پناہ دینے والا ہو جا۔", "RArabic": "YAA ZAHA-RAL-LAA JEENA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA KUN LEE HIS-NAN WA HIRZAN YAA KAH-FAL MUSTA-JEE-REENA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA KUN LEE KAH-FAN WA A’ZO-DAN WA NAASE-RAN WA YAA GHEYAA-SAL MUSTA-GHEE-SEENA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA KUN LEE GHAYAA-SAN WA MOJEE-RAN.", "ArabicText1": "یَاظَھَرَ اللّٰاجِیْنَ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَکُنْ لِیْ حِصْنًا وَّحِرْزًا یَّاکَھْفَ الْمُسْتَجِیْرِیْنَ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَکُنْ لِیْ کَھْفًا وَعَضُدًا وَّنَاصِرًا وَّیَا غِیَاثَ الْمُسْتَغِیْثِیْنَ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَکُنْ لِیْ غَیَاثًا وَّمُجِیْرًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011680, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O the guardian of the believers and bless Muhammad and Aale Muhammad (a.s). And be a guardian for me, O One who removes the worries of the believers; bless Muhammad and Aale Muhammad (a.s). Remove my distress and cure my sorrow and give me such felicity in this blessed month that after that I never incline to evil. O the most merciful of the merciful ones.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay momino ke Wali aur dost, rehmat naazil farma Hazrat Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par aur Tu mera madad-gaar ho ja. Ay momino ke dil ki tanghi aur uljano ko dur karne waale. Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par rehmat naazil farm aur mere ranj ko dur kar, mere gham ko sukoon de aur mujhe is buzurg aur ba-barkat mahine mein aisi saadat ataa kar, keh phir iske baad kabhi bhi shaqi na banu. Ay rahem karne waalo’n mein sab se ziyadah rahem karne waale.", "Urdu": "اے مومنوں کے ولی اور دست، رحمت نازل فرما حضرت محمدؐ اور آل محمدؑ پر اور میرا مدد گار ہو جا۔ اے مومنوں کے دل کی تنگی اور الجنوں کو دور کرنے والے۔ حضرت محمدؐ اور ان کی آلؑ پر رحمت نازل فرما اور میرے رنج کو دور کر، میرے غم کو سکون دے اور مجھے اس بزرگ اور بہ برکت مہینے ایسی سادات عطا کر، کہ پھر اس کے بعد کبھی بھی شکی نہ بنو۔ اے رحم کرنے والوں میں سب سے زیادہ رحم کرنے والے۔", "RArabic": "YAA WALIY-YAL MOME-NEENA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN WA KUN WA AJJIR GHUS-SATEE WA NAFSEE HAMMEE WAS-I’D NEE FEE HAA-ZASH SHAHRIL MOBAA-RAKIL A’ZEEME SA-AA’DATAN LAA ASH-QAA BA’DA-HAA YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "یَاوَلِیَّ الْمُؤْمِنِیْنَ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَکُنْ لِیْ وَلِیًّا یَامُجِیْرَ غُصَصِ الْمُؤْمِنِیْنَ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ وَکُنْ وَاَجِرْغُصَّتِیْ وَنَفِّسْ ھَمِّیْ وَاسْعِدْ نِیْ فِیْ ھٰذَاالشَّھْرِ الْمُبَارَکِ الْعَظِیْمِ سَعَادَۃً لَّااَشْقٰی بَعْدَھَا یَااَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": nu