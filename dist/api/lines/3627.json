[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016106, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah is great, Allah is great, and abundant praise belongs to Allah. O Allah! Endear faith to me, and adorn it in my heart, and make me hate disbelief and dissolution and disobedience, and make me of the righteous. O Lord! Forgive and have mercy and pardon and be gracious and excuse what Thou knowest, surely Thou knowest what we do not know, verily Thou art Allah, the All-mighty, the most Generous.", "Gujarati": null, "RGujarati": null, "RUrdu": "Allah buzurg o bartar hai, Allah buzurg o bartar hai, Allah ki kibriya’ee buland-tar hai, Allah ki hamd be-panah hai. Baar'e Ilaaha! Mere liye imaan ko mehboob bana de aur mere dil ko us imaan se zeenat bakhsh de aur meri nazr mein kufr, fisq aur na-farmaani ko na-pasandidah bana de aur mujhe hidaayat yaafta logo’n mein se qaraar de. Parwardigaar! Maaf farma, rahem farma, bakhsh de, karam farma aur dar-guzar farma us se jo kuchh Tu mere baare mein jaanta hai, yaqeenan Tu woh sab kuchh jaanta hai jo ham nahi jaante. Be-shak Tu Khuda'e azeez wa buzurg-waar hai.", "Urdu": "اللہ بزرگ و برتر ہے، اللہ بزرگ و برتر ہے، اللہ کی کبریائی بلندتر ہے، اللہ کی حمد بے پایاں ہے۔ بار الٰہا! میرے لئے ایمان کو محبوب بنا دے اور میرے دل کو اس ایمان سے زینت بخش دے، اور میری نظر میں کفر، فسق اور نا فرمانی کو نا پسندیدہ بنا دے اور مجھے ہدایت یافتہ لوگوں میں سے قرار دے۔ پروردگار! معاف فرما، رحم فرما، بخش دے، کرم فرما اور درگزر فرما اس سے جو کچھ تو میرے بارے میں جانتا ہے، یقینًا تو وہ سب کچھ جانتا ہے جو ہم نہیں جانتے۔ بےشک تو خدائے عزیز و بزرگوار ہے۔", "RArabic": "ALLAAHO AKBARO ALLAAHO AKBARO, ALLAAHO AKBARO KABEE-RAN WA HAMDO LIL LAAHE KASEE-RAN, ALLAAHUMMA HABBIB ILAIY-YAL EE-MAANA, WA ZAIYYIN-HO FEE QALBEE, WA KARREH ILAIY-YAL KUFRA WAL FOSOO-QA WA I’S-YAANA WAJ A’L-NEE MENAR RAASHE-DEENA, RAB-BIGH-FIR WAR-HAM WA’FO WA TA-KARRAM WA TAJAA-WAZ A’MMAA TA’LAMO, INNA-KA TA’LAMO MAA LAA NA’LAMO, INNA-KA ANTAL LAAHUL A-A’ZZUL AKRAMO.", "ArabicText1": "اَللہُ اَكْبَرُ اَللہُ اَكْبَرُ، اَللہُ اَكْبَرُ كَبِیْرًا وَالْحَمْدُ لِلهِ كَثِیْرًا۔ اَللّٰهُمَّ حَبِّبْ اِلَیَّ الْاَیْمَانَ، وَزَیِّنْهُ فِیْ قَلْبِیْ، وَكَرِّهْ اِلَیَّ الْكُفْرَ وَالْفُسُوْقَ وَالْعِصْیَانَ وَاجْعَلْنِیْ مِنَ الرَّاشِدِیْنَ، رَبِّ اغْفِرْ وَارْحَمْ وَاعْفُ وَتَكَرَّمْ وَتَجَاوَزْ عَمَّا تَعْلَمُ، اِنَّكَ تَعْلَمُ مَا لَا نَعْلَمُ، اِنَّكَ اَنْتَ اللهُ الْاَعَزُّ الْاَكْرَمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016107, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! Terminate our life in righteous deeds, and in Thy grace make our wishes true, and smooth our ways to reach Thy satisfaction, and in all states improve our deeds. O Thou Who rescue the drowning and save the perishing, O Thou Who witness all whispers, and to Whom all complaints are made, O Thou Whose bounty is ancient, and Whose beneficence is endless, O Thou of Whom nothing can be independent, and everything is dependent on Thee.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baar'e Ilaaha! Hamaari umr ko khair par khatm farma aur apne fazl se hamaari aarzoowo’n ko pura farma, aur hamare liye aasaan bana de keh ham Teri khushnoodi ke raasto’n par gaamzan ho jaaye, aur hamaare tamaam haalaat wa kaamo ko behtar bana de. Ay doobne waale ko najaat dene waale aur ay halaak hone waale ko najaat dene waale aur ay tamaam sar-goshiyo’n ke gawah, ay woh keh har shikwah aakhir-kaar Tujh tak pohonchta hai, ay qadeem alaa ehsaan, ay hamesha achchaayi karne waale, ay Woh jis se koi be-neyaaz nahi ho sakta aur har cheez ke liye Woh na-guzir hai.", "Urdu": "بار یلٰہا! ہماری عمر کو خیر پر ختم فرما اور اپنے فضل سے ہماری آرزؤں کو پورا فرما، اور ہمارے لئے آسان بنادے کہ ہم تیری خوشنودی کے راستوں پر گامزن ہو جائیں، اور ہمارے تمام حالات و کاموں کو بہتر بنا دے۔ اے ڈوبنے والے کو نجات دینے والے اور اے ہلاک ہونے والے کو نجات دینے والے اور اے تمام سرگوشیوں کے گواہ، اے وہ کہ ہر شکوہ آخر کار تجھ تک پہنچتا ہے، اے قدیم الا احسان، اے ہمیشہ اچھائی کرنے والے، اے وہ جس سے کوئی بے نیاز نہیں ہو سکتا، اور ہر چیز کے لئے وہ نافزیر ہے۔", "RArabic": "ALLAAHUM-MAKH TIM BIL-KHAI-RAATE AAJAA-LANAA, WA HAQQIQ BE-FAZLE-KA AAMAA-LANAA WA SAHHIL LE-BOLOO-GHE REZAA-KA SOBO-LANAA, WA HASEEN FEE JAMEE-I’L AH-WAALE A’MAA-LANAA, YAA MUNQE-NAL GHAR-QAA, YAA MUNJE-YAL HALKAA, YAA SHAAHE-DA KULLE NAJWAA, YAA MUNTA-HAA KULLE SHAK-WAA, YAA QADEE-MAL EH-SAANE, YAA DAA'e MAL MA’ROOFE, YAA MAN LAA GHE-NAA BE-SHAI-IN A’N-HO, WA LAA BUDDA LE-KULLE SHAI-IN MINHO.", "ArabicText1": "اَللّٰهُمَّ اخْتِمْ بِالْخَیْرَاتِ اٰجَالَنَا، وَحَقِّقْ بِفَضْلِكَ اٰمَالَنَا وَسَهِّلْ لِبُلُوْغِ رِضَاكَ سُبُلَنَا، وَحَسِّنْ فِیْ جَمِیْعِ الْاَحْوَالِ اَعْمَالَنَا، یَا مُنْقِنَ الْغَرْقٰی، یَا مُنْجِیَ الْهَلْكٰی، یَا شَاهِدَ كُلِّ نَجْوٰی، یَا مُنْتَهٰی كُلِّ شَكْوٰی، یَا قَدِیْمَ الْاِحْسَانِ، یَا دَائِمَ الْمَعْرُوْفِ، یَا مَنْ لَا غِنٰی بِشَیْئٍ عَنْهُ، وَلَا بُدَّ لِكُلِّ شَیْئٍ مِنْهُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016108, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Thou Who sustain all, and the return of everything is to Thee. O Allah! I take refuge in Thee from the evil of what Thou hast bestowed on us, and the evil of what Thou hast prohibited for us. O Allah! Make us die Muslims, and make us join the righteous, neither disgraced nor tempted. O Lord! Make our affairs easy not difficult. O Lord! End our affairs well.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Woh jis ke paas har ek ki rozi hai aur har ek ki (waapsi) Uski taraf hai. Baar'e Ilaaha! Mai Tujh se panah maangta hu har us cheez ke sharr se jise Tu ne hamein ataa kiya hai aur har us cheez ke sharr se jise Tu ne hamse dur rakkha hai. Parwardigaar! Hamein musalmaan ki maut de aur apne saalehin ke saath mila de jo keh na khwaar hai na gumrah hai. Parwardigaar! Hamaare liye aasaani paiyda kar sakhti nahi. Parwardigaar! Hamaare kaamo’n ko khair ke saath tamaam farma.", "Urdu": "اے وہ جس کے پاس ہر ایک کی روزی ہے اور ہر ایک کی (واپسی) اسکی طرف ہے۔ بار الٰہا! میں تجھ سے پناہ مانگتا ہوں ہر اس چیز کے شر سے جسے تو نے ہمیں عطا کیا ہے اور ہر اس چیز کے شر سے جسے تو نے ہم سے دور رکھا ہے۔ بار الٰہا! ہمیں مسلمان کی موت دے اور ایسے صالحین کے ساتھ ملا دے جو کہ نہ خوار ہیں نہ گمراہ ہیں۔ پروردگار! ہمارے لئے ّسانی پیدا کر سختی نہیں۔ پروردگار! ہمارے کاموں کو خیر کے ساتھ تمام فرما۔", "RArabic": "YAA MAR-RIZQO KULLE SHAI-IN A’LAIHE, WA MASEE-RO KULLE SHAI-IN ILAI-HE. ALLAAHUMMA INNEE AA’E-ZOON BEKA MIN SHARRE MAA A’TAIY-TANAA, WA MIN SHARRE MAA MANA’TANAA. ALLAAHUMMA TAWAF-FANAA MUSLE-MEENA, WA AL-HIQNA BIS-SAALE-HEENA, GHAIRA KHAZAA-YAA WA LAA MAFTOO-NEENA, RABBE YASSIR WA LAA TO-I’SSIR, RABBE ATMIM BIL-KHAIRE.", "ArabicText1": "یَا مَنْ رِّزْقُ كُلِّ شَیْئٍ عَلَیْهِ، وَمَصِیْرُ كُلِّ شَیْءٍ اِلَیْهِ۔ اَللّٰهُمَّ اِنِّیْ عَائِذٌ بِكَ مِنْ شَرِّ مَا اَعْطَیْتَنَا، وَمِنْ شَرِّمَا مَنَعْتَنَا۔ اَللّٰهُمَّ تَوَفَّنَا مُسْلِمِیْنَ، وَاَلْحِقْنَ بِالصَّالِحِیْنَ، غَیْرَ خَزَایَا وَلَا مَفْتُوْنِیْنَ، رَبِّ یَسِّرْ وَلَا تُعِسِّرْ، رَبِّ اَتْمِمْ بِالْخَیْرِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "Arabic