[{"Id": 1013027, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "The Prophet’s uncle, Abbas bin Abdul Muttalib (a) holds an esteemed position. He has given many sacrifices for Islam. Recite his Ziyarat in the following way…", "GujaratiDescription": null, "RUrduDescription": "Rasool-e-Khuda (s) ke chacha, Abbas ibne Abdul Muttalib (a) ek azeem shakhsiyat hai. Unho ne Islam ke liye kahi qurbaaniya di hai. Unki ziyarat is tarah se padhe…", "UrduDescription": "حضرت عباس ابن عبد المطلب پیغمبر اکرمؐ کے چچا اور بلند مرتبہ کے حامل تھے، دین اسلام اور پیغمبر اکرمؐ کے لئے آپ نے بہت سی قربانیاں دیں، آپ کی زیارت کے لئے کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign1