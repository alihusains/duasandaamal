bicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015343, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Lord! Please open the doors of relief for me through Your Power. O my God! Please destroy the power of grief that has overcome me by Your Strength and grant me good consideration regarding my complaint and let me taste the sweetness of Your Kindness regarding what I beg of You. And bestow me quick relief from Your Own Presence and provide a quick way out for me from Yourself. Please do not engage me in doing things other than the obligations and performing Your Traditions.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": "وَافْتَحْ لِيْ يَارَبِّ بَابَ الْفَرَجِ بِطَوْلِكَ وَاكْسِرْ عَنِّي سُلْطَانَ (قَرِيْبًا) الْهَمِّ بِحَوْلِكَ وَاَنِلْنِيْ حُسْنَ النَّظَرِ فِيْمَا شَكَوْتُ وَاَذِقْنِيْ حَلَاوَةَ الصُّنْعِ فِيْمَا سَاَلْتُ وَهَبْ لِيْ مِنْ لَدُنْكَ فَرَجًا (رَحْمَةً) هَنِيْئًا وَاجْعَلْ لِيْ مِنْ عِنْدِكَ مَخْرَجًا وَحِيًّا وَلَا تَشْغَلْنِيْ بِالْاِهْتِمَامِ عَنْ تَعَاهُدِ فُرُوْضِكَ وَاسْتِعْمَالِ سُنَّتِكَ فَقَدْ ضِقْتُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5"