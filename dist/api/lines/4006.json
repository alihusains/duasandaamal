-REEN.", "ArabicText1": "اَللّٰہُمَّ الْعَنْ قَتَلَۃَ اَمِیْرَ الْمُؤْمِنِیْنَ وَابْنِہِ الْحَسَنِ وَالْعَنْ العَصَابَۃُ الَّتِیْ قَاتَلَتُ الْحُسَیْنِ وَالَّعَنْ قَتَلَۃَ الْاَئِمَّۃَ الْمَعْصُوْمِیْنَ وَالْعَنْ قَتَلَۃَ زَیْدِ بِنْ عَلِیْ وَاخْزِہِمْ یَوْمَ النُّشُوْرِ وَاَصْلِہِمْ حَرَّ نَارِکَ وَلَا تَفْضِرْ لَہُمْ اَبَدَا۔ یَا مَوْلَایَ اِنِّیْ وَقْضَتُ فِیْ مَقَامِیْ ہٰذَا اَبْتَغِیْ رِضَا اللہِ تَعَالٰی بِمَوَالَاتِیْ لَکُمْ وَالتَّوْفِیْقَ لِمَ دَعَوْتُمْ اِلَیْہِ فَکُنْ لِیْ شَضِیْہًا عِنْدَ اللہِ۔ اَللّٰہُمَّ اَتَوَسِّلُ اِلَیْکَ بِحَقِّ مُحَمَّدٍ وَّبْنَتِہِ الصَّددِیْقَۃِ الزَّہْرَاءِ وَ وَصِیْہِ الْمُرْتَضٰی وَاَبْنَانِہِ الْمَعْصُوْمِیْنَ وَبِحَقِّ وَلِیِّکَ زَیْدَ بِنْ عَلِیْ اَنْ تُصَلِّیْ عَلٰی مُحِمَّدٍ وَّآلِ مُحَمَّدٍ وَاَنْ تَکْشُفَ کَرْبِیْ وَاَنْ تَقْضِیْ حَاجَتِیْ وَلَا تُخَیْبَ سَعْیِیْ وَرَجَائِیْ مِنْ شَفَاعَۃِ الْاَئِمَّۃِ الطَّاہِرِیْنَ اِنَّکَ اَرْحَمُ الرَّاحِمِیْنَ وَصَلَّی اللہُ عَلٰی مُحَمَّدٍ وَآلِہِ الطَّاہِرِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign1