[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011714, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, the Lord of the month of Ramazan and the revealer of Quran. And this month of Ramazan has bid farewell. O Lord, I seek Your refuge from the eventuality that this night should pass away and there is still a sin in my account, which You have not forgiven or there is something for which You have not rewarded me yet. Due to which You will punish me when I am presented in Your court. But that You forgive it through Your generosity and forgiveness, O the most merciful of the merciful ones. O Allah, bless Muhammad and Aale Muhammad (a.s). Indeed You are the praised and the favoring.", "Gujarati": null, "RGujarati": null, "RUrdu": "Baare Ilaaha, ay Mahe Ramazan ke Parwardigaar aur Qur’an ko utaar ne waale yeh Mahe Ramazan to ab rukhsat ho gaya. Ay Parwardigaar mai Tujh se aur Teri izzat aur karam waali zaat ke sahaare se us baat ki panah maangta hu keh kahin is raat ki subh namudaar ho jaaye ya yeh keh Mahe Ramazan guzar jaaye aur Tere nazdik mera koi gunah ya azaab baaqi rahe jaaye keh jiske baais us roz keh jab Teri bargah mein haazir hu, to mujh par azaab ka iraada rakhta ho magar yeh keh Tu apni karam farmayi aur jood o bakhshish se maaf kar de mere us gunah ko, ay rahem karne waalo’n mein sab se ziyadah raheem. Baare Ilaaha! Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par rehmat naazil farma, yaqeenan Tu to laayaqe taarif aur saaheb’e bakhshish hai.", "Urdu": "بار الہ! اے ماہ رمضان کے پروردگار اور قرآن کو اتار نے والے یہ ماہ رمضان تو اب رخصت ہو گیا۔ اے پروردگار میں تجھ سے اور تیری عزّت اور کرم والی ذات کے سہارے سے اس بات کی پناہ مانگتا ہو کہ کہیں اس رات کی صبح نمودار ہو جائے یا یہ کہ ماہ رمضان گزر جائے اور تیرے نزدیک میرا کوئی گناہ یا عذاب باقی رہے جائے کہ جس کی بائیس اس روز کہ جب تیری بارگاہ میں حضر ہو تو مجھ پر عذاب کا ارادہ رکھتا ہو مگر یہ کہ تو اپنی کرم فرمائی اور جود و بخشش سے معاف کر دے میں تے اس گناہ کو، اے رحم کرنے والوں میں سب سے زیادہ رحیم۔ بار الہ! محمدؐ اور آل محمدؑ پر رحمت نازل فرما، یقینًا تو تو لائقہ تعریف   اور صاحب بخشش ہے۔", "RArabic": "ALLAAHUMMA RABBA SHAHRE RAMAZAANA WA MUNZE-LAL QURAANE WA HAAZAA SHAHRO RAMAZAANA QAD TA-SARRAMA AIY RABBE INNEE AOO’ZO-BEKA WA BE-WAJHE-KAL KAREEME AIY-YATLO-A’L FAJRO MIN LAIY-LATEE HAAZE-HI AW-YAKH-ROJA SHAH-RO RAMAZAANA WA LAKA I’NDEE TABE-A’TOON AW-ZAM-BOON TOREE-DO AN TO-A’ZZE-BANEE A’LAIY-HE YAWMAL QAAKA ILLAA GHAFAR-TAHU LEE BE-KARAME-KA WA JOODE-KA YAA AR-HAMAR RAAHE-MEENA. ALLAAHUMMA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN INNA-KA HAMEE-DOON MAJEE-DOON.", "ArabicText1": "اَللّٰھُمَّ رَبَّ شَھْرِ رَمَضَانَ وَمُنْزِلَ الْقُرْاٰنِ وَھٰذَا شَھْرُ رَمَضَانَ قَدْ تَصَرَّمَ اَیْ رَبِّ اِنِّیْ اَعُوْذُبِکَ وَبِوَجْھِکَ الْکَرِیْمِ اَن یَّطْلُعَ الْفَجْرُ مِنْ لَیْلَتِیْ ھٰذِہٖ اَوْیَخْرُجَ شَھْرُ رَمَضَانَ وَلَکَ عِنْدِیْ تَبِعَۃٌ اَوْذَنْۢبٌ تُرِیْدُ اَنْ تُعَذِّبَنِیْ عَلَیْہِ یَوْمَ اَلْقَاکَ اِلَّا غَفَرْتَہٗ لِیْ بِکَرَمِکَ وَجُوْدِکَ یَااَرْحَمَ الرَّاحِمِیْنَ۔ اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِ مُحَمَّدٍ اِنَّکَ حَمِیْدٌ مَجِیْدٌ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGre