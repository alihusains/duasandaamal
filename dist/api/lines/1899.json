eSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002374, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "My Allah, O He, who, for seeking fulfillment of desires, is the ultimate means of relief. O He unto whom requests reach to obtain fulfillment. O He who does not sell favours for a price. O He who does not attach strings (of obligations) to His bestowals. O He, with whom sufficiency is secured, and no one is able to do anything without Him. O He who (alone), no one else, is humbly beseeched, and it (the desire) is never turned away. O He whose treasures are not consumed by giving what is asked for. O He whose wisdom is not altered by any means. O He from whom the \"be in need of\" relationship of the needy cannot be cut off.", "Gujarati": null, "RGujarati": null, "RUrdu": "INSHA-ALLAH COMING SOON", "Urdu": "انشاء اللہ ترجمہ جلد آرہا ہے", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اِنِّيْ اَسْاَلُكَ يَا مَنِ احْتَجَبَ بِشُعَاعِ نُوْرِهٖ عَنْ نَوَاظِرِ خَلْقِهٖ۔ يَا مَنْ تَسَرْبَلَ بِالْجَلَالِ وَالْعَظَمَةِ وَاشْتَهَرَ بِالتَّجَبُّرِ فِيْ قُدْسِهٖ۔ يَا مَنْ تَعَالٰى بِالْجَلَالِ وَالْكِبْرِيَاءِ فِيْ تَفَرُّدِ مَجْدِهٖ۔ يَا مَنِ انْقَادَتِ الْاُمُوْرُ بِاَزِمَّتِهَا طَوْعًا لِاَمْرِهٖ۔ يَا مَنْ قَامَتِ السَّمَاوَاتُ وَالْاَرَضُوْنَ مُجِيْبَاتٌ لِدَعْوَتِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002375, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O He who is not troubled by the calls of the supplicators. You have glorified Your quality of being independent of Your creations, and indeed You are. You have made wants necessary for Your creation, and they, always in need, turn to You. So whoever makes a request to You to free himself from poverty, has come at the right source, which alone gives satisfaction, but whoever turns to another, from among Your creation, to seek fulfillment of his desires, overlooking You, surely comes to grief, and in an attempt to bargain away, I is deprived of Your favours.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": "يَا مَنْ زَيَّنَ السَّمَاءَ بِالنُّجُوْمِ الطَّالِعَةِ وَجَعَلَهَا هَادِيَةً لِـخَلْقِهٖ۔ يَا مَنْ اَنَارَ الْقَمَرَ الْمُنِيْرَ فِيْ سَوَادِ اللَّيْلِ الْمُظْلِمِ بِلُطْفِهٖ۔ يَا مَنْ اَنَارَ الشَّمْسَ الْمُنِيْرَةَ وَجَعَلَهَا مَعَاشًا لِخَلْقِهٖ وَجَعَلَهَا مُفَرِّقَةً بَيْنَ اللَّيْلِ وَالنَّهَارِ بِعَظَمَتِهٖ۔ يَا مَنِ اسْتَوْجَبَ الشُّكْرَ بِنَشْرِ سَحَائِبِ نِعَمِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002376, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, now I put forward my need to You, since my efforts failed, my means fell short, my strategy has been interrupted, because my lust prompted me to go for him who, not being free from Your control, himself seeks Your help for fulfillment of his desires. It was an error like the errors of the transgressors, it was a blunder like the blunders of the sinners. Then, it was You who thought of me, awoke me out of the slumber, and helped me to realize my mistake, and on account of Your admonition, I turned back and abandoned my delusion, saying to myself, \"Glory be to my Lord.\"", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": "اَسْاَلُكَ بِمَعَاقِدِ الْعِزِّ مِنْ عَرْشِكَ وَمُنْتَهَى الرَّحْمَةِ مِنْ كِتَابِكَ وَبِكُلِّ اسْمٍ هُوَ لَكَ سَمَّيْتَ بِهٖ نَفْسَكَ اَوِ اسْتَاْثَرْتَ بِهٖ فِيْ عِلْمِ الْغَيْبِ عِنْدَكَ وَبِكُلِّ اسْمٍ هُوَ لَكَ اَنْزَلْتَهٗ فِيْ كِتَابِكَ اَوْ اَثْبَتَّهٗ فِيْ قُلُوْبِ الصَّافِّيْنَ الْحَافِّيْنَ حَوْلَ عَرْشِكَ فَتَرَاجَعَتِ الْقُلُوْبُ اِلَى الصُّدُوْرِ عَنِ الْبَيَانِ بِاِخْلَاصِ الْوَحْدَانِيَّةِ وَتَحْقِيْقِ الْفَرْدَانِيَّةِ مُقِرَّةً لَكَ بِالْعُبُوْدِيَّةِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlu