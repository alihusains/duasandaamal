[{"Id": 1014782, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Yunus has reported that whitish scales between the eyes affected him. He therefore complained about this disease to Imam Sadiq (a) who, leading him to a treatment, said: You may pure yourself ceremonially, offer a two-unit prayer, and say this (supplicatory prayer)…", "GujaratiDescription": null, "RUrduDescription": "Yunus ka bayaan hai keh meri aankho’n ke darmiyaan bars ki safaidi zaahir huwi to mai ne uski shikaayat Imam Jafar Sadiq (a) se ki to Aap (a) ne farmaaya wuzu kar ke 2 rakat namaz padho aur phir kaho…", "UrduDescription": "یونس کا بیان ہے : میری آنکھوں کے درمیان برص کی سفیدی ظاہر ہوئی تو میں نے اس کی شکایت امام جعفر صادق ؑ سے کی تو آپ نے فرمایا: وضو کر کے دو رکعت نماز پڑھ کر کہو۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014783, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! O All-beneficent! O All-merciful! O Hearer of prayers! O Donor of the good! (Please) give me the good of this world and the good of the Hereafter, protect me against the evil of this world and the evil of the Hereafter, and remove from me what I am facing, for this matter has enraged and saddened me.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah, ay bade rahem waale maher-baan, ay duaawo’n ke soonne waale, ay bhalaaiya’n ataa karne waale, mujhe duniya o aakherat mein bhalaayi ataa farma aur mujhe duniya o aakherat ke shar o buraayi se bacha le, meri woh bimaari dur kar jisey mehsoos karta hu, us ne mera kaam kharaab kiya aur gham-khwaar kiya.", "Urdu": "اے اللہ اے بڑے رحم والے مہر بان اے دعاؤں کے سننے والےاے بھلائیاں عطا کرنے والے مجھے دنیا اور آخرت میں بھلائی عطا فرما اور مجھے دنیا وآخرت کے شر اوربرائی سے بچا لے میری وہ بیمار ی دور کر جسے محسوس کرتا ہوں اس نے میرا کام خراب کیا اور غمگین کردیا۔", "RArabic": "YAA ALLAAHO YAA RAHMAANO YAA RAHEEMO YAA SAMEE-A’D DA-A’WAATE YAA MO’TE-YAL KHAIRAA-TE A’TE-NEE KHAIRAD DUNYAA WA KHAIRAL AAKHERA-TE WA-QENEE SHARRAD DUNYAA WA SHARRAL AAKHE-RATE WA AZHIB A’NNEE MAA AJEDO FA-QAD GHAAZA-NIL AMRO WA AHZANA-NEE.", "ArabicText1": "يَا اَللهُ يَا رَحْمٰنُ يَا رَحِيْمُ يَا سَمِيْعَ الدَّعَوَاتِ يَا مُعْطِىَ الْخَيْرَاتِ اَعْطِنِىْ خَيْرَ الدُّنْيَا وَخَيْرَ الْآخِرَةِ وَقِنِىْ شَرَّ الدُّنْيَا وَشَرَّ الْآخِرَةِ وَاَذْهِبْ عَنِّىْ مَا اَجِدُ فَقَدْ غَاضَنِى الْاَمْرُ وَاَحْزَنَنِىْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "Ara