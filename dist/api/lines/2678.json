[{"Id": 1002191, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Ibn Ayyash has reported Husain ibn Ali ibn Sufyan al-Bazufi as saying that he heard Imam Ja’far Sadiq (a) saying this dua on 3rd of Shaban. Imam Hussain (a) has said this dua when his enemies surrounded him in large numbers on the Day of ‘Ashura (10th of Muharram)…", "GujaratiDescription": null, "RUrduDescription": "Ibn Ayyas ne Husain ibn Ali ibn Sufyan al-Bazufi naql ki hai keh unho ne Imam Jafar Sadiq (a) ko soona keh woh is dua ko 3rd Shaban ke roz padhte thay. Imam Husain (a) ne is dua ko Roze Ashura padha tha jab dushman unhe ghere huwe thay…", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002192, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, You are verily the Elevated in position, the Magnificent in omnipotence, the Mighty in prowess, the Self-Sufficient from the creatures, the Ample in pride, the Powerful over all that which You want, the Close in mercy, the Truthful in promise, the Opulent in favors, the Sympathetic in ordeals, the Nigh when Your are prayed, the All-encompassing of all that which You have created, the Accepter of the repentance of him who repents to You, the Powerful to do whatever You want, the Taker in all that which You decide, the Thankful for those who thank You, and the Rememberer of those who mention You.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Tu buland-tar manzelat rakhta hai Tu bade hi ghalbe waala hai, zabardast taaqat waala, makhluqaat se be-neyaaz, be-had wa hisaab badaayi waala hai jo chaahe us par qaadir, rehmat karne mein qareeb, waade mein sachcha, kaamil neymato’n waala, behtareen aazmaaish karne waala hai Tu qareeb hai jab pukaara jaaye jisko paiyda kiya to usey ghere huwe hai Tu uski taubah qabool karta hai jo taubah kare. Tu jo iraada kare us par qaadir hai jise Tu talab kare usey paalne waala hai aur jab Tera shukr kiya jaaye Tu qadar karta hai.", "Urdu": "اے معبود! تو بلند تر منزلت رکھتا ہے تو بڑے ہی غلبے والا ہے زبردست طاقت والا، مخلوقات سے بے نیاز، بے حد و حساب بڑائی والاہے جو چاہے اس پر قادر، رحمت کرنے میں قریب، وعدے میں سچا، کامل نعمتوں والا، بہترین آزمائش کرنے والاہے تو قریب ہے جب پکارا جائے جس کو پیدا کیا تو اسے گھیرے ہوئے ہے تو اس کی توبہ قبول کرتا ہے جو توبہ کرے تو جو ارادہ کرے اس پر قادر ہے جسے تو طلب کرے اسے پالینے والا ہے اور جب تیرا شکر کیا جائے تو قدر کرتا ہے۔", "RArabic": "ALLAAHUMMA ANTA MOTA-AA’LIL MAKAANE A’ZEE-MUL JABAROO-TE SHADEE-DUL ME-HAALE GHANIY-YOON A’NIL KHALAA-E-QE A’REE-ZUL KIBRE-YAA-E QAADE-ROON A’LAA TASHAA-O QAREE-BUR RAHMATE SAADE-QUL WA’DE SAABE-GHUN NE’MATE HASA-NUL BALAA-E QAREE-BOON EZAA DO-EE’TA MOHEE-TOON BE-MAA KHALAQ-TA QAABE-LUT TAWBA-TE LE-MAN TAABA ILAIKA QAADE-ROON A’LAA MAA ARAD-TA WA MUDRE-KOON MAA TALAB-TA WA SHAKOO-ROON IZAA SHOKIR-TA WA ZAKOO-ROON IZAA ZOKIR-TA.", "ArabicText1": "اَللّٰهُمَّ اَنْتَ مُتَعَالِي الْمَكَانِ عَظِيْمُ الْجَبَرُوْتِ شَدِيْدُ الْمِحَالِ غَنِيٌّ عَنِ الْخَلَائِقِ عَرِيْضُ الْكِبْرِيَاءِ قَادِرٌ عَلٰى مَا تَشَاءُ قَرِيْبُ الرَّحْمَةِ صَادِقُ الْوَعْدِ سَابِغُ النِّعْمَةِ حَسَنُ الْبَلَاءِ قَرِيْبٌ اِذَا دُعِيْتَ مُحِيْطٌ بِمَا خَلَقْتَ قَابِلُ التَّوْبَةِ لِمَنْ تَابَ اِلَيْكَ قَادِرٌ عَلٰى مَا اَرَدْتَ وَمُدْرِكٌ مَا طَلَبْتَ وَشَكُوْرٌ اِذَا شُكِرْتَ وَذَكُوْرٌ اِذَا ذُكِرْتَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002193, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I pray You for I need You, I desire for You for I am in want of You, I resort to You for I am terrified, I weep before You for I am distressed, I seek Your aid for I am weak, and I depend upon You for I trust in none save You. (Please do) decide between our people and us with the truth, for they have deceived us, cheated us, disappointed us, betrayed us, and killed us.", "Gujarati": null, "RGujarati": null, "RUrdu": "Tujhe yaad kiya jaaye Tu bhi yaad karta hai, mai haajat-mand, mai Tujhe pukaarta aur muflisi mein Teri raghbat karta hu Tere khouf se ghabraata hu museebat mein Tere aaghe rota hu kamzori ke baais Tujh se madad maangta hu Tujhe kaafi jaan kar, tawakkul karta hu faisle kar de hamare aur hamari qaum ke darmiyaan keh unho ne hamein fareb diya aur ham se dhoka kiya, hamein chhod diya aur be-wafaayi ki aur hamein qatl kiya.", "Urdu": "تجھے یاد کیا جائےتو بھی یاد کرتا ہے میں حاجت مندی میں تجھے پکارتا اور مفلسی میں تیری رغبت کرتا ہوں تیرے خوف سے گھبراتا ہوں مصیبت میں تیرے آگے روتا ہوں کمزوری کے باعث تجھ سے مدد مانگتا ہوں تجھے کافی جان کر توکل کرتا ہوں فیصلہ کردے ہمارے اور ہماری قوم کے درمیان کہ انہوں نے ہمیں فریب دیا اور ہم سے دھوکہ کیا ہمیں چھوڑدیا اور بے وفائی کی اور ہمیں قتل کیا۔", "RArabic": "AD-OO’KA MOHTAA-JAN WA AR-GHABO ILAIKA FAQEE-RAN WA AFZA-O’ ILAIKA KHAA-E-FAN WA ABKEE ILAIKA MAKROO-BAN WA ASTA-EE’NO BEKA ZA-EE’FAN WA ATA-WAKKALO A’LAIKA KAAFE-YAN AH-KUM BAIYNA-NAA WA BAIYNA QAWME-NAA FA INNA-HUM GHARROO-NAA WA KHADA-OO’NAA WA KHAZA-LOO-NAA WA GHADAROO-BE-NAA WA QATALOO-NAA WA NAHNO I’T-RATO NABIYYE-KA.", "ArabicText1": "اَدْعُوْكَ مُحْتَاجًا وَاَرْغَبُ اِلَيْكَ فَقِيْرًا وَاَفْزَعُ اِلَيْكَ خَائِفًا وَاَبْكِيْ اِلَيْكَ مَكْرُوْبًا وَاَسْتَعِيْنُ بِكَ ضَعِيْفًا وَاَتَوَكَّلُ عَلَيْكَ كَافِيًا اَحْكُمْ بَيْنَنَا وَبَيْنَ قَوْمِنَا فَاِنَّهُمْ غَرُّوْنَا وَخَدَعُوْنَا وَخَذَلُوْنَا وَغَدَرُوْا بِنَا وَقَتَلُوْنَا وَنَحْنُ عِتْرَةُ نَبِيِّكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002194, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "We are the progeny of Your Prophet and the sons of Your beloved one; namely, Muhammad the son of Abdullah, whom You have chosen for the Divine Mission and for keeping Your Revelation. So, (please) prepare a way out and a relief for us, out of Your mercy, O most Merciful of all those who show mercy!", "Gujarati": null, "RGujarati": null, "RUrdu": "Jab keh Tere Nabi (s) ka gharaana aur Tere Habib Muhammad (s.a.w.a) bin Abdullah ki aulaad hai jin ko Tu ne tableeghe risaalat ke liye choona aur unhe apni wahi ka ameen banaaya. Pas us maamle mein hamein kushaadgi aur faraakhi de apni rehmat se, ay sabse ziyaada rahem waale.", "Urdu": "جب کہ ہم تیرے نبیؐ کا گھرانہ اور تیرے حبیب محمدؐ ابن عبداللہ کی اولاد ہیں جن کو تو نے تبلیغِ رسالت کے لئے چنا اور انہیں اپنی وحی کا امین بنایا پس اس معاملے میں ہمیں اپنی رحمت سے کشادگی اور آسائش دے اے سب سے زیادہ رحم کرنےوالے۔", "RArabic": "WA WALADO HABEEBE-KA MOHAMMADIB NE A’BDIL LAAHIL LAZEE ASTA-FAIYTA-HU BIR-RESAALA-TE WA-TAMANTA-HU A’LAA WAHYE-KA FAJ-A’L LANAA MIN AMRE-NAA FARA-JAN WA MAKHRA-JAN BE-RAHMATE-KA YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "وَ وَلَدُ حَبِيْبِكَ مُحَمَّدِ بْنِ عَبْدِ اللهِ الَّذِيْ اَصْطَفَيْتَهٗ بِالرِّسَالَةِ وَائْتَمَنْتَهٗ عَلٰى وَحْيِكَ فَاجْعَلْ لَنَا مِنْ اَمْرِنَا فَرَجًا وَمَخْرَجًا بِرَحْمَتِكَ يَا اَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null,