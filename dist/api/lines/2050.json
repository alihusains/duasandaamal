[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1018615, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah I seek Your refuge from that I abhor enmity of Your friends and I befriend Your enemies or I agree to Your eternal chastisement. O Allah I pray for Your mercy on those whom You has bestowed Your favours and my curses on him whom You curse. O Allah grant me safety from the one, on whose death there is happiness and the believers are at rest and grant us something good in exchange of it, so that whatever we know about Your acceptance of supplication, we can witness it with our eyes, O most merciful of all the mercifuls.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ya Allah! Mai Tujh se us baat ki panah maangta hu keh Tere kisi Wali se dushmani ya Tere kisi dushman se dosti karu ya Teri daaemi (hamesha rehne waali) na-raazgi par raazi ho jaawu. Khuda wanda! Jin par Tu ne rehmat naazil ki hai, mai bhi unke liye dua o talab’e rehmat karta hu, aur jis par Tu ne laanat ki hai hamaari laanate’n bhi un par ho. Khuda wanda! Jis ki maut se khushi ho aur tamaam’e momino ko raahat naseeb ho. Tu hamein us se dili sukoon ataa farma, aur hamein us ke badle mein hamare liye us se behtar ataa farma. Ta-keh ham Teri qabooliyat’e dua ke baare mein jis qadar jaante hai usey apne deen o dunya mein aankho’n se dekh bhi le.", "Urdu": "یا اللہ! میں تجھ سے اس بات کی پناہ مانگتا ہوں کہ تیرے کسی ولی سے دشمنی یا تیرے کسی دشمن سے دوستی کروں یا تیری دائمی ناراضگی پر راضی ہو جاؤں۔ خدا وندا! جن پر تونے رحمت نازل کی ہے، میں بھی ان کے لئے دعا و طلب رحمت کرتا ہوں اور جس پر تونے لعنت کی ہے ہماری لعنتیں بھی ان پر ہوں۔ خدا وندا! جس کی موت سے خوشی ہو اور تمام مومنوں کو راحت نصیب ہو، تو ہمیں اسے دلی سکون عطا فرما، اور ہمیں اس کے بدلے میں ہمارے لئے اس سے بہتر عطا فرما تا کہ ہم تیری قبولیت دعا کے بارے میں جس قدر جانتے ہیں اسے اپنی دین و دنیا میں آنکھوں سے دیکھ بھی لیں۔", "RArabic": "SORRY NOT AVAILABLE", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَعُوْذُ بِكَ اَنْ اُعَادِیْ لَكَ وَلِیًّا اَوْ اُوَالِیْ لَكَ عَدُوًّا وَاَرْضٰی لَكَ سَخْطًا اَبَدًا۔ اَللّٰهُمَّ مَنْ صَلَّیْتَ عَلَیْهِ فَصَلَوَاتُنَا عَلَیْهِ وَمَنْ لَعَنْتَۃُ فَلَعْنَتُنَا عَلَیْهِ۔ اَللّٰهُمَّ مَنْ كَانَ فِیْ مَوْتِهٖ فَرَحٌ وَلِجَمِیْعِ الْمُؤْمِنِیْنَ فَاَرِحْنَا وَاَبْدَلْنَا بِهٖ مَنْ هُوَ خَیْرٌ لَنَا مِنْهُ حَتّٰی تَرِیَنَا مِنْ عِلْمِ الْاِجَابَۃِ مَا تَعْرِفُهٗ فِیْ اَدْیَانِنَا وَمَعَایِشِنَا یَا اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": 