AFIYATIN WAJALANII MIN WAFDIKA-LLAZII RAZAITA WASAMMAITA WAKATABA.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَسْئَلُكَ اَنْ تَجْعَلَنِیْ مِمَّن اسْتَجَابَ لَكَ وَآمَنَ بِوَعْدِكَ وَاتَّبَعَ اَمْرَكَ فَاِنِّیْ عَبْدُكَ وَفِیْ قَبْضَتِكَ لَا اُوْقٰی اِلَّا مَا وَقَیْتَ وَلَا آخُذُ اِلَّا مَا اَعْطَیْتَ وَقَدْ ذَكَرْتَ الْحَجَّ فَاَسْئَلُكَ اَنْ تَعْزِمَ لِیْ عَلَیْهِ عَلٰی كِتَابِكَ وَسُنَّۃِ نَبِیِّكَ صَلَوَاتُكَ عِلَیْهِ وَآلِهٖ وَتُقَوِّیَنِیْ عَلٰی مَا ضَعُفْتُ عَنْهُ وَتُسَلِّمَ مِنِّیْ مَنَاسِكِیْ فِیْ یُسْرٍ مِنْكَ وَعَافِیَۃٍ وَاجْعَلْنِیْ مِنْ وَفْدِكَ الَّذِیْ رَضِیْتَ وَارْتَضَیْتَ وَسَمَّیْتَ وَكَتَبْتَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016068, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! I have traveled from far and have spent my property to attain Your pleasure. O Allah! Accomplish my hajj and Umrah. O Allah! In compliance with Your book and the practice of Your Prophet (s.a.w.a), I intend to perform the Umrat-e-Tamatu for Hajj. If any impediment comes in my way, remove it by Your power.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": "ALLAHUMMA INNI KHARAJTU MIN SHUQQATIN BAIIDATIN WAANFAQTU MALIYA-BTIGAA MARAZAATIK. ALAHUMMA FATAMIM LII HAJATII WAUMRATII. ALLAHUMMA INNI URIIDU LAMATTUA BILUMRATI ILA-IHAJJI ALA KITABIKA WASUNNATI NABIYYIKA SALWATUKA ALAIHI WAALEHI FAIN ARAZA LII AARIZUN YAHBISUNJI FAKHALLINII HAISU HABASTANII BIQADARIKA-LLAZII QADDARTA ALAYA.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ خَرَجْتُ مِنْ شُقَّۃٍ بَعِیْدَۃٍ وَاَنْفَقْتُ مَالِیْ اِبْتِغَآئَ مَرْضَاتِكَ۔ اَللّٰهُمَّ فَتَمِّمْ لِیْ حَجَّتِیْ وَعُمْرَتِیْ۔ اَللّٰهُمَّ اِنِّیْ اُرِیْدُ التَّمَتُّعَ بِالْعُمْرَۃِ اِلَی الْحَجِّ عَلٰی كِتَابِكَ وَسُنَّۃِ نَبِیِّكَ صَلَوَاتُكَ عَلَیْهِ وَآلِهٖ فَاِنْ عَرَضَ لِیْ عَارِضٌ یَحْبِسُنِیْ فَحَلَّنِیْ حَیْثُ حَبَسْتَنِیْ بِقَدَرِكَ الَّذِیْ قَدَّرْتَ عَلَیَّ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSi