rabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1007698, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 5, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "That He may cause the believing men and the believing women to enter gardens beneath which rivers flow to abide therein and remove from them their evil; and that is a grand achievement with Allah;", "Gujarati": null, "RGujarati": null, "RUrdu": "Ta-keh momin mard aur momina aurto’n ko un Jannato’n mein daakhil kar de jinke neeche nehre jaari hai woh unhi mein hamesha rahe aur unki buraaiyo’n ko un se dur kar de aur yahi Allah ke nazdeek azeem-tareen kaam-yaabi hai.", "Urdu": "تاکہ مومین مرد اور مومنہ عورتوں کو ان جنتوں میں داخل کر دے جن کے نیچے نہریں جاری ہیں وہ ان ہی میں ہمیشہ رہیں اور ان کی برائیوں کو ان سے دور کر دے اور یہی اللہ کے نزدیک عظیم ترین کامیابی ہے۔", "RArabic": "LIYUDKHILAL MU’MINEENA WALMU’MINAATI JANNAATIN TAJREE MIN TAHTIHAL ANHAARU KHAALIDEENA FEEHAA WA YUKAFFIRA ’ANHUM SAIYI AATIHIM; WA KAANA ZAALIKA ’INDAL LAAHI FAWZAN ’AZEEMAA.", "ArabicText1": "لِيُدْخِلَ الْمُؤْمِنِيْنَ وَالْمُؤْمِنٰتِ جَنَّاتٍ تَجْرِيْ مِنْ تَحْتِهَا الْاَنْهٰرُ خٰلِدِيْنَ فِيْهَا وَيُكَفِّرَ عَنْهُمْ سَيِّاٰتِهِمْ", "ArabicGreenSign1": null, "ArabicRedSign1": "ط ", "ArabicBlueSign1": null, "ArabicText2": "وَكَانَ ذٰلِكَ عِنْدَ اللهِ فَوْزًا عَظِيْمًا", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSi