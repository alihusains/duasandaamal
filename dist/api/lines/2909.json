[{"Id": 1012757, "EnglishTitle": "Hujr-e-Ismaeel", "GujaratiTitle": null, "RUrduTitle": "Hujr-e-Ismaeel", "UrduTitle": "حجر اسماعیل (ع)", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012758, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "It is at a distance from the area between Northern and western pillar. There are graves of Ismaeel (a), his respected mother Hajra (s) and many prophets other narrations prove that there are graves of many prophets around Kaba. We perform their Ziyarat also. It is recommended to wear Ehraam for Hajj-e-Tamatto in Hujr-e-Ismaeel on ’Mizab’ below the canal. It is the place to supplicate, repent and seek mercy and desires.", "GujaratiDescription": null, "RUrduDescription": "Masjidul Haraam mein Khaana-e-Kaaba se mutasil (Rukn-e-Gharbi aur Rukn-e-Shumaali ke darmiyaan) Hazrat Ismaeel (a) ka ghar hai jis mein Hazrat Ismaeel (a), unki waaleda Janabe Haajra (s) aur bohot se Ambiya ki qabre’n hai. Riwaayat ke mutaabiq Khaana-e-Kaaba ke eteraaf mein bohot se Ambiya ki qabre’n hai, usi maqaam par unki ziyarat bhi kare. Hajj-e-Tamatto ke liye Meezaab-e-Rehmat o haajat ki jagah hai.", "UrduDescription": "مسجد الحرام میں خانہ کعبہ سے متصل (رکن غربی اور رکن شمالی کے درمیان) حضرت اسماعیلؑ کا گھر ہے جس میں حضرت اسماعیلؑ، ان کی والدہ جناب ہاجرہؑ اور بہت سے انبیاء کی قبریں ہیں۔ روایات کے مطابق خانہ کعبہ کے اطراف میں بہت سے انبیاء کی قبریں ہیں، اسی مقام پر ان کی زیارت بھی کرے۔ حج تمتع کے لئے میزاب رحمت کے نیچے حجر اسماعیل میں محرم ہونا مستحب ہے کہ یہ جگہ توبہ و استغفار اور طلب رحمت و حاجت کی جگہ ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012759, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "Ziyarat of Prophet Ismaeel (a) and Hajra (s) in Hujr-e-Ismaeel (a)…", "GujaratiDescription": null, "RUrduDescription": "Hujar-e-Ismaeel (a) mein Hazrat Ismaeel (a) aur Hazrat Haajra (s) ki ziyarat…", "UrduDescription": "حجر اسماعیل میں جناب اسماعیلؑ اور حضرت ہاجرہؑ کی زیارت۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012760, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho hamare sardaar Janabe Ismaeel zabeehullah (a.s) par jo Hazrat Ibrahim Khaleelullah (a.s) ke farzand hai. Salaam ho aap par ay Allah ke nabi aur nabi ke bete. Aap par salaam ho ay Allah ke muntakhab aur Uske muntakhab bande ke farzand. Salaam ho aap par ay woh hasti jiske liye Allah ne Zamzam ke kuwe (well) ko taabe kar diya jab unke waalid ne unko zara’at se khaali waadi (valley) mein Allah ke mohtaram ghar ke nazdik saakin kiya.", "Urdu": "سلام ہو ہمارے سردار جناب اسماعیل ذبیح اللہ پر جو حضرت ابراہیم خلیل اللہ کے فرزند ہیں۔ سلام ہو آپ پر اے اللہ کے نبی اور نبی کے بیٹے، آپ پر سلام ہو اے اللہ کے منتخب اور اس کے منتخب بندے کے فرزند، سلام ہو آپ پر اے وہ ہستی جس کے لئے اللہ نے زمزم کے کنویں کو تابع کر دیا جب ان کے والد نے ان کو زراعت سے خالی وادی (زمین) میں اللہ کے محترم گھر کے نزدیک ساکن کیا۔", "RArabic": "ASSALAAMO A’LAA SAYYEDENAA ISMAA-E’ELA ZABEEHIL LAAHIB NE IBRAAHEEMA KHALEELIL LAAHE ASSALAAMO A’LAIKA YAA NABIYYAL LAAHE WABNA NABIYYEHI ASSALAAMO A’LAIKA YAA SAFIYYAL LAAHE WABNA SAFIYYEHI ASSALAAMO A’LAIKA YAA MAN ATBA-A’L LAAHO LAHU BEARA ZAMZAMA HEENA ASKANAHU ABOOHO BEWAADIN GHAYRE ZEE ZAR-I’N I’NDA BAYTIL LAAHIL MOHARRAME.", "ArabicText1": "اَلسَّلَامُ عَلٰی سَیِّدِنَا اِسْمَاعِیْلَ ذَبِیْحِ اللهِ ابْنِ اِبْرَاہِیْمَ خَلِیْلِ اللهِ۔ اَلسَّلَامُ عَلَیْكَ یَا نَبِیَّ اللهِ وَابْنَ نَبِیِّہٖ۔ اَلسَّلَامُ عَلَیْكَ یَا صَفِیَّ اللهِ وَابْنَ صَفِیِّہٖ۔ اَلسَّلَامُ عَلَیْكَ یَا مَنْ اَتْبَعَ اللهُ لَہٗ بِئْرَ زَمْزَمٍ حِیْنَ اَسْكَنَہٗ اَبُوْہُ بِوَادٍ غَیْرِ ذِیْ زَرْعٍ عِنْدَ بَیْتِ اللهِ الْمُحَرَّمِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012761, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Aur us mein unke baare mein Janabe Ibrahim (a.s) ki dua qabool ki, jab unho ne kaha: “Ay mere Parwardigaar! Mai ne apni zurriyat ko zara’at se khaali waadi (Makkah) mein Tere mohtaram ghar ke paas thaira liya hai ta keh yeh log namaz qaaem kare, to ay Allah! Logo’n ke dilo’n ko unki taraf jhukne waala qaraar de aur unhe phalo’n (fruits) ki rozi ataa kar ta keh woh Tera shukr adaa kare.”", "Urdu": "اور اس میں ان کے بارے میں جناب ابراہیلؑ کو دُعا قبول کی، جب انہوں نے کہا، اے میرے بروردگار میں نے اپنی ذرّیت کو زراعت سے خالی وادی (مکہ) میں تیرے محترم گھر کے پاس ٹھرا لیا ہے تا کہ یہ لوگ نماز قائم کریں، تو اے اللہ! لوگاں کے دلوں کو ان کی طرف جھکنے والا قرار دے اور انہیں پھلوں کی روزی عطا کر تا کہ وہ تیرا شکر ادا کریں۔", "RArabic": "WAS TAJAABAL LAAHO FEEHE DA’WATA ABEEHE IBRAAHEEMA HEENA QAALA: \"RABBANAA INNEE ASKANTO MIN ZURRIYYATEE BEWAADIN GHAYRE ZEE ZAR-I’N I’NDA BAYTEKAL MOHARRAME RABBANAA LEYOQEEMUS SALAATA FAJ-A’L AF-EDATAN MENAN NAASE TAHWEE ELAYHIM WAR ZUQHUM MENAS SAMARAATE LA-A’LLAHUM YASHKOROONA.\"", "ArabicText1": "وَاسْتَجَابَ اللهُ فِیْہِ دَعْوَۃَ اَبِیْہِ اِبْرَاہِیْمَ حِیْنَ قَالَ: رَبَّنَا اِنِّیْ اَسْكَنْتُ مِنْ ذُرِّیَّتِیْ بِوَادٍ غَیْرِ ذِیْ زَرْعٍ عِنْدَ بَیْتِكَ الْمُحَرَّمِ رَبَّنَا لِیُقِیْمُوْا الصَّلٰوۃَ فَاجْعَلْ اَفْئِدَۃً مِّنَ النَّاسِ تَہْوِیْ اِلَیْہِمْ وَارْزُقْہُمْ مِنَ الثَّمَرَاتِ لَعَلَّہُمْ یَشْكُرُوْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012762, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay woh hasti jis ne khud ko zibah ke liye Allah ke hukm ki ita’at ke liye supurd kar diya jab unke waalid ne un se yeh farmaya: “Mai khwaab mein dekh raha hu keh mai tum ko zibah kar raha hu, tum ghour karo tumhaara kya khayaal hai?” To unke farzand ne farmaya: “Ay Pidar’e buzurg-waar aap ko jo hukm diya ja raha hai usey pura kare, aap mujhe inshallah saabereen mein paayenge.” To Allah be un se zibah ko dur kar diya aur unka fidya zibahe azeem qaraar diya.", "Urdu": "سلام ہو آپ پر اے وہ ہستی جس نے خود کو ذبح کے لئے اللہ کے حکم کی اطاعت کے لئے سپرد کر دیا جب ان کے والد نے ان سے یہ فرمایا: میں خواب میں دیکھ رہا ہوں کہ میں تم کو ذبح کر رہا ہوں، تم غور کرو تمھارا کیا خیال ہے، تو ان کے فرزند نے فرمایا: اے بدر بزرگوار آپ کو جو حکم دیا جا رہا ہے اسے کر ڈالئے، آپ مجھے انشاء اللہ صابرین میں پائیں گے۔ تو اللہ نے ان سے ذبح کو دور کر دیا اور ان کا فدیہ ذبح عظیم قرار دیا۔", "RArabic": "ASSALAAMO A’LAIKA YAA MAN SALLAMA NAFSAHU LIZ-ZABEEHE TAA-A’TAN LE-AMRIL LAAHE TA-A’ALAA IZ QAALA LAHU ABOOHO: \"INNEE ARAA FIL MANAAME ANNEE AZBAHOKA FAN-ZUR MAA ZAA TARAA QAALA YAA ABATIF A’L MAA TOAMARO SATAJEDONEE IN SHAAA-AL LAAHO MENAS SAABEREENA.\" FA-DAFA-A’L LAAHO A’NHUZ ZIBHA WA FADAAHO BE-ZIBHIN A’ZEEME.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا مَنْ سَلَّمَ نَفْسَہٗ لِلذِّبْحِ طَاعَۃً لِاَمْرِ اللهِ تَعَالٰی اِذْ قَالَ لَہٗ اَبُوْہُ: اِنِّیْ اَرٰی فِی الْمَنَامِ اَنِّیْ اَذْبَحُكَ فَانْظُرْ مَا ذَا تَرٰی قَالَ یَا اَبَتِ افْعَلْ مَا تُؤْمَرُ سَتَجِدُنِیْ اِنْ شَآئَ اللهُ مِنَ الصَّابِرِیْنَ۔ فَدَفَعَ اللهُ عَنْہُ الذِّبْحَ وَفَدَاہُ بِذِبْحِ عَظِیْمِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012763, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay woh hasti jinho ne Kaaba ko bana ne mein apne baap ki madad ki, jaisa keh Allah ne farmaaya hai: “Aur us waqt ko yaad karo jab Ibrahim (a.s) aur Ismaeel (a.s) ghar ki bunyaad buland kar rahe thay to unho ne dua ki: Ay hamare Parwardigaar! Tu hamari is khidmat ko qabool kar le.”", "Urdu": "سلام ہو آپ پر اے وہ ہستی جنہوں نے کعبہ کو بنا نے میں اپنے باپ کی مدد کی، جیسا کہ اللہ نے فرمایا ہے: اور اس وقت کو یاد کرو جب ابراہیمؑ اور اسماعیلؑ گھر کی بنیاد بلند کر رہے تھے تو انہوں نے دعا کی: اے ہمارے پروردگار! تو ہماری اس خدمت کو قبول کر لے۔", "RArabic": "ASSALAAMO A’LAIKA YAA MAN A-A’ANA ABAAHO A’LAA BENAA-IL KA’BATE KAMAA QAALAL LAAHO TA-A’ALAA: \"WA IZ YARFA-O’ IBRAAHEEMUL QAWAA-E’DA MENAL BAYTE WA ISMAA-E’ELO RABBANAA TAQABBAL MINNAA INNAKA ANTAS SAMEE-U’L A’LEEMO\".", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا مَنْ اَعَانَ اَبَاہُ عَلٰی بِنَائِ الْكَعْبَۃِ كَمَا قَالَ اللهُ تَعَالٰی: وَاِذْ یَرْفَعُ اِبْرَاہِیْمُ الْقَوَاعِدَ مِنَ الْبَیْتِ وَاِسْمٰعِیْلُ رَبَّنَا تَقَبَّلْ مِنَّا اِنَّكَ اَنْتَ السَّمِیْعُ الْعَلِیْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012764, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Aap par salaam ho ay woh hasti jis ki Allah taala ne apni kitaab mein is tarah madah (taarif) ki hai: “Aur kitaab (Qur’an) mein tum Ismaeel (a.s) ko yaad karo who waada ke sachche thay aur rasool aur nabi thay, aur apne ghar waalo’n ko namaz aur zakaat ka hukm dete thay aur apne Parwardigaar ke nazdik pasandidah thay.”", "Urdu": "آپ پر سلام ہو اے وہ ہستی جس کی اللہ تعالٰی نے اپنی کتاب میں اس طرح مدح کی ہے: اور کتاب (قرآن) میں تم اسماعیل کو یاد کرو وہ وعدہ کے سچے تھے اور رسول اور نبی تھے، اور اپنے گھر والوں کو نماز اور زکوٰۃ کا حکم دیتے تھے اور اپنے پروردگار کے نزدیک پسندیدہ تھے۔", "RArabic": "ASSALAAMO A’LAIKA YAA MAN MADAHAHUL LAAHO TA-A’ALAA FEE KETAABEHI BEQAWLEHI: \"WAZ KUR FIL KETAABE ISMAA-E’ELA INNAHU KAANA SAADEQAL WA’DE WA KAANA RASOOLAN NABIYYAN WA KAANA YAAMORO AHLAHU BIS-SALAATE WAZ ZAKAATE WA KAANA I’NDA RABBEHI MARZIYYAN.\"", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا مَنْ مَدَحَہُ اللهُ تَعَالٰی فِیْ كِتَابِہٖ بِقَوْلِہٖ: وَاذْكُرْ فِی الْكِتَابِ اِسْمٰعِیْلَ اِنَّہٗ كَانَ صَادِقَ الْوَعْدِ وَكَانَ رَسُوْلًا نَبِیًّا وَكَانَ یَاْمُرُ اَھْلَہٗ بِالصَّلٰوۃِ وَالزَّكٰوۃِ وَكَانَ عِنْدَ رَبِّہٖ مَرْضِیًّا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlue