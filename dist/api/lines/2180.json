[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011712, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah open for us the treasures of your mercy. Give us compassion O Allah. Do not punish us in this world and the hereafter. Provide us from your abundant bounties a pure and good livelihood and let us not be in need or want of anyone other than you. Increase our thankfulness to you, turn to you in need and want and be prosperous without the help of anyone except you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Apni rehmato’n ke khazaane ham par khol de, aur ay Parwardigaar, hamein us rehmat se sarfaraaz farma keh jiske baad dunya o aakherat mein hamein azaab na aaye, aur apne Wasee o areez fazl se paak aur halaal rizq ataa farma, aur hamein siwaaye apni zaat ke kisi ka mohtaaj na karna. Ay Parwardigaar! Hamein shukr baja laane ki taufeeq ataa farma aur hamari mohtaaji aur neyaaz-mandi aur ghair se be-neyaazi aur izzat'e nafs mein izaafah farma.", "Urdu": "اے پروردگار! اپنی رحمتوں کے خزانے ہم پر کھول دے، اور اے پروردگار ہمیں اس رحمت سے سرفراز فرما کہ جس کے بعد دنیا و آخرت میں ہمیں عذاب نہ آئے، اور اپنے وسیع و عریض فضل سے پاک اور حلال رزق عطا فرما، اور ہمیں سوائے اپنی ذات کے کسی کا محتاج نہ کرنا۔ ے پروردگار! ہمیں شکر بجا لانے کی توفیق عطا فرما اور ہماری محتاجی اور نیاز مندی اور غیر سے بے نیازی اور عزّت نفس میں اضافہ فرما۔", "RArabic": "ALLAAHUMMAF TAH LANAA KHAZAA-ENA RAHMATEKA, WA HAB LANAL LAAHUMMA RAHMATAN LAA TO-A’ZZEBONAA BA’DAHAA FID DUNYAA WAL AAKHERATE, WAR ZUQNAA MIN FAZLEKAL WAASE-E’ RIZQAN HALAALAN TAYYEBAN, WA LAA TOHWIJNAA, WA LAA TUFQIRNAA ELAA AHADIN SEWAAKA, WA ZIDNAA BE-ZAALEKA SHUKRAN WA ELAYKA FAQRAN WA FAAQATAN, WA BEKA A’MMAN SEWAAKA GHENAN WA TA-A’FFOFAN.", "ArabicText1": "اَللّٰہُمَّ افْتَحْ لَنَا خَزَاۗئِنَ رَحْمَتِکَ، وَہَبْ لَنَا اللّٰہُمَّ رَحْمَۃً لَا تُعَذِّبُنَا بَعْدَہَا فِی الدُّنْیَا وَالْآخِرَۃِ، وَارْزُقْنَا مِنْ فَضِلِکَ الْوَاسِعِ رِزْقًا حَلَالًا طَیِّبًا، وَلَا تُحْوِجْنَا وَلَا تُفْقِرْنَا اِلٰی اَحَدٍ سِوَاکَ، وَزِدْنَا بِذٰلِکَ شُکْرًا، وَاِلَیْکَ فَقْرًا وَفَاقَۃً، وَبِکَ عَمَّنْ سِوَاکَ غِنًی وَتَعَفُّفًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011716, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah be generous to us in this world, surely we seek refuge with you from circumstances when you would turn away your face from us as we only ask from you. O Allah send your blessings on Muhammad and on the family of Muhammad and give us what you love and make it a source of strength for us, O the most merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Parwardigaar! Dunya mein hamare liye wus’at qaraar de. Ay Parwardigaar! Is haal mein keh ham Tere deedaar ke taalib hai, ham panah maangte hai keh Tu ham se rukh moude jab keh ham Tere deedaar ke taalib hai. Muhammad (s.a.w.a) wa Aale Muhammad (a.s) par durood bhej, aur apni pasandida cheez hamein ataa farma, aur usko hamare liye quwwat bana jis tarah ham chahte hai, ay beh-tareen rahem karne waale.", "Urdu": "اے پروردگار! دنیا میں ہمارے لئے وسعت قرار دے۔ اے پروردگار! اس حال میں کہ ہم تیرے دیدار کے طالب ہیں، ہم پناہ مانگتے ہیں کہ تو ہم سے رخ موڑے جبکہ ہم تیرے دیدار کے طالب ہیں۔ محمد وآل محمد پر درود بھیج، اور اپنی پسندیدہ چیز ہمیں عطا فرما، اور اس کو ہمارے لئے قوت بنا جس طرح ہم چاہتے ہیں، اے بہترین رحم کرنے والے۔", "RArabic": "ALLAAHUMMA WASSE’ A’LAYNAA FID DUNYAA, ALLAAHUMMA INNAA NA-O’OZO BEKA AN TAZWEYA WAJHAKA A’NNAA FEE HAALIN, WA NAHNO NARGHABO ELAYKA FEEHE. ALLAAHUMMA SALLE A’LAA MOHAMMADIN WA AALE MOHAMMADIN, WA A-A’TENAA MAA TOHIBBO, WAJ A’LHO LANAA QUWWATAN FEEMAA TOHIBBO, YAA ARHAMAR RAAHEMEEN.", "ArabicText1": "اَللّٰہُمَّ وَسِّعْ عَلَیْنَا فِی الدُّنْیَا، اَللّٰہُمَّ اِنَّا نَعُوْذُ بِکَ اَنْ تَزْوِیَ وَجْہَکَ عَنَّا فِیْ حَالٍ، وَنَحْنُ نَزْغَبُ اِلَیْکَ فِیْہِ۔ اَللّٰہُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّآلِ مُحَمَّدٍ، وَاَعْطِنَا مَا تُحِبُّ، وَاجْعَلْہُ لَنَا قُوَّۃً فِیْمَا تُحِبُّ، یَا اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) choicest blessings be upon Mohammed and his holy progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar Tu rehmat naazil farma Hazrat Muhammad (s.a.w.a) aur unki Aal (a.s) par.", "Urdu": "اے معبود! رحمت نازل فرما حضرت محمدؐ اور انکی آل ؑپر۔", "RArabic": "ALLAHUMMA SWALLE ALAA MUHAMMADIW WA AALE MUHAMMADIN", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": nu