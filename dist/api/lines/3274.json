[{"Id": 1014356, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Stand at the entrance of the Haram and seek permission in the following words…", "GujaratiDescription": null, "RUrduDescription": "Haram ke darwaaze par khade ho kar in alfaazo’n mein ijaazat talab kare…", "UrduDescription": "حرم کے دروازے پر کھڑے ہو کر ان جملوں کے ساتھ اعجازت طلب کرے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014357, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I am standing at one of the doors of Your Prophet’s Houses may Your blessings be upon him and his Household. And You have prevented people to enter there before they obtain his permission. You have thus said, “O you who believe! do not enter the houses of the Prophet unless permission is given to you…” (33:53). O Allah, I believe in the sanctity of the owner of this holy shrine in his absence as same as I believe in it in his presence. I also know for sure that Your Messenger and Your Representatives peace be upon them are live, finding their sustenance in the presence of You; they can see my place, hear my words, and respond to my greetings, but You have prevented my hearing from receiving their words and You have opened the door of my understanding to taste the fine flavor of my confidential speech with them.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai Tere Nabi (s) ke ghar ke darwaazo’n mein se ek darwaaze par haazir hu Un (s.a.w.a) par aur unki Aal (a.s) par Teri rehmat naazil ho. Tu ne logo’n ko Aan Hazrat (s.a.w.a) ki ijaazat ke baghair unke gharo’n mein daakhil hone se mana kiya hai aur Tera farmaan hai, “Ay imaan waalo! Daakhil na huwa karo Nabi ke gharo’n mein magar us waqt jab tumhe ijaazat mil jaaye” (33:53). Ay Allah! Be-shak mai is haram sharif mein madfoon (dafan-shudah) hasti ka unki ghaibat mein aise hi motaqid (aqeedat mand) hu jaise mai unke zahoor mein motaqid tha aur mai jaanta hu keh Tera Rasool (s.a.w.a) aur Tere kholafa keh un sab par salaam ho woh zindah hai aur Tere yahan rizq paate hai, woh mujhe dekh rahe hai, meri ghuftagu soon rahe hai aur mere salaam ka jawaab de rahe hai aur be-shak Tu ne mere kaano ko unka kalaam soonne se roka hai aur un se raaz o neyaaz karne mein mere faham (mind) ko khol rakkha hai.", "Urdu": "اے معبود! میں تیرے نبی کے گھر کے دروازوں میں سے ایک دروازے پر حاضر ہوں ان پر اور ان کی آل ؑپر تیری رحمت نازل ہوتو نے لوگوں کو آنحضرتؐ کی اجازت کے بغیر ان کے گھروں میں داخل ہونے سے منع کیا ہے اور تیرا فرمان ہے   اے ایمان والو! نبی کے گھروں میں داخل نہ ہواکرو مگر اس وقت جب تمہیں اجازت مل جائے۔ اے اﷲبے شک میں اس حرم مبارک میں مدفون ہستی کا ان کی غیبت میں ایسے ہی معتقد ہوں جیسے میں ان کے ظہور میں معتقد تھا اور میں جانتا ہوں کہ تیرا رسول ؐاور تیرے خلفاء کا ان سب پر سلام ہو وہ زندہ ہیں اور تیرے ہاں رزق پاتے ہیں وہ مجھے دیکھ رہے ہیں میری باتیں سن رہے ہیں اور میرے سلام کا جواب دے رہے ہیں اور بے شک تو نے میرے کانوں کو ان کا کلام سننے سے روکا ہے اور ان سے راز ونیاز کرنے میں میرے فہم کو کھول رکھا ہے۔", "RArabic": "ALLAAHUMMA INNEE WAQAFTO A'LAA BAABIN MIN ABWAABE BOYOOTE NABIYYEKA SALAWAATOKA A'LAYHE WA AALEHI WA QAD MANAA'-TAN NAASA AN YADKHOLOO ILLAA BE-IZNEHEE FAQULTA YAA AYYOHAL LAZEENA AAMANOO LAA TADKHOLOO BOYOOTAN NABIYYE ILLAA AN YU-ZANA LAKUM. ALLAAHUMMA INNEE AA'-TAQEDO HURMATA SAAHEBE HAAZAL MASH-HADISH SHAREEFE FEE GHAYBATEHE KAMAA AA'-TAQEDOHAA FEE HAZRATEHI WA AA'-LAMO ANNA RASOOLAKA WA KHOLAFAAA-AKA A'LAYHEMUS SALAAMO AHYAAA-UN I'NDAKA YURZAQOONA YARAWNA MAQAAMEE WA YASMA-O'ONA KALAAMEE WA YARUDDOONA SALAAMEE WA ANNAKA HAJABTA A'N SAM-E'E KALAAMAHUM WA FATAHTA BAABA FAHMEE BELAZEEZE MONAAJAATEHIM.", "ArabicText1": "اَللّٰہُمَّ اِنِّیْ وَقَفْتُ عَلٰی بَابٍ مِّنْ اَبْوَابِ بُیُوْتِ نَبِیِّکَ صَلَوَاتُکَ عَلَیْہِ وَآلِہٖ وَقَدْ مَنَعْتَ النَّاسَ اَنْ یَدْخُلُوْا اِلَّا بِاِذْنِہٖ فَقُلْتَ یَآ اَیُّہَا الَّذِیْنَ اٰمَنُوْا لَا تَدْخُلُوْا بُیُوْتَ النَّبِیِّ اِلَّا اَنْ یُّؤْذَنَ لَکُمْ۔ اَللّٰہُمَّ اِنِّیْ اَعْتَقِدُ حُرْمَۃَ صَاحِبِ ہٰذَا الْمَشْہَدِ الشَّرِیْفِ فِیْ غَیْبَتِہٖ کَمَآ اَعْتَقِدُہَا فِیْ حَضْرَتِہٖ وَاَعْلَمُ اَنَّ رَسُوْلَکَ وَخُلَفَآئَکَ عَلَیْہِمُ السَّلَامُ اَحْیَآئٌ عِنْدَکَ یُرْزَقُوْنَ یَرَوْنَ مَقَامِیْ وَیَسْمَعُوْنَ کَلَامِیْ وَیَرُدُّوْنَ سَلَامِیْ وَاَنَّکَ حَجَبْتَ عَنْ سَمْعِیْ کَلَامَہُمْ وَفَتَحْتَ بَابَ فَہْمِیْ بِلَذِیْذِ مُنَاجَاتِہِمْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014358, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I thus ask Your permission O my Lord first of all, the permission of Your Prophet peace be upon him and his Household secondly, the permission of Your Representative, Imam Ali ibne Musa (a.s), the obedience to whom is incumbent upon me and the permission of the angels whom are commissioned to supervise this blessed area, thirdly. May I enter, O Messenger of Allah? May I enter, O Argument of Allah? May I enter, O angels of Allah, the intimate, the residing in this shrine? So, (please do) permit me to enter, O my Master, in the best way of permission that you have ever conferred upon any of your intimate adherents. If I do not deserve such permission, then you are worthy of conferring it upon me.", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur ay mere Rab pehle mai Tujh se ijaazat maangta hu phir Tere Rasool (s.a.w.a) se ijaazat maangta hu keh Khuda rehmat kare un par aur unki Aal (a.s) par aur ijaazat maangta hu Tere Khalifa o Imam Ali bin Moosa (a.s) se jin ki ita’at mujh par waajib hai, aur phir un farishto’n se jo is baargah ke nigheh-baan hai jo ba-barkat hai. Aaya mai andar aa jaawu ay Allah ke Rasool (s.a.w.a), aaya mai andar aa jaawu ay Khuda ki Hujjat (a.s), aaya mai andar aa jaawu ay Khuda ke muqarrab malaayeka jo qabre mutahar ke paas muqeem (rehte) hai. Pas ay mere Maula (a.s) mujhe andar aane ki ijaazat, aisi behtareen ijaazat jo aap ne apne dosto’n mein kisi ko di ho, pas agar-che mai uske laayaq nahi hu lekin Aap ijaazat dene ke ahel hai.", "Urdu": " اور اے میرے رب پہلے میں تجھ سے اجازت مانگتاہوں پھر تیرے رسولؐ سے اجازت مانگتا ہوں کہ خدا رحمت کرے ان پر اور ان کی آل ؑپر اور اجازت مانگتا ہوں تیرے خلیفہ و امام علی بن موسٰیؑ سے جن کی اطاعت مجھ پر واجب ہے اور پھر ان فرشتوں سے جو اس بارگاہ کے نگہبان ہیں جو بابرکت ہے۔ میں اندر آجاؤں اے اﷲکے رسولؐ ؟آیا میں اندر آجاؤں اے خدا کی حجت ؑ؟آیا میں اندر آجاؤں اے خدا کےمقرب ملائکہ؟ جو قبر مطہر کے پاس مقیم ہیں پس اے میرے مولاؑ مجھے اندر آنے کی اجازت دیجیے ایسی بہترین اجازت جو آپ نےاپنے دوستوں میں کسی کو دی ہو پس اگرچہ میں اس کے لائق نہیں ہوں لیکن آپ اجازت دینے کے اہل ہیں۔", "RArabic": "WA INNEE ASTAAZENOKA YAA RABBE AWWALAN WA ASTAAZENO RASOOLAKA SALLALLAAHO A'LAYHE WA AALEHI SAANEYAN WA ASTAAZENO KHALEEFATAKAL EMAAMAL MAFROOZA A'LAYYA TAA-A'TOHU A'LIYYABNE MOOSAR REZAA A'LAYHEMAS SALAAMO WAL MALAAA-EKATAL MOWAKKELEENA BE HAAZEHIL BUQ-A'TIL MOBAARAKATE SAALESAN. A-ADKHOLO YAA RASOOLALLAAHE A-ADKHOLO YAA HUJJATALLAAHE A-ADKHOLO YAA MALAAA-EKATALLAAHIL MOQARRABEENAL MOQEEMEENA FEE HAAZAL MASH-HADE FAA-ZAN LEE YAA MAWLAAYA FID DOKHOOLE AFZALA MAA AZINTA LE-AHADIN MIN AWLEYAAA-EKA FA-IN LAM AKUN AHLAN LEZAALEKA FA-ANTA AHLUN LEZAALEKA.", "ArabicText1": "وَاِنِّیْ اَسْتَاذِنُکَ یَا رَبِّ اَوَّلًا وَّاَسْتَاْذِنُ رَسُوْلَکَ صَلَّی اللہُ عَلَیْہِ وَاٰلِہٖ ثَانِیًا وَاَسْتَاذِنُ خَلِیْفَتَکَ الْاِمَامَ الْمَفْرُوْضَ عَلَیَّ طَاعَتُہٗ عَلِیِّ بْنِ مُوْسَی الرِّضَا عَلَیْہِمَا السَّلَامُ وَالْمَلٰٓئِکَۃُ اَلْمُوَکَّلِیْنَ بِہٰذِہِ الْبُقْعَۃِ الْمُبَارَکَۃِ ثَالِثًا۔ ءَاَدْخُلُ یَا رَسُوْلَ اللہِ ءَاَدْخُلُ یَا حُجَّۃَ اللہِ ءَاَدْخُلُ یَا مَلٰٓئِکَۃَ اللہِ الْمُقَرَّبِیْنَ الْمُقِیْمِیْنَ فِیْ ہٰذَا الْمَشْہَدِ فَاْذَنْ لِیْ یَا مَوْلَایَ فِی الدُّخُوْلِ اَفْضَلَ مَآ اَذِنْتَ لِاَحَدٍ مِّنْ اَوْلِیَآئِکَ فَاِنْ اَکُنْ اَہْلًا لِذٰلِکَ فَاَنْتَ اَہْلٌ لِذٰلِکَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "Arabi