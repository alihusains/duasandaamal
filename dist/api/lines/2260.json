[{"Id": 1016640, "EnglishTitle": "PLEASE NOTE: Be it clear that the reason for presenting Translation is to understand Salaat and to recite in Arabic with concentration because reciting Salaat other than Arabic language (or Transliteration) is not correct.", "GujaratiTitle": null, "RUrduTitle": "Waazeh rahe keh tarjuma-e-namaz pesh karne ki asal wajah namaz samajh ke Arabi mein khuzoo aur tawajjoh ke saath namaz padhna hai. Kyu’n keh Arabi ya Roman-Arabi (Transliteration) ke siwa kisi aur zabaan mein namaz padhna sahih nahin hai.", "UrduTitle": "واضح رہے کہ ترجمۂ نماز پیش کرنے کی اصل غرض نماز سمجھ کے عربی میں خضوع اور توجہ کے ساتھ نماز پڑھنا ہے۔ کیوں کہ عربی کے سوا کسی اور زبان میں نماز پڑھنا صحیح نہیں ہے۔ اس لئے ہر ایک کے لئے نماز کی حد تک قرآن و عربی سیکھنا واجب ہے۔", "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1019150, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Ali ibn Asbaat narrates that when I asked Imam Reza (a) about my journey to Egypt. Whether should I go by sea or on land? He (a) said: “Go to Masjid al-Nabi other than the time of obligatory Namaz and perform 2 rakats namaz and seek benediction of Almighty Allah 100 times then act according to whatever is stronger (in your heart).”", "GujaratiDescription": null, "RUrduDescription": "Ali ibne Asbaat se riwaayat hai keh jab mai ne Imam Reza (a) se apne safar’e Misr (Egypt) ke baare mein poochha keh mai paani se safar karu ya zameen se (by sea or by land)? To Imam (a) ne farmaya: Masjid’e Nabawi us waqt jaawo keh waajib namaz ka waqt na ho aur wahan 2 rakat namaz adaa karo, phir 100 martaba Allah (swt) se rehmat talab karo aur jo bhi iraadah tumhare dil mein mazboot ho woh anjaam do.", "UrduDescription": "علی بن اسباط نے روایت کی ہے کہ جب میں نے امام رضاؑ سے اپنے سفر مصر کے بارے میں  پوچھا کہ میں دریا سے سفر کروں یا زمین سے؟ تو امامؑ نے فرمایا: مسجد نبوی اُس وقت جاؤ کہ جب واجب نماز کا وقت نہ ہو اور ۲ رکعت نماز ادا کرو، پھر ۱۰۰ مرتبہ اللہ سے رحمت طلب کرو اور جو ارادہ تمہارے دل میں مضبوط ہو وہ انجام دو۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSi