at rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016981, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I seek the best from You like those who have given away their affairs to You, and have surrendered themselves before You, and who rely upon You in their affair, and have surrendered to whatever has reached them.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaara! Tujh se talab'e khair karta hu us bande jaisa talab'e khair jisne apne sab umoor Tere supurd (hawaAle) kar diya ho aur apne ko Tere ikhteyaar mein de diya ho, Tujh par tawakkul kiya ho aur Tu ne uske liye jo hukm bhi jaari kiya us par sar'e tasleem kham kiya ho.", "Urdu": "پروردگارا! تجھ سے طلبِ خیر کرتا ہوں اس بندے جیسا طلبِ خیر جس نے اپنے سب امور تیرے سپرد کر دیے ہوں اور اپنے آپ کو تیرے اختیار میں دے دیا ہو، تجھ پر توکل کیا ہوا اور تو نے اس کے لئے جو حکم بھی جاری کیا اس پر سرِ تسلیم خم کیا ہو۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَسْتَخِیْرُكَ خِیَارَ مَنْ فَوَّضَ اِلَیْكَ اَمْرَهُ، وَاَسْلَمَ اِلَیْكَ نَفْسَهٗ وَتَوَكَّلَ عَلَیْكَ فِیْ اَمْرِهٖ، وَاسْتَسْلَمَ بِكَ فِیْمَا نَزَلَ بِهٖ مِنْ اَمْرِهٖ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016982, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, seek Good for me and do not seek bad, help me and do not help against me, strengthen me and do not dominate someone over me, guide me towards good and do not misguide me, make me satisfied with that You have destined, and make it gracious and blessed for me, indeed You do as per Your will, and grant what You decide.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Mere liye khair o bhalaayi ka intekhaab farma, na keh shar aur buraayi ka, meri madad farma, mujhe apne aap se dur na rakh, mujhe qudrat o taaqat ataa farma, bhalaayi ki taraf meri rehnumaayi farma, mujhe gumrah na kar, apni qaza par mujhe raazi aur apni qadr ko mere liye mubarak farma. Be-shak! Jo Tu chahta hai woh anjaam deta hai aur jo chahta hai woh ataa karta hai.", "Urdu": "خدایا! میرے لئے خیر و بھلائی کا انتخاب فرما نہ کہ شر اور برائی کا، میری مدد فرما، مجھے اپنے آپ سے دور نہ رکھ، مجھے قدرت و طاقت عطا فرما، بھلائی کی طرف میری رہنمائی فرما، مجھے گمراہ نہ کر، اپنی قضا پر مجھے راضی اور اپنی قدر کو میرے لئے مبارک فرما۔ بےشک! جو تو چاہتا ہے وہ انجام دیتا ہے اور جو چاہتا ہے وہ عطا کرتا ہے۔", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ خِرْلِیْ وَلَا تَخِرْ عَلَیَّ، وَاَعِنِّیْ وَلَا تُعِنْ عَلَیَّ، وَمَكِّنِّیْ وَلَا تُمَكِّنْ مِّنِّیْ، وَاهْدِنِیْ لِلْخَیْرِ وَلَا تُصِلَّنِیْ، وَاَرْضِنِیْ بِقَضَائِكَ، وَبَارِكْ لِیْ فِیْ قَدَرِكَ، اِنَّكَ تَفْعَلُ مَا تَشَائُ وَتُعْطِیْ مَا تُرِیْدُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016983, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, if there lies good in my intended work, then give it in my hands and grant me with the power of performing it, and command me to perform it, and illuminate the path of guidance towards it. O Allah, if it is anything but good, keep it away from me and change it to something which might be better for me, indeed You have the Power, not me, and You know whereas I don t, and You are the Knower of the Unseen, O the most Merciful of the merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khudaaya! Agar is fula’n fula’n kaam mein meri bhalaayi hai to mujhe isko paaye takmeel tak pohonchaane ke liye qudrat o taaqat ataa farma aur isko anjaam dene ka mujhe hukm farma aur mere liye raahe hidaayat ko khol de. Khudaaya! Agar iske bar-aks (opposite) ho to isey mere liye bhalaayi mein tabdeel farma de, kyu’n keh Tu qudrat rakhta hai aur mai qudrat nahi rakhta, Tu jaanta hai aur mai nahi jaanta aur Tu aale-mul-ghaib (ghaib ka jaanne waala) hai, ay rahem karne waalo’n mein sab se ziyadah rahem karne waale.", "Urdu": "خدایا! اگر اس فلاں فلاں کام میں میری بھلائی ہے تو مجھے اس کو پایۂ تکمیل تک پہنچا نے کے لئے قدرت و طاقت عطا فرما اور اس کو انجام دینے کا مجھے حکم فرما اور میرے لئے راہِ ہدایت کو کھول دے۔ خدایا! اگر اس کے برعکس ہو تو اسے میرے لئے بھلائی میں تبدیل فرما دے، کیوں کہ تو قدرت رکجتا ہے اور میں قدرت نہیں رکھتا، تو جانتا ہے اور میں نہیں جانتا اور تو علام الغیوب ہے اے رحم کرنے والوں میں سے سب سے زیادہ رحم کرنے والے!", "RArabic": null, "ArabicText1": "اَللّٰهُمَّ اِنْ كَانَتِ الْخِیَرَۃُ لِیْ فِیْ اَمْرِیْ هٰذَا وَهُوَ كَذَا وَكَذَا، فَمَكِّنِّیْ مِنْهُ، وَاَقْدِرْنِیْ عَلَیْهِ، وَامُرْنِیْ بِفِعْلِهٖ، وَاَوْضِهْ لِیْ طَرِیْقَ الْهِدَایَۃِ اِلَیْهِ، وَاِنْ كَانَ اللّٰهُمَّ غَیْرَ ذٰلِكَ فَاصْرِفْهُ عَنِّیْ اِلَی الَّذِیْ هُوَ خَیْرٌ لِیْ مِنْهُ، فِاِنَّكَ تَقْدِرُ وَلَا اَقْدِرُ وَتَعْلَمُ وَلَا اَعْلَمُ، وَاَنْتَ عَلَّامُ الْغُیُوْبِ، یَا اَرْحَمَ الرَّاحِمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Allah’s (s.w.t) choicest blessings be upon Mohammed and his holy progeny.", "Gujarati": null, "RGujarati": null, "RUrdu": "Parwardigaar Tu rehmat naazil farma Hazrat