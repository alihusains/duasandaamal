ign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1000488, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O God, O Shelter of the shelter-seekers! O Refuge of the refuge-seekers! O Deliverer of the perishing! O Preserver of the pitiful! O Merciful toward the miserable! O Responder to the distressed! O Treasure of the utterly poor! O Mender of the broken! O Haven of the cut off! O Helper of the abased! O Granter of sanctuary to the fearful! O Aider of the troubled! O Fortress of the refugees!", "Gujarati": null, "RGujarati": null, "RUrdu": "Mere Mabood! Ay panah dene waalo’n ki panah. Ay panah lene waalo’n ki panah-gah. Ay halaak hone waalo’n ko najaat dene waale, Ay be-chaaro’n ke nigheh-daar, Ay be-kaso par rahem karne waale. Ay pareshan logo’n ki dua qabool karne waale, ay mohtajo’n ke khazaane, ay toote huwo ko jod ne waale, Ay saharo’n ki jaaye panah. Ay kamzoro’n ki madad karne waale, ay khouf-zado’n ki panah-gah. Ay dukhyaaro’n ke fariyaad-ras. Ay panah-khwaho’n ki mohkam (mazboot) jaaye-panah.", "Urdu": "خدا کے نام سے شروع جو بڑا مہربان نہایت رحم والا ہے۔میرے معبود! اے پناہ دینے والوں کی پناہ اے پناہ لینے والوں کی پناہ گاہ اے ہلاکت والوں کو نجات دینے والے اے بے چاروں کے نگہدار اے بے کسوں پر رحم کرنے والے اے پریشانوں کی دعا قبول کرنے والے اے محتاجوں کے خزانے اے ٹوٹے ہوؤں کے جوڑنے والے اے بے ٹھکانوں کی جائے پناہ اور اے کمزوروں کی مدد کرنے والے اے خوف زدوں کی پناہ گاہ اے دکھیاروں کے فریاد رس اے پناہ خواہوں کی محکم جائے پناہ۔", "RArabic": "INSHA-ALLAH COMING SOON", "ArabicText1": "اَللّٰهُمَّ يَامَلَاذَ الَّلْآئِذِيْنَ وَيَا مَعَاذَالْعَآئِذِيْنَ وَيَا مُنْجِيَ الْهَالِكِيْنَ وَيَا عَاصِمَ الْبَآئِسِيْنَ وَيَا رَاحِمَ الْمَسَاكِيْنِ وَيَا مُجِيْبَ الْمُضْطَرِّيْنَ وَيَا كَنْزَ الْمُفْقَتِرِيْنَ وَيَا جَابِرَ الْمُنْكَسِرِيْنَ وَيَا مَاوَى الْمُنْقَطِعِيْنَ وَيَا نَاصِرَ الْمُسْتَضْعَفِيْنَ وَيَا مُجِيْرَ الْخَآئِـفِيْنَ وَيَا مُغِيْثَ الْمَكْرُوْبِيْنَ وَيَا حِصْنَ اللّٰاجِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012373, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "If I seek not refuge in Thy might, in whom shall I seek refuge? If I seek not shelter in Thy power, in whom shall I seek shelter? Sins have made me seek asylum in laying hold on the skirts of Thy pardon, offenses have compelled me to beg the opening of the doors of Thy forgiveness, evil doing has summoned me to dismount in the courtyard of Thy might, fear of Thy vengeance has prompted me to cling to the handhold of Thy tenderness!", "Gujarati": null, "RGujarati": null, "RUrdu": "Agar mai Teri izzat ki panah na lu to kis ki panah lu. Aur agar Teri qudrat se ilteja na karu to kis se ilteja (request) karu. Mere gunaho’n ne mujhe majboor kar diya hai keh mai Tere daaman’e afvo (maafi ke daaman) ko thaam lu. Aur meri khataawo’n ne mujhe Teri chashm-poshi ke darwaazo’n ke khul ne ka talab-gaar bana diya hai. Meri bad-amali ne mujhe Tere aastaane izzat par dera daal dene ko kaha hai. Aur Tere azaab ke khouf ne mujhe Teri maher-baani ki dori (rassi) pakad lene par aamadah (taiyyaar) kiya hai.", "Urdu": "اگر میں تیری عزّت کی پناہ نہ لوں تو کس کی پناہ لوں اور اگر تیری قدرت سے التجا نہ کروں تو کس سے التجا کروں میرے گناہوں نے مجھے مجبور کردیا ہے کہ میں تیرے دامنِ عفوودرگزر کوتھام لوں اور میری خطاؤں نے مجھے تیری درگزرکرنے کے دروازوں کے کھلنے کا طلب گار بنا دیا ہے میری بدعملی نے مجھے تیرے آستانۂ عزّت پرڈیرہ ڈال دینے کو کہا ہے اور تیرے عذاب کے خوف نے مجھے تیری مہربانی کی ڈوری پکڑ لینے پر آمادہ کیا ہے۔", "RArabic": null, "ArabicText1": "اِنْ لَّمْ اَعُذْ بِعِزَّتِكَ فَبِمَنْ اَعُوْذُ وَاِنْ لَّمْ اَلُذْ بِقُدْرَتِكَ فَبِمَنْ اَلُوْذُ وَقَدْ اَلْجَاَتْنِى الذُّنُوْبُ اِلَى التَّشَبُّتِ بِاَذْيَالِ عَفْوِكَ وَاَحْوَجَتْنِىْ الْخَطَايَا اِلَى اسْتِفْتَاحِ اَبْوَابِ صَفْحِكَ وَدَعَتْنِىْ الْاِسَآئَةُ اِلَى الْاِنَاخَةِ بِفِنَآءِ عِزِّكَ وَحَمَلَتْنِىْ الْمَخَافَةُ مِنْ نِقْمَتِكَ عَلَى التَّمَسُّكِ بِعُرْوَةِ عَطْفِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012374, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "It is not right for him who holds fast to Thy cord to be abandoned, nor proper for him who seeks the sanctuary of Thy might to be surrendered or disregarded. My God, empty us not of Thy defending, strip us not of Thy guarding, and protect us from the roads of destruction, for we are in Thy eye and under Thy wing!", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur haq yeh nahi keh Jo Teri rassi ko pakad le to usey ruswa kiya jaaye, aur yeh munaasib nahi keh jo Teri izzat ki panah le usko be-sahara chhoda jaaye. Mere Mabood! Hamein Apni himayat ke bagair chhod na de, aur hamein Apni nighahe karam se mehroom na farma. Aur hamein halaakat ki jagoh se dur rakh. Kyu’n keh ham Tere zere nazar aur Teri panah mein hai, mai Tere makhsoos farishto’n aur Teri makhluq mein se swoleh bando’n ka waasta de kar Tujh se sawaal karta hu keh ham par aisi sipar (shield) daal de jo hamein halaakato’n se bachaaye. Aur aafato’n se mehfooz rakkhe, aur Tu hamein badi-badi museebato’n se najaat ataa farma.", "Urdu": "اور حق یہ نہیں کہ جو تیری رسی کو پکڑ لے تو اسے رسوا کیا جائے اور یہ مناسب نہیں کہ جو تیری عزّت کی پناہ لے اس کو بے سہارا چھوڑا جائے میرے معبود! ہمیں اپنی حمایت کے بغیر چھوڑ نہ دے اور ہمیں اپنی نگاہ سے محروم نہ فرما اور ہمیں ہلاکت کی جگہوں سے دور رکھ کیوں کہ ہم تیرے زیرِ نظر اور تیری پناہ میں ہیں میں تیرے مخصوص فرشتوں اور تیری مخلوق میں سے صالح بندوں کا واسطہ دے کر تجھ سے سوال کرتا ہوں کہ ہم پر ایسی سپر ڈال دے جو ہمیں ہلاکتوں سے بچائےاور آفتوں سے محفوظ رکھے اور تو ہمیں بڑی بڑی مصیبتوں سے نجات عطا فرما۔", "RArabic": null, "ArabicText1": "وَمَا حَقُّ مَنِ اعْتَصَمَ بِحَبْلِكَ اَنْ يُخْذَلَ وَلَا يَلِيْقُ بِمَنِ اسْتَجَارَ بِعِزِّكَ اَنْ يُّسْلَمَ اَوْ يُهْمَلَ۔ اِلٰهِىْ فَلَا تُخْلِنَا مِنْ جِمَايَتِكَ وَلَا تَعْرِنَا مِنْ رِعَايَتِكَ وَذُدْنَا عَنْ مَوَارِدِ الْهَلَكَةِ فَاِنَّا بِعَيْنِكَ وَفِىْ كَنَفِكَ وَلَكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012375, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I ask Thee by those whom Thou hast singled out, Thy angels and the righteous among Thy creatures, to assign over us a protector through which Thou wilt deliver us from destructions, turn aside from us blights, and hide us from the striking of great afflictions, to send down upon us some of Thy tranquility, to wrap our faces in the lights of love for Thee, to give us haven in Thy strong pillar, and to gather us under the wings of Thy preservation! By Thy clemency and Thy mercy, O Most Merciful of the merciful!", "Gujarati": null, "RGujarati": null, "RUrdu": "Mai chahta hu keh Tu ham par Apni taraf se taskeen naazil kar. Aur hamare chehro’n ka Apni mohabbat ke anwaar se ehaata farma, hamein Apne mohkam o paaye-daar rukn (sutoon/pillar) ka sahara de. Aur Apni ismat ke saayo’n (shade) mein le le, waasta hai Teri rehmat o mulaayemat ka ay sabse ziyadah rahem karne waale.", "Urdu": "میں چاہتا ہوں کہ تو ہم پر اپنی طرف سے تسکین نازل کراور ہمارے چہروں کا اپنی محبت کے انوار سے احاطہ فرما ہمیں اپنے محکم و پائیدار رکن کا سہارا دے اور اپنی عصمت کےسایوں میں لے لے واسطہ ہے تیری رحمت و ملائمت[نرمی] کا اے سب سے زیادہ رحم کرنے والے۔", "RArabic": null, "ArabicText1": "اَسْئَلُكَ بِاَهْلِ خَآصَّتِكَ مِنْ مَلَآئِكَتِكَ وَالصَّالِحِيْنَ مِنْۢ بَرِيَّتِكَ اَنْ تَجْعَلَ عَلَيْنَا وَاقِيَةً تُنْجِيْنَا مِنَ الْهَلَكَـاتِ وَتُجَنِّبُنَا مِنَ الْاٰفَاتِ وَتُكِنُّنَا مِنْ دَوَاهِىْ الْمُصِيْبَاتِ وَاَنْ تُنْزِلَ عَلَيْنَا مِنْ سَكِيْنَتِكَ وَاَنْ تُغَشِّىَ وُجُوْهَنَا بِاَنْوَارِمَحَبَّتِكَ اَنْ تُؤْوِيَنَا اِلٰى شَدِيْدِ رُكْنِكَ وَاَنْ تَحْوِيَنَا فِىْ اَكْنَافِ عِصْمَتِكَ بِرَاَفَتِكَ وَرَحْمَتِكَ يَآاَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedS