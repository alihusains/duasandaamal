[{"Id": 1009636, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Based on obligatory precaution, a believer (male or female) who is dying ie. breathing his last breaths must be laid on his back, if possible, and in a way that the soles of his feet face qibla till the ghusl of mayyit is complete.", "GujaratiDescription": null, "RUrduDescription": "Jo Muslamaan (mard ya aurat) marne ke qareeb ho usey pusht ke bal yu’n letaana chahiye keh uske paawo’n ke talwe qibla rukh ho aur ghusl-e-mayyit mukammal hone tak isi tarah letaana chahiye.", "UrduDescription": "جو مسلمان محتضر ہو یعنی جاں کنی کی حالت میں ہو خواہ مرد ہو یا عورت، بڑا ہو یا چھوٹا، اسے احتیاط کی بنا پر بصورت امکان پشت کے بل یوں لٹانا چاہئے کہ اس کے پاوں کے تلوے قبلہ رخ ہوں اور غسل میت مکمل ہونے تک اسی طرح لےٹانا چاہیئے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1009637, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "It is recommended to recite Talqeen near a dying person with the Shahdatain (two testimonies), the names of the Twelve Imams (a), and other rightful beliefs of the faith in a manner that he understands. It is also recommended that the aforementioned things be repeated until the time of death.", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh jo shakhs marne ke qareeb ho uske saamne shahadatein, baara (12) Imamo’n ke naam aur dusre deeni aqaaed is tarah dohraaye jaaye keh woh samajh le aur uski maut ke waqt tak in cheezo’n ki takraar (repeat) karna bhi mustahab hai.", "UrduDescription": "مستحب ہے کہ جو شخص جاں کنی کی حالت میں ہو اس کے سامنے شہادتین، بارہ اماموں کے نام اور دوسرے دینی عقائد اس طرح دہرائے جائیں کہ وہ سمجھ لے اور اسکی موت کے وقت تک ان چیروں کی تکرا