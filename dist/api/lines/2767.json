[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1011656, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O the helper of all the Awliya, O one who is most powerful of the powerful ones, O the God of the formers, You have created me whereas I was nothing and You ordered me obedience and I also my Chief, obeyed You according to my capacity. Thus if there had been some sloth or forgetfulness in Your obedience, have mercy on me and do not cut off my hopes that I have reposed in Thee, my Chief. Bless me with Your mercy and join me with the Prophet of mercy, Muhammad bin Abdullah, may Allah bless him and his progeny and forgive me. And you are the one who accepts repentance and one who is merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay tamaam auliya ke naasir o madad-gaar, ay tamaam zabardasto’n se ziyadah zabardast, ay tamaam guzishta logo’n ke Khuda, Tu ne mujhe khalq kiya haala’n keh mai kuchh bhi na tha. Tu ne hi mujhe apni ita’at karne ka hukm diya to mai ne bhi ba-qadr apni bardaasht se ay mere Aaqa Teri ita’at ki. Pas agar Teri ita’at mein meri taraf se kuchh susti ya bhul-chuk ho gayi, to ay mere Aaqa! Tu mujh par apna fazl kar aur meri un ummeedo’n ko, jo Tujh se wa-basta hai qata (alag) na kar. Aur mujh par apni rehmat se ehsaan kar aur mujh ko aur Nabiye Rehmat Hazrat Muhammad bin Abdullah (s.a.w.a) ko yekja (ek saath) kar de (mujhe Jannat mein manzile Rasool tak pohoncha de) aur mere gunaho’n ko bakhsh de, yaqeenan Tu gunaho’n ko maaf karne waala raheem hai.", "Urdu": "اے تمام اولیا کے ناصر و مدد گار، اے تمام زبردستوں سے زیادہ زبردست، اے تمام گزشتہ لوگوں کے خدا، تو نے مجھے خلق کیا حالا کہ میں کچھ بھی نہ تھا۔ تو نے ہی مجھے اپنی اطاعت کرنے کا حکم دیا تو میں نے بھی با قدر اپنی برداشت سے اے میرے آقا تیری اطاعت کی۔ پس اگر تیری اطاعت میں میری طرف سے کچھ سستی یا بھل چک ہو گئی تو اے میرے آقا! تو مجھ پر اپنا فضل کر اور میری ان امیدوں کو، جو تجھ سے وابستہ ہے قطع نہ کر۔ اور مجھ پر اپنی رحمت سے احسان کر اور مجھ کو اور نبی رحمت حضرت محمد بن عبد اللہؐ کو یکجا کر دے اور میرے گناہوں کو معاف کرنے والا رحیم ہے۔", "RArabic": "YAA WALIY-YAL AWLEYAA-E WA JABBAA-RAL JAABERA-TE WA YAA ILAA-HAL AWWA-LEENA ANTA KHALAQ-TANEE WA LAM AKO SHAI-AN WA ANTA AMAR-TANEE BIT-TAA-A’TE WA ATA’TO SAYYEDEE BE-QADRE JOHDEE FA-IN KUNTA TAWWAA-NEE-TO AW-AKH-TAATO AW-NASEE-TO FA-TA-FAZZAL A’LAIYYA SAYYEDEE WA LAA TAQTA’ RAJAA-EE’ FAMNUN A’LAIYYA BIR-RAHMATE WAJMA’ BAIY-NEE WA BAIYNA NABIY-YIR RAHMATE MOHAMMADIB-NE A’BDIL-LAAHE SALAL-LAAHO A’LAIHE WA AALE-HI WAGH-FIR-LEE INNA-KA AN-TAT TAWWAA-BUR RAHEEM.", "ArabicText1": "یَاوَلِیَّ الْاَوْلِیَآئِ وَجَبَّارَ الْجَابِرَۃِ وَیَا اِلٰہَ الْاَوَّلِیْنَ اَنْتَ خَلَقْتَنِیْ وَلَمْ اَکُ شَیْئًا وَّاَنْتَ اَمَرْتَنِیْ بِاالطَّاعَۃِ وَاَطَعْتُ سَیِّدِیْ بِقَدْرِ جُھْدِیْ فَاِنْ کُنْتَ تَوَانَیْتُ اَوْاَخْطَاتُ اَوْنَسِیْتُ فَتَفَضَّلْ عَلَیَّ سَیِّدِیْ وَلَا تَقْطَعْ رَجَآئِیْ فَامْنُنْ عَلَیَّ بِالرَّحْمَۃِ وَاجْمَعْ بَیْنِیْ وَبَیْنَ نَبِیِّ الرَّحْمَۃِ مُحَمَّدِبْنِ عَبْدِاللہِ صَلَّی اللہُ عَلَیْہِ وَاٰلِہٖ وَاغْفِرْلِیْ اِنَّکَ اَنْتَ التَّوَّابُ الرَّحِیْمِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 2, "EnglishTitle": null, "Gujarati