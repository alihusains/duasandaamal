[{"Id": 1014635, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "Sayyid Ibn Tawus has stated that it is recommended to say the following dua immediately after performing the ziyarat of the Holy Imams (a)…", "GujaratiDescription": null, "RUrduDescription": "Sayyid Ibne Tawus farmaate hai keh Aimma (a) ki ziyarat ke baad is dua ko fauran padhna mustahab hai…", "UrduDescription": "یہ وہ دعا ہے جو ہر امامؑ کی زیارت کے بعد پڑھی جاتی ہے ‘ سید ابن طاؤسؒ فرماتے ہیں : تمام ائمہ ؑکی زیارت کے بعد اس دعا کا پڑھنا مستحب ہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014636, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah! If my sins have caused my face to be tattered in Your view, my prayers to be screened from You, and put a barrier between You and me, then I beseech You to come to me with Your noble Face, to spread Your mercy upon me, and to pour down Your benedictions on me. And if my sins have impeded from raising my voice to You, impeded from forgiving any of my sins, or overlooking any of my destructive fault.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Agar mere gunaho’n ne mujhe Tere saamne ruswa kar diya, meri dua ko Tere huzoor jaane se rok diya hai aur woh mere aur Tere darmiyaan rukaawat ban gaye hai to bhi sawaal karta hu keh Tu apni zaat'e kareem ke sadqe meri taraf tawajjoh kare, mujh par apni rehmat ka saaya daal de aur mujh par barkate’n naazil kar, agar-che woh gunah rukaawat hai is se keh meri awaaz Teri baargah mein pohonche, ya to mere gunah bakhshe, ya to meri khataae’n maaf kare jo tabah karne waali hai.", "Urdu": "اے معبود! اگر میرے گناہوں نے مجھے تیرے سامنے رسوا کر دیا میری دعا کو تیرے حضور جانے سے روک دیا ہے اور وہ میرے اور تیرے درمیان رکاوٹ بن گئے ہیں تو بھی سوال کرتا ہوں کہ تو اپنی کریم ذات کے صدقے میری طرف توجہ کرے مجھ پر اپنی رحمت کا سایہ ڈال دےاور مجھ پر برکتیں نازل کر اگرچہ وہ گناہ رکاوٹ ہیں اس سے کہ میری آواز تیری بارگاہ میں پہنچے یا تو میرے گناہ بخشے یا تو میری خطائیں معاف کرے جو تباہ کرنے والی ہیں۔", "RArabic": "ALLAAHUMMA IN KAA-NAT ZONOO-BEE QAD AKHLA-QAT WAJHEE I’NDAKA WA HAJA-BAT DOA’A-EE A’NKA WA HAALAT BAIY-NEE WA BAIY-NAKA FA-AS-ALOKA AN TUQBELA A’LAIYYA BE-WAJHE-KAL KAREEME WA TAN-SHORA A’LAIYYA RAH-MATAKA WA TO-NAZZELA A’LIYYA BARA-KAATE-KA WA IN KAA-NAT QAD MANA-A’T AN TARFA-A’ LEE ILAIKA SAWTAN AW TAGHFERA LEE ZANM-BAN AW TATA-JAAWAZA A’N KHATEE-A-TIN MOHLE-KATIN.", "ArabicText1": "اَللّٰهُمَّ اِنْ كَانَتْ ذُنُوْبِيْ قَدْ اَخْلَقَتْ وَجْهِيْ عِنْدَكَ وَحَجَبَتْ دُعَآئِيْ عَنْكَ وَحَالَتْ بَيْنِيْ وَبَيْنَكَ فَاَسْئَلُكَ اَنْ تُقْبِلَ عَلَيَّ بِوَجْهِكَ الْكَرِيْمِ وَتَنْشُرَ عَلَيَّ رَحْمَتَكَ وَتُنَزِّلَ عَلَيَّ بَرَكَاتِكَ وَاِنْ كَانَتْ قَدْ مَنَعَتْ اَنْ تَرْفَعَ لِيْ اِلَيْكَ صَوْتًا اَوْ تَغْفِرَ لِيْ ذَنْبًا اَوْ تَتَجَاوَزَ عَنْ خَطِيْئَةٍ مُهْلِكَةٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014637, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Then, here I am seeking shelter with the nobleness of Your Face and the dignity of Your majesty; and (here I am) begging You and seeking nearness to You through the most beloved of Your creatures to You, the most honorable with You, the nearest to You, the most obedient to You, and the owners of the greatest standing and position with You; namely, Muhammad and his immaculate descendants, the Imams, the guide and well-guided.", "Gujarati": null, "RGujarati": null, "RUrdu": "Pas mai panah leta hu Teri zaat'e kareem aur Teri izzat o jalaal ki Tujh se taaluq banaata hu, Tere qareeb hota hu unke zariye jo makhlooq mein Tere mehboob hai, Tere yahan sabse moaziz (ziyadah izzat waale) hai, Tere nazdik sab se behtar hai, sab se ziyadah farmaan bardaar hai, woh shaan mein sab se buland aur Tere yahan izzat waale Muhammad (s.a.w.a) hai aur ba-zariye unki paak aulaad ke jo Imam hai hidaayat dene waale hidaayat yaafta.", "Urdu": "پس میں پناہ حاصل کرتا ہوں تیری کریم ذات اور تیری عزّت و جلالت کی تجھ سے تعلق بناتاہوں تیرے قریب ہوتا ہوں ان کے ذریعے جو مخلوق میں تیرے محبوب ہیں تیرے ہاں سب سے معزز ہیں تیرے نزدیک سب سے بہتر ہیں سب سے زیادہ فرما بردار ہیں وہ شان میں سب سے بلند اورتیرے ہاں عزّت والے محمدؐ ہیں اور ان کی پاک اولادؑ کے ذریعےجو امامؑ ہیں ہدایت دینے والے ہدایت یافتہ۔", "RArabic": "FAHAA ANAA-ZAA MUSTA-JEEROON BE-KARAME WAJHE-KA WA I’ZZE JALAALE-KA MOTA-WASSE-LOON ILAIKA MOTA-QARRE-BOON ILAIKA BE-AHAB-BE KHALQE-QA ILAIKA WA AKRAME-HIM A’LAIKA WA AWLAA-HUM BEKA WA ATWA-E’HIM LAKA WA A’ZAME-HIM MANZE-LATAN WA MAKAA-NAN I’NDAKA MOHAMMADAW WA I’T-RATE-HIT TAAHE-REE-NAL A-IMMA-TIL HODAA-TIL MAHDEE-YEEY-NA.", "ArabicText1": "فَهَا اَنَاذَا مُسْتَجِيْرٌ بِكَرَمِ وَجْهِكَ وَعِزِّ جَلَالِكَ مُتَوَسِّلٌ اِلَيْكَ مُتَقَرِّبٌ اِلَيْكَ بِاَحَبِّ خَلْقِكَ اِلَيْكَ وَاَكْرَمِهِمْ عَلَيْكَ وَاَوْلَاهُمْ بِكَ وَاَطْوَعِهِمْ لَكَ وَاَعْظَمِهِمْ مَنْزِلَةً وَمَكَانًا عِنْدَكَ مُحَمَّدٍ وَّعِتْرَتِهِ الطَّاهِرِيْنَ الْاَئِمَّةِ الْهُدَاةِ الْمَهْدِيِّيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014638, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "The obedience to whom has been imposed by You on Your creatures, the love for whom has been ordered by You and whom You have made the men in authority after Your Messenger, Allah’s blessings be upon him and his Household. O He Who humiliates every obstinate tyrant! O He Who grants dignity to the faithful believers! I have exerted all my efforts; so, (please) release me at this very moment and grant me mercy from You that You may endow me, O Most Merciful of all.", "Gujarati": null, "RGujarati": null, "RUrdu": "Keh jin ki ita’at Tu ne apne bando’n par waajib ki hai, un se mohabbat rakhne ka hukm diya aur unhe apne Rasool ke baad wilaayat o hukumat di hai, un par aur unki Aal (a.s) par Khuda rehmat kare, ay har dushmani karne waale sar-kash ko zaleel karne waale, ay momino ko izzat dene waale meri himmat tamaam ho gayi hai, pas isi ghadi mujhe maafi de aur mujh par rehmat farma aur mujh par ehsaan kar, ay sab se ziyadah rahem karne waale.", "Urdu": "کہ جن کی اطاعت تو نے اپنے بندوں پر واجب کی ہے ان سے محبت رکھنے کا حکم دیا اور انہیں اپنے رسول ﷺ کے بعد ولایت و حکومت دی ہے ان پر اور ان کی آل ؑ پر خدا رحمت کرے اے ہر دشمنی کرنے والے سرکش کو ذلیل کرنے والے اے مومنوں کو عزّت دینے والے میری ہمت تمام ہوگئی ہے پس اسی گھڑی مجھے معافی دے اور مجھ پر رحمت فرما اور مجھ پر احسان کر اے سب سے زیادہ رحم کرنے والے۔", "RArabic": "ALLAZEE-NA FARAZ-TA A’LAA KHALQE-KA TAA-A’TA-HUM WA AMARTA BE-MAWADDA-TE-HIM WA JA-A’L-TA-HUM WA LAA TAL AMRE MIN BA’DE RASOOLE-KA SALLAL-LAAHO A’LAIHE WA AALE-HI MOZILLA KULLE JABBAA-RIN A’NEE-DIN WA YAA MO-I’ZZAL MO-MENEENA BALA-GHA MAJ-HOODI FA-HAB LEE NAFSE-YAS SAA-A’TA WA RAH-MATAM MINKA TAMUNNO BEHAA A’LAIYYA YAA AR-HAMAR RAAHE-MEENA.", "ArabicText1": "اَلَّذِيْنَ فَرَضْتَ عَلٰى خَلْقِكَ طَاعَتَهُمْ وَاَمَرْتَ بِمَوَدَّتِهِمْ وَجَعَلْتَهُمْ وُلَاةَ الْاَمْرِ مِنْ بَعْدِ رَسُوْلِكَ صَلَّى اللهُ عَلَيْهِ وَاٰلِهٖ يَا مُذِلَّ كُلِّ جَبَّارٍ عَنِيْدٍ وَيَا مُعِزَّ الْمُؤْمِنِيْنَ بَلَغَ مَجْهُوْدِيْ فَهَبْ لِيْ نَفْسِيَ السَّاعَةَ وَرَحْمَةً مِّنْكَ تَمُنُّ بِهَا عَلَيَّ يَا اَرْحَمَ الرَّاحِمِيْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicT