ِ الْوَاسِعِ‌ الْحَلَالِ الطَّيِّبِ بِرَحْمَتِكَ تَكُوْنُ لَكَ الْمِنَّةُ عَلَيَّ وَتَكُوْنُ لِيْ غِنًى عَنْ خَلْقِكَ خَالِصًا لَيْسَ لِاَحَدٍ مِّنْ خَلْقِكَ مِنْهُ (مِنْهُ مِنْ غَيْرِكَ) مِنْ غَيْرِكَ وَاجْعَلْنَا فِيْهِ مِنَ الشَّاكِرِيْنَ وَلَا تَفْضَحْنِيْ‌ يَوْمَ التَّلَاقِ‌۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1015482, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O my God! I ask you for prosperity in the world. I take refuge in You from wasting it! I ask You to grant me abstinence it this world! And I take refuge in You from being greedy of it! I ask You for wealth in this world, and I take refuge in You from being poor in it. O my God! If You grant me Extensive Sustenance in this world, please make me abstain from it. If You give me little sustenance, please make me inclined to it.", "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": "ALLAAHUMMA INNEE AS-ALO-KAS SA-A’TA FID-DUNYAA WA A-O’O-ZO BEKA MENAS SARAFE FEEHAA WA AS-ALO-KAZ ZOHDA FID-DUNYAA WA A-O’O-ZO BEKA MINAL HARSE A’LAIY-HAA WA AS-ALO-KAL GHENAA FID-DUNYAA WA A-O’O-ZOO BEKA MINAL FAQRE FEEHAA. ALLAAHUMMA IN BE-SATTA A’LAIY-YA FID-DUNYAA FA-ZAHHID NEE FEEHAA WA IN QATTAR-TA A’LAIY-YA RIZQEE FALAA TO-RAGH-GHIB-NEE FEEHAA.", "ArabicText1": "اَللّٰهُمَّ اِنِّيْ اَسْئَلُكَ السَّعَةَ فِي الدُّنْيَا وَاَعُوْذُ بِكَ مِنَ السَّرَفِ فِيْهَا وَاَسْئَلُكَ الزُّهْدَ فِي الدُّنْيَا وَاَعُوْذُ بِكَ مِنَ الْحِرْصِ عَلَيْهَا وَاَسْئَلُكَ الْغِنٰى فِي الدُّنْيَا وَاَعُوْذُ بِكَ مِنَ الْفَقْرِ فِيْهَا۔ اَللّٰهُمَّ اِنْ بَسَطْتَ عَلَيَّ فِي الدُّنْيَا فَزَهِّدْنِيْ فِيْهَا وَاِنْ قَتَّرْتَ عَلَيَّ رِزْقِيْ فَلَا تُرَغِّبْنِيْ فِيْهَا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "