TAABE SHAQEE-YAN FAK-TUBNEE I’NDA-KA SA-E’E-DAN MO-WAFFA-QAN LIL-KHAIRE WAM-HUS MASH-SHAKAAA-E A’NNEE QULTA FIL KETAA-BIL LAZEE AN-ZALTA A’LAA NABIYYE-KA SALA-WAATO-KA A’LAIY-HE WA AALE-HI YAMHUL LAAHO MAA YASHAAA-O WA YUSBE-TO WA I’N-DAHU UMMUL KITAABE.", "ArabicText1": "يَا ذَا الْمَنِّ وَالْاِحْسَانِ يَا ذَا الْجَلَالِ وَالْاِكْرَامِ يَا ذَا الْجُوْدِ وَالْاِفْضَالِ يَا ذَا الطَّوْلِ يَا لَا اِلٰهَ اِلَّا اَنْتَ ظَهْرَ اللَّاجِيْنَ وَاَمَانَ الْخَاۗئِفِيْنَ اِنْ كُنْتَ كَتَبْتَنِيْ فِيْ اُمِّ الْكِتَابِ شَقِيًّا فَاكْتُبْنِيْ عِنْدَكَ سَعِيْدًا مُوَفَّقًا لِلْخَيْرِ وَامْحُ اسْمَ الشَّقَاۗءِ عَنِّيْ فَاِنَّكَ قُلْتَ فِي الْكِتَابِ الَّذِيْ اَنْزَلْتَ عَلٰى نَبِيِّكَ صَلَوَاتُكَ عَلَيْهِ وَآلِهٖ‌ يَمْحُوا اللهُ مَا يَشَاۗءُ وَيُثْبِتُ وَعِنْدَهٗ اُمُّ الْكِتَابِ‌۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "Ara