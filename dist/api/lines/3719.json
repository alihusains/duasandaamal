[{"Id": 1010498, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "After ghusl has been given to a corpse, it is obligatory to camphorate it ie. to apply camphor on its forehead, palms, knees, and the tips of the big toes such that a little of the camphor remains on them even if by means other than rubbing. It is recommended that camphor also be applied to the tip of the nose of the corpse. The camphor must be powdered, fresh, and mubaḥ (not usurped); and if it has lost its fragrance on account of it being old, it will not suffice.", "GujaratiDescription": null, "RUrduDescription": "Ghusl dene ke baad waajib hai keh mayyit ko Hunoot kiya jaaye yaani uski peshaani (forehead), dono hatheliyo’n (palms), dono paaw ke gutno (knees) aur dono paaw ke anguto’n (toes) par kaafoor is tarah mala jaaye keh kuchh kaafoor us par baaqi rahe. Agar kuchh kaafoor bagair maley baaqi bache aur mustahab yeh hai keh mayyit ki naak par bhi kaafoor mala jaaye. Kaafoor peesa huwa (powder) aur taaza (fresh) hona chahiye aur agar puraana hone ki wajah se uski khusboo zaael (khatm) ho gayi ho to kaafi nahi.", "UrduDescription": "غسل دینے کے بعد واجب ہے کہ میت کو حنوط کیا جائے یعنی اس کی پیشانی، دونوں ہتھیلیوں، دونوں پاوں کے گوٹھنوں  اور دونو پاوں کے انگوٹھوں پر کافور اس طرح ملا جائے کہ کچھ کافور اس پر باقی رہے۔ خواہ کچھ کافور بغیر ملے باقی بچے اور مستحب یہ ہے کہ میت کی ناک پر بھی کافور ملا جائے۔ کافور پسا ہوا اور تازہ ہونا چاہئے اور اگر پرانا ہونے کی وجہ سے اس کی خوشبو زائل ہو گئی ہو تو کافی نہیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010499, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "The recommended precaution is that camphor should be first applied to the forehead of the corpse; thereafter, there is no particular order in applying camphor to the other parts of the body.", "GujaratiDescription": null, "RUrduDescription": "Ehtiyaat-e-mustahab yeh hai keh kaafoor pehle mayyit ki peshaani par mala jaaye lekin dusre maqaamaat par malne mein tarteeb zaroori nahi hai.", "UrduDescription": "احتیاط مستحب یہ ہے کہ کافور پہلے میت کی پیشانی پر ملا جائے لیکن دوسرے مقامات پر ملنے میں ترتیب ضروری نہیں ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010500, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 3, "EnglishDescription": "If someone dies in the state of Ehraam, it is not permitted to camphorate his body, unless he was in the state of Ehraam for Haj-e-Tamatto and he had completed the Tawaf its Prayer, and Saee or, he was in the state of Ehram for Haj-e-Qiraan or Haj-e-Ifrada and he had performed Halaq (saving head) in these two cases, he must be given ghusl with camphor water.", "GujaratiDescription": null, "RUrduDescription": "Agar koi shakhs ehraam ki haalat mein mar jaaye to usey Hunoot karna jaaez nahi hai lekin agar woh Haj-e-Tamatto ka ehraam ho aur woh Tawaaf aur Tawaaf ki Namaz aur Saee ko mukammal kar chuka ho ya Haj-e-Qiraan ya Haj-e-Ifrada ke Ehraam mein ho aur sar munda chuka ho to in do (2) surato’n mein usko Hunoot karna jaaez hai.", "UrduDescription": " اگر کوئی شخص احرام کی حالت میں مر جائے تو اسے حنوط کرنا جائز نہیں ہے لیکن اگر وہ حج تمتع کا احرام ہو اور وہ طواف اور نماز طواف اور سعی کو مکمل کر چکا ہو یا حج قران یا حج افراد کے احرام میں ہو اور سر منڈا چکا ہو تو ان دو صورتوں میں اس کو حنوط کیا جا سکتا ہے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010501, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 4, "EnglishDescription": "The recommended precaution is that a corpse should not be perfumed with musk, ambergris (anbar), aloes-wood (Ood) and other fragrances, and nor should these be mixed with the camphor.", "GujaratiDescription": null, "RUrduDescription": "Ehtiyaat-e-Mustahab yeh hai keh mayyit ko Mushk, Amber, Ood aur dusri khushbooe’n na lagaayi jaaye aur unhe’n kaafoor ke saath bhi na milaaya jaaye.", "UrduDescription": "احتیاط مستحب یہ ہے کہ میت کو مشک، عنبر، عُود اور دوسری خوشبوئیں نہ لگائی جائیں اور انہیں کافور کے ساتھ بھی نہ ملایا جائے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010502, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 5, "EnglishDescription": "It is recommended to mix some turbah from the grave of His Eminence Sayyidush Shohada (Imam al-Ḥusain) (a) with the camphor. However, the camphor must not be applied to places on the body that would cause disrespect to that earth (khaak-e-shifa). Furthermore, the amount of turbah should not be so great that when it is mixed with the camphor, it can no longer be called camphor.", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh Sayyadush Shohoda Imam Husain (a) ki qabr-e-mubaarak ki mitti (khaak-e-shifa) ki kuchh miqdaar kaafoor mein mila li jaaye lekin uska kaafoor ko aise maqaamaat par nahi lagna chahiye jahan lagne se khaak-e-shifa ki be-hurmati ho aur yeh bhi zaroori hai keh khaak-e-shifa itni ziyadah na ho keh jab woh kaafoor ke saath mil jaaye to usey kaafoor na kaha ja sakey.", "UrduDescription": "مستحب ہے کہ سید الشہداء امام حسینؑ کی قبر مبارک کی مٹی (خاک شفا) کی کچھ مقدار کافور میں ملا لی جائے لیکن اس کافور کو ایسے مقامات پر نہیں لگانا چاہئے جہاں لگانے سے خاک شفا کی بے حرمتی ہو اور یہ بھی ضروری ہے کہ خاک شفا اتنی زیادہ نہ ہو کہ جب وہ کافور کے ساتھ مل جائے تو اسے کافور نہ کہا جا سکے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010503, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 6, "EnglishDescription": "If camphor cannot be procured, or if the quantity that can be procured is sufficient only for ghusl, then camphorating is not necessary. And in the event that after ghusl an amount of camphor is left over but it is not sufficient for it to be applied to all seven parts of the body, then based on recommended precaution it must first be applied to the forehead and then to the other parts if any is left over.", "GujaratiDescription": null, "RUrduDescription": "Agar kaafoor na mil sakey ya faqat ghusl ke liye kaafi ho to hunoot karna zaroori nahi aur agar ghusl ki zaroori se ziyadah ho lekin tamaam 7 aaza (parts) ke liye kaafi na ho to ehtiyaat-e-mustahab ki bina bar chahiye keh pehle peshaani par aur agar bach jaaye to dusre maqaamaat par mala jaaye.", "UrduDescription": "اگر کافور نہ مل سکے یا فقط غسل کے لئے کافی ہو تو حنوط کرنا ضروری نہیں اور اگر غسل کی ضرورت سے زیادہ ہو لیکن تمام سات اعضا کے لئے کافی نہ ہو تو احتیاط مستحب کی بنا پر چاہئے کہ پہلے پیشانی پر اور اگر بچ جائے تو دوسرے مقامات پر ملا جائے۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": nu