[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016056, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Mai Tujh se is jagah sawaal karta hu aur apni is pehle ibaadat mein keh meri taubah ko qabool kar aur meri khataawo’n se dar-guzar farma aur mere gunaho’n ke bojh ko mujh se dur kar de. Tamaam taarife’n us Allah ke liye hai jis ne mujhe apni mohtaram ghar tak pohonchaya. Ay Allah! Mai gawahi deta hu keh yeh Tera woh mohtaram ghar jise Tu ne logo’n ke jama hone ki jagah qaraar diya hai aur jaaye aman o mubarak aur tamaam logo’n ke liye sabab'e hidaayat qaraar diya hi.", "Urdu": "اے اللہ! میں تجھ سے اس جگہ سوال کرتا ہوں اور اپنی اس پہلی عبادت میں کہ میری توبہ کو قبول کر اور میری خطاؤں سے درگزر فرما اور میرے گناہوں کے بوجھ کو مجھ سے دور کر دے، تمام تعریفیں اس اللہ کے لئے ہیں جس نے مجھے اپنے محترم گھر تک پہونچایا۔ اے اللہ! میں گواہی دیتا ہوں کہ یہ تیرا وہ محترم گھر ہے جسے تو نے لوگوں کے جمع ہونے کی جگہ قرار دیا ہے اور جائے امن و مبارک اور تمام لوگوں کے لئے سبب ہدایت قرار دیا ہے۔", "RArabic": "ALLAAHUMMA INNEE AS-ALOKA FEE MAQAAMEE HAAZAA WA FEE AWWALE MANAASEKEE AN TAQBALA TAWBATEE WA AN TATAJAAWAZA A’N KHATEEE-ATEE WA AN TAZA-A’ A’NNEE WIZREE ALHAMDO LILLAAHIL LAZEE BALLAGHANEE BAYTAHUL HARAAMA ALLAAHUMMA INNEE ASH-HADO ANNA HAAZAA BAYTOKAL HARAAMUL LAZEE JA-A’LTAHU MASAABATAN LIN-NAASE WA AMNAN MOBAARAKAN WA HODAN LIL-A’ALAMEENA.", "ArabicText1": "اَللّٰہُمَّ اِنِّیْ اَسْئَلُكَ فِیْ مَقَامِیْ ہٰذَا وَفِیْ اَوَّلِ مَنَاسِكِیْ اَنْ تَقْبَلَ تَوْبَتِیْ وَاَنْ تَتَجَاوَزَ عَنْ خَطِیْٓئَتِیْ وَاَنْ تَضَعَ عَنِّیْ وِزْرِیْ۔ اَلْحَمْدُ لِلہِ الَّذِیْ بَلَّغَنِیْ بَیْتَہُ الْحَرَامَ۔ اَللّٰہُمَّ اِنِّیْ اَشْہَدُ اَنَّ ہٰذَا بَیْتُكَ الْحَرَامُ الَّذِیْ جَعَلْتَہٗ مَثَابَۃً لِلنَّاسِ وَاَمْنًا مُبَارَكًا وَہُدًی لِّلْعَالَمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016057, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Mai Tera banda hu aur yeh shaher Tera shaher hai aur yeh ghar Tera ghar hai. mai rehmat ka talab gaar ban kar aaya hu, aur Teri ita’at ka qasad kiye hu aur Tere hukm ki ita’at karne waala, Teri taqdeer o andaaza par raazi hu, mai Tujh se is tarah sawaal karta hu jaise Tere dar ka faqeer aur Teri saza se darne waala sawaal karta hai. Khudaaya! Mujh par apni rehmato’n ke darwaaze khol de aur mujhe ita’at aur marzi mein masroof'e kaar (lagaaye rehna) wa sar-gharm (koshish karne waala) rakkh.", "Urdu": "اے اللہ! میں تیرا بندہ ہوں اور یہ شہر تیرا شہر ہے اور یہ گھر تیرا گھر ہے، میں رحمت کا طلب گار بن کر آیا ہوں، اور تیری اطاعت کا قصد کئے ہوں اور تیرے حکم کی اطاعت کرنے والا، تیری تقدیر و اندازہ پر راضی ہوں، میں تجھ سے اس طرح سوال کرتا ہوں جیسے تیرے در کا فقیر اور تیری سزا سے ڈرنے والا سوال کرتا ہے۔ خدایا! مجھ پر اپنی رحمتوں کے دروازئ کھول سے اور مجھے اطاعت اور مرضی میں مصروف کار و سرگرم رکھ۔", "RArabic": "ALLAAHUMMA INNEE A’BDOKA WAL BALADA BALADOKA WAL-BAYTA BAYTOKA JEA-TO ATLOBO RAHMATAKA WA AUMMO TAA-A’TAKA MOTEE-A’N LEAMREKA RAAZEYAN BEQADAREKA AS-ALOKA MAS-ALATA AMREKA RAAZEYAN BEQADAREKA AS-ALOKA MAS-ALATAL FAQEERE ELAYKAL KHAAA-EFE LE-O’QOOBATEKA ALLAAHUMMAF TAH LEE ABWAABA RAHMATEKA WAS-TA’MILNEE BE-TAA-A’TEKA WA MARZAATEKA.", "ArabicText1": "اَللّٰہُمَّ اِنِّیْ عَبْدُكَ وَالْبَلَدَ بَلَدُكَ وَالْبَیْتَ بَیْتُكَ جِئْتُ اَطْلُبُ رَحْمَتَكَ وَاَؤُمُّ طَاعَتَكَ مُطِیْعًا لِاَمْرِكَ رَاضِیًا بِقَدَرِكَ اَسْئَلُكَ مَسْاَلَۃَ الْفَقِیْرِ اِلَیْكَ الْخَآئِفِ لِعُقُوْبَتِكَ۔ اَللّٰہُمَّ افْتَحْ لِیْ اَبْوَابَ رَحْمَتِكَ وَاسْتَعْمِلْنِیْ بِطَاعَتِكَ وَمَرْضَاتِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15"