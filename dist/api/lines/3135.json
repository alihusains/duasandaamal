bicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1013807, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Glory be to the Lord of majesty and exalted greatness. Glory be to the Lord of honor and sublime authority. Glory be to the Lord of eternal, splendid sovereignty. Glory be to the Lord of splendor and beauty. Glory be to Him Who is clad in light and dignity. Glory be to Him Who makes out the footprints of the ant on the stone and (the exact time and place of) the bird dipping down through the air.", "Gujarati": null, "RGujarati": null, "RUrdu": "Paak hai woh jo bade jalaal o buzurgi ka maalik hai. Paak hai woh jo badi buland izzat ka maalik hai. Paak hai woh jo qadeem mulk o iftekhaar waala hai. Paak hai woh jo husn o Jamaal waala hai. Paak hai woh jis ne noor aur waqaar ki rida pehni. Paak hai woh jo patthar par chalti chiuti ka naqshe pa aur hawa mein udte parinde ko dekhta hai.", "Urdu": "پاک ہے وہ جو بڑے جلال و بزرگی کا مالک ہے پاک ہے وہ جو بڑی بلند عزّت کا مالک ہےپاک ہے وہ جو قدیم ملک و افتخار والا ہے پاک ہے وہ جو حسنؑ و جمال والا ہے پاک ہے وہ جس نے نور اور وقارکی ردا پہنی پاک ہے وہ جوپتھر پر چلتی چیونٹی کا نقش پا اور ہوا میں اڑتے پرندے کو دیکھتا ہے۔", "RArabic": "SUBHAANA ZIL JALAALIL BAA-ZEKHIL A’ZEEME SUBHAANA ZIL I’ZZISH SHAAMEKHIL MONEEFE SUBHAANA ZIL MULKIL FAAKHERIL QADEEME SUBHAANA ZIL BAHJATE WAL JAMAALE SUBHAANA MAN TARADDAA BIN-NOORE WAL WEQAARE SUBHAANA MAYN YARAA ASARAN NAMLE FIS-SAFAA WA WAQA-A’T TAYRE FIL HAWAA-E.", "ArabicText1": "سُبْحَانَ ذِی الْجَلَالِ الْبَاذِخِ الْعَظِیْمِ۔ سُبْحَانَ ذِی الْعِزِّ الشَّامِخِ الْمُنِیْفِ۔ سُبْحَانَ ذِی الْمُلْكِ الْفَاخِرِ الْقَدِیْمِ۔ سُبْحَانَ ذِیْ الْبَهْجَۃِ وَالْجَمَالِ۔ سُبحَانَ مَنْ تَرَدّٰی بِالنُّوْرِ وَالْوِقَارِ۔ سُبْحَانَ مَنْ یَّرٰی اَثَرَ الْنَّمْلِ فِی الصَّفَا وَ وَقْعَ الطَّیْرِ فِی الْهَوَاءِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "Arab