[{"Id": 1012801, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "The Late Shaykh Kafami says that when you intend to enter the Masjid Nabawi (Prophet’s mosque) or the shrine of any Imam (a) you must recite as follows…", "GujaratiDescription": null, "RUrduDescription": "Marhoom Shaikh Kafami farmate hai keh jab tum Masjid Nabavi ya koi Imam (a) ke Haram mein daakhil hone ka iraada karo to is tarah se kaho…", "UrduDescription": "شیخ کفعمیؒ نے فرمایا ہے : جب حضرت رسول ؐ کی مسجد یا ائمہ ؑمیں سے کسی امام ؑکے حرم میں جانے کا ارادہ کرے تو دروازے پر کھڑے ہو کر یہ پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012802, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I am standing at one of the doors of Your Prophet’s Houses may Your blessings be upon him and his Household. And You have prevented people to enter there before they obtain his permission. You have thus said, “O ye who believe! Enter not the Prophet’s houses until leave is given you.”", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Mai Tere Nabi (s) ke ghar ke darwaazo’n mein se ek darwaaze par haazir hu, Un (s.a.w.a) par aur unki Aal (a.s) par Teri rehmat naazil ho. Tu ne logo’n ko Aan Hazrat (s.a.w.a) ki ijaazat ke baghair unke gharo’n mein daakhil hone se mana kiya hai aur Tera farmaan hai, “Ay imaan waalo! Daakhil na huwa karo Nabi ke gharo’n mein magar us waqt jab tumhe ijaazat mil jaaye” (33:53).", "Urdu": "اے معبود! میں تیرے نبی کے گھر کے دروازوں میں سے ایک دروازے پر حاضر ہوں ان پر اور ان کی آل ؑپر تیری رحمت نازل ہوتو نے لوگوں کو آنحضرتؐ کی اجازت کے بغیر ان کے گھروں میں داخل ہونے سے منع کیا ہے اور تیرا فرمان ہے اے ایمان والو! نبی کے گھروں میں داخل نہ ہواکرو مگر اس وقت جب تمہیں اجازت مل جائے۔", "RArabic": "ALLAAHUMMA INNEE WAQAF-TO A’LAA BAA-BIN MIN ABWAABE BOYOO-TE NABIYYE-KA SALAWAATO-KA A’LAYHE WA AALEHI WA QAD MANAA’-TAN NAASA AN YAD-KHOLOO ILLAA BE-IZNE-HEE FA-QULTA YAA AYYOHAL LAZEENA AAMANOO LAA TAD-KHOLOO BOYOO-TAN NABIYYE ILLAA AN YU-ZANA LA-KUM.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ وَقَفْتُ عَلٰی بَابٍ مِّنْ اَبْوَابِ بُیُوْتِ نَبِیِّكَ صَلَوَاتُكَ عَلَیْهِ وَآلِهٖ وَقَدْ مَنَعْتَ النَّاسَ اَنْ یَّدْخُلُوْا اِلَّا بِاِذْنِهٖ فَقُلْتَ یَآ اَیُّهَا الَّذِیْنَ اٰمَنُوْا لَا تَدْخُلُوْا بُیُوْتً النَّبِیِّ اِلَّا اَنْ یُّؤْذَنَ لَكُمْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012803, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, I believe in the sanctity of the owner of this holy shrine in his absence as same as I believe in it in his presence. I also know for sure that Your Messenger and Your Representatives, peace be upon them are live, finding their sustenance in the presence of You; they can see my place, hear my words, and respond to my greetings, but You have prevented my hearing from receiving their words and You have opened the door of my understanding to taste the fine flavor of my confidential speech with them.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Allah! Be-shak mai is haram sharif mein madfoon (dafan shudah) hasti ka unki ghaibat mein aise hi motaqid (maanta) hu jaise mai unke zahoor mein motaqid tha aur mai jaanta hu keh Tera Rasool (s.a.w.a) aur Tere kholafa keh un sab par salaam ho woh zindah hai aur Tere yahan rizq paate hai, woh mujhe dekh rahe hai, meri maar o zaat (talab o haajaat) soon rahe hai aur mere salaam ka jawaab de rahe hai aur be-shak Tu ne mere kaano ko unka kalaam soonne se roka hai aur un se raaz o neyaaz karne mein mere fahem (samajh) ko khol rakkha hai.", "Urdu": "اے اﷲبے شک میں اس حرم مبارک میں مدفون ہستی کا ان کی غیبت میں ایسے ہی معتقد ہوں جیسے میں ان کے ظہور میں معتقد تھا اور میں جانتا ہوں کہ تیرا رسول ؐاور تیرے خلفاء کہ ان سب پر سلام ہو وہ زندہ ہیں اور تیرے ہاں رزق پاتے ہیں وہ مجھے دیکھ رہے ہیں میری باتیں سن رہے ہیں اور میرے سلام کا جواب دے رہے ہیں اور بے شک تو نے میرے کانوں کو ان کا کلام سننے سے روکا ہے اور ان سے راز ونیاز کرنے میں میرے فہم کو کھول رکھا ہے اور۔", "RArabic": "ALLAAHUMMA INNEE AA’-TAQEDO HURMATA SAAHEBE HAAZAL MASH-HADISH SHAREE-FE FEE GHAYBATE-HE KAMAA AA’-TAQEDO-HAA FEE HAZRATE-HI WA AA’-LAMO ANNA RASOOLA-KA WA KHOLAFAAA-A-KA A’LAYHE-MUS SALAAMO AHYAAA-UN I’NDAKA YURZAQOO-NA YARAW-NA MAQAA-MEE WA YASMA-O’ONA KALAA-MEE WA YARUDDOO-NA SALAAMEE WA ANNAKA HAJABTA A’N SAM-E’E KALAAMA-HUM WA FATAH-TA BAABA FAHMEE BE-LAZEEZE MONAAJAATE-HIM.", "ArabicText1": "اَللّٰهُمَّ اِنِّیْ اَعْتَقِدُ حُرْمَۃَ صَاحِبِ هٰذَا الْمَشْهَدِ الشَّرِیْفِ فِیْ غَیْبَتِهٖ كَمَآ اَعْتَقِدُهَا فِیْ حَضْرَتِهٖ وَاَعْلَمُ اَنَّ رَسُوْلَكَ وَخُلَفَآئَكَ عَلَیْهِمُ السَّلَامُ اَحْیَآءٌ عِنْدَكَ یُرْزَقُوْنَ یَرَوْنَ مَقَامِیْ وَیَسْمَعُوْنَ كَلَامِیْ وَیَرُدُّوْنَ سَلَامِیْ وَاَنَّكَ حَجَبْتَ عَنْ سَمْعِیْ كَلَامَهُمْ وَفَتَحْتَ بَابَ فَهْمِیْ بِلَذِیْذِ مُنَاجَاتِهِمْ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012804, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "I thus ask Your permission, O my Lord, first of all, the permission of Your Prophet, peace be upon him and his Household, secondly, the permission of Your Representative, the Imam the obedience to whom is incumbent upon me…", "Gujarati": null, "RGujarati": null, "RUrdu": "Aur ay mere Rab pehle mai Tujh se ijaazat maangta hu phir Tere Rasool (s.a.w.a) se ijaazat maangta hu, keh Khuda rehmat kare un par aur unki Aal (a.s) par aur ijaazat maangta hu Tere Khalifa o Imam se jin ki ita’at mujh par waajib hai…", "Urdu": "اے میرے رب پہلے میں تجھ سے اجازت مانگتاہوں پھر تیرے رسولؐ سے اجازت مانگتا ہوں کہ خدا رحمت کرے ان پر اور ان کی آل ؑپر اور اجازت مانگتا ہوں تیرے خلیفہ و امام سے جن کی اطاعت مجھ پر واجب ہے۔۔۔", "RArabic": "WA INNEE ASTAAZENO-KA YAA RABBE AWWALAN WA ASTAA-ZENO RASOOLA-KA SALLALLAAHO A’LAYHE WA AALEHI SAANE-YAN WA ASTAA-ZENO KHALEEFATA-KAL IMAAMAL MAFROOZA A’LAYYA TAA-A’TO-HU…", "ArabicText1": "وَاِنِّیْ اَسْتَاذِنُكَ یَا رَبِّ اَوَّلًا وَّاَسْتَاْذِنُ رَسُوْلَكَ صَلَّی اللہُ عَلَیْهِ وَاٰلِهٖ ثَانِیًا وَاَسْتَاذِنُ خَلِیْفَتَكَ الْاِمَامَ الْمَفْرُوْضَ عَلَیَّ طَاعَتُهٗ فُلَانَ بْنَ فُلَانٍ۔۔۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012805, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "In place of Fulaan bin Fulaan mention the name of the Infallible whose Ziyarat you are reciting. In the same way mention the name of his father also. And after that recite the following…", "GujaratiDescription": null, "RUrduDescription": "Fulaan bin Fulaan ki jagah par us Imam (a) ka naam unke waalid ke naam ke saath kaho jiske rauze ke saamne tum khade ho. Iske baad is tarah kaho…", "UrduDescription": "فلاں ابن فلاں کے بجائے ان امام ؑ کا نام مع ان کے والد بزرگوار کے اسم گرامی کو زبان پر لائے کہ جن کی زیارت کررہا ہے مثلاً اگر امام حسینؑ کی زیارت ہے تو کہے حسین ابن علیؑ اورپھریہ پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012806, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "…and the permission of the angels whom are commissioned to supervise this blessed area, thirdly. May I enter, O Messenger of Allah? May I enter, O Argument of Allah? May I enter, O angels of Allah the intimate, the residing in this shrine? So, (please do) permit me to enter, O my Master, in the best way of permission that you have ever conferred upon any of your intimate adherents. If I do not deserve such permission, then you are worthy of conferring it upon me.", "Gujarati": null, "RGujarati": null, "RUrdu": "…aur phir un farishto’n se jo is baargah ke nigheh-baan hai jo ba-barkat hai. Aaya mai andar aa jaawu ay Allah ke Rasool (s.a.w.a), aaya mai andar aa jaawu ay Khuda ki Hujjat (a.s), aaya mai andar aa jaawu ay Khuda ke muqarrab malaayeka jo qabre mutahar ke paas muqeem (ruke huwe) hai. Pas ay mere Maula (a.s) mujhe andar aane ki ijaazat, aisi behtareen ijaazat jo aap ne apne dosto’n mein kisi ko di ho, pas agar-che mai uske laayaq nahi hu lekin Aap ijaazat dene ke ahel hai.", "Urdu": "۔۔۔اورپھر ان فرشتوں سے جو اس بارگاہ کے نگہبان ہیں جو پُر برکت ہے آیا میں اندر آجاؤں اے اﷲکے رسولؐ ؟آیا میں اندر آجاؤں اے خدا کی حجت ؑ؟آیا میں اندر آجاؤں اے خدا کےمقرب ملائکہ؟ جو قبر مطہر کے پاس مقیم ہیں پس اے میرے مولاؑ مجھے اندر آنے کی اجازت دیجیے ایسی بہترین اجازت جو آپ نےاپنے دوستوں میں کسی کو دی ہو پس اگرچہ میں اس کے لائق نہیں ہوں لیکن آپ اجازت دینے کے اہل ہیں۔", "RArabic": "…WAL MALAAA-EKA-TAL MOWAKKE-LEENA BE-HAAZE-HIL BUQ-A’TIL MOBAARAKA-TE SAALE-SAN A-AD-KHOLO YAA RASOOLALLAA-HE A-AD-KHOLO YAA HUJJATALLAA-HE A-AD-KHOLO YAA MALAAA-E-KATAL-LAAHIL MOQARRABEE-NAL MOQEE-MEENA FEE HAAZAL MASH-HADE FAA-ZAN LEE YAA MAWLAAYA FID DOKHOO-LE AFZALA MAA AZINTA LE-AHA-DIN MIN AWLEYAAA-E-KA FA-IN LAM AKUN AHLAN LE-ZAALEKA FA-ANTA AHLUN LE-ZAALEKA.", "ArabicText1": "۔۔۔وَالْمَلَٓائِكَةَ الْمُوَكَّلِيْنَ بِهٰذِهِ الْبُقْعَةِ الْمُبَارَكَةِ ثَالِثًا ءَاَدْخُلُ يَارَسُوْلَ اللهِ ءَاَدْخُلُ يَاحُجَّةَ اللهِ ءَاَدْخُلُ يَامَلَٓائِكَةَ اللهِ الْمُقَرَّبِيْنَ الْمُقِيْمِيْنَ فِيْ هٰذَا الْمَشْهَدِ فَاذَنْ لِيْ يَامَوْلَايَ فِي الدُّخُوْلِ اَفْضَلَ مَا اَذِنْتَ لِاَحَدٍ مِّنْ اَوْلِيَآئِكَ فَاِنْ لَّمْ اَكُنْ اَهْلًا لِّذٰلِكَ فَانْتَ اَهْلٌ لِّذٰلِكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014695, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "You may then kiss the holy doorstep (of the shrine) and enter with your right foot, thus saying…", "GujaratiDescription": null, "RUrduDescription": "Ab aap haram ke darwaaze ko bosa de aur apna daaya’n qadam se daakhil ho yeh kehte huwe…", "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012810, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah (I begin), in Allah (I trust), on the way of Allah, and on the norm of the Messenger of Allah (I proceed), may Allah bless him and his Household. O Allah, (please do) forgive me for You are verily the Oft-Returning.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke naam se, Khuda ki zaat se, Khuda ki raah mein aur Hazrat Rasool (s.a.w.a) Khuda ki millat par, keh rehmat kare Allah un par aur unki Aal (a.s) par. Ay Ma’bood! Mujhe bakhsh de, mujh par rahem farma aur meri taubah qabool kar, keh be-shak Tu bada taubah qabool karne waala maher-baan hai.", "Urdu": "خدا کے نام سے خدا کی ذات سے خدا کی راہ میں اور حضرت رسولِؐ خداکی ملت پر کہ رحمت کرے اﷲان پر اوران کی آلؑ پر اے معبود! مجھے بخش دے مجھ پر رحم فرما اور میری توبہ قبول کرکہ بے شک تو بڑا توبہ قبول کرنے والا مہربان ہے۔", "RArabic": "BISMILLAA-HE WA BILLAA-HE WA FEE SABEELILLAA-HE WA A’LAA MILLA-TE RASOOLILLAA-HE SALLALLAA-HO A’LAIY-HE WA AALE-HI. ALLAAHUM-MAGH FIR-LEE WAR-HAMNEE WA TUB A’LAIYYA INNAKA ANTAT TAWWAA-BUR RAHEEMO.", "ArabicText1": "بِسْمِ اللہ وَبِاللهِ وَفِیْ سَبِیْلِ اللہِ وَعَلٰی مِلَّۃِ رَسُوْلِ اللہِ صَلَّی اللہُ عَلَیْهِ وَاٰلِهٖ۔ اَللّٰهُمَّ اغْفِرْ لِیْ وَارْحَمْنِیْ وَتُبْ عَلَیَّ اِنَّكَ اَنْتَ التَّوَّابُ الرَّحِیْمُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, 