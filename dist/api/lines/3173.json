ھ ہوتا اور یہ لوگ کیسے اچھے رفیق ہیں، خداوندا صلوات بھیج محمد مصطفیٰ اور ان کی آل پر جو پاکیزہ ہیں اور تمام انبیا و مرسلین پر اور ان کے اوصیا و مخلصین پر اور ملائکہ مقربین پر اور خدا کے صالح بندوں پر۔", "RArabic": "FA-YAA LAIY-TA-NEE KUNTO MA-A’KA FAA-FOOZO MA-A’KA FIL JE-NAANE MA-A’N-NABIY-YEENA WASH SHOHA-DAAA-E WAS-SAALE-HEENA WA HASONA OO-LAA'e KA RAFEEQAA. ALLAAHUMMA SALLE A’LAA MOHAMMADIW WA AALE-HIT TAIYYE-BEE-NAT TAAHE-REENA WA A’LAA JAMEE-I’L AMBE-YAA-E WAL MURSA-LEENA WA AW-SEYAAA'e HEMUL MUKHLA-SEENA WA A’LAL MALAAA'e KATIL MOQARRA-BEENA WA E’BAADIL-LAAHIS SAALE-HEEN.", "ArabicText1": "فَیَا لَیْتَنِیْ كُنْتُ مَعَكَ فَافُوْزَ مَعَكَ فِی الْجِنَانِ مَعَ النَّبِیّٖنَ وَالصِّدِّیْقِیْنَ وَالشُّهَدَاۗئِ وَالصَّالِحِیْنَ وَحَسُنَ اُوْلٰۗئِكَ رَفِیْقًا۔ اَللّٰهُمَّ صَلِّ عَلٰی مُحَمَّدٍ وَّاٰلِهِ الطَّیِّبِیْنَ الطَّاهِرِیْنَ وَعَلٰی جَمِیْعِ الْاَنْۢبِیَاۗئِ وَالْمُرْسَلِیْنَ وَاَوْصِیَاۗئِهِمُ الْمُخْلَصِیْنَ وَعَلَی الْمَلَاۗئِكَۃِ الْمُقَرَّبِیْنَ وَعِبَادِ اللهِ الصَّالِحِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010702, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda wanda bakhsh de momineen ko aur momenaat ko, muslemeen ko aur muslemaat ko jo zindah hai aur jo murda hai, hamaare aur unke darmiyaan nekiyo’n ka silsila qaaem kar. Yaqeenan Tu dua qabool karne waala hai, yaqeenan Tu haajate’n puri karne waala hai, yaqeenan Tu har shai par qaadir hai. Puri kar hamaari haajate’n aur mohtaajo’n ki haajate’n, ay aalameen ke Rab.", "Urdu": "خداوندا بخش دے مومنوں کو اور مومنات کو، مسلمین کو اور مسلمات کو جو زندہ ہیں اور جو مردہ ہیں ہمارے اور ان کے درمیان نیکیوں کا سلسلہ قائم کر یقیناً تو دعا قبول کرنے والا ہے، یقیناً تو حاجتیں پوری کرنے والا، یقیناً تو ہرشے پر قادر ہے، پوری کر ہماری حاجتیں اور محتاجوں کی حاجتیں اے رب العالمین۔ ", "RArabic": "ALLAAHUM-MAGH FIR LIL-MO-MENEENA WA LIL-MO-MENAATE WAL MUSLE-MEENA WAL MUSLE-MAATE AL-AHYAAA-E MIN-HUM WAL AM-WAATE TAABE-E’ BAIYNA-NAA WA BAIYNA-HUM BIL KHAIRAA-TE INNA-KA MOJEE-BUD DA’WAATE INNA-KA QAAZE-UL HAA-JAATE INNA-KA A’LAA KULLE SHAI-IN QADEE-ROON WAQZA HAWAA-E-JANAA WA HAWAA-E-JAL MOHTAA-JEENA YAA RABBAL AA’LAMEEN.", "ArabicText1": "اَللّٰهُمَّ اغْفِرْ لِلْمُؤْمِنِیْنَ وَلِلْمُؤْمِنَاتِ وَالْمُسْلِمِیْنَ وَالْمُسْلِمَاتِ اَلْاَحْیَاۗئِ مِنْهُمْ وَالْاَمْوَاتِ تَابِعِ بَیْنَنَا وَبَیْنَهُمْ بِالْخَیْرَاتِ اِنَّكَ مُجِیْبُ الدَّعْوَاتِ اِنَّكَ قَاضِیُ الْحَاجَاتِ اِنَّكَ عَلٰی كُلِّ شَیْئٍ قَدِیْرٌ وَاقْضَ حَوَاۗئِجَنَا وَحَوَاۗئِجَ الْمُحْتَاجِیْنَ یَا رَبَّ الْعٰلَمِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13"