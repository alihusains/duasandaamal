[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010581, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "INSHA-ALLAH COMING SOON", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho Hazrat Rasool'e Khuda (s.a.w.a) par jo Saadiq o ameen hai. Salaam ho Hujjat'e Khuda Hazrat Ali (a.s) par jo Ameerul Momeneen hai. Salaam ho hamaari shehzaadi Hazrat Fatema Zahra (s.a) par jo saare aalam ki aurto’n ki sardaar hai. Salaam ho Hazrat Imam Hasan (a.s) aur Imam Husain (a.s) par jo sardaar hai kul ahle Jannat ke jawaano ke.", "Urdu": "سلام ہو حضرت رسول خدا پر جو صادق و امین ہیں، سلام ہو حجت خدا حضرت علیؑ پر جو امیرالمومنین ہیں، سلام ہو ہماری شہزادی حضرت فاطمہ زہراؑ پر جو سردار ہیں سارے عالم کی عورتوں کی، سلام ہو حضرت امام حسنؑ اور امام حسینؑ پر جو سردار ہیں کل اہل جنت کے جوانوں کے۔", "RArabic": "AS-SALAAMO A’LAA RASOOLIL LAAHIS SAADE-QIL AMEEN. AS-SALAAMO A’LAA HUJJATIL LAAHE A’LIYYIN AMEERIL MO-MEENEEN. AS-SALAAMO A’LAA SAYYE-DA-TE-NAA FAATEMA-TAZ ZAHRAA-E SAYYEDA-TE NESAAA-IL AALAMEEN. AS-SALAAMO A’LAL HASANE WAL HUSAINE SAYYE-DAIY SHA-BAABE AHLIL JANNATE AJMA-EE’N.", "ArabicText1": "اَلسَّلَامُ عَلٰی رَسُوْلِ اللهِ الصَّادِقِ الْاَمِیْنِ۔ اَلسَّلَامُ عَلٰی حُجَّۃِ اللهِ عَلَیٍّ اَمِیْرِ الْمُؤْمِنِیْنَ۔ اَلسَّلَامُ عَلٰی سَیِّدَتِنَا فَاطِمَۃَ الزَّهْرَاۗئِ سَیِّدَۃِ نِسَاۗئِ الْعَالَمِیْنَ۔ اَلسَّلَامُ عَلَی الْحَسَنِ وَالْحُسَیْنِ سَیِّدَیْ شَبَابِ اَهْلِ الْجَنَّۃِ اَجْمَعِیْنَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010582, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho Hazraat'e Aimma (a.s) taahereen par. Salaam ho Khuda ke qareeb-tar malaayeka par. Salaam ho aap par ay shaheed hone waale nusrat'e Imam Husain (a.s) mein. Salaam ho aap par ay Aun ibne Abdillah ibne Ja’far'e Tayyaar (a.s). Mujhe ijaazat dijiye daakhil hone ki apne haram'e shareef mein aur Khuda ki rahmat aur barkate’n ho aap par.", "Urdu": "سلام ہو حضرت ائمہ طاہرین پار، سلام ہوخدا کے مقربین ملائکہ پر، سلام ہو آپ پر اے شہید ہونے والے نصرت امام حسینؑ میں، سلام ہو آپ پر اے عون بن عبد اللہ بن جعفر طیار مجھے اجازت دیجئے داخل ہونے کی اپنے حرم شریف میں اور خدا کی رحمت اور برکتیں ہوں آپ پر۔", "RArabic": "AS-SALAAMO A’LAL AIMMA-TIT TAAHE-REEN. AS-SALAAMO A’LAA MALAA'e KA-TIL LAAHIL MO-QARRA-BEEN. AS-SALAAMO A’LAIKA AYYO-HASH SHAHEEDO FEE NUSRA-TIL HUSAINE A’LAI-HIS SALAAM. AS-SALAAMO A’LAIKA YAA A’W-NABNA A’BDIL LAAHIB-NE JA’FA-RIT TAYYAAR. ATAA-ZANO LEE BID-DOKHOO-LE ELAA HARAME-KASH SHAREE-FE WA RAHMA-TUL LAAHE WA BARA-KAATOH.", "ArabicText1": "اَلسَّلَامُ عَلَی الْاَئِمَّۃِ الطَّاهِرِیْنَ۔ اَلسَّلَامُ عَلٰی مَلَاۗئِكَۃِ اللهِ الْمُقَرَّبِیْنَ۔ اَلسَّلَامُ عَلَیْكَ اَیُّهَا الشَّهِیْدُ فِیْ نُصْرَۃِ الْحُسَیْنِ عَلَیْهِ السَّلَامُ۔ اَلسَّلَامُ عَلَیْكَ یَا عَـوْنَ ابْنَ عَـبْدِ اللهِ بْنِ جَعْفَرِ الطَّیَّارِ۔ اَتَاذَنُ لِیْ بِالدُّخُوْلِ اِلٰی حَرَمِكَ الشَّرِیْفِ وَرَحْمَۃُ اللهِ وَبَرَكَاتُهٗ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlue