onLine": 0, "IsPrintable": 0}, {"Id": 1010677, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay farzand'e Fatema Zahra (s.a) jo sardaar hai tamaam aalaam ki aurto’n ki. Salaam ho aap par ay nek logo’n ki aulaad. Salaam ho aap par ay raahe haq par shaheed hone waale. Salaam ho aap par ay kaafiro’n ke maqtool. Salaam ho aap par ay Aun ibne Abdula bin Ja’far'e Tayyaar (a.s).", "Urdu": "سلام ہو آپ پر اے فرزند فاطمہ زہرا کے جو سردار ہیں تمام زنان عالم کی، سلام ہو آپ پر اے نیک لوگوں کی اولاد، سلام ہو آپ پر اے حق پر شہید ہونے والے، سلام ہو آپ پر اے کافروں کے مقتول، سلام ہو آپ پر اے عون بن عبداللہ بن جعفر طیار۔", "RArabic": "AS-SALAAMO A’LAIKA YABNA FAATEMA-TAZ ZEHRAA-E SAYYE-DATE NESAA-IL AA’LAMEEN. AS-SALAAMO A’LAIKA YA SULAA-LATAL AKH-YAAR. AS-SALAAMO A’LAIKA YAA SHAEE-DAL HAQQE. AS-SALAAMO A’LAIKA YAA QATEE-LAL KUFFAAR. AS-SALAAMO A’LAIKA YAA A’W-NABNA A’BDIL-LAA-HIBNE JA’FA-RIT TAYYAAR.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَابْنَ فَاطِمَۃَ الزَّهْرَاۗئِ سَیِّدَۃِ نِسَاۗئِ الْعَالَمِیْنَ۔ اَلسَّلَامُ عَلَیْكَ یَا سُلَالَۃَ الْاَخْیَارِ۔ اَلسَّلَامُ عَلَیْكَ یَا شَهِیْدَ الْحَقِّ۔ اَلسَّلَامُ عَلَیْكَ یَا قَتِیْلَ الْكُفَّارِ۔ اَلسَّلَامُ عَلَیْكَ یَا عَـوْنَ بْنَ عَبْدِ اللهِ بْنِ جَعْفَرِ الطَّیَّارِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1010684, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay buland martaba waale. Salaam ho aap par ay farzand'e Zainab (s.a) jo taqi hai. Salaam ho aap par ay saeed. Salaam ho aap par ay hameed. Salaam ho aap par ay shaheed. Mere maa-baap aap par fida, aap bhi paakeeza aur woh zameen bhi paakeeza jis mein aap dafn huwe aur badi kaamyaabi haasil ki.", "Urdu": " سلام ہو آپ پر اے بلند مرتبہ والے، سلام ہو آپ پر اے فرزند زینب تقیہ کے، سلام ہو آپ پر اے سعید، سلام ہو آپ پر اے حمید، سلام ہو آپ پر اے شہید، میرے ماں باپ آپ پر فدا آپ بھی پاکیزہ اور وہ زمین بھی پاکیزہ جس میں آپ دفن ہوئے اور بڑی کامیابی حاصل کی۔", "RArabic": "AS-SALAAMO A’LAIKA YAA ZARRAA-YATIL AA’LE-YAH. AS-SALAAMO A’LAIKA YABNA ZAINA-BAT TAQIYYAH. AS-SALAAMO A’LAIKA YAA SAEE’D. AS-SALAAMO A’LAIKA YAA HAMEED. AS-SALAAMO A’LAIKA YAA SHAHEED. BE-ABEE ANTA WA UMMEE TIBTA WA TAABA-TIL ARZUL LATEE FEE-HAA DO-FEEN-TA WA FUZTA FAW-ZAN A’ZEEMAA.", "ArabicText1": "اَلسَّلَامُ عَلَیْكَ یَا ذَالرَّایَۃِ الْعَالِیَۃِ۔ اَلسَّلَامُ عَلَیْكَ یَاابْنَ زَیْنَبَ التَّقِیَّۃِ۔ اَلسَّلَامُ عَلَیْكَ یَا سَعِیْدُ۔ اَلسَّلَامُ عَلَیْكَ یَا حَمِیْدُ۔ اَلسَّلَامُ عَلَیْكَ یَا شَهِیْدُ۔ بِاَبِیْ اَنْتَ وَاُمِّیْ طِبْتَ وَطَابَتِ الْاَرْضُ الَّتِیْ فِیْهَا دُفِنْتَ وَفُزْتَ فَوْزًا عَظِیْمًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10"