فِیْظُ یَارَقِیْبُ یَاقَرِیْبُ۔ اَلْقَابضُ، الْبَاسِطُ، الْخَافِضُ، الرَّافِعُ، الْمُعِزُّ، الْمُذِلُّ، السَّمِیْعُ، الْبَصِیْرُ، الْحَکَمُ، الْعَدْلُ، یَاحَافِظُ یَاحَفِیْظُ یَارَقِیْبُ یَاقَرِیْبُ۔ اَللَّطِیْفُ، الْخَبِیْرُ، الْحَلِیْمُ، الْعَظِیْمُ، الْغَفُوْرُ، الشَّکُوْرُ، الْعَلِیُّ، الْکَبِیْرُ، الْحَفِیْظُ، الْمُقِیْتُ، یَاحَافِظُ یَاحَفِیْظُ یَارَقِیْبُ یَاقَرِیْبُ۔ ذُوْالْحَسِیْبُ، الْجَلِیْلُ، الْکَرِیْمُ، الرَّقِیْبُ، الْمُجِیْبُ، الْوَاسِعُ، الْحَکِیْمُ، الْوَدُوْدُ، الْمَجِیْدُ، الْبَاعِثُ، یَاحَافِظُ یَاحَفِیْظُ یَارَقِیْبُ یَاقَرِیْبُ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1021422, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": "ASH SHAEE-DUL HAQQUL WAKEE-LUL QAWIY-YUL MATEE-NUL WALIY-YUL HAMEE-DUL MUHSIL MUBDE-UL MO’EEDO, YAA HAAFE-ZO YAA HAFEE-ZO YAA RAQEE-BO YAA QAREE-BO. AL MOH-YIL MOMEE-TO ZUL HAYYUL QAYYOO-MUL WAAJE-DUL MAAJE-DUL WAAHE-DUS SAMA-DUL QAADE-RUL MUQTA-DERO, YAA HAAFE-ZO YAA HAFEE-ZO YAA RAQEE-BO YAA QAREE-BO. AL MUQADDE-MUL MOA-KHERUL AWWA-LUL AAKHE-RUZ ZAAHE-RUL BAATE-NUL WALIY-YUL MOTA’AALIY-YUL BIRRUT TAWWAA-BO, YAA HAAFE-ZO YAA HAFEE-ZO YAA RAQEE-BO YAA QAREE-BO. AL MUNTA-QE-MUL ‘AFOO-WUR RAOO-FUL MAALE-KUL MULKO ZUL JALAALE WAL IKRAA-MIL MUQSE-TUL JAAME’UL GHANIY-YUL MUGH-NEYO, YAA HAAFE-ZO YAA HAFEE-ZO YAA RAQEE-BO YAA QAREE-BO. AL MAANE’UZ ZARRUN NAAFE’UN NOORUL HAADE-YUL BADEE’UL BAAQE-YUL WAARE-SUR RASHEE-DUS SABOO-RO, YAA HAAFE-ZO YAA HAFEE-ZO YAA RAQEE-BO YAA QAREE-BO.", "ArabicText1": "اَلشَّھِیْدُ، الْحَقُّ، الْوَکِیْلُ، الْقَوِیُّ، الْمَتِیْنُ، الْوَلِیُّ، الْحَمِیْدُ، الْمُحْصِیْ، الْمُبْدِیُٔ، الْمُعِیْدُ، یَاحَافِظُ یَاحَفِیْظُ یَارَقِیْبُ یَاقَرِیْبُ۔ اَلْمُحْیِیْ، الْمُمِیْتُ، ذُوْالْحَیُّ، الْقَیُّوْمُ