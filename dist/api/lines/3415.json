[{"Id": 1014792, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": "One of the companions of the Holy Imams (a) is reported to have uncovered his private parts in a situation where it is improper to uncover one’s private parts; he was therefore affected by an ailment at that place. When he complained about this to Imam Sadiq (a), he was taught to do this supplicatory amulet: Put your left hand on the ailed part and repeat the following supplicatory prayer 3 times. If you do, you will be restored to health, Allah willing…", "GujaratiDescription": null, "RUrduDescription": "Riwaayat hai keh Aimma (a) keh ek sahaabi ke badan mein aisi jagah dard la-haq huwa keh jis ka zikr munaasib nahi hota, us ne Imam Jafar Sadiq (a) ki khidmat mein uski shikaayat ki to Aap (a) ne usey yeh taweez taleem farmaaya aur hidaayat ki keh apna baaya’n (left) haath us jagah par rakho aur is tarah se is ko 3 martaba padhe to insha-Allah aafiyat paayenge…", "UrduDescription": "روایت نقل ہوئی ہے : ائمہؑ کے ایک صحابی کے بدن میں ایسی جگہ درد لا حق ہوا کہ جس کا ذکر مناسب نہیں ہوتا اس نے امام جعفر صادق ؑ کی خدمت اقدس میں اس کی شکایت کی تو آپؑ نے اسے یہ تعویذ تعلیم فرمایا اور ہدایت کی کہ اپنا بایاں ہاتھ اس جگہ پر رکھ کر اس کو ۳ مرتبہ کہے انشاء اللہ عافیت پائے گا۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014793, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah (I begin) and in Allah (I trust). “Yes! Whoever submits himself entirely to Allah and he is the doer of good (to others), he has his reward from his Lord, and there is no fear for him nor shall he grieve.” O Allah, I have submitted myself to You and entrusted my affair to You. There is neither shelter nor refuge against You except with You.", "Gujarati": null, "RGujarati": null, "RUrdu": "Khuda ke naam aur Uski zaat se, haa’n jo shakhs Khuda ki taraf jhuk jaaye aur nekoo-kaar bhi ho to uska ajr uske Rab ke paas hai, aise logo’n ko na koi khouf hoga na ghamgeen honge. Ay Ma’bood! Mai apna sar Tere aage jhuka chuka hu apne maamle Tere supurd kiye huwe hu, Tere baghair koi jaa'e panah aur maqaam'e najaat nahi.", "Urdu": "خدا کے نام اور اس کی ذات سے ہاں جو شخص خدا کی طرف جھک جائے اور نیکو کار بھی ہو تو اس کا اجراس کے رب کے پاس ہے ایسے لوگوں کو نہ کوئی خوف ہوگا نہ غمگین ہوں گے اے معبود! میں اپنا سر تیرے آگے جھکا چکا ہوں اپنے معاملے تیرے سپرد کیے ہوئے ہوں تیرے بغیر کوئی جائےپناہ اور مقام ِنجات نہیں۔", "RArabic": "BISMILLAAHE WA BILLAAHE BALAA MAN ASLAMA WAJHA-HU LILLAAHE WA HOWA MOHSE-NUN FALA-HU AJRO-HU I’NDA RABBE-HI WA LAA KHAWFUN A’LAIY-HIM WA LAA HUM YAH-ZANOONA. ALLAAHUMMA INNEE AS-LAMTO WAJHEE ILAIKA WA FAWWAZ-TO AMREE ILAIKA LAA MALJAAA-A WA LAA MANJAA MINKA ILLAA ILAIKA.", "ArabicText1": "بِسْمِ اللهِ وَبِاللهِ بَلٰى مَنْ اَسْلَمَ وَجْهَهٗ لِلهِ وَهُوَ مُحْسِنٌ فَلَهٗ اَجْرُهٗ عِنْدَ رَبِّهٖ وَلَا خَوْفٌ عَلَيْهِمْ وَلَاهُمْ يَحْزَنُوْنَ۔ اَللّٰهُمَّ اِنِّىْ اَسْلَمْتُ وَجْهِىْ اِلَيْكَ وَفَوَّضْتُ اَمْرِىْ اِلَيْكَ لَا مَلْجَاۗءَ وَلَامَنْجَا مِنْكَ اِلَّا اِلَيْكَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "Ar