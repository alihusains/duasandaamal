[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002176, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O One who was there before everything. Then He created everything. Then He will be there forever, whereas everything else will be destroyed. O one except whom there is no deity either in the high heavens or in the deep earths or upon them or in them or between them. Numerous praises are for You, whose counting only You can do and none else.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Woh jo har cheez se pehle maujood tha, phir har ek cheez ko paiyda kiya. Tu woh hai jo baaqi rahega aur har cheez fanah ho jaayegi, ay Woh jiski maanind koi cheez nahi. Ay Woh jo na buland aasmaano mein hai aur na pastt (neechli) zameeno mein hai aur na unke upar aur na unke neeche hai aur na darmiyaan mein hai. Woh Ma’bood jiske siwa koi ma’bood nahi Tere liye hamd o sana hai, woh hamd keh koi usey shumaar (count) na kar sake’n siwaaye Tere.", "Urdu": "اے وہ جو ہر چیز سے پہلے موجود تھا، پھر ہر ایک چیز کو پیدا کیا، تو وہ ہے جو باقی رہے گا اور ہر چیز فنا ہو جائے گی، اے وہ جس کی مانند کوئی چیز نہیں۔ اے وہ جو نہ بلند آسمانوں میں ہے اور نہ پست زمینوں میں ہے اور نہ ان کے اپر اور نہ ان کے نیچے ہے اور نہ درمیان میں ہے۔ وہ معبود جس کے سوا کوئی معبود نہیں تیرے لئے حمد و سنا ہے، وہ حمد کہ کوئی اسے شمار نہ کر سکے سوائے تیرے۔", "RArabic": "YAA ZALLA-ZEE KAANA QABLA KULLE SHAIY-IN SUMMA KHALA-QA KULLA SHAIY-IN SUMMA YAB-QAA WA YAF-NAA KULLO SHAIY-IN YAA ZAL-LAZEE LAIY-SA FIS SAMAA-WAATIL O’LAA WA LAA FIL ARZEE-NAS SUFLAA WA LAA FAWQE-HUNNA WA LAA BAIYNA-HUNNA WA LAA TAHTA-HUNNA ELAA-HUN YO’BADO GHAIY-RO-HU LA-KAL HAMDO HAMDAN LAA YAQ-DERO A’LAA EHSAA-E-HIL LAA ANTA.", "ArabicText1": "یَاذَالَّذِیْ کَانَ قَبْلَ کُلِّ شَیْٓءٍ ثُمَّ خَلَقَ کُلَّ شَیْٓءٍ ثُمَّ یَبْقٰی وَیَفْنٰی کُلُّ شَیْٓءٍ یَاذَالَّذِیْ لَیْسَ فِی السَّمٰوٰتِ الْعُلٰی وَلَا فِی الْاَرْضِیْنَ السُّفْلٰی وَلَا فَوْقِھُنَّ وَلَا بَیْنَھُنَّ وَلَاتَحْتَھُنَّ اِلٰہٌ یُّعْبَدُ غَیْرُہٗ لَکَ الْحَمْدُ حَمْدًا لَایَقْدِرُ عَلٰی اِحْصَآئِہِ الَّااَنْتَ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "A