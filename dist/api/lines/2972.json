[{"Id": 1012979, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "While standing in the area between the Holy Prophet (s)’s tomb and minbar, you may visit the tomb of Fatema Zahra (s). There is disagreement about the place of the tomb of Fatema (s); some say that she was buried in the Rauza. Others say that she was buried at her house. Others say that she was buried in the Baqi Cemetery. However, the majority of our scholars agree that she must be visited from the Rauza, although to visit her at all these 3 places is more preferable. When you stand for the ziyarat of Fatema Zahra (s), you may say…", "GujaratiDescription": null, "RUrduDescription": "Jab aap Rasool-e-Khuda (s) ki qabr aur mimbar ke darmiyan ho to Qabr’e Fatema Zahra (s) ki ziyarat karo. Is mein ikhtelaaf hai keh woh kahan dafn hai. Kuchh ka kehna hai keh woh isi jagah par dafn hai. Baaz ka kehna hai keh woh apne ghar mein dafn hai aur baaz kehte hai keh woh Jannatul Baqi mein dafn hai. Khair aksariyat ulma’o ka kehna hai keh Janabe Zahra (s) ki ziyarat Rasool-e-Khuda (s) ke rauze mein padhi jaaye, behtar hai keh teeno (3) jagah par unki ziyarat padhe. Jab ziyarat padhna chaho to is tarah se kaho…", "UrduDescription": "بعض لوگ کہتے ہیں: آپ(س) کی قبرِ مبارک روضۂ رسولؐ اور آپ کے منبر کے درمیان ہے، بعض کا کہنا ہے : بی بی(س) کی قبرِ مبارک ان کے گھر میں ہی ہے، ایک تیسرے گروہ نے کہا ہے: آپ کی قبرِ مبارک جنت البقیع میں ہے اور ہمارے اکثر علماء فرماتے ہیں : آپ کی قبر روضۂ رسول ؐکے قریب ہے۔ وہاں زیارت پڑھی جائے البتہ آپ کی زیارت ان تینوں جگہ پر پڑھنا بہتر ہے۔ جب آپ کی زیارت کرے تو یہ پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012980, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O carefully examined (lady): Allah Who created you had tried you before He created you (for this worldly life), and thus He found you successfully enduring in that trial. We claim being loyalists to you, believers in you, and tolerant as regards all that which has been conveyed to us by your father, peace of Allah be upon him and his Household, and all that which his Successor has brought to us. We, thus, ask you, if we have really believed you, that you may include us with those who believe in both of them (i.e. the Holy Prophet and Imam Ali), so that we may feel happy that we have been purified on account of our loyalty to you.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay azmaayi huwi bibi, Allah ne aap ka imtehaan le liya aap ki khilqat se qabl (pehle), to aap ko imtehaan mein saaberah paaya, aur ham yeh khayaal karte hai keh aap ke dost hai aur tasdeeq karne waale aur sabr o ita’at karne waale hai har us amr par jo hamare paas aap ke Pidar’e buzurg waar (s.a.w.a) laaye aur unke wasila hai, to ham aap se darkhwaast karte hai keh agar ham ne aap ki tasdeeq ki hai to ham ko mulhaq kar (mila) lijiye hamari un dono tasdeeq ki wajah se ta keh ham apne nafs ko bashaarat de keh ham aap ki dosti ki wajah se paak ho gaye.", "Urdu": "سلام ہو آپ پر اے آزمائی ہوئی بی بی، اللہ نے آپ کا امتحان لے لیا، آپ کی خلقت سے قبل، تو آپ کو امتحان میں صابرہ پایا، اور ہم یہ خیال کرتے ہیں کہ آپ کے دوست ہیں اور تصدیق کرنے والے اور صبر و اطاعت کرنے والے ہیں ہر اس امر پر جو ہمارے پاس آپ کے پدر بزرگوارؐ لائے، اور ان کے وصی لائے، تو ہم آپ سے درخوست کرتے ہیں کہ اگر ہم نے آپ کی تصدیق کی ہے تو ہم کو ملحق کر لیجئے ہماری ان دونوں تصدیق کی وجہ سے تا کہ ہم اپنے نفس کو بشارت دیں کہ ہم آپ کی دوستی کی وجہ سے پاک ہو گئے۔", "RArabic": "ASSALAAMO A’LAYKE YAA MUMTAHANATO QADIM TAHANAKIL LAZEE KHALAQAKE QABLA AYN YAKHLOQAKE FA-WAJADEKE LEMAM TAHANAKE SAABERATAN WA NAHNO LA-KE AWLEYAAA-O SAABEROONA WA MOSADDEQOONA LE-KULLE MAA ATAANAA BEHI ABOOKE SALLAL LAAHO A’LAYHE WA AALEHI WA ATAANAA BEHI WASIYYOHU FA-INNAA NAS-ALOKE AN KUNNAA SADDAQNAAKE ILLAA ALHAQTENAA BE-TASDEEQENAA LAHUMAA LE-NOBASH-SHERA ANFOSANAA ANNAA QAD TAHURNAA BE-WELAAYATEKE.", "ArabicText1": "اَلسَّلَامُ عَلَیْكِ یَا مُمْتَحَنَۃُ قَدِ امْتَحَنَكِ الَّذِیْ خَلَقَكِ قَبْلَ اَنْ یَّخْلُقَكِ فَوَجَدَكِ لِمَا امْتَحَنَكِ صَابِرَۃً وَنَحْنُ لَكِ اَوْلِیَآئُ صَابِرُوْنَ وَمُصَدِّقُوْنَ لِكُلِّ مَا اَتٰینَا بِہٖ اَبُوْكِ صَلَّی اللہُ عَلَیْہِ وَاٰلِہٖ وَاَتٰینَا بِہٖ وَصِیُّہٗ فَاِنَّا نَسْئَلُكِ اِنْ كُنَّا صَدَّقْنَاكِ اِلَّا اَلْحَقْتِنَا بِتَصْدِیْقِنَا لَہُمَا لِنُبَشِّرَ اَنْفُسَنَا اَنَّا قَدْ طَہُرْنَا بِوَلَایَتِكِ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1012981, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "It is recommended to add the following…", "GujaratiDescription": null, "RUrduDescription": "Mustahab hai keh in jumlo’n ko bhi adaa kare…", "UrduDescription": "پھر کہے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 1, "IsPrintable": 0}, {"Id": 1012982, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "Peace be upon you, O daughter of the Messenger of Allah. Peace be upon you, O daughter of the Prophet of Allah. Peace be upon you, O daughter of the most beloved of Allah. Peace be upon you, O daughter of the Trustee of Allah. Peace be upon you, O daughter of the best of Allah’s creatures. I ask Allah, His Messengers, and His angels to be the witnesses that I am verily pleased with him whomever you accept, I am displeased with him whomever you detest, I disavow him whomever you disavow, I am loyal to him whomever you support, I am the enemy of him whomever you betake as enemy, I am hateful to him whomever you hate, and I like him whomever you like. Verily, Allah is Sufficient as Witness, Reckoner, Punisher, and Rewarder.", "Gujarati": null, "RGujarati": null, "RUrdu": "Salaam ho aap par ay Rasoolullah (s.a.w.a) ki dukhtar. Salaam ho aap par ay Nabiye Khuda (s.a.w.a) ki dukhtar. Salaam ho aap par ay Khaleel’e Khuda ki dukhtar. Salaam ho aap par ay Khuda ke ameen ki dukhtar. Salaam ho aap par ay makhlooqaat mein sab se behtar insaan ki dukhtar. Mai Khuda ko, Uske Rasool (s.a.w.a) ko aur Malaayeka ko gawah bana ke kehta hu keh mai raazi hu us shakhs se jis se aap raazi hai aur mai har us shakhs se naaraaz hu jis se aap naaraaz hai, jis se aap be-zaar hai, mai us se be-zaar hu. Mai dost hu uska jiski aap dost ho, mai dushman hu uska jo aap ka dushman hai. Mai us se bughz rakhta hu jis ne aap se bughz rakkha. Jo aap se mohabbat rakkhe mai us se mohabbat rakhta hu aur Khuda gawahi ke liye kaafi hai hisaab karne, badla aur sawaab dene ke liye kaafi hai.", "Urdu": "سلام ہو آپ پر اے رسولؐ کی دختر، سلام ہو آپ پر اے نبی خداؐ کی دختر، سلام ہو آپ پر اے خلیلِ خدا کی دختر، سلام ہو آپ پر اے خدا کے امین کی دختر، سلام ہو آپ پر اے مخلوقات میں سب سے بہتر انسان کی دختر، میں خدا کو، اس کے رسولؐ کو اور ملائکہ کو گواہ بنا کے کہتا ہوں کہ میں راضی ہوں اس شخص سے جس سے آپ راضی ہیں اور میں ہر اس شخص سے ناراض ہوں جس سے آپ ناراض ہیں، جس سے آپ بیزار ہیں، میں اس سے بیزار ہوں، میں دوست ہوں اس کا جس کی آپ دوست ہوں، میں دشمن ہوں اس کا جو آپ کا دشمن ہے، میں اس سے بغض رکھتا ہوں جس نے آپ سے بغض رکھا، جو آپ سے محبت رکھے میں اس سے محبت رکھتا ہوں اور خدا گواہی کے لئے کافی ہے حساب کرنے، بدلہ اور ثواب دینے کے لئے کافی ہے۔", "RArabic": "ASSALAAMO A’LAYKE YAA BINTA RASOOLIL LAAHE ASSALAAMO A’LAYKE YAA BINTA NABIYYIL LAAHE ASSALAAMO A’LAYKE YAA BINTA KHALEELIL LAAHE ASSALAAMO A’LAYKE YAA BINTA KHAYRE KHALQIL LAAHE USH-HEDUL LAAHA WA RASOOLAHU WA MALAAA-EKATAHU ANNEE RAAZIN A’MMAN RAZEETA A’NHO SAAKHETUN A’LAA MAN SHA-KHIT-TE A’LAYHE MOTABRRE-UN MIMMAN TABARRAATE MINHO MOWAALIN LEMAN WAALAYTE MO-A’ADIN LEMAN A’-ADAYTE MUBGHEZUN LEMAN ABGHAZTE MOHIBBUN LEMAN AHBABTE WA KAFAA BILLAAHE SHAHEEDAN WA HASEEBAN WA JAAZEYAN WA MOSEEBAN.", "ArabicText1": "اَلسَّلَامُ عَلَیْكِ یَا بِنْتَ رَسُوْلِ اللہِ۔ اَلسَّلَامُ عَلَیْكِ یَا بِنْتَ نَبِیِّ اللہِ۔ اَلسَّلَامُ عَلَیْكِ یَا بِنْتَ خَلِیْلِ اللہِ۔ اَلسَّلَامُ عَلِیْكِ یَا بِنْتَ اَمِیْنِ اللہِ۔ اَلسَّلَامُ عَلَیْكِ یَا بِنْتَ خَیْرِ خَلْقِ اللہِ۔ اُشْہِدُ اللہَ وَرَسُوْلَہٗ وَمَلَآئِكَتَہٗ اَنِّیْ رَاضٍ عَمَّنْ رَضِیْتِ عَنْہُ سَاخِطٌ عَلٰی مَنْ سَخِطْتِ عَلَیْہِ مُتَبَرِّئٌ مِمَّنْ تَبَرَّاْتِ مِنْہُ مُوَالٍ لِمَنْ وَالَیْتِ مُعَادٍ لِمَنْ عَادَیْتِ مُبْغِضٌ لِمَنْ اَبْغَضْتِ مُحِبٌّ لِمَنْ اَحْبَبْتِ وَكَفٰی بِاللہِ شَہِیْدًا وَحَسِیْبًا وَجَازِیًا وَمُثِیْبًا۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "