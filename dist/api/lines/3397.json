[{"Id": 1013936, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 1, "EnglishDescription": "Al-Shahid, has reported that whoever is tensely ailed may recite <Surah Fateha> 40 times on a glass of water. He may then pour the water on his body. He may have a measure of wheat near him and hand over each beggar a measure and ask him to pray Almighty Allah to cure him. If he does so, he will be restored to health, Allah willing. “Medicate your patients with alms.” This saying is reported through considerable chains of authority.", "GujaratiDescription": null, "RUrduDescription": "Shaikh Shaheed ne naql farmaaya hai keh, jise koi shadeed dard la-haq ho jaaye to woh ek bartan kuchh gandoom daal kar apne paas rakhe aur paani ka ek jaam (jug) par 40 martabah <Surah Fateha> padhe, phir woh paani apne upar chhidak le baad mein apne paas rakhi huwi gandoom kisi saael ko de aur usey kahe keh woh uske liye bimaari se shafa-yaabi ki dua kare, insha-Allah shafa haasil ho jaayegi aur motabar asnaad ke saath yeh baat ham tak pohonchi hai keh apni bimaaro’n ka ilaaj sadqe se karo.", "UrduDescription": "شیخ شہید ؒ نے نقل فرمایا ہے : جسے کوئی شدید درد لاحق ہو جائے تو وہ ایک برتن میں کچھ گندم ڈال کر اپنے پاس رکھے اور پانی کے ایک جام پر ۴۰ مرتبہ <سورۂ فاتحہ> پڑھے پھر وہ پانی اپنے اوپر چھڑک لے بعد میں اپنے پاس رکھے ہوئے گندم کسی سائل کو دے اور اسے کہے کہ وہ اس کے لئے بیماری سے شفا یابی کی دعا کرے انشاء اللہ شفا حاصل ہوجائے گی۔ اور معتبر اسناد کے ساتھ یہ بات ہم تک پہنچی ہے کہ اپنے بیماروں کا علاج صدقہ سے کرو۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014246, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "With reference to removal of diseases, Shahid has also reported that the right arm of a patient may be held while reciting <Surah Fateha> 7 times. After that, the following supplicatory prayer may be said…", "GujaratiDescription": null, "RUrduDescription": "Neez Shaikh Shaheed ne dafa-e-marz ke liye yeh bhi naql kiya hai keh insaan apna haath bimaar ke daayne baazu (right shoulder) par rakhe aur 7 martaba <Surah Fateha> ki tilaawat kare aur phir yeh dua padhe…", "UrduDescription": "مزید شیخ شہید ؒ نے دفعِ مرض کے لئے یہ بھی نقل کیا ہے : انسان اپنا ہاتھ بیمار کے دائیں بازو پر رکھے اور ۷ مرتبہ <سورۂ فاتحہ> کی تلاوت کرکےیہ د عا پڑھے۔۔۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014292, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please) remove ailments and maladies from him, restore him to health and cure, supply him with excellent protection, return him to excellent wellbeing, and cause what has afflicted him in this ailment of him to be material of his life and remission of his evildoings. O Allah, (please) bless Muhammad and the Household of Muhammad.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Is se bimaari aur asbaab dur kar de, usey sehat aur shafa ki taraf lauta de, behtareen hifaazat se uski madad kar aur usey achchhi haalat ki taraf palta de, is bimaari mein usey jo takleef pohonchi hai usko uski zindagi ka sabab aur uske gunaho’n ka kaffaara bana de. Ay Ma’bood! Rehmat naazil farma Muhammad (s.a.w.a) aur Aale Muhammad (a.s) par.", "Urdu": "اے معبود! اس سے بیماری اور اسباب دور کر دے اسے صحت اور شفا کی طرف لوٹا دے بہترین حفاظت سے اس کی مدد کر اور اسے اچھی حالت کی طرف پلٹا دے اس بیماری میں اسے جو تکلیف پہنچی ہے اس کو اس کی زندگی کا سبب اور اس کے گناہوں کا کفارہ بنا دے اے معبود! رحمت نازل فرما محمدؐ اور آل محمؑدپر۔", "RArabic": "ALLAAHUMMA AZIL A’N-HUL E’LALA WAD-DAAA-A WA A-I’D-HO ILAS SAHHA-TE WASH SHEFAAA-E WA AMIDDA-HO BE-HUSNIL WEQAA-YATE WA RUDDA-HO ILAA HUSNIL AA’FEYATE WAJ-A’L MAA NAALA-HO FEE MARAZE-HE HAAZAA MADDA-TAN LE-HAIWATE-HE WA KAFFAA-RATAN LESAYYE-AATEHE. ALLAAHUMMA WA SALLE A’LAA MOHAMMADIW WA AALE MOHAMMADIN.", "ArabicText1": "اَللّٰهُمَّ اَزِلْ عَنْهُ الْعِلَلَ وَالدَّاۗءَ وَاَعِدْهُ اِلَى الصِّحَّةِ وَالشِّفآءِ وَاَمِدَّهُ بِحُسْنِ الْوِقايَةِ وَرُدَّهُ اِلٰى حُسْنِ الْعَافِيَةِ وَاجْعَلْ مَا نَالَهُ فِىْ مَرَضِهِ هٰذَا مَادَّةً لِحَيْوَتِهِ وَكَفَّارَةً لِسَيِّئَاتِهِ اَللّٰهُمَّ وَصَلِّ عَلٰى مُحَمَّدٍ وَّآلِ مُحَمَّدٍ۔", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014293, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 3, "EnglishDescription": "If this does not work, <Surah Fateha> may be repeated 70 times, and it will be effective, Allah willing.", "GujaratiDescription": null, "RUrduDescription": "Agar yeh dua uski tandurast hone ke silsile mein koi asar na dikhaaye to dobaara yahi amal kare, lekin is dafa <Surah Fateha> 70 martaba padhe insha-Allah dua asar karegi.", "UrduDescription": "اگر یہ دعا اس کے شفایاب ہونے کے سلسلے میں کوئی اثر نہ دکھائے تو دوبارہ یہی عمل کرے لیکن اس دفعہ <سورۂ فاتحہ> ۷۰ مرتبہ پڑھے انشا ء اللہ دعا اثر کرے گی۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1014294, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 4, "EnglishDescription": "Imam Baqir (a) is reported to have said, “Whoever is not healed by <Surah Fateha> and <Surah Ikhlaas>, nothing else will heal him. Verily, these two Surahs cure of all ailments.”", "GujaratiDescription": null, "RUrduDescription": "Imam Muhammad Baqir (a) se riwaayat hai keh jis ko <Surah Fateha> aur <Surah Ikhlaas> sehat-yaab na kare to phir koi cheez usko sehat-yaab nahi kar sakti jab keh yeh do (2) surah har marz o bimaari ko dur karti hai.", "UrduDescription": "امام محمد باقر ؑ سے روایت ہے : جس کو <سورۂ فاتحہ> اور <سورۂ اخلاص> شفایاب نہ کریں تو پھر کوئی چیز اس کو شفایاب نہیں کر سکتی جب کہ یہ دو سورتیں ہر مرض وبیماری کو دور کرتی ہیں۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGre