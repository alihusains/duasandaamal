[{"Id": 1, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "In the Name of Allah, the most Gracious, the most Merciful.", "Gujarati": null, "RGujarati": null, "RUrdu": "(Shuru karta hu) Allah ke naam se Jo bada maher-baan nehaayat rahem karne waala hai.", "Urdu": "اللہ کے نام سے (شروع کرتا ہوں) جو بڑا مہربا ن نہایت رحم کرنے والا ہے۔", "RArabic": "BISMILLAAHIR RAHMAANIR RAHEEM", "ArabicText1": "بِسْمِ اللہِ الرَّحْمٰنِ الرَّحِیْمِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1002435, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": null, "EnglishDescription": null, "GujaratiDescription": null, "RUrduDescription": null, "UrduDescription": null, "English": "O Allah, (please) send blessings upon Muhammad the son of Ali the son of Musa, the epitome of piety, the illumination of true guidance, the essence of faithfulness, the branch of the bright ones, the vicegerent of the Successors, and Your trustee on Your revelations. O Allah, as You have guided through him against straying off, saved against confusion, directed those who were rightly guided, and purified those who were purified, so also (please) bless him with the most favorite blessings that You have ever conferred upon any of Your intimate servants and agents of Your Successors. Verily, You are Almighty, All-wise.", "Gujarati": null, "RGujarati": null, "RUrdu": "Ay Ma’bood! Muhammad bin Ali bin Moosa (a.s) par durood bhej jo parhez-gaari ke nishaan, hidaayat ke noor, wafa ke markaz o mahewar, paak-baazo’n ki shaakh aur ausiya’e paighambar ke ja-nasheen aur Teri wahi ke amaanat-daar hai. Pas ay Ma’bood! Jaise Tu ne unke zariye gumrahi se nikaal kar hidaayat di, unke wasile se pareshaani o sar-gardaani (mushkilo’n) se bachaaya, unke zariye raah dikhaayi usey jis ne hidaayat chahi aur unke zariye paak kiya Tu ne jaise paak karne ka haq hai, aise hi un par rehmat kar, behtareen rehmat jo Tu ne kisi par ki hai apne auliya mein se aur ausiya mein se maujood wasi par, be-shak Tu zabardast hikmat waala hai.", "Urdu": "اے معبود! محمدؑ ابن علیؑ ابن موسیٰؑ پر درود بھیج جو پرہیز گاری کے نشان، ہدایت کے نور،وفا کے مرکز و محور پاک بازوں کی شاخ اور اوصیاء پیغمبرؐ کے جانشین اور تیری وحی کے امانت دار ہیں پس اے معبود! جیسے تو نے ان کے ذریعے گمراہی سے نکال کر ہدایت دی ان کے وسیلے سے پریشانی و سرگردانی سے بچایا ان کے ذریعے راہ دکھائی اسے جس نے ہدایت چاہی اور ان کے ذریعے پاک کیا اسے جو پاک ہوا ایسے ہی ان پر رحمت کر بہترین رحمت جو تو نے کسی پر کی ہے اپنے اولیاء میں سے اور اوصیاء میں سے موجود وصی پر بے شک تو زبردست حکمت والاہے۔", "RArabic": "ALLAAHUMMA SALLE A’LAA MOHAMMADIB-NE A’LIYYIB-NE MOOSAA A’LA-MIT TOQAA WA NOO-RIL HODAA WA MA’DE-NIL WAFAA-E WA FAR-I’L AZ-KEYAA-E WA KHALEEFA-TIL AWSE-YAA-E WA AMEENE-KA A’LAA WAHYE-KA. ALLAAHUMMA FA-KAMAA HADAIY-TA BEHI MINAZ ZA-LAALA-TE WAS TAN-QAZTA BEHI MINAL HAIYRA-TE WA AR-SHAD-TA BEHI ME-NEH TA-DAA WA ZAKKAIY-TA BEHI MAN TA-ZAKKAA FA-SALLE A’LAIHE AF-ZALA MAA SAL-LAIY-TA A’LAA AHA-DIN MIN AWLEYAA-E-KA WA BAQIYYA-TE AWSE-YAA-E-KA INNA-KA A’ZEE-ZOON HAKEE-MOON.", "ArabicText1": "اَللّٰهُمَّ صَلِّ عَلٰى مُحَمَّدِ بْنِ عَلِيِّ بْنِ مُوْسٰى عَلَمِ التُّقٰی وَنُوْرِ الْهُدٰى وَمَعْدِ", "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": " نِ", "ArabicText2": "الْوَفَاءِ وَفَرْعِ الْاَزْكِيَاءِ وَخَلِيْفَةِ الْاَوْصِيَاءِ وَاَمِيْنِكَ عَلٰى وَحْيِكَ۔ اَللّٰهُمَّ فَكَمَا هَدَيْتَ بِهٖ مِنَ الضَّلَالَةِ وَاسْتَنْقَذْتَ بِهٖ مِنَ الْحَيْرَةِ وَاَرْشَدْتَ بِهٖ مِنِ اهْتَدٰى وَزَكَّيْتَ بِهٖ مَنْ تَزَكّٰی فَصَلِّ عَلَيْهِ اَفْضَلَ مَا صَلَّيْتَ عَلٰى اَحَدٍ مِّنْ اَوْلِيَائِكَ وَبَقِيَّةِ اَوْصِيَائِكَ اِنَّكَ عَزِيْزٌ حَكِيْمٌ۔", "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "Arabic