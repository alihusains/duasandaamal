bicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016032, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 2, "EnglishDescription": "If a person is performing his 2nd Hajj due to having doubt regarding the previous (1st) Hajj was performed correctly or something went wrong then his intention (niyyat) for the current Hajj should be of HAJJ-E-EHTIYAAT (ie. if my previous Hajj was wrong then this is my Waajib Hajj and if it was correct then this is my Mustahab Hajj).", "GujaratiDescription": null, "RUrduDescription": "Agar koi shakhs ka yeh 2nd Hajj hai is shak (doubt) ki bina par keh us ne 1st Hajj ko sahih tarike se anjaam diya tha ya nahi to usey chahiye keh woh HAJJ-E-EHTIYAAT ki niyyat se isey anjaam de (yaani agar mera 1st Hajj sahih nahi tha to yeh mera Waajib Hajj hai aur agar sahih tha to yeh mera Mustahab Hajj hai).", "UrduDescription": "اگر کوئی شخص اپنا دوسرا  حج کر رہا ہے اور اسے شک ہے کہ اس کا پہلا حج صحیح طریقے سے انجام دیا تھا یا نہیں، تو اسے چاہیے کہ وہ حج احتیات کی نیت سے انجام دے (یعنی اگر میرا پہلا حج صحیح نہیں تھا تو یہ میرا واجب حج ہے اور اگر صحیح تھا تو یہ میرا مستحب حج ہے)۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicText4": null, "ArabicGreenSign4": null, "ArabicRedSign4": null, "ArabicBlueSign4": null, "ArabicText5": null, "ArabicGreenSign5": null, "ArabicRedSign5": null, "ArabicBlueSign5": null, "ArabicText6": null, "ArabicGreenSign6": null, "ArabicRedSign6": null, "ArabicBlueSign6": null, "ArabicText7": null, "ArabicGreenSign7": null, "ArabicRedSign7": null, "ArabicBlueSign7": null, "ArabicText8": null, "ArabicGreenSign8": null, "ArabicRedSign8": null, "ArabicBlueSign8": null, "ArabicText9": null, "ArabicGreenSign9": null, "ArabicRedSign9": null, "ArabicBlueSign9": null, "ArabicText10": null, "ArabicGreenSign10": null, "ArabicRedSign10": null, "ArabicBlueSign10": null, "ArabicText11": null, "ArabicGreenSign11": null, "ArabicRedSign11": null, "ArabicBlueSign11": null, "ArabicText12": null, "ArabicGreenSign12": null, "ArabicRedSign12": null, "ArabicBlueSign12": null, "ArabicText13": null, "ArabicGreenSign13": null, "ArabicRedSign13": null, "ArabicBlueSign13": null, "ArabicText14": null, "ArabicGreenSign14": null, "ArabicRedSign14": null, "ArabicBlueSign14": null, "ArabicText15": null, "ArabicGreenSign15": null, "ArabicRedSign15": null, "ArabicBlueSign15": null, "ArabicText16": null, "ArabicGreenSign16": null, "ArabicRedSign16": null, "ArabicBlueSign16": null, "ArabicText17": null, "ArabicGreenSign17": null, "ArabicRedSign17": null, "ArabicBlueSign17": null, "ArabicText18": null, "ArabicGreenSign18": null, "ArabicRedSign18": null, "ArabicBlueSign18": null, "ArabicText19": null, "ArabicGreenSign19": null, "ArabicRedSign19": null, "ArabicBlueSign19": null, "ArabicText20": null, "ArabicGreenSign20": null, "ArabicRedSign20": null, "ArabicBlueSign20": null, "EnglishImage": null, "GujaratiImage": null, "RUrduImage": null, "UrduImage": null, "IsRed": 0, "MinimizeDescriptionLine": 0, "IsPrintable": 0}, {"Id": 1016033, "EnglishTitle": null, "GujaratiTitle": null, "RUrduTitle": null, "UrduTitle": null, "Sequence": 3, "EnglishDescription": "If a person has the sufficient amount to go for Hajj but he is not sure whether Hajj has become obligatory on him or not, in this situation he should perform his Hajj with the intention (niyyat) of MAA FEE ZIMMAH (ie. if Hajj has become obligatory then this will be the Waajib Hajj and if not then it will be Mustahab Hajj).", "GujaratiDescription": null, "RUrduDescription": "Agar kisi shakhs ke paas Hajj pe jaane ki rakam hai magar usey yeh pata nahi keh Hajj us par waajib bhi hai ya nahi to usey chahiye ke woh MAA FEE ZIMMAH ki niyyat se isey anjaam de (yaani agar us par waajib hai to yeh uska Waajib Hajj hoga aur agar waajib nahi hai to yeh Mustahab Hajj hoga).", "UrduDescription": "اگر کوئی شخص کے پاس حج پے جانے کی رقم ہے مگر اسے یہ نہیں پتا کہ حج اس پر واجب بھی ہو ہے یہ نہیں، تو اسے چاہے کہ وہ ما فی ذماہ کی نیت سے انجام دے (یعنی اگر اس پر واجب ہو گیا ہے تو یہ اس کا واجب حج ہو گا اور اگر واجب نہیں ہوا تو یہ اس کا مستحب حج ہے)۔", "English": null, "Gujarati": null, "RGujarati": null, "RUrdu": null, "Urdu": null, "RArabic": null, "ArabicText1": null, "ArabicGreenSign1": null, "ArabicRedSign1": null, "ArabicBlueSign1": null, "ArabicText2": null, "ArabicGreenSign2": null, "ArabicRedSign2": null, "ArabicBlueSign2": null, "ArabicText3": null, "ArabicGreenSign3": null, "ArabicRedSign3": null, "ArabicBlueSign3": null, "ArabicTe